{
  "chapter": {
    "id": "peshitta:colossians.4",
    "translationId": "peshitta",
    "bookSlug": "colossians",
    "chapterNumber": 4,
    "referenceLabel": "Colossians 4",
    "summary": "Source text for Colossians 4 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:colossians.4.1",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Colossians 4:1",
      "text": "ܡܪܝܐ ܥܒܕܘ ܫܘܝܘܬܐ ܘܟܐܢܘܬܐ ܠܘܬ ܥܒܕܝܟܘܢ ܘܗܘܝܬܘܢ ܝܕܥܝܢ ܕܐܦ ܠܟܘܢ ܐܝܬ ܗܘ ܡܪܐ ܒܫܡܝܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:colossians.4.2",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Colossians 4:2",
      "text": "ܒܨܠܘܬܐ ܐܬܐܡܢܘ ܘܗܘܝܬܘܢ ܥܝܪܝܢ ܐܢܬܘܢ ܒܗ ܘܡܘܕܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.4.3",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Colossians 4:3",
      "text": "ܘܡܨܠܝܢ ܐܦ ܥܠܝܢ ܕܐܠܗܐ ܢܦܬܚ ܠܢ ܬܪܥܐ ܕܡܠܬܐ ܠܡܡܠܠܘ ܐܪܙܐ ܕܡܫܝܚܐ ܕܡܛܠܬܗ ܐܤܝܪ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.4.4",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Colossians 4:4",
      "text": "ܕܐܓܠܝܘܗܝ ܘܐܡܠܠܝܘܗܝ ܐܝܟܢܐ ܕܘܠܐ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.4.5",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Colossians 4:5",
      "text": "ܒܚܟܡܬܐ ܗܠܟܘ ܠܘܬ ܒܪܝܐ ܘܙܒܢܘ ܩܐܪܤܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.4.6",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Colossians 4:6",
      "text": "ܘܡܠܬܟܘܢ ܒܟܠܙܒܢ ܒܛܝܒܘܬܐ ܐܝܟ ܕܒܡܠܚܐ ܬܗܘܐ ܡܡܕܟܐ ܘܗܘܝܬܘܢ ܝܕܥܝܢ ܠܐܢܫ ܐܢܫ ܐܝܟܢܐ ܘܠܐ ܠܟܘܢ ܠܡܬܒܘ ܦܬܓܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.4.7",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Colossians 4:7",
      "text": "ܡܕܡ ܕܠܘܬܝ ܕܝܢ ܢܘܕܥܟܘܢ ܛܘܟܝܩܘܤ ܐܚܐ ܚܒܝܒܐ ܘܡܫܡܫܢܐ ܡܗܝܡܢܐ ܘܟܢܬܢ ܒܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.4.8",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Colossians 4:8",
      "text": "ܗܢܐ ܕܫܕܪܬ ܠܘܬܟܘܢ ܥܠܝܗ ܥܠ ܗܕܐ ܕܢܕܥ ܡܐ ܕܠܘܬܟܘܢ ܘܢܒܝܐ ܠܒܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.4.9",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Colossians 4:9",
      "text": "ܥܡ ܐܢܤܝܡܘܤ ܐܚܐ ܡܗܝܡܢܐ ܘܚܒܝܒܐ ܗܘ ܕܐܝܬܘܗܝ ܡܢܟܘܢ ܗܢܘܢ ܢܘܕܥܘܢܟܘܢ ܡܕܡ ܕܠܘܬܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.4.10",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Colossians 4:10",
      "text": "ܫܐܠ ܒܫܠܡܟܘܢ ܐܪܤܛܪܟܘܤ ܫܒܝܐ ܕܥܡܝ ܘܡܪܩܘܤ ܒܪ ܕܕܗ ܕܒܪܢܒܐ ܗܘ ܕܐܬܦܩܕܬܘܢ ܥܠܘܗܝ ܕܐܢ ܐܬܐ ܠܘܬܟܘܢ ܬܩܒܠܘܢܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.4.11",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Colossians 4:11",
      "text": "ܘܝܫܘܥ ܗܘ ܕܡܬܩܪܐ ܝܘܤܛܘܤ ܗܠܝܢ ܕܐܝܬܝܗܘܢ ܡܢ ܓܙܘܪܬܐ ܘܗܢܘܢ ܒܠܚܘܕ ܥܕܪܘܢܝ ܒܡܠܟܘܬܗ ܕܐܠܗܐ ܘܗܢܘܢ ܗܘܘ ܠܝ ܒܘܝܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.4.12",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Colossians 4:12",
      "text": "ܫܐܠ ܒܫܠܡܟܘܢ ܐܦܦܪܐ ܗܘ ܕܡܢܟܘܢ ܥܒܕܐ ܕܡܫܝܚܐ ܟܕ ܒܟܠܙܒܢ ܥܡܠ ܚܠܦܝܟܘܢ ܒܨܠܘܬܐ ܕܬܩܘܡܘܢ ܓܡܝܪܐ ܘܡܫܡܠܝܐ ܒܟܠܗ ܨܒܝܢܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.4.13",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Colossians 4:13",
      "text": "ܤܗܕ ܐܢܐ ܓܝܪ ܥܠܘܗܝ ܕܛܢܢܐ ܤܓܝܐܐ ܐܝܬ ܠܗ ܚܠܦܝܟܘܢ ܘܚܠܦ ܗܢܘܢ ܕܒܠܕܝܩܝܐ ܘܕܒܐܝܪܦܘܠܝܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.4.14",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Colossians 4:14",
      "text": "ܫܐܠ ܒܫܠܡܟܘܢ ܠܘܩܐ ܐܤܝܐ ܚܒܝܒܢ ܘܕܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.4.15",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Colossians 4:15",
      "text": "ܫܐܠܘ ܒܫܠܡܐ ܕܐܚܐ ܕܒܠܕܝܩܝܐ ܘܕܢܘܡܦܐ ܘܕܥܕܬܐ ܕܒܒܝܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.4.16",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Colossians 4:16",
      "text": "ܘܡܐ ܕܐܬܩܪܝܬ ܐܓܪܬܐ ܗܕܐ ܠܘܬܟܘܢ ܥܒܕܘ ܕܐܦ ܒܥܕܬܐ ܕܠܕܝܩܝܐ ܬܬܩܪܐ ܘܗܝ ܕܐܬܟܬܒܬ ܡܢ ܠܕܝܩܝܐ ܩܪܐܘܗ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.4.17",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Colossians 4:17",
      "text": "ܘܐܡܪܘ ܠܐܪܟܝܦܘܤ ܕܐܙܕܗܪ ܒܬܫܡܫܬܐ ܗܝ ܕܩܒܠܬ ܒܡܪܢ ܕܬܗܘܐ ܡܫܡܠܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.4.18",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Colossians 4:18",
      "text": "ܫܠܡܐ ܗܢܐ ܒܐܝܕܐ ܕܝܠܝ ܕܦܘܠܘܤ ܗܘܝܬܘܢ ܥܗܕܝܢ ܠܐܤܘܪܝ ܛܝܒܘܬܐ ܥܡܟܘܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
