{
  "chapter": {
    "id": "peshitta:colossians.1",
    "translationId": "peshitta",
    "bookSlug": "colossians",
    "chapterNumber": 1,
    "referenceLabel": "Colossians 1",
    "summary": "Source text for Colossians 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:colossians.1.1",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Colossians 1:1",
      "text": "ܦܘܠܘܤ ܫܠܝܚܐ ܕܝܫܘܥ ܡܫܝܚܐ ܒܨܒܝܢܗ ܕܐܠܗܐ ܘܛܝܡܬܐܘܤ ܐܚܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:colossians.1.2",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Colossians 1:2",
      "text": "ܠܐܝܠܝܢ ܕܐܝܬ ܒܩܘܠܤܘܤ ܐܚܐ ܩܕܝܫܐ ܘܡܗܝܡܢܐ ܒܝܫܘܥ ܡܫܝܚܐ ܫܠܡܐ ܥܡܟܘܢ ܘܛܝܒܘܬܐ ܡܢ ܐܠܗܐ ܐܒܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.3",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Colossians 1:3",
      "text": "ܡܘܕܝܢܢ ܠܐܠܗܐ ܐܒܘܗܝ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܒܟܠܙܒܢ ܘܡܨܠܝܢܢ ܥܠܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.4",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Colossians 1:4",
      "text": "ܗܐ ܡܢ ܕܫܡܥܢ ܗܝܡܢܘܬܟܘܢ ܕܒܝܫܘܥ ܡܫܝܚܐ ܘܚܘܒܟܘܢ ܕܠܘܬ ܟܠܗܘܢ ܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.5",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Colossians 1:5",
      "text": "ܡܛܠ ܤܒܪܐ ܗܘ ܕܢܛܝܪ ܠܟܘܢ ܒܫܡܝܐ ܗܘ ܕܡܢ ܩܕܝܡ ܫܡܥܬܘܢ ܒܡܠܬܐ ܕܩܘܫܬܐ ܕܤܒܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.6",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Colossians 1:6",
      "text": "ܗܝ ܕܐܬܟܪܙܬ ܠܟܘܢ ܐܝܟ ܕܐܦ ܠܟܠܗ ܥܠܡܐ ܘܪܒܝܐ ܘܝܗܒܐ ܦܐܪܐ ܐܝܟܢܐ ܕܐܦ ܒܟܘܢ ܡܢ ܝܘܡܐ ܕܫܡܥܬܘܢ ܘܐܫܬܘܕܥܬܘܢ ܛܝܒܘܬܗ ܕܐܠܗܐ ܒܩܘܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.7",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Colossians 1:7",
      "text": "ܐܝܟ ܡܐ ܕܝܠܦܬܘܢ ܡܢ ܐܦܦܪܐ ܟܢܬܢ ܚܒܝܒܐ ܕܗܘ ܐܝܬܘܗܝ ܚܠܦܝܟܘܢ ܡܫܡܫܢܐ ܡܗܝܡܢܐ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.8",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Colossians 1:8",
      "text": "ܘܗܘ ܐܘܕܥܢ ܚܘܒܟܘܢ ܕܒܪܘܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.9",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Colossians 1:9",
      "text": "ܡܛܠܗܢܐ ܐܦ ܚܢܢ ܡܢ ܝܘܡܐ ܕܫܡܥܢ ܠܐ ܫܠܝܢܢ ܠܡܨܠܝܘ ܥܠܝܟܘܢ ܘܠܡܫܐܠ ܕܬܬܡܠܘܢ ܝܕܥܬܐ ܕܨܒܝܢܗ ܕܐܠܗܐ ܒܟܠ ܚܟܡܐ ܘܒܟܠ ܤܘܟܠ ܕܪܘܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.10",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Colossians 1:10",
      "text": "ܕܬܗܠܟܘܢ ܐܝܟ ܕܙܕܩ ܘܬܫܦܪܘܢ ܠܐܠܗܐ ܒܟܠ ܥܒܕܝܢ ܛܒܝܢ ܘܬܬܠܘܢ ܦܐܪܐ ܘܬܪܒܘܢ ܒܝܕܥܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.11",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Colossians 1:11",
      "text": "ܘܒܟܠ ܚܝܠ ܬܬܚܝܠܘܢ ܐܝܟ ܪܒܘܬܐ ܕܫܘܒܚܗ ܒܟܠ ܡܤܝܒܪܢܘ ܘܒܡܓܪܬ ܪܘܚ ܘܒܚܕܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.12",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Colossians 1:12",
      "text": "ܬܘܕܘܢ ܠܐܠܗܐ ܐܒܐ ܕܐܫܘܝܢ ܠܡܢܬܐ ܕܝܪܬܘܬܐ ܕܩܕܝܫܐ ܒܢܘܗܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.13",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Colossians 1:13",
      "text": "ܘܦܪܩܢ ܡܢ ܫܘܠܛܢܗ ܕܚܫܘܟܐ ܘܐܝܬܝܢ ܠܡܠܟܘܬܐ ܕܒܪܗ ܚܒܝܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.14",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Colossians 1:14",
      "text": "ܗܘ ܕܒܗ ܐܝܬ ܠܢ ܦܘܪܩܢܐ ܘܫܘܒܩܢܐ ܕܚܛܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.15",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Colossians 1:15",
      "text": "ܗܘ ܕܗܘܝܘ ܕܡܘܬܐ ܕܐܠܗܐ ܕܠܐ ܡܬܚܙܐ ܘܒܘܟܪܐ ܕܟܠܗܝܢ ܒܪܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.16",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Colossians 1:16",
      "text": "ܘܒܗ ܐܬܒܪܝ ܟܠܡܕܡ ܕܒܫܡܝܐ ܘܒܐܪܥܐ ܟܠ ܕܡܬܚܙܐ ܘܟܠ ܕܠܐ ܡܬܚܙܐ ܐܢ ܡܘܬܒܐ ܘܐܢ ܡܪܘܬܐ ܘܐܢ ܐܪܟܘܤ ܘܐܢ ܫܘܠܛܢܐ ܟܠܡܕܡ ܒܐܝܕܗ ܘܒܗ ܐܬܒܪܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.17",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Colossians 1:17",
      "text": "ܘܗܘܝܘ ܕܡܢ ܩܕܡ ܟܠ ܘܟܠܡܕܡ ܒܗ ܩܐܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.18",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Colossians 1:18",
      "text": "ܘܗܘܝܘ ܪܫܐ ܕܦܓܪܐ ܕܥܕܬܐ ܕܐܝܬܘܗܝ ܪܫܐ ܘܒܘܟܪܐ ܕܡܢ ܒܝܬ ܡܝܬܐ ܕܢܗܘܐ ܩܕܡܝ ܒܟܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.19",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Colossians 1:19",
      "text": "ܕܒܗ ܗܘ ܨܒܐ ܟܠܗ ܡܘܠܝܐ ܠܡܥܡܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.20",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Colossians 1:20",
      "text": "ܘܒܐܝܕܗ ܠܡܪܥܝܘ ܠܗ ܟܠܡܕܡ ܘܫܝܢ ܒܕܡܐ ܕܙܩܝܦܗ ܒܐܝܕܘܗܝ ܐܢ ܕܒܐܪܥܐ ܘܐܢ ܕܒܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.21",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Colossians 1:21",
      "text": "ܐܦ ܠܟܘܢ ܕܡܢ ܩܕܝܡ ܢܘܟܪܝܐ ܗܘܝܬܘܢ ܘܒܥܠܕܒܒܐ ܒܪܥܝܢܝܟܘܢ ܡܛܠ ܥܒܕܝܟܘܢ ܒܝܫܐ ܫܝܢܟܘܢ ܗܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.22",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Colossians 1:22",
      "text": "ܒܦܓܪܐ ܕܒܤܪܗ ܘܒܡܘܬܗ ܕܢܩܝܡܟܘܢ ܩܕܡܘܗܝ ܩܕܝܫܝܢ ܕܠܐ ܡܘܡ ܘܕܠܐ ܪܫܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.23",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Colossians 1:23",
      "text": "ܐܢ ܬܩܘܘܢ ܒܗܝܡܢܘܬܟܘܢ ܟܕ ܫܪܝܪܐ ܫܬܐܤܬܟܘܢ ܘܠܐ ܡܬܬܙܝܥܝܬܘܢ ܡܢ ܤܒܪܐ ܕܐܘܢܓܠܝܘܢ ܗܘ ܕܫܡܥܬܘܢ ܕܐܬܟܪܙ ܒܟܠܗ ܒܪܝܬܐ ܕܬܚܝܬ ܫܡܝܐ ܗܘ ܕܐܢܐ ܦܘܠܘܤ ܗܘܝܬ ܡܫܡܫܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.24",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Colossians 1:24",
      "text": "ܘܚܕܐ ܐܢܐ ܒܚܫܐ ܕܥܠ ܐܦܝܟܘܢ ܘܡܡܠܐ ܐܢܐ ܚܤܝܪܘܬܐ ܕܐܘܠܨܢܘܗܝ ܕܡܫܝܚܐ ܒܒܤܪܝ ܚܠܦ ܦܓܪܗ ܕܐܝܬܘܗܝ ܥܕܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.25",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Colossians 1:25",
      "text": "ܗܝ ܕܐܢܐ ܗܘܝܬ ܡܫܡܫܢܗ ܐܝܟ ܡܕܒܪܢܘܬܐ ܕܐܠܗܐ ܕܐܬܝܗܒܬ ܠܝ ܒܟܘܢ ܕܐܫܡܠܐ ܡܠܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.26",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "Colossians 1:26",
      "text": "ܐܪܙܐ ܗܘ ܕܡܟܤܝ ܗܘܐ ܡܢ ܥܠܡܐ ܘܡܢ ܕܪܐ ܗܫܐ ܕܝܢ ܐܬܓܠܝ ܠܩܕܝܫܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.27",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "Colossians 1:27",
      "text": "ܠܐܝܠܝܢ ܕܨܒܐ ܐܠܗܐ ܕܢܘܕܥ ܡܢܘ ܥܘܬܪܐ ܕܫܘܒܚܗ ܕܐܪܙܐ ܗܢܐ ܒܥܡܡܐ ܕܗܘܝܘ ܡܫܝܚܐ ܕܒܟܘܢ ܤܒܪܐ ܕܫܘܒܚܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.28",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "Colossians 1:28",
      "text": "ܗܘ ܕܚܢܢ ܡܟܪܙܝܢܢ ܘܡܠܦܝܢܢ ܘܡܤܟܠܝܢܢ ܠܟܠ ܒܪܢܫ ܒܟܠ ܚܟܡܐ ܕܢܩܝܡ ܠܟܠ ܒܪܢܫ ܟܕ ܓܡܝܪ ܒܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.1.29",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "Colossians 1:29",
      "text": "ܒܗܕܐ ܗܘ ܓܝܪ ܐܦ ܥܡܠ ܐܢܐ ܘܡܬܟܬܫ ܐܢܐ ܒܡܥܕܪܢܘܬܐ ܕܚܝܠܐ ܕܡܬܝܗܒ ܠܝ ܀",
      "paragraphStart": false
    }
  ]
}
