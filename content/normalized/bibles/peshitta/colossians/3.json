{
  "chapter": {
    "id": "peshitta:colossians.3",
    "translationId": "peshitta",
    "bookSlug": "colossians",
    "chapterNumber": 3,
    "referenceLabel": "Colossians 3",
    "summary": "Source text for Colossians 3 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:colossians.3.1",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Colossians 3:1",
      "text": "ܐܢ ܗܟܝܠ ܩܡܬܘܢ ܥܡ ܡܫܝܚܐ ܕܠܥܠ ܒܥܘ ܐܬܪ ܕܡܫܝܚܐ ܝܬܒ ܥܠ ܝܡܝܢܐ ܕܐܠܗܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:colossians.3.2",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Colossians 3:2",
      "text": "ܕܠܥܠ ܐܬܪܥܘ ܘܠܐ ܕܒܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.3",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Colossians 3:3",
      "text": "ܡܝܬܬܘܢ ܠܟܘܢ ܓܝܪ ܘܚܝܝܟܘܢ ܟܤܝܢ ܥܡ ܡܫܝܚܐ ܒܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.4",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Colossians 3:4",
      "text": "ܘܐܡܬܝ ܕܡܫܝܚܐ ܡܬܓܠܐ ܕܗܘܝܘ ܚܝܝܢ ܗܝܕܝܢ ܐܦ ܐܢܬܘܢ ܬܬܓܠܘܢ ܥܡܗ ܒܫܘܒܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.5",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Colossians 3:5",
      "text": "ܐܡܝܬܘ ܗܟܝܠ ܗܕܡܝܟܘܢ ܕܒܐܪܥܐ ܙܢܝܘܬܐ ܘܛܢܦܘܬܐ ܘܟܐܒܐ ܘܪܓܬܐ ܒܝܫܬܐ ܘܥܠܘܒܘܬܐ ܕܗܝ ܗܝ ܕܚܠܬ ܦܬܟܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.6",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Colossians 3:6",
      "text": "ܡܛܠ ܗܠܝܢ ܓܝܪ ܐܬܐ ܪܘܓܙܗ ܕܐܠܗܐ ܥܠ ܒܢܝܗ ܕܠܐ ܡܬܛܦܝܤܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.7",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Colossians 3:7",
      "text": "ܘܒܗܠܝܢ ܐܦ ܐܢܬܘܢ ܗܠܟܬܘܢ ܡܢ ܩܕܝܡ ܟܕ ܡܬܗܦܟܝܢ ܗܘܝܬܘܢ ܒܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.8",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Colossians 3:8",
      "text": "ܗܫܐ ܕܝܢ ܐܢܝܚܘ ܡܢܟܘܢ ܟܠܗܝܢ ܗܠܝܢ ܪܘܓܙܐ ܚܡܬܐ ܒܝܫܘܬܐ ܓܘܕܦܐ ܡܡܠܠܐ ܛܢܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.9",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Colossians 3:9",
      "text": "ܘܠܐ ܬܗܘܘܢ ܡܕܓܠܝܢ ܚܕ ܒܚܕ ܐܠܐ ܫܘܠܚܘܗܝ ܠܒܪܢܫܐ ܥܬܝܩܐ ܥܡ ܟܠܗܘܢ ܗܘܦܟܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.10",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Colossians 3:10",
      "text": "ܘܠܒܫܘ ܚܕܬܐ ܕܡܬܚܕܬ ܒܝܕܥܬܐ ܒܕܡܘܬܐ ܕܒܪܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.11",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Colossians 3:11",
      "text": "ܟܪ ܕܠܝܬ ܝܗܘܕܝܐ ܘܐܪܡܝܐ ܘܠܐ ܓܙܘܪܬܐ ܘܥܘܪܠܘܬܐ ܘܠܐ ܝܘܢܝܐ ܘܒܪܒܪܝܐ ܘܠܐ ܥܒܕܐ ܘܒܪܚܐܪܐ ܐܠܐ ܟܠ ܘܒܟܠܢܫ ܡܫܝܚܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.12",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Colossians 3:12",
      "text": "ܠܒܫܘ ܗܟܝܠ ܐܝܟ ܓܒܝܐ ܕܐܠܗܐ ܩܕܝܫܐ ܘܚܒܝܒܐ ܪܚܡܐ ܘܪܘܚܦܐ ܘܒܤܝܡܘܬܐ ܘܡܟܝܟܘܬ ܪܥܝܢܐ ܘܢܝܚܘܬܐ ܘܢܓܝܪܘܬ ܪܘܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.13",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Colossians 3:13",
      "text": "ܘܗܘܝܬܘܢ ܡܤܝܒܪܝܢ ܚܕ ܠܚܕ ܘܫܒܩܝܢ ܚܕ ܠܚܕ ܘܐܢ ܐܝܬ ܠܐܢܫ ܥܠ ܚܒܪܗ ܪܘܥܡܐ ܐܝܟܢܐ ܕܡܫܝܚܐ ܫܒܩ ܠܟܘܢ ܗܟܢܐ ܐܦ ܐܢܬܘܢ ܫܒܘܩܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.14",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Colossians 3:14",
      "text": "ܘܥܡ ܗܠܝܢ ܟܠܗܝܢ ܚܘܒܐ ܕܗܘܝܘ ܚܙܩܐ ܕܓܡܝܪܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.15",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Colossians 3:15",
      "text": "ܘܫܠܡܗ ܕܡܫܝܚܐ ܢܕܒܪ ܠܒܘܬܟܘܢ ܕܠܗ ܐܬܩܪܝܬܘܢ ܒܚܕ ܦܓܪ ܘܗܘܝܬܘܢ ܡܘܕܝܢ ܠܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.16",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Colossians 3:16",
      "text": "ܕܡܠܬܗ ܬܥܡܪ ܒܟܘܢ ܥܬܝܪܐܝܬ ܒܟܠ ܚܟܡܐ ܘܗܘܝܬܘܢ ܡܠܦܝܢ ܘܪܕܝܢ ܢܦܫܟܘܢ ܒܡܙܡܘܪܐ ܘܒܬܫܒܚܬܐ ܘܒܙܡܝܪܬܐ ܕܪܘܚܐ ܘܒܛܝܒܘܬܐ ܗܘܝܬܘܢ ܙܡܪܝܢ ܒܠܒܘܬܟܘܢ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.17",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Colossians 3:17",
      "text": "ܘܟܠ ܡܕܡ ܕܤܥܪܝܢ ܐܢܬܘܢ ܒܡܠܬܐ ܘܒܥܒܕܐ ܒܫܡܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܗܘܝܬܘܢ ܥܒܕܝܢ ܘܗܘܝܬܘܢ ܡܘܕܝܢ ܒܐܝܕܗ ܠܐܠܗܐ ܐܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.18",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Colossians 3:18",
      "text": "ܢܫܐ ܐܫܬܥܒܕܝܢ ܠܒܥܠܝܟܝܢ ܐܝܟ ܕܙܕܩ ܒܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.19",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Colossians 3:19",
      "text": "ܓܒܪܐ ܐܚܒܘ ܢܫܝܟܘܢ ܘܠܐ ܬܗܘܘܢ ܡܪܝܪܝܢ ܥܠܝܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.20",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Colossians 3:20",
      "text": "ܒܢܝܐ ܐܫܬܡܥܘ ܠܐܒܗܝܟܘܢ ܒܟܠܡܕܡ ܗܟܢܐ ܓܝܪ ܫܦܝܪ ܩܕܡ ܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.21",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Colossians 3:21",
      "text": "ܐܒܗܐ ܠܐ ܬܪܓܙܘܢ ܒܢܝܟܘܢ ܕܠܐ ܢܬܬܥܝܩܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.22",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Colossians 3:22",
      "text": "ܥܒܕܐ ܐܫܬܡܥܘ ܒܟܠܡܕܡ ܠܡܪܝܟܘܢ ܕܦܓܪܐ ܠܐ ܒܡܚܙܐ ܥܝܢܐ ܐܝܟ ܗܢܘܢ ܕܫܦܪܝܢ ܠܒܢܝܢܫܐ ܐܠܐ ܒܠܒܐ ܦܫܝܛܐ ܘܒܕܚܠܬܗ ܕܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.23",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Colossians 3:23",
      "text": "ܘܟܠ ܕܥܒܕܝܢ ܐܢܬܘܢ ܡܢ ܟܠܗ ܢܦܫܟܘܢ ܥܒܕܘ ܐܝܟ ܕܠܡܪܢ ܘܠܐ ܐܝܟ ܕܠܒܢܝܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.24",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Colossians 3:24",
      "text": "ܘܕܥܘ ܕܡܢ ܡܪܢ ܡܩܒܠܝܬܘܢ ܦܘܪܥܢܐ ܒܝܪܬܘܬܐ ܠܡܪܝܐ ܓܝܪ ܡܫܝܚܐ ܦܠܚܝܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.3.25",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Colossians 3:25",
      "text": "ܡܤܟܠܢܐ ܕܝܢ ܡܬܦܪܥ ܐܝܟ ܡܕܡ ܕܐܤܟܠ ܘܠܝܬ ܡܤܒ ܒܐܦܐ ܀",
      "paragraphStart": false
    }
  ]
}
