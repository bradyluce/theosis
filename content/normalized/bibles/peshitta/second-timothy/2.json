{
  "chapter": {
    "id": "peshitta:second-timothy.2",
    "translationId": "peshitta",
    "bookSlug": "second-timothy",
    "chapterNumber": 2,
    "referenceLabel": "2 Timothy 2",
    "summary": "Source text for 2 Timothy 2 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:second-timothy.2.1",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "2 Timothy 2:1",
      "text": "ܐܢܬ ܗܟܝܠ ܒܪܝ ܐܬܚܝܠ ܒܛܝܒܘܬܐ ܕܒܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-timothy.2.2",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "2 Timothy 2:2",
      "text": "ܘܐܝܠܝܢ ܕܫܡܥܬ ܡܢܝ ܒܝܕ ܤܗܕܐ ܤܓܝܐܐ ܗܢܝܢ ܐܓܥܠ ܠܐܢܫܐ ܡܗܝܡܢܐ ܐܝܠܝܢ ܕܡܛܝܐ ܒܐܝܕܝܗܘܢ ܐܦ ܠܐܚܪܢܐ ܠܡܠܦܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.3",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "2 Timothy 2:3",
      "text": "ܘܤܝܒܪ ܒܝܫܬܐ ܐܝܟ ܦܠܚܐ ܛܒܐ ܕܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.4",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "2 Timothy 2:4",
      "text": "ܠܐ ܐܢܫ ܦܠܚ ܘܡܬܦܟܪ ܒܨܒܘܬܐ ܕܥܠܡܐ ܕܢܫܦܪ ܠܗܘ ܡܢ ܕܓܒܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.5",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "2 Timothy 2:5",
      "text": "ܘܐܢ ܡܬܟܬܫ ܐܢܫ ܠܐ ܡܬܟܠܠ ܐܢ ܒܢܡܘܤܗ ܠܐ ܡܬܟܬܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.6",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "2 Timothy 2:6",
      "text": "ܠܐܟܪܐ ܕܠܐܐ ܘܠܐ ܠܗ ܕܩܕܡܐ ܡܢ ܦܐܪܘܗܝ ܢܤܬܝܒܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.7",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "2 Timothy 2:7",
      "text": "ܐܤܬܟܠ ܡܕܡ ܕܐܡܪ ܐܢܐ ܢܬܠ ܠܟ ܡܪܢ ܚܟܡܬܐ ܒܟܠ ܡܕܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.8",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "2 Timothy 2:8",
      "text": "ܐܬܕܟܪ ܠܝܫܘܥ ܡܫܝܚܐ ܕܩܡ ܡܢ ܒܝܬ ܡܝܬܐ ܗܘ ܕܐܝܬܘܗܝ ܡܢ ܙܪܥܐ ܕܕܘܝܕ ܐܝܟ ܐܘܢܓܠܝܘܢ ܕܝܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.9",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "2 Timothy 2:9",
      "text": "ܕܒܗ ܤܒܠ ܐܢܐ ܒܝܫܬܐ ܥܕܡܐ ܠܐܤܘܪܐ ܐܝܟ ܥܒܕ ܒܝܫܬܐ ܐܠܐ ܡܠܬܗ ܕܐܠܗܐ ܠܐ ܐܤܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.10",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "2 Timothy 2:10",
      "text": "ܡܛܠ ܗܢܐ ܟܠܡܕܡ ܡܤܝܒܪ ܐܢܐ ܡܛܠ ܓܒܝܐ ܕܐܦ ܗܢܘܢ ܢܫܟܚܘܢ ܚܝܐ ܕܒܝܫܘܥ ܡܫܝܚܐ ܥܡ ܫܘܒܚܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.11",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "2 Timothy 2:11",
      "text": "ܡܗܝܡܢܐ ܗܝ ܡܠܬܐ ܐܢ ܓܝܪ ܡܝܬܢ ܥܡܗ ܐܦ ܥܡܗ ܢܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.12",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "2 Timothy 2:12",
      "text": "ܘܐܢ ܢܤܝܒܪ ܐܦ ܢܡܠܟ ܥܡܗ ܐܢ ܕܝܢ ܢܟܦܘܪ ܒܗ ܐܦ ܗܘ ܢܟܦܘܪ ܒܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.13",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "2 Timothy 2:13",
      "text": "ܘܐܢ ܠܐ ܢܗܝܡܢ ܒܗ ܗܘ ܒܗܝܡܢܘܬܗ ܡܩܘܐ ܕܢܟܦܘܪ ܓܝܪ ܒܢܦܫܗ ܠܐ ܡܫܟܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.14",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "2 Timothy 2:14",
      "text": "ܗܠܝܢ ܗܘܝܬ ܡܥܗܕ ܠܗܘܢ ܘܡܤܗܕ ܩܕܡ ܡܪܢ ܕܠܐ ܢܗܘܘܢ ܡܬܚܪܝܢ ܒܡܠܐ ܕܠܐ ܝܘܬܪܢ ܠܤܘܚܦܐ ܕܐܝܠܝܢ ܕܫܡܥܝܢ ܠܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.15",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "2 Timothy 2:15",
      "text": "ܘܢܬܒܛܠ ܠܟ ܕܬܩܝܡ ܢܦܫܟ ܓܡܝܪܐܝܬ ܩܕܡ ܐܠܗܐ ܦܠܚܐ ܕܠܐ ܒܗܬܬܐ ܕܡܟܪܙ ܬܪܝܨܐܝܬ ܡܠܬܐ ܕܫܪܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.16",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "2 Timothy 2:16",
      "text": "ܘܡܢ ܡܠܐ ܤܪܝܩܬܐ ܕܠܝܬ ܒܗܝܢ ܚܫܚܘ ܐܫܬܐܠ ܝܬܝܪܐܝܬ ܓܝܪ ܢܘܤܦܘܢ ܥܠ ܪܘܫܥܗܘܢ ܗܢܘܢ ܕܥܢܝܢ ܒܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.17",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "2 Timothy 2:17",
      "text": "ܘܡܠܬܗܘܢ ܐܝܟ ܚܠܕܝܬܐ ܢܘܡܐ ܬܐܚܘܕ ܒܤܓܝܐܐ ܐܝܬܘܗܝ ܕܝܢ ܚܕ ܡܢܗܘܢ ܗܘܡܢܐܘܤ ܘܐܚܪܢܐ ܦܝܠܛܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.18",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "2 Timothy 2:18",
      "text": "ܗܠܝܢ ܕܛܥܘ ܡܢ ܫܪܪܐ ܟܕ ܐܡܪܝܢ ܕܩܝܡܬܐ ܕܡܝܬܐ ܗܘܬ ܠܗ ܘܗܝܡܢܘܬܐ ܕܐܢܫ ܐܢܫ ܡܗܦܟܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.19",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "2 Timothy 2:19",
      "text": "ܫܬܐܤܬܐ ܕܝܢ ܫܪܝܪܬܐ ܕܐܠܗܐ ܩܝܡܐ ܗܝ ܘܐܝܬ ܠܗ ܚܬܡܐ ܗܢܐ ܘܝܕܥ ܡܪܝܐ ܠܐܝܠܝܢ ܕܕܝܠܗ ܐܢܘܢ ܘܢܦܪܘܩ ܡܢ ܥܘܠܐ ܟܠ ܕܩܪܐ ܠܫܡܗ ܕܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.20",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "2 Timothy 2:20",
      "text": "ܒܒܝܬܐ ܕܝܢ ܪܒܐ ܠܐ ܗܘܐ ܡܐܢܐ ܕܕܗܒܐ ܒܠܚܘܕ ܐܘ ܕܤܐܡܐ ܐܝܬ ܒܗ ܐܠܐ ܐܦ ܕܩܝܤܐ ܐܦ ܕܦܚܪܐ ܡܢܗܘܢ ܠܐܝܩܪܐ ܘܡܢܗܘܢ ܠܨܥܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.21",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "2 Timothy 2:21",
      "text": "ܐܢ ܐܢܫ ܗܟܝܠ ܢܕܟܐ ܢܦܫܗ ܡܢ ܗܠܝܢ ܗܘܐ ܡܐܢܐ ܕܟܝܐ ܠܐܝܩܪܐ ܕܥܗܢ ܠܚܘܫܚܐ ܕܡܪܗ ܘܡܛܝܒ ܠܟܠ ܥܒܕ ܛܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.22",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "2 Timothy 2:22",
      "text": "ܡܢ ܟܠܗܝܢ ܪܓܝܓܬܐ ܕܛܠܝܘܬܐ ܥܪܘܩ ܘܗܪܛ ܒܬܪ ܟܐܢܘܬܐ ܘܗܝܡܢܘܬܐ ܘܚܘܒܐ ܘܫܠܡܐ ܥܡ ܐܝܠܝܢ ܕܩܪܝܢ ܠܡܪܢ ܒܠܒܐ ܕܟܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.23",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "2 Timothy 2:23",
      "text": "ܚܪܝܢܐ ܤܟܠܐ ܐܝܠܝܢ ܕܕܠܐ ܡܪܕܘ ܐܢܘܢ ܐܫܬܐܠ ܡܢܗܘܢ ܝܕܥ ܐܢܬ ܓܝܪ ܕܬܟܬܘܫܐ ܡܘܠܕܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.24",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "2 Timothy 2:24",
      "text": "ܥܒܕܗ ܕܝܢ ܕܡܪܢ ܠܐ ܚܝܒ ܠܡܬܟܬܫܘ ܐܠܐ ܕܢܗܘܐ ܡܟܝܟ ܠܘܬ ܟܠܢܫ ܘܡܠܦܢ ܘܢܓܝܪܐ ܪܘܚܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.25",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "2 Timothy 2:25",
      "text": "ܕܢܗܘܐ ܪܕܐ ܠܐܝܠܝܢ ܕܡܬܚܪܝܢ ܠܩܘܒܠܗ ܒܡܟܝܟܘܬܐ ܕܠܡܐ ܢܬܠ ܠܗܘܢ ܐܠܗܐ ܬܝܒܘܬܐ ܘܢܕܥܘܢ ܫܪܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.2.26",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "2 Timothy 2:26",
      "text": "ܘܢܥܗܕܘܢ ܢܦܫܗܘܢ ܘܢܦܪܩܘܢ ܡܢ ܦܚܗ ܕܤܛܢܐ ܕܒܗ ܐܬܬܨܝܕܘ ܠܨܒܝܢܗ ܀",
      "paragraphStart": false
    }
  ]
}
