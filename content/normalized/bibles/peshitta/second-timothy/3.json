    "referenceLabel": "2 Timothy 3",
    "summary": "Source text for 2 Timothy 3 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:second-timothy.3.1",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "2 Timothy 3:1",
      "text": "ܗܕܐ ܕܝܢ ܗܘܝܬ ܝܕܥ ܕܒܝܘܡܬܐ ܐܚܪܝܐ ܢܐܬܘܢ ܙܒܢܐ ܩܫܝܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-timothy.3.2",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "2 Timothy 3:2",
      "text": "ܘܢܗܘܘܢ ܒܢܝܢܫܐ ܪܚܡܝ ܢܦܫܗܘܢ ܘܪܚܡܝ ܟܤܦܐ ܫܒܗܪܢܐ ܪܡܐ ܡܓܕܦܢܐ ܕܠܐܢܫܝܗܘܢ ܠܐ ܡܬܛܦܝܤܝܢ ܟܦܪܝ ܒܛܝܒܘܬܐ ܪܫܝܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.3.3",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "2 Timothy 3:3",
      "text": "ܐܟܠܝ ܩܪܨܐ ܡܫܥܒܕܝ ܠܪܓܬܐ ܒܥܪܝܪܝܐ ܤܢܝܝ ܛܒܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.3.4",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "2 Timothy 3:4",
      "text": "ܡܫܠܡܢܐ ܡܤܪܗܒܐ ܚܬܝܪܐ ܪܚܡܝ ܪܓܝܓܬܐ ܛܒ ܡܢ ܚܘܒܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.3.5",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "2 Timothy 3:5",
      "text": "ܕܐܝܬ ܠܗܘܢ ܐܤܟܡܐ ܕܕܚܠܬ ܐܠܗܐ ܘܡܢ ܚܝܠܗ ܪܚܝܩܝܢ ܐܝܠܝܢ ܕܗܟܢܐ ܐܢܘܢ ܕܚܘܩ ܐܢܘܢ ܡܢܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.3.6",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "2 Timothy 3:6",
      "text": "ܡܢܗܘܢ ܐܢܘܢ ܓܝܪ ܗܠܝܢ ܕܡܚܠܕܝܢ ܒܝܬ ܒܬܐ ܘܫܒܝܢ ܢܫܐ ܕܛܡܝܪܢ ܒܚܛܗܐ ܘܡܬܕܒܪܢ ܠܪܓܝܓܬܐ ܡܫܚܠܦܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.3.7",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "2 Timothy 3:7",
      "text": "ܕܒܟܠܙܒܢ ܝܠܦܢ ܘܡܡܬܘܡ ܠܝܕܥܬܐ ܕܫܪܪܐ ܠܡܐܬܐ ܠܐ ܡܫܟܚܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.3.8",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "2 Timothy 3:8",
      "text": "ܐܝܟܢܐ ܕܝܢ ܕܝܢܤ ܘܝܡܒܪܝܤ ܩܡܘ ܠܘܩܒܠ ܡܘܫܐ ܗܟܢܐ ܐܦ ܗܢܘܢ ܩܝܡܝܢ ܠܘܩܒܠ ܫܪܪܐ ܐܢܫܐ ܕܡܚܒܠ ܪܥܝܢܗܘܢ ܘܤܠܝܢ ܡܢ ܗܝܡܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.3.9",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "2 Timothy 3:9",
      "text": "ܐܠܐ ܠܐ ܢܐܬܘܢ ܠܩܕܡܝܗܘܢ ܫܛܝܘܬܗܘܢ ܓܝܪ ܡܬܝܕܥܐ ܗܝ ܠܟܠܢܫ ܐܝܟܢܐ ܕܐܦ ܕܗܢܘܢ ܐܬܝܕܥܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.3.10",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "2 Timothy 3:10",
      "text": "ܐܢܬ ܕܝܢ ܐܬܝܬ ܒܬܪ ܝܘܠܦܢܝ ܘܒܬܪ ܕܘܒܪܝ ܘܒܬܪ ܨܒܝܢܝ ܘܒܬܪ ܗܝܡܢܘܬܝ ܘܒܬܪ ܢܓܝܪܘܬ ܪܘܚܝ ܘܒܬܪ ܚܘܒܝ ܘܒܬܪ ܡܤܝܒܪܢܘܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.3.11",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "2 Timothy 3:11",
      "text": "ܘܒܬܪ ܪܕܝܦܘܬܝ ܘܒܬܪ ܚܫܝ ܘܝܕܥ ܐܢܬ ܐܝܠܝܢ ܤܝܒܪܬ ܒܐܢܛܝܟܝܐ ܘܒܐܝܩܢܘܢ ܘܒܠܘܤܛܪܐ ܐܝܕܐ ܪܕܝܦܘܬܐ ܤܝܒܪܬ ܘܡܢ ܟܠܗܝܢ ܦܨܝܢܝ ܡܪܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.3.12",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "2 Timothy 3:12",
      "text": "ܘܟܠܗܘܢ ܕܝܢ ܐܝܠܝܢ ܕܨܒܝܢ ܒܕܚܠܬ ܐܠܗܐ ܕܢܚܘܢ ܒܝܫܘܥ ܡܫܝܚܐ ܡܬܪܕܦܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.3.13",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "2 Timothy 3:13",
      "text": "ܒܢܝܢܫܐ ܕܝܢ ܒܝܫܐ ܘܡܛܥܝܢܐ ܢܘܤܦܘܢ ܥܠ ܒܝܫܘܬܗܘܢ ܟܕ ܛܥܝܢ ܘܡܛܥܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.3.14",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "2 Timothy 3:14",
      "text": "ܐܢܬ ܕܝܢ ܩܘܐ ܒܐܝܠܝܢ ܕܝܠܦܬ ܘܐܫܬܪܪܬ ܝܕܥ ܐܢܬ ܓܝܪ ܡܢ ܡܢܘ ܝܠܦܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.3.15",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "2 Timothy 3:15",
      "text": "ܘܕܡܢ ܛܠܝܘܬܟ ܤܦܪܐ ܩܕܝܫܐ ܝܠܝܦ ܐܢܬ ܕܡܫܟܚܝܢ ܕܢܚܟܡܘܢܟ ܠܚܝܐ ܒܗܝܡܢܘܬܐ ܕܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.3.16",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "2 Timothy 3:16",
      "text": "ܟܠ ܟܬܒ ܕܒܪܘܚܐ ܐܬܟܬܒ ܡܘܬܪܢܐ ܗܘ ܠܝܘܠܦܢܐ ܘܠܟܘܘܢܐ ܘܠܬܘܪܨܐ ܘܠܡܪܕܘܬܐ ܕܒܟܐܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.3.17",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "2 Timothy 3:17",
      "text": "ܕܢܗܘܐ ܓܡܝܪ ܒܪܢܫܐ ܕܐܠܗܐ ܘܠܟܠ ܥܒܕ ܛܒ ܡܫܠܡܢ ܀",
      "paragraphStart": false
    }
  ]
}
