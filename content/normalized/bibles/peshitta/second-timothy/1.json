{
  "chapter": {
    "id": "peshitta:second-timothy.1",
    "translationId": "peshitta",
    "bookSlug": "second-timothy",
    "chapterNumber": 1,
    "referenceLabel": "2 Timothy 1",
    "summary": "Source text for 2 Timothy 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:second-timothy.1.1",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "2 Timothy 1:1",
      "text": "ܦܘܠܘܤ ܫܠܝܚܐ ܕܝܫܘܥ ܡܫܝܚܐ ܒܨܒܝܢܗ ܕܐܠܗܐ ܘܒܡܘܠܟܢܐ ܕܚܝܐ ܕܒܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-timothy.1.2",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "2 Timothy 1:2",
      "text": "ܠܛܝܡܬܐܘܤ ܒܪܐ ܚܒܝܒܐ ܛܝܒܘܬܐ ܘܪܚܡܐ ܘܫܠܡܐ ܡܢ ܐܠܗܐ ܐܒܐ ܘܡܢ ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.1.3",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "2 Timothy 1:3",
      "text": "ܡܘܕܐ ܐܢܐ ܠܐܠܗܐ ܗܘ ܕܠܗ ܡܫܡܫ ܐܢܐ ܡܢ ܐܒܗܬܝ ܒܬܐܪܬܐ ܕܟܝܬܐ ܕܐܡܝܢܐܝܬ ܡܬܕܟܪ ܐܢܐ ܠܟ ܒܨܠܘܬܝ ܕܠܠܝܐ ܘܕܐܝܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.1.4",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "2 Timothy 1:4",
      "text": "ܘܤܘܐ ܐܢܐ ܠܡܚܙܝܟ ܘܡܬܕܟܪ ܐܢܐ ܕܡܥܝܟ ܕܐܬܡܠܐ ܚܕܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.1.5",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "2 Timothy 1:5",
      "text": "ܒܥܘܗܕܢܐ ܕܗܘܐ ܠܝ ܒܗܝܡܢܘܬܟ ܫܪܝܪܬܐ ܗܝ ܕܫܪܬ ܠܘܩܕܡ ܒܐܡܐ ܕܐܡܟ ܠܘܐܝܤ ܘܒܐܡܟ ܐܘܢܝܩܐ ܡܦܤ ܐܢܐ ܕܝܢ ܕܐܦ ܒܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.1.6",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "2 Timothy 1:6",
      "text": "ܡܛܠ ܗܢܐ ܡܥܗܕ ܐܢܐ ܠܟ ܕܬܥܝܪ ܡܘܗܒܬܐ ܕܐܠܗܐ ܗܝ ܕܐܝܬ ܒܟ ܒܤܝܡ ܐܝܕܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.1.7",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "2 Timothy 1:7",
      "text": "ܠܐ ܓܝܪ ܝܗܒ ܠܢ ܐܠܗܐ ܪܘܚܐ ܕܕܚܠܬܐ ܐܠܐ ܕܚܝܠܐ ܘܕܚܘܒܐ ܘܕܡܪܬܝܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.1.8",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "2 Timothy 1:8",
      "text": "ܠܐ ܗܟܝܠ ܬܒܗܬ ܒܤܗܕܘܬܗ ܕܡܪܢ ܐܦܠܐ ܒܝ ܒܐܤܝܪܗ ܐܠܐ ܫܩܘܠ ܒܝܫܬܐ ܥܡ ܐܘܢܓܠܝܘܢ ܒܚܝܠܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.1.9",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "2 Timothy 1:9",
      "text": "ܗܘ ܕܐܚܝܢ ܘܩܪܢ ܒܩܪܝܢܐ ܩܕܝܫܐ ܠܘ ܐܝܟ ܥܒܕܝܢ ܐܠܐ ܐܝܟ ܨܒܝܢܗ ܘܛܝܒܘܬܗ ܗܝ ܕܐܬܝܗܒܬ ܠܢ ܒܝܫܘܥ ܡܫܝܚܐ ܡܢ ܩܕܡ ܙܒܢܐ ܕܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.1.10",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "2 Timothy 1:10",
      "text": "ܘܐܬܓܠܝܬ ܗܫܐ ܒܓܠܝܢܗ ܕܡܚܝܢܢ ܝܫܘܥ ܡܫܝܚܐ ܕܒܛܠ ܠܡܘܬܐ ܘܚܘܝ ܚܝܐ ܘܠܐ ܡܬܚܒܠܢܘܬܐ ܒܐܘܢܓܠܝܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.1.11",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "2 Timothy 1:11",
      "text": "ܗܘ ܕܐܬܬܤܝܡܬ ܒܗ ܐܢܐ ܟܪܘܙܐ ܘܫܠܝܚܐ ܘܡܠܦܢܐ ܕܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.1.12",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "2 Timothy 1:12",
      "text": "ܡܛܠ ܗܕܐ ܡܤܝܒܪ ܐܢܐ ܗܠܝܢ ܘܠܐ ܒܗܬ ܐܢܐ ܝܕܥ ܐܢܐ ܓܝܪ ܒܡܢ ܗܝܡܢܬ ܘܡܦܤ ܐܢܐ ܕܡܛܝܐ ܒܐܝܕܘܗܝ ܓܘܥܠܢܝ ܠܡܛܪ ܠܝ ܠܝܘܡܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.1.13",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "2 Timothy 1:13",
      "text": "ܢܗܘܝܢ ܠܟ ܚܘܪܐ ܡܠܐ ܚܠܝܡܬܐ ܕܫܡܥܬ ܡܢܝ ܒܗܝܡܢܘܬܐ ܘܒܚܘܒܐ ܕܒܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.1.14",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "2 Timothy 1:14",
      "text": "ܓܘܥܠܢܐ ܛܒܐ ܛܪ ܒܪܘܚܐ ܕܩܘܕܫܐ ܗܝ ܕܥܡܪܬ ܒܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.1.15",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "2 Timothy 1:15",
      "text": "ܝܕܥ ܐܢܬ ܗܕܐ ܕܗܦܟܘ ܡܢܝ ܟܠܗܘܢ ܗܠܝܢ ܕܒܐܤܝܐ ܕܐܝܬܝܗܘܢ ܡܢܗܘܢ ܦܘܓܠܘܤ ܘܗܪܡܓܢܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.1.16",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "2 Timothy 1:16",
      "text": "ܢܬܠ ܡܪܢ ܪܚܡܐ ܠܒܝܬܗ ܕܐܢܤܝܦܘܪܘܤ ܕܙܒܢܝܢ ܤܓܝܐܢ ܐܢܝܚܢܝ ܘܒܫܫܠܬܐ ܕܐܤܘܪܝ ܠܐ ܒܗܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.1.17",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "2 Timothy 1:17",
      "text": "ܐܠܐ ܐܦ ܟܕ ܐܬܐ ܠܪܗܘܡܝ ܒܚܦܝܛܘܬܐ ܒܥܢܝ ܘܐܫܟܚܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.1.18",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "2 Timothy 1:18",
      "text": "ܢܬܠ ܠܗ ܡܪܢ ܕܢܫܟܚ ܪܚܡܐ ܠܘܬ ܡܪܢ ܒܝܘܡܐ ܗܘ ܘܟܡܐ ܕܫܡܫܢܝ ܒܐܦܤܘܤ ܝܬܝܪܐܝܬ ܝܕܥ ܐܢܬ ܀",
      "paragraphStart": false
    }
  ]
}
