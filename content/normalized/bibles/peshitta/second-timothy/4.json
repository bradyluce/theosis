{
  "chapter": {
    "id": "peshitta:second-timothy.4",
    "translationId": "peshitta",
    "bookSlug": "second-timothy",
    "chapterNumber": 4,
    "referenceLabel": "2 Timothy 4",
    "summary": "Source text for 2 Timothy 4 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:second-timothy.4.1",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "2 Timothy 4:1",
      "text": "ܡܤܗܕ ܐܢܐ ܠܟ ܩܕܡ ܐܠܗܐ ܘܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܗܘ ܕܥܬܝܕ ܠܡܕܢ ܚܝܐ ܘܡܝܬܐ ܒܓܠܝܢܐ ܕܡܠܟܘܬܗ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-timothy.4.2",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "2 Timothy 4:2",
      "text": "ܐܟܪܙ ܡܠܬܐ ܘܩܘܡ ܒܚܦܝܛܘܬܐ ܒܙܒܢܐ ܘܕܠܐ ܙܒܢܐ ܐܟܤ ܘܟܘܢ ܒܟܠܗ ܡܓܪܬ ܪܘܚܐ ܘܝܘܠܦܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.3",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "2 Timothy 4:3",
      "text": "ܢܗܘܐ ܓܝܪ ܙܒܢܐ ܕܠܝܘܠܦܢܐ ܚܠܝܡܐ ܠܐ ܢܫܬܡܥܘܢ ܐܠܐ ܐܝܟ ܪܓܝܓܬܗܘܢ ܢܤܓܘܢ ܠܢܦܫܗܘܢ ܡܠܦܢܐ ܒܚܘܬܚܬܐ ܕܡܫܡܥܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.4",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "2 Timothy 4:4",
      "text": "ܘܡܢ ܫܪܪܐ ܢܗܦܟܘܢ ܐܕܢܗܘܢ ܠܫܘܥܝܬܐ ܕܝܢ ܢܤܛܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.5",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "2 Timothy 4:5",
      "text": "ܐܢܬ ܕܝܢ ܗܘܝܬ ܥܝܪ ܒܟܠܡܕܡ ܘܤܝܒܪ ܒܝܫܬܐ ܘܥܒܕܐ ܥܒܕ ܕܡܤܒܪܢܐ ܘܬܫܡܫܬܟ ܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.6",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "2 Timothy 4:6",
      "text": "ܐܢܐ ܓܝܪ ܡܟܝܠ ܡܬܢܩܐ ܐܢܐ ܘܙܒܢܐ ܕܐܫܬܪܐ ܡܛܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.7",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "2 Timothy 4:7",
      "text": "ܐܓܘܢܐ ܫܦܝܪܐ ܐܬܟܬܫܬ ܘܪܗܛܝ ܫܠܡܬ ܘܗܝܡܢܘܬܝ ܢܛܪܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.8",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "2 Timothy 4:8",
      "text": "ܘܡܢ ܗܫܐ ܢܛܝܪ ܠܝ ܟܠܝܠܐ ܕܟܐܢܘܬܐ ܕܢܦܪܥܝܘܗܝ ܠܝ ܡܪܝ ܒܝܘܡܐ ܗܘ ܕܗܘܝܘ ܕܝܢܐ ܟܐܢܐ ܠܐ ܕܝܢ ܒܠܚܘܕ ܠܝ ܐܠܐ ܐܦ ܠܐܝܠܝܢ ܕܐܚܒܘ ܠܓܠܝܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.9",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "2 Timothy 4:9",
      "text": "ܢܬܒܛܠ ܠܟ ܕܬܐܬܐ ܠܘܬܝ ܒܥܓܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.10",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "2 Timothy 4:10",
      "text": "ܕܡܐ ܓܝܪ ܫܒܩܢܝ ܘܐܚܒ ܥܠܡܐ ܗܢܐ ܘܐܙܠ ܠܗ ܠܬܤܠܘܢܝܩܐ ܩܪܤܩܘܤ ܠܓܠܛܝܐ ܛܛܘܤ ܠܕܠܡܛܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.11",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "2 Timothy 4:11",
      "text": "ܠܘܩܐ ܗܘ ܒܠܚܘܕܘܗܝ ܥܡܝ ܠܡܪܩܘܤ ܕܒܪ ܘܐܝܬܝܗܝ ܥܡܟ ܥܗܢ ܠܝ ܓܝܪ ܠܬܫܡܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.12",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "2 Timothy 4:12",
      "text": "ܠܛܘܟܝܩܘܤ ܕܝܢ ܫܕܪܬ ܠܐܦܤܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.13",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "2 Timothy 4:13",
      "text": "ܒܝܬ ܟܬܒܐ ܕܝܢ ܕܫܒܩܬ ܒܛܪܘܐܘܤ ܠܘܬ ܩܪܦܘܤ ܡܐ ܕܐܬܐ ܐܢܬ ܐܝܬܝܗܝ ܘܟܬܒܐ ܝܬܝܪܐܝܬ ܟܪܟܐ ܕܡܓܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.14",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "2 Timothy 4:14",
      "text": "ܐܠܟܤܢܕܪܤ ܩܝܢܝܐ ܒܝܫܬܐ ܤܓܝܐܬܐ ܚܘܝܢܝ ܦܪܥ ܠܗ ܡܪܢ ܐܝܟ ܥܒܕܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.15",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "2 Timothy 4:15",
      "text": "ܐܦ ܐܢܬ ܕܝܢ ܐܙܕܗܪ ܡܢܗ ܛܒ ܓܝܪ ܙܩܝܦ ܠܘܩܒܠ ܡܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.16",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "2 Timothy 4:16",
      "text": "ܒܡܦܩ ܒܪܘܚܝ ܩܕܡܝܐ ܠܐ ܐܢܫ ܗܘܐ ܥܡܝ ܐܠܐ ܟܠܗܘܢ ܫܒܩܘܢܝ ܠܐ ܬܬܚܫܒ ܠܗܘܢ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.17",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "2 Timothy 4:17",
      "text": "ܡܪܝ ܕܝܢ ܩܡ ܠܝ ܘܚܝܠܢܝ ܕܒܝ ܟܪܘܙܘܬܐ ܬܫܬܠܡ ܘܢܫܡܥܘܢ ܥܡܡܐ ܟܠܗܘܢ ܕܐܬܦܨܝܬ ܡܢ ܦܘܡܐ ܕܐܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.18",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "2 Timothy 4:18",
      "text": "ܘܢܦܨܝܢܝ ܡܪܝ ܡܢ ܟܠ ܥܒܕ ܒܝܫ ܘܢܚܝܢܝ ܒܡܠܟܘܬܗ ܕܒܫܡܝܐ ܕܠܗ ܫܘܒܚܐ ܠܥܠܡ ܥܠܡܝܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.19",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "2 Timothy 4:19",
      "text": "ܗܒ ܫܠܡܐ ܠܦܪܝܤܩܠܐ ܘܠܐܩܠܘܤ ܘܠܒܝܬܐ ܕܐܢܤܝܦܘܪܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.20",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "2 Timothy 4:20",
      "text": "ܐܪܤܛܘܤ ܦܫ ܠܗ ܒܩܘܪܢܬܘܤ ܛܪܘܦܝܡܘܤ ܕܝܢ ܫܒܩܬܗ ܟܕ ܟܪܝܗ ܒܡܝܠܝܛܘܤ ܡܕܝܢܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.21",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "2 Timothy 4:21",
      "text": "ܢܬܒܛܠ ܠܟ ܕܩܕܡ ܤܬܘܐ ܬܐܬܐ ܫܐܠ ܒܫܠܡܟ ܐܘܒܘܠܘܤ ܘܦܘܕܤ ܘܠܝܢܘܤ ܘܩܠܘܕܝܐ ܘܐܚܐ ܟܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-timothy.4.22",
      "translationId": "peshitta",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "2 Timothy 4:22",
      "text": "ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܥܡ ܪܘܚܟ ܛܝܒܘܬܐ ܥܡܟ ܐܡܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
