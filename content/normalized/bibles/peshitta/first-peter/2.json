    "bookSlug": "first-peter",
    "chapterNumber": 2,
    "referenceLabel": "1 Peter 2",
    "summary": "Source text for 1 Peter 2 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:first-peter.2.1",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "1 Peter 2:1",
      "text": "ܐܢܝܚܘ ܗܟܝܠ ܡܢܟܘܢ ܟܠܗ ܒܝܫܘܬܐ ܘܟܠܗ ܢܟܠܐ ܘܡܤܒ ܒܐܦܐ ܘܚܤܡܐ ܘܡܐܟܠ ܩܪܨܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-peter.2.2",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "1 Peter 2:2",
      "text": "ܘܗܘܘ ܐܝܟ ܝܠܘܕܐ ܫܒܪܐ ܘܐܬܪܓܪܓܘ ܠܗ ܠܡܠܬܐ ܐܝܟ ܕܠܚܠܒܐ ܢܩܕܐ ܘܪܘܚܢܐ ܕܒܗ ܬܬܪܒܘܢ ܠܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.3",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "1 Peter 2:3",
      "text": "ܐܢ ܛܥܡܬܘܢ ܘܚܙܝܬܘܢ ܕܛܒ ܗܘ ܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.4",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "1 Peter 2:4",
      "text": "ܗܘ ܕܠܗ ܡܬܩܪܒܝܢ ܐܢܬܘܢ ܕܐܝܬܘܗܝ ܟܐܦܐ ܚܝܐ ܕܐܤܠܝܘܗܝ ܒܢܝ ܐܢܫܐ ܘܓܒܐ ܘܡܝܩܪ ܠܘܬ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.5",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "1 Peter 2:5",
      "text": "ܘܐܦ ܐܢܬܘܢ ܐܝܟ ܟܐܦܐ ܚܝܬܐ ܐܬܒܢܘ ܘܗܘܘ ܗܝܟܠܐ ܪܘܚܢܐ ܘܟܗܢܐ ܩܕܝܫܐ ܠܡܤܩܘ ܕܒܚܐ ܪܘܚܢܐ ܕܡܩܒܠܝܢ ܩܕܡ ܐܠܗܐ ܒܝܕ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.6",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "1 Peter 2:6",
      "text": "ܐܡܝܪ ܗܘ ܓܝܪ ܒܟܬܒܐ ܕܗܐ ܤܐܡ ܐܢܐ ܒܨܗܝܘܢ ܟܐܦܐ ܒܚܝܪܬܐ ܘܝܩܝܪܬܐ ܒܪܝܫ ܙܘܝܬܐ ܘܡܢ ܕܡܗܝܡܢ ܒܗ ܠܐ ܢܒܗܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.7",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "1 Peter 2:7",
      "text": "ܠܟܘܢ ܗܟܝܠ ܐܬܝܗܒ ܗܢܐ ܐܝܩܪܐ ܠܐܝܠܝܢ ܕܡܗܝܡܢܝܢ ܠܗܢܘܢ ܕܝܢ ܕܠܐ ܡܬܛܦܝܤܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.8",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "1 Peter 2:8",
      "text": "ܟܐܦܐ ܗܘ ܕܬܘܩܠܬܐ ܘܐܒܢܐ ܕܟܫܠܐ ܘܡܬܬܩܠܝܢ ܒܗ ܒܕܠܐ ܡܬܛܦܝܤܝܢ ܠܡܠܬܐ ܕܠܗܕܐ ܤܝܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.9",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "1 Peter 2:9",
      "text": "ܐܢܬܘܢ ܕܝܢ ܫܪܒܬܐ ܐܢܬܘܢ ܓܒܝܬܐ ܕܡܟܗܢܐ ܠܡܠܟܘܬܐ ܥܡܐ ܩܕܝܫܐ ܟܢܫܐ ܦܪܝܩܐ ܬܤܒܪܘܢ ܬܫܒܚܬܗ ܕܗܘ ܕܩܪܟܘܢ ܡܢ ܚܫܘܟܐ ܠܢܘܗܪܗ ܡܝܬܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.10",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "1 Peter 2:10",
      "text": "ܐܝܠܝܢ ܕܡܢ ܩܕܝܡ ܠܐ ܚܫܝܒܝܢ ܗܘܝܬܘܢ ܥܡܐ ܗܫܐ ܕܝܢ ܥܡܐ ܕܐܠܗܐ ܐܦܠܐ ܪܚܡܐ ܐܝܬ ܗܘܘ ܥܠܝܟܘܢ ܗܫܐ ܕܝܢ ܐܫܬܦܥܘ ܥܠܝܟܘܢ ܪܚܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.11",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "1 Peter 2:11",
      "text": "ܚܒܝܒܝ ܒܥܐ ܐܢܐ ܡܢܟܘܢ ܐܝܟ ܥܪܨܐ ܘܐܝܟ ܬܘܬܒܐ ܐܬܦܪܩܘ ܡܢ ܟܠܗܝܢ ܪܓܝܓܬܗ ܕܦܓܪܐ ܗܠܝܢ ܕܥܒܕܢ ܩܪܒܐ ܠܘܩܒܠ ܢܦܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.12",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "1 Peter 2:12",
      "text": "ܘܢܗܘܘܢ ܫܦܝܪܝܢ ܗܘܦܟܝܟܘܢ ܩܕܡ ܟܠܗܘܢ ܒܢܝ ܐܢܫܐ ܐܝܠܝܢ ܕܡܡܠܠܝܢ ܥܠܝܟܘܢ ܡܠܐ ܒܝܫܬܐ ܢܚܙܘܢ ܥܒܕܝܟܘܢ ܫܦܝܪܐ ܘܢܫܒܚܘܢ ܠܐܠܗܐ ܒܝܘܡܐ ܕܒܘܚܪܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.13",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "1 Peter 2:13",
      "text": "ܘܗܘܝܬܘܢ ܡܫܬܥܒܕܝܢ ܠܟܠܗܘܢ ܒܢܝ ܐܢܫܐ ܡܛܠ ܐܠܗܐ ܠܡܠܟܐ ܡܛܠ ܫܘܠܛܢܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.14",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "1 Peter 2:14",
      "text": "ܘܠܕܝܢܐ ܡܛܠ ܕܡܢܗ ܡܫܬܕܪܝܢ ܠܬܒܥܬܐ ܕܡܤܟܠܢܐ ܘܠܬܫܒܘܚܬܐ ܕܥܒܕܝ ܛܒܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.15",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "1 Peter 2:15",
      "text": "ܕܗܟܢܐ ܗܘ ܨܒܝܢܐ ܕܐܠܗܐ ܕܒܥܒܕܝܟܘܢ ܫܦܝܪܐ ܬܤܟܪܘܢ ܦܘܡܐ ܕܤܟܠܐ ܗܢܘܢ ܕܠܐ ܝܕܥܝܢ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.16",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "1 Peter 2:16",
      "text": "ܐܝܟ ܒܢܝ ܚܐܪܐ ܘܠܐ ܐܝܟ ܐܢܫܐ ܕܥܒܝܕܐ ܠܗܘܢ ܚܐܪܘܬܗܘܢ ܬܚܦܝܬܐ ܠܒܝܫܘܬܗܘܢ ܐܠܐ ܐܝܟ ܥܒܕܘܗܝ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.17",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "1 Peter 2:17",
      "text": "ܠܟܠܢܫ ܝܩܪܘ ܠܐܚܝܟܘܢ ܐܚܒܘ ܘܡܢ ܐܠܗܐ ܕܚܠܘ ܘܠܡܠܟܐ ܝܩܪܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.18",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "1 Peter 2:18",
      "text": "ܘܐܝܠܝܢ ܥܒܕܐ ܕܐܝܬ ܒܟܘܢ ܐܫܬܥܒܕܘ ܠܡܪܝܟܘܢ ܒܕܚܠܬܐ ܠܐ ܒܠܚܘܕ ܠܛܒܐ ܘܠܡܟܝܟܐ ܐܠܐ ܐܦ ܠܩܫܝܐ ܘܠܥܤܩܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.19",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "1 Peter 2:19",
      "text": "ܠܗܠܝܢ ܓܝܪ ܐܝܬ ܠܗܘܢ ܛܝܒܘܬܐ ܩܕܡ ܐܠܗܐ ܠܐܝܠܝܢ ܕܡܛܠ ܬܐܪܬܐ ܫܦܝܪܬܐ ܡܤܝܒܪܝܢ ܥܩܬܐ ܕܐܬܝܢ ܥܠܝܗܘܢ ܒܥܘܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.20",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "1 Peter 2:20",
      "text": "ܐܝܠܝܢ ܕܝܢ ܕܡܛܠ ܤܟܠܘܬܗܘܢ ܡܤܝܒܪܝܢ ܐܘܠܨܢܐ ܐܝܕܐ ܬܫܒܘܚܬܐ ܗܘܝܐ ܠܗܘܢ ܐܠܐ ܡܐ ܕܥܒܕܝܢ ܐܢܬܘܢ ܕܫܦܝܪ ܘܐܠܨܝܢ ܠܟܘܢ ܘܡܤܝܒܪܝܢ ܐܢܬܘܢ ܗܝܕܝܢ ܝܪܒܐ ܬܫܒܘܚܬܟܘܢ ܠܘܬ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.21",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "1 Peter 2:21",
      "text": "ܠܗܕܐ ܓܝܪ ܐܬܩܪܝܬܘܢ ܕܐܦ ܡܫܝܚܐ ܡܝܬ ܚܠܦܝܢ ܘܫܒܩ ܠܢ ܗܢܐ ܛܘܦܤܐ ܕܐܢܬܘܢ ܒܥܩܒܬܗ ܬܗܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.22",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "1 Peter 2:22",
      "text": "ܗܘ ܕܠܐ ܥܒܕ ܚܛܝܬܐ ܐܦܠܐ ܢܟܠܐ ܐܫܬܟܚ ܒܦܘܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.23",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "1 Peter 2:23",
      "text": "ܗܘ ܕܡܨܛܚܐ ܗܘܐ ܘܠܐ ܡܨܚܐ ܘܚܐܫ ܗܘܐ ܘܠܐ ܡܬܠܚܡ ܐܠܐ ܡܫܠܡ ܗܘܐ ܕܝܢܗ ܠܕܝܢܐ ܕܟܐܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.24",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "1 Peter 2:24",
      "text": "ܘܫܩܠ ܚܛܗܝܢ ܟܠܗܘܢ ܘܐܤܩ ܐܢܘܢ ܒܦܓܪܗ ܠܨܠܝܒܐ ܕܟܕ ܡܝܬܝܢܢ ܠܚܛܝܬܐ ܒܙܕܝܩܘܬܐ ܕܝܠܗ ܢܚܐ ܒܫܘܡܬܗ ܓܝܪ ܐܬܐܤܝܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.2.25",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "1 Peter 2:25",
      "text": "ܕܛܥܝܢ ܗܘܝܬܘܢ ܐܝܟ ܥܪܒܐ ܘܐܬܦܢܝܬܘܢ ܗܫܐ ܠܘܬ ܪܥܝܐ ܘܤܥܘܪܐ ܕܢܦܫܬܟܘܢ ܀",
      "paragraphStart": false
    }
  ]
}
