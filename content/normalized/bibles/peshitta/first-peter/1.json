{
  "chapter": {
    "id": "peshitta:first-peter.1",
    "translationId": "peshitta",
    "bookSlug": "first-peter",
    "chapterNumber": 1,
    "referenceLabel": "1 Peter 1",
    "summary": "Source text for 1 Peter 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:first-peter.1.1",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "1 Peter 1:1",
      "text": "ܦܛܪܘܤ ܫܠܝܚܐ ܕܝܫܘܥ ܡܫܝܚܐ ܠܓܒܝܐ ܘܬܘܬܒܐ ܕܙܪܝܥܝܢ ܒܦܢܛܘܤ ܘܒܓܠܛܝܐ ܘܒܩܦܘܕܩܝܐ ܘܒܐܤܝܐ ܘܒܒܝܬܘܢܝܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-peter.1.2",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "1 Peter 1:2",
      "text": "ܐܝܠܝܢ ܕܐܬܓܒܝܘ ܒܡܩܕܡܘܬ ܝܕܥܬܗ ܕܐܠܗܐ ܐܒܐ ܒܩܕܝܫܘܬܐ ܕܪܘܚܐ ܕܢܗܘܘܢ ܠܡܫܡܥܬܐ ܘܠܪܤܤ ܕܡܗ ܕܝܫܘܥ ܡܫܝܚܐ ܛܝܒܘܬܐ ܘܫܠܡܐ ܢܤܓܐ ܠܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.3",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "1 Peter 1:3",
      "text": "ܡܒܪܟ ܗܘ ܐܠܗܐ ܐܒܘܗܝ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܗܘ ܕܒܚܢܢܗ ܤܓܝܐܐ ܐܘܠܕܢ ܡܢ ܕܪܝܫ ܒܩܝܡܬܗ ܕܝܫܘܥ ܡܫܝܚܐ ܠܤܒܪܐ ܕܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.4",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "1 Peter 1:4",
      "text": "ܘܠܝܪܬܘܬܐ ܕܠܐ ܡܬܚܒܠܐ ܘܠܐ ܡܬܛܢܦܐ ܘܠܐ ܚܡܝܐ ܗܝ ܕܡܛܝܒܐ ܠܟܘܢ ܒܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.5",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "1 Peter 1:5",
      "text": "ܟܕ ܢܛܝܪܝܢ ܐܢܬܘܢ ܒܚܝܠܐ ܕܐܠܗܐ ܘܒܗܝܡܢܘܬܐ ܠܚܝܐ ܕܡܛܝܒܝܢ ܕܢܬܓܠܘܢ ܠܙܒܢܐ ܐܚܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.6",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "1 Peter 1:6",
      "text": "ܕܒܗܘܢ ܬܚܕܘܢ ܠܥܠܡ ܐܦܢ ܒܗܢܐ ܙܒܢܐ ܩܠܝܠ ܡܬܬܥܝܩܝܢ ܐܢܬܘܢ ܒܢܤܝܘܢܐ ܡܫܚܠܦܐ ܕܥܕܝܢ ܥܠܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.7",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "1 Peter 1:7",
      "text": "ܐܝܟܢܐ ܕܒܘܚܪܢܐ ܕܗܝܡܢܘܬܟܘܢ ܢܬܚܙܐ ܕܡܝܬܪ ܡܢ ܕܗܒܐ ܤܢܝܢܐ ܕܐܬܒܩܝ ܒܢܘܪܐ ܠܬܫܒܘܚܬܐ ܘܠܐܝܩܪܐ ܘܠܩܘܠܤܐ ܒܓܠܝܢܗ ܕܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.8",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "1 Peter 1:8",
      "text": "ܗܘ ܕܠܐ ܚܙܝܬܘܢܝܗܝ ܘܡܚܒܝܢ ܐܢܬܘܢ ܠܗ ܘܒܗܝܡܢܘܬܗ ܪܘܙܝܢ ܐܢܬܘܢ ܒܚܕܘܬܐ ܡܫܒܚܬܐ ܕܠܐ ܡܬܡܠܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.9",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "1 Peter 1:9",
      "text": "ܕܬܩܒܠܘܢ ܦܘܪܥܢܐ ܕܗܝܡܢܘܬܟܘܢ ܚܝܐ ܕܢܦܫܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.10",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "1 Peter 1:10",
      "text": "ܗܢܘܢ ܚܝܐ ܕܥܩܒܘ ܗܘܘ ܥܠܝܗܘܢ ܢܒܝܐ ܟܕ ܐܬܢܒܝܘ ܥܠ ܛܝܒܘܬܐ ܕܥܬܝܕܐ ܗܘܬ ܕܬܬܝܗܒ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.11",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "1 Peter 1:11",
      "text": "ܘܒܨܘ ܕܒܐܝܢܐ ܙܒܢܐ ܡܚܘܝܐ ܘܡܤܗܕܐ ܪܘܚܗ ܕܡܫܝܚܐ ܕܥܡܪܐ ܒܗܘܢ ܕܥܬܝܕܝܢ ܚܫܘܗܝ ܕܡܫܝܚܐ ܘܬܫܒܘܚܬܗ ܕܡܢ ܒܬܪܟܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.12",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "1 Peter 1:12",
      "text": "ܘܐܬܓܠܝ ܠܗܘܢ ܟܠ ܕܒܨܝܢ ܗܘܘ ܡܛܠ ܕܠܘ ܠܢܦܫܗܘܢ ܒܥܝܢ ܗܘܘ ܐܠܐ ܠܢ ܕܝܠܢ ܡܬܢܒܝܢ ܗܘܘ ܐܝܠܝܢ ܕܗܫܐ ܐܬܓܠܝ ܠܟܘܢ ܒܝܕ ܐܝܠܝܢ ܕܤܒܪܢܟܘܢ ܒܪܘܚܐ ܕܩܘܕܫܐ ܕܐܫܬܕܪ ܡܢ ܫܡܝܐ ܕܒܗܝܢ ܒܗܠܝܢ ܡܬܪܓܪܓܝܢ ܐܦ ܡܠܐܟܐ ܕܢܕܝܩܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.13",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "1 Peter 1:13",
      "text": "ܡܛܠ ܗܢܐ ܚܙܘܩܘ ܚܨܐ ܕܬܪܥܝܬܟܘܢ ܘܐܬܬܥܝܪܘ ܓܡܝܪܐܝܬ ܘܤܒܪܘ ܥܠ ܚܕܘܬܐ ܕܐܬܝܐ ܠܟܘܢ ܒܓܠܝܢܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.14",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "1 Peter 1:14",
      "text": "ܐܝܟ ܒܢܝܐ ܡܫܬܡܥܢܐ ܘܠܐ ܬܫܬܘܬܦܘܢ ܬܘܒ ܠܪܓܝܓܬܟܘܢ ܩܕܡܝܬܐ ܐܝܠܝܢ ܕܪܓܝܢ ܗܘܝܬܘܢ ܕܠܐ ܒܝܕܥܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.15",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "1 Peter 1:15",
      "text": "ܐܠܐ ܗܘܘ ܩܕܝܫܝܢ ܒܟܠܗܘܢ ܗܘܦܟܝܟܘܢ ܐܝܟ ܕܩܕܝܫ ܗܘ ܡܢ ܕܩܪܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.16",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "1 Peter 1:16",
      "text": "ܡܛܠ ܕܟܬܝܒ ܕܗܘܝܬܘܢ ܩܕܝܫܝܢ ܐܝܟܢܐ ܕܐܦ ܐܢܐ ܩܕܝܫ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.17",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "1 Peter 1:17",
      "text": "ܘܐܢ ܗܘ ܕܐܒܐ ܩܪܝܢ ܐܢܬܘܢ ܗܘ ܕܠܝܬ ܩܕܡܘܗܝ ܡܤܒ ܒܐܦܐ ܘܕܐܢ ܠܟܠܢܫ ܐܝܟ ܥܒܕܘܗܝ ܒܕܚܠܬܐ ܐܬܕܒܪܘ ܒܙܒܢܐ ܗܢܐ ܕܬܘܬܒܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.18",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "1 Peter 1:18",
      "text": "ܟܕ ܝܕܥܝܢ ܐܢܬܘܢ ܕܠܐ ܒܟܤܦܐ ܕܒܠܐ ܘܠܐ ܒܕܗܒܐ ܐܬܦܪܩܬܘܢ ܡܢ ܥܒܕܝܟܘܢ ܤܪܝܩܐ ܗܢܘܢ ܕܩܒܠܬܘܢ ܡܢ ܐܒܗܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.19",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "1 Peter 1:19",
      "text": "ܐܠܐ ܒܕܡܐ ܝܩܝܪܐ ܕܐܡܪܐ ܕܡܘܡܐ ܘܛܘܠܫܐ ܠܝܬ ܒܗ ܕܐܝܬܘܗܝ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.20",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "1 Peter 1:20",
      "text": "ܗܘ ܕܡܩܕܡ ܗܘܐ ܦܪܝܫ ܠܗܕܐ ܡܢ ܩܕܡ ܬܪܡܝܬܗ ܕܥܠܡܐ ܘܐܬܓܠܝ ܒܐܚܪܝܬܗܘܢ ܕܙܒܢܐ ܡܛܠܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.21",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "1 Peter 1:21",
      "text": "ܐܝܠܝܢ ܕܒܐܝܕܗ ܗܝܡܢܬܘܢ ܒܐܠܗܐ ܗܘ ܕܐܩܝܡܗ ܡܢ ܒܝܬ ܡܝܬܐ ܘܝܗܒ ܠܗ ܫܘܒܚܐ ܕܗܝܡܢܘܬܟܘܢ ܘܤܒܪܟܘܢ ܢܗܘܐ ܥܠ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.22",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "1 Peter 1:22",
      "text": "ܟܕ ܢܗܘܝܢ ܩܕܝܫܢ ܢܦܫܬܟܘܢ ܒܡܫܬܡܥܢܘܬܗ ܕܫܪܪܐ ܘܢܗܘܝܢ ܡܠܝܢ ܚܘܒܐ ܕܠܐ ܡܤܒ ܒܐܦܐ ܕܡܢ ܠܒܐ ܕܟܝܐ ܘܓܡܝܪܐ ܬܗܘܘܢ ܡܚܒܝܢ ܚܕ ܠܚܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.23",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "1 Peter 1:23",
      "text": "ܐܝܟ ܐܢܫܐ ܕܡܢ ܕܪܝܫ ܐܬܝܠܕܬܘܢ ܠܐ ܡܢ ܙܪܥܐ ܕܒܠܐ ܐܠܐ ܡܢ ܐܝܢܐ ܕܠܐ ܒܠܐ ܒܡܠܬܐ ܚܝܬܐ ܕܐܠܗܐ ܕܩܝܡܐ ܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.24",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "1 Peter 1:24",
      "text": "ܡܛܠ ܕܟܠ ܒܤܪ ܥܡܝܪܐ ܘܟܠܗ ܝܐܝܘܬܗ ܐܝܟ ܥܘܦܝܐ ܕܚܩܠܐ ܝܒܫ ܥܡܝܪܐ ܘܚܡܐ ܥܘܦܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.1.25",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "1 Peter 1:25",
      "text": "ܘܡܠܬܗ ܕܐܠܗܢ ܩܝܡܐ ܠܥܠܡܝܢ ܘܗܕܐ ܗܝ ܡܠܬܐ ܗܝ ܕܐܤܬܒܪܬܘܢ ܀",
      "paragraphStart": false
    }
  ]
}
