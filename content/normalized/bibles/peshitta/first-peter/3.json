    "bookSlug": "first-peter",
    "chapterNumber": 3,
    "referenceLabel": "1 Peter 3",
    "summary": "Source text for 1 Peter 3 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:first-peter.3.1",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "1 Peter 3:1",
      "text": "ܗܟܢܐ ܐܦ ܐܢܬܝܢ ܢܫܐ ܐܫܬܥܒܕܝܢ ܠܒܥܠܝܟܝܢ ܕܐܝܠܝܢ ܕܠܐ ܡܬܛܦܝܤܝܢ ܠܡܠܬܐ ܒܕܘܒܪܝܟܝܢ ܫܦܝܪܐ ܕܠܐ ܥܡܠܐ ܬܩܢܝܢ ܐܢܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-peter.3.2",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "1 Peter 3:2",
      "text": "ܟܕ ܚܙܝܢ ܕܒܕܚܠܬܐ ܘܒܢܟܦܘܬܐ ܡܬܕܒܪܢ ܐܢܬܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.3",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "1 Peter 3:3",
      "text": "ܘܠܐ ܬܨܛܒܬܢ ܒܨܒܬܐ ܒܪܝܐ ܕܓܕܘܠܐ ܕܤܥܪܝܟܝܢ ܐܘ ܕܚܫܠܬܐ ܕܕܗܒܐ ܐܘ ܕܠܒܘܫܐ ܡܝܬܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.4",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "1 Peter 3:4",
      "text": "ܐܠܐ ܐܨܛܒܬܝܢ ܒܒܪܢܫܐ ܟܤܝܐ ܕܠܒܐ ܒܪܘܚܐ ܡܟܝܟܬܐ ܕܠܐ ܡܬܚܒܠܐ ܨܒܬܐ ܕܡܝܬܪ ܩܕܡ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.5",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "1 Peter 3:5",
      "text": "ܗܟܢܐ ܓܝܪ ܐܦ ܡܢ ܩܕܝܡ ܢܫܐ ܩܕܝܫܬܐ ܐܝܠܝܢ ܕܡܤܒܪܢ ܗܘܝ ܒܐܠܗܐ ܡܨܒܬܢ ܗܘܝ ܢܦܫܬܗܝܢ ܘܡܫܬܥܒܕܢ ܗܘܝ ܠܒܥܠܝܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.6",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "1 Peter 3:6",
      "text": "ܐܝܟܢܐ ܕܤܪܐ ܡܫܬܥܒܕܐ ܗܘܬ ܠܐܒܪܗܡ ܘܩܪܝܐ ܗܘܬ ܠܗ ܡܪܝ ܗܝ ܕܗܘܝܢ ܐܢܬܝܢ ܠܗ ܒܢܬܐ ܒܥܒܕܐ ܛܒܐ ܟܕ ܠܐ ܡܬܬܙܝܥܢ ܐܢܬܝܢ ܡܢ ܟܠ ܕܚܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.7",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "1 Peter 3:7",
      "text": "ܘܐܢܬܘܢ ܓܒܪܐ ܗܟܢܐ ܥܡܪܘ ܥܡ ܢܫܝܟܘܢ ܒܝܕܥܬܐ ܘܐܝܟ ܕܠܡܐܢܐ ܡܚܝܠܐ ܒܐܝܩܪܐ ܐܚܘܕܘ ܐܢܝܢ ܡܛܠ ܕܐܦ ܗܢܝܢ ܥܡܟܘܢ ܝܪܬܢ ܡܘܗܒܬܐ ܕܚܝܐ ܕܠܥܠܡ ܕܠܐ ܬܗܘܘܢ ܡܬܬܩܠܝܢ ܒܨܠܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.8",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "1 Peter 3:8",
      "text": "ܫܘܠܡܐ ܕܝܢ ܕܬܗܘܘܢ ܟܠܟܘܢ ܒܐܘܝܘܬܐ ܘܗܘܝܬܘܢ ܚܫܝܢ ܥܡ ܐܝܠܝܢ ܕܚܫܝܢ ܘܪܚܡܝܢ ܚܕ ܠܚܕ ܘܗܘܝܬܘܢ ܪܚܡܬܢܝܢ ܘܡܟܝܟܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.9",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "1 Peter 3:9",
      "text": "ܘܠܐܢܫ ܒܝܫܬܐ ܚܠܦ ܒܝܫܬܐ ܠܐ ܬܦܪܥܘܢ ܘܐܦܠܐ ܨܘܚܝܬܐ ܚܠܦ ܨܘܚܝܬܐ ܐܠܐ ܕܠܩܘܒܠܐ ܕܗܠܝܢ ܗܘܝܬܘܢ ܡܒܪܟܝܢ ܠܗܕܐ ܓܝܪ ܐܬܩܪܝܬܘܢ ܕܒܘܪܟܬܐ ܬܐܪܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.10",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "1 Peter 3:10",
      "text": "ܡܢ ܕܨܒܐ ܗܟܝܠ ܚܝܐ ܘܪܚܡ ܝܘܡܬܐ ܛܒܐ ܠܡܚܙܐ ܢܛܪ ܠܫܢܗ ܡܢ ܒܝܫܬܐ ܘܤܦܘܬܗ ܠܐ ܢܡܠܠܢ ܢܟܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.11",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "1 Peter 3:11",
      "text": "ܢܥܒܪ ܡܢ ܒܝܫܬܐ ܘܢܥܒܕ ܛܒܬܐ ܘܢܒܥܐ ܫܠܡܐ ܘܢܪܗܛ ܒܬܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.12",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "1 Peter 3:12",
      "text": "ܡܛܠ ܕܥܝܢܘܗܝ ܕܡܪܝܐ ܥܠ ܙܕܝܩܐ ܘܐܕܢܘܗܝ ܠܡܫܡܥ ܐܢܘܢ ܘܐܦܘܗܝ ܕܡܪܝܐ ܥܠ ܒܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.13",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "1 Peter 3:13",
      "text": "ܘܡܢܘ ܕܢܥܒܕ ܠܟܘܢ ܒܝܫܬܐ ܐܢ ܬܗܘܘܢ ܛܢܢܐ ܕܛܒܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.14",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "1 Peter 3:14",
      "text": "ܘܐܢ ܗܘ ܕܬܚܫܘܢ ܥܠ ܐܦܝ ܟܐܢܘܬܐ ܛܘܒܝܟܘܢ ܘܠܐ ܬܕܚܠܘܢ ܡܢ ܐܝܠܝܢ ܕܡܕܚܠܝܢ ܠܟܘܢ ܘܠܐ ܬܫܬܓܫܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.15",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "1 Peter 3:15",
      "text": "ܐܠܐ ܩܕܫܘ ܒܠܒܘܬܟܘܢ ܠܡܪܝܐ ܡܫܝܚܐ ܘܗܘܝܬܘܢ ܡܛܝܒܝܢ ܠܡܦܩ ܒܪܘܚܐ ܠܟܠ ܕܬܒܥ ܠܟܘܢ ܡܠܬܐ ܥܠ ܤܒܪܐ ܕܗܝܡܢܘܬܟܘܢ ܒܡܟܝܟܘܬܐ ܘܒܕܚܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.16",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "1 Peter 3:16",
      "text": "ܟܕ ܐܝܬ ܠܟܘܢ ܬܐܪܬܐ ܛܒܬܐ ܐܝܟܢܐ ܕܗܢܘܢ ܕܡܡܠܠܝܢ ܥܠܝܟܘܢ ܐܝܟ ܕܥܠ ܐܢܫܐ ܒܝܫܐ ܢܒܗܬܘܢ ܐܝܟ ܐܢܫܐ ܕܛܠܡܝܢ ܠܕܘܒܪܝܟܘܢ ܫܦܝܪܐ ܕܒܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.17",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "1 Peter 3:17",
      "text": "ܥܕܪܐ ܗܝ ܠܟܘܢ ܓܝܪ ܕܟܕ ܥܒܕܝܢ ܐܢܬܘܢ ܥܒܕܐ ܛܒܐ ܬܤܒܠܘܢ ܒܝܫܬܐ ܐܢ ܗܟܢܐ ܗܘ ܨܒܝܢܐ ܕܐܠܗܐ ܘܠܐ ܟܕ ܥܒܕܝܢ ܐܢܬܘܢ ܒܝܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.18",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "1 Peter 3:18",
      "text": "ܡܛܠ ܕܐܦ ܡܫܝܚܐ ܚܕܐ ܙܒܢ ܡܝܬ ܚܠܦ ܚܛܗܝܢ ܙܕܝܩܐ ܚܠܦ ܚܛܝܐ ܕܢܩܪܒܟܘܢ ܠܐܠܗܐ ܘܡܝܬ ܒܦܓܪ ܘܚܝܐ ܒܪܘܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.19",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "1 Peter 3:19",
      "text": "ܘܐܟܪܙ ܠܢܦܫܬܐ ܐܝܠܝܢ ܕܐܚܝܕܢ ܗܘܝ ܒܫܝܘܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.20",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "1 Peter 3:20",
      "text": "ܗܠܝܢ ܕܡܢ ܩܕܝܡ ܠܐ ܐܬܛܦܝܤ ܗܘܝ ܒܝܘܡܬܗ ܕܢܘܚ ܟܕ ܡܓܪܬ ܪܘܚܗ ܕܐܠܗܐ ܦܩܕܬ ܕܬܗܘܐ ܩܒܘܬܐ ܥܠ ܤܒܪܐ ܕܬܝܒܘܬܗܘܢ ܘܬܡܢܐ ܒܠܚܘܕ ܢܦܫܢ ܥܠܝܢ ܠܗ ܘܚܝܝ ܒܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.21",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "1 Peter 3:21",
      "text": "ܕܐܦ ܐܢܬܘܢ ܒܗ ܒܗܘ ܛܘܦܤܐ ܚܝܝܢ ܐܢܬܘܢ ܒܡܥܡܘܕܝܬܐ ܠܘ ܟܕ ܦܓܪܐ ܡܫܝܓܝܢ ܐܢܬܘܢ ܡܢ ܨܐܬܐ ܐܠܐ ܟܕ ܡܘܕܝܢ ܐܢܬܘܢ ܒܐܠܗܐ ܒܬܐܪܬܐ ܕܟܝܬܐ ܘܒܩܝܡܬܗ ܕܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.3.22",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "1 Peter 3:22",
      "text": "ܗܘ ܕܐܬܥܠܝ ܠܫܡܝܐ ܘܐܝܬܘܗܝ ܥܠ ܝܡܝܢܐ ܕܐܠܗܐ ܘܐܫܬܥܒܕܘ ܠܗ ܡܠܐܟܐ ܘܫܠܝܛܢܐ ܘܚܝܠܘܬܐ ܀",
      "paragraphStart": false
    }
  ]
}
