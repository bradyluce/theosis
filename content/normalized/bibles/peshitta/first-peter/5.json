  "verses": [
    {
      "id": "peshitta:first-peter.5.1",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "1 Peter 5:1",
      "text": "ܒܥܐ ܐܢܐ ܕܝܢ ܡܢ ܩܫܝܫܐ ܕܐܝܬ ܒܟܘܢ ܐܢܐ ܩܫܝܫܐ ܚܒܪܟܘܢ ܘܤܗܕܐ ܕܚܫܘܗܝ ܕܡܫܝܚܐ ܘܫܘܬܦܐ ܕܫܘܒܚܗ ܗܘ ܕܥܬܝܕ ܕܢܬܓܠܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-peter.5.2",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "1 Peter 5:2",
      "text": "ܪܥܘ ܡܪܥܝܬܐ ܕܐܠܗܐ ܕܡܫܠܡܐ ܠܟܘܢ ܘܤܥܘܪܘ ܪܘܚܢܐܝܬ ܠܐ ܒܩܛܝܪܐ ܐܠܐ ܒܨܒܝܢܐ ܠܐ ܒܝܘܬܪܢܐ ܛܢܦܐ ܐܠܐ ܡܢ ܟܠܗ ܠܒܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.5.3",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "1 Peter 5:3",
      "text": "ܠܐ ܐܝܟ ܡܪܝܐ ܕܡܪܥܝܬܐ ܐܠܐ ܐܝܟ ܕܬܗܘܘܢ ܠܗܘܢ ܕܡܘܬܐ ܫܦܝܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.5.4",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "1 Peter 5:4",
      "text": "ܕܟܕ ܢܬܓܠܐ ܪܒ ܪܥܘܬܐ ܬܩܒܠܘܢ ܡܢܗ ܟܠܝܠܐ ܕܫܘܒܚܐ ܕܠܐ ܚܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.5.5",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "1 Peter 5:5",
      "text": "ܘܐܢܬܘܢ ܥܠܝܡܐ ܐܫܬܥܒܕܘ ܠܩܫܝܫܝܟܘܢ ܘܐܬܥܛܦܘ ܚܝܨܐܝܬ ܡܟܝܟܘܬ ܪܥܝܢܐ ܠܘܬ ܚܕܕܐ ܡܛܠ ܕܐܠܗܐ ܤܩܘܒܠܐ ܗܘ ܕܐܝܠܝܢ ܕܡܬܬܪܝܡܝܢ ܘܠܡܟܝܟܐ ܝܗܒ ܛܝܒܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.5.6",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "1 Peter 5:6",
      "text": "ܐܬܡܟܟܘ ܗܟܝܠ ܬܚܝܬ ܐܝܕܗ ܬܩܝܦܬܐ ܕܐܠܗܐ ܕܗܝ ܬܪܝܡܟܘܢ ܒܙܒܢܐ ܕܙܕܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.5.7",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "1 Peter 5:7",
      "text": "ܘܨܦܬܟܘܢ ܟܠܗ ܫܕܘ ܥܠ ܐܠܗܐ ܕܠܗ ܒܛܝܠ ܥܠܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.5.8",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "1 Peter 5:8",
      "text": "ܐܬܬܥܝܪܘ ܘܥܗܕܘ ܡܛܠ ܕܒܥܠܕܒܒܟܘܢ ܤܛܢܐ ܐܝܟ ܐܪܝܐ ܢܗܡ ܘܡܗܠܟ ܘܒܥܐ ܕܠܡܢܘ ܢܒܠܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.5.9",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "1 Peter 5:9",
      "text": "ܩܘܡܘ ܗܟܝܠ ܠܩܘܒܠܗ ܟܕ ܡܫܪܪܝܢ ܐܢܬܘܢ ܒܗܝܡܢܘܬܐ ܘܕܥܘ ܕܐܦ ܥܠ ܐܚܝܟܘܢ ܕܒܥܠܡܐ ܗܢܘܢ ܗܠܝܢ ܚܫܐ ܥܪܨܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.5.10",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "1 Peter 5:10",
      "text": "ܐܠܗܐ ܕܝܢ ܕܛܝܒܘܬܐ ܗܘ ܕܩܪܢ ܠܫܘܒܚܗ ܕܠܥܠܡ ܒܝܕ ܝܫܘܥ ܡܫܝܚܐ ܗܘ ܕܝܗܒ ܠܢ ܕܟܕ ܢܤܝܒܪ ܗܠܝܢ ܐܘܠܨܢܐ ܙܥܘܪܐ ܕܢܬܚܝܠ ܘܢܫܬܪܪ ܘܢܬܩܝܡ ܒܗ ܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.5.11",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "1 Peter 5:11",
      "text": "ܕܠܗ ܫܘܒܚܐ ܘܐܘܚܕܢܐ ܘܐܝܩܪܐ ܠܥܠܡ ܥܠܡܝܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.5.12",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "1 Peter 5:12",
      "text": "ܗܠܝܢ ܙܥܘܪܝܬܐ ܐܝܟ ܕܤܒܪ ܐܢܐ ܟܬܒܬ ܠܟܘܢ ܒܝܕ ܤܠܘܢܘܤ ܐܚܐ ܡܗܝܡܢܐ ܘܡܦܤ ܐܢܐ ܘܤܗܕ ܐܢܐ ܕܗܕܐ ܗܝ ܛܝܒܘܬܐ ܫܪܝܪܬܐ ܕܐܠܗܐ ܗܕܐ ܕܩܝܡܝܢ ܐܢܬܘܢ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.5.13",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "1 Peter 5:13",
      "text": "ܫܐܠܐ ܫܠܡܟܘܢ ܥܕܬܐ ܓܒܝܬܐ ܕܒܒܒܠ ܘܡܪܩܘܤ ܒܪܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.5.14",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "1 Peter 5:14",
      "text": "ܫܐܠܘ ܒܫܠܡܐ ܚܕ ܕܚܕ ܒܢܘܫܩܬܐ ܩܕܝܫܬܐ ܫܠܡܐ ܥܡ ܟܠܗܘܢ ܐܝܠܝܢ ܕܒܡܫܝܚܐ ܐܢܘܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
