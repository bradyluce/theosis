    "summary": "Source text for 1 Peter 4 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:first-peter.4.1",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "1 Peter 4:1",
      "text": "ܐܢ ܡܫܝܚܐ ܗܟܝܠ ܚܫ ܚܠܦܝܟܘܢ ܒܒܤܪ ܘܐܦ ܐܢܬܘܢ ܒܗ ܒܗܢܐ ܪܥܝܢܐ ܐܙܕܝܢܘ ܟܠܡܢ ܕܡܐܬ ܓܝܪ ܒܦܓܪܗ ܫܠܝ ܠܗ ܡܢ ܟܠܗܘܢ ܚܛܗܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-peter.4.2",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "1 Peter 4:2",
      "text": "ܕܠܐ ܡܟܝܠ ܠܪܓܝܓܬܐ ܕܒܢܝܢܫܐ ܢܚܐ ܟܡܐ ܙܒܢܐ ܕܐܝܬܘܗܝ ܒܦܓܪܐ ܐܠܐ ܠܨܒܝܢܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.4.3",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "1 Peter 4:3",
      "text": "ܤܦܩ ܓܝܪ ܙܒܢܐ ܗܘ ܕܥܒܪ ܕܦܠܚܬܘܢ ܒܗ ܨܒܝܢܐ ܕܚܢܦܐ ܒܐܤܘܛܘܬܐ ܘܒܪܘܝܘܬܐ ܘܒܨܚܢܘܬܐ ܘܒܙܡܪܐ ܘܒܦܘܠܚܢܐ ܕܫܐܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.4.4",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "1 Peter 4:4",
      "text": "ܘܗܐ ܗܫܐ ܡܬܕܡܪܝܢ ܘܡܓܕܦܝܢ ܥܠܝܟܘܢ ܒܕܠܐ ܡܫܬܪܚܝܬܘܢ ܥܡܗܘܢ ܒܗܝ ܐܤܘܛܘܬܐ ܩܕܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.4.5",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "1 Peter 4:5",
      "text": "ܗܢܘܢ ܕܝܗܒܝܢ ܦܬܓܡܐ ܠܐܠܗܐ ܗܘ ܕܥܬܝܕ ܠܡܕܢ ܡܝܬܐ ܘܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.4.6",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "1 Peter 4:6",
      "text": "ܡܛܠ ܗܢܐ ܓܝܪ ܐܤܬܒܪ ܐܦ ܠܡܝܬܐ ܕܢܬܕܝܢܘܢ ܐܝܟ ܒܢܝܢܫܐ ܒܒܤܪ ܘܢܚܘܢ ܒܐܠܗܐ ܒܪܘܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.4.7",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "1 Peter 4:7",
      "text": "ܡܛܝܬ ܠܗ ܕܝܢ ܚܪܬܐ ܕܟܠ ܡܛܠ ܗܢܐ ܐܬܢܟܦܘ ܘܐܬܬܥܝܪܘ ܠܨܠܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.4.8",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "1 Peter 4:8",
      "text": "ܘܩܕܡ ܟܠ ܡܕܡ ܚܘܒܐ ܚܪܝܦܐ ܠܘܬ ܚܕܕܐ ܢܗܘܐ ܠܟܘܢ ܚܘܒܐ ܓܝܪ ܡܚܦܐ ܤܘܓܐܐ ܕܚܛܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.4.9",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "1 Peter 4:9",
      "text": "ܘܗܘܝܬܘܢ ܪܚܡܝܢ ܐܟܤܢܝܐ ܕܠܐ ܪܛܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.4.10",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "1 Peter 4:10",
      "text": "ܘܟܠܢܫ ܡܢܟܘܢ ܡܘܗܒܬܐ ܕܩܒܠ ܡܢ ܐܠܗܐ ܢܫܡܫ ܒܗ ܠܚܒܪܘܗܝ ܐܝܟ ܪܒܝ ܒܬܐ ܛܒܐ ܕܛܝܒܘܬܐ ܡܦܪܫܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.4.11",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "1 Peter 4:11",
      "text": "ܟܠܡܢ ܕܡܡܠܠ ܐܝܟ ܡܠܬܐ ܕܐܠܗܐ ܢܡܠܠ ܘܟܠܡܢ ܕܡܫܡܫ ܐܝܟ ܕܡܢ ܚܝܠܐ ܗܘ ܕܐܠܗܐ ܝܗܒ ܠܗ ܕܒܟܠ ܕܥܒܕܝܢ ܐܢܬܘܢ ܢܫܬܒܚ ܐܠܗܐ ܒܝܕ ܝܫܘܥ ܡܫܝܚܐ ܗܘ ܕܕܝܠܗ ܗܝ ܬܫܒܘܚܬܐ ܘܐܝܩܪܐ ܠܥܠܡ ܥܠܡܝܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.4.12",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "1 Peter 4:12",
      "text": "ܚܒܝܒܝ ܠܐ ܬܬܕܡܪܘܢ ܒܢܤܝܘܢܐ ܕܗܘܝܢ ܠܟܘܢ ܐܝܟ ܕܡܕܡ ܢܘܟܪܝ ܓܕܫ ܠܟܘܢ ܡܛܠ ܕܠܒܘܚܪܢܟܘܢ ܗܘ ܗܘܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.4.13",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "1 Peter 4:13",
      "text": "ܐܠܐ ܚܕܘ ܕܡܫܬܘܬܦܝܢ ܐܢܬܘܢ ܠܚܫܘܗܝ ܕܡܫܝܚܐ ܕܗܟܢܐ ܐܦ ܒܓܠܝܢܐ ܕܬܫܒܘܚܬܗ ܬܚܕܘܢ ܘܬܪܘܙܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.4.14",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "1 Peter 4:14",
      "text": "ܘܐܢ ܡܬܚܤܕܝܢ ܐܢܬܘܢ ܥܠ ܐܦܝ ܫܡܗ ܕܡܫܝܚܐ ܛܘܒܝܟܘܢ ܕܪܘܚܐ ܡܫܒܚܬܐ ܕܐܠܗܐ ܡܬܬܢܝܚܐ ܥܠܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.4.15",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "1 Peter 4:15",
      "text": "ܒܠܚܘܕ ܠܐ ܐܢܫ ܡܢܟܘܢ ܐܝܟ ܩܛܘܠܐ ܐܘ ܐܝܟ ܓܢܒܐ ܐܘ ܐܝܟ ܥܒܕ ܒܝܫܬܐ ܢܗܘܐ ܚܐܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.4.16",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "1 Peter 4:16",
      "text": "ܐܢ ܕܝܢ ܚܐܫ ܐܝܟ ܟܪܤܛܝܢܐ ܠܐ ܢܒܗܬ ܐܠܐ ܢܫܒܚ ܠܐܠܗܐ ܒܗ ܒܗܢܐ ܫܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.4.17",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "1 Peter 4:17",
      "text": "ܡܛܠ ܕܙܒܢܐ ܗܘ ܕܢܫܪܐ ܕܝܢܐ ܡܢ ܒܝܬܗ ܕܐܠܗܐ ܐܢ ܕܝܢ ܡܢܢ ܡܫܪܐ ܐܝܕܐ ܗܝ ܚܪܬܐ ܕܐܝܠܝܢ ܕܠܐ ܡܬܛܦܝܤܝܢ ܠܤܒܪܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.4.18",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "1 Peter 4:18",
      "text": "ܘܐܢ ܙܕܝܩܐ ܠܡܚܤܢ ܚܝܐ ܪܫܝܥܐ ܘܚܛܝܐ ܐܝܟܐ ܡܫܬܟܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-peter.4.19",
      "translationId": "peshitta",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "1 Peter 4:19",
      "text": "ܡܛܠ ܗܢܐ ܐܝܠܝܢ ܕܚܫܝܢ ܐܝܟ ܨܒܝܢܗ ܕܐܠܗܐ ܢܓܥܠܘܢ ܠܗ ܢܦܫܬܗܘܢ ܒܥܒܕܐ ܫܦܝܪܐ ܐܝܟ ܕܠܒܪܘܝܐ ܡܗܝܡܢܐ ܀",
      "paragraphStart": false
    }
  ]
}
