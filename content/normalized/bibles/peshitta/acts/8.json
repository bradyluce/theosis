    "bookSlug": "acts",
    "chapterNumber": 8,
    "referenceLabel": "Acts 8",
    "summary": "Source text for Acts 8 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.8.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Acts 8:1",
      "text": "ܫܐܘܠ ܕܝܢ ܨܒܐ ܗܘܐ ܘܡܫܘܬܦ ܗܘܐ ܒܩܛܠܗ ܘܗܘܐ ܗܘܐ ܒܗܘ ܝܘܡܐ ܪܕܘܦܝܐ ܪܒܐ ܠܥܕܬܐ ܕܒܐܘܪܫܠܡ ܘܐܬܒܕܪܘ ܟܠܗܘܢ ܒܩܘܪܝܐ ܕܝܗܘܕ ܘܐܦ ܒܝܬ ܫܡܪܝܐ ܠܒܪ ܡܢ ܫܠܝܚܐ ܒܠܚܘܕ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.8.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Acts 8:2",
      "text": "ܘܩܦܤܘ ܩܒܪܘܗܝ ܠܐܤܛܦܢܘܤ ܓܒܪܐ ܡܗܝܡܢܐ ܘܐܬܐܒܠܘ ܥܠܘܗܝ ܪܘܪܒܐܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Acts 8:3",
      "text": "ܫܐܘܠ ܕܝܢ ܪܕܦ ܗܘܐ ܠܥܕܬܗ ܕܐܠܗܐ ܟܕ ܥܐܠ ܗܘܐ ܠܒܬܐ ܘܡܓܪܓܪ ܠܓܒܪܐ ܘܠܢܫܐ ܘܡܫܠܡܝܢ ܗܘܐ ܠܒܝܬ ܐܤܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Acts 8:4",
      "text": "ܘܗܢܘܢ ܕܐܬܒܕܪܘ ܡܬܟܪܟܝܢ ܗܘܘ ܘܡܟܪܙܝܢ ܡܠܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Acts 8:5",
      "text": "ܦܝܠܝܦܘܤ ܕܝܢ ܢܚܬ ܠܗ ܠܡܕܝܢܬܐ ܕܫܡܪܝܐ ܘܡܟܪܙ ܗܘܐ ܠܗܘܢ ܥܠ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Acts 8:6",
      "text": "ܘܟܕ ܫܡܥܝܢ ܗܘܘ ܡܠܬܗ ܒܢܝܢܫܐ ܕܬܡܢ ܨܝܬܝܢ ܗܘܘ ܠܗ ܘܡܬܛܦܝܤܝܢ ܗܘܘ ܠܟܠ ܕܐܡܪ ܗܘܐ ܕܚܙܝܢ ܗܘܘ ܐܬܘܬܐ ܕܥܒܕ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Acts 8:7",
      "text": "ܤܓܝܐܐ ܓܝܪ ܕܐܚܝܕܢ ܗܘܝ ܠܗܘܢ ܪܘܚܐ ܛܢܦܬܐ ܩܥܝܢ ܗܘܘ ܒܩܠܐ ܪܡܐ ܘܢܦܩܢ ܗܘܝ ܡܢܗܘܢ ܘܐܚܪܢܐ ܡܫܪܝܐ ܘܡܚܓܪܐ ܐܬܐܤܝܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Acts 8:8",
      "text": "ܘܚܕܘܬܐ ܪܒܬܐ ܗܘܬ ܒܗܝ ܡܕܝܢܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Acts 8:9",
      "text": "ܐܝܬ ܗܘܐ ܕܝܢ ܬܡܢ ܓܒܪܐ ܚܕ ܕܫܡܗ ܤܝܡܘܢ ܕܥܡܝܪ ܗܘܐ ܠܗ ܒܗ ܒܡܕܝܢܬܐ ܙܒܢܐ ܤܓܝܐܐ ܘܒܚܪܫܘܗܝ ܡܛܥܐ ܗܘܐ ܠܥܡܐ ܕܫܡܪܝܐ ܟܕ ܡܘܪܒ ܗܘܐ ܢܦܫܗ ܘܐܡܪ ܕܐܢܐ ܐܢܐ ܪܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Acts 8:10",
      "text": "ܘܨܠܝܢ ܗܘܘ ܠܘܬܗ ܟܠܗܘܢ ܪܘܪܒܐ ܘܕܩܕܩܐ ܘܐܡܪܝܢ ܗܘܘ ܗܢܘ ܚܝܠܗ ܪܒܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Acts 8:11",
      "text": "ܘܡܬܛܦܝܤܝܢ ܗܘܘ ܠܗ ܟܠܗܘܢ ܡܛܠ ܕܙܒܢܐ ܤܓܝܐܐ ܒܚܪܫܘܗܝ ܐܬܡܗ ܗܘܐ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Acts 8:12",
      "text": "ܟܕ ܕܝܢ ܗܝܡܢܘ ܠܦܝܠܝܦܘܤ ܕܡܤܒܪ ܗܘܐ ܡܠܟܘܬܐ ܕܐܠܗܐ ܒܫܡܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܥܡܕܝܢ ܗܘܘ ܓܒܪܐ ܘܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Acts 8:13",
      "text": "ܘܐܦ ܗܘ ܤܝܡܘܢ ܗܝܡܢ ܗܘܐ ܘܥܡܕ ܘܢܩܝܦ ܗܘܐ ܠܗ ܠܦܝܠܝܦܘܤ ܘܟܕ ܚܙܐ ܗܘܐ ܐܬܘܬܐ ܘܚܝܠܐ ܪܘܪܒܐ ܕܗܘܝܢ ܗܘܘ ܒܐܝܕܗ ܬܡܗ ܗܘܐ ܘܡܬܕܡܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Acts 8:14",
      "text": "ܘܟܕ ܫܡܥܘ ܫܠܝܚܐ ܕܒܐܘܪܫܠܡ ܕܩܒܠܘ ܥܡܐ ܕܫܡܪܝܐ ܡܠܬܐ ܕܐܠܗܐ ܫܕܪܘ ܠܘܬܗܘܢ ܠܫܡܥܘܢ ܟܐܦܐ ܘܠܝܘܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Acts 8:15",
      "text": "ܘܢܚܬܘ ܘܨܠܝܘ ܥܠܝܗܘܢ ܐܝܟ ܕܢܩܒܠܘܢ ܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Acts 8:16",
      "text": "ܠܝܬ ܗܘܐ ܓܝܪ ܥܠ ܚܕ ܡܢܗܘܢ ܥܕܟܝܠ ܒܠܚܘܕ ܕܝܢ ܥܡܕܝܢ ܗܘܘ ܒܫܡܗ ܕܡܪܢ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Acts 8:17",
      "text": "ܗܝܕܝܢ ܤܝܡܝܢ ܗܘܘ ܥܠܝܗܘܢ ܐܝܕܐ ܘܡܩܒܠܝܢ ܗܘܘ ܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Acts 8:18",
      "text": "ܘܟܕ ܚܙܐ ܤܝܡܘܢ ܕܒܤܝܡ ܐܝܕܐ ܕܫܠܝܚܐ ܡܬܝܗܒܐ ܪܘܚܐ ܕܩܘܕܫܐ ܩܪܒ ܠܗܘܢ ܟܤܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Acts 8:19",
      "text": "ܟܕ ܐܡܪ ܗܒܘ ܐܦ ܠܝ ܫܘܠܛܢܐ ܗܢܐ ܕܐܝܢܐ ܕܐܤܝܡ ܥܠܘܗܝ ܐܝܕܐ ܢܗܘܐ ܡܩܒܠ ܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "Acts 8:20",
      "text": "ܐܡܪ ܠܗ ܫܡܥܘܢ ܟܐܦܐ ܟܤܦܟ ܥܡܟ ܢܐܙܠ ܠܐܒܕܢܐ ܡܛܠ ܕܤܒܪܬ ܕܡܘܗܒܬܗ ܕܐܠܗܐ ܒܩܢܝܢ ܥܠܡܐ ܡܬܩܢܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "Acts 8:21",
      "text": "ܠܝܬ ܠܟ ܡܢܬܐ ܐܦܠܐ ܦܤܐ ܒܗܝܡܢܘܬܐ ܗܕܐ ܡܛܠ ܕܠܒܟ ܠܐ ܗܘܐ ܬܪܝܨ ܩܕܡ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "Acts 8:22",
      "text": "ܒܪܡ ܬܘܒ ܡܢ ܒܝܫܘܬܟ ܗܕܐ ܘܒܥܝ ܡܢ ܐܠܗܐ ܕܠܡܐ ܢܫܬܒܩ ܠܟ ܢܟܠܐ ܕܠܒܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "Acts 8:23",
      "text": "ܒܟܒܕܐ ܓܝܪ ܡܪܝܪܬܐ ܘܒܩܛܪܐ ܕܥܘܠܐ ܚܙܐ ܐܢܐ ܕܐܝܬܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "Acts 8:24",
      "text": "ܥܢܐ ܤܝܡܘܢ ܘܐܡܪ ܒܥܘ ܐܢܬܘܢ ܚܠܦܝ ܡܢ ܐܠܗܐ ܕܠܐ ܢܐܬܐ ܥܠܝ ܡܕܡ ܡܢ ܗܠܝܢ ܕܐܡܪܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 25,
      "referenceLabel": "Acts 8:25",
      "text": "ܫܡܥܘܢ ܕܝܢ ܘܝܘܚܢܢ ܟܕ ܤܗܕܘ ܐܢܘܢ ܘܐܠܦܘ ܡܠܬܐ ܕܐܠܗܐ ܗܦܟܘ ܠܗܘܢ ܠܐܘܪܫܠܡ ܘܒܩܘܪܝܐ ܤܓܝܐܬܐ ܕܫܡܪܝܐ ܤܒܪܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 26,
      "referenceLabel": "Acts 8:26",
      "text": "ܘܡܠܠ ܡܠܐܟܐ ܕܡܪܝܐ ܥܡ ܦܝܠܝܦܘܤ ܘܐܡܪ ܠܗ ܩܘܡ ܙܠ ܠܬܝܡܢܐ ܒܐܘܪܚܐ ܡܕܒܪܝܬܐ ܕܢܚܬܐ ܡܢ ܐܘܪܫܠܡ ܠܓܙܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 27,
      "referenceLabel": "Acts 8:27",
      "text": "ܘܩܡ ܐܙܠ ܘܐܪܥܗ ܡܗܝܡܢܐ ܚܕ ܕܐܬܐ ܗܘܐ ܡܢ ܟܘܫ ܫܠܝܛܐ ܕܩܢܕܩ ܡܠܟܬܐ ܕܟܘܫܝܐ ܘܗܘ ܫܠܝܛ ܗܘܐ ܥܠ ܟܠܗ ܓܙܗ ܘܐܬܐ ܗܘܐ ܕܢܤܓܘܕ ܒܐܘܪܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 28,
      "referenceLabel": "Acts 8:28",
      "text": "ܘܟܕ ܗܦܟ ܕܢܐܙܠ ܝܬܒ ܗܘܐ ܥܠ ܡܪܟܒܬܐ ܘܩܪܐ ܗܘܐ ܒܐܫܥܝܐ ܢܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.29",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 29,
      "referenceLabel": "Acts 8:29",
      "text": "ܘܐܡܪܬ ܪܘܚܐ ܠܦܝܠܝܦܘܤ ܐܬܩܪܒ ܘܩܦ ܠܡܪܟܒܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.30",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 30,
      "referenceLabel": "Acts 8:30",
      "text": "ܘܟܕ ܐܬܩܪܒ ܫܡܥ ܕܩܪܐ ܒܐܫܥܝܐ ܢܒܝܐ ܘܐܡܪ ܠܗ ܕܐܢ ܡܤܬܟܠ ܐܢܬ ܡܢܐ ܩܪܐ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.31",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 31,
      "referenceLabel": "Acts 8:31",
      "text": "ܘܗܘ ܐܡܪ ܐܝܟܢܐ ܡܫܟܚ ܐܢܐ ܕܐܤܬܟܠ ܐܠܐ ܐܢ ܐܢܫ ܢܪܬܝܢܝ ܘܒܥܐ ܡܢܗ ܡܢ ܦܝܠܝܦܘܤ ܕܢܤܩ ܘܢܬܒ ܥܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.32",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 32,
      "referenceLabel": "Acts 8:32",
      "text": "ܦܤܘܩܐ ܕܝܢ ܕܟܬܒܐ ܕܩܪܐ ܗܘܐ ܒܗ ܐܝܬܘܗܝ ܗܘܐ ܗܢܐ ܐܝܟ ܐܡܪܐ ܠܢܟܤܬܐ ܐܬܕܒܪ ܘܐܝܟ ܢܩܝܐ ܩܕܡ ܓܙܘܙܐ ܫܬܝܩ ܗܘܐ ܘܗܟܢܐ ܠܐ ܦܬܚ ܦܘܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.33",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 33,
      "referenceLabel": "Acts 8:33",
      "text": "ܒܡܘܟܟܗ ܡܢ ܚܒܘܫܝܐ ܘܡܢ ܕܝܢܐ ܐܬܕܒܪ ܘܕܪܗ ܡܢܘ ܢܫܬܥܐ ܕܡܫܬܩܠܝܢ ܚܝܘܗܝ ܡܢ ܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.34",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
      "verseNumber": 34,
      "referenceLabel": "Acts 8:34",
      "text": "ܘܐܡܪ ܗܘ ܡܗܝܡܢܐ ܠܦܝܠܝܦܘܤ ܒܥܐ ܐܢܐ ܡܢܟ ܥܠ ܡܢܘ ܐܡܪܗ ܗܕܐ ܢܒܝܐ ܥܠ ܢܦܫܗ ܐܘ ܥܠ ܐܢܫ ܐܚܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.8.35",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 8,
