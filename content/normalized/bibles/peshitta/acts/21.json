    "bookSlug": "acts",
    "chapterNumber": 21,
    "referenceLabel": "Acts 21",
    "summary": "Source text for Acts 21 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.21.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Acts 21:1",
      "text": "ܘܦܪܫܢ ܡܢܗܘܢ ܘܪܕܝܢ ܬܪܝܨܐܝܬ ܠܩܘ ܓܙܪܬܐ ܘܠܝܘܡܐ ܐܚܪܢܐ ܐܬܝܢ ܠܪܘܕܘܤ ܘܡܢ ܬܡܢ ܠܦܐܛܪܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.21.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Acts 21:2",
      "text": "ܘܐܫܟܚܢ ܬܡܢ ܐܠܦܐ ܕܐܙܠܐ ܠܦܘܢܝܩܐ ܘܤܠܩܢ ܠܗ ܘܪܕܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Acts 21:3",
      "text": "ܘܡܛܝܢ ܥܕܡܐ ܠܘܬ ܩܘܦܪܘܤ ܓܙܪܬܐ ܘܫܒܩܢܗ ܠܤܡܠܐ ܘܐܬܝܢ ܠܤܘܪܝܐ ܘܡܢ ܬܡܢ ܡܛܝܢ ܠܨܘܪ ܬܡܢ ܓܝܪ ܐܝܬ ܗܘܐ ܠܗ ܠܐܠܦܐ ܠܡܢܚܘ ܛܥܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Acts 21:4",
      "text": "ܘܟܕ ܐܫܟܚܢ ܬܡܢ ܬܠܡܝܕܐ ܩܘܝܢ ܠܘܬܗܘܢ ܝܘܡܬܐ ܫܒܥܐ ܘܗܠܝܢ ܐܡܪܝܢ ܗܘܘ ܟܠܝܘܡ ܠܦܘܠܘܤ ܒܪܘܚ ܕܠܐ ܢܐܙܠ ܠܐܘܪܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Acts 21:5",
      "text": "ܘܡܢ ܒܬܪ ܗܠܝܢ ܝܘܡܬܐ ܢܦܩܢ ܕܢܐܙܠ ܒܐܘܪܚܐ ܘܡܠܘܝܢ ܗܘܘ ܠܢ ܟܠܗܘܢ ܗܢܘܢ ܘܢܫܝܗܘܢ ܘܒܢܝܗܘܢ ܥܕܡܐ ܠܒܪ ܡܢ ܡܕܝܢܬܐ ܘܩܥܕܘ ܥܠ ܒܘܪܟܝܗܘܢ ܥܠ ܝܕ ܝܡܐ ܘܨܠܝܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Acts 21:6",
      "text": "ܘܢܫܩܢ ܠܚܕܕܐ ܘܤܠܩܢ ܠܐܠܦܐ ܘܗܦܟܘ ܗܢܘܢ ܠܒܬܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Acts 21:7",
      "text": "ܚܢܢ ܕܝܢ ܪܕܝܢ ܡܢ ܨܘܪ ܘܐܬܝܢ ܠܥܟܘ ܡܕܝܢܬܐ ܘܝܗܒܢ ܫܠܡܐ ܠܐܚܐ ܕܬܡܢ ܘܫܪܝܢ ܨܐܕܝܗܘܢ ܝܘܡܐ ܚܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Acts 21:8",
      "text": "ܘܠܝܘܡܐ ܐܚܪܢܐ ܢܦܩܢ ܘܐܬܝܢ ܠܩܤܪܝܐ ܘܥܠܢ ܫܪܝܢ ܒܒܝܬܗ ܕܦܝܠܝܦܘܤ ܡܤܒܪܢܐ ܐܝܢܐ ܕܐܝܬܘܗܝ ܗܘܐ ܡܢ ܫܒܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Acts 21:9",
      "text": "ܘܐܝܬ ܗܘܝ ܠܗ ܒܢܬܐ ܒܬܘܠܬܐ ܐܪܒܥ ܕܡܬܢܒܝܢ ܗܘܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Acts 21:10",
      "text": "ܘܟܕ ܐܝܬܝܢ ܬܡܢ ܝܘܡܬܐ ܤܓܝܐܐ ܢܚܬ ܗܘܐ ܡܢ ܝܗܘܕ ܢܒܝܐ ܚܕ ܕܫܡܗ ܗܘܐ ܐܓܒܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Acts 21:11",
      "text": "ܘܥܠ ܠܘܬܢ ܘܫܩܠ ܥܪܩܬܐ ܕܚܨܘܗܝ ܕܦܘܠܘܤ ܘܐܤܪ ܪܓܠܐ ܕܢܦܫܗ ܘܐܝܕܘܗܝ ܘܐܡܪ ܗܟܢܐ ܐܡܪ ܪܘܚܐ ܕܩܘܕܫܐ ܕܓܒܪܐ ܡܪܗ ܕܥܪܩܬܐ ܗܕܐ ܗܟܢܐ ܢܐܤܪܘܢܗ ܝܗܘܕܝܐ ܒܐܘܪܫܠܡ ܘܢܫܠܡܘܢܗ ܒܐܝܕܝ ܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Acts 21:12",
      "text": "ܘܟܕ ܗܠܝܢ ܡܠܐ ܫܡܥܢ ܒܥܝܢ ܡܢܗ ܚܢܢ ܘܒܢܝ ܐܬܪܐ ܕܠܐ ܢܐܙܠ ܠܐܘܪܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Acts 21:13",
      "text": "ܗܝܕܝܢ ܥܢܐ ܘܐܡܪ ܦܘܠܘܤ ܡܢܐ ܥܒܕܝܢ ܐܢܬܘܢ ܕܒܟܝܢ ܐܢܬܘܢ ܘܫܚܩܝܢ ܐܢܬܘܢ ܠܗ ܠܠܒܝ ܐܢܐ ܓܝܪ ܠܐ ܗܘܐ ܕܐܬܐܤܪ ܒܠܚܘܕ ܡܛܝܒ ܐܢܐ ܐܠܐ ܐܦ ܕܐܡܘܬ ܒܐܘܪܫܠܡ ܚܠܦ ܫܡܗ ܕܡܪܢ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Acts 21:14",
      "text": "ܘܟܕ ܠܐ ܐܬܛܦܝܤ ܠܢ ܒܗܠܢ ܠܢ ܘܐܡܪܢ ܕܨܒܝܢܗ ܕܡܪܢ ܢܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Acts 21:15",
      "text": "ܘܒܬܪ ܝܘܡܬܐ ܗܠܝܢ ܐܬܛܝܒܢ ܘܤܠܩܢ ܠܢ ܠܐܘܪܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Acts 21:16",
      "text": "ܘܐܬܘ ܗܘܘ ܥܡܢ ܐܢܫܐ ܬܠܡܝܕܐ ܡܢ ܩܤܪܝܐ ܟܕ ܕܒܝܪܝܢ ܥܡܗܘܢ ܐܚܐ ܚܕ ܡܢ ܬܠܡܝܕܐ ܩܕܡܝܐ ܕܫܡܗ ܗܘܐ ܡܢܤܘܢ ܘܐܝܬܘܗܝ ܗܘܐ ܡܢ ܩܘܦܪܘܤ ܕܢܩܒܠܢ ܒܒܝܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Acts 21:17",
      "text": "ܘܟܕ ܐܬܝܢ ܠܐܘܪܫܠܡ ܩܒܠܘܢ ܐܚܐ ܚܕܝܐܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Acts 21:18",
      "text": "ܘܠܝܘܡܐ ܐܚܪܢܐ ܥܠܢ ܥܡ ܦܘܠܘܤ ܠܘܬ ܝܥܩܘܒ ܟܕ ܐܝܬ ܗܘܐ ܠܘܬܗ ܟܠܗܘܢ ܩܫܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Acts 21:19",
      "text": "ܘܝܗܒܢ ܠܗܘܢ ܫܠܡܐ ܘܡܫܬܥܐ ܗܘܐ ܠܗܘܢ ܦܘܠܘܤ ܒܬܪ ܒܬܪ ܟܠ ܡܐ ܕܥܒܕ ܐܠܗܐ ܒܥܡܡܐ ܒܬܫܡܫܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Acts 21:20",
      "text": "ܘܟܕ ܫܡܥܘ ܫܒܚܘ ܠܐܠܗܐ ܘܐܡܪܘ ܠܗ ܚܙܐ ܐܢܬ ܐܚܘܢ ܟܡܐ ܪܒܘܢ ܐܝܬ ܒܝܗܘܕ ܐܝܠܝܢ ܕܗܝܡܢܘ ܘܟܠܗܘܢ ܗܠܝܢ ܛܢܢܐ ܐܢܘܢ ܕܢܡܘܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Acts 21:21",
      "text": "ܐܬܐܡܪ ܠܗܘܢ ܕܝܢ ܥܠܝܟ ܕܡܠܦ ܐܢܬ ܕܢܦܪܩܘܢ ܡܢ ܡܘܫܐ ܟܠܗܘܢ ܝܗܘܕܝܐ ܕܒܥܡܡܐ ܟܕ ܐܡܪ ܐܢܬ ܕܠܐ ܢܗܘܘܢ ܓܙܪܝܢ ܒܢܝܗܘܢ ܘܠܐ ܒܥܝܕܐ ܕܢܡܘܤܐ ܢܗܘܘܢ ܡܗܠܟܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Acts 21:22",
      "text": "ܡܛܠ ܗܟܝܠ ܕܡܫܬܡܥܐ ܗܝ ܠܗܘܢ ܕܐܬܝܬ ܠܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Acts 21:23",
      "text": "ܥܒܕ ܡܕܡ ܕܐܡܪܝܢܢ ܠܟ ܐܝܬ ܠܢ ܓܒܪܐ ܐܪܒܥܐ ܕܢܕܝܪ ܠܗܘܢ ܕܢܬܕܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Acts 21:24",
      "text": "ܕܒܪ ܐܢܘܢ ܘܙܠ ܐܬܕܟܐ ܥܡܗܘܢ ܘܐܦܩ ܥܠܝܗܘܢ ܢܦܩܬܐ ܐܝܟ ܕܢܓܪܥܘܢ ܪܫܝܗܘܢ ܘܡܬܝܕܥܐ ܠܟܠܢܫ ܕܡܕܡ ܕܐܬܐܡܪ ܥܠܝܟ ܕܓܠ ܗܘ ܘܐܢܬ ܠܢܡܘܤܐ ܫܠܡ ܐܢܬ ܘܢܛܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Acts 21:25",
      "text": "ܥܠ ܐܝܠܝܢ ܕܝܢ ܕܗܝܡܢܘ ܡܢ ܥܡܡܐ ܚܢܢ ܟܬܒܢ ܕܢܗܘܘܢ ܢܛܪܝܢ ܢܦܫܗܘܢ ܡܢ ܕܕܒܝܚܐ ܘܡܢ ܙܢܝܘܬܐ ܘܡܢ ܚܢܝܩܐ ܘܡܢ ܕܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Acts 21:26",
      "text": "ܗܝܕܝܢ ܦܘܠܘܤ ܕܒܪ ܐܢܘܢ ܠܓܒܪܐ ܗܠܝܢ ܠܝܘܡܐ ܐܚܪܢܐ ܘܐܬܕܟܝ ܥܡܗܘܢ ܘܥܠ ܐܙܠ ܠܗܝܟܠܐ ܟܕ ܡܘܕܥ ܠܗܘܢ ܡܘܠܝܐ ܕܝܘܡܬܐ ܕܬܕܟܝܬܐ ܥܕܡܐ ܕܐܬܩܪܒ ܩܘܪܒܢܐ ܕܐܢܫ ܐܢܫ ܡܢܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Acts 21:27",
      "text": "ܘܟܕ ܡܛܝ ܝܘܡܐ ܕܫܒܥܐ ܝܗܘܕܝܐ ܕܡܢ ܐܤܝܐ ܚܙܐܘܗܝ ܒܗܝܟܠܐ ܘܓܪܝܘ ܥܠܘܗܝ ܥܡܐ ܟܠܗ ܘܐܪܡܝܘ ܥܠܘܗܝ ܐܝܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Acts 21:28",
      "text": "ܟܕ ܡܒܓܢܝܢ ܘܐܡܪܝܢ ܓܒܪܐ ܒܢܝ ܐܝܤܪܝܠ ܥܕܪܘ ܗܢܐ ܗܘ ܓܒܪܐ ܕܠܘܩܒܠ ܥܡܐ ܕܝܠܢ ܡܠܦ ܒܟܠ ܕܘܟܐ ܘܠܘܩܒܠ ܢܡܘܤܐ ܘܠܘܩܒܠ ܐܬܪܐ ܗܢܐ ܘܐܦ ܠܐܪܡܝܐ ܐܥܠ ܠܗܝܟܠܐ ܘܤܝܒܗ ܠܐܬܪܐ ܗܢܐ ܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.29",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Acts 21:29",
      "text": "ܩܕܡܘ ܗܘܘ ܓܝܪ ܚܙܘ ܥܡܗ ܠܛܪܘܦܝܡܤ ܐܦܤܝܐ ܒܡܕܝܢܬܐ ܘܤܒܪܝܢ ܗܘܘ ܕܥܡ ܦܘܠܘܤ ܥܠ ܠܗܝܟܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.30",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Acts 21:30",
      "text": "ܘܐܫܬܓܫܬ ܡܕܝܢܬܐ ܘܐܬܟܢܫܘ ܟܠܗ ܥܡܐ ܘܐܚܕܘܗܝ ܠܦܘܠܘܤ ܘܓܪܘܗܝ ܠܒܪ ܡܢ ܗܝܟܠܐ ܘܒܪ ܫܥܬܗ ܐܬܬܚܕܘ ܬܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.31",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Acts 21:31",
      "text": "ܘܟܕ ܒܥܐ ܗܘܐ ܟܢܫܐ ܠܡܩܛܠܗ ܐܫܬܡܥܬ ܠܟܠܝܪܟܐ ܕܐܤܦܝܪ ܕܟܠܗ ܡܕܝܢܬܐ ܐܬܬܙܝܥܬ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.21.32",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 21,
