    {
      "id": "peshitta:acts.17.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 17,
      "referenceLabel": "Acts 17:17",
      "text": "ܘܡܡܠܠ ܗܘܐ ܒܟܢܘܫܬܐ ܥܡ ܝܗܘܕܝܐ ܘܥܡ ܐܝܠܝܢ ܕܕܚܠܝܢ ܡܢ ܐܠܗܐ ܘܒܫܘܩܐ ܥܡ ܐܝܠܝܢ ܕܡܤܬܩܒܠܝܢ ܗܘܘ ܟܠܝܘܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.17.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 18,
      "referenceLabel": "Acts 17:18",
      "text": "ܘܐܦ ܦܝܠܤܘܦܐ ܕܡܢ ܝܘܠܦܢܗ ܕܐܦܝܩܘܪܤ ܘܐܚܪܢܐ ܕܡܬܩܪܝܢ ܤܛܘܐܝܩܘ ܕܪܫܝܢ ܗܘܘ ܥܡܗ ܘܐܢܫ ܐܢܫ ܡܢܗܘܢ ܐܡܪܝܢ ܗܘܘ ܡܢܐ ܨܒܐ ܗܢܐ ܡܠܩܛ ܡܠܐ ܘܐܚܪܢܐ ܐܡܪܝܢ ܗܘܘ ܕܐܠܗܐ ܢܘܟܪܝܐ ܡܟܪܙ ܡܛܠ ܕܠܝܫܘܥ ܘܠܩܝܡܬܗ ܡܟܪܙ ܗܘܐ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.17.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 19,
      "referenceLabel": "Acts 17:19",
      "text": "ܘܐܚܕܘܗܝ ܘܐܝܬܝܘܗܝ ܠܒܝܬ ܕܝܢܐ ܕܡܬܩܪܐ ܐܪܝܘܤ ܦܓܘܤ ܟܕ ܐܡܪܝܢ ܠܗ ܡܫܟܚܝܢܢ ܠܡܕܥ ܡܢܘ ܗܢܐ ܝܘܠܦܢܐ ܚܕܬܐ ܕܡܟܪܙ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.17.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 20,
      "referenceLabel": "Acts 17:20",
      "text": "ܡܠܐ ܓܝܪ ܢܘܟܪܝܬܐ ܙܪܥ ܐܢܬ ܒܡܫܡܥܬܢ ܘܨܒܝܢܢ ܠܡܕܥ ܡܢܐ ܐܢܝܢ ܗܠܝܢ ܀",
      "paragraphStart": false
