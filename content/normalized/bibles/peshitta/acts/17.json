      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Acts 17:1",
      "text": "ܘܥܒܪܘ ܥܠ ܐܡܦܝܦܘܠܝܤ ܘܐܦܠܘܢܝܐ ܡܕܝܢܬܐ ܘܐܬܘ ܠܬܤܠܘܢܝܩܐ ܐܝܟܐ ܕܐܝܬ ܗܘܐ ܟܢܘܫܬܐ ܕܝܗܘܕܝܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.17.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Acts 17:2",
      "text": "ܘܥܠ ܦܘܠܘܤ ܐܝܟܢܐ ܕܡܥܕ ܗܘܐ ܠܘܬܗܘܢ ܘܫܒܐ ܬܠܬ ܡܠܠ ܥܡܗܘܢ ܡܢ ܟܬܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.17.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Acts 17:3",
      "text": "ܟܕ ܡܦܫܩ ܗܘܐ ܘܡܚܘܐ ܕܥܬܝܕ ܗܘܐ ܡܫܝܚܐ ܕܢܚܫ ܘܕܢܩܘܡ ܡܢ ܒܝܬ ܡܝܬܐ ܘܗܘܝܘ ܝܫܘܥ ܡܫܝܚܐ ܗܢܐ ܕܡܤܒܪ ܐܢܐ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.17.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Acts 17:4",
      "text": "ܘܐܢܫܝܢ ܡܢܗܘܢ ܗܝܡܢܘ ܘܢܩܦܘ ܠܦܘܠܘܤ ܘܠܫܝܠܐ ܘܤܓܝܐܐ ܡܢ ܝܘܢܝܐ ܐܝܠܝܢ ܕܕܚܠܝܢ ܗܘܘ ܡܢ ܐܠܗܐ ܘܐܦ ܢܫܐ ܝܕܝܥܬܐ ܠܐ ܙܥܘܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.17.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Acts 17:5",
      "text": "ܘܚܤܡܘ ܗܘܘ ܝܗܘܕܝܐ ܘܐܩܦܘ ܠܗܘܢ ܐܢܫܐ ܒܝܫܐ ܡܢ ܫܘܩܐ ܕܡܕܝܢܬܐ ܘܥܒܕܘ ܐܟܠܘܤ ܤܓܝܐܐ ܘܕܠܚܘ ܗܘܘ ܠܡܕܝܢܬܐ ܘܐܬܘ ܘܩܡܘ ܠܗܘܢ ܥܠ ܒܝܬܗ ܕܐܝܤܘܢ ܘܒܥܝܢ ܗܘܘ ܕܢܦܩܘܢ ܐܢܘܢ ܡܢ ܬܡܢ ܘܢܫܠܡܘܢ ܐܢܘܢ ܠܐܟܠܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.17.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Acts 17:6",
      "text": "ܘܟܕ ܠܐ ܐܫܟܚܘ ܐܢܘܢ ܬܡܢ ܓܪܘܗܝ ܗܘܘ ܠܐܝܤܘܢ ܘܠܐܚܐ ܕܐܝܬ ܗܘܘ ܬܡܢ ܘܐܝܬܝܘ ܐܢܘܢ ܠܘܬ ܪܫܐ ܕܡܕܝܢܬܐ ܟܕ ܩܥܝܢ ܗܘܘ ܕܗܠܝܢ ܐܢܘܢ ܕܠܟܠܗ ܐܪܥܐ ܕܠܚܘ ܘܗܐ ܬܘܒ ܠܗܪܟܐ ܐܬܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.17.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Acts 17:7",
      "text": "ܘܡܩܒܠܢܗܘܢ ܗܢܘ ܐܝܤܘܢ ܘܟܠܗܘܢ ܗܠܝܢ ܠܘܩܒܠ ܦܘܩܕܢܘܗܝ ܕܩܤܪ ܩܝܡܝܢ ܟܕ ܐܡܪܝܢ ܕܐܝܬ ܡܠܟܐ ܐܚܪܢܐ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.17.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Acts 17:8",
      "text": "ܐܬܕܠܚܘ ܕܝܢ ܪܫܐ ܕܡܕܝܢܬܐ ܘܟܠܗ ܥܡܐ ܟܕ ܫܡܥܘ ܗܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.17.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Acts 17:9",
      "text": "ܘܢܤܒܘ ܥܪܒܐ ܡܢ ܐܝܤܘܢ ܘܐܦ ܡܢ ܐܚܐ ܘܗܝܕܝܢ ܫܪܘ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.17.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Acts 17:10",
      "text": "ܐܚܐ ܕܝܢ ܒܪ ܫܥܬܗ ܒܗ ܒܠܠܝܐ ܫܪܘ ܠܦܘܠܘܤ ܘܠܫܝܠܐ ܠܒܪܘܐܐ ܡܕܝܢܬܐ ܘܟܕ ܐܬܘ ܠܬܡܢ ܥܐܠܝܢ ܗܘܘ ܠܟܢܘܫܬܐ ܕܝܗܘܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.17.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Acts 17:11",
      "text": "ܚܐܪܝܝܢ ܗܘܘ ܓܝܪ ܗܢܘܢ ܝܗܘܕܝܐ ܕܬܡܢ ܡܢ ܝܗܘܕܝܐ ܗܢܘܢ ܕܐܝܬ ܗܘܘ ܒܬܤܠܘܢܝܩܐ ܘܫܡܥܝܢ ܗܘܘ ܡܢܗܘܢ ܡܠܬܐ ܟܠܝܘܡ ܚܕܝܐܝܬ ܟܕ ܡܦܪܫܝܢ ܗܘܘ ܡܢ ܟܬܒܐ ܕܐܢ ܗܠܝܢ ܗܟܢܐ ܐܝܬܝܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.17.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Acts 17:12",
      "text": "ܘܤܓܝܐܐ ܡܢܗܘܢ ܗܝܡܢܘ ܘܗܟܢܐ ܐܦ ܡܢ ܝܘܢܝܐ ܓܒܪܐ ܤܓܝܐܐ ܘܢܫܐ ܝܕܝܥܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.17.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Acts 17:13",
      "text": "ܘܟܕ ܝܕܥܘ ܗܢܘܢ ܝܗܘܕܝܐ ܕܡܢ ܬܤܠܘܢܝܩܐ ܕܡܠܬܗ ܕܐܠܗܐ ܐܬܟܪܙܬ ܡܢ ܦܘܠܘܤ ܒܒܪܘܐܐ ܡܕܝܢܬܐ ܐܬܘ ܐܦ ܠܬܡܢ ܘܠܐ ܫܠܝܘ ܠܡܙܥܘ ܘܠܡܕܠܚܘ ܠܐܢܫܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.17.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Acts 17:14",
      "text": "ܘܠܦܘܠܘܤ ܫܪܐܘܗܝ ܐܚܐ ܕܢܚܘܬ ܠܗ ܠܝܡܐ ܘܩܘܝ ܗܘܐ ܒܗ ܒܡܕܝܢܬܐ ܗܝ ܫܝܠܐ ܘܛܝܡܬܐܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.17.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Acts 17:15",
      "text": "ܘܗܢܘܢ ܕܐܬܠܘܝܘ ܠܗ ܠܦܘܠܘܤ ܐܬܘ ܥܡܗ ܥܕܡܐ ܠܐܬܢܘܤ ܡܕܝܢܬܐ ܘܟܕ ܢܦܩܝܢ ܡܢ ܨܐܕܘܗܝ ܩܒܠܘ ܡܢܗ ܐܓܪܬܐ ܠܘܬ ܫܝܠܐ ܘܛܝܡܬܐܘܤ ܕܒܥܓܠ ܢܐܙܠܘܢ ܠܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.17.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Acts 17:16",
      "text": "ܗܘ ܕܝܢ ܦܘܠܘܤ ܟܕ ܡܩܘܐ ܗܘܐ ܒܐܬܢܘܤ ܡܬܡܪܡܪ ܗܘܐ ܒܪܘܚܗ ܟܕ ܚܙܐ ܗܘܐ ܕܡܕܝܢܬܐ ܟܠܗ ܡܠܝܐ ܦܬܟܪܐ ܀",
      "paragraphStart": false
