    {
      "id": "peshitta:acts.17.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 17,
      "verseNumber": 23,
      "referenceLabel": "Acts 17:23",
      "text": "ܟܕ ܓܝܪ ܡܬܟܪܟ ܗܘܝܬ ܘܚܙܐ ܗܘܝܬ ܒܝܬ ܕܚܠܬܟܘܢ ܐܫܟܚܬ ܥܠܬܐ ܚܕܐ ܕܟܬܝܒ ܗܘܐ ܥܠܝܗ ܕܐܠܗܐ ܓܢܝܙܐ ܗܘ ܗܟܝܠ ܕܟܕ ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܕܚܠܝܢ ܐܢܬܘܢ ܠܗ ܠܗ ܠܗܢܐ ܐܢܐ ܡܤܒܪ ܐܢܐ ܠܟܘܢ ܀",
      "paragraphStart": false
