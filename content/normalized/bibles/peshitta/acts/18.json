    "bookSlug": "acts",
    "chapterNumber": 18,
    "referenceLabel": "Acts 18",
    "summary": "Source text for Acts 18 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.18.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Acts 18:1",
      "text": "ܘܟܕ ܢܦܩ ܦܘܠܘܤ ܡܢ ܐܬܢܘܤ ܐܬܐ ܠܗ ܠܩܘܪܢܬܘܤ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.18.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Acts 18:2",
      "text": "ܘܐܫܟܚ ܬܡܢ ܓܒܪܐ ܚܕ ܝܗܘܕܝܐ ܕܫܡܗ ܗܘܐ ܐܩܠܘܤ ܕܐܝܬܘܗܝ ܗܘܐ ܡܢ ܦܢܛܘܤ ܐܬܪܐ ܕܒܗ ܒܗܘ ܙܒܢܐ ܐܬܐ ܗܘܐ ܡܢ ܐܬܪܐ ܕܐܝܛܠܝܐ ܗܘ ܘܦܪܝܤܩܠܐ ܐܢܬܬܗ ܡܛܠ ܕܦܩܕ ܗܘܐ ܩܠܘܕܝܘܤ ܩܤܪ ܕܢܦܩܘܢ ܟܠܗܘܢ ܝܗܘܕܝܐ ܡܢ ܪܗܘܡܐ ܘܐܬܩܪܒ ܠܘܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Acts 18:3",
      "text": "ܘܡܛܠ ܕܒܪ ܐܘܡܢܘܬܗܘܢ ܗܘܐ ܫܪܐ ܠܗ ܠܘܬܗܘܢ ܘܦܠܚ ܗܘܐ ܥܡܗܘܢ ܒܐܘܡܢܘܬܗܘܢ ܕܝܢ ܠܘܠܪܐ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Acts 18:4",
      "text": "ܘܡܡܠܠ ܗܘܐ ܒܟܢܘܫܬܐ ܒܟܠ ܫܒܐ ܘܡܦܝܤ ܗܘܐ ܠܝܗܘܕܝܐ ܘܠܚܢܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Acts 18:5",
      "text": "ܘܟܕ ܐܬܘ ܗܘܘ ܡܢ ܡܩܕܘܢܝܐ ܫܝܠܐ ܘܛܝܡܬܐܘܤ ܐܠܝܨ ܗܘܐ ܒܡܠܬܐ ܗܘ ܦܘܠܘܤ ܡܛܠ ܕܩܝܡܝܢ ܗܘܘ ܠܩܘܒܠܗ ܝܗܘܕܝܐ ܘܡܓܕܦܝܢ ܗܘܘ ܟܕ ܡܤܗܕ ܗܘܐ ܠܗܘܢ ܕܝܫܘܥ ܗܘܝܘ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Acts 18:6",
      "text": "ܘܢܦܨ ܡܐܢܘܗܝ ܘܐܡܪ ܠܗܘܢ ܡܢ ܗܫܐ ܐܢܐ ܕܟܐ ܐܢܐ ܐܙܠ ܐܢܐ ܠܝ ܠܘܬ ܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Acts 18:7",
      "text": "ܘܢܦܩ ܡܢ ܬܡܢ ܘܥܠ ܠܒܝܬܗ ܕܓܒܪܐ ܕܫܡܗ ܛܛܘܤ ܐܝܢܐ ܕܕܚܠ ܗܘܐ ܡܢ ܐܠܗܐ ܘܒܝܬܗ ܢܩܝܦ ܗܘܐ ܠܟܢܘܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Acts 18:8",
      "text": "ܘܟܪܝܤܦܘܤ ܪܒ ܟܢܘܫܬܐ ܗܝܡܢ ܗܘܐ ܒܡܪܢ ܗܘ ܘܒܢܝ ܒܝܬܗ ܟܠܗܘܢ ܘܤܓܝܐܐ ܩܘܪܢܬܝܐ ܫܡܥܝܢ ܗܘܘ ܘܡܗܝܡܢܝܢ ܒܐܠܗܐ ܘܥܡܕܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Acts 18:9",
      "text": "ܘܐܡܪ ܡܪܝܐ ܒܚܙܘܐ ܠܦܘܠܘܤ ܠܐ ܬܕܚܠ ܐܠܐ ܡܠܠ ܘܠܐ ܬܫܬܘܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Acts 18:10",
      "text": "ܡܛܠ ܕܐܢܐ ܥܡܟ ܐܢܐ ܘܐܢܫ ܠܐ ܡܫܟܚ ܠܡܗܪܘܬܟ ܘܥܡܐ ܤܓܝܐܐ ܐܝܬ ܠܝ ܒܡܕܝܢܬܐ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Acts 18:11",
      "text": "ܝܬܒ ܗܘܐ ܕܝܢ ܫܢܬܐ ܚܕܐ ܘܝܪܚܐ ܫܬܐ ܒܩܘܪܢܬܘܤ ܘܡܠܦ ܗܘܐ ܠܗܘܢ ܡܠܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Acts 18:12",
      "text": "ܘܟܕ ܐܝܬܘܗܝ ܗܘܐ ܓܐܠܝܘܢ ܐܢܬܘܦܛܘܤ ܕܐܟܐܝܐ ܐܬܟܢܫܘ ܐܟܚܕܐ ܝܗܘܕܝܐ ܥܠ ܦܘܠܘܤ ܘܐܝܬܝܘܗܝ ܩܕܡ ܒܝܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "Acts 18:13",
      "text": "ܟܕ ܐܡܪܝܢ ܕܗܢܐ ܠܒܪ ܡܢ ܢܡܘܤܐ ܡܦܝܤ ܠܒܢܝܢܫܐ ܕܢܗܘܘܢ ܕܚܠܝܢ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "Acts 18:14",
      "text": "ܘܟܕ ܒܥܐ ܗܘܐ ܦܘܠܘܤ ܕܢܦܬܚ ܦܘܡܗ ܘܢܡܠܠ ܐܡܪ ܓܐܠܝܘܢ ܠܝܗܘܕܝܐ ܐܠܘ ܥܠ ܡܕܡ ܕܒܝܫ ܐܘ ܕܢܟܝܠ ܐܘ ܕܤܢܐ ܡܩܛܪܓܝܢ ܗܘܝܬܘܢ ܐܘ ܝܗܘܕܝܐ ܒܘܠܝܬܐ ܡܩܒܠ ܗܘܝܬ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "Acts 18:15",
      "text": "ܐܢ ܕܝܢ ܙܛܡܐ ܐܢܘܢ ܥܠ ܡܠܬܐ ܘܥܠ ܫܡܗܐ ܘܥܠ ܢܡܘܤܐ ܕܝܠܟܘܢ ܐܢܬܘܢ ܝܕܥܝܢ ܐܢܬܘܢ ܒܝܢܬܟܘܢ ܐܢܐ ܓܝܪ ܠܐ ܨܒܐ ܐܢܐ ܕܐܗܘܐ ܕܝܢܐ ܕܗܠܝܢ ܨܒܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 16,
      "referenceLabel": "Acts 18:16",
      "text": "ܘܛܪܕ ܐܢܘܢ ܡܢ ܒܝܡ ܕܝܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 17,
      "referenceLabel": "Acts 18:17",
      "text": "ܘܐܚܕܘ ܗܘܘ ܟܠܗܘܢ ܚܢܦܐ ܠܤܘܤܬܢܝܤ ܩܫܝܫܐ ܕܟܢܘܫܬܐ ܘܡܚܝܢ ܗܘܘ ܠܗ ܩܕܡ ܒܝܡ ܘܓܐܠܝܘܢ ܡܗܡܐ ܗܘܐ ܒܗܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 18,
      "referenceLabel": "Acts 18:18",
      "text": "ܘܟܕ ܗܘܐ ܦܘܠܘܤ ܬܡܢ ܝܘܡܬܐ ܤܓܝܐܐ ܝܗܒ ܫܠܡܐ ܠܐܚܐ ܘܪܕܐ ܒܝܡܐ ܕܢܐܙܠ ܠܤܘܪܝܐ ܘܐܬܘ ܥܡܗ ܦܪܝܤܩܠܐ ܘܐܩܠܘܤ ܟܕ ܤܦܪ ܪܫܗ ܒܩܢܟܪܐܤ ܡܛܠ ܕܢܕܪܐ ܢܕܝܪ ܗܘܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 19,
      "referenceLabel": "Acts 18:19",
      "text": "ܘܡܛܝܘ ܠܐܦܤܘܤ ܘܥܠ ܦܘܠܘܤ ܠܟܢܘܫܬܐ ܘܡܡܠܠ ܗܘܐ ܥܡ ܝܗܘܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 20,
      "referenceLabel": "Acts 18:20",
      "text": "ܘܒܥܝܢ ܗܘܘ ܡܢܗ ܕܢܓܪ ܠܘܬܗܘܢ ܘܠܐ ܐܬܛܦܝܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 21,
      "referenceLabel": "Acts 18:21",
      "text": "ܟܕ ܐܡܪ ܕܘܠܐ ܠܝ ܐܡܝܢܐܝܬ ܕܥܐܕܐ ܕܐܬܐ ܒܐܘܪܫܠܡ ܐܥܒܕܝܘܗܝ ܘܐܢ ܐܠܗܐ ܢܨܒܐ ܐܦܢܐ ܬܘܒ ܠܘܬܟܘܢ ܘܠܐܩܠܘܤ ܘܠܦܪܝܤܩܠܐ ܫܒܩ ܐܢܘܢ ܒܐܦܤܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 22,
      "referenceLabel": "Acts 18:22",
      "text": "ܘܗܘ ܪܕܐ ܒܝܡܐ ܘܐܬܐ ܠܩܤܪܝܐ ܘܤܠܩ ܘܫܐܠ ܒܫܠܡܐ ܕܒܢܝ ܥܕܬܐ ܘܐܙܠ ܠܗ ܠܐܢܛܝܘܟܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 23,
      "referenceLabel": "Acts 18:23",
      "text": "ܘܟܕ ܗܘܐ ܬܡܢ ܝܘܡܬܐ ܝܕܝܥܐ ܢܦܩ ܘܐܬܟܪܟ ܒܬܪ ܒܬܪ ܒܐܬܪܐ ܕܓܠܛܝܐ ܘܕܦܪܘܓܝܐ ܟܕ ܡܩܝܡ ܗܘܐ ܠܟܠܗܘܢ ܬܠܡܝܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 24,
      "referenceLabel": "Acts 18:24",
      "text": "ܘܓܒܪܐ ܚܕ ܕܫܡܗ ܗܘܐ ܐܦܠܘ ܝܗܘܕܝܐ ܕܐܝܬܘܗܝ ܗܘܐ ܛܘܗܡܗ ܡܢ ܐܠܟܤܢܕܪܝܐ ܘܪܕܐ ܗܘܐ ܒܡܠܬܐ ܘܡܕܩ ܗܘܐ ܒܟܬܒܐ ܐܬܐ ܠܐܦܤܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 25,
      "referenceLabel": "Acts 18:25",
      "text": "ܗܢܐ ܡܬܠܡܕ ܗܘܐ ܠܐܘܪܚܗ ܕܡܪܝܐ ܘܪܬܚ ܗܘܐ ܒܪܘܚ ܘܡܡܠܠ ܗܘܐ ܘܡܠܦ ܡܠܝܐܝܬ ܥܠ ܝܫܘܥ ܟܕ ܡܕܡ ܠܐ ܝܕܥ ܗܘܐ ܐܠܐ ܐܢ ܡܥܡܘܕܝܬܐ ܕܝܘܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 26,
      "referenceLabel": "Acts 18:26",
      "text": "ܘܫܪܝ ܥܝܢ ܒܓܠܐ ܡܡܠܠ ܒܟܢܘܫܬܐ ܘܟܕ ܫܡܥܘܗܝ ܐܩܠܘܤ ܘܦܪܝܤܩܠܐ ܐܝܬܝܘܗܝ ܠܒܝܬܗܘܢ ܘܡܠܝܐܝܬ ܚܘܝܘܗܝ ܐܘܪܚܗ ܕܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 27,
      "referenceLabel": "Acts 18:27",
      "text": "ܘܟܕ ܨܒܐ ܕܢܐܙܠ ܠܐܟܐܝܐ ܚܦܛܘܗܝ ܐܚܐ ܘܟܬܒܘ ܠܬܠܡܝܕܐ ܕܢܩܒܠܘܢܝܗܝ ܘܟܕ ܐܙܠ ܥܕܪ ܤܓܝ ܒܝܕ ܛܝܒܘܬܐ ܠܟܠܗܘܢ ܡܗܝܡܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.18.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 18,
      "verseNumber": 28,
      "referenceLabel": "Acts 18:28",
      "text": "ܬܩܝܦܐܝܬ ܓܝܪ ܕܪܫ ܗܘܐ ܠܘܩܒܠ ܝܗܘܕܝܐ ܩܕܡ ܟܢܫܐ ܟܕ ܡܚܘܐ ܗܘܐ ܡܢ ܟܬܒܐ ܥܠ ܝܫܘܥ ܕܡܫܝܚܐ ܗܘ ܀",
      "paragraphStart": false
    }
  ]
}
