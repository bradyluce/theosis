{
  "chapter": {
    "id": "peshitta:acts.11",
    "translationId": "peshitta",
    "bookSlug": "acts",
    "chapterNumber": 11,
    "referenceLabel": "Acts 11",
    "summary": "Source text for Acts 11 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.11.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Acts 11:1",
      "text": "ܘܐܫܬܡܥܬ ܗܘܬ ܠܫܠܝܚܐ ܘܠܐܚܐ ܕܒܝܗܘܕ ܕܐܦ ܥܡܡܐ ܩܒܠܘ ܡܠܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.11.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Acts 11:2",
      "text": "ܘܟܕ ܤܠܩ ܫܡܥܘܢ ܠܐܘܪܫܠܡ ܕܝܢܝܢ ܗܘܘ ܥܡܗ ܗܢܘܢ ܕܡܢ ܓܙܘܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Acts 11:3",
      "text": "ܟܕ ܐܡܪܝܢ ܕܠܘܬ ܐܢܫܐ ܥܘܪܠܐ ܥܠ ܘܠܥܤ ܥܡܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Acts 11:4",
      "text": "ܘܐܩܦ ܗܘܐ ܫܡܥܘܢ ܒܬܪ ܒܬܪ ܠܡܐܡܪ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Acts 11:5",
      "text": "ܕܟܕ ܡܨܠܐ ܗܘܝܬ ܒܝܘܦܐ ܚܙܝܬ ܒܚܙܘܐ ܕܢܚܬ ܗܘܐ ܡܐܢܐ ܚܕ ܐܝܢܐ ܕܕܡܐ ܗܘܐ ܠܟܬܢܐ ܘܐܤܝܪ ܗܘܐ ܒܐܪܒܥ ܩܪܢܬܗ ܘܫܐܒ ܗܘܐ ܡܢ ܫܡܝܐ ܘܐܬܐ ܥܕܡܐ ܠܘܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Acts 11:6",
      "text": "ܘܚܪܬ ܒܗ ܘܚܙܐ ܗܘܝܬ ܕܐܝܬ ܒܗ ܚܝܘܬܐ ܕܐܪܒܥܬ ܪܓܠܝܗܝܢ ܘܪܚܫܐ ܕܐܪܥܐ ܘܐܦ ܦܪܚܬܐ ܕܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Acts 11:7",
      "text": "ܘܫܡܥܬ ܗܘܝܬ ܩܠܐ ܕܐܡܪ ܗܘܐ ܠܝ ܫܡܥܘܢ ܩܘܡ ܟܘܤ ܘܐܟܘܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Acts 11:8",
      "text": "ܘܐܡܪܬ ܚܤ ܡܪܝ ܕܡܡܬܘܡ ܠܐ ܥܠ ܠܦܘܡܝ ܕܛܡܐ ܘܕܡܤܝܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Acts 11:9",
      "text": "ܘܬܘܒ ܩܠܐ ܐܡܪ ܠܝ ܡܢ ܫܡܝܐ ܕܡܕܡ ܕܐܠܗܐ ܕܟܝ ܐܢܬ ܠܐ ܬܤܝܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Acts 11:10",
      "text": "ܗܕܐ ܗܘܬ ܬܠܬ ܙܒܢܝܢ ܘܐܤܬܠܩ ܠܗ ܟܠܡܕܡ ܠܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Acts 11:11",
      "text": "ܘܒܗ ܒܫܥܬܐ ܬܠܬܐ ܓܒܪܝܢ ܕܐܫܬܕܪܘ ܠܘܬܝ ܡܢ ܩܘܪܢܠܝܘܤ ܡܢ ܩܤܪܝܐ ܐܬܘ ܘܩܡܘ ܥܠ ܬܪܥܐ ܕܕܪܬܐ ܕܫܪܐ ܗܘܝܬ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Acts 11:12",
      "text": "ܘܐܡܪ ܠܝ ܪܘܚܐ ܕܙܠ ܥܡܗܘܢ ܕܠܐ ܦܘܠܓܐ ܘܐܬܘ ܥܡܝ ܐܦ ܗܠܝܢ ܫܬܐ ܐܚܝܢ ܘܥܠܢ ܠܒܝܬܗ ܕܓܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Acts 11:13",
      "text": "ܘܐܫܬܥܝ ܠܢ ܐܝܟܢܐ ܚܙܐ ܒܒܝܬܗ ܡܠܐܟܐ ܕܩܡ ܘܐܡܪ ܠܗ ܕܫܕܪ ܠܝܘܦܐ ܡܕܝܢܬܐ ܘܐܝܬܐ ܠܫܡܥܘܢ ܕܡܬܩܪܐ ܟܐܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Acts 11:14",
      "text": "ܘܗܘ ܢܡܠܠ ܥܡܟ ܡܠܐ ܕܒܗܝܢ ܬܚܐ ܐܢܬ ܘܟܠܗ ܒܝܬܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Acts 11:15",
      "text": "ܘܟܕ ܐܩܦܬ ܗܘܝܬ ܬܡܢ ܠܡܡܠܠܘ ܐܓܢܬ ܪܘܚܐ ܕܩܘܕܫܐ ܥܠܝܗܘܢ ܐܝܟ ܡܐ ܕܥܠܝܢ ܡܢ ܩܕܝܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Acts 11:16",
      "text": "ܘܐܬܕܟܪܬ ܡܠܬܗ ܕܡܪܢ ܕܐܡܪ ܗܘܐ ܕܝܘܚܢܢ ܐܥܡܕ ܒܡܝܐ ܐܢܬܘܢ ܕܝܢ ܬܥܡܕܘܢ ܒܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Acts 11:17",
      "text": "ܐܢ ܗܟܝܠ ܐܠܗܐ ܫܘܝܐܝܬ ܝܗܒܗ ܡܘܗܒܬܐ ܠܥܡܡܐ ܐܝܠܝܢ ܕܗܝܡܢܘ ܒܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܐܝܟ ܕܐܦ ܠܢ ܐܢܐ ܡܢ ܗܘܝܬ ܕܐܤܦܩ ܗܘܝܬ ܕܐܟܠܐ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Acts 11:18",
      "text": "ܘܟܕ ܗܠܝܢ ܡܠܐ ܫܡܥܘ ܫܠܝܘ ܠܗܘܢ ܘܫܒܚܘ ܠܐܠܗܐ ܘܐܡܪܝܢ ܗܘܘ ܕܟܒܪ ܐܦ ܠܥܡܡܐ ܐܠܗܐ ܝܗܒ ܬܝܒܘܬܐ ܠܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Acts 11:19",
      "text": "ܗܢܘܢ ܕܝܢ ܕܐܬܒܕܪܘ ܗܘܘ ܡܢ ܐܘܠܨܢܐ ܕܗܘܐ ܗܘܐ ܥܠ ܐܤܛܦܢܘܤ ܡܛܝܘ ܗܘܘ ܥܕܡܐ ܠܦܘܢܝܩܐ ܘܐܦ ܠܐܬܪܐ ܕܩܘܦܪܘܤ ܘܠܐܢܛܝܟܝܐ ܟܕ ܥܡ ܐܢܫ ܠܐ ܡܡܠܠܝܢ ܗܘܘ ܡܠܬܐ ܐܠܐ ܒܠܚܘܕ ܥܡ ܝܗܘܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Acts 11:20",
      "text": "ܐܝܬ ܗܘܘ ܕܝܢ ܐܢܫܐ ܡܢܗܘܢ ܡܢ ܩܘܦܪܘܤ ܘܡܢ ܩܘܪܝܢܐ ܗܠܝܢ ܥܠܘ ܗܘܘ ܠܐܢܛܝܘܟܝ ܘܡܡܠܠܝܢ ܗܘܘ ܥܡ ܝܘܢܝܐ ܘܡܤܒܪܝܢ ܗܘܘ ܥܠ ܡܪܢ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Acts 11:21",
      "text": "ܘܐܝܬ ܗܘܬ ܥܡܗܘܢ ܐܝܕܗ ܕܡܪܝܐ ܘܤܓܝܐܐ ܗܝܡܢܘ ܘܐܬܦܢܝܘ ܠܘܬ ܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Acts 11:22",
      "text": "ܘܐܫܬܡܥܬ ܗܘܬ ܗܝ ܗܕܐ ܠܐܕܢܝܗܘܢ ܕܒܢܝ ܥܕܬܐ ܕܒܐܘܪܫܠܡ ܘܫܕܪܘ ܠܒܪܢܒܐ ܠܐܢܛܝܘܟܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Acts 11:23",
      "text": "ܘܟܕ ܐܬܐ ܠܬܡܢ ܘܚܙܐ ܛܝܒܘܬܗ ܕܐܠܗܐ ܚܕܝ ܘܒܥܐ ܗܘܐ ܡܢܗܘܢ ܕܒܟܠܗ ܠܒܗܘܢ ܢܗܘܘܢ ܢܩܝܦܝܢ ܠܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Acts 11:24",
      "text": "ܡܛܠ ܕܓܒܪܐ ܗܘܐ ܛܒܐ ܘܡܫܡܠܝ ܗܘܐ ܒܪܘܚܐ ܕܩܘܕܫܐ ܘܒܗܝܡܢܘܬܐ ܘܐܬܬܘܤܦ ܗܘܐ ܥܡܐ ܤܓܝܐܐ ܠܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Acts 11:25",
      "text": "ܘܗܘ ܢܦܩ ܗܘܐ ܠܛܪܤܘܤ ܠܡܒܥܐ ܠܫܐܘܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Acts 11:26",
      "text": "ܘܟܕ ܐܫܟܚܗ ܐܝܬܝܗ ܥܡܗ ܠܐܢܛܝܟܝܐ ܘܫܢܬܐ ܟܠܗ ܐܟܚܕܐ ܟܢܝܫܝܢ ܗܘܘ ܒܥܕܬܐ ܘܐܠܦܘ ܥܡܐ ܤܓܝܐܐ ܡܢ ܗܝܕܝܢ ܩܕܡܝܬ ܐܬܩܪܝܘ ܒܐܢܛܝܘܟܝ ܬܠܡܝܕܐ ܟܪܤܛܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Acts 11:27",
      "text": "ܘܒܝܘܡܬܐ ܗܢܘܢ ܐܬܘ ܡܢ ܐܘܪܫܠܡ ܠܬܡܢ ܢܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "Acts 11:28",
      "text": "ܘܩܡ ܚܕ ܡܢܗܘܢ ܕܫܡܗ ܗܘܐ ܐܓܒܘܤ ܘܐܘܕܥ ܐܢܘܢ ܒܪܘܚ ܕܟܦܢܐ ܪܒܐ ܗܘܐ ܒܟܠܗ ܐܪܥܐ ܘܗܘܐ ܟܦܢܐ ܗܢܐ ܒܝܘܡܝ ܩܠܘܕܝܘܤ ܩܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.29",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "Acts 11:29",
      "text": "ܒܪܡ ܕܝܢ ܬܠܡܝܕܐ ܐܝܟ ܡܐ ܕܐܝܬ ܗܘܐ ܠܐܢܫ ܐܢܫ ܡܢܗܘܢ ܦܪܫܘ ܕܢܫܕܪܘܢ ܠܬܫܡܫܬܐ ܕܐܚܐ ܐܝܠܝܢ ܕܥܡܪܝܢ ܒܝܗܘܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.11.30",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "Acts 11:30",
      "text": "ܘܫܕܪܘ ܒܝܕ ܒܪܢܒܐ ܘܫܐܘܠ ܠܩܫܝܫܐ ܕܬܡܢ ܀",
      "paragraphStart": false
    }
  ]
}
