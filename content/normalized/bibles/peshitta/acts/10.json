{
  "chapter": {
    "id": "peshitta:acts.10",
    "translationId": "peshitta",
    "bookSlug": "acts",
    "chapterNumber": 10,
    "referenceLabel": "Acts 10",
    "summary": "Source text for Acts 10 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.10.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Acts 10:1",
      "text": "ܒܩܤܪܝܐ ܕܝܢ ܐܝܬ ܗܘܐ ܓܒܪܐ ܚܕ ܩܢܛܪܘܢܐ ܕܫܡܗ ܗܘܐ ܩܘܪܢܠܝܘܤ ܡܢ ܤܦܝܪܐ ܗܝ ܕܡܬܩܪܝܐ ܐܝܛܠܝܩܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.10.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Acts 10:2",
      "text": "ܘܙܕܝܩ ܗܘܐ ܘܕܚܠ ܗܘܐ ܡܢ ܐܠܗܐ ܗܘ ܘܒܝܬܗ ܟܠܗ ܘܥܒܕ ܗܘܐ ܙܕܩܬܐ ܤܓܝܐܬܐ ܒܥܡܐ ܘܒܟܠܙܒܢ ܒܥܐ ܗܘܐ ܡܢ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Acts 10:3",
      "text": "ܗܢܐ ܚܙܐ ܡܠܐܟܐ ܕܐܠܗܐ ܒܚܙܘܐ ܓܠܝܐܝܬ ܠܐܦܝ ܬܫܥ ܫܥܝܢ ܒܐܝܡܡܐ ܕܥܠ ܠܘܬܗ ܘܐܡܪ ܠܗ ܩܘܪܢܠܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Acts 10:4",
      "text": "ܘܗܘ ܚܪ ܒܗ ܘܕܚܠ ܘܐܡܪ ܡܢܐ ܡܪܝ ܘܐܡܪ ܠܗ ܡܠܐܟܐ ܨܠܘܬܟ ܘܙܕܩܬܟ ܤܠܩ ܠܕܘܟܪܢܐ ܩܕܡ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Acts 10:5",
      "text": "ܘܗܫܐ ܫܕܪ ܓܒܪܐ ܠܝܘܦܐ ܡܕܝܢܬܐ ܘܐܝܬܐ ܠܫܡܥܘܢ ܕܡܬܩܪܐ ܟܐܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Acts 10:6",
      "text": "ܗܐ ܫܪܐ ܒܒܝܬܗ ܕܫܡܥܘܢ ܒܘܪܤܝܐ ܗܘ ܕܐܝܬܘܗܝ ܥܠ ܝܕ ܝܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Acts 10:7",
      "text": "ܘܟܕ ܐܙܠ ܠܗ ܡܠܐܟܐ ܕܡܠܠ ܥܡܗ ܩܪܐ ܬܪܝܢ ܡܢ ܒܢܝ ܒܝܬܗ ܘܦܠܚܐ ܚܕ ܕܕܚܠ ܠܐܠܗܐ ܐܝܢܐ ܕܡܬܕܢܐ ܗܘܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Acts 10:8",
      "text": "ܘܐܫܬܥܝ ܠܗܘܢ ܟܠܡܕܡ ܕܚܙܐ ܘܫܕܪ ܐܢܘܢ ܠܝܘܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Acts 10:9",
      "text": "ܘܠܝܘܡܐ ܐܚܪܢܐ ܟܕ ܗܢܘܢ ܪܕܝܢ ܒܐܘܪܚܐ ܘܩܪܝܒܝܢ ܠܡܕܝܢܬܐ ܤܠܩ ܫܡܥܘܢ ܠܐܓܪܐ ܕܢܨܠܐ ܒܫܬ ܫܥܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Acts 10:10",
      "text": "ܘܟܦܢ ܘܨܒܐ ܗܘܐ ܕܢܠܥܤ ܘܟܕ ܗܢܘܢ ܡܬܩܢܝܢ ܠܗ ܢܦܠ ܥܠܘܗܝ ܬܡܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Acts 10:11",
      "text": "ܘܚܙܐ ܫܡܝܐ ܟܕ ܦܬܝܚܝܢ ܘܡܐܢܐ ܚܕ ܟܕ ܐܤܝܪ ܒܐܪܒܥ ܩܪܢܢ ܘܕܡܐ ܗܘܐ ܠܟܬܢܐ ܪܒܐ ܘܫܐܒ ܗܘܐ ܡܢ ܫܡܝܐ ܥܠ ܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Acts 10:12",
      "text": "ܘܐܝܬ ܗܘܐ ܒܗ ܟܠܗܝܢ ܚܝܘܬܐ ܕܐܪܒܥܬ ܪܓܠܐ ܘܪܚܫܐ ܕܐܪܥܐ ܘܦܪܚܬܐ ܕܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Acts 10:13",
      "text": "ܘܩܠܐ ܐܬܐ ܠܗ ܕܐܡܪ ܫܡܥܘܢ ܩܘܡ ܟܘܤ ܘܐܟܘܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Acts 10:14",
      "text": "ܘܫܡܥܘܢ ܐܡܪ ܚܤ ܡܪܝ ܕܡܡܬܘܡ ܠܐ ܐܟܠܬ ܟܠ ܕܡܤܝܒ ܘܛܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Acts 10:15",
      "text": "ܘܬܘܒ ܕܬܪܬܝܢ ܙܒܢܝܢ ܩܠܐ ܗܘܐ ܠܘܬܗ ܐܝܠܝܢ ܕܐܠܗܐ ܕܟܝ ܐܢܬ ܠܐ ܬܤܝܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Acts 10:16",
      "text": "ܗܕܐ ܕܝܢ ܗܘܬ ܬܠܬ ܙܒܢܝܢ ܘܐܬܥܠܝ ܠܗ ܡܐܢܐ ܠܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Acts 10:17",
      "text": "ܘܟܕ ܡܬܕܡܪ ܫܡܥܘܢ ܒܢܦܫܗ ܕܡܢܘ ܚܙܘܐ ܕܚܙܐ ܡܛܝܘ ܓܒܪܐ ܗܢܘܢ ܕܐܫܬܕܪܘ ܗܘܘ ܡܢ ܩܘܪܢܠܝܘܤ ܘܫܐܠܘ ܥܠ ܒܝܬܐ ܕܫܪܐ ܒܗ ܫܡܥܘܢ ܘܐܬܘ ܘܩܡܘ ܥܠ ܬܪܥܐ ܕܕܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Acts 10:18",
      "text": "ܘܩܪܝܢ ܗܘܘ ܬܡܢ ܘܡܫܐܠܝܢ ܕܐܢ ܫܡܥܘܢ ܕܡܬܩܪܐ ܟܐܦܐ ܗܪܟܐ ܫܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Acts 10:19",
      "text": "ܘܟܕ ܫܡܥܘܢ ܪܢܐ ܗܘܐ ܒܚܙܘܐ ܐܡܪ ܠܗ ܪܘܚܐ ܗܐ ܓܒܪܐ ܬܠܬܐ ܒܥܝܢ ܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Acts 10:20",
      "text": "ܩܘܡ ܚܘܬ ܘܙܠ ܥܡܗܘܢ ܟܕ ܠܐ ܡܬܦܠܓ ܪܥܝܢܟ ܡܛܠ ܕܐܢܐ ܗܘ ܫܕܪܬ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Acts 10:21",
      "text": "ܗܝܕܝܢ ܢܚܬ ܫܡܥܘܢ ܠܘܬ ܓܒܪܐ ܗܢܘܢ ܘܐܡܪ ܠܗܘܢ ܐܢܐ ܗܘ ܕܒܥܝܢ ܐܢܬܘܢ ܐܝܕܐ ܗܝ ܥܠܬܐ ܕܡܛܠܬܗ ܐܬܝܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Acts 10:22",
      "text": "ܐܡܪܝܢ ܠܗ ܓܒܪܐ ܚܕ ܕܫܡܗ ܩܘܪܢܠܝܘܤ ܩܢܛܪܘܢܐ ܟܐܢܐ ܕܕܚܠ ܡܢ ܐܠܗܐ ܘܡܤܗܕ ܥܠܘܗܝ ܟܠܗ ܥܡܐ ܕܝܗܘܕܝܐ ܐܬܐܡܪ ܠܗ ܒܚܙܘܐ ܡܢ ܡܠܐܟܐ ܩܕܝܫܐ ܕܢܫܕܪ ܢܥܠܟ ܠܒܝܬܗ ܘܢܫܡܥ ܡܠܬܐ ܡܢܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Acts 10:23",
      "text": "ܘܐܥܠ ܐܢܘܢ ܫܡܥܘܢ ܘܩܒܠ ܐܢܘܢ ܟܪ ܕܫܪܐ ܗܘܐ ܘܩܡ ܠܒܬܪܗ ܕܝܘܡܐ ܘܢܦܩ ܐܙܠ ܥܡܗܘܢ ܘܐܙܠܘ ܥܡܗ ܐܢܫ ܐܢܫ ܡܢ ܐܚܐ ܕܝܘܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Acts 10:24",
      "text": "ܘܠܝܘܡܐ ܐܚܪܢܐ ܥܠ ܠܩܤܪܝܐ ܩܘܪܢܠܝܘܤ ܕܝܢ ܡܩܘܐ ܗܘܐ ܠܗܘܢ ܟܕ ܡܟܢܫܝܢ ܠܗ ܟܠܗܘܢ ܒܢܝ ܛܘܗܡܗ ܘܐܦ ܪܚܡܐ ܚܒܝܒܐ ܕܐܝܬ ܗܘܘ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Acts 10:25",
      "text": "ܘܟܕ ܥܐܠ ܫܡܥܘܢ ܐܪܥܗ ܩܘܪܢܠܝܘܤ ܘܢܦܠ ܤܓܕ ܠܪܓܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Acts 10:26",
      "text": "ܘܫܡܥܘܢ ܐܩܝܡܗ ܘܐܡܪ ܠܗ ܩܘܡ ܠܟ ܘܐܦ ܐܢܐ ܒܪܢܫܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Acts 10:27",
      "text": "ܘܟܕ ܡܡܠܠ ܥܡܗ ܥܠ ܘܐܫܟܚ ܤܓܝܐܐ ܕܐܬܘ ܗܘܘ ܠܬܡܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Acts 10:28",
      "text": "ܘܐܡܪ ܠܗܘܢ ܐܢܬܘܢ ܝܕܥܝܢ ܐܢܬܘܢ ܕܠܐ ܡܦܤ ܠܓܒܪܐ ܝܗܘܕܝܐ ܕܢܩܦ ܠܐܢܫܐ ܢܘܟܪܝܐ ܕܠܐ ܗܘܐ ܒܪ ܫܪܒܬܗ ܘܠܝ ܐܠܗܐ ܚܘܝܢܝ ܕܠܐ ܐܡܪ ܥܠ ܐܢܫ ܕܛܡܐ ܐܘ ܡܤܝܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.29",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Acts 10:29",
      "text": "ܡܛܠ ܗܢܐ ܥܬܝܕܐܝܬ ܐܬܝܬ ܟܕ ܫܕܪܬܘܢ ܒܬܪܝ ܒܪܡ ܡܫܐܠ ܐܢܐ ܠܟܘܢ ܡܛܠ ܡܢܐ ܫܕܪܬܘܢ ܒܬܪܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.30",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Acts 10:30",
      "text": "ܐܡܪ ܠܗ ܩܘܪܢܠܝܘܤ ܐܪܒܥܐ ܝܘܡܝܢ ܐܝܬ ܥܕܡܐ ܠܗܫܐ ܗܐ ܡܢ ܕܨܐܡ ܐܢܐ ܘܒܬܫܥ ܫܥܝܢ ܟܕ ܡܨܠܐ ܐܢܐ ܒܒܝܬܝ ܩܡ ܓܒܪܐ ܚܕ ܩܕܡܝ ܟܕ ܠܒܝܫ ܚܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.31",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Acts 10:31",
      "text": "ܘܐܡܪ ܠܝ ܩܘܪܢܠܝܐ ܐܫܬܡܥܬ ܨܠܘܬܟ ܘܠܙܕܩܬܟ ܕܘܟܪܢܐ ܗܘܐ ܩܕܡ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.32",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Acts 10:32",
      "text": "ܒܪܡ ܫܕܪ ܠܝܘܦܐ ܡܕܝܢܬܐ ܘܐܝܬܐ ܠܫܡܥܘܢ ܕܡܬܩܪܐ ܟܐܦܐ ܗܐ ܫܪܐ ܒܒܝܬܗ ܕܫܡܥܘܢ ܒܘܪܤܝܐ ܕܥܠ ܝܕ ܝܡܐ ܘܗܘ ܢܐܬܐ ܢܡܠܠ ܥܡܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.33",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "Acts 10:33",
      "text": "ܘܒܪ ܫܥܬܗ ܫܕܪܬ ܠܘܬܟ ܘܐܢܬ ܫܦܝܪ ܥܒܕܬ ܕܐܬܝܬ ܘܗܐ ܚܢܢ ܟܠܢ ܩܕܡܝܟ ܘܨܒܝܢܢ ܕܢܫܡܥ ܟܠ ܡܐ ܕܐܬܦܩܕ ܠܟ ܡܢ ܠܘܬ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.34",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 34,
      "referenceLabel": "Acts 10:34",
      "text": "ܦܬܚ ܕܝܢ ܫܡܥܘܢ ܦܘܡܗ ܘܐܡܪ ܒܫܪܪܐ ܐܕܪܟܬ ܕܐܠܗܐ ܠܐ ܗܘܐ ܢܤܒ ܒܐܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.10.35",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 10,
      "verseNumber": 35,
      "referenceLabel": "Acts 10:35",
      "text": "ܐܠܐ ܒܟܠܗܘܢ ܥܡܡܐ ܐܝܢܐ ܕܕܚܠ ܡܢܗ ܘܦܠܚ ܟܐܢܘܬܐ ܡܩܒܠ ܗܘ ܠܘܬܗ ܀",
      "paragraphStart": false
    },
    {
