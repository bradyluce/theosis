      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 50,
      "referenceLabel": "Acts 7:50",
      "text": "ܠܐ ܗܐ ܐܝܕܐ ܕܝܠܝ ܥܒܕܬ ܗܠܝܢ ܟܠܗܝܢ ܀",
      "paragraphStart": false
