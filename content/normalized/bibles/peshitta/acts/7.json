    {
      "id": "peshitta:acts.7.39",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 39,
      "referenceLabel": "Acts 7:39",
      "text": "ܘܠܐ ܨܒܘ ܠܡܬܕܢܝܘ ܠܗ ܐܒܗܬܢ ܐܠܐ ܫܒܩܘܗܝ ܘܒܠܒܘܬܗܘܢ ܗܦܟܘ ܠܗܘܢ ܠܡܨܪܝܢ ܀",
      "paragraphStart": false
