{
  "chapter": {
    "id": "peshitta:acts.7",
    "translationId": "peshitta",
    "bookSlug": "acts",
    "chapterNumber": 7,
    "referenceLabel": "Acts 7",
    "summary": "Source text for Acts 7 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.7.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Acts 7:1",
      "text": "ܘܫܐܠܗ ܪܒ ܟܗܢܐ ܕܐܢ ܗܘ ܕܗܠܝܢ ܗܟܢܐ ܐܢܝܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.7.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Acts 7:2",
      "text": "ܗܘ ܕܝܢ ܐܡܪ ܓܒܪܐ ܐܚܝܢ ܘܐܒܗܬܢ ܫܡܥܘ ܐܠܗܐ ܕܬܫܒܘܚܬܐ ܐܬܚܙܝ ܠܐܒܘܢ ܐܒܪܗܡ ܟܕ ܐܝܬܘܗܝ ܗܘܐ ܒܝܬ ܢܗܪܝܢ ܥܕ ܠܐ ܢܐܬܐ ܢܥܡܪ ܒܚܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Acts 7:3",
      "text": "ܘܐܡܪ ܗܘܐ ܠܗ ܕܦܘܩ ܡܢ ܐܪܥܟ ܘܡܢ ܠܘܬ ܒܢܝ ܛܘܗܡܟ ܘܬܐ ܠܐܪܥܐ ܐܝܕܐ ܕܐܚܘܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Acts 7:4",
      "text": "ܘܗܝܕܝܢ ܢܦܩ ܐܒܪܗܡ ܡܢ ܐܪܥܐ ܕܟܠܕܝܐ ܘܐܬܐ ܥܡܪ ܒܚܪܢ ܘܡܢ ܬܡܢ ܟܕ ܡܝܬ ܐܒܘܗܝ ܫܢܝܗ ܐܠܗܐ ܠܐܪܥܐ ܗܕܐ ܕܒܗ ܥܡܪܝܢ ܐܢܬܘܢ ܝܘܡܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Acts 7:5",
      "text": "ܘܠܐ ܝܗܒ ܠܗ ܝܪܬܘܬܐ ܒܗ ܐܦ ܠܐ ܕܘܪܟܬܐ ܕܪܓܠܐ ܘܐܫܬܘܕܝ ܗܘܐ ܕܢܬܠܝܗ ܠܗ ܐܝܟ ܕܠܡܐܪܬܗ ܠܗ ܘܠܙܪܥܗ ܟܕ ܠܝܬ ܗܘܐ ܠܗ ܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Acts 7:6",
      "text": "ܘܡܠܠ ܗܘܐ ܥܡܗ ܐܠܗܐ ܟܕ ܐܡܪ ܠܗ ܕܢܗܘܐ ܙܪܥܟ ܬܘܬܒܐ ܒܐܪܥܐ ܢܘܟܪܝܬܐ ܘܢܫܥܒܕܘܢܝܗܝ ܘܢܒܐܫܘܢ ܠܗ ܐܪܒܥܡܐܐ ܫܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Acts 7:7",
      "text": "ܘܠܥܡܐ ܕܢܦܠܚܘܢ ܥܒܕܘܬܐ ܐܕܘܢܝܘܗܝ ܐܢܐ ܐܡܪ ܐܠܗܐ ܘܡܢ ܒܬܪ ܗܠܝܢ ܢܦܩܘܢ ܘܢܦܠܚܘܢ ܠܝ ܒܐܬܪܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Acts 7:8",
      "text": "ܘܝܗܒ ܠܗ ܕܝܬܩܐ ܕܓܙܘܪܬܐ ܘܗܝܕܝܢ ܐܘܠܕ ܠܐܝܤܚܩ ܘܓܙܪܗ ܒܝܘܡܐ ܬܡܝܢܝܐ ܘܐܝܤܚܩ ܐܘܠܕ ܠܝܥܩܘܒ ܘܝܥܩܘܒ ܐܘܠܕ ܠܬܪܥܤܪ ܐܒܗܬܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Acts 7:9",
      "text": "ܘܗܢܘܢ ܐܒܗܬܢ ܛܢܘ ܒܝܘܤܦ ܘܙܒܢܘܗܝ ܠܡܨܪܝܢ ܘܐܠܗܐ ܥܡܗ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Acts 7:10",
      "text": "ܘܦܪܩܗ ܗܘܐ ܡܢ ܟܠܗܘܢ ܐܘܠܨܢܘܗܝ ܘܝܗܒ ܠܗ ܛܝܒܘܬܐ ܘܚܟܡܬܐ ܩܕܡ ܦܪܥܘܢ ܡܠܟܐ ܕܡܨܪܝܢ ܘܐܩܝܡܗ ܪܫܐ ܥܠ ܡܨܪܝܢ ܘܥܠ ܒܝܬܗ ܟܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Acts 7:11",
      "text": "ܘܗܘܐ ܟܦܢܐ ܘܐܘܠܨܢܐ ܪܒܐ ܒܟܠܗ ܡܨܪܝܢ ܘܒܐܪܥܐ ܕܟܢܥܢ ܘܠܝܬ ܗܘܐ ܠܗܘܢ ܠܡܤܒܥ ܠܐܒܗܬܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Acts 7:12",
      "text": "ܘܟܕ ܫܡܥ ܝܥܩܘܒ ܕܐܝܬ ܥܒܘܪܐ ܒܡܨܪܝܢ ܫܕܪ ܗܘܐ ܠܐܒܗܬܢ ܠܘܩܕܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Acts 7:13",
      "text": "ܘܟܕ ܐܙܠܘ ܕܬܪܬܝܢ ܙܒܢܝܢ ܐܘܕܥ ܝܘܤܦ ܢܦܫܗ ܠܐܚܘܗܝ ܘܐܬܝܕܥ ܠܦܪܥܘܢ ܛܘܗܡܗ ܕܝܘܤܦ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Acts 7:14",
      "text": "ܘܫܕܪ ܗܘܐ ܝܘܤܦ ܘܐܝܬܝܗ ܠܐܒܘܗܝ ܝܥܩܘܒ ܘܠܟܠܗ ܛܘܗܡܗ ܘܗܘܝܢ ܗܘܘ ܒܡܢܝܢܐ ܫܒܥܝܢ ܘܚܡܫ ܢܦܫܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Acts 7:15",
      "text": "ܘܢܚܬ ܝܥܩܘܒ ܠܡܨܪܝܢ ܘܡܝܬ ܬܡܢ ܗܘ ܘܐܒܗܬܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Acts 7:16",
      "text": "ܘܐܫܬܢܝ ܠܫܟܝܡ ܘܐܬܬܤܝܡ ܒܩܒܪܐ ܕܙܒܢ ܗܘܐ ܐܒܪܗܡ ܒܟܤܦܐ ܡܢ ܒܢܝ ܚܡܘܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Acts 7:17",
      "text": "ܘܟܕ ܡܛܝ ܗܘܐ ܙܒܢܐ ܕܡܕܡ ܕܐܫܬܘܕܝ ܗܘܐ ܒܡܘܡܬܐ ܐܠܗܐ ܠܐܒܪܗܡ ܤܓܝ ܗܘܐ ܥܡܐ ܘܬܩܦ ܒܡܨܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Acts 7:18",
      "text": "ܥܕܡܐ ܕܩܡ ܡܠܟܐ ܐܚܪܢܐ ܥܠ ܡܨܪܝܢ ܐܝܢܐ ܕܠܐ ܝܕܥ ܗܘܐ ܠܗ ܠܝܘܤܦ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Acts 7:19",
      "text": "ܘܐܨܛܢܥ ܥܠ ܛܘܗܡܢ ܘܐܒܐܫ ܠܐܒܗܬܢ ܘܦܩܕ ܕܢܗܘܘܢ ܡܫܬܕܝܢ ܝܠܘܕܝܗܘܢ ܕܠܐ ܢܚܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Acts 7:20",
      "text": "ܒܗ ܒܙܒܢܐ ܗܘ ܐܬܝܠܕ ܡܘܫܐ ܘܪܚܝܡ ܗܘܐ ܠܐܠܗܐ ܘܐܬܪܒܝ ܝܪܚܐ ܬܠܬܐ ܒܝܬ ܐܒܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Acts 7:21",
      "text": "ܘܟܕ ܐܫܬܕܝ ܡܢ ܐܡܗ ܐܫܟܚܬܗ ܒܪܬ ܦܪܥܘܢ ܘܪܒܝܬܗ ܠܗ ܠܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Acts 7:22",
      "text": "ܘܐܬܪܕܝ ܡܘܫܐ ܒܟܠܗ ܚܟܡܬܐ ܕܡܨܪܝܐ ܘܥܬܝܕ ܗܘܐ ܒܡܠܘܗܝ ܘܐܦ ܒܥܒܕܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Acts 7:23",
      "text": "ܘܟܕ ܗܘܐ ܒܪ ܐܪܒܥܝܢ ܫܢܝܢ ܤܠܩ ܗܘܐ ܥܠ ܠܒܗ ܕܢܤܥܘܪ ܠܐܚܘܗܝ ܒܢܝ ܐܝܤܪܝܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Acts 7:24",
      "text": "ܘܚܙܐ ܠܚܕ ܡܢ ܒܢܝ ܫܪܒܬܗ ܕܡܬܕܒܪ ܒܩܛܝܪܐ ܘܬܒܥܗ ܘܥܒܕ ܠܗ ܕܝܢܐ ܘܩܛܠܗ ܠܡܨܪܝܐ ܗܘ ܕܡܤܟܠ ܗܘܐ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Acts 7:25",
      "text": "ܘܤܒܪ ܕܡܤܬܟܠܝܢ ܐܚܘܗܝ ܒܢܝ ܐܝܤܪܝܠ ܕܐܠܗܐ ܒܐܝܕܗ ܝܗܒ ܠܗܘܢ ܦܘܪܩܢܐ ܘܠܐ ܐܤܬܟܠܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "Acts 7:26",
      "text": "ܘܠܝܘܡܐ ܐܚܪܢܐ ܐܬܚܙܝ ܠܗܘܢ ܟܕ ܢܨܝܢ ܗܢܘܢ ܚܕ ܥܡ ܚܕ ܘܡܦܝܤ ܗܘܐ ܠܗܘܢ ܕܢܫܬܝܢܘܢ ܟܕ ܐܡܪ ܓܒܪܐ ܐܚܐ ܐܢܬܘܢ ܡܛܠ ܡܢܐ ܡܤܟܠܝܢ ܐܢܬܘܢ ܚܕ ܒܚܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "Acts 7:27",
      "text": "ܗܘ ܕܝܢ ܕܡܤܟܠ ܗܘܐ ܒܚܒܪܗ ܕܚܩܗ ܡܢ ܠܘܬܗ ܘܐܡܪ ܠܗ ܡܢܘ ܐܩܝܡܟ ܥܠܝܢ ܪܫܐ ܘܕܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "Acts 7:28",
      "text": "ܕܠܡܐ ܠܡܩܛܠܢܝ ܒܥܐ ܐܢܬ ܐܝܟ ܕܩܛܠܬ ܐܬܡܠܝ ܠܡܨܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.29",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "Acts 7:29",
      "text": "ܘܥܪܩ ܡܘܫܐ ܒܡܠܬܐ ܗܕܐ ܘܗܘܐ ܬܘܬܒܐ ܒܐܪܥܐ ܕܡܕܝܢ ܘܗܘܘ ܠܗ ܬܪܝܢ ܒܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.30",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 30,
      "referenceLabel": "Acts 7:30",
      "text": "ܘܟܕ ܡܠܝ ܠܗ ܬܡܢ ܐܪܒܥܝܢ ܫܢܝܢ ܐܬܚܙܝ ܠܗ ܒܡܕܒܪܐ ܕܛܘܪ ܤܝܢܝ ܡܠܐܟܗ ܕܡܪܝܐ ܒܢܘܪܐ ܕܝܩܕܐ ܒܤܢܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.31",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 31,
      "referenceLabel": "Acts 7:31",
      "text": "ܘܟܕ ܚܙܐ ܡܘܫܐ ܐܬܕܡܪ ܒܚܙܘܐ ܘܟܕ ܐܬܩܪܒ ܕܢܚܙܐ ܐܡܪ ܠܗ ܡܪܝܐ ܒܩܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.32",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 32,
      "referenceLabel": "Acts 7:32",
      "text": "ܐܢܐ ܐܢܐ ܐܠܗܐ ܕܐܒܗܝܟ ܐܠܗܗ ܕܐܒܪܗܡ ܘܕܐܝܤܚܩ ܘܕܝܥܩܘܒ ܘܟܕ ܪܬܝܬ ܗܘܐ ܡܘܫܐ ܠܐ ܡܡܪܚ ܗܘܐ ܕܢܚܘܪ ܒܚܙܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.33",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 33,
      "referenceLabel": "Acts 7:33",
      "text": "ܘܐܡܪ ܠܗ ܡܪܝܐ ܫܪܝ ܡܤܢܝܟ ܡܢ ܪܓܠܝܟ ܐܪܥܐ ܓܝܪ ܕܩܐܡ ܐܢܬ ܒܗ ܩܕܝܫܐ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.34",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 34,
      "referenceLabel": "Acts 7:34",
      "text": "ܡܚܙܐ ܚܙܝܬ ܐܘܠܨܢܗ ܕܥܡܝ ܕܒܡܨܪܝܢ ܘܬܢܚܬܗ ܫܡܥܬ ܘܢܚܬܬ ܕܐܦܪܘܩ ܐܢܘܢ ܘܗܫܐ ܬܐ ܐܫܕܪܟ ܠܡܨܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.35",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 35,
      "referenceLabel": "Acts 7:35",
      "text": "ܠܗܢܐ ܡܘܫܐ ܕܟܦܪܘ ܒܗ ܟܕ ܐܡܪܝܢ ܕܡܢܘ ܐܩܝܡܟ ܥܠܝܢ ܪܫܐ ܘܕܝܢܐ ܠܗ ܠܗܢܐ ܐܠܗܐ ܪܫܐ ܘܦܪܘܩܐ ܫܕܪ ܠܗܘܢ ܒܐܝܕܝ ܡܠܐܟܐ ܗܘ ܕܐܬܚܙܝ ܠܗ ܒܤܢܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.7.36",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 36,
      "referenceLabel": "Acts 7:36",
      "text": "ܗܢܘ ܕܐܦܩ ܐܢܘܢ ܟܕ ܥܒܕ ܐܬܘܬܐ ܘܬܕܡܪܬܐ ܘܓܒܪܘܬܐ ܒܐܪܥܐ ܕܡܨܪܝܢ ܘܒܝܡܐ ܕܤܘܦ ܘܒܡܕܒܪܐ ܫܢܝܢ ܐܪܒܥܝܢ ܀",
      "paragraphStart": false
    },
    {
