      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 7,
      "verseNumber": 47,
      "referenceLabel": "Acts 7:47",
      "text": "ܫܠܝܡܘܢ ܕܝܢ ܒܢܐ ܠܗ ܒܝܬܐ ܀",
