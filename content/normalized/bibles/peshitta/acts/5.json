    "chapterNumber": 5,
    "referenceLabel": "Acts 5",
    "summary": "Source text for Acts 5 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.5.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Acts 5:1",
      "text": "ܘܓܒܪܐ ܚܕ ܕܫܡܗ ܗܘܐ ܚܢܢܝܐ ܥܡ ܐܢܬܬܗ ܕܫܡܗ ܗܘܐ ܫܦܝܪܐ ܙܒܢ ܗܘܐ ܩܪܝܬܗ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.5.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Acts 5:2",
      "text": "ܘܫܩܠ ܡܢ ܛܝܡܝܗ ܘܛܫܝ ܟܕ ܪܓܝܫܐ ܗܘܬ ܒܗ ܐܢܬܬܗ ܘܐܝܬܝ ܡܢܗ ܡܢ ܟܤܦܐ ܘܤܡ ܩܕܡ ܪܓܠܝܗܘܢ ܕܫܠܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Acts 5:3",
      "text": "ܘܐܡܪ ܠܗ ܫܡܥܘܢ ܚܢܢܝܐ ܡܢܘ ܕܗܟܢܐ ܡܠܐ ܤܛܢܐ ܠܒܟ ܕܬܕܓܠ ܒܪܘܚܐ ܕܩܘܕܫܐ ܘܬܛܫܐ ܡܢ ܟܤܦܐ ܕܕܡܝܗ ܕܩܪܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Acts 5:4",
      "text": "ܠܐ ܗܘܐ ܕܝܠܟ ܗܘܬ ܥܕܠܐ ܬܙܕܒܢ ܘܡܢ ܕܐܙܕܒܢܬ ܬܘܒ ܐܢܬ ܫܠܝܛ ܗܘܝܬ ܥܠ ܕܡܝܗ ܠܡܢܐ ܤܡܬ ܒܠܒܟ ܕܬܥܒܕ ܨܒܘܬܐ ܗܕܐ ܠܐ ܕܓܠܬ ܒܒܢܝ ܐܢܫܐ ܐܠܐ ܒܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Acts 5:5",
      "text": "ܘܟܕ ܫܡܥ ܚܢܢܝܐ ܗܠܝܢ ܡܠܐ ܢܦܠ ܘܡܝܬ ܘܗܘܬ ܕܚܠܬܐ ܪܒܬܐ ܒܟܠܗܘܢ ܗܠܝܢ ܕܫܡܥܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Acts 5:6",
      "text": "ܘܩܡܘ ܐܝܠܝܢ ܕܥܠܝܡܝܢ ܒܗܘܢ ܘܟܢܫܘܗܝ ܘܐܦܩܘ ܩܒܪܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Acts 5:7",
      "text": "ܘܡܢ ܒܬܪ ܕܗܘܝ ܬܠܬ ܫܥܝܢ ܐܦ ܐܢܬܬܗ ܥܠܬ ܟܕ ܠܐ ܝܕܥܐ ܗܘܬ ܡܢܐ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Acts 5:8",
      "text": "ܐܡܪ ܠܗ ܫܡܥܘܢ ܐܡܪ ܠܝ ܐܢ ܒܗܠܝܢ ܕܡܝܐ ܙܒܢܬܘܢ ܩܪܝܬܐ ܗܝ ܕܝܢ ܐܡܪܬ ܐܝܢ ܒܗܠܝܢ ܕܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Acts 5:9",
      "text": "ܐܡܪ ܠܗ ܫܡܥܘܢ ܡܛܠ ܕܐܫܬܘܝܬܘܢ ܠܡܢܤܝܘ ܪܘܚܗ ܕܡܪܝܐ ܗܐ ܪܓܠܝܗܘܢ ܕܩܒܘܪܘܗܝ ܕܒܥܠܟܝ ܒܬܪܥܐ ܘܗܢܘܢ ܢܦܩܘܢܟܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Acts 5:10",
      "text": "ܘܒܗ ܒܫܥܬܐ ܢܦܠܬ ܩܕܡ ܪܓܠܝܗܘܢ ܘܡܝܬܬ ܘܥܠܘ ܥܠܝܡܐ ܗܢܘܢ ܘܐܫܟܚܘܗ ܟܕ ܡܝܬܐ ܘܩܦܤܘ ܐܘܒܠܘ ܩܒܪܘܗ ܥܠ ܓܢܒ ܒܥܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Acts 5:11",
      "text": "ܘܗܘܬ ܕܚܠܬܐ ܪܒܬܐ ܒܟܠܗ ܥܕܬܐ ܘܒܟܠܗܘܢ ܗܢܘܢ ܕܫܡܥܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Acts 5:12",
      "text": "ܘܗܘܝܢ ܗܘܝ ܒܝܕ ܫܠܝܚܐ ܐܬܘܬܐ ܘܓܒܪܘܬܐ ܤܓܝܐܬܐ ܒܥܡܐ ܘܟܠܗܘܢ ܟܢܝܫܝܢ ܗܘܘ ܐܟܚܕܐ ܒܐܤܛܘܐ ܕܫܠܝܡܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Acts 5:13",
      "text": "ܘܡܢ ܐܢܫܐ ܐܚܪܢܐ ܐܢܫ ܠܐ ܡܡܪܚ ܗܘܐ ܕܢܬܩܪܒ ܠܘܬܗܘܢ ܐܠܐ ܡܘܪܒ ܗܘܐ ܠܗܘܢ ܥܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Acts 5:14",
      "text": "ܘܝܬܝܪ ܡܬܬܘܤܦܢ ܗܘܘ ܐܝܠܝܢ ܕܡܗܝܡܢܝܢ ܗܘܘ ܒܡܪܝܐ ܟܢܫܐ ܕܓܒܪܐ ܘܕܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Acts 5:15",
      "text": "ܐܝܟܢܐ ܕܒܫܘܩܐ ܡܦܩܝܢ ܗܘܘ ܠܟܪܝܗܐ ܟܕ ܪܡܝܢ ܗܘܘ ܒܥܪܤܬܐ ܕܐܡܬܝ ܕܢܗܘܐ ܐܬܐ ܫܡܥܘܢ ܐܦܢ ܛܠܢܝܬܗ ܬܓܢ ܥܠܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Acts 5:16",
      "text": "ܐܬܝܢ ܗܘܘ ܕܝܢ ܤܓܝܐܐ ܠܘܬܗܘܢ ܡܢ ܡܕܝܢܬܐ ܐܚܪܢܝܬܐ ܕܚܕܪܝ ܐܘܪܫܠܡ ܟܕ ܡܝܬܝܢ ܗܘܘ ܟܪܝܗܐ ܘܐܝܠܝܢ ܕܗܘܝܢ ܗܘܝ ܠܗܘܢ ܪܘܚܐ ܛܢܦܬܐ ܘܡܬܚܠܡܝܢ ܗܘܘ ܟܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Acts 5:17",
      "text": "ܘܐܬܡܠܝ ܗܘܐ ܚܤܡܐ ܪܒ ܟܗܢܐ ܘܟܠܗܘܢ ܕܥܡܗ ܕܐܝܬܝܗܘܢ ܗܘܘ ܡܢ ܝܘܠܦܢܐ ܕܙܕܘܩܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Acts 5:18",
      "text": "ܘܐܪܡܝܘ ܐܝܕܝܐ ܥܠ ܫܠܝܚܐ ܘܐܚܕܘ ܐܤܪܘ ܐܢܘܢ ܒܝܬ ܐܤܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Acts 5:19",
      "text": "ܗܝܕܝܢ ܒܠܠܝܐ ܡܠܐܟܐ ܕܡܪܝܐ ܦܬܚ ܬܪܥܐ ܕܒܝܬ ܐܤܝܪܐ ܘܐܦܩ ܐܢܘܢ ܘܐܡܪ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Acts 5:20",
      "text": "ܙܠܘ ܩܘܡܘ ܒܗܝܟܠܐ ܘܡܠܠܘ ܠܥܡܐ ܟܠܗܝܢ ܡܠܐ ܗܠܝܢ ܕܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Acts 5:21",
      "text": "ܘܢܦܩܘ ܥܕܢ ܫܦܪܐ ܘܥܠܘ ܠܗܝܟܠܐ ܘܡܠܦܝܢ ܗܘܘ ܪܒ ܟܗܢܐ ܕܝܢ ܘܐܝܠܝܢ ܕܥܡܗ ܩܪܘ ܠܚܒܪܝܗܘܢ ܘܠܩܫܝܫܐ ܕܐܝܤܪܝܠ ܘܫܕܪܘ ܠܒܝܬ ܐܤܝܪܐ ܕܢܝܬܘܢ ܐܢܘܢ ܠܫܠܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Acts 5:22",
      "text": "ܘܟܕ ܐܙܠܘ ܐܝܠܝܢ ܕܐܫܬܕܪܘ ܡܢܗܘܢ ܠܐ ܐܫܟܚܘ ܐܢܘܢ ܒܝܬ ܐܤܝܪܐ ܘܗܦܟܘ ܐܬܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Acts 5:23",
      "text": "ܐܡܪܝܢ ܐܫܟܚܢ ܒܝܬ ܐܤܝܪܐ ܕܐܚܝܕ ܙܗܝܪܐܝܬ ܘܐܦ ܠܢܛܘܪܐ ܕܩܝܡܝܢ ܥܠ ܬܪܥܐ ܘܦܬܚܢ ܘܐܢܫ ܠܐ ܐܫܟܚܢ ܬܡܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Acts 5:24",
      "text": "ܘܟܕ ܫܡܥܘ ܗܠܝܢ ܡܠܐ ܪܒܝ ܟܗܢܐ ܘܐܪܟܘܢܐ ܕܗܝܟܠܐ ܬܘܝܪܝܢ ܗܘܘ ܥܠܝܗܘܢ ܘܡܬܚܫܒܝܢ ܗܘܘ ܕܡܢܐ ܗܝ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Acts 5:25",
      "text": "ܘܐܬܐ ܐܢܫ ܐܘܕܥ ܐܢܘܢ ܕܗܢܘܢ ܓܒܪܐ ܕܚܒܫܬܘܢ ܒܝܬ ܐܤܝܪܐ ܗܐ ܩܝܡܝܢ ܒܗܝܟܠܐ ܘܡܠܦܝܢ ܠܥܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Acts 5:26",
      "text": "ܗܝܕܝܢ ܐܙܠܘ ܐܪܟܘܢܐ ܥܡ ܕܚܫܐ ܕܢܝܬܘܢ ܐܢܘܢ ܠܐ ܒܩܛܝܪܐ ܕܚܠܝܢ ܗܘܘ ܓܝܪ ܕܠܡܐ ܢܪܓܘܡ ܐܢܘܢ ܥܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Acts 5:27",
      "text": "ܘܟܕ ܐܝܬܝܘ ܐܢܘܢ ܐܩܝܡܘ ܐܢܘܢ ܩܕܡ ܟܠܗ ܟܢܫܐ ܘܐܩܦ ܗܘܐ ܪܒ ܟܗܢܐ ܠܡܐܡܪ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "Acts 5:28",
      "text": "ܠܐ ܗܘܐ ܡܦܩܕ ܦܩܕܢ ܗܘܝܢ ܠܟܘܢ ܕܠܐܢܫ ܠܐ ܬܠܦܘܢ ܒܫܡܐ ܗܢܐ ܐܢܬܘܢ ܕܝܢ ܗܐ ܡܠܝܬܘܢܗ ܠܐܘܪܫܠܡ ܡܢ ܝܘܠܦܢܟܘܢ ܘܨܒܝܢ ܐܢܬܘܢ ܕܬܝܬܘܢ ܥܠܝܢ ܕܡܗ ܕܓܒܪܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.29",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "Acts 5:29",
      "text": "ܥܢܐ ܫܡܥܘܢ ܥܡ ܫܠܝܚܐ ܘܐܡܪ ܠܗܘܢ ܠܐܠܗܐ ܘܠܐ ܠܡܬܛܦܤܘ ܝܬܝܪ ܡܢ ܕܠܒܢܝܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.30",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "Acts 5:30",
      "text": "ܐܠܗܐ ܕܐܒܗܬܢ ܐܩܝܡ ܠܝܫܘܥ ܐܝܢܐ ܕܐܢܬܘܢ ܩܛܠܬܘܢ ܟܕ ܬܠܝܬܘܢܝܗܝ ܥܠ ܩܝܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.31",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "Acts 5:31",
      "text": "ܠܗ ܠܗܢܐ ܐܩܝܡ ܐܠܗܐ ܪܫܐ ܘܡܚܝܢܐ ܘܐܪܝܡܗ ܒܝܡܝܢܗ ܐܝܟ ܕܢܬܠ ܬܝܒܘܬܐ ܘܫܘܒܩܢ ܚܛܗܐ ܠܐܝܤܪܝܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.32",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 32,
      "referenceLabel": "Acts 5:32",
      "text": "ܘܚܢܢ ܤܗܕܐ ܚܢܢ ܕܡܠܐ ܗܠܝܢ ܘܪܘܚܐ ܕܩܘܕܫܐ ܗܘ ܕܝܗܒ ܐܠܗܐ ܠܐܝܠܝܢ ܕܡܗܝܡܢܝܢ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.33",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 33,
      "referenceLabel": "Acts 5:33",
      "text": "ܘܟܕ ܫܡܥܘ ܗܘܘ ܗܠܝܢ ܡܠܐ ܡܬܓܘܙܠܝܢ ܗܘܘ ܒܪܘܓܙܐ ܘܡܬܚܫܒܝܢ ܗܘܘ ܠܡܩܛܠ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.5.34",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 5,
      "verseNumber": 34,
      "referenceLabel": "Acts 5:34",
