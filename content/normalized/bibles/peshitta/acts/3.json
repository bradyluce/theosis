{
  "chapter": {
    "id": "peshitta:acts.3",
    "translationId": "peshitta",
    "bookSlug": "acts",
    "chapterNumber": 3,
    "referenceLabel": "Acts 3",
    "summary": "Source text for Acts 3 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.3.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Acts 3:1",
      "text": "ܘܗܘܐ ܕܟܕ ܤܠܩܝܢ ܫܡܥܘܢ ܟܐܦܐ ܘܝܘܚܢܢ ܐܟܚܕܐ ܠܗܝܟܠܐ ܒܥܕܢܐ ܕܨܠܘܬܐ ܕܬܫܥ ܫܥܝܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.3.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Acts 3:2",
      "text": "ܘܗܐ ܓܒܪܐ ܚܕ ܚܓܝܪܐ ܕܡܢ ܟܪܤ ܐܡܗ ܫܩܝܠܝܢ ܗܘܘ ܐܢܫܐ ܐܝܠܝܢ ܕܡܥܕܝܢ ܗܘܘ ܡܝܬܝܢ ܘܤܝܡܝܢ ܠܗ ܒܬܪܥܐ ܕܗܝܟܠܐ ܕܡܬܩܪܐ ܫܦܝܪܐ ܕܢܗܘܐ ܫܐܠ ܙܕܩܬܐ ܡܢ ܗܢܘܢ ܕܥܐܠܝܢ ܠܗܝܟܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Acts 3:3",
      "text": "ܗܢܐ ܟܕ ܚܙܐ ܠܫܡܥܘܢ ܘܠܝܘܚܢܢ ܕܥܐܠܝܢ ܠܗܝܟܠܐ ܒܥܐ ܗܘܐ ܡܢܗܘܢ ܕܢܬܠܘܢ ܠܗ ܙܕܩܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Acts 3:4",
      "text": "ܘܚܪܘ ܒܗ ܫܡܥܘܢ ܘܝܘܚܢܢ ܘܐܡܪܘ ܠܗ ܚܘܪ ܒܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Acts 3:5",
      "text": "ܗܘ ܕܝܢ ܚܪ ܒܗܘܢ ܟܕ ܤܒܪ ܗܘܐ ܠܡܤܒ ܡܢܗܘܢ ܡܕܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Acts 3:6",
      "text": "ܐܡܪ ܠܗ ܫܡܥܘܢ ܕܗܒܐ ܘܤܐܡܐ ܠܝܬ ܠܝ ܐܠܐ ܡܕܡ ܕܐܝܬ ܠܝ ܝܗܒ ܐܢܐ ܠܟ ܒܫܡܗ ܕܝܫܘܥ ܡܫܝܚܐ ܢܨܪܝܐ ܩܘܡ ܗܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Acts 3:7",
      "text": "ܘܐܚܕܗ ܒܐܝܕܗ ܕܝܡܝܢܐ ܘܐܩܝܡܗ ܘܒܗ ܒܫܥܬܐ ܫܪ ܪܓܠܘܗܝ ܘܥܩܒܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Acts 3:8",
      "text": "ܘܫܘܪ ܩܡ ܘܗܠܟ ܘܥܠ ܥܡܗܘܢ ܠܗܝܟܠܐ ܟܕ ܡܗܠܟ ܘܡܫܘܪ ܘܡܫܒܚ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Acts 3:9",
      "text": "ܘܚܙܐܘܗܝ ܟܠܗ ܥܡܐ ܟܕ ܡܗܠܟ ܘܡܫܒܚ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Acts 3:10",
      "text": "ܘܐܫܬܘܕܥܘ ܕܗܘܝܘ ܗܘ ܚܕܘܪܐ ܕܝܬܒ ܗܘܐ ܟܠܝܘܡ ܘܫܐܠ ܙܕܩܬܐ ܥܠ ܬܪܥܐ ܕܡܬܩܪܐ ܫܦܝܪܐ ܘܐܬܡܠܝܘ ܬܡܗܐ ܘܕܘܡܪܐ ܥܠ ܡܕܡ ܕܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Acts 3:11",
      "text": "ܘܟܕ ܐܚܝܕ ܗܘܐ ܠܫܡܥܘܢ ܘܠܝܘܚܢܢ ܪܗܛ ܟܠܗ ܥܡܐ ܟܕ ܬܗܝܪ ܠܘܬܗܘܢ ܠܐܤܛܘܐ ܕܡܬܩܪܐ ܕܫܠܝܡܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Acts 3:12",
      "text": "ܘܟܕ ܚܙܐ ܫܡܥܘܢ ܥܢܐ ܘܐܡܪ ܠܗܘܢ ܓܒܪܐ ܒܢܝ ܐܝܤܪܝܠ ܡܢܐ ܡܬܕܡܪܝܢ ܐܢܬܘܢ ܒܗܢܐ ܐܘ ܒܢ ܡܢܐ ܚܝܪܝܢ ܐܢܬܘܢ ܐܝܟ ܗܘ ܕܒܚܝܠܐ ܕܝܠܢ ܐܘ ܒܫܘܠܛܢܢ ܥܒܕܢ ܗܕܐ ܕܢܗܠܟ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Acts 3:13",
      "text": "ܐܠܗܗ ܗܘ ܕܐܒܪܗܡ ܘܕܐܝܤܚܩ ܘܕܝܥܩܘܒ ܐܠܗܐ ܕܐܒܗܬܢ ܫܒܚ ܠܒܪܗ ܝܫܘܥ ܗܘ ܕܐܢܬܘܢ ܐܫܠܡܬܘܢ ܘܟܦܪܬܘܢ ܒܗ ܩܕܡ ܐܦܘܗܝ ܕܦܝܠܛܘܤ ܟܕ ܗܘ ܙܕܩ ܗܘܐ ܕܢܫܪܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Acts 3:14",
      "text": "ܐܢܬܘܢ ܕܝܢ ܒܩܕܝܫܐ ܘܙܕܝܩܐ ܟܦܪܬܘܢ ܘܫܐܠܬܘܢ ܠܟܘܢ ܠܓܒܪܐ ܩܛܘܠܐ ܕܢܬܝܗܒ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Acts 3:15",
      "text": "ܘܠܗܘ ܪܫܐ ܕܚܝܐ ܩܛܠܬܘܢ ܕܠܗ ܐܩܝܡ ܐܠܗܐ ܡܢ ܒܝܬ ܡܝܬܐ ܘܚܢܢ ܟܠܢ ܤܗܕܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Acts 3:16",
      "text": "ܘܒܗܝܡܢܘܬܐ ܕܫܡܗ ܠܗܢܐ ܕܚܙܝܢ ܐܢܬܘܢ ܘܝܕܥܝܢ ܐܢܬܘܢ ܗܘ ܐܫܪ ܘܐܤܝ ܘܗܝܡܢܘܬܐ ܕܒܗ ܝܗܒܬ ܠܗ ܗܕܐ ܚܠܝܡܘܬܐ ܩܕܡ ܟܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Acts 3:17",
      "text": "ܒܪܡ ܗܫܐ ܐܚܝ ܝܕܥ ܐܢܐ ܕܒܛܘܥܝܝ ܥܒܕܬܘܢ ܗܕܐ ܐܝܟ ܕܥܒܕܘ ܪܫܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Acts 3:18",
      "text": "ܘܐܠܗܐ ܐܝܟ ܡܕܡ ܕܩܕܡ ܐܟܪܙ ܒܦܘܡ ܟܠܗܘܢ ܢܒܝܐ ܕܢܚܫ ܡܫܝܚܗ ܡܠܝ ܗܟܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Acts 3:19",
      "text": "ܬܘܒܘ ܗܟܝܠ ܘܐܬܦܢܘ ܐܝܟܢܐ ܕܢܬܥܛܘܢ ܚܛܗܝܟܘܢ ܘܢܐܬܘܢ ܠܟܘܢ ܙܒܢܐ ܕܢܝܚܬܐ ܡܢ ܩܕܡ ܦܪܨܘܦܗ ܕܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Acts 3:20",
      "text": "ܘܢܫܕܪ ܠܟܘܢ ܠܐܝܢܐ ܕܡܛܝܒ ܗܘܐ ܠܟܘܢ ܠܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Acts 3:21",
      "text": "ܕܠܗ ܘܠܐ ܠܫܡܝܐ ܕܢܩܒܠܘܢ ܥܕܡܐ ܠܡܘܠܝܐ ܕܙܒܢܐ ܕܟܠܗܝܢ ܐܝܠܝܢ ܕܡܠܠ ܐܠܗܐ ܒܦܘܡܐ ܕܢܒܝܘܗܝ ܩܕܝܫܐ ܕܡܢ ܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Acts 3:22",
      "text": "ܡܘܫܐ ܓܝܪ ܐܡܪ ܕܢܒܝܐ ܢܩܝܡ ܠܟܘܢ ܡܪܝܐ ܡܢ ܐܚܝܟܘܢ ܐܟܘܬܝ ܠܗ ܫܡܥܘ ܒܟܠ ܡܐ ܕܢܡܠܠ ܥܡܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Acts 3:23",
      "text": "ܘܬܗܘܐ ܟܠ ܢܦܫܐ ܐܝܕܐ ܕܠܐ ܬܫܡܥ ܠܢܒܝܐ ܗܘ ܬܐܒܕ ܢܦܫܐ ܗܝ ܡܢ ܥܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Acts 3:24",
      "text": "ܘܢܒܝܐ ܟܠܗܘܢ ܡܢ ܫܡܘܐܝܠ ܘܐܝܠܝܢ ܕܡܢ ܒܬܪܗ ܗܘܘ ܡܠܠܘ ܘܐܟܪܙܘ ܥܠ ܝܘܡܬܐ ܗܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Acts 3:25",
      "text": "ܐܢܬܘܢ ܐܢܘܢ ܒܢܝܗܘܢ ܕܢܒܝܐ ܘܕܕܝܬܩܐ ܐܝܕܐ ܕܤܡ ܐܠܗܐ ܠܐܒܗܬܢ ܟܕ ܐܡܪ ܠܐܒܪܗܡ ܕܒܙܪܥܟ ܢܬܒܪܟܢ ܟܠܗܝܢ ܫܪܒܬܐ ܕܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.3.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Acts 3:26",
      "text": "ܠܟܘܢ ܡܢ ܩܕܝܡ ܐܩܝܡ ܘܫܕܪ ܐܠܗܐ ܠܒܪܗ ܟܕ ܡܒܪܟ ܠܟܘܢ ܐܢ ܬܬܦܢܘܢ ܘܬܬܘܒܘܢ ܡܢ ܒܝܫܬܟܘܢ ܀",
      "paragraphStart": false
    }
  ]
}
