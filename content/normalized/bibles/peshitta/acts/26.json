{
  "chapter": {
    "id": "peshitta:acts.26",
    "translationId": "peshitta",
    "bookSlug": "acts",
    "chapterNumber": 26,
    "referenceLabel": "Acts 26",
    "summary": "Source text for Acts 26 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.26.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Acts 26:1",
      "text": "ܘܐܡܪ ܐܓܪܦܘܤ ܠܦܘܠܘܤ ܡܦܤ ܠܟ ܠܡܡܠܠܘ ܥܠ ܐܦܝ ܢܦܫܟ ܗܝܕܝܢ ܦܘܠܘܤ ܦܫܛ ܐܝܕܗ ܘܢܦܩ ܗܘܐ ܪܘܚܐ ܘܐܡܪ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.26.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Acts 26:2",
      "text": "ܥܠ ܟܠ ܡܐ ܕܡܬܪܫܐ ܐܢܐ ܡܢ ܝܗܘܕܝܐ ܡܠܟܐ ܐܓܪܦܐ ܤܒܪ ܐܢܐ ܥܠ ܢܦܫܝ ܕܛܘܒܢܐ ܐܢܐ ܕܩܕܡܝܟ ܝܘܡܢܐ ܢܦܩ ܐܢܐ ܪܘܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Acts 26:3",
      "text": "ܝܬܝܪܐܝܬ ܕܝܕܥ ܐܢܐ ܕܡܦܤ ܐܢܬ ܒܟܠܗܘܢ ܙܛܡܐ ܘܢܡܘܤܐ ܕܝܗܘܕܝܐ ܡܛܠ ܗܢܐ ܒܥܐ ܐܢܐ ܡܢܟ ܕܒܡܓܪܬ ܪܘܚܐ ܬܫܡܥܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Acts 26:4",
      "text": "ܝܕܥܝܢ ܐܢܘܢ ܓܝܪ ܐܦ ܗܢܘܢ ܝܗܘܕܝܐ ܐܢ ܨܒܝܢ ܕܢܤܗܕܘܢ ܕܘܒܪܝ ܕܡܢ ܛܠܝܘܬܝ ܕܗܘܘ ܠܝ ܡܢ ܫܘܪܝܐ ܒܥܡܝ ܘܒܐܘܪܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Acts 26:5",
      "text": "ܡܛܠ ܕܡܢ ܢܘܓܪܐ ܡܦܤܝܢ ܒܝ ܘܝܕܥܝܢ ܕܒܝܘܠܦܢܐ ܪܫܝܐ ܕܦܪܝܫܐ ܚܝܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Acts 26:6",
      "text": "ܘܗܫܐ ܥܠ ܤܒܪܐ ܕܫܘܘܕܝܐ ܕܗܘܐ ܗܘܐ ܠܐܒܗܬܢ ܡܢ ܐܠܗܐ ܩܐܡ ܐܢܐ ܘܡܬܕܝܢ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Acts 26:7",
      "text": "ܕܥܠ ܗܢܐ ܤܒܪܐ ܬܪܬܥܤܪܐ ܫܪܒܢ ܡܤܒܪܢ ܕܢܡܢܥܢ ܒܨܠܘܬܐ ܚܦܝܛܬܐ ܕܐܝܡܡܐ ܘܕܠܠܝܐ ܘܥܠܘܗܝ ܥܠ ܗܢܐ ܤܒܪܐ ܡܬܪܫܐ ܐܢܐ ܡܢ ܐܝܕܝ ܝܗܘܕܝܐ ܡܠܟܐ ܐܓܪܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Acts 26:8",
      "text": "ܡܢܐ ܕܝܢܝܢ ܐܢܬܘܢ ܠܐ ܘܠܐ ܕܢܗܝܡܢ ܕܡܩܝܡ ܐܠܗܐ ܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Acts 26:9",
      "text": "ܐܢܐ ܓܝܪ ܡܢ ܩܕܝܡ ܤܡܬ ܒܪܥܝܢܝ ܕܤܩܘܒܠܐ ܤܓܝܐܐ ܐܤܥܘܪ ܠܘܩܒܠ ܫܡܗ ܕܝܫܘܥ ܢܨܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Acts 26:10",
      "text": "ܗܕܐ ܕܥܒܕܬ ܐܦ ܒܐܘܪܫܠܡ ܘܩܕܝܫܐ ܤܓܝܐܐ ܐܪܡܝܬ ܒܝܬ ܐܤܝܪܐ ܒܫܘܠܛܢܐ ܕܩܒܠܬ ܡܢ ܪܒܝ ܟܗܢܐ ܘܟܕ ܡܬܩܛܠܝܢ ܗܘܘ ܡܢܗܘܢ ܐܫܬܘܬܦܬ ܠܐܝܠܝܢ ܕܚܝܒܘ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Acts 26:11",
      "text": "ܘܒܟܠ ܟܢܘܫܐ ܡܫܬܢܕ ܗܘܝܬ ܒܗܘܢ ܟܕ ܐܠܨ ܗܘܝܬ ܕܢܗܘܘܢ ܡܓܕܦܝܢ ܒܫܡܗ ܕܝܫܘܥ ܘܒܪܘܓܙܐ ܤܓܝܐܐ ܕܡܠܐ ܗܘܝܬ ܥܠܝܗܘܢ ܐܦ ܠܡܕܝܢܬܐ ܐܚܪܢܝܬܐ ܢܦܩ ܗܘܝܬ ܠܡܪܕܦ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Acts 26:12",
      "text": "ܘܟܕ ܐܙܠ ܗܘܝܬ ܡܛܠ ܗܕܐ ܠܕܪܡܤܘܩ ܒܫܘܠܛܢܐ ܘܒܡܦܤܢܘܬܐ ܕܪܒܝ ܟܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 13,
      "referenceLabel": "Acts 26:13",
      "text": "ܒܦܠܓܗ ܕܝܘܡܐ ܒܐܘܪܚܐ ܚܙܝܬ ܡܢ ܫܡܝܐ ܐܘ ܡܠܟܐ ܕܐܙܠܓ ܥܠܝ ܘܥܠ ܟܠ ܕܥܡܝ ܗܘܘ ܢܘܗܪܐ ܕܡܝܬܪ ܡܢ ܕܫܡܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 14,
      "referenceLabel": "Acts 26:14",
      "text": "ܘܢܦܠܢ ܟܠܢ ܥܠ ܐܪܥܐ ܘܫܡܥܬ ܩܠܐ ܟܕ ܐܡܪ ܠܝ ܥܒܪܐܝܬ ܫܐܘܠ ܫܐܘܠ ܡܢܐ ܪܕܦ ܐܢܬ ܠܝ ܩܫܐ ܗܘ ܠܟ ܠܡܒܥܛܘ ܠܥܘܩܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 15,
      "referenceLabel": "Acts 26:15",
      "text": "ܘܐܢܐ ܐܡܪܬ ܡܢ ܐܢܬ ܡܪܝ ܘܡܪܢ ܐܡܪ ܠܝ ܐܢܐ ܗܘ ܝܫܘܥ ܢܨܪܝܐ ܕܐܢܬ ܪܕܦ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 16,
      "referenceLabel": "Acts 26:16",
      "text": "ܘܐܡܪ ܠܝ ܩܘܡ ܥܠ ܪܓܠܝܟ ܡܛܠ ܗܕܐ ܓܝܪ ܐܬܚܙܝܬ ܠܟ ܕܐܩܝܡܟ ܡܫܡܫܢܐ ܘܤܗܕܐ ܕܡܕܡ ܕܚܙܝܬܢܝ ܘܕܥܬܝܕ ܐܢܬ ܕܬܚܙܝܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 17,
      "referenceLabel": "Acts 26:17",
      "text": "ܘܐܦܨܝܟ ܡܢ ܥܡܐ ܕܝܗܘܕܝܐ ܘܡܢ ܥܡܡܐ ܐܚܪܢܐ ܕܠܘܬܗܘܢ ܡܫܕܪ ܐܢܐ ܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 18,
      "referenceLabel": "Acts 26:18",
      "text": "ܕܬܦܬܚ ܥܝܢܝܗܘܢ ܐܝܟ ܕܢܗܦܟܘܢ ܡܢ ܚܫܘܟܐ ܠܢܗܝܪܐ ܘܡܢ ܫܘܠܛܢܗ ܕܤܛܢܐ ܠܘܬ ܐܠܗܐ ܘܢܩܒܠܘܢ ܫܘܒܩܢ ܚܛܗܐ ܘܦܤܐ ܥܡ ܩܕܝܫܐ ܒܗܝܡܢܘܬܐ ܕܒܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 19,
      "referenceLabel": "Acts 26:19",
      "text": "ܡܛܠ ܗܕܐ ܡܠܟܐ ܐܓܪܦܐ ܠܐ ܩܡܬ ܒܚܪܝܢܐ ܠܘܩܒܠ ܚܙܘܐ ܫܡܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 20,
      "referenceLabel": "Acts 26:20",
      "text": "ܐܠܐ ܐܟܪܙܬ ܡܢ ܠܩܘܕܡܝܢ ܠܗܢܘܢ ܕܒܕܪܡܤܘܩ ܘܠܗܢܘܢ ܕܒܐܘܪܫܠܡ ܘܕܒܟܠܗܝܢ ܩܘܪܝܐ ܕܝܗܘܕ ܘܐܦ ܠܥܡܡܐ ܐܟܪܙܬ ܕܢܬܘܒܘܢ ܘܢܬܦܢܘܢ ܠܘܬ ܐܠܗܐ ܘܢܥܒܕܘܢ ܥܒܕܐ ܕܫܘܝܢ ܠܬܝܒܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 21,
      "referenceLabel": "Acts 26:21",
      "text": "ܘܥܠ ܐܦܝ ܗܠܝܢ ܐܚܕܘܢܝ ܝܗܘܕܝܐ ܒܗܝܟܠܐ ܘܨܒܝܢ ܗܘܘ ܠܡܩܛܠܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 22,
      "referenceLabel": "Acts 26:22",
      "text": "ܥܕܪܢܝ ܕܝܢ ܐܠܗܐ ܥܕܡܐ ܠܝܘܡܐ ܗܢܐ ܘܗܐ ܩܐܡ ܐܢܐ ܘܡܤܗܕ ܐܢܐ ܠܙܥܘܪܐ ܘܠܪܒܐ ܟܕ ܡܕܡ ܠܒܪ ܡܢ ܡܘܫܐ ܘܢܒܝܐ ܠܐ ܐܡܪ ܐܢܐ ܐܠܐ ܐܝܠܝܢ ܕܗܢܘܢ ܐܡܪܘ ܕܥܬܝܕܢ ܕܢܗܘܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 23,
      "referenceLabel": "Acts 26:23",
      "text": "ܕܢܚܫ ܡܫܝܚܐ ܘܢܗܘܐ ܪܫܝܬܐ ܕܩܝܡܬܐ ܕܡܢ ܒܝܬ ܡܝܬܐ ܘܕܥܬܝܕ ܕܢܟܪܙ ܢܘܗܪܐ ܠܥܡܐ ܘܠܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 24,
      "referenceLabel": "Acts 26:24",
      "text": "ܘܟܕ ܗܟܢܐ ܢܦܩ ܗܘܐ ܦܘܠܘܤ ܪܘܚܐ ܩܥܐ ܦܗܤܛܘܤ ܒܩܠܐ ܪܡܐ ܫܢܝܬ ܠܟ ܦܘܠܐ ܤܦܪܐ ܤܓܝܐܐ ܥܒܕܟ ܕܬܫܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 25,
      "referenceLabel": "Acts 26:25",
      "text": "ܐܡܪ ܦܘܠܘܤ ܠܐ ܫܢܝܬ ܢܨܝܚܐ ܦܗܤܛܘܤ ܐܠܐ ܡܠܝ ܫܪܪܐ ܘܬܩܢܘܬܐ ܡܡܠܠ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 26,
      "referenceLabel": "Acts 26:26",
      "text": "ܘܐܦ ܡܠܟܐ ܐܓܪܦܘܤ ܝܬܝܪܐܝܬ ܝܕܥ ܥܠܝܗܝܢ ܕܗܠܝܢ ܘܡܛܠ ܗܢܐ ܥܝܢ ܒܓܠܐ ܡܡܠܠ ܐܢܐ ܩܕܡܘܗܝ ܡܛܠ ܕܚܕܐ ܡܢ ܗܠܝܢ ܡܠܐ ܠܐ ܤܒܪ ܐܢܐ ܕܛܥܝܢ ܠܗ ܕܠܐ ܗܘܐ ܒܛܘܫܝܐ ܤܥܝܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 27,
      "referenceLabel": "Acts 26:27",
      "text": "ܡܗܝܡܢ ܐܢܬ ܡܠܟܐ ܐܓܪܦܐ ܠܢܒܝܐ ܝܕܥ ܐܢܐ ܕܡܗܝܡܢ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 28,
      "referenceLabel": "Acts 26:28",
      "text": "ܐܡܪ ܠܗ ܐܓܪܦܘܤ ܒܩܠܝܠ ܡܕܡ ܡܦܝܤ ܐܢܬ ܠܝ ܕܐܗܘܐ ܟܪܤܛܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.29",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 29,
      "referenceLabel": "Acts 26:29",
      "text": "ܘܦܘܠܘܤ ܐܡܪ ܒܥܐ ܗܘܝܬ ܡܢ ܐܠܗܐ ܒܩܠܝܠ ܘܒܤܓܝ ܠܐ ܗܘܐ ܠܟ ܒܠܚܘܕ ܐܠܐ ܐܦ ܠܟܠܗܘܢ ܐܝܠܝܢ ܕܫܡܥܝܢ ܠܝ ܝܘܡܢܐ ܕܢܗܘܘܢ ܐܟܘܬܝ ܠܒܪ ܡܢ ܐܤܘܪܐ ܗܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.30",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 30,
      "referenceLabel": "Acts 26:30",
      "text": "ܘܩܡ ܠܗ ܡܠܟܐ ܘܗܓܡܘܢܐ ܘܒܪܢܝܩܐ ܘܐܝܠܝܢ ܕܝܬܒܝܢ ܗܘܘ ܥܡܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.31",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 31,
      "referenceLabel": "Acts 26:31",
      "text": "ܘܟܕ ܦܪܩܘ ܡܢ ܬܡܢ ܡܡܠܠܝܢ ܗܘܘ ܚܕ ܥܡ ܚܕ ܘܐܡܪܝܢ ܕܡܕܡ ܕܫܘܐ ܠܡܘܬܐ ܐܘ ܠܐܤܘܪܐ ܠܐ ܥܒܕ ܓܒܪܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.26.32",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 26,
      "verseNumber": 32,
      "referenceLabel": "Acts 26:32",
      "text": "ܘܐܡܪ ܐܓܪܦܘܤ ܠܦܗܤܛܘܤ ܡܫܟܚ ܗܘܐ ܓܒܪܐ ܗܢܐ ܕܢܫܬܪܐ ܐܠܘ ܒܓܢ ܩܤܪ ܠܐ ܩܪܐ ܀",
      "paragraphStart": false
    }
  ]
}
