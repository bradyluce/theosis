{
  "chapter": {
    "id": "peshitta:acts.23",
    "translationId": "peshitta",
    "bookSlug": "acts",
    "chapterNumber": 23,
    "referenceLabel": "Acts 23",
    "summary": "Source text for Acts 23 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.23.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Acts 23:1",
      "text": "ܘܟܕ ܚܪ ܦܘܠܘܤ ܒܟܢܫܗܘܢ ܐܡܪ ܓܒܪܐ ܐܚܝ ܐܢܐ ܒܟܠ ܬܐܪܬܐ ܛܒܬܐ ܐܬܕܒܪܬ ܩܕܡ ܐܠܗܐ ܥܕܡܐ ܠܝܘܡܢܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.23.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Acts 23:2",
      "text": "ܘܚܢܢܝܐ ܟܗܢܐ ܦܩܕ ܠܗܢܘܢ ܕܩܝܡܝܢ ܥܠ ܓܒܗ ܕܢܡܚܘܢܗ ܠܦܘܠܘܤ ܥܠ ܦܘܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Acts 23:3",
      "text": "ܘܦܘܠܘܤ ܐܡܪ ܠܗ ܥܬܝܕ ܗܘ ܐܠܗܐ ܕܢܡܚܝܟ ܐܤܬܐ ܡܚܘܪܬܐ ܘܐܢܬ ܝܬܒ ܐܢܬ ܕܐܢ ܐܢܬ ܠܝ ܐܝܟ ܕܒܢܡܘܤܐ ܟܕ ܥܒܪ ܐܢܬ ܥܠ ܢܡܘܤܐ ܘܦܩܕ ܐܢܬ ܕܢܡܚܘܢܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Acts 23:4",
      "text": "ܘܐܝܠܝܢ ܕܩܝܡܝܢ ܗܘܘ ܬܡܢ ܐܡܪܝܢ ܠܗ ܠܟܗܢܐ ܕܐܠܗܐ ܡܨܚܐ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Acts 23:5",
      "text": "ܐܡܪ ܠܗܘܢ ܦܘܠܘܤ ܠܐ ܝܕܥ ܗܘܝܬ ܐܚܝ ܕܟܗܢܐ ܗܘ ܟܬܝܒ ܗܘ ܓܝܪ ܕܠܪܫܐ ܕܥܡܟ ܠܐ ܬܠܘܛ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Acts 23:6",
      "text": "ܘܟܕ ܝܕܥ ܦܘܠܘܤ ܕܡܢܗ ܕܥܡܐ ܐܝܬܘܗܝ ܕܙܕܘܩܝܐ ܘܡܢܗ ܕܦܪܝܫܐ ܩܥܐ ܗܘܐ ܒܟܢܫܐ ܓܒܪܐ ܐܚܝ ܐܢܐ ܦܪܝܫܐ ܐܢܐ ܒܪ ܦܪܝܫܐ ܘܥܠ ܤܒܪܐ ܕܩܝܡܬܐ ܕܡܝܬܐ ܡܬܕܝܢ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Acts 23:7",
      "text": "ܘܟܕ ܗܕܐ ܐܡܪ ܢܦܠܘ ܚܕ ܒܚܕ ܦܪܝܫܐ ܘܙܕܘܩܝܐ ܘܐܬܦܠܓ ܥܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Acts 23:8",
      "text": "ܙܕܘܩܝܐ ܓܝܪ ܐܡܪܝܢ ܕܠܝܬ ܩܝܡܬܐ ܘܠܐ ܡܠܐܟܐ ܘܠܐ ܪܘܚܐ ܦܪܝܫܐ ܕܝܢ ܡܘܕܝܢ ܒܟܠܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Acts 23:9",
      "text": "ܘܗܘܐ ܩܠܐ ܪܒܐ ܘܩܡܘ ܐܢܫܐ ܤܦܪܐ ܡܢ ܓܒܐ ܕܦܪܝܫܐ ܘܢܨܝܢ ܗܘܘ ܥܡܗܘܢ ܘܐܡܪܝܢ ܠܐ ܡܫܟܚܝܢܢ ܡܕܡ ܕܒܝܫ ܒܗܢܐ ܓܒܪܐ ܐܢ ܕܝܢ ܪܘܚܐ ܐܘ ܡܠܐܟܐ ܡܠܠ ܥܡܗ ܡܢܐ ܐܝܬ ܒܗ ܒܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Acts 23:10",
      "text": "ܘܟܕ ܗܘܐ ܫܓܘܫܝܐ ܪܒܐ ܒܝܢܬܗܘܢ ܕܚܠ ܗܘܐ ܟܠܝܪܟܐ ܕܠܡܐ ܢܦܫܚܘܢܗ ܠܦܘܠܘܤ ܘܫܠܚ ܠܪܗܘܡܝܐ ܕܢܐܬܘܢ ܢܚܛܦܘܢܗ ܡܢ ܡܨܥܬܗܘܢ ܘܢܥܠܘܢܗ ܠܡܫܪܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "Acts 23:11",
      "text": "ܘܟܕ ܗܘܐ ܠܠܝܐ ܐܬܚܙܝ ܠܗ ܡܪܢ ܠܦܘܠܘܤ ܘܐܡܪ ܠܗ ܐܬܚܝܠ ܡܛܠ ܕܐܝܟ ܕܐܤܗܕܬ ܥܠܝ ܒܐܘܪܫܠܡ ܗܟܢܐ ܥܬܝܕ ܐܢܬ ܕܐܦ ܒܪܗܘܡܐ ܬܤܗܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "Acts 23:12",
      "text": "ܘܟܕ ܗܘܐ ܨܦܪܐ ܐܬܟܢܫܘ ܗܘܘ ܐܢܫܝܢ ܡܢ ܝܗܘܕܝܐ ܘܐܚܪܡܘ ܥܠܝܗܘܢ ܕܠܐ ܢܐܟܠܘܢ ܘܠܐ ܢܫܬܘܢ ܥܕܡܐ ܕܢܩܛܠܘܢܗ ܠܦܘܠܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "Acts 23:13",
      "text": "ܗܘܝܢ ܗܘܘ ܕܝܢ ܗܢܘܢ ܕܐܩܝܡܘ ܒܡܘܡܬܐ ܗܢܐ ܩܝܡܐ ܝܬܝܪ ܡܢ ܐܪܒܥܝܢ ܓܒܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "Acts 23:14",
      "text": "ܘܐܬܩܪܒܘ ܠܘܬ ܟܗܢܐ ܘܠܘܬ ܩܫܝܫܐ ܘܐܡܪܝܢ ܗܘܘ ܕܚܪܡܐ ܐܚܪܡܢ ܥܠܝܢ ܕܡܕܡ ܠܐ ܢܛܥܡ ܥܕܡܐ ܕܢܩܛܘܠ ܠܦܘܠܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "Acts 23:15",
      "text": "ܘܗܫܐ ܒܥܘ ܐܢܬܘܢ ܘܪܫܐ ܕܟܢܘܫܬܐ ܡܢ ܟܠܝܪܟܐ ܕܢܝܬܝܘܗܝ ܠܘܬܟܘܢ ܐܝܟ ܒܥܝܢ ܐܢܬܘܢ ܕܬܒܨܘܢ ܫܪܝܪܐܝܬ ܤܘܥܪܢܗ ܘܚܢܢ ܡܛܝܒܝܢܢ ܕܢܩܛܠܝܘܗܝ ܥܕܠܐ ܢܡܛܐ ܠܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "Acts 23:16",
      "text": "ܘܫܡܥ ܗܘܐ ܒܪ ܚܬܗ ܕܦܘܠܘܤ ܐܦܪܤܢܐ ܗܢܐ ܘܥܠ ܠܡܫܪܝܬܐ ܘܒܕܩ ܠܦܘܠܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "Acts 23:17",
      "text": "ܘܫܕܪ ܦܘܠܘܤ ܩܪܐ ܠܚܕ ܡܢ ܩܢܛܪܘܢܐ ܘܐܡܪ ܠܗ ܐܘܒܠ ܠܥܠܝܡܐ ܗܢܐ ܠܘܬ ܟܠܝܪܟܐ ܐܝܬ ܠܗ ܓܝܪ ܡܕܡ ܕܢܐܡܪ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 18,
      "referenceLabel": "Acts 23:18",
      "text": "ܘܕܒܪܗ ܩܢܛܪܘܢܐ ܠܥܠܝܡܐ ܘܐܥܠܗ ܠܘܬ ܟܠܝܪܟܐ ܘܐܡܪ ܦܘܠܘܤ ܐܤܝܪܐ ܩܪܢܝ ܘܒܥܐ ܡܢܝ ܕܐܝܬܐ ܗܢܐ ܥܠܝܡܐ ܠܘܬܟ ܕܐܝܬ ܠܗ ܡܕܡ ܕܢܐܡܪ ܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 19,
      "referenceLabel": "Acts 23:19",
      "text": "ܘܐܚܕܗ ܒܐܝܕܗ ܟܠܝܪܟܐ ܠܥܠܝܡܐ ܘܢܓܕܗ ܠܚܕ ܓܒܐ ܘܡܫܐܠ ܗܘܐ ܠܗ ܕܡܢܐ ܐܝܬ ܠܟ ܕܬܐܡܪ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 20,
      "referenceLabel": "Acts 23:20",
      "text": "ܘܐܡܪ ܠܗ ܥܠܝܡܐ ܝܗܘܕܝܐ ܐܬܚܫܒܘ ܕܢܒܥܘܢ ܡܢܟ ܕܬܚܬ ܠܦܘܠܘܤ ܡܚܪ ܠܟܢܫܗܘܢ ܐܝܟ ܨܒܝܢ ܡܕܡ ܝܬܝܪ ܕܢܐܠܦܘܢ ܡܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 21,
      "referenceLabel": "Acts 23:21",
      "text": "ܐܢܬ ܗܟܝܠ ܠܐ ܬܬܛܦܝܤ ܠܗܘܢ ܗܐ ܓܝܪ ܝܬܝܪ ܡܢ ܐܪܒܥܝܢ ܓܒܪܝܢ ܡܢܗܘܢ ܢܛܪܝܢ ܠܗ ܒܟܡܐܢܐ ܘܐܚܪܡܘ ܥܠ ܢܦܫܗܘܢ ܕܠܐ ܢܐܟܠܘܢ ܘܠܐ ܢܫܬܘܢ ܥܕܡܐ ܕܢܩܛܠܘܢܗ ܘܗܐ ܡܛܝܒܝܢ ܘܡܩܘܝܢ ܠܫܘܘܕܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 22,
      "referenceLabel": "Acts 23:22",
      "text": "ܘܫܪܝܗܝ ܟܠܝܪܟܐ ܠܥܠܝܡܐ ܟܕ ܦܩܕܗ ܕܐܢܫ ܠܐ ܢܕܥ ܕܗܠܝܢ ܒܕܩܬ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 23,
      "referenceLabel": "Acts 23:23",
      "text": "ܘܩܪܐ ܠܬܪܝܢ ܩܢܛܪܘܢܝܢ ܘܐܡܪ ܠܗܘܢ ܙܠܘ ܥܬܕܘ ܪܗܘܡܝܐ ܡܐܬܝܢ ܕܢܐܙܠܘܢ ܠܩܤܪܝܐ ܘܦܪܫܐ ܫܒܥܝܢ ܘܫܕܝܝ ܒܝܡܝܢܐ ܡܐܬܝܢ ܕܢܦܩܘܢ ܡܢ ܬܠܬ ܫܥܝܢ ܒܠܠܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 24,
      "referenceLabel": "Acts 23:24",
      "text": "ܛܝܒܘ ܕܝܢ ܐܦ ܒܥܝܪܐ ܐܝܟ ܕܢܪܟܒܘܢ ܠܦܘܠܘܤ ܘܢܦܠܛܘܢܗ ܠܘܬ ܦܝܠܟܤ ܗܓܡܘܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 25,
      "referenceLabel": "Acts 23:25",
      "text": "ܘܟܬܒ ܐܓܪܬܐ ܝܗܒ ܠܗܘܢ ܕܐܝܬ ܒܗ ܗܟܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 26,
      "referenceLabel": "Acts 23:26",
      "text": "ܠܘܤܝܘܤ ܠܦܝܠܟܤ ܗܓܡܘܢܐ ܢܨܝܚܐ ܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 27,
      "referenceLabel": "Acts 23:27",
      "text": "ܠܓܒܪܐ ܗܢܐ ܐܚܕܘ ܝܗܘܕܝܐ ܐܝܟ ܕܢܩܛܠܘܢܗ ܘܩܡܬ ܐܢܐ ܥܡ ܪܗܘܡܝܐ ܘܦܪܩܬܗ ܟܕ ܝܠܦܬ ܕܪܗܘܡܝܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 28,
      "referenceLabel": "Acts 23:28",
      "text": "ܘܟܕ ܒܥܐ ܗܘܝܬ ܠܡܕܥ ܥܠܬܐ ܕܡܛܠܬܗ ܪܫܝܢ ܗܘܘ ܠܗ ܐܚܬܬܗ ܠܟܢܫܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.29",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 29,
      "referenceLabel": "Acts 23:29",
      "text": "ܘܐܫܟܚܬ ܕܥܠ ܙܛܡܐ ܕܢܡܘܤܗܘܢ ܪܫܝܢ ܗܘܘ ܠܗ ܘܥܠܬܐ ܕܫܘܝܐ ܠܐܤܘܪܐ ܐܘ ܠܡܘܬܐ ܠܝܬ ܗܘܐ ܠܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.30",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 30,
      "referenceLabel": "Acts 23:30",
      "text": "ܘܟܕ ܐܬܒܕܩ ܠܝ ܢܟܠܐ ܒܟܡܐܢܐ ܕܥܒܕܘ ܥܠܘܗܝ ܝܗܘܕܝܐ ܡܚܕܐ ܫܕܪܬܗ ܠܘܬܟ ܘܦܩܕܬ ܠܩܛܓܪܢܘܗܝ ܕܢܐܬܘܢ ܘܢܐܡܪܘܢ ܥܡܗ ܩܕܡܝܟ ܗܘܝ ܚܠܝܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.31",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 31,
      "referenceLabel": "Acts 23:31",
      "text": "ܗܝܕܝܢ ܪܗܘܡܝܐ ܐܝܟ ܕܐܬܦܩܕܘ ܕܒܪܘܗܝ ܠܦܘܠܘܤ ܒܠܠܝܐ ܘܐܝܬܝܘܗܝ ܠܐܢܛܝܦܛܪܤ ܡܕܝܢܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.32",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 23,
      "verseNumber": 32,
      "referenceLabel": "Acts 23:32",
      "text": "ܘܠܝܘܡܐ ܐܚܪܢܐ ܫܪܘ ܦܪܫܐ ܠܪܓܠܐ ܚܒܪܝܗܘܢ ܕܢܗܦܟܘܢ ܠܡܫܪܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.23.33",
      "translationId": "peshitta",
