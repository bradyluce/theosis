{
  "chapter": {
    "id": "peshitta:acts.1",
    "translationId": "peshitta",
    "bookSlug": "acts",
    "chapterNumber": 1,
    "referenceLabel": "Acts 1",
    "summary": "Source text for Acts 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.1.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Acts 1:1",
      "text": "ܟܬܒܐ ܩܕܡܝܐ ܟܬܒܬ ܐܘ ܬܐܘܦܝܠܐ ܥܠ ܟܠܗܝܢ ܐܝܠܝܢ ܕܫܪܝ ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܠܡܥܒܕ ܘܠܡܠܦܘ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.1.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Acts 1:2",
      "text": "ܥܕܡܐ ܠܝܘܡܐ ܗܘ ܕܒܗ ܐܤܬܠܩ ܡܢ ܒܬܪ ܕܦܩܕ ܗܘܐ ܐܢܘܢ ܠܫܠܝܚܐ ܐܝܠܝܢ ܕܓܒܐ ܒܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Acts 1:3",
      "text": "ܗܢܘܢ ܕܐܦ ܚܘܝ ܠܗܘܢ ܢܦܫܗ ܟܕ ܚܝ ܡܢ ܒܬܪ ܕܚܫ ܒܐܬܘܬܐ ܤܓܝܐܬܐ ܒܝܘܡܝܢ ܐܪܒܥܝܢ ܟܕ ܡܬܚܙܐ ܗܘܐ ܠܗܘܢ ܘܐܡܪ ܥܠ ܡܠܟܘܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Acts 1:4",
      "text": "ܘܟܕ ܐܟܠ ܥܡܗܘܢ ܠܚܡܐ ܦܩܕ ܐܢܘܢ ܕܡܢ ܐܘܪܫܠܡ ܠܐ ܢܦܪܩܘܢ ܐܠܐ ܕܢܩܘܘܢ ܠܫܘܘܕܝܗ ܕܐܒܐ ܗܘ ܕܫܡܥܬܘܢ ܡܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Acts 1:5",
      "text": "ܕܝܘܚܢܢ ܐܥܡܕ ܒܡܝܐ ܘܐܢܬܘܢ ܬܥܡܕܘܢ ܒܪܘܚܐ ܕܩܘܕܫܐ ܠܐ ܒܬܪ ܝܘܡܬܐ ܤܓܝܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Acts 1:6",
      "text": "ܗܢܘܢ ܕܝܢ ܟܕ ܟܢܝܫܝܢ ܫܐܠܘܗܝ ܘܐܡܪܝܢ ܠܗ ܡܪܢ ܐܢ ܒܗܢܐ ܙܒܢܐ ܡܦܢܐ ܐܢܬ ܡܠܟܘܬܐ ܠܐܝܤܪܝܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Acts 1:7",
      "text": "ܐܡܪ ܠܗܘܢ ܗܘ ܠܐ ܗܘܬ ܕܝܠܟܘܢ ܗܕܐ ܠܡܕܥ ܙܒܢܐ ܐܘ ܙܒܢܐ ܐܝܠܝܢ ܕܐܒܐ ܤܡ ܐܢܘܢ ܒܫܘܠܛܢܐ ܕܢܦܫܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Acts 1:8",
      "text": "ܐܠܐ ܟܕ ܬܐܬܐ ܪܘܚܐ ܕܩܘܕܫܐ ܥܠܝܟܘܢ ܬܩܒܠܘܢ ܚܝܠܐ ܘܬܗܘܘܢ ܠܝ ܤܗܕܐ ܒܐܘܪܫܠܡ ܘܒܟܠܗ ܝܗܘܕ ܘܐܦ ܒܝܬ ܫܡܪܝܐ ܘܥܕܡܐ ܠܤܘܦܝܗ ܕܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Acts 1:9",
      "text": "ܘܟܕ ܗܠܝܢ ܐܡܪ ܟܕ ܚܙܝܢ ܠܗ ܐܤܬܠܩ ܘܥܢܢܐ ܩܒܠܬܗ ܘܐܬܟܤܝ ܡܢ ܥܝܢܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Acts 1:10",
      "text": "ܘܟܕ ܚܝܪܝܢ ܗܘܘ ܒܫܡܝܐ ܟܕ ܗܘ ܐܙܠ ܗܘܐ ܐܫܬܟܚܘ ܬܪܝܢ ܓܒܪܝܢ ܩܝܡܝܢ ܠܘܬܗܘܢ ܒܠܒܘܫܐ ܚܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Acts 1:11",
      "text": "ܘܐܡܪܝܢ ܠܗܘܢ ܓܒܪܐ ܓܠܝܠܝܐ ܡܢܐ ܩܝܡܝܢ ܐܢܬܘܢ ܘܚܝܪܝܢ ܒܫܡܝܐ ܗܢܐ ܝܫܘܥ ܕܐܤܬܠܩ ܡܢܟܘܢ ܠܫܡܝܐ ܗܟܢܐ ܢܐܬܐ ܐܝܟ ܡܐ ܕܚܙܝܬܘܢܝܗܝ ܕܤܠܩ ܠܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Acts 1:12",
      "text": "ܘܡܢ ܒܬܪܟܢ ܗܦܟܘ ܠܗܘܢ ܠܐܘܪܫܠܡ ܡܢ ܛܘܪܐ ܕܡܬܩܪܐ ܕܒܝܬ ܙܝܬܐ ܕܐܝܬܘܗܝ ܥܠ ܓܢܒ ܐܘܪܫܠܡ ܘܦܪܝܩ ܡܢܗ ܐܝܟ ܫܒܥܐ ܐܤܛܕܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Acts 1:13",
      "text": "ܘܡܢ ܒܬܪ ܕܥܠܘ ܤܠܩܘ ܠܗܘܢ ܠܥܠܝܬܐ ܗܝ ܕܗܘܝܢ ܗܘܘ ܒܗ ܦܛܪܘܤ ܘܝܘܚܢܢ ܘܝܥܩܘܒ ܘܐܢܕܪܐܘܤ ܘܦܝܠܝܦܘܤ ܘܬܐܘܡܐ ܘܡܬܝ ܘܒܪ ܬܘܠܡܝ ܘܝܥܩܘܒ ܒܪ ܚܠܦܝ ܘܫܡܥܘܢ ܛܢܢܐ ܘܝܗܘܕܐ ܒܪ ܝܥܩܘܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Acts 1:14",
      "text": "ܗܠܝܢ ܟܠܗܘܢ ܐܟܚܕܐ ܐܡܝܢܝܢ ܗܘܘ ܒܨܠܘܬܐ ܒܚܕܐ ܢܦܫ ܥܡ ܢܫܐ ܘܥܡ ܡܪܝܡ ܐܡܗ ܕܝܫܘܥ ܘܥܡ ܐܚܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Acts 1:15",
      "text": "ܘܒܗܘܢ ܒܝܘܡܬܐ ܗܢܘܢ ܩܡ ܫܡܥܘܢ ܟܐܦܐ ܡܨܥܬ ܬܠܡܝܕܐ ܐܝܬ ܗܘܐ ܕܝܢ ܬܡܢ ܟܢܫܐ ܕܐܢܫܐ ܐܝܟ ܡܐܐ ܘܥܤܪܝܢ ܘܐܡܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Acts 1:16",
      "text": "ܓܒܪܐ ܐܚܝܢ ܙܕܩ ܗܘܐ ܕܢܬܡܠܐ ܟܬܒܐ ܐܝܢܐ ܕܩܕܡ ܐܡܪ ܪܘܚܐ ܕܩܘܕܫܐ ܒܦܘܡܗ ܕܕܘܝܕ ܥܠ ܝܗܘܕܐ ܗܘ ܕܗܘܐ ܡܕܒܪܢܐ ܠܗܢܘܢ ܕܐܚܕܘ ܠܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Acts 1:17",
      "text": "ܡܛܠ ܕܡܢܐ ܗܘܐ ܥܡܢ ܘܐܝܬ ܗܘܐ ܠܗ ܦܤܐ ܒܬܫܡܫܬܐ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Acts 1:18",
      "text": "ܗܢܘ ܕܩܢܐ ܠܗ ܩܪܝܬܐ ܡܢ ܐܓܪܐ ܕܚܛܝܬܐ ܘܢܦܠ ܥܠ ܐܦܘܗܝ ܥܠ ܐܪܥܐ ܘܐܬܦܪܬ ܡܢ ܡܨܥܬܗ ܘܐܬܐܫܕ ܟܠܗ ܓܘܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Acts 1:19",
      "text": "ܘܗܝ ܗܕܐ ܐܬܝܕܥܬ ܠܟܠܗܘܢ ܕܥܡܪܝܢ ܒܐܘܪܫܠܡ ܘܗܟܢܐ ܐܬܩܪܝܬ ܩܪܝܬܐ ܗܝ ܒܠܫܢܗ ܕܐܬܪܐ ܚܩܠ ܕܡܐ ܕܐܝܬܘܗܝ ܬܘܪܓܡܗ ܩܘܪܝܬ ܕܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Acts 1:20",
      "text": "ܟܬܝܒ ܓܝܪ ܒܤܦܪܐ ܕܡܙܡܘܪܐ ܕܕܝܪܗ ܬܗܘܐ ܚܪܒܐ ܘܥܡܘܪ ܠܐ ܢܗܘܐ ܒܗ ܘܬܫܡܫܬܗ ܢܤܒ ܐܚܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Acts 1:21",
      "text": "ܘܠܝܐ ܗܝ ܗܟܝܠ ܠܚܕ ܡܢ ܗܠܝܢ ܓܒܪܐ ܕܗܘܘ ܥܡܢ ܒܗܢܐ ܙܒܢܐ ܟܠܗ ܕܒܗ ܥܠ ܘܢܦܩ ܥܠܝܢ ܡܪܢ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Acts 1:22",
      "text": "ܕܐܩܦ ܡܢ ܡܥܡܘܕܝܬܗ ܕܝܘܚܢܢ ܥܕܡܐ ܠܝܘܡܐ ܕܐܤܬܠܩ ܡܢ ܠܘܬܢ ܕܗܘ ܢܗܘܐ ܥܡܢ ܤܗܕܐ ܕܩܝܡܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Acts 1:23",
      "text": "ܘܐܩܝܡܘ ܬܪܝܢ ܠܝܘܤܦ ܕܡܬܩܪܐ ܒܪܫܒܐ ܕܐܫܬܡܝ ܝܘܤܛܘܤ ܘܠܡܬܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Acts 1:24",
      "text": "ܘܟܕ ܨܠܝܘ ܐܡܪܘ ܐܢܬ ܡܪܝܐ ܝܕܥ ܕܒܠܒܘܬܐ ܕܟܠ ܚܘܐ ܚܕ ܐܝܢܐ ܕܓܒܐ ܐܢܬ ܡܢ ܗܠܝܢ ܬܪܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Acts 1:25",
      "text": "ܕܗܘ ܢܩܒܠ ܦܤܐ ܕܬܫܡܫܬܐ ܘܫܠܝܚܘܬܐ ܕܡܢܗ ܦܪܩ ܝܗܘܕܐ ܕܢܐܙܠ ܠܗ ܠܐܬܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.1.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "Acts 1:26",
      "text": "ܘܐܪܡܝܘ ܦܨܐ ܘܤܠܩܬ ܠܡܬܝܐ ܘܐܬܡܢܝ ܥܡ ܚܕܥܤܪ ܫܠܝܚܐ ܀",
      "paragraphStart": false
    }
  ]
}
