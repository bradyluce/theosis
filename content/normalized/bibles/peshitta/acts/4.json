{
  "chapter": {
    "id": "peshitta:acts.4",
    "translationId": "peshitta",
    "bookSlug": "acts",
    "chapterNumber": 4,
    "referenceLabel": "Acts 4",
    "summary": "Source text for Acts 4 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.4.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Acts 4:1",
      "text": "ܘܟܕ ܗܠܝܢ ܡܠܐ ܡܡܠܠܝܢ ܗܘܘ ܠܥܡܐ ܩܡܘ ܥܠܝܗܘܢ ܟܗܢܐ ܘܙܕܘܩܝܐ ܘܐܪܟܘܢܐ ܕܗܝܟܠܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.4.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Acts 4:2",
      "text": "ܟܕ ܡܬܚܡܬܝܢ ܗܘܘ ܥܠܝܗܘܢ ܕܡܠܦܝܢ ܠܥܡܐ ܘܡܟܪܙܝܢ ܒܡܫܝܚܐ ܥܠ ܩܝܡܬܐ ܕܡܢ ܒܝܬ ܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Acts 4:3",
      "text": "ܘܐܪܡܝܘ ܥܠܝܗܘܢ ܐܝܕܝܐ ܘܢܛܪܘ ܐܢܘܢ ܠܝܘܡܐ ܐܚܪܢܐ ܡܛܠ ܕܩܪܒ ܗܘܐ ܠܗ ܪܡܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Acts 4:4",
      "text": "ܘܤܓܝܐܐ ܕܫܡܥܘ ܗܘܘ ܡܠܬܐ ܗܝܡܢܘ ܗܘܘ ܘܐܝܬܝܗܘܢ ܗܘܘ ܒܡܢܝܢܐ ܐܝܟ ܚܡܫܐ ܐܠܦܝܢ ܓܒܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Acts 4:5",
      "text": "ܘܠܝܘܡܐ ܐܚܪܢܐ ܐܬܟܢܫܘ ܐܪܟܘܢܐ ܘܩܫܝܫܐ ܘܤܦܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Acts 4:6",
      "text": "ܘܐܦ ܚܢܢ ܪܒ ܟܗܢܐ ܘܩܝܦܐ ܘܝܘܚܢܢ ܘܐܠܟܤܢܕܪܘܤ ܘܐܝܠܝܢ ܕܐܝܬܝܗܘܢ ܗܘܘ ܡܢ ܫܪܒܬܐ ܕܪܒܝ ܟܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Acts 4:7",
      "text": "ܘܟܕ ܐܩܝܡܘ ܐܢܘܢ ܒܡܨܥܬܐ ܡܫܐܠܝܢ ܗܘܘ ܠܗܘܢ ܕܒܐܝܢܐ ܚܝܠ ܐܘ ܒܐܝܢܐ ܫܡ ܥܒܕܬܘܢ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Acts 4:8",
      "text": "ܗܝܕܝܢ ܫܡܥܘܢ ܟܐܦܐ ܐܬܡܠܝ ܪܘܚܐ ܕܩܘܕܫܐ ܘܐܡܪ ܠܗܘܢ ܐܪܟܘܢܘܗܝ ܕܥܡܐ ܘܩܫܝܫܐ ܕܒܝܬ ܐܝܤܪܝܠ ܫܡܥܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Acts 4:9",
      "text": "ܐܢ ܚܢܢ ܝܘܡܢܐ ܡܬܕܝܢܝܢ ܚܢܢ ܡܢܟܘܢ ܥܠ ܫܦܝܪܬܐ ܕܗܘܬ ܠܒܪܢܫܐ ܟܪܝܗܐ ܕܒܡܢܐ ܗܢܐ ܐܬܐܤܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Acts 4:10",
      "text": "ܗܕܐ ܬܬܝܕܥ ܠܟܘܢ ܘܠܟܠܗ ܥܡܐ ܕܐܝܤܪܝܠ ܕܒܫܡܗ ܕܝܫܘܥ ܡܫܝܚܐ ܢܨܪܝܐ ܗܘ ܕܐܢܬܘܢ ܙܩܦܬܘܢܝܗܝ ܗܘ ܕܐܩܝܡ ܐܠܗܐ ܡܢ ܒܝܬ ܡܝܬܐ ܒܗ ܒܗܘ ܗܐ ܩܐܡ ܗܢܐ ܩܕܡܝܟܘܢ ܟܕ ܚܠܝܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Acts 4:11",
      "text": "ܗܢܘ ܟܐܦܐ ܕܐܤܠܝܬܘܢ ܐܢܬܘܢ ܒܢܝܐ ܘܗܘ ܗܘܐ ܠܪܝܫ ܩܪܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Acts 4:12",
      "text": "ܘܠܝܬ ܒܐܢܫ ܐܚܪܝܢ ܦܘܪܩܢܐ ܠܐ ܓܝܪ ܐܝܬ ܫܡܐ ܐܚܪܢܐ ܬܚܝܬ ܫܡܝܐ ܕܐܬܝܗܒ ܠܒܢܝܢܫܐ ܕܒܗ ܘܠܐ ܠܡܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Acts 4:13",
      "text": "ܘܟܕ ܫܡܥܘ ܡܠܬܗ ܕܫܡܥܘܢ ܘܕܝܘܚܢܢ ܕܥܝܢ ܒܓܠܐ ܐܡܪܘܗ ܐܤܬܟܠܘ ܕܠܐ ܝܕܥܝܢ ܤܦܪܐ ܘܗܕܝܘܛܐ ܐܢܘܢ ܘܬܗܪܘ ܒܗܘܢ ܘܐܫܬܘܕܥܘ ܐܢܘܢ ܕܥܡ ܝܫܘܥ ܡܬܗܦܟܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Acts 4:14",
      "text": "ܘܚܙܝܢ ܗܘܘ ܕܩܐܡ ܗܘܐ ܥܡܗܘܢ ܚܓܝܪܐ ܗܘ ܕܐܬܐܤܝ ܘܠܐ ܡܫܟܚܝܢ ܗܘܘ ܡܕܡ ܠܡܐܡܪ ܠܘܩܒܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Acts 4:15",
      "text": "ܗܝܕܝܢ ܦܩܕܘ ܕܢܦܩܘܢ ܐܢܘܢ ܡܢ ܟܢܫܗܘܢ ܘܐܡܪܝܢ ܗܘܘ ܚܕ ܠܚܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Acts 4:16",
      "text": "ܡܢܐ ܢܥܒܕ ܠܗܘܢ ܠܓܒܪܐ ܗܠܝܢ ܗܐ ܓܝܪ ܐܬܐ ܓܠܝܬܐ ܕܗܘܬ ܒܐܝܕܝܗܘܢ ܠܟܠܗܘܢ ܥܡܘܪܝܗ ܕܐܘܪܫܠܡ ܐܬܝܕܥܬ ܘܠܐ ܡܫܟܚܝܢܢ ܕܢܟܦܘܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Acts 4:17",
      "text": "ܐܠܐ ܕܠܐ ܝܬܝܪܐܝܬ ܢܦܘܩ ܒܥܡܐ ܛܒܐ ܗܢܐ ܢܬܠܚܡ ܠܗܘܢ ܕܬܘܒ ܠܐ ܢܡܠܠܘܢ ܒܫܡܐ ܗܢܐ ܠܐܢܫ ܡܢ ܒܢܝܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Acts 4:18",
      "text": "ܘܩܪܘ ܐܢܘܢ ܘܦܩܕܘ ܐܢܘܢ ܕܠܓܡܪ ܠܐ ܢܡܠܠܘܢ ܘܠܐ ܢܠܦܘܢ ܒܫܡ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Acts 4:19",
      "text": "ܥܢܘ ܫܡܥܘܢ ܟܐܦܐ ܘܝܘܚܢܢ ܘܐܡܪܘ ܠܗܘܢ ܐܢ ܟܐܢܐ ܩܕܡ ܐܠܗܐ ܕܠܟܘܢ ܢܫܡܥ ܝܬܝܪ ܡܢ ܐܠܗܐ ܕܘܢܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Acts 4:20",
      "text": "ܠܐ ܓܝܪ ܡܫܟܚܝܢ ܚܢܢ ܕܡܐ ܕܚܙܝܢ ܘܫܡܥܢ ܕܠܐ ܢܡܠܠܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Acts 4:21",
      "text": "ܘܐܬܠܚܡܘ ܠܗܘܢ ܘܫܪܘ ܐܢܘܢ ܠܐ ܓܝܪ ܐܫܟܚܘ ܠܗܘܢ ܥܠܬܐ ܕܢܤܝܡܘܢ ܒܪܫܗܘܢ ܡܛܠ ܥܡܐ ܟܠܢܫ ܓܝܪ ܡܫܒܚ ܗܘܐ ܠܐܠܗܐ ܥܠ ܡܕܡ ܕܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Acts 4:22",
      "text": "ܝܬܝܪ ܓܝܪ ܡܢ ܒܪ ܐܪܒܥܝܢ ܫܢܝܢ ܐܝܬܘܗܝ ܗܘܐ ܓܒܪܐ ܗܘ ܕܗܘܬ ܒܗ ܗܕܐ ܐܬܐ ܕܐܤܝܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Acts 4:23",
      "text": "ܘܟܕ ܐܫܬܪܝܘ ܐܬܘ ܠܘܬ ܐܚܝܗܘܢ ܘܐܫܬܥܝܘ ܠܗܘܢ ܟܠ ܡܐ ܕܐܡܪܘ ܟܗܢܐ ܘܩܫܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Acts 4:24",
      "text": "ܘܗܢܘܢ ܟܕ ܫܡܥܘ ܐܟܚܕ ܐܪܝܡܘ ܩܠܗܘܢ ܠܘܬ ܐܠܗܐ ܘܐܡܪܘ ܡܪܝܐ ܐܢܬ ܗܘ ܐܠܗܐ ܕܥܒܕܬ ܫܡܝܐ ܘܐܪܥܐ ܘܝܡܡܐ ܘܟܠ ܕܐܝܬ ܒܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Acts 4:25",
      "text": "ܘܐܢܬ ܗܘ ܕܡܠܠܬ ܒܝܕ ܪܘܚܐ ܕܩܘܕܫܐ ܒܦܘܡ ܕܘܝܕ ܥܒܕܟ ܠܡܢܐ ܪܓܫܘ ܥܡܡܐ ܘܐܡܘܬܐ ܪܢܝ ܤܪܝܩܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Acts 4:26",
      "text": "ܩܡܘ ܡܠܟܐ ܕܐܪܥܐ ܘܫܠܝܛܢܐ ܘܐܬܡܠܟܘ ܐܟܚܕܐ ܥܠ ܡܪܝܐ ܘܥܠ ܡܫܝܚܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Acts 4:27",
      "text": "ܐܬܟܢܫܘ ܓܝܪ ܫܪܝܪܐܝܬ ܒܡܕܝܢܬܐ ܗܕܐ ܥܠ ܩܕܝܫܐ ܒܪܟ ܝܫܘܥ ܐܝܢܐ ܕܐܢܬ ܡܫܚܬ ܗܪܘܕܤ ܘܦܝܠܛܘܤ ܥܡ ܥܡܡܐ ܘܟܢܫܐ ܕܐܝܤܪܝܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "Acts 4:28",
      "text": "ܠܡܥܒܕ ܟܠ ܡܐ ܕܐܝܕܟ ܘܨܒܝܢܟ ܩܕܡ ܪܫܡ ܕܢܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.29",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "Acts 4:29",
      "text": "ܘܐܦ ܗܫܐ ܡܪܝܐ ܚܘܪ ܘܚܙܝ ܠܠܘܚܡܝܗܘܢ ܘܗܒ ܠܥܒܕܝܟ ܕܥܝܢ ܒܓܠܐ ܢܗܘܘܢ ܡܟܪܙܝܢ ܡܠܬܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.30",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "Acts 4:30",
      "text": "ܟܕ ܐܝܕܟ ܡܘܫܛ ܐܢܬ ܠܐܤܘܬܐ ܘܠܓܒܪܘܬܐ ܘܠܐܬܘܬܐ ܕܢܗܘܝܢ ܒܫܡܗ ܕܒܪܟ ܩܕܝܫܐ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.31",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "Acts 4:31",
      "text": "ܘܟܕ ܒܥܘ ܘܐܬܟܫܦܘ ܐܬܬܙܝܥ ܐܬܪܐ ܕܒܗ ܟܢܝܫܝܢ ܗܘܘ ܘܐܬܡܠܝܘ ܟܠܗܘܢ ܒܪܘܚܐ ܕܩܘܕܫܐ ܘܡܡܠܠܝܢ ܗܘܘ ܥܝܢ ܒܓܠܐ ܡܠܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.32",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 32,
      "referenceLabel": "Acts 4:32",
      "text": "ܐܝܬ ܗܘܐ ܕܝܢ ܠܟܢܫܐ ܕܐܢܫܐ ܐܝܠܝܢ ܕܗܝܡܢܘ ܗܘܘ ܚܕܐ ܢܦܫ ܘܚܕ ܪܥܝܢ ܘܠܐ ܐܢܫ ܡܢܗܘܢ ܐܡܪ ܗܘܐ ܥܠ ܢܟܤܐ ܕܩܢܐ ܗܘܐ ܕܕܝܠܗ ܐܢܘܢ ܐܠܐ ܟܠ ܡܕܡ ܕܐܝܬ ܗܘܐ ܠܗܘܢ ܕܓܘܐ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.33",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
      "verseNumber": 33,
      "referenceLabel": "Acts 4:33",
      "text": "ܘܒܚܝܠܐ ܪܒܐ ܡܤܗܕܝܢ ܗܘܘ ܗܢܘܢ ܫܠܝܚܐ ܥܠ ܩܝܡܬܗ ܕܝܫܘܥ ܡܫܝܚܐ ܘܛܝܒܘܬܐ ܪܒܬܐ ܐܝܬ ܗܘܬ ܥܡ ܟܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.4.34",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 4,
