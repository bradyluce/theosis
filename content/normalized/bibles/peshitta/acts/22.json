{
  "chapter": {
    "id": "peshitta:acts.22",
    "translationId": "peshitta",
    "bookSlug": "acts",
    "chapterNumber": 22,
    "referenceLabel": "Acts 22",
    "summary": "Source text for Acts 22 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.22.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Acts 22:1",
      "text": "ܐܚܐ ܘܐܒܗܬܐ ܫܡܥܘ ܡܦܩ ܒܪܘܚ ܕܠܘܬܟܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.22.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Acts 22:2",
      "text": "ܘܟܕ ܫܡܥܘ ܕܥܒܪܐܝܬ ܡܡܠܠ ܗܘܐ ܥܡܗܘܢ ܝܬܝܪܐܝܬ ܒܗܠܘ ܘܐܡܪ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Acts 22:3",
      "text": "ܐܢܐ ܓܒܪܐ ܐܢܐ ܝܗܘܕܝܐ ܘܝܠܝܕ ܐܢܐ ܒܛܪܤܘܤ ܕܩܝܠܝܩܝܐ ܐܬܪܒܝܬ ܕܝܢ ܒܗܕܐ ܡܕܝܢܬܐ ܥܠ ܓܢܒ ܪܓܠܘܗܝ ܕܓܡܠܝܐܝܠ ܘܐܬܪܕܝܬ ܓܡܝܪܐܝܬ ܒܢܡܘܤܐ ܕܐܒܗܬܢ ܘܐܝܬܝ ܗܘܝܬ ܛܢܢܐ ܕܐܠܗܐ ܐܝܟ ܡܐ ܕܐܦ ܐܢܬܘܢ ܟܠܟܘܢ ܐܝܬܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Acts 22:4",
      "text": "ܘܠܗܕܐ ܐܘܪܚܐ ܪܕܦܬ ܥܕܡܐ ܠܡܘܬܐ ܟܕ ܐܤܪ ܗܘܝܬ ܘܡܫܠܡ ܗܘܝܬ ܠܒܝܬ ܐܤܝܪܐ ܓܒܪܐ ܘܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Acts 22:5",
      "text": "ܐܝܟ ܡܐ ܕܤܗܕ ܥܠܝ ܪܒ ܟܗܢܐ ܘܟܠܗܘܢ ܩܫܝܫܐ ܕܡܢܗܘܢ ܩܒܠܬ ܐܓܪܬܐ ܕܐܙܠ ܠܘܬ ܐܚܐ ܕܒܕܪܡܤܘܩ ܕܐܦ ܠܗܢܘܢ ܕܐܝܬ ܗܘܘ ܬܡܢ ܐܝܬܐ ܐܢܘܢ ܠܐܘܪܫܠܡ ܟܕ ܐܤܝܪܝܢ ܘܢܩܒܠܘܢ ܡܤܡ ܒܪܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Acts 22:6",
      "text": "ܘܟܕ ܐܙܠ ܗܘܝܬ ܘܫܪܝܬ ܡܡܛܐ ܐܢܐ ܠܕܪܡܤܘܩ ܒܦܠܓܗ ܕܝܘܡܐ ܡܢ ܬܚܝܬ ܫܠܝܐ ܡܢ ܫܡܝܐ ܐܙܠܓ ܥܠܝ ܢܘܗܪܐ ܤܓܝܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Acts 22:7",
      "text": "ܘܢܦܠܬ ܥܠ ܐܪܥܐ ܘܫܡܥܬ ܩܠܐ ܕܐܡܪ ܗܘܐ ܠܝ ܫܐܘܠ ܫܐܘܠ ܡܢܐ ܪܕܦ ܐܢܬ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Acts 22:8",
      "text": "ܐܢܐ ܕܝܢ ܥܢܝܬ ܘܐܡܪܬ ܡܢ ܐܢܬ ܡܪܝ ܘܗܘ ܐܡܪ ܠܝ ܐܢܐ ܗܘ ܝܫܘܥ ܢܨܪܝܐ ܕܐܢܬ ܪܕܦ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Acts 22:9",
      "text": "ܘܐܢܫܐ ܕܐܝܬ ܗܘܘ ܥܡܝ ܚܙܘ ܢܘܗܪܐ ܩܠܐ ܕܝܢ ܠܐ ܫܡܥܘ ܕܗܘ ܕܡܡܠܠ ܗܘܐ ܥܡܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Acts 22:10",
      "text": "ܘܐܡܪܬ ܡܢܐ ܐܥܒܕ ܡܪܝ ܘܡܪܢ ܐܡܪ ܠܝ ܩܘܡ ܙܠ ܠܕܪܡܤܘܩ ܘܬܡܢ ܢܬܡܠܠ ܥܡܟ ܥܠ ܟܠ ܡܕܡ ܕܡܬܦܩܕ ܠܟ ܕܬܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Acts 22:11",
      "text": "ܘܟܕ ܠܐ ܡܬܚܙܐ ܗܘܐ ܠܝ ܡܛܠ ܬܫܒܘܚܬܗ ܕܢܘܗܪܐ ܗܘ ܐܚܕܘܢܝ ܒܐܝܕܝ ܗܢܘܢ ܕܥܡܝ ܗܘܘ ܘܥܠܬ ܠܕܪܡܤܘܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Acts 22:12",
      "text": "ܘܓܒܪܐ ܚܕ ܚܢܢܝܐ ܟܐܢܐ ܒܢܡܘܤܐ ܐܝܟ ܕܤܗܕܝܢ ܗܘܘ ܥܠܘܗܝ ܟܠܗܘܢ ܝܗܘܕܝܐ ܕܬܡܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Acts 22:13",
      "text": "ܐܬܐ ܠܘܬܝ ܘܐܡܪ ܠܝ ܫܐܘܠ ܐܚܝ ܦܬܚ ܥܝܢܝܟ ܘܒܗ ܒܫܥܬܐ ܐܬܦܬܚ ܥܝܢܝ ܘܚܪܬ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Acts 22:14",
      "text": "ܘܐܡܪ ܠܝ ܐܠܗܐ ܕܐܒܗܬܢ ܐܩܝܡܟ ܠܡܕܥ ܨܒܝܢܗ ܘܬܚܙܐ ܠܙܕܝܩܐ ܘܬܫܡܥ ܩܠܐ ܡܢ ܦܘܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Acts 22:15",
      "text": "ܘܬܗܘܐ ܠܗ ܤܗܕܐ ܠܘܬ ܟܠܗܘܢ ܒܢܝܢܫܐ ܥܠ ܟܘܠ ܡܐ ܕܚܙܝܬ ܘܫܡܥܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Acts 22:16",
      "text": "ܘܗܫܐ ܡܢܐ ܡܫܬܘܚܪ ܐܢܬ ܩܘܡ ܥܡܕ ܘܐܬܕܟܐ ܡܢ ܚܛܗܝܟ ܟܕ ܩܪܐ ܐܢܬ ܫܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Acts 22:17",
      "text": "ܘܗܦܟܬ ܐܬܝܬ ܠܟܐ ܠܐܘܪܫܠܡ ܘܨܠܝܬ ܒܗܝܟܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Acts 22:18",
      "text": "ܘܚܙܝܬܗ ܒܚܙܘܐ ܟܕ ܐܡܪ ܠܝ ܐܤܬܪܗܒ ܘܦܘܩ ܠܟ ܡܢ ܐܘܪܫܠܡ ܡܛܠ ܕܠܐ ܡܩܒܠܝܢ ܤܗܕܘܬܟ ܕܥܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Acts 22:19",
      "text": "ܘܐܢܐ ܐܡܪܬ ܡܪܝ ܐܦ ܗܢܘܢ ܝܕܥܝܢ ܕܐܢܐ ܡܫܠܡ ܗܘܝܬ ܠܒܝܬ ܐܤܝܪܐ ܘܡܚܐ ܗܘܝܬ ܒܟܠ ܟܢܘܫܢ ܠܐܝܠܝܢ ܕܡܗܝܡܢܝܢ ܗܘܘ ܒܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Acts 22:20",
      "text": "ܘܟܕ ܡܬܐܫܕ ܗܘܐ ܕܡܗ ܕܐܤܛܦܢܤ ܤܗܕܟ ܘܐܦ ܐܢܐ ܥܡܗܘܢ ܩܐܡ ܗܘܝܬ ܘܫܠܡ ܗܘܝܬ ܠܨܒܝܢܗܘܢ ܕܩܛܘܠܘܗܝ ܘܢܛܪ ܗܘܝܬ ܡܐܢܐ ܕܐܝܠܝܢ ܕܪܓܡܝܢ ܗܘܘ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Acts 22:21",
      "text": "ܘܐܡܪ ܠܝ ܙܠ ܕܐܢܐ ܡܫܕܪ ܐܢܐ ܠܟ ܠܪܘܚܩܐ ܠܡܟܪܙܘ ܠܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Acts 22:22",
      "text": "ܘܟܕ ܫܡܥܘܗܝ ܠܦܘܠܘܤ ܥܕܡܐ ܠܗܕܐ ܡܠܬܐ ܐܪܝܡܘ ܩܠܗܘܢ ܘܩܥܘ ܢܫܬܩܠ ܡܢ ܐܪܥܐ ܐܝܢܐ ܕܗܟܢܐ ܗܘ ܠܐ ܓܝܪ ܘܠܐ ܠܗ ܠܡܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Acts 22:23",
      "text": "ܘܟܕ ܡܒܓܢܝܢ ܗܘܘ ܘܡܫܕܝܢ ܗܘܘ ܡܐܢܝܗܘܢ ܘܡܤܩܝܢ ܗܘܘ ܚܠܐ ܠܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Acts 22:24",
      "text": "ܦܩܕ ܟܠܝܪܟܐ ܕܢܥܠܘܢܗ ܠܡܫܪܝܬܐ ܘܦܩܕ ܕܒܢܓܕܐ ܢܫܬܐܠ ܐܝܟ ܕܢܕܥ ܡܛܠ ܐܝܕܐ ܥܠܬܐ ܩܥܝܢ ܗܘܘ ܥܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Acts 22:25",
      "text": "ܘܟܕ ܡܬܚܘܗܝ ܒܥܪܩܐ ܐܡܪ ܗܘ ܦܘܠܘܤ ܠܩܢܛܪܘܢܐ ܕܩܐܡ ܗܘܐ ܥܠܘܗܝ ܡܦܤ ܠܟܘܢ ܕܠܓܒܪܐ ܪܗܘܡܝܐ ܕܠܐ ܡܚܝܒ ܕܬܢܓܕܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Acts 22:26",
      "text": "ܘܟܕ ܫܡܥ ܩܢܛܪܘܢܐ ܩܪܒ ܠܘܬ ܟܠܝܪܟܐ ܘܐܡܪ ܠܗ ܡܢܐ ܥܒܕ ܐܢܬ ܗܢܐ ܓܝܪ ܓܒܪܐ ܪܗܘܡܝܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Acts 22:27",
      "text": "ܘܩܪܒ ܠܘܬܗ ܟܠܝܪܟܐ ܘܐܡܪ ܠܗ ܐܡܪ ܠܝ ܐܢܬ ܪܗܘܡܝܐ ܐܢܬ ܘܐܡܪ ܠܗ ܐܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Acts 22:28",
      "text": "ܘܥܢܐ ܟܠܝܪܟܐ ܘܐܡܪ ܐܢܐ ܒܟܤܦܐ ܤܓܝܐܐ ܩܢܝܬܗ ܠܪܗܘܡܝܘܬܐ ܐܡܪ ܠܗ ܦܘܠܘܤ ܐܢܐ ܕܝܢ ܐܦ ܒܗ ܐܬܝܠܕܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.29",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Acts 22:29",
      "text": "ܘܡܚܕܐ ܦܪܩܘ ܠܗܘܢ ܡܢܗ ܗܢܘܢ ܕܒܥܝܢ ܗܘܘ ܠܡܢܓܕܘܬܗ ܘܕܚܠ ܟܠܝܪܟܐ ܟܕ ܝܠܦ ܕܪܗܘܡܝܐ ܗܘ ܥܠ ܕܦܟܪܗ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.22.30",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "Acts 22:30",
      "text": "ܘܠܝܘܡܐ ܐܚܪܢܐ ܨܒܐ ܗܘܐ ܠܡܕܥ ܫܪܝܪܐܝܬ ܕܡܢܐ ܗܝ ܩܛܓܪܢܘܬܐ ܕܡܝܬܝܢ ܗܘܘ ܥܠܘܗܝ ܝܗܘܕܝܐ ܘܫܪܝܗܝ ܘܦܩܕ ܕܢܐܬܘܢ ܪܒܝ ܟܗܢܐ ܘܟܠܗ ܟܢܫܐ ܕܪܫܝܗܘܢ ܘܕܒܪ ܠܦܘܠܘܤ ܘܐܚܬ ܐܩܝܡܗ ܒܝܢܬܗܘܢ ܀",
      "paragraphStart": false
    }
  ]
}
