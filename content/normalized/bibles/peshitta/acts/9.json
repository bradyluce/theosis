    "referenceLabel": "Acts 9",
    "summary": "Source text for Acts 9 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.9.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Acts 9:1",
      "text": "ܫܐܘܠ ܕܝܢ ܥܕܟܝܠ ܡܠܐ ܗܘܐ ܠܘܚܡܐ ܘܚܡܬܐ ܕܩܛܠܐ ܥܠ ܬܠܡܝܕܘܗܝ ܕܡܪܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.9.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Acts 9:2",
      "text": "ܘܫܐܠ ܠܗ ܐܓܪܬܐ ܡܢ ܪܒ ܟܗܢܐ ܕܢܬܠ ܠܗ ܠܕܪܡܤܘܩ ܠܟܢܘܫܬܐ ܕܐܢ ܗܘ ܕܢܫܟܚ ܕܪܕܝܢ ܒܗܕܐ ܐܘܪܚܐ ܓܒܪܐ ܐܘ ܢܫܐ ܢܐܤܘܪ ܢܝܬܐ ܐܢܘܢ ܠܐܘܪܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Acts 9:3",
      "text": "ܘܟܕ ܐܙܠ ܗܘܐ ܘܫܪܝ ܡܡܛܐ ܠܕܪܡܤܘܩ ܡܢ ܬܚܝܬ ܫܠܝܐ ܐܙܠܓ ܗܘܐ ܥܠܘܗܝ ܢܘܗܪܐ ܡܢ ܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Acts 9:4",
      "text": "ܘܢܦܠ ܥܠ ܐܪܥܐ ܘܫܡܥ ܩܠܐ ܕܐܡܪ ܠܗ ܫܐܘܠ ܫܐܘܠ ܡܢܐ ܪܕܦ ܐܢܬ ܠܝ ܩܫܐ ܗܘ ܠܟ ܠܡܒܥܛܘ ܠܥܘܩܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Acts 9:5",
      "text": "ܥܢܐ ܗܘ ܘܐܡܪ ܡܢ ܐܢܬ ܡܪܝ ܘܡܪܢ ܐܡܪ ܐܢܐ ܐܢܐ ܝܫܘܥ ܢܨܪܝܐ ܗܘ ܕܐܢܬ ܪܕܦ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Acts 9:6",
      "text": "ܐܠܐ ܩܘܡ ܥܘܠ ܠܡܕܝܢܬܐ ܘܬܡܢ ܢܬܡܠܠ ܥܡܟ ܥܠ ܡܐ ܕܘܠܐ ܠܟ ܠܡܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Acts 9:7",
      "text": "ܘܓܒܪܐ ܕܐܙܠܝܢ ܗܘܘ ܥܡܗ ܒܐܘܪܚܐ ܩܝܡܝܢ ܗܘܘ ܟܕ ܬܡܝܗܝܢ ܡܛܠ ܕܩܠܐ ܒܠܚܘܕ ܫܡܥܝܢ ܗܘܘ ܐܢܫ ܕܝܢ ܠܐ ܡܬܚܙܐ ܗܘܐ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Acts 9:8",
      "text": "ܘܩܡ ܫܐܘܠ ܡܢ ܐܪܥܐ ܘܠܐ ܡܬܚܙܐ ܗܘܐ ܠܗ ܡܕܡ ܟܕ ܥܝܢܘܗܝ ܦܬܝܚܢ ܗܘܝ ܘܟܕ ܐܚܝܕܝܢ ܒܐܝܕܘܗܝ ܐܥܠܘܗܝ ܠܕܪܡܤܘܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Acts 9:9",
      "text": "ܘܠܐ ܡܬܚܙܐ ܗܘܐ ܠܗ ܬܠܬܐ ܝܘܡܝܢ ܘܠܐ ܐܟܠ ܘܠܐ ܐܫܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Acts 9:10",
      "text": "ܐܝܬ ܗܘܐ ܕܝܢ ܒܗ ܒܕܪܡܤܘܩ ܬܠܡܝܕܐ ܚܕ ܕܫܡܗ ܗܘܐ ܚܢܢܝܐ ܘܡܪܝܐ ܐܡܪ ܠܗ ܒܚܙܘܐ ܚܢܢܝܐ ܘܐܡܪ ܗܐ ܐܢܐ ܡܪܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Acts 9:11",
      "text": "ܘܡܪܢ ܐܡܪ ܠܗ ܩܘܡ ܙܠ ܠܫܘܩܐ ܕܡܬܩܪܐ ܬܪܝܨܐ ܘܒܥܝ ܒܒܝܬܐ ܕܝܗܘܕܐ ܠܫܐܘܠ ܕܐܝܬܘܗܝ ܡܢ ܛܪܤܘܤ ܡܕܝܢܬܐ ܗܐ ܓܝܪ ܟܕ ܗܘ ܡܨܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Acts 9:12",
      "text": "ܚܙܐ ܒܚܙܘܐ ܠܓܒܪܐ ܕܫܡܗ ܚܢܢܝܐ ܕܥܠ ܘܤܡ ܥܠܘܗܝ ܐܝܕܐ ܐܝܟ ܕܢܬܦܬܚܢ ܥܝܢܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Acts 9:13",
      "text": "ܘܐܡܪ ܚܢܢܝܐ ܡܪܝ ܫܡܥܬ ܡܢ ܤܓܝܐܐ ܥܠ ܓܒܪܐ ܗܢܐ ܕܟܡܐ ܒܝܫܬܐ ܐܤܒܠ ܠܩܕܝܫܝܟ ܒܐܘܪܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Acts 9:14",
      "text": "ܘܗܐ ܐܦ ܗܪܟܐ ܐܝܬ ܠܗ ܫܘܠܛܢܐ ܡܢ ܪܒܝ ܟܗܢܐ ܕܢܐܤܘܪ ܠܟܠܗܘܢ ܐܝܠܝܢ ܕܩܪܝܢ ܫܡܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Acts 9:15",
      "text": "ܘܐܡܪ ܠܗ ܡܪܝܐ ܩܘܡ ܙܠ ܡܛܠ ܕܡܐܢܐ ܗܘ ܠܝ ܓܒܝܐ ܕܢܫܩܘܠ ܫܡܝ ܒܥܡܡܐ ܘܒܡܠܟܐ ܘܒܝܬ ܒܢܝ ܐܝܤܪܝܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Acts 9:16",
      "text": "ܐܢܐ ܓܝܪ ܐܚܘܝܘܗܝ ܟܡܐ ܥܬܝܕ ܠܡܚܫ ܡܛܠ ܫܡܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Acts 9:17",
      "text": "ܗܝܕܝܢ ܚܢܢܝܐ ܐܙܠ ܠܒܝܬܐ ܠܘܬܗ ܘܤܡ ܥܠܘܗܝ ܐܝܕܐ ܘܐܡܪ ܠܗ ܫܐܘܠ ܐܚܝ ܡܪܢ ܝܫܘܥ ܫܕܪܢܝ ܗܘ ܕܐܬܚܙܝ ܠܟ ܒܐܘܪܚܐ ܟܕ ܐܬܐ ܐܢܬ ܐܝܟ ܕܢܬܦܬܚܢ ܥܝܢܝܟ ܘܬܬܡܠܐ ܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Acts 9:18",
      "text": "ܘܒܪ ܫܥܬܗ ܢܦܠ ܡܢ ܥܝܢܘܗܝ ܡܕܡ ܕܕܡܐ ܠܩܠܦܐ ܘܐܬܦܬܚ ܥܝܢܘܗܝ ܘܩܡ ܥܡܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Acts 9:19",
      "text": "ܘܩܒܠ ܤܝܒܪܬܐ ܘܐܬܚܝܠ ܘܗܘܐ ܝܘܡܬܐ ܠܘܬ ܬܠܡܝܕܐ ܗܢܘܢ ܕܐܝܬ ܗܘܘ ܒܕܪܡܤܘܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Acts 9:20",
      "text": "ܘܒܪ ܫܥܬܗ ܡܟܪܙ ܗܘܐ ܒܟܢܘܫܬܐ ܕܝܗܘܕܝܐ ܥܠ ܝܫܘܥ ܕܗܘܝܘ ܒܪܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Acts 9:21",
      "text": "ܘܬܡܝܗܝܢ ܗܘܘ ܟܠܗܘܢ ܐܝܠܝܢ ܕܫܡܥܝܢ ܗܘܘ ܠܗ ܘܐܡܪܝܢ ܗܘܘ ܠܐ ܗܘܐ ܗܢܐ ܗܘ ܕܪܕܦ ܗܘܐ ܠܟܠܗܘܢ ܐܝܠܝܢ ܕܩܪܝܢ ܗܘܘ ܠܫܡܐ ܗܢܐ ܒܐܘܪܫܠܡ ܐܦ ܠܗܪܟܐ ܥܠܝܗ ܥܠ ܗܕܐ ܡܫܕܪ ܗܘܐ ܐܝܟ ܕܢܐܤܘܪ ܢܘܒܠ ܐܢܘܢ ܠܪܒܝ ܟܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "Acts 9:22",
      "text": "ܫܐܘܠ ܕܝܢ ܝܬܝܪ ܡܬܚܝܠ ܗܘܐ ܘܡܙܝܥ ܗܘܐ ܠܗܘܢ ܠܝܗܘܕܝܐ ܗܢܘܢ ܕܥܡܪܝܢ ܗܘܘ ܒܕܪܡܤܘܩ ܟܕ ܡܚܘܐ ܗܘܐ ܕܗܢܘ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "Acts 9:23",
      "text": "ܘܟܕ ܤܓܝܘ ܠܗ ܬܡܢ ܝܘܡܬܐ ܥܒܕܘ ܥܠܘܗܝ ܢܟܠܐ ܝܗܘܕܝܐ ܕܢܩܛܠܘܢܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "Acts 9:24",
      "text": "ܐܬܒܕܩ ܠܗ ܕܝܢ ܠܫܐܘܠ ܐܦܪܤܢܐ ܕܒܥܝܢ ܗܘܘ ܠܡܥܒܕ ܠܗ ܘܢܛܪܝܢ ܗܘܘ ܬܪܥܐ ܕܡܕܝܢܬܐ ܐܝܡܡܐ ܘܠܠܝܐ ܕܢܩܛܠܘܢܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "Acts 9:25",
      "text": "ܗܝܕܝܢ ܤܡܘܗܝ ܬܠܡܝܕܐ ܒܐܤܦܪܝܕܐ ܘܫܒܘܗܝ ܡܢ ܫܘܪܐ ܒܠܠܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "Acts 9:26",
      "text": "ܘܐܙܠ ܠܗ ܠܐܘܪܫܠܡ ܘܨܒܐ ܗܘܐ ܠܡܬܢܩܦܘ ܠܬܠܡܝܕܐ ܘܟܠܗܘܢ ܕܚܠܝܢ ܗܘܘ ܡܢܗ ܘܠܐ ܡܗܝܡܢܝܢ ܗܘܘ ܕܬܠܡܝܕܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "Acts 9:27",
      "text": "ܒܪܢܒܐ ܕܝܢ ܐܚܕܗ ܘܐܝܬܝܗ ܠܘܬ ܫܠܝܚܐ ܘܐܫܬܥܝ ܠܗܘܢ ܐܝܟܢܐ ܒܐܘܪܚܐ ܚܙܐ ܠܡܪܝܐ ܘܕܐܝܟܢܐ ܡܠܠ ܥܡܗ ܘܐܝܟܢܐ ܒܕܪܡܤܘܩ ܥܝܢ ܒܓܠܐ ܡܠܠ ܒܫܡܗ ܕܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "Acts 9:28",
      "text": "ܘܥܐܠ ܗܘܐ ܥܡܗܘܢ ܘܢܦܩ ܒܐܘܪܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.29",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 29,
      "referenceLabel": "Acts 9:29",
      "text": "ܘܡܡܠܠ ܗܘܐ ܒܫܡܗ ܕܝܫܘܥ ܥܝܢ ܒܓܠܐ ܘܕܪܫ ܗܘܐ ܥܡ ܝܗܘܕܝܐ ܐܝܠܝܢ ܕܝܕܥܝܢ ܗܘܘ ܝܘܢܐܝܬ ܗܢܘܢ ܕܝܢ ܨܒܝܢ ܗܘܘ ܠܡܩܛܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.30",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 30,
      "referenceLabel": "Acts 9:30",
      "text": "ܘܟܕ ܝܕܥܘ ܐܚܐ ܐܝܬܝܘܗܝ ܒܠܠܝܐ ܠܩܤܪܝܐ ܘܡܢ ܬܡܢ ܫܕܪܘܗܝ ܠܛܪܤܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.31",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 31,
      "referenceLabel": "Acts 9:31",
      "text": "ܒܪܡ ܕܝܢ ܥܕܬܐ ܕܒܟܠܗ ܝܗܘܕ ܘܒܓܠܝܠܐ ܘܒܫܡܪܝܢ ܐܝܬ ܗܘܐ ܒܗ ܫܠܡܐ ܟܕ ܡܬܒܢܝܐ ܗܘܬ ܘܪܕܝܐ ܒܕܚܠܬ ܐܠܗܐ ܘܒܒܘܝܐܐ ܕܪܘܚܐ ܕܩܘܕܫܐ ܤܓܝܐ ܗܘܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.32",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 32,
      "referenceLabel": "Acts 9:32",
      "text": "ܘܗܘܐ ܕܟܕ ܡܬܟܪܟ ܗܘܐ ܫܡܥܘܢ ܒܡܕܝܢܬܐ ܢܚܬ ܐܦ ܠܘܬ ܩܕܝܫܐ ܕܥܡܪܝܢ ܒܠܘܕ ܡܕܝܢܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.33",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 33,
      "referenceLabel": "Acts 9:33",
      "text": "ܘܐܫܟܚ ܓܒܪܐ ܚܕ ܕܫܡܗ ܐܢܝܤ ܕܪܡܐ ܗܘܐ ܒܥܪܤܐ ܘܡܫܪܝ ܫܢܝܢ ܬܡܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.9.34",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 9,
      "verseNumber": 34,
      "referenceLabel": "Acts 9:34",
      "text": "ܘܐܡܪ ܠܗ ܫܡܥܘܢ ܐܢܝܐ ܡܐܤܐ ܠܟ ܝܫܘܥ ܡܫܝܚܐ ܩܘܡ ܘܫܘܐ ܥܪܤܟ ܘܒܪ ܫܥܬܗ ܩܡ ܀",
      "paragraphStart": false
