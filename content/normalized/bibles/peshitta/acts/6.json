{
  "chapter": {
    "id": "peshitta:acts.6",
    "translationId": "peshitta",
    "bookSlug": "acts",
    "chapterNumber": 6,
    "referenceLabel": "Acts 6",
    "summary": "Source text for Acts 6 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.6.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Acts 6:1",
      "text": "ܘܒܗܘܢ ܒܝܘܡܬܐ ܗܢܘܢ ܟܕ ܤܓܝܘ ܬܠܡܝܕܐ ܪܛܢܘ ܗܘܘ ܝܘܢܝܐ ܬܠܡܝܕܐ ܥܠ ܥܒܪܝܐ ܕܡܬܒܤܝܢ ܗܘܝ ܐܪܡܠܬܗܘܢ ܒܬܫܡܫܬܐ ܕܟܠܝܘܡ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.6.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Acts 6:2",
      "text": "ܘܩܪܘ ܬܪܥܤܪ ܫܠܝܚܐ ܠܟܠܗ ܟܢܫܐ ܕܬܠܡܝܕܐ ܘܐܡܪܘ ܠܗܘܢ ܠܐ ܫܦܝܪ ܕܢܫܒܘܩ ܡܠܬܐ ܕܐܠܗܐ ܘܢܫܡܫ ܦܬܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.6.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Acts 6:3",
      "text": "ܒܨܘ ܗܟܝܠ ܐܚܝ ܘܓܒܘ ܫܒܥܐ ܓܒܪܝܢ ܡܢܟܘܢ ܕܐܝܬ ܥܠܝܗܘܢ ܤܗܕܘܬܐ ܘܡܠܝܢ ܪܘܚܗ ܕܡܪܝܐ ܘܚܟܡܬܐ ܘܢܩܝܡ ܐܢܘܢ ܥܠ ܗܕܐ ܨܒܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.6.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Acts 6:4",
      "text": "ܘܚܢܢ ܢܗܘܐ ܐܡܝܢܝܢ ܒܨܠܘܬܐ ܘܒܬܫܡܫܬܐ ܕܡܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.6.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Acts 6:5",
      "text": "ܘܫܦܪܬ ܗܕܐ ܡܠܬܐ ܩܕܡ ܟܠܗ ܥܡܐ ܘܓܒܘ ܠܐܤܛܦܢܘܤ ܓܒܪܐ ܕܡܠܐ ܗܘܐ ܗܝܡܢܘܬܐ ܘܪܘܚܐ ܕܩܘܕܫܐ ܘܠܦܝܠܝܦܘܤ ܘܠܦܪܟܪܘܤ ܘܠܢܝܩܢܘܪ ܘܠܛܝܡܘܢ ܘܠܦܪܡܢܐ ܘܠܢܝܩܠܐܘܤ ܓܝܘܪܐ ܐܢܛܝܘܟܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.6.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Acts 6:6",
      "text": "ܗܠܝܢ ܩܡܘ ܩܕܡܝܗܘܢ ܕܫܠܝܚܐ ܘܟܕ ܨܠܝܘ ܤܡܘ ܥܠܝܗܘܢ ܐܝܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.6.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Acts 6:7",
      "text": "ܘܡܠܬܗ ܕܐܠܗܐ ܪܒܝܐ ܗܘܬ ܘܤܓܐ ܗܘܐ ܡܢܝܢܐ ܕܬܠܡܝܕܐ ܒܐܘܪܫܠܡ ܛܒ ܘܥܡܐ ܤܓܝܐܐ ܡܢ ܝܗܘܕܝܐ ܡܫܬܡܥ ܗܘܐ ܠܗܝܡܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.6.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Acts 6:8",
      "text": "ܐܤܛܦܢܘܤ ܕܝܢ ܡܠܐ ܗܘܐ ܛܝܒܘܬܐ ܘܚܝܠܐ ܘܥܒܕ ܗܘܐ ܐܬܘܬܐ ܘܬܕܡܪܬܐ ܒܥܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.6.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Acts 6:9",
      "text": "ܘܩܡܘ ܗܘܘ ܐܢܫܐ ܡܢ ܟܢܘܫܬܐ ܕܡܬܩܪܝܐ ܕܠܝܒܪܛܝܢܘ ܘܩܘܪܝܢܝܐ ܘܐܠܟܤܢܕܪܝܐ ܘܕܡܢ ܩܝܠܝܩܝܐ ܘܡܢ ܐܤܝܐ ܘܕܪܫܝܢ ܗܘܘ ܥܡ ܐܤܛܦܢܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.6.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Acts 6:10",
      "text": "ܘܠܐ ܡܫܟܚܝܢ ܗܘܘ ܠܡܩܡ ܠܘܩܒܠ ܚܟܡܬܐ ܘܪܘܚܐ ܕܡܡܠܠܐ ܗܘܬ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.6.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Acts 6:11",
      "text": "ܗܝܕܝܢ ܫܕܪܘ ܠܓܒܪܐ ܘܐܠܦܘ ܐܢܘܢ ܕܢܐܡܪܘܢ ܕܚܢܢ ܫܡܥܢܝܗܝ ܕܐܡܪ ܡܠܐ ܕܓܘܕܦܐ ܥܠ ܡܘܫܐ ܘܥܠ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.6.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Acts 6:12",
      "text": "ܘܫܓܫܘ ܠܥܡܐ ܘܠܩܫܝܫܐ ܘܠܤܦܪܐ ܘܐܬܘ ܘܩܡܘ ܥܠܘܗܝ ܘܚܛܦܘ ܐܝܬܝܘܗܝ ܠܡܨܥܬ ܟܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.6.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Acts 6:13",
      "text": "ܘܐܩܝܡܘ ܤܗܕܐ ܕܓܠܐ ܕܐܡܪܝܢ ܗܢܐ ܓܒܪܐ ܠܐ ܫܠܐ ܠܡܡܠܠܘ ܡܠܐ ܠܘܩܒܠ ܢܡܘܤܐ ܘܥܠ ܐܬܪܐ ܗܢܐ ܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.6.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Acts 6:14",
      "text": "ܚܢܢ ܓܝܪ ܫܡܥܢܝܗܝ ܕܐܡܪ ܕܝܫܘܥ ܗܢܐ ܢܨܪܝܐ ܗܘ ܢܫܪܝܘܗܝ ܠܐܬܪܐ ܗܢܐ ܘܢܚܠܦ ܥܝܕܐ ܕܐܫܠܡ ܠܟܘܢ ܡܘܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.6.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Acts 6:15",
      "text": "ܘܚܪܘ ܒܗ ܟܠܗܘܢ ܗܢܘܢ ܕܝܬܒܝܢ ܗܘܘ ܒܟܢܘܫܬܐ ܘܚܙܘ ܦܪܨܘܦܗ ܐܝܟ ܦܪܨܘܦܐ ܕܡܠܐܟܐ ܀",
      "paragraphStart": false
    }
  ]
}
