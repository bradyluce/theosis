{
  "chapter": {
    "id": "peshitta:acts.2",
    "translationId": "peshitta",
    "bookSlug": "acts",
    "chapterNumber": 2,
    "referenceLabel": "Acts 2",
    "summary": "Source text for Acts 2 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.2.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Acts 2:1",
      "text": "ܘܟܕ ܐܬܡܠܝܘ ܝܘܡܬܐ ܕܦܢܛܩܘܤܛܐ ܟܕ ܟܢܝܫܝܢ ܗܘܘ ܟܠܗܘܢ ܐܟܚܕܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.2.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Acts 2:2",
      "text": "ܗܘܐ ܡܢ ܫܠܝܐ ܡܢ ܫܡܝܐ ܩܠܐ ܐܝܟ ܪܘܚܐ ܥܙܝܙܬܐ ܘܐܬܡܠܝ ܗܘܐ ܡܢܗ ܟܠܗ ܒܝܬܐ ܗܘ ܕܒܗ ܝܬܒܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Acts 2:3",
      "text": "ܘܐܬܚܙܝܘ ܠܗܘܢ ܠܫܢܐ ܕܡܬܦܠܓܝܢ ܗܘܘ ܐܝܟ ܢܘܪܐ ܘܝܬܒܘ ܥܠ ܚܕ ܚܕ ܡܢܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Acts 2:4",
      "text": "ܘܐܬܡܠܝܘ ܟܠܗܘܢ ܒܪܘܚܐ ܕܩܘܕܫܐ ܘܐܩܦܘ ܗܘܘ ܠܡܡܠܠܘ ܒܠܫܢ ܠܫܢ ܐܝܟ ܡܐ ܕܪܘܚܐ ܝܗܒ ܗܘܐ ܠܗܘܢ ܠܡܡܠܠܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Acts 2:5",
      "text": "ܐܝܬ ܗܘܘ ܕܝܢ ܓܒܪܐ ܕܥܡܪܝܢ ܒܐܘܪܫܠܡ ܕܕܚܠܝܢ ܡܢ ܐܠܗܐ ܝܗܘܕܝܐ ܡܢ ܟܠ ܥܡܡܐ ܕܬܚܝܬ ܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Acts 2:6",
      "text": "ܘܟܕ ܗܘܐ ܩܠܐ ܗܘ ܟܢܫ ܟܠܗ ܥܡܐ ܘܐܫܬܓܫ ܡܛܠ ܕܫܡܥ ܗܘܐ ܐܢܫ ܐܢܫ ܡܢܗܘܢ ܕܡܡܠܠܝܢ ܗܘܘ ܒܠܫܢܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Acts 2:7",
      "text": "ܬܗܝܪܝܢ ܗܘܘ ܕܝܢ ܟܠܗܘܢ ܘܡܬܕܡܪܝܢ ܟܕ ܐܡܪܝܢ ܗܘܘ ܚܕ ܠܚܕ ܗܠܝܢ ܟܠܗܘܢ ܕܡܡܠܠܝܢ ܠܐ ܗܐ ܓܠܝܠܝܐ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Acts 2:8",
      "text": "ܐܝܟܢܐ ܚܢܢ ܫܡܥܝܢ ܚܢܢ ܐܢܫ ܐܢܫ ܠܫܢܗ ܕܒܗ ܝܠܝܕܝܢ ܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Acts 2:9",
      "text": "ܦܪܬܘܝܐ ܘܡܕܝܐ ܘܐܠܢܝܐ ܘܐܝܠܝܢ ܕܥܡܪܝܢ ܒܝܬ ܢܗܪܝܢ ܝܗܘܕܝܐ ܘܩܦܘܕܩܝܐ ܘܕܡܢ ܐܬܪܐ ܕܦܢܛܘܤ ܘܕܐܤܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Acts 2:10",
      "text": "ܘܕܡܢ ܐܬܪܐ ܕܦܪܘܓܝܐ ܘܕܦܡܦܘܠܝܐ ܘܕܡܨܪܝܢ ܘܕܐܬܪܘܬܐ ܕܠܘܒܐ ܕܩܪܝܒܝܢ ܠܩܘܪܝܢܐ ܘܐܝܠܝܢ ܕܐܬܘ ܡܢ ܪܗܘܡܐ ܝܗܘܕܝܐ ܘܓܝܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Acts 2:11",
      "text": "ܘܕܡܢ ܩܪܛܐ ܘܥܪܒܝܐ ܗܐ ܫܡܥܝܢ ܚܢܢ ܡܢܗܘܢ ܕܡܡܠܠܝܢ ܒܠܫܢܝܢ ܕܝܠܢ ܬܕܡܪܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Acts 2:12",
      "text": "ܡܬܕܡܪܝܢ ܗܘܘ ܕܝܢ ܟܠܗܘܢ ܘܬܘܝܪܝܢ ܟܕ ܐܡܪܝܢ ܚܕ ܠܚܕ ܕܡܢܐ ܗܝ ܗܕܐ ܨܒܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Acts 2:13",
      "text": "ܐܚܪܢܐ ܕܝܢ ܡܡܝܩܝܢ ܗܘܘ ܒܗܘܢ ܟܕ ܐܡܪܝܢ ܗܠܝܢ ܡܐܪܝܬܐ ܐܫܬܝܘ ܘܪܘܝܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Acts 2:14",
      "text": "ܒܬܪܟܢ ܩܡ ܫܡܥܘܢ ܟܐܦܐ ܥܡ ܚܕܥܤܪ ܫܠܝܚܝܢ ܘܐܪܝܡ ܩܠܗ ܘܐܡܪ ܠܗܘܢ ܓܒܪܐ ܝܗܘܕܝܐ ܘܟܠܗܘܢ ܕܥܡܪܝܢ ܒܐܘܪܫܠܡ ܗܕܐ ܬܬܝܕܥ ܠܟܘܢ ܘܨܘܬܘ ܡܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Acts 2:15",
      "text": "ܠܐ ܓܝܪ ܐܝܟܢܐ ܕܐܢܬܘܢ ܤܒܪܝܢ ܗܠܝܢ ܪܘܝܢ ܕܗܐ ܥܕܡܐ ܠܗܫܐ ܬܠܬ ܐܢܝܢ ܫܥܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Acts 2:16",
      "text": "ܐܠܐ ܗܕܐ ܗܝ ܕܐܡܝܪܐ ܒܝܘܐܝܠ ܢܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Acts 2:17",
      "text": "ܢܗܘܐ ܒܝܘܡܬܐ ܐܚܪܝܐ ܐܡܪ ܐܠܗܐ ܐܫܘܕ ܪܘܚܝ ܥܠ ܟܠ ܒܤܪ ܘܢܬܢܒܘܢ ܒܢܝܟܘܢ ܘܒܢܬܟܘܢ ܘܓܕܘܕܝܟܘܢ ܚܙܘܢܐ ܢܚܙܘܢ ܘܩܫܝܫܝܟܘܢ ܚܠܡܐ ܢܚܠܡܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Acts 2:18",
      "text": "ܘܥܠ ܥܒܕܝ ܘܥܠ ܐܡܗܬܝ ܐܫܘܕ ܪܘܚܝ ܒܝܘܡܬܐ ܗܢܘܢ ܘܢܬܢܒܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Acts 2:19",
      "text": "ܘܐܬܠ ܐܬܘܬܐ ܒܫܡܝܐ ܘܓܒܪܘܬܐ ܥܠ ܐܪܥܐ ܕܡܐ ܘܢܘܪܐ ܘܥܛܪܐ ܕܬܢܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Acts 2:20",
      "text": "ܫܡܫܐ ܢܬܚܠܦ ܒܥܡܛܢܐ ܘܤܗܪܐ ܒܕܡܐ ܥܕܠܐ ܢܐܬܐ ܝܘܡܗ ܕܡܪܝܐ ܪܒܐ ܘܕܚܝܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Acts 2:21",
      "text": "ܘܢܗܘܐ ܟܠ ܕܢܩܪܐ ܫܡܗ ܕܡܪܝܐ ܢܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Acts 2:22",
      "text": "ܓܒܪܐ ܒܢܝ ܐܝܤܪܝܠ ܫܡܥܘ ܡܠܐ ܗܠܝܢ ܝܫܘܥ ܢܨܪܝܐ ܓܒܪܐ ܕܡܢ ܐܠܗܐ ܐܬܚܙܝ ܠܘܬܟܘܢ ܒܚܝܠܐ ܘܒܐܬܘܬܐ ܘܒܓܒܪܘܬܐ ܐܝܠܝܢ ܕܐܠܗܐ ܥܒܕ ܒܝܢܬܟܘܢ ܒܐܝܕܗ ܐܝܟ ܕܐܢܬܘܢ ܝܕܥܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Acts 2:23",
      "text": "ܠܗܢܐ ܕܦܪܝܫ ܗܘܐ ܠܗ ܠܗܕܐ ܒܡܩܕܡܘܬ ܝܕܥܬܗ ܘܒܨܒܝܢܗ ܕܐܠܗܐ ܐܫܠܡܬܘܢܝܗܝ ܒܐܝܕܝ ܪܫܝܥܐ ܘܙܩܦܬܘܢ ܘܩܛܠܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "Acts 2:24",
      "text": "ܐܠܗܐ ܕܝܢ ܐܩܝܡܗ ܘܫܪܐ ܚܒܠܝܗ ܕܫܝܘܠ ܡܛܠ ܕܠܐ ܡܫܟܚܐ ܗܘܬ ܕܢܬܬܚܕ ܒܗ ܒܫܝܘܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "Acts 2:25",
      "text": "ܕܘܝܕ ܓܝܪ ܐܡܪ ܥܠܘܗܝ ܡܩܕܡ ܗܘܝܬ ܚܙܐ ܠܡܪܝ ܒܟܠܙܒܢ ܕܥܠ ܝܡܝܢܝ ܗܘ ܕܠܐ ܐܙܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "Acts 2:26",
      "text": "ܡܛܠ ܗܢܐ ܐܬܒܤܡ ܠܒܝ ܘܪܘܙܬ ܬܫܒܘܚܬܝ ܘܐܦ ܦܓܪܝ ܢܓܢ ܥܠ ܤܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "Acts 2:27",
      "text": "ܡܛܠ ܕܠܐ ܫܒܩ ܐܢܬ ܠܢܦܫܝ ܒܫܝܘܠ ܘܠܐ ܝܗܒ ܐܢܬ ܠܚܤܝܟ ܕܢܚܙܐ ܚܒܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "Acts 2:28",
      "text": "ܓܠܝܬ ܠܝ ܐܘܪܚܐ ܕܚܝܐ ܬܡܠܝܢܝ ܒܤܝܡܘܬܐ ܥܡ ܦܪܨܘܦܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.29",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 29,
      "referenceLabel": "Acts 2:29",
      "text": "ܓܒܪܐ ܐܚܝܢ ܡܦܤ ܠܡܐܡܪ ܥܝܢ ܒܓܠܐ ܠܘܬܟܘܢ ܥܠ ܪܝܫ ܐܒܗܬܐ ܕܘܝܕ ܕܡܝܬ ܘܐܦ ܐܬܩܒܪ ܘܒܝܬ ܩܒܘܪܗ ܐܝܬܘܗܝ ܠܘܬܢ ܥܕܡܐ ܠܝܘܡܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.30",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 30,
      "referenceLabel": "Acts 2:30",
      "text": "ܢܒܝܐ ܗܘܐ ܓܝܪ ܘܝܕܥ ܗܘܐ ܕܡܘܡܬܐ ܝܡܐ ܠܗ ܐܠܗܐ ܕܡܢ ܦܐܪܐ ܕܟܪܤܟ ܐܘܬܒ ܥܠ ܟܘܪܤܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.31",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 31,
      "referenceLabel": "Acts 2:31",
      "text": "ܘܩܕܡ ܚܙܐ ܘܡܠܠ ܥܠ ܩܝܡܬܗ ܕܡܫܝܚܐ ܕܠܐ ܐܫܬܒܩ ܒܫܝܘܠ ܐܦܠܐ ܦܓܪܗ ܚܙܐ ܚܒܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.32",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 32,
      "referenceLabel": "Acts 2:32",
      "text": "ܠܗܢܐ ܝܫܘܥ ܐܩܝܡ ܐܠܗܐ ܘܚܢܢ ܟܠܢ ܤܗܕܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.33",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 33,
      "referenceLabel": "Acts 2:33",
      "text": "ܘܗܘܝܘ ܕܒܝܡܝܢܗ ܕܐܠܗܐ ܐܬܬܪܝܡ ܘܢܤܒ ܡܢ ܐܒܐ ܫܘܘܕܝܐ ܕܥܠ ܪܘܚܐ ܕܩܘܕܫܐ ܘܐܫܕ ܡܘܗܒܬܐ ܗܕܐ ܕܗܐ ܚܙܝܢ ܐܢܬܘܢ ܘܫܡܥܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.34",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 34,
      "referenceLabel": "Acts 2:34",
      "text": "ܠܐ ܗܘܐ ܓܝܪ ܕܘܝܕ ܤܠܩ ܠܫܡܝܐ ܡܛܠ ܕܗܘ ܐܡܪ ܕܐܡܪ ܡܪܝܐ ܠܡܪܝ ܬܒ ܠܟ ܡܢ ܝܡܝܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.35",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 35,
      "referenceLabel": "Acts 2:35",
      "text": "ܥܕܡܐ ܕܐܤܝܡ ܒܥܠܕܒܒܝܟ ܟܘܒܫܐ ܠܪܓܠܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.2.36",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 2,
      "verseNumber": 36,
      "referenceLabel": "Acts 2:36",
