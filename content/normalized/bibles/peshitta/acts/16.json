    "chapterNumber": 16,
    "referenceLabel": "Acts 16",
    "summary": "Source text for Acts 16 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.16.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Acts 16:1",
      "text": "ܘܡܛܝ ܗܘܐ ܠܕܪܒܐ ܡܕܝܢܬܐ ܘܠܠܘܤܛܪܐ ܐܝܬ ܗܘܐ ܕܝܢ ܬܡܢ ܬܠܡܝܕܐ ܚܕ ܕܫܡܗ ܛܝܡܬܐܘܤ ܒܪܗ ܕܝܗܘܕܝܬܐ ܚܕܐ ܡܗܝܡܢܬܐ ܘܐܒܘܗܝ ܐܪܡܝܐ ܗܘܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.16.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Acts 16:2",
      "text": "ܘܟܠܗܘܢ ܬܠܡܝܕܐ ܕܡܢ ܠܘܤܛܪܐ ܘܡܢ ܐܝܩܢܘܢ ܡܤܗܕܝܢ ܗܘܘ ܥܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Acts 16:3",
      "text": "ܠܗܢܐ ܨܒܐ ܗܘܐ ܦܘܠܘܤ ܕܢܕܒܪܝܘܗܝ ܥܡܗ ܘܢܤܒ ܓܙܪܗ ܡܛܠ ܝܗܘܕܝܐ ܕܐܝܬ ܗܘܘ ܒܐܬܪܐ ܝܕܥܝܢ ܗܘܘ ܓܝܪ ܟܠܗܘܢ ܠܐܒܘܗܝ ܕܐܪܡܝܐ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Acts 16:4",
      "text": "ܘܟܕ ܐܙܠܝܢ ܗܘܘ ܒܡܕܝܢܬܐ ܡܟܪܙܝܢ ܗܘܘ ܘܡܠܦܝܢ ܠܗܘܢ ܕܢܗܘܘܢ ܢܛܪܝܢ ܦܘܩܕܢܐ ܐܝܠܝܢ ܕܟܬܒܘ ܫܠܝܚܐ ܘܩܫܝܫܐ ܕܒܐܘܪܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Acts 16:5",
      "text": "ܒܪܡ ܥܕܬܐ ܡܬܩܝܡܢ ܗܘܝ ܒܗܝܡܢܘܬܐ ܘܤܓܝܢ ܗܘܝ ܒܡܢܝܢܐ ܟܠܝܘܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Acts 16:6",
      "text": "ܗܠܟܘ ܕܝܢ ܒܦܪܘܓܝܐ ܘܒܓܠܛܝܐ ܐܬܪܘܬܐ ܘܟܠܬ ܐܢܘܢ ܪܘܚܐ ܕܩܘܕܫܐ ܕܠܐ ܢܡܠܠܘܢ ܡܠܬܐ ܕܐܠܗܐ ܒܐܤܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Acts 16:7",
      "text": "ܘܟܕ ܐܬܘ ܠܡܘܤܝܐ ܐܬܪܐ ܨܒܝܢ ܗܘܘ ܕܢܐܙܠܘܢ ܡܢ ܬܡܢ ܠܒܝܬܘܢܝܐ ܘܠܐ ܐܦܤܬ ܠܗܘܢ ܪܘܚܗ ܕܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Acts 16:8",
      "text": "ܘܟܕ ܢܦܩܘ ܡܢ ܡܘܤܝܐ ܢܚܬܘ ܠܗܘܢ ܠܛܪܘܐܤ ܐܬܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Acts 16:9",
      "text": "ܘܒܚܙܘܐ ܕܠܠܝܐ ܐܬܚܙܝ ܠܦܘܠܘܤ ܐܝܟ ܓܒܪܐ ܚܕ ܡܩܕܘܢܝܐ ܕܩܐܡ ܘܒܥܐ ܡܢܗ ܟܕ ܐܡܪ ܕܬܐ ܠܡܩܕܘܢܝܐ ܘܥܕܪܝܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Acts 16:10",
      "text": "ܟܕ ܕܝܢ ܚܙܐ ܦܘܠܘܤ ܗܢܐ ܚܙܘܐ ܡܚܕܐ ܨܒܝܢ ܠܡܦܩ ܠܡܩܕܘܢܝܐ ܡܛܠ ܕܐܤܬܟܠܢ ܕܡܪܢ ܩܪܢ ܕܢܤܒܪ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Acts 16:11",
      "text": "ܘܪܕܝܢ ܡܢ ܛܪܘܐܤ ܘܬܪܨܢ ܠܤܡܬܪܩܐ ܘܡܢ ܬܡܢ ܠܝܘܡܐ ܐܚܪܢܐ ܐܬܝܢ ܠܢܐܦܘܠܝܤ ܡܕܝܢܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Acts 16:12",
      "text": "ܘܡܢ ܬܡܢ ܠܦܝܠܝܦܘܤ ܕܗܝ ܗܝ ܪܫܐ ܕܡܩܕܘܢܝܐ ܘܐܝܬܝܗ ܩܘܠܘܢܝܐ ܗܘܝܢ ܕܝܢ ܒܗ ܒܗܕܐ ܡܕܝܢܬܐ ܝܘܡܬܐ ܝܕܝܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Acts 16:13",
      "text": "ܘܢܦܩܢ ܒܝܘܡܐ ܕܫܒܬܐ ܠܒܪ ܡܢ ܬܪܥܐ ܕܡܕܝܢܬܐ ܥܠ ܝܕ ܢܗܪܐ ܡܛܠ ܕܬܡܢ ܡܬܚܙܐ ܗܘܐ ܒܝܬ ܨܠܘܬܐ ܘܟܕ ܝܬܒܢ ܡܡܠܠܝܢ ܗܘܝܢ ܥܡ ܢܫܐ ܕܟܢܝܫܢ ܗܘܝ ܬܡܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Acts 16:14",
      "text": "ܘܐܢܬܬܐ ܚܕܐ ܡܙܒܢܬ ܐܪܓܘܢܐ ܕܕܚܠܐ ܗܘܬ ܡܢ ܐܠܗܐ ܫܡܗ ܗܘܐ ܠܘܕܝܐ ܡܢ ܬܐܘܛܝܪܐ ܡܕܝܢܬܐ ܕܗܕܐ ܦܬܚ ܠܒܗ ܡܪܢ ܘܫܡܥܐ ܗܘܬ ܡܕܡ ܕܐܡܪ ܦܘܠܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Acts 16:15",
      "text": "ܘܥܡܕܬ ܗܘܬ ܗܝ ܘܒܢܝ ܒܝܬܗ ܘܒܥܝܐ ܗܘܬ ܡܢܢ ܘܐܡܪܐ ܕܐܢ ܗܘ ܕܫܪܝܪܐܝܬ ܬܟܝܠܝܢ ܐܢܬܘܢ ܕܗܝܡܢܬ ܒܡܪܢ ܬܘ ܫܪܘ ܠܟܘܢ ܒܒܝܬܝ ܘܤܓܝ ܐܠܨܬܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Acts 16:16",
      "text": "ܘܗܘܐ ܕܟܕ ܐܙܠܝܢܢ ܠܒܝܬ ܨܠܘܬܐ ܦܓܥܬ ܒܢ ܥܠܝܡܬܐ ܚܕܐ ܕܐܝܬ ܗܘܐ ܠܗ ܪܘܚܐ ܕܩܨܡܐ ܘܥܒܕܐ ܗܘܬ ܠܡܪܝܗ ܬܐܓܘܪܬܐ ܤܓܝܐܬܐ ܒܩܨܡܐ ܕܩܨܡܐ ܗܘܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Acts 16:17",
      "text": "ܘܐܬܝܐ ܗܘܬ ܒܬܪ ܦܘܠܘܤ ܘܒܬܪܢ ܘܩܥܝܐ ܗܘܬ ܘܐܡܪܐ ܗܠܝܢ ܐܢܫܐ ܥܒܕܘܗܝ ܐܢܘܢ ܕܐܠܗܐ ܡܪܝܡܐ ܘܡܤܒܪܝܢ ܠܟܘܢ ܐܘܪܚܐ ܕܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Acts 16:18",
      "text": "ܘܗܟܢܐ ܥܒܕܐ ܗܘܬ ܝܘܡܬܐ ܤܓܝܐܐ ܘܐܬܬܦܝܪ ܦܘܠܘܤ ܘܐܡܪ ܠܗ ܠܪܘܚܐ ܗܝ ܦܩܕ ܐܢܐ ܠܟܝ ܒܫܡܗ ܕܝܫܘܥ ܡܫܝܚܐ ܕܬܦܩܝܢ ܡܢܗ ܘܒܗ ܒܫܥܬܐ ܢܦܩܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Acts 16:19",
      "text": "ܘܟܕ ܚܙܘ ܡܪܝܗ ܕܢܦܩ ܠܗ ܡܢܗ ܤܒܪܐ ܕܬܐܓܘܪܬܗܘܢ ܐܚܕܘܗܝ ܠܦܘܠܘܤ ܘܠܫܝܠܐ ܘܢܓܕܘ ܐܝܬܝܘ ܐܢܘܢ ܠܫܘܩܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Acts 16:20",
      "text": "ܘܩܪܒܘ ܐܢܘܢ ܠܐܤܛܪܛܓܐ ܘܠܪܫܐ ܕܡܕܝܢܬܐ ܘܐܡܪܝܢ ܗܘܘ ܕܗܠܝܢ ܐܢܫܐ ܡܕܠܚܝܢ ܠܗ ܠܡܕܝܢܬܢ ܡܛܠ ܕܝܗܘܕܝܐ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "Acts 16:21",
      "text": "ܘܡܟܪܙܝܢ ܠܢ ܥܝܕܐ ܐܝܠܝܢ ܕܠܐ ܡܦܤ ܠܢ ܠܡܩܒܠܘ ܘܠܡܥܒܕ ܡܛܠ ܕܪܗܘܡܝܐ ܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "Acts 16:22",
      "text": "ܘܟܢܫܐ ܤܓܝܐܐ ܐܬܟܢܫܘ ܥܠܝܗܘܢ ܗܝܕܝܢ ܐܤܛܪܛܓܐ ܤܕܩܘ ܢܚܬܝܗܘܢ ܘܦܩܕܘ ܕܢܢܓܕܘܢ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "Acts 16:23",
      "text": "ܘܟܕ ܢܓܕܘ ܐܢܘܢ ܤܓܝ ܐܪܡܝܘ ܐܢܘܢ ܒܝܬ ܐܤܝܪܐ ܘܦܩܕܘ ܠܢܛܪ ܒܝܬ ܐܤܝܪܐ ܕܢܛܪ ܐܢܘܢ ܙܗܝܪܐܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "Acts 16:24",
      "text": "ܗܘ ܕܝܢ ܟܕ ܩܒܠ ܗܢܐ ܦܘܩܕܢܐ ܐܥܠ ܚܒܫ ܐܢܘܢ ܒܒܝܬܐ ܓܘܝܐ ܕܒܝܬ ܐܤܝܪܐ ܘܐܤܪ ܪܓܠܝܗܘܢ ܒܤܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 25,
      "referenceLabel": "Acts 16:25",
      "text": "ܘܒܦܠܓܗ ܕܠܠܝܐ ܦܘܠܘܤ ܘܫܝܠܐ ܡܨܠܝܢ ܗܘܘ ܘܡܫܒܚܝܢ ܗܘܘ ܠܐܠܗܐ ܘܫܡܥܝܢ ܗܘܘ ܠܗܘܢ ܐܤܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 26,
      "referenceLabel": "Acts 16:26",
      "text": "ܘܡܢ ܫܠܝܐ ܙܘܥܐ ܪܒܐ ܗܘܐ ܘܐܬܬܙܝܥ ܫܬܐܤܐ ܕܒܝܬ ܐܤܝܪܐ ܘܐܬܦܬܚܘ ܡܚܕܐ ܬܪܥܐ ܟܠܗܘܢ ܘܐܤܘܪܝܗܘܢ ܕܟܠܗܘܢ ܐܫܬܪܝܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 27,
      "referenceLabel": "Acts 16:27",
      "text": "ܘܟܕ ܐܬܬܥܝܪ ܢܛܪ ܒܝܬ ܐܤܝܪܐ ܘܚܙܐ ܕܦܬܝܚܝܢ ܬܪܥܐ ܕܒܝܬ ܐܤܝܪܐ ܢܤܒ ܤܦܤܪܐ ܘܒܥܐ ܕܢܩܛܘܠ ܢܦܫܗ ܡܛܠ ܕܤܒܪ ܗܘܐ ܕܥܪܩܘ ܠܗܘܢ ܐܤܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 28,
      "referenceLabel": "Acts 16:28",
      "text": "ܘܩܪܝܗܝ ܦܘܠܘܤ ܒܩܠܐ ܪܡܐ ܘܐܡܪ ܠܗ ܠܐ ܬܥܒܕ ܠܢܦܫܟ ܡܕܡ ܕܒܝܫ ܡܛܠ ܕܟܠܢ ܗܪܟܐ ܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.29",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 29,
      "referenceLabel": "Acts 16:29",
      "text": "ܘܐܢܗܪ ܠܗ ܫܪܓܐ ܘܫܘܪ ܘܥܠ ܟܕ ܪܐܬ ܘܢܦܠ ܥܠ ܪܓܠܝܗܘܢ ܕܦܘܠܘܤ ܘܕܫܝܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.30",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 30,
      "referenceLabel": "Acts 16:30",
      "text": "ܘܐܦܩ ܐܢܘܢ ܠܒܪ ܘܐܡܪ ܗܘܐ ܠܗܘܢ ܡܪܝ ܡܢܐ ܘܠܐ ܠܝ ܠܡܥܒܕ ܐܝܟ ܕܐܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.31",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 31,
      "referenceLabel": "Acts 16:31",
      "text": "ܘܗܢܘܢ ܐܡܪܝܢ ܗܘܘ ܠܗ ܗܝܡܢ ܒܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܘܬܚܐ ܐܢܬ ܘܒܝܬܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.16.32",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 16,
      "verseNumber": 32,
      "referenceLabel": "Acts 16:32",
      "text": "ܘܡܠܠܘ ܥܡܗ ܡܠܬܐ ܕܡܪܝܐ ܘܥܡ ܟܠܗܘܢ ܒܢܝ ܒܝܬܗ ܀",
      "paragraphStart": false
