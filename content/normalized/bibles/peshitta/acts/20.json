{
  "chapter": {
    "id": "peshitta:acts.20",
    "translationId": "peshitta",
    "bookSlug": "acts",
    "chapterNumber": 20,
    "referenceLabel": "Acts 20",
    "summary": "Source text for Acts 20 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.20.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Acts 20:1",
      "text": "ܘܒܬܪ ܕܫܠܝ ܫܓܘܫܝܐ ܩܪܐ ܦܘܠܘܤ ܠܬܠܡܝܕܐ ܘܒܝܐ ܐܢܘܢ ܘܢܫܩ ܐܢܘܢ ܘܢܦܩ ܐܙܠ ܠܗ ܠܡܩܕܘܢܝܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.20.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Acts 20:2",
      "text": "ܘܟܕ ܐܬܟܪܟ ܐܢܘܢ ܠܐܬܪܘܬܐ ܗܠܝܢ ܘܒܝܐ ܐܢܘܢ ܒܡܠܐ ܤܓܝܐܬܐ ܐܬܐ ܠܗ ܠܗܠܤ ܐܬܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Acts 20:3",
      "text": "ܘܗܘܐ ܬܡܢ ܬܠܬܐ ܝܪܚܝܢ ܥܒܕܘ ܕܝܢ ܥܠܘܗܝ ܢܟܠܐ ܝܗܘܕܝܐ ܟܕ ܥܬܝܕ ܗܘܐ ܠܡܐܙܠ ܠܤܘܪܝܐ ܘܐܬܚܫܒ ܕܢܗܦܘܟ ܠܗ ܠܡܩܕܘܢܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Acts 20:4",
      "text": "ܘܢܦܩܘ ܥܡܗ ܥܕܡܐ ܠܐܤܝܐ ܤܘܦܛܪܘܤ ܕܡܢ ܒܪܘܐܐ ܡܕܝܢܬܐ ܘܐܪܤܛܪܟܘܤ ܘܤܩܘܢܕܘܤ ܕܡܢ ܬܤܠܘܢܝܩܐ ܘܓܐܝܘܤ ܕܡܢ ܕܪܒܐ ܡܕܝܢܬܐ ܘܛܝܡܬܐܘܤ ܕܡܢ ܠܘܤܛܪܐ ܘܡܢ ܐܤܝܐ ܛܘܟܝܩܘܤ ܘܛܪܘܦܝܡܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Acts 20:5",
      "text": "ܗܠܝܢ ܐܙܠܘ ܩܕܡܝܢ ܘܩܘܝܘ ܠܢ ܒܛܪܘܐܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Acts 20:6",
      "text": "ܚܢܢ ܕܝܢ ܢܦܩܢ ܡܢ ܦܝܠܝܦܘܤ ܡܕܝܢܬܐ ܕܡܩܕܘܢܝܐ ܒܬܪ ܝܘܡܬܐ ܕܦܛܝܪܐ ܘܪܕܝܢ ܒܝܡܐ ܘܐܬܝܢ ܠܛܪܘܐܤ ܠܝܘܡܬܐ ܚܡܫܐ ܘܗܘܝܢ ܬܡܢ ܝܘܡܬܐ ܫܒܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Acts 20:7",
      "text": "ܘܒܝܘܡܐ ܕܚܕ ܒܫܒܐ ܟܕ ܟܢܝܫܝܢܢ ܕܢܩܨܐ ܐܘܟܪܤܛܝܐ ܡܡܠܠ ܗܘܐ ܥܡܗܘܢ ܦܘܠܘܤ ܡܛܠ ܕܠܝܘܡܐ ܐܚܪܢܐ ܥܬܝܕ ܗܘܐ ܕܢܦܘܩ ܠܗ ܘܐܓܪ ܗܘܐ ܠܡܡܠܠܘ ܥܕܡܐ ܠܦܠܓܗ ܕܠܠܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Acts 20:8",
      "text": "ܘܐܝܬ ܗܘܐ ܬܡܢ ܠܡܦܐܕܐ ܕܢܘܪܐ ܤܓܝܐܐ ܒܥܠܝܬܐ ܗܝ ܕܟܢܝܫܝܢ ܗܘܝܢ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Acts 20:9",
      "text": "ܘܝܬܒ ܗܘܐ ܥܠܝܡܐ ܚܕ ܕܫܡܗ ܗܘܐ ܐܘܛܟܘܤ ܒܟܘܬܐ ܘܫܡܥ ܘܛܒܥ ܒܫܢܬܐ ܝܩܝܪܬܐ ܟܕ ܐܓܪ ܗܘܐ ܒܡܠܬܐ ܦܘܠܘܤ ܘܒܫܢܬܗ ܢܦܠ ܗܘܐ ܡܢ ܬܠܬܐ ܡܕܝܪܝܢ ܘܐܫܬܩܠ ܟܕ ܡܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Acts 20:10",
      "text": "ܘܢܚܬ ܦܘܠܘܤ ܢܦܠ ܠܥܠ ܡܢܗ ܘܥܦܩܗ ܘܐܡܪ ܠܐ ܬܬܙܝܥܘܢ ܡܛܠ ܕܢܦܫܗ ܒܗ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Acts 20:11",
      "text": "ܟܕ ܤܠܩ ܕܝܢ ܩܨܐ ܠܚܡܐ ܘܛܥܡ ܘܗܘܐ ܡܡܠܠ ܥܕܡܐ ܕܤܠܩ ܨܦܪܐ ܘܗܝܕܝܢ ܢܦܩ ܕܢܐܙܠ ܒܝܒܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Acts 20:12",
      "text": "ܘܕܒܪܘܗܝ ܠܥܠܝܡܐ ܟܕ ܚܝ ܘܚܕܝܘ ܒܗ ܪܘܪܒܐܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "Acts 20:13",
      "text": "ܚܢܢ ܕܝܢ ܢܚܬܢ ܠܐܠܦܐ ܘܪܕܝܢ ܠܘܥܕܐ ܕܬܤܘܤ ܡܛܠ ܕܡܢ ܬܡܢ ܥܬܝܕܝܢ ܗܘܝܢ ܕܢܩܒܠܝܘܗܝ ܠܦܘܠܘܤ ܗܟܢܐ ܓܝܪ ܦܩܕ ܗܘܐ ܠܢ ܟܕ ܐܙܠ ܗܘܐ ܗܘ ܒܝܒܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 14,
      "referenceLabel": "Acts 20:14",
      "text": "ܟܕ ܕܝܢ ܩܒܠܢܝܗܝ ܡܢ ܬܤܘܤ ܫܩܠܢܝܗܝ ܒܐܠܦܐ ܘܐܬܝܢ ܠܡܝܛܘܠܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 15,
      "referenceLabel": "Acts 20:15",
      "text": "ܘܡܢ ܬܡܢ ܠܝܘܡܐ ܐܚܪܢܐ ܪܕܝܢ ܠܘܩܒܠ ܟܝܘܤ ܓܙܪܬܐ ܘܬܘܒ ܠܝܘܡܐ ܐܚܪܢܐ ܐܬܝܢ ܠܤܡܘܤ ܘܩܘܝܢ ܒܛܪܘܓܠܝܘܢ ܘܠܝܘܡܐ ܐܚܪܢܐ ܐܬܝܢ ܠܡܝܠܝܛܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 16,
      "referenceLabel": "Acts 20:16",
      "text": "ܦܤܝܩ ܗܘܐ ܠܗ ܓܝܪ ܠܦܘܠܘܤ ܕܢܥܒܪܝܗ ܠܐܦܤܘܤ ܕܠܡܐ ܢܫܬܘܚܪ ܠܗ ܬܡܢ ܡܛܠ ܕܡܤܪܗܒ ܗܘܐ ܕܐܢ ܡܫܟܚܐ ܝܘܡܐ ܕܦܢܛܩܘܤܛܐ ܒܐܘܪܫܠܡ ܢܥܒܕܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 17,
      "referenceLabel": "Acts 20:17",
      "text": "ܘܡܢܗ ܡܢ ܡܝܠܝܛܘܤ ܫܕܪ ܐܝܬܝ ܠܩܫܝܫܐ ܕܥܕܬܐ ܕܐܦܤܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 18,
      "referenceLabel": "Acts 20:18",
      "text": "ܘܟܕ ܐܬܘ ܠܘܬܗ ܐܡܪ ܠܗܘܢ ܐܢܬܘܢ ܝܕܥܝܢ ܐܢܬܘܢ ܕܡܢ ܝܘܡܐ ܩܕܡܝܐ ܕܥܠܬ ܠܐܤܝܐ ܐܝܟܢܐ ܗܘܝܬ ܥܡܟܘܢ ܟܠܗ ܙܒܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 19,
      "referenceLabel": "Acts 20:19",
      "text": "ܟܕ ܦܠܚ ܐܢܐ ܠܐܠܗܐ ܒܡܟܝܟܘܬܐ ܤܓܝܐܬܐ ܘܒܕܡܥܐ ܘܒܢܤܝܘܢܐ ܐܝܠܝܢ ܕܥܕܝܢ ܗܘܘ ܥܠܝ ܒܢܟܠܝܗܘܢ ܕܝܗܘܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 20,
      "referenceLabel": "Acts 20:20",
      "text": "ܘܠܐ ܒܤܝܬ ܒܡܕܡ ܕܦܩܚ ܗܘܐ ܠܢܦܫܬܟܘܢ ܕܐܟܪܙ ܠܟܘܢ ܘܐܠܦ ܒܫܘܩܐ ܘܒܒܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 21,
      "referenceLabel": "Acts 20:21",
      "text": "ܟܕ ܡܤܗܕ ܗܘܝܬ ܠܝܗܘܕܝܐ ܘܠܐܪܡܝܐ ܥܠ ܬܝܒܘܬܐ ܕܠܘܬ ܐܠܗܐ ܘܗܝܡܢܘܬܐ ܕܒܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 22,
      "referenceLabel": "Acts 20:22",
      "text": "ܘܗܫܐ ܐܢܐ ܐܤܝܪ ܐܢܐ ܒܪܘܚܐ ܘܐܙܠ ܐܢܐ ܠܐܘܪܫܠܡ ܘܠܐ ܝܕܥ ܐܢܐ ܡܢܐ ܐܪܥ ܠܝ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 23,
      "referenceLabel": "Acts 20:23",
      "text": "ܒܪܡ ܪܘܚܐ ܕܩܘܕܫܐ ܒܟܠ ܡܕܝܢܐ ܡܤܗܕ ܠܝ ܘܐܡܪ ܕܐܤܘܪܐ ܘܐܘܠܨܢܐ ܥܬܝܕܝܢ ܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 24,
      "referenceLabel": "Acts 20:24",
      "text": "ܐܠܐ ܠܝ ܠܐ ܚܫܝܒܐ ܢܦܫܝ ܡܕܡ ܐܝܟ ܕܐܫܠܡ ܪܗܛܝ ܘܬܫܡܫܬܐ ܕܩܒܠܬ ܡܢ ܡܪܢ ܝܫܘܥ ܕܐܤܗܕ ܥܠ ܤܒܪܬܐ ܕܛܝܒܘܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 25,
      "referenceLabel": "Acts 20:25",
      "text": "ܘܗܫܐ ܐܢܐ ܝܕܥ ܐܢܐ ܕܬܘܒ ܦܪܨܘܦܝ ܠܐ ܚܙܝܢ ܐܢܬܘܢ ܟܠܟܘܢ ܐܝܠܝܢ ܕܐܬܟܪܟܬ ܐܟܪܙܬ ܠܟܘܢ ܡܠܟܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 26,
      "referenceLabel": "Acts 20:26",
      "text": "ܘܡܛܠ ܗܢܐ ܡܤܗܕ ܐܢܐ ܠܟܘܢ ܝܘܡܐ ܕܝܘܡܢܐ ܕܕܟܐ ܐܢܐ ܡܢ ܕܡܐ ܕܟܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 27,
      "referenceLabel": "Acts 20:27",
      "text": "ܠܐ ܓܝܪ ܐܫܬܐܠܬ ܕܐܘܕܥܟܘܢ ܟܠܗ ܨܒܝܢܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 28,
      "referenceLabel": "Acts 20:28",
      "text": "ܐܙܕܗܪܘ ܗܟܝܠ ܒܢܦܫܟܘܢ ܘܒܟܠܗ ܡܪܥܝܬܐ ܗܝ ܕܐܩܝܡܟܘܢ ܒܗ ܪܘܚܐ ܕܩܘܕܫܐ ܐܦܤܩܘܦܐ ܕܬܪܥܘܢ ܠܥܕܬܗ ܕܐܠܗܐ ܗܝ ܕܩܢܗ ܒܕܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.29",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 29,
      "referenceLabel": "Acts 20:29",
      "text": "ܐܢܐ ܝܕܥ ܐܢܐ ܕܡܢ ܒܬܪ ܕܐܙܠ ܐܢܐ ܢܥܠܘܢ ܥܡܟܘܢ ܕܐܒܐ ܬܩܝܦܐ ܕܠܐ ܚܝܤܝܢ ܥܠ ܡܪܥܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.30",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 30,
      "referenceLabel": "Acts 20:30",
      "text": "ܘܐܦ ܡܢܟܘܢ ܕܝܠܟܘܢ ܢܩܘܡܘܢ ܓܒܪܐ ܡܡܠܠܝ ܡܥܩܡܬܐ ܐܝܟ ܕܢܗܦܟܘܢ ܠܬܠܡܝܕܐ ܕܢܐܙܠܘܢ ܒܬܪܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.31",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 31,
      "referenceLabel": "Acts 20:31",
      "text": "ܡܛܠ ܗܢܐ ܗܘܝܬܘܢ ܥܝܪܝܢ ܘܥܗܝܕܝܢ ܕܫܢܝܐ ܬܠܬ ܠܐ ܫܠܝܬ ܒܠܠܝܐ ܘܒܐܝܡܡܐ ܟܕ ܒܕܡܥܐ ܡܪܬܐ ܐܢܐ ܠܐܢܫ ܐܢܫ ܡܢܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.32",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 32,
      "referenceLabel": "Acts 20:32",
      "text": "ܘܗܫܐ ܡܓܥܠ ܐܢܐ ܠܟܘܢ ܠܐܠܗܐ ܘܠܡܠܬܐ ܕܛܝܒܘܬܗ ܕܗܝ ܡܫܟܚܐ ܒܢܝܐ ܠܟܘܢ ܘܝܗܒܐ ܠܟܘܢ ܝܘܪܬܢܐ ܥܡ ܟܠܗܘܢ ܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.33",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 20,
      "verseNumber": 33,
      "referenceLabel": "Acts 20:33",
      "text": "ܟܤܦܐ ܐܘ ܕܗܒܐ ܐܘ ܢܚܬܐ ܠܐ ܪܓܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.20.34",
