{
  "chapter": {
    "id": "peshitta:acts.27",
    "translationId": "peshitta",
    "bookSlug": "acts",
    "chapterNumber": 27,
    "referenceLabel": "Acts 27",
    "summary": "Source text for Acts 27 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.27.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 1,
      "referenceLabel": "Acts 27:1",
      "text": "ܘܦܩܕ ܥܠܘܗܝ ܦܗܤܛܤ ܕܢܫܬܕܪ ܠܘܬ ܩܤܪ ܠܐܝܛܠܝܐ ܘܐܫܠܡܗ ܠܦܘܠܘܤ ܘܠܐܤܝܪܐ ܐܚܪܢܐ ܥܡܗ ܠܓܒܪܐ ܚܕ ܩܢܛܪܘܢܐ ܡܢ ܐܤܦܝܪ ܤܒܤܛܐ ܕܫܡܗ ܗܘܐ ܝܘܠܝܘܤ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.27.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 2,
      "referenceLabel": "Acts 27:2",
      "text": "ܘܟܕ ܗܘܬ ܕܢܪܕܐ ܢܚܬܢ ܠܐܠܦܐ ܕܐܝܬܝܗ ܗܘܬ ܡܢ ܐܕܪܡܢܛܘܤ ܡܕܝܢܬܐ ܘܐܙܠܐ ܗܘܬ ܠܐܬܪܐ ܕܐܤܝܐ ܘܥܠ ܗܘܐ ܥܡܢ ܠܐܠܦܐ ܐܪܤܛܪܟܘܤ ܡܩܕܘܢܝܐ ܕܡܢ ܬܤܠܘܢܝܩܐ ܡܕܝܢܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 3,
      "referenceLabel": "Acts 27:3",
      "text": "ܘܠܝܘܡܐ ܐܚܪܢܐ ܡܛܝܢ ܠܨܝܕܢ ܘܐܬܚܫܚ ܩܢܛܪܘܢܐ ܒܡܪܚܡܢܘܬܐ ܠܘܬ ܦܘܠܘܤ ܘܐܦܤ ܠܗ ܕܢܐܙܠ ܠܘܬ ܪܚܡܘܗܝ ܘܢܬܬܢܝܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 4,
      "referenceLabel": "Acts 27:4",
      "text": "ܘܡܢ ܬܡܢ ܪܕܝܢ ܘܡܛܠ ܕܪܘܚܐ ܤܩܘܒܠܢ ܗܘܝ ܐܬܟܪܟܢ ܥܠ ܩܘܦܪܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 5,
      "referenceLabel": "Acts 27:5",
      "text": "ܘܥܒܪܢ ܝܡܐ ܕܩܝܠܝܩܝܐ ܘܕܦܡܦܘܠܝܐ ܘܡܛܝܢ ܠܡܘܪܐ ܡܕܝܢܬܐ ܕܠܘܩܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 6,
      "referenceLabel": "Acts 27:6",
      "text": "ܘܐܫܟܚ ܬܡܢ ܩܢܛܪܘܢܐ ܐܠܦܐ ܡܢ ܐܠܟܤܢܕܪܝܐ ܕܐܙܠܐ ܗܘܬ ܠܐܝܛܠܝܐ ܘܐܘܬܒܢ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 7,
      "referenceLabel": "Acts 27:7",
      "text": "ܘܡܛܠ ܕܝܩܝܪܐܝܬ ܪܕܝܐ ܗܘܬ ܠܝܘܡܬܐ ܤܓܝܐܐ ܠܡܚܤܢ ܡܛܝܢ ܠܘܩܒܠ ܩܢܝܕܘܤ ܓܙܪܬܐ ܘܡܛܠ ܕܠܐ ܫܒܩܐ ܗܘܬ ܪܘܚܐ ܕܢܐܙܠ ܬܪܝܨܐܝܬ ܐܬܟܪܟܢ ܥܠ ܩܪܛܐ ܠܘܩܒܠ ܤܠܡܘܢܐ ܡܕܝܢܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 8,
      "referenceLabel": "Acts 27:8",
      "text": "ܘܠܡܚܤܢ ܟܕ ܪܕܝܢܢ ܚܕܪܝܗ ܡܛܝܢ ܠܕܘܟܬܐ ܕܡܬܩܪܝܐ ܠܡܐܢܐ ܫܦܝܪܐ ܘܩܪܝܒܐ ܗܘܬ ܠܗ ܡܕܝܢܬܐ ܕܫܡܗ ܠܐܤܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 9,
      "referenceLabel": "Acts 27:9",
      "text": "ܘܗܘܝܢ ܬܡܢ ܙܒܢܐ ܤܓܝܐܐ ܥܕܡܐ ܕܥܒܪ ܐܦ ܝܘܡܐ ܕܨܘܡܐ ܕܝܗܘܕܝܐ ܘܗܘܐ ܠܗ ܩܢܛܐ ܕܢܪܕܐ ܐܢܫ ܒܝܡܐ ܘܡܠܟ ܗܘܐ ܠܗܘܢ ܦܘܠܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 10,
      "referenceLabel": "Acts 27:10",
      "text": "ܘܐܡܪ ܓܒܪܐ ܚܙܐ ܐܢܐ ܕܒܐܘܠܨܢܐ ܘܒܚܘܤܪܢܐ ܤܓܝܐܐ ܗܘܝܐ ܡܪܕܝܬܢ ܠܘ ܒܠܚܘܕ ܕܡܘܒܠܗ ܕܐܠܦܢ ܐܠܐ ܐܦ ܕܢܦܫܬܢ ܕܝܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 11,
      "referenceLabel": "Acts 27:11",
      "text": "ܩܢܛܪܘܢܐ ܕܝܢ ܠܩܘܒܪܢܛܐ ܘܠܡܪܗ ܕܐܠܦܐ ܫܡܥ ܗܘܐ ܝܬܝܪ ܡܢ ܡܠܘܗܝ ܕܦܘܠܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 12,
      "referenceLabel": "Acts 27:12",
      "text": "ܘܡܛܠ ܕܠܐ ܥܗܢ ܗܘܐ ܗܘ ܠܡܐܢܐ ܠܡܤܬܝܘ ܒܗ ܤܬܘܐ ܤܓܝܐܐ ܡܢܢ ܨܒܝܢ ܗܘܘ ܕܢܪܕܐ ܡܢ ܬܡܢ ܘܐܢܗܘ ܕܡܫܟܚܝܢ ܕܢܡܢܥܘܢ ܘܢܤܬܘܢ ܒܠܡܐܢܐ ܚܕ ܕܐܝܬܘܗܝ ܗܘܐ ܒܩܪܛܐ ܘܡܬܩܪܐ ܗܘܐ ܦܘܢܟܤ ܘܚܐܪ ܗܘܐ ܠܬܝܡܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 13,
      "referenceLabel": "Acts 27:13",
      "text": "ܘܟܕ ܢܫܒܬ ܪܘܚܐ ܕܬܝܡܢܐ ܘܤܒܪܘ ܕܡܡܛܝܢ ܐܝܟ ܨܒܝܢܗܘܢ ܪܕܝܢ ܗܘܘ ܚܕܪܝ ܩܪܛܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 14,
      "referenceLabel": "Acts 27:14",
      "text": "ܘܡܢ ܒܬܪ ܩܠܝܠ ܢܦܩ ܥܠܝܢ ܡܫܒܐ ܕܥܠܥܠܐ ܕܡܬܩܪܐ ܛܘܦܢܝܩܘܤ ܐܘܪܩܠܝܕܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 15,
      "referenceLabel": "Acts 27:15",
      "text": "ܘܐܬܚܛܦܬ ܐܠܦܐ ܘܠܐ ܐܫܟܚܬ ܕܬܩܘܡ ܠܘܩܒܠ ܪܘܚܐ ܘܝܗܒܢ ܠܐܝܕܐ ܕܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 16,
      "referenceLabel": "Acts 27:16",
      "text": "ܘܟܕ ܥܒܪܢ ܓܙܪܬܐ ܚܕܐ ܕܡܬܩܪܝܐ ܩܘܕܐ ܠܡܚܤܢ ܐܫܟܚܢ ܐܚܕܢ ܠܩܪܩܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 17,
      "referenceLabel": "Acts 27:17",
      "text": "ܘܟܕ ܫܩܠܢܗ ܡܚܝܨܝܢ ܗܘܝܢ ܘܡܬܩܢܝܢ ܠܗ ܠܐܠܦܐ ܘܡܛܠ ܕܕܚܠܝܢ ܗܘܝܢ ܕܕܠܡܐ ܢܦܠ ܒܡܚܬܬܗ ܕܝܡܐ ܐܚܬܢܝܗܝ ܠܐܪܡܢܘܢ ܘܗܟܘܬ ܪܕܝܢ ܗܘܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 18,
      "referenceLabel": "Acts 27:18",
      "text": "ܘܟܕ ܩܡ ܠܗ ܥܠܝܢ ܟܝܡܘܢܐ ܩܫܝܐ ܠܝܘܡܐ ܐܚܪܢܐ ܫܕܝܢ ܡܐܢܝܢ ܒܝܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 19,
      "referenceLabel": "Acts 27:19",
      "text": "ܘܠܝܘܡܐ ܕܬܠܬܐ ܡܐܢܐ ܕܝܠܗ ܕܐܠܦܐ ܒܐܝܕܝܢ ܫܕܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 20,
      "referenceLabel": "Acts 27:20",
      "text": "ܘܟܕ ܐܚܕ ܠܗ ܤܬܘܐ ܝܘܡܬܐ ܝܬܝܪܐ ܘܠܐ ܫܡܫܐ ܡܬܚܙܐ ܗܘܐ ܘܠܐ ܤܗܪܐ ܘܠܐ ܟܘܟܒܐ ܤܒܪܐ ܕܚܝܝܢ ܟܠ ܟܠܗ ܐܬܦܤܩ ܗܘܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 21,
      "referenceLabel": "Acts 27:21",
      "text": "ܘܟܕ ܐܢܫ ܡܕܡ ܠܐ ܡܤܬܝܒܪ ܗܘܐ ܗܝܕܝܢ ܩܡ ܦܘܠܘܤ ܒܝܢܬܗܘܢ ܘܐܡܪ ܐܠܘ ܐܬܛܦܝܤܬܘܢ ܠܝ ܓܒܪܐ ܠܐ ܪܕܝܢ ܗܘܝܢ ܡܢ ܩܪܛܐ ܘܡܬܚܤܟܝܢ ܗܘܝܢ ܡܢ ܚܘܤܪܢܐ ܘܡܢ ܐܘܠܨܢܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 22,
      "referenceLabel": "Acts 27:22",
      "text": "ܘܗܫܐ ܡܠܟ ܐܢܐ ܕܬܗܘܘܢ ܕܠܐ ܥܩܐ ܢܦܫܐ ܓܝܪ ܡܢܟܘܢ ܚܕܐ ܠܐ ܐܒܕܐ ܐܠܐ ܐܢ ܐܠܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 23,
      "referenceLabel": "Acts 27:23",
      "text": "ܐܬܚܙܝ ܠܝ ܓܝܪ ܒܠܠܝܐ ܗܢܐ ܡܠܐܟܗ ܕܐܠܗܐ ܗܘ ܕܕܝܠܗ ܐܢܐ ܘܠܗ ܦܠܚ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 24,
      "referenceLabel": "Acts 27:24",
      "text": "ܘܐܡܪ ܠܝ ܠܐ ܬܕܚܠ ܦܘܠܐ ܥܬܝܕ ܗܘ ܠܟ ܠܡܩܡ ܩܕܡ ܩܤܪ ܘܗܐ ܝܗܒ ܠܟ ܐܠܗܐ ܡܘܗܒܬܐ ܠܟܠ ܕܪܕܝܢ ܥܡܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 25,
      "referenceLabel": "Acts 27:25",
      "text": "ܡܛܠ ܗܢܐ ܐܬܠܒܒܘ ܓܒܪܐ ܡܗܝܡܢ ܐܢܐ ܓܝܪ ܒܐܠܗܐ ܕܗܟܢܐ ܗܘܐ ܐܝܟ ܡܐ ܕܐܬܡܠܠ ܥܡܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 26,
      "referenceLabel": "Acts 27:26",
      "text": "ܒܪܡ ܠܓܙܪܬܐ ܚܕܐ ܐܝܬ ܠܢ ܕܢܫܬܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 27,
      "referenceLabel": "Acts 27:27",
      "text": "ܘܡܢ ܒܬܪ ܐܪܒܬܥܤܪ ܝܘܡܝܢ ܕܛܥܝܢ ܘܐܬܛܪܦܢ ܒܗܕܪܝܘܤ ܝܡܐ ܒܦܠܓܗ ܕܠܠܝܐ ܤܒܪܘ ܡܠܚܐ ܕܠܐܪܥܐ ܡܬܩܪܒܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 28,
      "referenceLabel": "Acts 27:28",
      "text": "ܘܐܪܡܝܘ ܐܘܩܝܢܤ ܘܐܫܟܚܘ ܩܘܡܝܢ ܥܤܪܝܢ ܘܬܘܒ ܩܠܝܠ ܪܕܘ ܘܐܫܟܚܘ ܩܘܡܝܢ ܚܡܫܥܤܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.29",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 29,
      "referenceLabel": "Acts 27:29",
      "text": "ܘܟܕ ܕܚܝܠܝܢ ܗܘܝܢ ܕܠܡܐ ܢܫܬܟܚ ܠܢ ܒܕܘܟܝܬܐ ܕܐܝܬ ܒܗܝܢ ܫܘܥܐ ܐܪܡܝܘ ܡܢ ܚܪܬܗ ܕܐܠܦܐ ܐܘܩܝܢܤ ܐܪܒܥ ܘܡܨܠܝܢ ܗܘܘ ܕܢܗܘܐ ܝܘܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.30",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 30,
      "referenceLabel": "Acts 27:30",
      "text": "ܡܠܚܐ ܕܝܢ ܒܥܘ ܠܡܥܪܩ ܡܢܗ ܡܢ ܐܠܦܐ ܘܐܚܬܘ ܡܢܗ ܠܩܪܩܘܪܐ ܠܝܡܐ ܒܥܠܬܐ ܕܢܐܙܠܘܢ ܒܗ ܘܢܐܤܪܘܢܗ ܠܐܠܦܐ ܒܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.31",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 31,
      "referenceLabel": "Acts 27:31",
      "text": "ܘܟܕ ܚܙܐ ܦܘܠܘܤ ܐܡܪ ܠܩܢܛܪܘܢܐ ܘܠܐܤܛܪܛܝܘܛܐ ܕܐܢ ܗܠܝܢ ܒܐܠܦܐ ܠܐ ܡܟܬܪܝܢ ܐܢܬܘܢ ܠܐ ܡܫܟܚܝܢ ܐܢܬܘܢ ܕܬܚܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.32",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 32,
      "referenceLabel": "Acts 27:32",
      "text": "ܗܝܕܝܢ ܦܤܩܘ ܐܤܛܪܛܝܘܛܐ ܠܚܒܠܝܗ ܕܩܪܩܘܪܐ ܡܢ ܐܠܦܐ ܘܫܒܩܘܗ ܛܥܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.27.33",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 27,
      "verseNumber": 33,
      "referenceLabel": "Acts 27:33",
      "text": "ܗܘ ܕܝܢ ܦܘܠܘܤ ܥܕܡܐ ܕܗܘܐ ܨܦܪܐ ܡܦܝܤ ܗܘܐ ܠܟܠܗܘܢ ܕܢܩܒܠܘܢ ܤܝܒܪܬܐ ܟܕ ܐܡܪ ܠܗܘܢ ܝܘܡܢܐ ܗܐ ܐܪܒܬܥܤܪ ܝܘܡܝܢ ܡܢ ܩܢܛܐ ܡܕܡ ܠܐ ܛܥܝܡ ܠܟܘܢ ܀",
