{
  "chapter": {
    "id": "peshitta:acts.14",
    "translationId": "peshitta",
    "bookSlug": "acts",
    "chapterNumber": 14,
    "referenceLabel": "Acts 14",
    "summary": "Source text for Acts 14 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.14.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Acts 14:1",
      "text": "ܘܐܬܘ ܘܥܠܘ ܠܗܘܢ ܠܟܢܘܫܬܐ ܕܝܗܘܕܝܐ ܘܗܟܢܐ ܡܠܠܘ ܥܡܗܘܢ ܐܝܟ ܕܢܗܝܡܢܘܢ ܤܓܝܐܐ ܡܢ ܝܗܘܕܝܐ ܘܡܢ ܝܘܢܝܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.14.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Acts 14:2",
      "text": "ܝܗܘܕܝܐ ܕܝܢ ܐܝܠܝܢ ܕܠܐ ܡܬܛܦܝܤܝܢ ܗܘܘ ܓܪܓܘ ܠܥܡܡܐ ܕܢܒܐܫܘܢ ܠܗܘܢ ܠܐܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Acts 14:3",
      "text": "ܘܗܢܘܢ ܙܒܢܐ ܤܓܝܐܐ ܗܘܘ ܬܡܢ ܘܥܝܢ ܒܓܠܐ ܡܡܠܠܝܢ ܗܘܘ ܥܠ ܡܪܝܐ ܘܗܘ ܡܤܗܕ ܗܘܐ ܥܠ ܡܠܬܐ ܕܛܝܒܘܬܗ ܒܐܬܘܬܐ ܘܒܬܕܡܪܬܐ ܕܥܒܕ ܗܘܐ ܒܐܝܕܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Acts 14:4",
      "text": "ܘܟܠܗ ܟܢܫܐ ܕܡܕܝܢܬܐ ܦܠܝܓ ܗܘܐ ܡܢܗܘܢ ܐܝܬ ܗܘܘ ܥܡ ܝܗܘܕܝܐ ܘܡܢܗܘܢ ܢܩܝܦܝܢ ܗܘܘ ܠܫܠܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Acts 14:5",
      "text": "ܗܘܐ ܕܝܢ ܥܠܝܗܘܢ ܓܙܡܐ ܡܢ ܥܡܡܐ ܘܡܢ ܝܗܘܕܝܐ ܘܪܫܢܝܗܘܢ ܕܢܨܥܪܘܢ ܐܢܘܢ ܘܢܪܓܡܘܢ ܐܢܘܢ ܒܟܐܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Acts 14:6",
      "text": "ܘܟܕ ܝܕܥܘ ܫܢܝܘ ܘܐܬܓܘܤܘ ܒܡܕܝܢܬܐ ܕܠܘܩܢܝܐ ܠܘܤܛܪܐ ܘܕܪܒܐ ܘܩܘܪܝܐ ܕܚܕܪܝܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Acts 14:7",
      "text": "ܘܬܡܢ ܡܤܒܪܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Acts 14:8",
      "text": "ܘܓܒܪܐ ܚܕ ܝܬܒ ܗܘܐ ܒܠܘܤܛܪܐ ܡܕܝܢܬܐ ܕܤܓܝܦ ܗܘܐ ܒܪܓܠܘܗܝ ܚܓܝܪܐ ܕܡܢ ܟܪܤ ܐܡܗ ܕܡܡܬܘܡ ܠܐ ܗܠܟ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Acts 14:9",
      "text": "ܗܢܐ ܫܡܥ ܠܦܘܠܘܤ ܕܡܡܠܠ ܘܟܕ ܚܙܝܗܝ ܦܘܠܘܤ ܘܐܫܬܘܕܥ ܕܐܝܬ ܒܗ ܗܝܡܢܘܬܐ ܕܢܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Acts 14:10",
      "text": "ܐܡܪ ܠܗ ܒܩܠܐ ܪܡܐ ܠܟ ܐܡܪ ܐܢܐ ܒܫܡܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܩܘܡ ܥܠ ܪܓܠܝܟ ܘܫܘܪ ܩܡ ܘܗܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Acts 14:11",
      "text": "ܘܟܢܫܐ ܕܥܡܐ ܟܕ ܚܙܘ ܡܕܡ ܕܥܒܕ ܦܘܠܘܤ ܐܪܝܡܘ ܩܠܗܘܢ ܒܠܫܢܗ ܕܐܬܪܐ ܘܐܡܪܝܢ ܐܠܗܐ ܐܬܕܡܝܘ ܒܒܢܝ ܐܢܫܐ ܘܢܚܬܘ ܠܘܬܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Acts 14:12",
      "text": "ܘܫܡܝܘ ܗܘܘ ܠܒܪܢܒܐ ܡܪܐ ܐܠܗܐ ܘܠܦܘܠܘܤ ܗܪܡܝܤ ܡܛܠ ܕܗܘ ܡܫܪܐ ܗܘܐ ܒܡܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Acts 14:13",
      "text": "ܘܟܘܡܪܐ ܕܡܪܐ ܐܠܗܐ ܗܘ ܕܐܝܬ ܗܘܐ ܠܒܪ ܡܢ ܡܕܝܢܬܐ ܐܝܬܝ ܬܘܪܐ ܘܟܠܝܠܐ ܠܬܪܥܐ ܕܕܪܬܐ ܐܬܪ ܕܫܪܝܢ ܗܘܘ ܘܨܒܐ ܗܘܐ ܕܢܕܒܚ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Acts 14:14",
      "text": "ܒܪܢܒܐ ܕܝܢ ܘܦܘܠܘܤ ܟܕ ܫܡܥܘ ܤܕܩܘ ܢܚܬܝܗܘܢ ܘܫܘܪܘ ܘܢܦܩܘ ܠܗܘܢ ܠܘܬ ܐܟܠܘܤ ܘܩܥܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Acts 14:15",
      "text": "ܘܐܡܪܝܢ ܓܒܪܐ ܡܢܐ ܥܒܕܝܢ ܐܢܬܘܢ ܐܦ ܚܢܢ ܒܢܝܢܫܐ ܚܢܢ ܚܫܘܫܐ ܐܟܘܬܟܘܢ ܕܡܤܒܪܝܢܢ ܠܟܘܢ ܕܡܢ ܗܠܝܢ ܒܛܠܬܐ ܬܬܦܢܘܢ ܠܘܬ ܐܠܗܐ ܚܝܐ ܗܘ ܕܥܒܕ ܫܡܝܐ ܘܐܪܥܐ ܘܝܡܡܐ ܘܟܠ ܕܐܝܬ ܒܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Acts 14:16",
      "text": "ܗܘ ܕܒܕܪܐ ܩܕܡܝܐ ܫܒܩ ܗܘܐ ܐܢܘܢ ܠܟܠܗܘܢ ܥܡܡܐ ܕܢܐܙܠܘܢ ܒܐܘܪܚܬܐ ܕܢܦܫܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Acts 14:17",
      "text": "ܟܕ ܠܐ ܫܒܩ ܢܦܫܗ ܕܠܐ ܤܗܕܘ ܒܕܥܒܕ ܗܘܐ ܠܗܘܢ ܛܒܬܐ ܡܢ ܫܡܝܐ ܘܡܚܬ ܗܘܐ ܠܗܘܢ ܡܛܪܐ ܘܡܪܒܐ ܗܘܐ ܦܐܪܐ ܒܙܒܢܝܗܘܢ ܘܡܠܐ ܗܘܐ ܬܘܪܤܝܐ ܘܒܤܝܡܘܬܐ ܠܒܘܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Acts 14:18",
      "text": "ܘܟܕ ܗܠܝܢ ܐܡܪܝܢ ܗܘܘ ܡܢ ܡܚܤܢ ܟܠܘ ܠܥܡܐ ܕܐܢܫ ܠܐ ܢܕܒܚ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Acts 14:19",
      "text": "ܐܬܘ ܕܝܢ ܠܬܡܢ ܝܗܘܕܝܐ ܡܢ ܐܝܩܢܘܢ ܘܡܢ ܐܢܛܝܟܝܐ ܘܫܓܫܘ ܥܠܝܗܘܢ ܠܥܡܐ ܘܪܓܡܘܗܝ ܠܦܘܠܘܤ ܘܓܪܘܗܝ ܠܒܪ ܡܢ ܡܕܝܢܬܐ ܡܛܠ ܕܤܒܪܝܢ ܗܘܘ ܕܡܝܬ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Acts 14:20",
      "text": "ܘܟܢܫܘ ܥܠܘܗܝ ܬܠܡܝܕܐ ܘܩܡ ܥܠ ܠܡܕܝܢܬܐ ܘܠܝܘܡܐ ܐܚܪܢܐ ܢܦܩ ܠܗ ܡܢ ܬܡܢ ܥܡ ܒܪܢܒܐ ܘܐܬܘ ܠܕܪܒܐ ܡܕܝܢܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Acts 14:21",
      "text": "ܘܟܕ ܡܤܒܪܝܢ ܗܘܘ ܠܒܢܝ ܡܕܝܢܬܐ ܗܝ ܬܠܡܕܘ ܗܘܘ ܠܤܓܝܐܐ ܘܗܦܟܘ ܐܬܘ ܠܗܘܢ ܠܠܘܤܛܪܐ ܡܕܝܢܬܐ ܘܠܐܝܩܢܘܢ ܘܠܐܢܛܝܟܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Acts 14:22",
      "text": "ܟܕ ܡܫܪܪܝܢ ܗܘܘ ܢܦܫܬܗܘܢ ܕܬܠܡܝܕܐ ܘܒܥܝܢ ܗܘܘ ܡܢܗܘܢ ܕܢܩܘܘܢ ܒܗܝܡܢܘܬܐ ܘܐܡܪܝܢ ܗܘܘ ܠܗܘܢ ܕܒܐܘܠܨܢܐ ܤܓܝܐܐ ܘܠܐ ܠܡܥܠ ܠܡܠܟܘܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Acts 14:23",
      "text": "ܘܐܩܝܡܘ ܠܗܘܢ ܒܟܠ ܥܕܬܐ ܩܫܝܫܐ ܟܕ ܨܝܡܝܢ ܗܘܘ ܥܡܗܘܢ ܘܡܨܠܝܢ ܘܡܓܥܠܝܢ ܗܘܘ ܠܗܘܢ ܠܡܪܢ ܗܘ ܕܗܝܡܢܘ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Acts 14:24",
      "text": "ܘܟܕ ܐܬܟܪܟܘ ܒܐܬܪܐ ܕܦܝܤܝܕܝܐ ܐܬܘ ܠܗܘܢ ܠܦܡܦܘܠܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Acts 14:25",
      "text": "ܘܟܕ ܡܠܠܘ ܒܦܪܓܐ ܡܕܝܢܬܐ ܡܠܬܐ ܕܡܪܝܐ ܢܚܬܘ ܠܗܘܢ ܠܐܝܛܠܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Acts 14:26",
      "text": "ܘܡܢ ܬܡܢ ܪܕܘ ܒܝܡܐ ܘܐܬܘ ܠܗܘܢ ܠܐܢܛܝܟܝܐ ܡܛܠ ܕܡܢ ܬܡܢ ܡܓܥܠܝܢ ܗܘܘ ܠܛܝܒܘܬܗ ܕܡܪܝܐ ܠܥܒܕܐ ܗܘ ܕܫܠܡܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Acts 14:27",
      "text": "ܘܟܕ ܟܢܫܘ ܟܠܗ ܥܕܬܐ ܡܫܬܥܝܢ ܗܘܘ ܟܠܡܕܡ ܕܥܒܕ ܥܡܗܘܢ ܐܠܗܐ ܘܕܦܬܚ ܬܪܥܐ ܕܗܝܡܢܘܬܐ ܠܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.14.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "Acts 14:28",
      "text": "ܘܙܒܢܐ ܤܓܝܐܐ ܗܘܘ ܬܡܢ ܠܘܬ ܬܠܡܝܕܐ ܀",
      "paragraphStart": false
    }
  ]
}
