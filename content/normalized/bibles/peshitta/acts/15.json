  },
  "verses": [
    {
      "id": "peshitta:acts.15.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Acts 15:1",
      "text": "ܢܚܬܘ ܗܘܘ ܕܝܢ ܐܢܫܐ ܡܢ ܝܗܘܕ ܘܡܠܦܝܢ ܗܘܘ ܠܗܘܢ ܠܐܚܐ ܕܐܢ ܗܘ ܕܠܐ ܓܙܪܝܢ ܐܢܬܘܢ ܒܥܝܕܐ ܕܢܡܘܤܐ ܠܐ ܡܫܟܚܝܢ ܐܢܬܘܢ ܠܡܚܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.15.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Acts 15:2",
      "text": "ܘܗܘܐ ܫܓܘܫܝܐ ܤܓܝܐܐ ܘܒܥܬܐ ܠܦܘܠܘܤ ܘܠܒܪܢܒܐ ܥܡܗܘܢ ܘܗܘܬ ܕܢܤܩܘܢ ܦܘܠܘܤ ܘܒܪܢܒܐ ܘܐܚܪܢܐ ܥܡܗܘܢ ܠܘܬ ܫܠܝܚܐ ܘܩܫܝܫܐ ܕܒܐܘܪܫܠܡ ܡܛܠ ܗܕܐ ܒܥܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Acts 15:3",
      "text": "ܘܠܘܝܬ ܫܕܪܬ ܐܢܘܢ ܥܕܬܐ ܘܪܕܝܢ ܗܘܘ ܒܟܠܗ ܦܘܢܝܩܐ ܘܐܦ ܒܝܬ ܫܡܪܝܐ ܟܕ ܡܫܬܥܝܢ ܗܘܘ ܥܠ ܦܘܢܝܐ ܕܥܡܡܐ ܘܥܒܕܝܢ ܗܘܘ ܚܕܘܬܐ ܪܒܬܐ ܠܟܠܗܘܢ ܐܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Acts 15:4",
      "text": "ܘܟܕ ܐܬܘ ܠܐܘܪܫܠܡ ܐܬܩܒܠܘ ܡܢ ܥܕܬܐ ܘܡܢ ܫܠܝܚܐ ܘܡܢ ܩܫܝܫܐ ܘܐܫܬܥܝܘ ܠܗܘܢ ܟܠ ܡܐ ܕܥܒܕ ܥܡܗܘܢ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Acts 15:5",
      "text": "ܩܡܘ ܗܘܘ ܕܝܢ ܐܢܫܐ ܐܝܠܝܢ ܕܗܝܡܢܘ ܗܘܘ ܡܢ ܝܘܠܦܢܐ ܕܦܪܝܫܐ ܘܐܡܪܝܢ ܕܘܠܐ ܗܘ ܠܟܘܢ ܠܡܓܙܪ ܐܢܘܢ ܘܬܦܩܕܘܢ ܐܢܘܢ ܕܢܛܪܘܢ ܢܡܘܤܐ ܕܡܘܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Acts 15:6",
      "text": "ܐܬܟܢܫܘ ܕܝܢ ܫܠܝܚܐ ܘܩܫܝܫܐ ܕܢܚܙܘܢ ܥܠ ܡܠܬܐ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Acts 15:7",
      "text": "ܘܟܕ ܗܘܬ ܒܥܬܐ ܤܓܝܐܬܐ ܩܡ ܫܡܥܘܢ ܘܐܡܪ ܠܗܘܢ ܓܒܪܐ ܐܚܝܢ ܐܢܬܘܢ ܝܕܥܝܢ ܐܢܬܘܢ ܕܡܢ ܝܘܡܬܐ ܩܕܡܝܐ ܡܢ ܦܘܡܝ ܕܝܠܝ ܓܒܐ ܐܠܗܐ ܕܢܫܡܥܘܢ ܥܡܡܐ ܡܠܬܐ ܕܤܒܪܬܐ ܘܢܗܝܡܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Acts 15:8",
      "text": "ܘܐܠܗܐ ܕܝܕܥ ܕܒܠܒܘܬܐ ܐܤܗܕ ܥܠܝܗܘܢ ܘܝܗܒ ܠܗܘܢ ܪܘܚܐ ܕܩܘܕܫܐ ܐܝܟ ܕܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Acts 15:9",
      "text": "ܘܡܕܡ ܠܐ ܦܪܫ ܒܝܢܝܢ ܘܠܗܘܢ ܡܛܠ ܕܕܟܝ ܒܗܝܡܢܘܬܐ ܠܒܘܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Acts 15:10",
      "text": "ܘܗܫܐ ܐܢܬܘܢ ܡܢܐ ܡܢܤܝܢ ܐܢܬܘܢ ܠܐܠܗܐ ܐܝܟ ܕܬܤܝܡܘܢ ܢܝܪܐ ܥܠ ܨܘܪܝܗܘܢ ܕܬܠܡܝܕܐ ܐܝܢܐ ܕܐܦܠܐ ܐܒܗܬܢ ܐܦܠܐ ܚܢܢ ܐܫܟܚܢ ܠܡܛܥܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Acts 15:11",
      "text": "ܐܠܐ ܒܛܝܒܘܬܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܡܗܝܡܢܝܢܢ ܕܢܚܐ ܐܟܘܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Acts 15:12",
      "text": "ܘܫܬܩܘ ܟܠܗ ܟܢܫܐ ܘܫܡܥܝܢ ܗܘܘ ܠܦܘܠܘܤ ܘܠܒܪܢܒܐ ܕܡܫܬܥܝܢ ܗܘܘ ܟܠ ܡܐ ܕܥܒܕ ܐܠܗܐ ܒܐܝܕܝܗܘܢ ܐܬܘܬܐ ܘܓܒܪܘܬܐ ܒܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Acts 15:13",
      "text": "ܘܒܬܪ ܕܫܬܩܘ ܩܡ ܝܥܩܘܒ ܘܐܡܪ ܓܒܪܐ ܐܚܝܢ ܫܘܡܥܘܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Acts 15:14",
      "text": "ܫܡܥܘܢ ܐܫܬܥܝ ܠܟܘܢ ܐܝܟܢܐ ܫܪܝ ܐܠܗܐ ܠܡܓܒܐ ܡܢ ܥܡܡܐ ܥܡܐ ܠܫܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Acts 15:15",
      "text": "ܘܠܗܕܐ ܫܠܡܢ ܡܠܝܗܘܢ ܕܢܒܝܐ ܐܝܟ ܡܐ ܕܟܬܝܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Acts 15:16",
      "text": "ܕܡܢ ܒܬܪ ܗܠܝܢ ܐܗܦܘܟ ܘܐܩܝܡ ܡܫܟܢܗ ܕܕܘܝܕ ܐܝܢܐ ܕܢܦܠ ܘܐܒܢܐ ܡܕܡ ܕܢܦܠ ܡܢܗ ܘܐܩܝܡܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Acts 15:17",
      "text": "ܐܝܟ ܕܢܒܥܘܢ ܫܪܟܗܘܢ ܕܒܢܝܢܫܐ ܠܡܪܝܐ ܘܟܠܗܘܢ ܥܡܡܐ ܐܝܠܝܢ ܕܐܬܩܪܝ ܫܡܝ ܥܠܝܗܘܢ ܐܡܪ ܡܪܝܐ ܕܥܒܕ ܗܠܝܢ ܟܠܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Acts 15:18",
      "text": "ܝܕܝܥܝܢ ܡܢ ܥܠܡ ܥܒܕܘܗܝ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Acts 15:19",
      "text": "ܡܛܠ ܗܕܐ ܐܢܐ ܐܡܪ ܐܢܐ ܕܠܐ ܢܗܘܘܢ ܫܚܩܝܢ ܠܐܝܠܝܢ ܕܡܢ ܥܡܡܐ ܡܬܦܢܝܢ ܠܘܬ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Acts 15:20",
      "text": "ܐܠܐ ܢܫܬܠܚ ܠܗܘܢ ܕܢܗܘܘܢ ܦܪܝܩܝܢ ܡܢ ܛܡܐܘܬܐ ܕܕܒܝܚܐ ܘܡܢ ܙܢܝܘܬܐ ܘܡܢ ܕܚܢܝܩܐ ܘܡܢ ܕܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Acts 15:21",
      "text": "ܡܘܫܐ ܓܝܪ ܡܢ ܕܪܐ ܩܕܡܝܐ ܒܟܠ ܡܕܝܢܐ ܐܝܬ ܗܘܐ ܠܗ ܟܪܘܙܐ ܒܟܢܘܫܬܐ ܕܒܟܠ ܫܒܝܢ ܩܪܝܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Acts 15:22",
      "text": "ܗܝܕܝܢ ܫܠܝܚܐ ܘܩܫܝܫܐ ܥܡ ܟܠܗ ܥܕܬܐ ܓܒܘ ܓܒܪܐ ܡܢܗܘܢ ܘܫܕܪܘ ܠܐܢܛܝܘܟܝ ܥܡ ܦܘܠܘܤ ܘܒܪܢܒܐ ܠܝܗܘܕܐ ܕܡܬܩܪܐ ܒܪ ܫܒܐ ܘܠܫܝܠܐ ܓܒܪܐ ܕܪܫܐ ܗܘܘ ܒܗܘܢ ܒܐܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Acts 15:23",
      "text": "ܘܟܬܒܘ ܐܓܪܬܐ ܒܐܝܕܝܗܘܢ ܗܟܢܐ ܫܠܝܚܐ ܘܩܫܝܫܐ ܘܐܚܐ ܠܐܝܠܝܢ ܕܐܝܬ ܒܐܢܛܝܘܟܝ ܘܒܤܘܪܝܐ ܘܒܩܝܠܝܩܝܐ ܐܚܐ ܕܡܢ ܥܡܡܐ ܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Acts 15:24",
      "text": "ܫܡܝܥ ܠܢ ܕܐܢܫܝܢ ܡܢܢ ܢܦܩܘ ܘܕܠܚܟܘܢ ܒܡܠܐ ܘܐܗܦܟܘ ܢܦܫܬܟܘܢ ܟܕ ܐܡܪܝܢ ܕܬܗܘܘܢ ܓܙܪܝܢ ܘܢܛܪܝܢ ܢܡܘܤܐ ܐܝܠܝܢ ܕܚܢܢ ܠܐ ܦܩܕܢ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Acts 15:25",
      "text": "ܡܛܠ ܗܢܐ ܐܬܚܫܒܢ ܟܠܢ ܟܕ ܟܢܝܫܝܢܢ ܘܓܒܝܢ ܓܒܪܐ ܘܫܕܪܢ ܠܘܬܟܘܢ ܥܡ ܦܘܠܘܤ ܘܒܪܢܒܐ ܚܒܝܒܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Acts 15:26",
      "text": "ܐܢܫܐ ܕܐܫܠܡܘ ܢܦܫܬܗܘܢ ܚܠܦ ܫܡܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Acts 15:27",
      "text": "ܘܫܕܪܢ ܥܡܗܘܢ ܠܝܗܘܕܐ ܘܠܫܝܠܐ ܕܗܢܘܢ ܒܡܠܬܐ ܢܐܡܪܘܢ ܠܟܘܢ ܗܢܝܢ ܗܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Acts 15:28",
      "text": "ܗܘܐ ܓܝܪ ܨܒܝܢܐ ܠܪܘܚܐ ܕܩܘܕܫܐ ܘܐܦ ܠܢ ܕܠܐ ܢܬܬܤܝܡ ܥܠܝܟܘܢ ܝܘܩܪܐ ܝܬܝܪܐ ܠܒܪ ܡܢ ܗܠܝܢ ܕܐܠܨܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.29",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Acts 15:29",
      "text": "ܕܬܬܪܚܩܘܢ ܡܢ ܕܕܒܝܚܐ ܘܡܢ ܕܡܐ ܘܡܢ ܚܢܝܩܐ ܘܡܢ ܙܢܝܘܬܐ ܕܟܕ ܬܛܪܘܢ ܢܦܫܟܘܢ ܡܢ ܗܠܝܢ ܫܦܝܪ ܬܗܘܘܢ ܗܘܘ ܫܪܝܪܝܢ ܒܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.30",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Acts 15:30",
      "text": "ܗܢܘܢ ܕܝܢ ܕܐܫܬܠܚܘ ܐܬܘ ܠܐܢܛܝܟܝܐ ܘܟܢܫܘ ܟܠܗ ܥܡܐ ܘܝܗܒܘ ܐܓܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.31",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Acts 15:31",
      "text": "ܘܟܕ ܩܪܘ ܚܕܝܘ ܘܐܬܒܝܐܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.32",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Acts 15:32",
      "text": "ܘܒܡܠܬܐ ܥܬܝܪܬܐ ܚܝܠܘ ܠܐܚܐ ܘܩܝܡܘ ܐܢܘܢ ܕܒܝܬ ܝܗܘܕܐ ܘܫܝܠܐ ܡܛܠ ܕܐܦ ܗܢܘܢ ܢܒܝܐ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.33",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Acts 15:33",
      "text": "ܘܟܕ ܗܘܘ ܬܡܢ ܙܒܢܐ ܫܪܘ ܐܢܘܢ ܐܚܐ ܒܫܠܡܐ ܠܘܬ ܫܠܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.34",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
      "verseNumber": 34,
      "referenceLabel": "Acts 15:34",
      "text": "ܒܪܡ ܗܘܐ ܨܒܝܢܗ ܕܫܝܠܐ ܕܢܩܘܐ ܬܡܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.15.35",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 15,
