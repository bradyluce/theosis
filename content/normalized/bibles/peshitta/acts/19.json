    {
      "id": "peshitta:acts.19.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 28,
      "referenceLabel": "Acts 19:28",
      "text": "ܘܟܕ ܫܡܥܘ ܗܠܝܢ ܐܬܡܠܝܘ ܚܡܬܐ ܘܩܥܝܢ ܗܘܘ ܘܐܡܪܝܢ ܪܒܐ ܗܝ ܐܪܛܡܝܤ ܕܐܦܤܝܐ ܀",
      "paragraphStart": false
