    {
      "id": "peshitta:acts.19.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 24,
      "referenceLabel": "Acts 19:24",
      "text": "ܐܝܬ ܗܘܐ ܕܝܢ ܬܡܢ ܥܒܕ ܤܐܡܐ ܚܕ ܕܫܡܗ ܗܘܐ ܕܡܛܪܝܘܤ ܕܥܒܕ ܗܘܐ ܢܘܤܐ ܕܤܐܡܐ ܠܐܪܛܡܝܤ ܘܡܘܬܪ ܗܘܐ ܠܒܢܝ ܐܘܡܢܘܬܗ ܝܘܬܪܢܐ ܪܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 25,
      "referenceLabel": "Acts 19:25",
      "text": "ܗܢܐ ܟܢܫ ܐܢܘܢ ܠܒܢܝ ܐܘܡܢܘܬܗ ܟܠܗܘܢ ܘܠܐܝܠܝܢ ܕܦܠܚܝܢ ܥܡܗܘܢ ܘܐܡܪ ܠܗܘܢ ܓܒܪܐ ܝܕܥܝܢ ܐܢܬܘܢ ܕܬܐܓܘܪܬܢ ܟܠܗ ܡܢ ܗܢܐ ܗܝ ܦܘܠܚܢܐ ܀",
      "paragraphStart": false
