  "verses": [
    {
      "id": "peshitta:acts.19.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Acts 19:1",
      "text": "ܘܟܕ ܐܝܬܘܗܝ ܗܘܐ ܐܦܠܘ ܒܩܘܪܢܬܘܤ ܐܬܟܪܟ ܦܘܠܘܤ ܒܐܬܪܘܬܐ ܥܠܝܐ ܘܐܬܐ ܠܐܦܤܘܤ ܘܡܫܐܠ ܗܘܐ ܠܬܠܡܝܕܐ ܐܝܠܝܢ ܕܐܫܟܚ ܬܡܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.19.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Acts 19:2",
      "text": "ܕܐܢ ܩܒܠܬܘܢ ܪܘܚܐ ܕܩܘܕܫܐ ܡܢ ܕܗܝܡܢܬܘܢ ܥܢܘ ܘܐܡܪܝܢ ܠܗ ܘܐܦܠܐ ܐܢ ܐܝܬ ܪܘܚܐ ܕܩܘܕܫܐ ܫܡܝܥ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Acts 19:3",
      "text": "ܐܡܪ ܠܗܘܢ ܘܒܡܢܐ ܥܡܕܬܘܢ ܐܡܪܝܢ ܒܡܥܡܘܕܝܬܗ ܕܝܘܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Acts 19:4",
      "text": "ܐܡܪ ܠܗܘܢ ܦܘܠܘܤ ܝܘܚܢܢ ܐܥܡܕ ܡܥܡܘܕܝܬܐ ܕܬܝܒܘܬܐ ܠܥܡܐ ܟܕ ܐܡܪ ܗܘܐ ܕܢܗܝܡܢܘܢ ܒܐܝܢܐ ܕܐܬܐ ܒܬܪܗ ܕܐܝܬܘܗܝ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Acts 19:5",
      "text": "ܘܟܕ ܗܠܝܢ ܫܡܥܘ ܥܡܕܘ ܒܫܡܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Acts 19:6",
      "text": "ܘܤܡ ܥܠܝܗܘܢ ܐܝܕܐ ܦܘܠܘܤ ܘܐܬܐ ܪܘܚܐ ܕܩܘܕܫܐ ܥܠܝܗܘܢ ܘܡܡܠܠܝܢ ܗܘܘ ܒܠܫܢ ܠܫܢ ܘܡܬܢܒܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Acts 19:7",
      "text": "ܗܘܝܢ ܗܘܘ ܕܝܢ ܟܠܗܘܢ ܐܢܫܐ ܬܪܥܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Acts 19:8",
      "text": "ܘܥܠ ܗܘܐ ܦܘܠܘܤ ܠܟܢܘܫܬܐ ܘܡܡܠܠ ܗܘܐ ܥܝܢ ܒܓܠܐ ܝܪܚܐ ܬܠܬܐ ܘܡܦܝܤ ܗܘܐ ܥܠ ܡܠܟܘܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Acts 19:9",
      "text": "ܘܐܢܫܝܢ ܡܢܗܘܢ ܡܬܩܫܝܢ ܗܘܘ ܘܡܬܚܪܝܢ ܘܡܨܚܝܢ ܠܐܘܪܚܐ ܕܐܠܗܐ ܩܕܡ ܟܢܫܐ ܕܥܡܡܐ ܗܝܕܝܢ ܐܪܚܩ ܦܘܠܘܤ ܘܦܪܫ ܡܢܗܘܢ ܠܬܠܡܝܕܐ ܘܟܠܝܘܡ ܡܡܠܠ ܗܘܐ ܥܡܗܘܢ ܒܐܤܟܘܠܐ ܕܓܒܪܐ ܕܫܡܗ ܛܘܪܢܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Acts 19:10",
      "text": "ܘܗܕܐ ܗܘܬ ܫܢܝܢ ܬܪܬܝܢ ܥܕܡܐ ܕܫܡܥܘ ܡܠܬܐ ܕܡܪܝܐ ܟܠܗܘܢ ܕܥܡܪܝܢ ܒܐܤܝܐ ܝܗܘܕܝܐ ܘܐܪܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Acts 19:11",
      "text": "ܘܚܝܠܐ ܪܘܪܒܐ ܥܒܕ ܗܘܐ ܐܠܗܐ ܒܐܝܕܗ ܕܦܘܠܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Acts 19:12",
      "text": "ܗܟܢܐ ܕܐܦ ܡܢ ܢܚܬܐ ܕܥܠ ܓܘܫܡܗ ܤܘܕܪܐ ܐܘ ܪܘܩܥܐ ܡܝܬܝܢ ܗܘܘ ܘܤܝܡܝܢ ܥܠ ܟܪܝܗܐ ܘܦܪܩܝܢ ܗܘܘ ܡܢܗܘܢ ܟܘܪܗܢܐ ܘܐܦ ܫܐܕܐ ܢܦܩܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Acts 19:13",
      "text": "ܨܒܘ ܗܘܘ ܕܝܢ ܐܦ ܐܢܫܐ ܝܗܘܕܝܐ ܐܝܠܝܢ ܕܡܬܟܪܟܝܢ ܗܘܘ ܘܡܘܡܝܢ ܥܠ ܫܐܕܐ ܕܢܘܡܘܢ ܒܫܡܗ ܕܡܪܢ ܝܫܘܥ ܥܠ ܐܝܠܝܢ ܕܐܝܬ ܗܘܝ ܠܗܘܢ ܪܘܚܐ ܛܢܦܬܐ ܟܕ ܐܡܪܝܢ ܗܘܘ ܡܘܡܝܢܢ ܠܟܘܢ ܒܫܡܗ ܕܝܫܘܥ ܐܝܢܐ ܕܡܟܪܙ ܦܘܠܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Acts 19:14",
      "text": "ܐܝܬ ܗܘܐ ܕܝܢ ܫܒܥܐ ܒܢܘܗܝ ܕܓܒܪܐ ܚܕ ܝܗܘܕܝܐ ܪܒ ܟܗܢܐ ܕܫܡܗ ܗܘܐ ܤܩܘܐ ܕܥܒܕܝܢ ܗܘܘ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Acts 19:15",
      "text": "ܘܥܢܐ ܫܐܕܐ ܗܘ ܒܝܫܐ ܘܐܡܪ ܠܗܘܢ ܠܝܫܘܥ ܡܫܬܘܕܥ ܐܢܐ ܘܠܦܘܠܘܤ ܝܕܥ ܐܢܐ ܐܢܬܘܢ ܕܝܢ ܡܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "Acts 19:16",
      "text": "ܘܫܘܪ ܥܠܝܗܘܢ ܓܒܪܐ ܗܘ ܕܐܝܬ ܗܘܐ ܒܗ ܪܘܚܐ ܒܝܫܬܐ ܘܐܬܚܝܠ ܥܠܝܗܘܢ ܘܫܦܠ ܐܢܘܢ ܘܟܕ ܫܠܝܚܝܢ ܘܦܥܝܥܝܢ ܥܪܩܘ ܡܢ ܒܝܬܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "Acts 19:17",
      "text": "ܘܗܕܐ ܐܬܝܕܥܬ ܗܘܬ ܠܟܠܗܘܢ ܝܗܘܕܝܐ ܘܐܪܡܝܐ ܕܥܡܪܝܢ ܒܐܦܤܘܤ ܘܢܦܠܬ ܕܚܠܬܐ ܥܠ ܟܠܗܘܢ ܘܡܬܪܡܪܡ ܗܘܐ ܫܡܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "Acts 19:18",
      "text": "ܘܤܓܝܐܐ ܡܢ ܐܝܠܝܢ ܕܗܝܡܢܘ ܐܬܝܢ ܗܘܘ ܘܡܫܬܥܝܢ ܤܟܠܘܬܗܘܢ ܘܡܘܕܝܢ ܒܡܕܡ ܕܥܒܕܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "Acts 19:19",
      "text": "ܤܓܝܐܐ ܕܝܢ ܐܦ ܚܪܫܐ ܟܢܫܘ ܟܬܒܝܗܘܢ ܘܐܝܬܝܘ ܐܘܩܕܘ ܐܢܘܢ ܩܕܡ ܟܠܢܫ ܘܚܫܒܘ ܕܡܝܗܘܢ ܘܤܠܩ ܟܤܦܐ ܪܒܘܬܐ ܚܡܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "Acts 19:20",
      "text": "ܘܗܟܢܐ ܒܚܝܠܐ ܪܒܐ ܬܩܦܐ ܗܘܬ ܘܤܓܝܐ ܗܝܡܢܘܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "Acts 19:21",
      "text": "ܟܕ ܕܝܢ ܐܫܬܠܡ ܗܠܝܢ ܤܡ ܦܘܠܘܤ ܒܪܥܝܢܗ ܕܢܬܟܪܟ ܒܟܠܗ ܡܩܕܘܢܝܐ ܘܒܐܟܐܝܐ ܘܢܐܙܠ ܠܐܘܪܫܠܡ ܘܐܡܪ ܕܡܐ ܕܐܙܠܬ ܠܬܡܢ ܘܠܐ ܠܝ ܕܐܦ ܪܗܘܡܝ ܐܚܙܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 22,
      "referenceLabel": "Acts 19:22",
      "text": "ܘܫܕܪ ܗܘܐ ܬܪܝܢ ܐܢܫܝܢ ܡܢ ܗܢܘܢ ܕܡܫܡܫܝܢ ܗܘܘ ܠܗ ܠܡܩܕܘܢܝܐ ܠܛܝܡܬܐܘܤ ܘܠܐܪܤܛܘܤ ܗܘ ܕܝܢ ܩܘܝ ܙܒܢܐ ܒܐܤܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 23,
      "referenceLabel": "Acts 19:23",
      "text": "ܗܘܐ ܗܘܐ ܕܝܢ ܒܗܘ ܙܒܢܐ ܫܓܘܫܝܐ ܤܓܝܐܐ ܥܠ ܐܘܪܚܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
