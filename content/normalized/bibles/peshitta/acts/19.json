    {
      "id": "peshitta:acts.19.29",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 29,
      "referenceLabel": "Acts 19:29",
      "text": "ܘܐܫܬܓܫܬ ܟܠܗ ܡܕܝܢܬܐ ܘܪܗܛܘ ܐܟܚܕܐ ܘܐܙܠܘ ܠܬܐܛܪܘܢ ܘܚܛܦܘ ܐܘܒܠܘ ܥܡܗܘܢ ܠܓܐܝܘܤ ܘܠܐܪܤܛܪܟܘܤ ܓܒܪܐ ܡܩܕܘܢܝܐ ܒܢܝ ܠܘܝܬܗ ܕܦܘܠܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.19.30",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 19,
      "verseNumber": 30,
      "referenceLabel": "Acts 19:30",
      "text": "ܘܦܘܠܘܤ ܨܒܐ ܗܘܐ ܕܢܥܘܠ ܠܬܐܛܪܘܢ ܘܟܠܐܘܗܝ ܬܠܡܝܕܐ ܀",
