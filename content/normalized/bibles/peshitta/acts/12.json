{
  "chapter": {
    "id": "peshitta:acts.12",
    "translationId": "peshitta",
    "bookSlug": "acts",
    "chapterNumber": 12,
    "referenceLabel": "Acts 12",
    "summary": "Source text for Acts 12 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.12.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Acts 12:1",
      "text": "ܒܗܘ ܕܝܢ ܙܒܢܐ ܐܪܡܝ ܗܘܐ ܐܝܕܝܐ ܥܠ ܐܢܫܝܢ ܕܒܥܕܬܐ ܐܝܟ ܕܢܒܐܫ ܠܗܘܢ ܗܪܘܕܤ ܡܠܟܐ ܗܘ ܕܡܬܟܢܐ ܗܘܐ ܐܓܪܦܘܤ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.12.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Acts 12:2",
      "text": "ܘܩܛܠ ܒܤܝܦܐ ܠܝܥܩܘܒ ܐܚܘܗܝ ܕܝܘܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Acts 12:3",
      "text": "ܘܟܕ ܚܙܐ ܕܫܦܪܬ ܗܕܐ ܠܝܗܘܕܝܐ ܐܘܤܦ ܗܘܐ ܠܡܐܚܕ ܐܦ ܠܫܡܥܘܢ ܟܐܦܐ ܘܐܝܬܝܗܘܢ ܗܘܘ ܝܘܡܬܐ ܕܦܛܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Acts 12:4",
      "text": "ܘܐܚܕܗ ܘܐܪܡܝܗ ܒܝܬ ܐܤܝܪܐ ܘܐܫܠܡ ܠܗ ܫܬܬܥܤܪ ܤܛܪܛܘܛܝܢ ܕܢܛܪܘܢܗ ܕܡܢ ܒܬܪ ܦܨܚܐ ܢܫܠܡܝܘܗܝ ܠܥܡܐ ܕܝܗܘܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Acts 12:5",
      "text": "ܘܟܕ ܗܘ ܫܡܥܘܢ ܡܬܢܛܪ ܗܘܐ ܒܝܬ ܐܤܝܪܐ ܨܠܘܬܐ ܐܡܝܢܬܐ ܡܬܩܪܒܐ ܗܘܬ ܡܢ ܥܕܬܐ ܚܠܦܘܗܝ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Acts 12:6",
      "text": "ܘܒܗ ܒܗܘ ܠܠܝܐ ܕܠܨܦܪܐ ܥܬܝܕ ܗܘܐ ܕܢܫܠܡܝܘܗܝ ܟܕ ܕܡܟ ܗܘܐ ܫܡܥܘܢ ܒܝܬ ܬܪܝܢ ܐܤܛܪܛܝܘܛܝܢ ܘܐܤܝܪ ܗܘܐ ܒܬܪܬܝܢ ܫܫܠܢ ܘܐܚܪܢܐ ܢܛܪܝܢ ܗܘܘ ܬܪܥܐ ܕܒܝܬ ܐܤܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Acts 12:7",
      "text": "ܡܠܐܟܐ ܕܡܪܝܐ ܩܡ ܠܥܠ ܡܢܗ ܘܢܘܗܪܐ ܐܙܠܓ ܒܟܠܗ ܒܝܬܐ ܘܕܩܪܗ ܒܓܒܗ ܘܐܩܝܡܗ ܘܐܡܪ ܠܗ ܩܘܡ ܥܓܠ ܘܢܦܠ ܫܫܠܬܐ ܡܢ ܐܝܕܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Acts 12:8",
      "text": "ܘܐܡܪ ܠܗ ܡܠܐܟܐ ܐܤܘܪ ܚܨܝܟ ܘܤܐܢ ܛܠܪܝܟ ܘܥܒܕ ܗܟܢܐ ܘܬܘܒ ܐܡܪ ܠܗ ܐܬܥܛܦ ܬܟܤܝܬܟ ܘܬܐ ܒܬܪܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Acts 12:9",
      "text": "ܘܢܦܩ ܘܐܙܠ ܗܘܐ ܒܬܪܗ ܟܕ ܠܐ ܝܕܥ ܗܘܐ ܕܫܪܝܪܐ ܗܘܬ ܗܝ ܕܗܘܝܐ ܗܘܬ ܒܝܕ ܡܠܐܟܐ ܤܒܪ ܗܘܐ ܓܝܪ ܕܚܙܘܐ ܚܙܐ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Acts 12:10",
      "text": "ܘܟܕ ܥܒܪܘ ܡܛܪܬܐ ܩܕܡܝܬܐ ܘܕܬܪܬܝܢ ܐܬܘ ܥܕܡܐ ܠܬܪܥܐ ܕܦܪܙܠܐ ܘܐܬܦܬܚ ܠܗܘܢ ܡܢ ܨܒܘܬ ܢܦܫܗ ܘܟܕ ܢܦܩܘ ܘܥܒܪܘ ܫܘܩܐ ܚܕ ܦܪܩ ܡܢ ܠܘܬܗ ܡܠܐܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Acts 12:11",
      "text": "ܗܝܕܝܢ ܐܫܬܘܕܥ ܫܡܥܘܢ ܘܐܡܪ ܗܫܐ ܝܕܥܬ ܒܩܘܫܬܐ ܕܡܪܝܐ ܫܕܪ ܡܠܐܟܗ ܘܦܠܛܢܝ ܡܢ ܐܝܕܗ ܕܗܪܘܕܤ ܡܠܟܐ ܘܡܢ ܡܕܡ ܕܡܬܚܫܒܝܢ ܗܘܘ ܥܠܝ ܝܗܘܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Acts 12:12",
      "text": "ܘܟܕ ܐܤܬܟܠ ܐܬܐ ܠܗ ܠܒܝܬܐ ܕܡܪܝܡ ܐܡܗ ܕܝܘܚܢܢ ܗܘ ܕܐܬܟܢܝ ܡܪܩܘܤ ܡܛܠ ܕܐܚܐ ܤܓܝܐܐ ܬܡܢ ܟܢܝܫܝܢ ܗܘܘ ܘܡܨܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Acts 12:13",
      "text": "ܘܢܩܫ ܒܬܪܥܐ ܕܕܪܬܐ ܘܢܦܩܬ ܕܬܥܢܝܘܗܝ ܛܠܝܬܐ ܕܫܡܗ ܪܘܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Acts 12:14",
      "text": "ܘܐܫܬܘܕܥܬ ܩܠܗ ܕܫܡܥܘܢ ܘܒܚܕܘܬܗ ܠܐ ܦܬܚܬ ܠܗ ܬܪܥܐ ܐܠܐ ܗܦܟܬ ܒܪܗܛܐ ܘܐܡܪܐ ܠܗܘܢ ܫܡܥܘܢ ܗܐ ܩܐܡ ܥܠ ܬܪܥܐ ܕܕܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Acts 12:15",
      "text": "ܐܡܪܝܢ ܠܗ ܡܙܥ ܙܥܬܝ ܠܟܝ ܘܗܝ ܡܬܚܪܝܐ ܗܘܬ ܕܗܕܐ ܗܟܢܐ ܗܝ ܐܡܪܝܢ ܠܗ ܟܒܪ ܡܠܐܟܗ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Acts 12:16",
      "text": "ܘܫܡܥܘܢ ܢܩܫ ܗܘܐ ܒܬܪܥܐ ܘܢܦܩܘ ܚܙܐܘܗܝ ܘܬܡܗܘ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Acts 12:17",
      "text": "ܘܡܢܝܦ ܗܘܐ ܠܗܘܢ ܐܝܕܗ ܐܝܟ ܕܢܫܬܩܘܢ ܠܗܘܢ ܘܥܠ ܘܐܫܬܥܝ ܠܗܘܢ ܐܝܟܢܐ ܡܪܝܐ ܐܦܩܗ ܡܢ ܒܝܬ ܐܤܝܪܐ ܘܐܡܪ ܠܗܘܢ ܐܫܬܥܘ ܗܠܝܢ ܠܝܥܩܘܒ ܘܠܐܚܝܢ ܘܢܦܩ ܐܙܠ ܠܗ ܠܐܬܪ ܐܚܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Acts 12:18",
      "text": "ܘܟܕ ܗܘܐ ܨܦܪܐ ܗܘܐ ܗܘܐ ܪܘܒܐ ܤܓܝܐܐ ܒܝܬ ܐܤܛܪܛܝܘܛܐ ܥܠ ܫܡܥܘܢ ܕܡܢܐ ܗܘܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Acts 12:19",
      "text": "ܗܪܘܕܤ ܕܝܢ ܟܕ ܒܥܝܗܝ ܘܠܐ ܐܫܟܚܗ ܕܢ ܐܢܘܢ ܠܢܛܘܪܐ ܘܦܩܕ ܕܢܡܘܬܘܢ ܘܢܦܩ ܠܗ ܡܢ ܝܗܘܕ ܘܐܝܬܘܗܝ ܗܘܐ ܒܩܤܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Acts 12:20",
      "text": "ܘܡܛܠ ܕܪܓܝܙ ܗܘܐ ܥܠ ܨܘܪܝܐ ܘܥܠ ܨܝܕܢܝܐ ܐܬܟܢܫܘ ܘܐܬܘ ܠܘܬܗ ܐܟܚܕܐ ܘܐܦܝܤܘ ܠܒܠܤܛܘܤ ܩܝܛܘܢܩܢܗ ܕܡܠܟܐ ܘܫܐܠܘ ܡܢܗ ܕܢܗܘܐ ܠܗܘܢ ܫܝܢܐ ܡܛܠ ܕܦܘܪܢܤܐ ܕܐܬܪܗܘܢ ܡܢ ܡܠܟܘܬܗ ܗܘܐ ܕܗܪܘܕܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Acts 12:21",
      "text": "ܒܝܘܡܐ ܕܝܢ ܝܕܝܥܐ ܠܒܫ ܗܘܐ ܗܪܘܕܤ ܠܒܘܫܐ ܕܡܠܟܘܬܐ ܘܝܬܒ ܥܠ ܒܝܡ ܘܡܡܠܠ ܗܘܐ ܥܡ ܟܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Acts 12:22",
      "text": "ܥܡܐ ܕܝܢ ܟܠܗ ܩܥܐ ܗܘܐ ܘܐܡܪ ܗܠܝܢ ܒܢܬ ܩܠܐ ܕܐܠܗܐ ܐܢܝܢ ܘܠܐ ܗܘܝ ܕܒܢܝܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Acts 12:23",
      "text": "ܘܚܠܦ ܕܠܐ ܝܗܒ ܬܫܒܘܚܬܐ ܠܐܠܗܐ ܒܗ ܒܫܥܬܐ ܡܚܝܗܝ ܡܠܐܟܗ ܕܡܪܝܐ ܘܪܦܬ ܒܬܘܠܥܐ ܘܡܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Acts 12:24",
      "text": "ܘܤܒܪܬܐ ܕܐܠܗܐ ܡܬܟܪܙܐ ܗܘܬ ܘܪܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.12.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Acts 12:25",
      "text": "ܒܪܢܒܐ ܕܝܢ ܘܫܐܘܠ ܦܢܘ ܡܢ ܐܘܪܫܠܡ ܠܐܢܛܝܘܟܝ ܡܢ ܒܬܪ ܕܫܠܡܘ ܬܫܡܫܬܗܘܢ ܘܕܒܪܘ ܥܡܗܘܢ ܠܝܘܚܢܢ ܗܘ ܕܐܬܟܢܝ ܡܪܩܘܤ ܀",
      "paragraphStart": false
    }
  ]
}
