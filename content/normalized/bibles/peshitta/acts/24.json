{
  "chapter": {
    "id": "peshitta:acts.24",
    "translationId": "peshitta",
    "bookSlug": "acts",
    "chapterNumber": 24,
    "referenceLabel": "Acts 24",
    "summary": "Source text for Acts 24 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.24.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Acts 24:1",
      "text": "ܘܡܢ ܒܬܪ ܝܘܡܬܐ ܚܡܫܐ ܢܚܬ ܚܢܢܝܐ ܪܒ ܟܗܢܐ ܥܡ ܩܫܝܫܐ ܘܥܡ ܛܪܛܠܘܤ ܪܗܛܪܐ ܘܐܘܕܥܘ ܠܗܓܡܘܢܐ ܥܠ ܦܘܠܘܤ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.24.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Acts 24:2",
      "text": "ܘܟܕ ܐܬܩܪܝ ܐܩܦ ܗܘܐ ܛܪܛܠܘܤ ܡܩܛܪܓ ܠܗ ܘܐܡܪ ܒܤܘܓܐܐ ܕܫܝܢܐ ܥܡܪܝܢܢ ܡܛܠܬܟ ܘܬܩܢܬܐ ܤܓܝܐܬܐ ܗܘܝ ܠܥܡܐ ܗܢܐ ܒܫܩܠ ܛܥܢܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Acts 24:3",
      "text": "ܘܟܠܢ ܒܟܠ ܕܘܟ ܡܩܒܠܝܢܢ ܛܝܒܘܬܟ ܢܨܝܚܐ ܦܝܠܟܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Acts 24:4",
      "text": "ܕܠܐ ܕܝܢ ܢܠܐܝܟ ܒܤܓܝܐܬܐ ܒܥܐ ܐܢܐ ܡܢܟ ܕܬܫܡܥ ܠܡܟܝܟܘܬܢ ܒܦܤܝܩܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Acts 24:5",
      "text": "ܐܫܟܚܢ ܓܝܪ ܠܓܒܪܐ ܗܢܐ ܕܐܝܬܘܗܝ ܡܫܚܛܢܐ ܘܡܥܝܪ ܫܓܘܫܝܐ ܠܟܠܗܘܢ ܝܗܘܕܝܐ ܕܒܟܠܗ ܐܪܥܐ ܪܫܐ ܗܘ ܓܝܪ ܕܝܘܠܦܢܐ ܕܢܨܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Acts 24:6",
      "text": "ܘܠܗܝܟܠܢ ܨܒܐ ܠܡܤܝܒܘ ܘܟܕ ܐܚܕܢܝܗܝ ܒܥܝܢ ܕܢܕܘܢܝܘܗܝ ܐܝܟ ܕܒܢܡܘܤܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Acts 24:7",
      "text": "ܐܬܐ ܕܝܢ ܠܘܤܝܘܤ ܟܠܝܪܟܐ ܘܒܩܛܝܪܐ ܤܓܝܐܐ ܡܢ ܐܝܕܝܢ ܐܥܕܝܗ ܘܠܟ ܫܕܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Acts 24:8",
      "text": "ܘܦܩܕ ܠܩܛܪܓܢܘܗܝ ܕܢܐܬܘܢ ܠܘܬܟ ܘܡܫܟܚ ܐܢܬ ܟܕ ܡܫܐܠ ܐܢܬ ܠܗ ܕܬܐܠܦ ܡܢܗ ܥܠ ܟܠܗܝܢ ܗܠܝܢ ܕܡܩܛܪܓܝܢܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Acts 24:9",
      "text": "ܐܪܝܒܘ ܕܝܢ ܥܠܘܗܝ ܐܦ ܗܢܘܢ ܝܗܘܕܝܐ ܟܕ ܐܡܪܝܢ ܕܗܠܝܢ ܗܟܢܐ ܐܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Acts 24:10",
      "text": "ܘܪܡܙ ܗܓܡܘܢܐ ܠܦܘܠܘܤ ܕܢܡܠܠ ܘܥܢܐ ܦܘܠܘܤ ܘܐܡܪ ܡܢ ܫܢܝܐ ܤܓܝܐܬܐ ܝܕܥ ܐܢܐ ܕܐܝܬܝܟ ܕܝܢܐ ܕܥܡܐ ܗܢܐ ܘܡܛܠ ܗܢܐ ܚܕܝܐܝܬ ܢܦܩ ܐܢܐ ܪܘܚܐ ܥܠ ܐܦܝ ܢܦܫܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 11,
      "referenceLabel": "Acts 24:11",
      "text": "ܟܕ ܡܫܟܚ ܐܢܬ ܠܡܕܥ ܕܠܝܬ ܠܝ ܝܬܝܪ ܡܢ ܬܪܥܤܪ ܝܘܡܝܢ ܕܤܠܩܬ ܠܐܘܪܫܠܡ ܠܡܤܓܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 12,
      "referenceLabel": "Acts 24:12",
      "text": "ܘܠܐ ܐܫܟܚܘܢܝ ܕܡܡܠܠ ܐܢܐ ܥܡ ܐܢܫ ܒܗܝܟܠܐ ܘܐܦܠܐ ܟܢܫܐ ܕܟܢܫ ܐܢܐ ܠܐ ܒܟܢܘܫܬܗܘܢ ܘܠܐ ܒܡܕܝܢܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 13,
      "referenceLabel": "Acts 24:13",
      "text": "ܘܠܐ ܕܢܚܘܘܢ ܡܛܝܐ ܒܐܝܕܝܗܘܢ ܩܕܡܝܟ ܥܠ ܡܕܡ ܕܗܫܐ ܡܩܛܪܓܝܢ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 14,
      "referenceLabel": "Acts 24:14",
      "text": "ܒܪܡ ܕܝܢ ܗܕܐ ܡܘܕܐ ܐܢܐ ܕܒܗ ܒܗܢܐ ܝܘܠܦܢܐ ܕܐܡܪܝܢ ܒܗ ܦܠܚ ܐܢܐ ܠܐܠܗܐ ܕܐܒܗܝ ܟܕ ܡܗܝܡܢ ܐܢܐ ܠܟܠܗܝܢ ܕܟܬܝܒܢ ܒܢܡܘܤܐ ܘܒܢܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 15,
      "referenceLabel": "Acts 24:15",
      "text": "ܘܟܕ ܐܝܬ ܠܝ ܤܒܪܐ ܥܠ ܐܠܗܐ ܐܝܢܐ ܕܐܦ ܗܢܘܢ ܗܠܝܢ ܡܤܒܪܝܢ ܕܥܬܝܕܐ ܕܬܗܘܐ ܩܝܡܬܐ ܕܡܢ ܒܝܬ ܡܝܬܐ ܕܟܐܢܐ ܘܕܥܘܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 16,
      "referenceLabel": "Acts 24:16",
      "text": "ܡܛܠ ܗܢܐ ܐܦ ܥܡܠ ܐܢܐ ܕܬܐܪܬܐ ܕܟܝܬܐ ܬܗܘܐ ܠܝ ܩܕܡ ܐܠܗܐ ܘܩܕܡ ܒܢܝ ܐܢܫܐ ܐܡܝܢܐܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 17,
      "referenceLabel": "Acts 24:17",
      "text": "ܠܫܢܝܢ ܕܝܢ ܤܓܝܐܢ ܐܬܝܬ ܠܘܬ ܒܢܝ ܥܡܐ ܕܝܠܝ ܕܐܬܠ ܙܕܩܬܐ ܘܐܩܪܒ ܩܘܪܒܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 18,
      "referenceLabel": "Acts 24:18",
      "text": "ܘܐܫܟܚܘܢܝ ܗܠܝܢ ܒܗܝܟܠܐ ܟܕ ܡܕܟܝ ܐܢܐ ܠܐ ܥܡ ܟܢܫܐ ܐܦܠܐ ܒܫܓܘܫܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 19,
      "referenceLabel": "Acts 24:19",
      "text": "ܐܠܐ ܐܢ ܕܫܓܫܘ ܐܢܫܝܢ ܝܗܘܕܝܐ ܕܐܬܘ ܡܢ ܐܤܝܐ ܐܝܠܝܢ ܕܘܠܐ ܗܘܐ ܕܢܩܘܡܘܢ ܥܡܝ ܩܕܡܝܟ ܘܢܩܛܪܓܘܢ ܡܕܡ ܕܐܝܬ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 20,
      "referenceLabel": "Acts 24:20",
      "text": "ܐܘ ܗܢܘܢ ܗܠܝܢ ܢܐܡܪܘܢ ܡܢܐ ܐܫܟܚܘ ܒܝ ܤܟܠܘܬܐ ܟܕ ܩܡܬ ܩܕܡ ܟܢܫܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 21,
      "referenceLabel": "Acts 24:21",
      "text": "ܐܠܐ ܐܢ ܗܕܐ ܚܕܐ ܡܠܬܐ ܕܩܥܝܬ ܟܕ ܩܐܡ ܐܢܐ ܒܝܢܬܗܘܢ ܕܥܠ ܩܝܡܬܐ ܕܡܝܬܐ ܡܬܕܝܢ ܐܢܐ ܝܘܡܢܐ ܩܕܡܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 22,
      "referenceLabel": "Acts 24:22",
      "text": "ܦܝܠܟܤ ܕܝܢ ܡܛܠ ܕܝܕܥ ܗܘܐ ܠܗ ܠܐܘܪܚܐ ܗܕܐ ܡܠܝܐܝܬ ܬܗܝ ܐܢܘܢ ܟܕ ܐܡܪ ܕܡܐ ܕܐܬܐ ܟܠܝܪܟܐ ܫܡܥ ܐܢܐ ܒܝܢܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 23,
      "referenceLabel": "Acts 24:23",
      "text": "ܘܦܩܕ ܠܩܢܛܪܘܢܐ ܕܢܛܪܝܘܗܝ ܠܦܘܠܘܤ ܒܢܝܚܐ ܘܕܠܐ ܐܢܫ ܡܢ ܝܕܘܥܘܗܝ ܢܬܟܠܐ ܕܢܗܘܐ ܡܫܡܫ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 24,
      "referenceLabel": "Acts 24:24",
      "text": "ܘܡܢ ܒܬܪ ܩܠܝܠ ܝܘܡܬܐ ܫܕܪ ܦܝܠܟܤ ܘܕܘܪܤܠܐ ܐܢܬܬܗ ܕܐܝܬܝܗ ܗܘܬ ܝܗܘܕܝܬܐ ܘܩܪܘ ܠܗ ܠܦܘܠܘܤ ܘܫܡܥܘ ܡܢܗ ܥܠ ܗܝܡܢܘܬܐ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 25,
      "referenceLabel": "Acts 24:25",
      "text": "ܘܟܕ ܡܡܠܠ ܥܡܗܘܢ ܥܠ ܙܕܝܩܘܬܐ ܘܥܠ ܩܕܝܫܘܬܐ ܘܥܠ ܕܝܢܐ ܕܥܬܝܕ ܐܬܡܠܝ ܕܚܠܬܐ ܦܝܠܟܤ ܘܐܡܪ ܕܗܫܐ ܙܠ ܘܐܡܬܝ ܕܢܗܘܐ ܠܝ ܐܬܪܐ ܐܫܕܪ ܒܬܪܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 26,
      "referenceLabel": "Acts 24:26",
      "text": "ܤܒܪ ܗܘܐ ܓܝܪ ܕܫܘܚܕܐ ܡܬܝܗܒ ܗܘܐ ܠܗ ܡܢ ܦܘܠܘܤ ܡܛܠ ܗܕܐ ܐܦ ܐܡܝܢܐܝܬ ܡܫܕܪ ܗܘܐ ܡܝܬܐ ܠܗ ܘܡܡܠܠ ܥܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.24.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 24,
      "verseNumber": 27,
      "referenceLabel": "Acts 24:27",
      "text": "ܘܟܕ ܡܠܝ ܠܗ ܬܪܬܝܢ ܫܢܝܢ ܐܚܪܢܐ ܗܓܡܘܢܐ ܐܬܐ ܗܘܐ ܠܕܘܟܬܗ ܕܡܬܩܪܐ ܗܘܐ ܦܪܩܝܘܤ ܦܗܤܛܘܤ ܦܝܠܟܤ ܕܝܢ ܐܝܟ ܕܢܥܒܕ ܛܝܒܘܬܐ ܒܝܗܘܕܝܐ ܫܒܩܗ ܠܦܘܠܘܤ ܟܕ ܐܤܝܪ ܀",
      "paragraphStart": false
    }
  ]
}
