{
  "chapter": {
    "id": "peshitta:acts.13",
    "translationId": "peshitta",
    "bookSlug": "acts",
    "chapterNumber": 13,
    "referenceLabel": "Acts 13",
    "summary": "Source text for Acts 13 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.13.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Acts 13:1",
      "text": "ܐܝܬ ܗܘܐ ܕܝܢ ܒܥܕܬܐ ܕܐܢܛܝܟܝܐ ܢܒܝܐ ܘܡܠܦܢܐ ܒܪܢܒܐ ܘܫܡܥܘܢ ܕܡܬܩܪܐ ܢܝܓܪ ܘܠܘܩܝܤ ܕܡܢ ܩܘܪܝܢܐ ܡܕܝܢܬܐ ܘܡܢܐܝܠ ܒܪ ܡܪܒܝܢܘܗܝ ܕܗܪܘܕܤ ܛܛܪܪܟܐ ܘܫܐܘܠ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.13.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Acts 13:2",
      "text": "ܘܟܕ ܗܢܘܢ ܨܝܡܝܢ ܗܘܘ ܘܡܬܟܫܦܝܢ ܠܐܠܗܐ ܐܡܪܬ ܠܗܘܢ ܪܘܚܐ ܕܩܘܕܫܐ ܦܪܘܫܘ ܠܝ ܠܫܐܘܠ ܘܠܒܪܢܒܐ ܠܥܒܕܐ ܐܝܢܐ ܕܐܢܐ ܩܪܝܬ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Acts 13:3",
      "text": "ܘܒܬܪ ܕܨܡܘ ܘܨܠܝܘ ܤܡܘ ܥܠܝܗܘܢ ܐܝܕܐ ܘܫܕܪܘ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Acts 13:4",
      "text": "ܘܗܢܘܢ ܟܕ ܐܫܬܠܚܘ ܡܢ ܪܘܚܐ ܕܩܘܕܫܐ ܢܚܬܘ ܠܗܘܢ ܠܤܠܘܩܝܐ ܘܡܢ ܬܡܢ ܪܕܘ ܒܝܡܐ ܥܕܡܐ ܠܩܘܦܪܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Acts 13:5",
      "text": "ܘܟܕ ܥܠܘ ܠܤܠܡܢܐ ܡܕܝܢܬܐ ܡܤܒܪܝܢ ܗܘܘ ܡܠܬܗ ܕܡܪܢ ܒܟܢܘܫܬܐ ܕܝܗܘܕܝܐ ܘܝܘܚܢܢ ܡܫܡܫ ܗܘܐ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Acts 13:6",
      "text": "ܘܟܕ ܐܬܟܪܟܘܗ ܠܟܠܗ ܓܙܪܬܐ ܥܕܡܐ ܠܦܦܘܤ ܡܕܝܢܬܐ ܐܫܟܚܘ ܓܒܪܐ ܚܕ ܚܪܫܐ ܝܗܘܕܝܐ ܕܐܝܬܘܗܝ ܗܘܐ ܢܒܝܐ ܕܓܠܐ ܕܫܡܗ ܗܘܐ ܒܪܫܘܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Acts 13:7",
      "text": "ܗܢܐ ܕܒܝܩ ܗܘܐ ܠܓܒܪܐ ܚܟܝܡܐ ܕܐܝܬܘܗܝ ܗܘܐ ܐܢܬܘܦܛܘܤ ܘܡܬܩܪܐ ܗܘܐ ܤܪܓܝܘܤ ܦܘܠܘܤ ܘܩܪܐ ܗܘܐ ܐܢܬܘܦܛܘܤ ܠܫܐܘܠ ܘܠܒܪܢܒܐ ܘܒܥܐ ܗܘܐ ܕܢܫܡܥ ܡܢܗܘܢ ܡܠܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Acts 13:8",
      "text": "ܩܐܡ ܗܘܐ ܕܝܢ ܠܘܩܒܠܗܘܢ ܗܘ ܗܢܐ ܚܪܫܐ ܒܪܫܘܡܐ ܕܡܬܬܪܓܡ ܫܡܗ ܐܠܘܡܤ ܡܛܠ ܕܨܒܐ ܗܘܐ ܕܢܥܩܡܝܘܗܝ ܠܐܢܬܘܦܛܘܤ ܡܢ ܗܝܡܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Acts 13:9",
      "text": "ܫܐܘܠ ܕܝܢ ܗܘ ܕܐܬܩܪܝ ܦܘܠܘܤ ܐܬܡܠܝ ܗܘܐ ܒܪܘܚܐ ܕܩܘܕܫܐ ܘܚܪ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Acts 13:10",
      "text": "ܘܐܡܪ ܐܘ ܕܡܠܐ ܟܠ ܢܟܠܝܢ ܘܟܠܗܝܢ ܒܝܫܬܐ ܒܪܗ ܕܐܟܠ ܩܪܨܐ ܘܒܥܠܕܒܒܐ ܕܟܠܗ ܟܐܢܘܬܐ ܠܐ ܫܠܐ ܐܢܬ ܠܡܥܩܡܘ ܐܘܪܚܬܗ ܬܪܝܨܬܐ ܕܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Acts 13:11",
      "text": "ܘܗܫܐ ܐܝܕܗ ܕܡܪܝܐ ܥܠܝܟ ܘܬܗܘܐ ܤܡܐ ܘܠܐ ܬܚܙܐ ܫܡܫܐ ܥܕܡܐ ܠܙܒܢܐ ܘܒܗ ܒܫܥܬܐ ܢܦܠ ܥܠܘܗܝ ܥܡܛܢܐ ܘܚܫܘܟܐ ܘܡܬܟܪܟ ܗܘܐ ܘܒܥܐ ܕܡܢܘ ܢܐܚܘܕ ܒܐܝܕܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Acts 13:12",
      "text": "ܘܟܕ ܚܙܐ ܐܢܬܘܦܛܘܤ ܡܕܡ ܕܗܘܐ ܐܬܕܡܪ ܘܗܝܡܢ ܒܝܘܠܦܢܗ ܕܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Acts 13:13",
      "text": "ܦܘܠܘܤ ܕܝܢ ܘܒܪܢܒܐ ܪܕܘ ܒܝܡܐ ܡܢ ܦܦܘܤ ܡܕܝܢܬܐ ܘܐܬܘ ܠܗܘܢ ܠܦܪܓܐ ܡܕܝܢܬܐ ܕܦܡܦܘܠܝܐ ܘܦܪܫ ܡܢܗܘܢ ܝܘܚܢܢ ܘܐܙܠ ܠܗ ܠܐܘܪܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Acts 13:14",
      "text": "ܗܢܘܢ ܕܝܢ ܢܦܩܘ ܡܢ ܦܪܓܐ ܘܐܬܘ ܠܐܢܛܝܟܝܐ ܡܕܝܢܬܐ ܕܦܝܤܝܕܝܐ ܘܥܠܘ ܠܟܢܘܫܬܐ ܘܝܬܒܘ ܒܝܘܡܐ ܘܫܒܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Acts 13:15",
      "text": "ܘܒܬܪ ܕܐܬܩܪܝ ܢܡܘܤܐ ܘܢܒܝܐ ܫܠܚܘ ܠܗܘܢ ܩܫܝܫܐ ܕܟܢܘܫܬܐ ܘܐܡܪܘ ܓܒܪܐ ܐܚܝܢ ܐܢ ܗܘ ܕܐܝܬ ܠܟܘܢ ܡܠܬܐ ܕܒܘܝܐܐ ܡܠܠܘ ܥܡ ܥܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Acts 13:16",
      "text": "ܘܩܡ ܦܘܠܘܤ ܘܐܢܝܦ ܐܝܕܗ ܘܐܡܪ ܓܒܪܐ ܒܢܝ ܐܝܤܪܝܠ ܘܐܝܠܝܢ ܕܕܚܠܝܢ ܡܢ ܐܠܗܐ ܫܡܥܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Acts 13:17",
      "text": "ܐܠܗܗ ܕܥܡܐ ܗܢܐ ܓܒܐ ܠܐܒܗܬܢ ܘܐܪܝܡ ܘܐܘܪܒ ܐܢܘܢ ܟܕ ܗܘܘ ܬܘܬܒܐ ܒܐܪܥܐ ܕܡܨܪܝܢ ܘܒܕܪܥܐ ܪܡܐ ܐܦܩ ܐܢܘܢ ܡܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Acts 13:18",
      "text": "ܘܬܪܤܝ ܐܢܘܢ ܒܡܕܒܪܐ ܐܪܒܥܝܢ ܫܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Acts 13:19",
      "text": "ܘܗܓܡ ܫܒܥܐ ܥܡܡܝܢ ܒܐܪܥܐ ܕܟܢܥܢ ܘܝܗܒ ܠܗܘܢ ܐܪܥܗܘܢ ܠܝܘܪܬܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Acts 13:20",
      "text": "ܘܐܪܒܥ ܡܐܐ ܘܚܡܫܝܢ ܫܢܝܢ ܝܗܒ ܠܗܘܢ ܕܝܢܐ ܥܕܡܐ ܠܫܡܘܐܝܠ ܢܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Acts 13:21",
      "text": "ܘܗܝܕܝܢ ܫܐܠܘ ܠܗܘܢ ܡܠܟܐ ܘܝܗܒ ܠܗܘܢ ܐܠܗܐ ܠܫܐܘܠ ܒܪ ܩܝܫ ܓܒܪܐ ܡܢ ܫܪܒܬܐ ܕܒܢܝܡܝܢ ܫܢܝܢ ܐܪܒܥܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Acts 13:22",
      "text": "ܘܢܤܒܗ ܘܐܩܝܡ ܠܗܘܢ ܠܕܘܝܕ ܡܠܟܐ ܘܐܤܗܕ ܥܠܘܗܝ ܘܐܡܪ ܕܐܫܟܚܬ ܠܕܘܝܕ ܒܪܗ ܕܐܝܫܝ ܓܒܪܐ ܐܝܟ ܠܒܝ ܗܘ ܢܥܒܕ ܟܠܗܘܢ ܨܒܝܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Acts 13:23",
      "text": "ܡܢ ܙܪܥܗ ܕܗܢܐ ܐܩܝܡ ܐܠܗܐ ܠܐܝܤܪܝܠ ܐܝܟ ܡܐ ܕܐܫܬܘܕܝ ܠܝܫܘܥ ܦܪܘܩܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Acts 13:24",
      "text": "ܘܫܕܪ ܠܝܘܚܢܢ ܕܢܟܪܙ ܩܕܡ ܡܐܬܝܬܗ ܡܥܡܘܕܝܬܐ ܕܬܝܒܘܬܐ ܠܟܠܗ ܥܡܐ ܕܐܝܤܪܝܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Acts 13:25",
      "text": "ܘܟܕ ܡܫܠܡ ܗܘܐ ܝܘܚܢܢ ܬܫܡܫܬܗ ܐܡܪ ܗܘܐ ܡܢܘ ܤܒܪܝܢ ܐܢܬܘܢ ܕܐܝܬܝ ܠܐ ܗܘܝܬ ܐܢܐ ܐܠܐ ܗܐ ܐܬܐ ܒܬܪܝ ܗܘ ܕܠܐ ܫܘܐ ܐܢܐ ܕܐܫܪܐ ܥܪܩܐ ܕܡܤܢܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 26,
      "referenceLabel": "Acts 13:26",
      "text": "ܓܒܪܐ ܐܚܝܢ ܒܢܝ ܫܪܒܬܗ ܕܐܒܪܗܡ ܘܐܝܠܝܢ ܕܕܚܠܝܢ ܥܡܟܘܢ ܠܐܠܗܐ ܠܟܘܢ ܗܘ ܐܫܬܕܪܬ ܡܠܬܐ ܕܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 27,
      "referenceLabel": "Acts 13:27",
      "text": "ܗܠܝܢ ܓܝܪ ܥܡܘܪܐ ܕܐܘܪܫܠܡ ܘܪܫܢܝܗܘܢ ܠܐ ܐܪܓܫܘ ܒܗ ܐܦܠܐ ܒܟܬܒܐ ܕܢܒܝܐ ܕܡܬܩܪܝܢ ܒܟܠ ܫܒܐ ܐܠܐ ܕܢܘܗܝ ܘܫܠܡܘ ܗܠܝܢ ܕܟܬܝܒܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 28,
      "referenceLabel": "Acts 13:28",
      "text": "ܘܟܕ ܠܐ ܐܫܟܚܘ ܥܠܬܐ ܕܡܘܬܐ ܡܕܡ ܫܐܠܘ ܡܢ ܦܝܠܛܘܤ ܕܢܩܛܠܘܢܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.29",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 29,
      "referenceLabel": "Acts 13:29",
      "text": "ܘܟܕ ܫܠܡܘ ܟܠܡܕܡ ܕܟܬܝܒ ܗܘܐ ܥܠܘܗܝ ܐܚܬܘܗܝ ܡܢ ܨܠܝܒܐ ܘܤܡܘܗܝ ܒܝܬ ܩܒܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.30",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 30,
      "referenceLabel": "Acts 13:30",
      "text": "ܐܠܗܐ ܕܝܢ ܐܩܝܡܗ ܡܢ ܒܝܬ ܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.31",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 31,
      "referenceLabel": "Acts 13:31",
      "text": "ܘܐܬܚܙܝ ܝܘܡܬܐ ܤܓܝܐܐ ܠܐܝܠܝܢ ܕܤܠܩܘ ܥܡܗ ܡܢ ܓܠܝܠܐ ܠܐܘܪܫܠܡ ܘܗܢܘܢ ܐܢܘܢ ܗܫܐ ܤܗܕܘܗܝ ܠܘܬ ܥܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.32",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 32,
      "referenceLabel": "Acts 13:32",
      "text": "ܘܐܦ ܚܢܢ ܗܐ ܡܤܒܪܝܢܢ ܠܟܘܢ ܕܫܘܘܕܝܐ ܗܘ ܕܗܘܐ ܠܘܬ ܐܒܗܬܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.33",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 33,
      "referenceLabel": "Acts 13:33",
      "text": "ܗܐ ܫܡܠܝܗ ܐܠܗܐ ܠܢ ܠܒܢܝܗܘܢ ܕܐܩܝܡ ܠܝܫܘܥ ܐܝܟ ܕܟܬܝܒ ܒܡܙܡܘܪܐ ܕܬܪܝܢ ܕܒܪܝ ܐܢܬ ܐܢܐ ܝܘܡܢܐ ܝܠܕܬܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.34",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 34,
      "referenceLabel": "Acts 13:34",
      "text": "ܘܗܟܢܐ ܐܩܝܡܗ ܐܠܗܐ ܡܢ ܒܝܬ ܡܝܬܐ ܕܬܘܒ ܠܐ ܢܗܦܘܟ ܢܚܙܐ ܚܒܠܐ ܐܝܟ ܕܐܡܪ ܕܐܬܠ ܠܟܘܢ ܛܝܒܘܬܗ ܕܕܘܝܕ ܡܗܝܡܢܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.35",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 35,
      "referenceLabel": "Acts 13:35",
      "text": "ܘܬܘܒ ܐܡܪ ܒܕܘܟܬܐ ܐܚܪܬܐ ܕܠܐ ܝܗܒܬ ܠܚܤܝܟ ܕܢܚܙܐ ܚܒܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.36",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 36,
      "referenceLabel": "Acts 13:36",
      "text": "ܕܘܝܕ ܓܝܪ ܒܫܪܒܬܗ ܫܡܫ ܨܒܝܢܗ ܕܐܠܗܐ ܘܫܟܒ ܘܐܬܬܘܤܦ ܥܠ ܐܒܗܘܗܝ ܘܚܙܐ ܚܒܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.37",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 37,
      "referenceLabel": "Acts 13:37",
      "text": "ܗܢܐ ܕܝܢ ܕܐܩܝܡ ܐܠܗܐ ܠܐ ܚܙܐ ܚܒܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.38",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 38,
      "referenceLabel": "Acts 13:38",
      "text": "ܕܥܘ ܗܟܝܠ ܐܚܝ ܕܒܗ ܒܗܢܐ ܡܬܟܪܙ ܠܟܘܢ ܫܘܒܩܢ ܚܛܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.39",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 39,
      "referenceLabel": "Acts 13:39",
      "text": "ܘܡܢ ܟܠ ܕܠܐ ܐܫܟܚܬܘܢ ܒܢܡܘܤܐ ܕܡܘܫܐ ܕܬܙܕܕܩܘܢ ܒܗܢܐ ܟܠ ܕܡܗܝܡܢ ܡܙܕܕܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.40",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 40,
      "referenceLabel": "Acts 13:40",
      "text": "ܐܙܕܗܪܘ ܗܟܝܠ ܕܠܡܐ ܢܐܬܐ ܥܠܝܟܘܢ ܡܕܡ ܕܟܬܝܒ ܒܢܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.41",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 41,
      "referenceLabel": "Acts 13:41",
      "text": "ܕܚܙܘ ܡܒܤܪܢܐ ܘܬܬܡܗܘܢ ܘܬܬܚܒܠܘܢ ܕܥܒܕܐ ܥܒܕ ܐܢܐ ܒܝܘܡܝܟܘܢ ܐܝܢܐ ܕܠܐ ܬܗܝܡܢܘܢ ܐܢ ܐܢܫ ܡܫܬܥܐ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.42",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 42,
      "referenceLabel": "Acts 13:42",
      "text": "ܘܟܕ ܢܦܩܝܢ ܗܘܘ ܡܢ ܨܐܕܝܗܘܢ ܒܥܘ ܡܢܗܘܢ ܕܠܫܒܬܐ ܐܚܪܬܐ ܢܡܠܠܘܢ ܥܡܗܘܢ ܡܠܐ ܗܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.43",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 43,
      "referenceLabel": "Acts 13:43",
      "text": "ܘܡܢ ܕܐܫܬܪܝܬ ܟܢܘܫܬܐ ܤܓܝܐܐ ܝܗܘܕܝܐ ܐܙܠܘ ܒܬܪܗܘܢ ܘܐܦ ܓܝܘܪܐ ܕܕܚܠܝܢ ܗܘܘ ܡܢ ܐܠܗܐ ܘܗܢܘܢ ܡܡܠܠܝܢ ܗܘܘ ܘܡܦܝܤܝܢ ܠܗܘܢ ܕܢܗܘܘܢ ܢܩܝܦܝܢ ܠܛܝܒܘܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.44",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 44,
      "referenceLabel": "Acts 13:44",
      "text": "ܘܠܫܒܬܐ ܐܚܪܬܐ ܟܢܫܬ ܟܠܗ ܡܕܝܢܬܐ ܠܡܫܡܥ ܡܠܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.45",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 45,
      "referenceLabel": "Acts 13:45",
      "text": "ܘܟܕ ܚܙܘ ܝܗܘܕܝܐ ܟܢܫܐ ܤܓܝܐܐ ܐܬܡܠܝܘ ܚܤܡܐ ܘܩܝܡܝܢ ܗܘܘ ܠܘܩܒܠ ܡܠܐ ܕܐܡܪ ܗܘܐ ܦܘܠܘܤ ܘܡܓܕܦܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.46",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 46,
      "referenceLabel": "Acts 13:46",
      "text": "ܐܡܪ ܕܝܢ ܦܘܠܘܤ ܘܒܪܢܒܐ ܥܝܢ ܒܓܠܐ ܠܟܘܢ ܗܘ ܘܠܐ ܗܘܐ ܩܕܡܝܬ ܕܬܬܐܡܪ ܡܠܬܗ ܕܐܠܗܐ ܐܠܐ ܡܛܠ ܕܕܚܝܢ ܐܢܬܘܢ ܠܗ ܡܢܟܘܢ ܘܦܤܩܬܘܢ ܥܠ ܢܦܫܟܘܢ ܕܠܐ ܫܘܝܢ ܐܢܬܘܢ ܠܚܝܐ ܕܠܥܠܡ ܗܐ ܡܬܦܢܝܢܢ ܠܢ ܠܘܬ ܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.47",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 47,
      "referenceLabel": "Acts 13:47",
      "text": "ܗܟܢܐ ܓܝܪ ܦܩܕܢ ܡܪܢ ܐܝܟ ܕܟܬܝܒ ܕܤܡܬܟ ܢܘܗܪܐ ܠܥܡܡܐ ܕܬܗܘܐ ܠܚܝܐ ܥܕܡܐ ܠܤܘܦܝܗ ܕܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.48",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 48,
      "referenceLabel": "Acts 13:48",
      "text": "ܘܟܕ ܫܡܥܝܢ ܗܘܘ ܥܡܡܐ ܚܕܝܢ ܗܘܘ ܘܡܫܒܚܝܢ ܠܐܠܗܐ ܘܗܝܡܢܘ ܐܝܠܝܢ ܕܤܝܡܝܢ ܗܘܘ ܠܚܝܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.49",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 49,
      "referenceLabel": "Acts 13:49",
      "text": "ܘܡܠܬܗ ܕܡܪܝܐ ܡܬܡܠܠܐ ܗܘܬ ܒܟܠܗ ܗܘ ܐܬܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.50",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 50,
      "referenceLabel": "Acts 13:50",
      "text": "ܝܗܘܕܝܐ ܕܝܢ ܓܪܓܘ ܠܪܫܐ ܕܡܕܝܢܬܐ ܘܠܢܫܐ ܥܬܝܪܬܐ ܐܝܠܝܢ ܕܕܚܠܢ ܗܘܝ ܥܡܗܘܢ ܠܐܠܗܐ ܘܐܩܝܡܘ ܪܕܘܦܝܐ ܥܠ ܦܘܠܘܤ ܘܥܠ ܒܪܢܒܐ ܘܐܦܩܘ ܐܢܘܢ ܡܢ ܬܚܘܡܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.51",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 51,
      "referenceLabel": "Acts 13:51",
      "text": "ܘܟܕ ܢܦܩܘ ܢܦܨܘ ܥܠܝܗܘܢ ܚܠܐ ܕܪܓܠܝܗܘܢ ܘܐܬܘ ܠܗܘܢ ܠܐܝܩܢܘܢ ܡܕܝܢܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.13.52",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 13,
      "verseNumber": 52,
      "referenceLabel": "Acts 13:52",
      "text": "ܘܬܠܡܝܕܐ ܡܬܡܠܝܢ ܗܘܘ ܚܕܘܬܐ ܘܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    }
