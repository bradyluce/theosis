{
  "chapter": {
    "id": "peshitta:acts.28",
    "translationId": "peshitta",
    "bookSlug": "acts",
    "chapterNumber": 28,
    "referenceLabel": "Acts 28",
    "summary": "Source text for Acts 28 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.28.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Acts 28:1",
      "text": "ܘܡܢ ܒܬܪܟܢ ܝܠܦܢ ܕܡܠܝܛܐ ܡܬܩܪܝܐ ܗܝ ܓܙܪܬܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.28.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Acts 28:2",
      "text": "ܘܒܪܒܪܝܐ ܕܥܡܪܝܢ ܗܘܘ ܒܗ ܪܚܡܐ ܤܓܝܐܐ ܚܘܝܘ ܠܘܬܢ ܘܐܘܚܕܘ ܢܘܪܐ ܘܩܪܐܘܢ ܠܟܠܢ ܕܢܫܚܢ ܡܛܠ ܡܛܪܐ ܤܓܝܐܐ ܘܩܘܪܫܐ ܕܐܝܬ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Acts 28:3",
      "text": "ܘܦܘܠܘܤ ܫܩܠ ܤܘܓܐܐ ܕܚܒܘܒܐ ܘܤܡ ܥܠ ܢܘܪܐ ܘܢܦܩܬ ܡܢܗܘܢ ܐܟܕܢܐ ܡܢ ܪܬܚܐ ܕܢܘܪܐ ܘܢܟܬܬ ܒܐܝܕܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Acts 28:4",
      "text": "ܘܟܕ ܚܙܐܘܗ ܒܪܒܪܝܐ ܕܬܠܝܐ ܒܐܝܕܗ ܐܡܪܝܢ ܗܘܘ ܟܒܪ ܗܢܐ ܓܒܪܐ ܩܛܘܠܐ ܗܘ ܕܟܕ ܐܫܬܘܙܒ ܡܢ ܝܡܐ ܟܐܢܘܬܐ ܠܐ ܫܒܩܬܗ ܕܢܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Acts 28:5",
      "text": "ܗܘ ܕܝܢ ܦܘܠܘܤ ܐܢܝܦ ܐܝܕܗ ܘܫܕܗ ܠܐܟܕܢܐ ܒܢܘܪܐ ܘܡܕܡ ܕܤܢܐ ܠܐ ܗܘܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Acts 28:6",
      "text": "ܤܒܪܝܢ ܗܘܘ ܕܝܢ ܒܪܒܪܝܐ ܕܒܪ ܫܥܬܗ ܡܬܡܤܐ ܘܢܦܠ ܟܕ ܡܝܬ ܥܠ ܐܪܥܐ ܘܟܕ ܥܕܢܐ ܤܓܝܐܐ ܤܟܝܘ ܘܚܙܘ ܕܡܕܡ ܕܤܢܐ ܠܐ ܗܘܝܗܝ ܫܚܠܦܘ ܡܠܝܗܘܢ ܘܐܡܪܘ ܕܐܠܗܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Acts 28:7",
      "text": "ܐܝܬ ܗܘܐ ܕܝܢ ܩܘܪܝܐ ܒܗ ܒܗܘ ܐܬܪܐ ܠܓܒܪܐ ܚܕ ܕܫܡܗ ܗܘܐ ܦܘܦܠܝܘܤ ܕܗܘ ܗܘܐ ܪܫܗ ܕܓܙܪܬܐ ܘܩܒܠܢ ܒܒܝܬܗ ܬܠܬܐ ܝܘܡܝܢ ܚܕܝܐܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Acts 28:8",
      "text": "ܐܒܘܗܝ ܕܝܢ ܕܦܘܦܠܝܘܤ ܒܐܫܬܐ ܘܒܟܐܒ ܡܥܝܐ ܟܪܝܗ ܗܘܐ ܘܥܠ ܠܘܬܗ ܦܘܠܘܤ ܘܨܠܝ ܘܤܡ ܥܠܘܗܝ ܐܝܕܗ ܘܐܚܠܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Acts 28:9",
      "text": "ܘܟܕ ܗܘܬ ܗܕܐ ܐܦ ܫܪܟܐ ܐܝܠܝܢ ܕܐܝܬ ܗܘܘ ܒܗ ܒܓܙܪܬܐ ܟܪܝܗܐ ܩܪܒܝܢ ܗܘܘ ܠܘܬܗ ܘܡܬܐܤܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Acts 28:10",
      "text": "ܘܐܝܩܪܐ ܪܘܪܒܐ ܝܩܪܘܢ ܘܟܕ ܢܦܩܝܢ ܗܘܝܢ ܡܢ ܬܡܢ ܙܘܕܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Acts 28:11",
      "text": "ܢܦܩܢ ܕܝܢ ܒܬܪ ܝܪܚܐ ܬܠܬܐ ܘܪܕܝܢ ܒܐܠܦܐ ܐܠܟܤܢܕܪܝܬܐ ܕܐܤܬܝܬ ܗܘܬ ܒܗ ܒܓܙܪܬܐ ܘܐܝܬ ܗܘܬ ܥܠܝܗ ܐܬܐ ܕܬܐܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 12,
      "referenceLabel": "Acts 28:12",
      "text": "ܘܐܬܝܢ ܠܤܪܩܘܤܐ ܡܕܝܢܬܐ ܘܩܘܝܢ ܬܡܢ ܝܘܡܬܐ ܬܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 13,
      "referenceLabel": "Acts 28:13",
      "text": "ܘܡܢ ܬܡܢ ܐܬܟܪܟܢ ܘܡܢܥܢ ܠܪܓܝܘܢ ܡܕܝܢܬܐ ܘܒܬܪ ܝܘܡܐ ܚܕ ܢܫܒܬ ܠܢ ܪܘܚܐ ܕܬܝܡܢܐ ܘܠܬܪܝܢ ܝܘܡܝܢ ܐܬܝܢ ܠܦܘܛܝܐܠܤ ܡܕܝܢܬܐ ܕܐܝܛܠܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 14,
      "referenceLabel": "Acts 28:14",
      "text": "ܘܐܫܟܚܢ ܬܡܢ ܐܚܐ ܘܒܥܘ ܡܢܢ ܘܗܘܝܢ ܠܘܬܗܘܢ ܝܘܡܬܐ ܫܒܥܐ ܘܗܝܕܝܢ ܐܙܠܢ ܠܪܗܘܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 15,
      "referenceLabel": "Acts 28:15",
      "text": "ܘܟܕ ܫܡܥܘ ܐܚܐ ܕܬܡܢ ܢܦܩܘ ܠܐܘܪܥܢ ܥܕܡܐ ܠܫܘܩܐ ܕܡܬܩܪܐ ܐܦܝܘܤ ܦܘܪܘܤ ܘܥܕܡܐ ܠܬܠܬ ܚܢܘܢ ܘܟܕ ܚܙܐ ܐܢܘܢ ܦܘܠܘܤ ܐܘܕܝ ܠܐܠܗܐ ܘܐܬܚܝܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 16,
      "referenceLabel": "Acts 28:16",
      "text": "ܘܥܠܢ ܠܪܗܘܡܐ ܘܐܦܤ ܩܢܛܪܘܢܐ ܠܦܘܠܘܤ ܕܢܫܪܐ ܐܝܟܐ ܕܨܒܐ ܥܡ ܐܤܛܪܛܝܘܛܐ ܗܘ ܕܢܛܪ ܗܘܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 17,
      "referenceLabel": "Acts 28:17",
      "text": "ܘܡܢ ܒܬܪ ܬܠܬܐ ܝܘܡܝܢ ܫܕܪ ܦܘܠܘܤ ܩܪܐ ܠܪܫܢܝܗܘܢ ܕܝܗܘܕܝܐ ܘܟܕ ܐܬܟܢܫܘ ܐܡܪ ܠܗܘܢ ܓܒܪܐ ܐܚܝ ܐܢܐ ܟܕ ܒܡܕܡ ܠܐ ܩܡܬ ܠܘܩܒܠ ܥܡܐ ܘܢܡܘܤܐ ܕܐܒܗܝ ܒܐܤܘܪܐ ܐܫܬܠܡܬ ܡܢ ܐܘܪܫܠܡ ܒܐܝܕܐ ܕܪܗܘܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 18,
      "referenceLabel": "Acts 28:18",
      "text": "ܘܗܢܘܢ ܟܕ ܫܐܠܘܢܝ ܨܒܘ ܕܢܫܪܘܢܢܝ ܡܛܠ ܕܠܐ ܐܫܟܚܘ ܒܬܪܝ ܪܫܝܢܐ ܡܕܡ ܕܫܘܐ ܠܡܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 19,
      "referenceLabel": "Acts 28:19",
      "text": "ܘܟܕ ܩܝܡܝܢ ܗܘܘ ܠܘܩܒܠܝ ܝܗܘܕܝܐ ܐܬܐܠܨܬ ܕܐܩܥܐ ܒܓܢ ܩܤܪ ܠܐ ܐܝܟ ܐܝܬ ܠܝ ܕܐܩܛܪܓ ܒܡܕܡ ܠܒܢܝ ܥܡܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 20,
      "referenceLabel": "Acts 28:20",
      "text": "ܡܛܠ ܗܢܐ ܒܥܝܬ ܡܢܟܘܢ ܕܬܐܬܘܢ ܘܐܚܙܝܟܘܢ ܘܐܫܬܥܐ ܠܟܘܢ ܗܠܝܢ ܡܛܠ ܤܒܪܐ ܓܝܪ ܕܐܝܤܪܝܠ ܐܤܝܪ ܐܢܐ ܒܫܫܠܬܐ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 21,
      "referenceLabel": "Acts 28:21",
      "text": "ܐܡܪܝܢ ܠܗ ܗܢܘܢ ܚܢܢ ܐܓܪܬܐ ܥܠܝܟ ܠܐ ܩܒܠܢ ܡܢ ܝܗܘܕ ܘܠܐ ܐܢܫ ܡܢ ܐܚܐ ܕܐܬܘ ܡܢ ܐܘܪܫܠܡ ܐܡܪܘ ܠܢ ܡܕܡ ܕܒܝܫ ܥܠܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 22,
      "referenceLabel": "Acts 28:22",
      "text": "ܨܒܝܢܢ ܕܝܢ ܕܢܫܡܥ ܡܢܟ ܡܕܡ ܕܡܬܪܥܐ ܐܢܬ ܡܛܠ ܕܝܘܠܦܢܐ ܗܢܐ ܝܕܥܝܢܢ ܕܥܠ ܐܢܫ ܠܐ ܡܩܒܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 23,
      "referenceLabel": "Acts 28:23",
      "text": "ܘܐܩܝܡܘ ܠܗ ܝܘܡܐ ܘܟܢܫܘ ܘܐܬܘ ܠܘܬܗ ܤܓܝܐܐ ܟܪ ܕܫܪܐ ܗܘܐ ܘܓܠܐ ܠܗܘܢ ܥܠ ܡܠܟܘܬܐ ܕܐܠܗܐ ܟܕ ܡܤܗܕ ܘܡܦܝܤ ܠܗܘܢ ܥܠ ܝܫܘܥ ܡܢ ܢܡܘܤܐ ܕܡܘܫܐ ܘܡܢ ܢܒܝܐ ܡܢ ܨܦܪܐ ܘܥܕܡܐ ܠܪܡܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 24,
      "referenceLabel": "Acts 28:24",
      "text": "ܘܐܢܫܝܢ ܡܢܗܘܢ ܡܬܛܦܝܤܝܢ ܗܘܘ ܠܡܠܘܗܝ ܘܐܚܪܢܐ ܠܐ ܡܬܛܦܝܤܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 25,
      "referenceLabel": "Acts 28:25",
      "text": "ܘܐܫܬܪܝܘ ܡܢ ܠܘܬܗ ܟܕ ܠܐ ܫܠܡܝܢ ܠܚܕܕܐ ܘܐܡܪ ܠܗܘܢ ܗܘ ܦܘܠܘܤ ܡܠܬܐ ܗܕܐ ܫܦܝܪ ܡܠܠ ܪܘܚܐ ܕܩܘܕܫܐ ܒܦܘܡ ܐܫܥܝܐ ܢܒܝܐ ܠܘܩܒܠ ܐܒܗܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 26,
      "referenceLabel": "Acts 28:26",
      "text": "ܟܕ ܐܡܪ ܕܙܠ ܠܘܬ ܥܡܐ ܗܢܐ ܘܐܡܪ ܠܗܘܢ ܕܫܡܥܐ ܬܫܡܥܘܢ ܘܠܐ ܬܤܬܟܠܘܢ ܘܬܚܙܘܢ ܘܠܐ ܬܒܚܪܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 27,
      "referenceLabel": "Acts 28:27",
      "text": "ܐܬܥܒܝ ܠܗ ܓܝܪ ܠܒܗ ܕܥܡܐ ܗܢܐ ܘܡܫܡܥܬܗܘܢ ܐܘܩܪܘ ܘܥܝܢܝܗܘܢ ܥܡܨܘ ܕܠܐ ܢܚܙܘܢ ܒܥܝܢܝܗܘܢ ܘܢܫܡܥܘܢ ܒܐܕܢܝܗܘܢ ܘܢܤܬܟܠܘܢ ܒܠܒܗܘܢ ܘܢܬܘܒܘܢ ܠܘܬܝ ܘܐܫܒܘܩ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.28",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 28,
      "referenceLabel": "Acts 28:28",
      "text": "ܬܬܝܕܥ ܠܟܘܢ ܗܟܝܠ ܗܕܐ ܕܠܥܡܡܐ ܗܘ ܐܫܬܕܪ ܗܢܐ ܦܘܪܩܢܐ ܕܐܠܗܐ ܗܢܘܢ ܓܝܪ ܐܦ ܫܡܥܝܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.29",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 29,
      "referenceLabel": "Acts 28:29",
      "text": "ܘܟܕ ܗܠܝܢ ܐܡܪ ܢܦܩܘ ܝܗܘܕܝܐ ܘܤܓܝ ܕܪܫܝܢ ܗܘܘ ܒܝܢܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.30",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 30,
      "referenceLabel": "Acts 28:30",
      "text": "ܘܐܓܪ ܠܗ ܦܘܠܘܤ ܡܢ ܕܝܠܗ ܒܝܬܐ ܘܗܘܐ ܒܗ ܬܪܬܝܢ ܫܢܝܢ ܘܡܩܒܠ ܗܘܐ ܬܡܢ ܠܟܠܗܘܢ ܐܝܠܝܢ ܕܐܬܝܢ ܗܘܘ ܠܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.28.31",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 28,
      "verseNumber": 31,
      "referenceLabel": "Acts 28:31",
      "text": "ܘܡܟܪܙ ܗܘܐ ܥܠ ܡܠܟܘܬܗ ܕܐܠܗܐ ܘܡܠܦ ܗܘܐ ܥܝܢ ܒܓܠܐ ܥܠ ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܕܠܐ ܟܠܝܢ ܀ ܀ ܀",
      "paragraphStart": false
    }
  ]
}
