{
  "chapter": {
    "id": "peshitta:acts.25",
    "translationId": "peshitta",
    "bookSlug": "acts",
    "chapterNumber": 25,
    "referenceLabel": "Acts 25",
    "summary": "Source text for Acts 25 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:acts.25.1",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Acts 25:1",
      "text": "ܘܟܕ ܐܬܐ ܦܗܤܛܘܤ ܠܩܤܪܝܐ ܒܬܪ ܬܠܬܐ ܝܘܡܝܢ ܤܠܩ ܠܐܘܪܫܠܡ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:acts.25.2",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Acts 25:2",
      "text": "ܘܐܘܕܥܘܗܝ ܪܒܝ ܟܗܢܐ ܘܪܫܐ ܕܝܗܘܕܝܐ ܥܠ ܦܘܠܘܤ ܘܒܥܝܢ ܗܘܘ ܡܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.3",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Acts 25:3",
      "text": "ܟܕ ܫܐܠܝܢ ܠܗ ܗܕܐ ܛܝܒܘܬܐ ܕܢܫܕܪ ܢܝܬܝܘܗܝ ܠܐܘܪܫܠܡ ܟܕ ܥܒܕܝܢ ܗܘܘ ܟܡܐܢܐ ܒܐܘܪܚܐ ܕܢܩܛܠܘܢܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.4",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Acts 25:4",
      "text": "ܘܦܗܤܛܘܤ ܦܢܝ ܦܬܓܡܐ ܕܦܘܠܘܤ ܡܬܢܛܪ ܒܩܤܪܝܐ ܘܐܢܐ ܡܤܪܗܒ ܐܢܐ ܕܐܚܙܘܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.5",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Acts 25:5",
      "text": "ܐܝܠܝܢ ܗܟܝܠ ܕܐܝܬ ܒܟܘܢ ܕܡܛܝܐ ܒܐܝܕܝܗܘܢ ܢܚܬܘܢ ܥܡܢ ܘܥܠ ܟܠ ܤܟܠܘ ܕܐܝܬ ܒܗ ܒܓܒܪܐ ܢܩܛܪܓܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.6",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Acts 25:6",
      "text": "ܘܟܕ ܗܘܐ ܬܡܢ ܝܘܡܬܐ ܬܡܢܝܐ ܐܘ ܥܤܪܐ ܢܚܬ ܠܗ ܠܩܤܪܝܐ ܘܠܝܘܡܐ ܐܚܪܢܐ ܝܬܒ ܥܠ ܒܝܡ ܘܦܩܕ ܕܢܝܬܘܢ ܠܦܘܠܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.7",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Acts 25:7",
      "text": "ܘܟܕ ܐܬܐ ܚܕܪܘܗܝ ܝܗܘܕܝܐ ܕܢܚܬܘ ܡܢ ܐܘܪܫܠܡ ܘܪܫܐ ܤܓܝܐܐ ܘܩܫܝܐ ܡܝܬܝܢ ܗܘܘ ܒܬܪܗ ܐܝܠܝܢ ܕܠܐ ܡܫܟܚܝܢ ܗܘܘ ܕܢܚܘܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.8",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Acts 25:8",
      "text": "ܘܟܕ ܦܘܠܘܤ ܢܦܩ ܗܘܐ ܪܘܚܐ ܕܠܐ ܐܤܟܠ ܡܕܡ ܠܐ ܒܢܡܘܤܐ ܕܝܗܘܕܝܐ ܘܠܐ ܒܗܝܟܠܐ ܘܠܐ ܒܩܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.9",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Acts 25:9",
      "text": "ܦܗܤܛܘܤ ܕܝܢ ܡܛܠ ܕܨܒܐ ܗܘܐ ܕܢܪܫܐ ܛܝܒܘܬܐ ܒܝܗܘܕܝܐ ܐܡܪ ܠܗ ܠܦܘܠܘܤ ܨܒܐ ܐܢܬ ܕܬܤܩ ܠܐܘܪܫܠܡ ܘܬܡܢ ܥܠ ܗܠܝܢ ܬܬܕܝܢ ܩܕܡܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.10",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Acts 25:10",
      "text": "ܥܢܐ ܦܘܠܘܤ ܘܐܡܪ ܥܠ ܒܝܡ ܕܩܤܪ ܩܐܡ ܐܢܐ ܗܪܟܐ ܗܘ ܙܕܩ ܠܝ ܠܡܬܕܢܘ ܠܐ ܡܕܡ ܚܛܝܬ ܠܝܗܘܕܝܐ ܐܝܟ ܕܐܦ ܐܢܬ ܝܕܥ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.11",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Acts 25:11",
      "text": "ܘܐܢ ܤܟܠܘܬܐ ܥܒܝܕܐ ܠܝ ܐܘ ܡܕܡ ܕܫܘܐ ܠܡܘܬܐ ܠܐ ܡܫܬܐܠ ܐܢܐ ܡܢ ܡܘܬܐ ܐܢ ܕܝܢ ܠܝܬ ܡܕܡ ܨܐܕܝ ܡܢ ܗܠܝܢ ܕܡܩܛܪܓܝܢ ܠܝ ܠܐ ܐܢܫ ܝܗܒ ܠܝ ܠܗܘܢ ܡܘܗܒܬ ܒܓܢܘܗܝ ܕܩܤܪ ܩܪܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.12",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Acts 25:12",
      "text": "ܗܝܕܝܢ ܦܗܤܛܘܤ ܡܠܠ ܥܡ ܒܢܝ ܡܠܟܗ ܘܐܡܪ ܒܓܢ ܩܤܪ ܩܪܝܬ ܠܘܬ ܩܤܪ ܐܙܠ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.13",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "Acts 25:13",
      "text": "ܘܟܕ ܗܘܘ ܝܘܡܬܐ ܢܚܬ ܐܓܪܦܘܤ ܡܠܟܐ ܘܒܪܢܝܩܐ ܠܩܤܪܝܐ ܕܢܫܐܠܘܢ ܫܠܡܗ ܕܦܗܤܛܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.14",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "Acts 25:14",
      "text": "ܘܟܕ ܗܘܘ ܠܘܬܗ ܝܘܡܬܐ ܐܫܬܥܝ ܦܗܤܛܘܤ ܠܡܠܟܐ ܕܝܢܗ ܕܦܘܠܘܤ ܟܕ ܐܡܪ ܓܒܪܐ ܚܕ ܐܤܝܪܐ ܐܫܬܒܩ ܡܢ ܐܝܕܝ ܦܝܠܟܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.15",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 15,
      "referenceLabel": "Acts 25:15",
      "text": "ܘܟܕ ܗܘܝܬ ܒܐܘܪܫܠܡ ܐܘܕܥܘ ܠܝ ܥܠܘܗܝ ܪܒܝ ܟܗܢܐ ܘܩܫܝܫܐ ܕܝܗܘܕܝܐ ܘܒܥܘ ܕܐܥܒܕ ܠܗܘܢ ܕܝܢܐ ܡܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.16",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 16,
      "referenceLabel": "Acts 25:16",
      "text": "ܘܐܡܪܬ ܠܗܘܢ ܕܠܝܬ ܥܝܕܐ ܠܪܗܘܡܝܐ ܕܢܬܠܘܢ ܒܪܢܫܐ ܡܘܗܒܬ ܠܩܛܠܐ ܥܕܡܐ ܕܢܐܬܐ ܒܥܠ ܕܝܢܗ ܘܢܟܤܝܘܗܝ ܒܐܦܘܗܝ ܘܢܬܝܗܒ ܠܗ ܐܬܪܐ ܠܡܦܩ ܒܪܘܚܐ ܥܠ ܡܐ ܕܡܬܪܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.17",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 17,
      "referenceLabel": "Acts 25:17",
      "text": "ܘܟܕ ܐܬܝܬ ܠܟܐ ܕܠܐ ܬܘܗܝܐ ܠܝܘܡܐ ܐܚܪܢܐ ܝܬܒܬ ܥܠ ܒܝܡ ܘܦܩܕܬ ܕܢܝܬܘܢܝܗܝ ܠܝ ܠܓܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.18",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 18,
      "referenceLabel": "Acts 25:18",
      "text": "ܘܩܡܘ ܥܡܗ ܩܛܪܓܢܘܗܝ ܘܠܐ ܐܫܟܚܘ ܡܕܡ ܪܫܝܢܐ ܒܝܫܐ ܕܢܚܘܘܢ ܥܠܘܗܝ ܐܝܟ ܡܐ ܕܤܒܪ ܗܘܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.19",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 19,
      "referenceLabel": "Acts 25:19",
      "text": "ܙܛܡܐ ܕܝܢ ܡܕܡ ܡܕܡ ܥܠ ܕܚܠܬܗܘܢ ܐܝܬ ܗܘܐ ܠܗܘܢ ܠܘܬܗ ܘܥܠ ܝܫܘܥ ܐܢܫ ܕܡܝܬ ܗܘ ܕܐܡܪ ܗܘܐ ܦܘܠܘܤ ܕܚܝ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.20",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 20,
      "referenceLabel": "Acts 25:20",
      "text": "ܘܡܛܠ ܕܠܐ ܩܐܡ ܗܘܝܬ ܐܢܐ ܥܠ ܒܥܬܐ ܕܗܠܝܢ ܐܡܪܬ ܗܘܝܬ ܠܦܘܠܘܤ ܕܐܢ ܒܥܐ ܐܢܬ ܕܬܐܙܠ ܠܐܘܪܫܠܡ ܘܬܡܢ ܬܬܕܝܢ ܥܠ ܗܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.21",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 21,
      "referenceLabel": "Acts 25:21",
      "text": "ܗܘ ܕܝܢ ܒܥܐ ܕܢܬܢܛܪ ܠܕܝܢܗ ܕܩܤܪ ܘܦܩܕܬ ܕܢܬܢܛܪ ܥܕܡܐ ܕܐܫܕܪܝܘܗܝ ܠܘܬ ܩܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.22",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 22,
      "referenceLabel": "Acts 25:22",
      "text": "ܘܐܡܪ ܐܓܪܦܘܤ ܨܒܐ ܗܘܝܬ ܕܐܫܡܥܝܘܗܝ ܠܓܒܪܐ ܗܢܐ ܘܦܗܤܛܘܤ ܐܡܪ ܕܠܡܚܪ ܫܡܥ ܐܢܬ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.23",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 23,
      "referenceLabel": "Acts 25:23",
      "text": "ܘܠܝܘܡܐ ܐܚܪܢܐ ܐܬܐ ܐܓܪܦܘܤ ܘܒܪܢܝܩܐ ܒܙܘܚܐ ܤܓܝܐܐ ܘܥܠ ܠܒܝܬ ܕܝܢܐ ܥܡ ܟܠܝܪܟܐ ܘܪܫܐ ܕܡܕܝܢܬܐ ܘܦܩܕ ܦܗܤܛܘܤ ܘܐܬܐ ܦܘܠܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.24",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 24,
      "referenceLabel": "Acts 25:24",
      "text": "ܘܐܡܪ ܦܗܤܛܘܤ ܐܓܪܦܘܤ ܡܠܟܐ ܘܟܠܟܘܢ ܓܒܪܐ ܕܐܝܬܝܟܘܢ ܥܡܢ ܥܠ ܗܢܐ ܓܒܪܐ ܕܚܙܝܢ ܐܢܬܘܢ ܟܠܗ ܥܡܐ ܕܝܗܘܕܝܐ ܩܒܠܢܝ ܒܐܘܪܫܠܡ ܘܗܪܟܐ ܟܕ ܩܥܝܢ ܕܠܐ ܬܘܒ ܘܠܐ ܠܗܢܐ ܕܢܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.25",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 25,
      "referenceLabel": "Acts 25:25",
      "text": "ܐܢܐ ܕܝܢ ܐܕܪܟܬ ܕܡܕܡ ܕܫܘܐ ܠܡܘܬܐ ܠܐ ܤܥܝܪ ܠܗ ܘܡܛܠ ܕܗܘ ܒܥܐ ܕܢܬܢܛܪ ܠܕܝܢܗ ܕܩܤܪ ܦܩܕܬ ܕܢܫܬܕܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.26",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 26,
      "referenceLabel": "Acts 25:26",
      "text": "ܘܠܐ ܝܕܥ ܐܢܐ ܡܢܐ ܐܟܬܘܒ ܥܠܘܗܝ ܠܩܤܪ ܡܛܠ ܗܢܐ ܨܒܝܬ ܠܡܝܬܝܘܬܗ ܩܕܡܝܟܘܢ ܘܝܬܝܪܐܝܬ ܩܕܡܝܟ ܡܠܟܐ ܐܓܪܦܐ ܕܡܐ ܕܐܫܬܐܠ ܕܝܢܗ ܐܫܟܚ ܡܢܐ ܐܟܬܘܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:acts.25.27",
      "translationId": "peshitta",
      "bookSlug": "acts",
      "chapterNumber": 25,
      "verseNumber": 27,
      "referenceLabel": "Acts 25:27",
      "text": "ܠܐ ܓܝܪ ܘܠܐ ܕܟܕ ܡܫܕܪܝܢܢ ܓܒܪܐ ܐܤܝܪܐ ܕܠܐ ܢܟܬܘܒ ܤܟܠܘܬܗ ܀",
      "paragraphStart": false
    }
  ]
}
