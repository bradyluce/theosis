    {
      "id": "peshitta:luke.16.29",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 29,
      "referenceLabel": "Luke 16:29",
      "text": "ܐܡܪ ܠܗ ܐܒܪܗܡ ܐܝܬ ܠܗܘܢ ܡܘܫܐ ܘܢܒܝܐ ܢܫܡܥܘܢ ܐܢܘܢ ܀",
