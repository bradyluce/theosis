  },
  "verses": [
    {
      "id": "peshitta:luke.16.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Luke 16:1",
      "text": "ܘܐܡܪ ܡܬܠܐ ܠܘܬ ܬܠܡܝܕܘܗܝ ܓܒܪܐ ܚܕ ܐܝܬ ܗܘܐ ܥܬܝܪܐ ܘܐܝܬ ܗܘܐ ܠܗ ܪܒܝܬܐ ܘܐܬܐܟܠܘ ܠܗ ܩܪܨܘܗܝ ܕܩܢܝܢܗ ܡܦܪܚ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.16.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Luke 16:2",
      "text": "ܘܩܪܝܗܝ ܡܪܗ ܘܐܡܪ ܠܗ ܡܢܘ ܗܢܐ ܕܫܡܥ ܐܢܐ ܥܠܝܟ ܗܒ ܠܝ ܚܘܫܒܢܐ ܕܪܒܬ ܒܝܬܘܬܟ ܠܐ ܓܝܪ ܡܫܟܚ ܐܢܬ ܡܟܝܠ ܪܒܝܬܐ ܕܬܗܘܐ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Luke 16:3",
      "text": "ܐܡܪ ܗܘ ܪܒܝܬܐ ܒܢܦܫܗ ܡܢܐ ܐܥܒܕ ܕܡܪܝ ܫܩܠ ܠܗ ܡܢܝ ܪܒܬ ܒܝܬܘܬܐ ܕܐܚܦܘܪ ܠܐ ܡܫܟܚ ܐܢܐ ܘܠܡܚܕܪ ܒܗܬ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Luke 16:4",
      "text": "ܝܕܥܬ ܡܢܐ ܐܥܒܕ ܕܡܐ ܕܢܦܩܬ ܡܢ ܪܒܬ ܒܝܬܘܬܐ ܢܩܒܠܘܢܢܝ ܒܒܬܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Luke 16:5",
      "text": "ܘܩܪܐ ܚܕ ܚܕ ܡܢ ܚܝܒܐ ܕܡܪܗ ܘܐܡܪ ܠܩܕܡܝܐ ܟܡܐ ܚܝܒ ܐܢܬ ܠܡܪܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Luke 16:6",
      "text": "ܐܡܪ ܠܗ ܡܐܐ ܡܬܪܝܢ ܡܫܚܐ ܐܡܪ ܠܗ ܤܒ ܟܬܒܟ ܘܬܒ ܒܥܓܠ ܟܬܘܒ ܚܡܫܝܢ ܡܬܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Luke 16:7",
      "text": "ܘܐܡܪ ܠܐܚܪܢܐ ܘܐܢܬ ܡܢܐ ܚܝܒ ܐܢܬ ܠܡܪܝ ܐܡܪ ܠܗ ܡܐܐ ܟܘܪܝܢ ܚܛܐ ܐܡܪ ܠܗ ܩܒܠ ܟܬܒܟ ܘܬܒ ܟܬܘܒ ܬܡܢܐܝܢ ܟܘܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Luke 16:8",
      "text": "ܘܫܒܚ ܡܪܢ ܠܪܒܝܬܐ ܕܥܘܠܐ ܕܚܟܝܡܐܝܬ ܥܒܕ ܒܢܘܗܝ ܓܝܪ ܕܥܠܡܐ ܗܢܐ ܚܟܝܡܝܢ ܐܢܘܢ ܡܢ ܒܢܘܗܝ ܕܢܘܗܪܐ ܒܫܪܒܬܗܘܢ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Luke 16:9",
      "text": "ܘܐܦ ܐܢܐ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܥܒܕܘ ܠܟܘܢ ܪܚܡܐ ܡܢ ܡܡܘܢܐ ܗܢܐ ܕܥܘܠܐ ܕܡܐ ܕܓܡܪ ܢܩܒܠܘܢܟܘܢ ܒܡܛܠܝܗܘܢ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Luke 16:10",
      "text": "ܡܢ ܕܒܩܠܝܠ ܡܗܝܡܢ ܐܦ ܒܤܓܝ ܡܗܝܡܢ ܗܘ ܘܡܢ ܕܒܩܠܝܠ ܥܘܠ ܐܦ ܒܤܓܝ ܥܘܠ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Luke 16:11",
      "text": "ܐܢ ܗܟܝܠ ܒܡܡܘܢܐ ܕܥܘܠܐ ܡܗܝܡܢܐ ܠܐ ܗܘܝܬܘܢ ܫܪܪܐ ܠܟܘܢ ܡܢܘ ܡܗܝܡܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Luke 16:12",
      "text": "ܘܐܢ ܒܕܠܐ ܕܝܠܟܘܢ ܠܐ ܐܫܬܟܚܬܘܢ ܡܗܝܡܢܐ ܕܝܠܟܘܢ ܡܢܘ ܢܬܠ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.13",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Luke 16:13",
      "text": "ܠܝܬ ܥܒܕܐ ܕܡܫܟܚ ܠܬܪܝܢ ܡܪܘܢ ܠܡܦܠܚ ܐܘ ܓܝܪ ܠܚܕ ܢܤܢܐ ܘܠܐܚܪܢܐ ܢܪܚܡ ܐܘ ܠܚܕ ܢܝܩܪ ܘܠܐܚܪܢܐ ܢܫܘܛ ܠܐ ܡܫܟܚܝܢ ܐܢܬܘܢ ܠܡܦܠܚ ܠܐܠܗܐ ܘܠܡܡܘܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Luke 16:14",
      "text": "ܦܪܝܫܐ ܕܝܢ ܟܕ ܫܡܥܘ ܗܠܝܢ ܟܠܗܝܢ ܡܛܠ ܕܪܚܡܝܢ ܗܘܘ ܟܤܦܐ ܡܡܝܩܝܢ ܗܘܘ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Luke 16:15",
      "text": "ܝܫܘܥ ܕܝܢ ܐܡܪ ܠܗܘܢ ܐܢܬܘܢ ܐܢܘܢ ܕܡܙܕܩܝܢ ܢܦܫܗܘܢ ܩܕܡ ܒܢܝ ܐܢܫܐ ܐܠܗܐ ܕܝܢ ܝܕܥ ܠܒܘܬܟܘܢ ܕܡܕܡ ܕܪܡ ܒܝܬ ܒܢܝܢܫܐ ܩܕܡ ܐܠܗܐ ܢܕܝܕ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.16",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Luke 16:16",
      "text": "ܢܡܘܤܐ ܘܢܒܝܐ ܥܕܡܐ ܠܝܘܚܢܢ ܡܢ ܗܝܕܝܢ ܡܠܟܘܬܐ ܕܐܠܗܐ ܡܤܬܒܪܐ ܘܟܠ ܠܗ ܚܒܨ ܕܢܥܘܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.17",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Luke 16:17",
      "text": "ܦܫܝܩ ܗܘ ܕܝܢ ܕܫܡܝܐ ܘܐܪܥܐ ܢܥܒܪܘܢ ܐܘ ܐܬܘܬܐ ܚܕܐ ܡܢ ܢܡܘܤܐ ܬܥܒܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.18",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Luke 16:18",
      "text": "ܟܠ ܡܢ ܕܫܪܐ ܐܢܬܬܗ ܘܢܤܒ ܐܚܪܬܐ ܓܐܪ ܘܟܠ ܡܢ ܕܢܤܒ ܫܒܝܩܬܐ ܓܐܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.19",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Luke 16:19",
      "text": "ܓܒܪܐ ܕܝܢ ܚܕ ܥܬܝܪܐ ܐܝܬ ܗܘܐ ܘܠܒܫ ܗܘܐ ܒܘܨܐ ܘܐܪܓܘܢܐ ܘܟܠܝܘܡ ܡܬܒܤܡܝܢ ܗܘܐ ܓܐܝܐܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.20",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Luke 16:20",
      "text": "ܘܡܤܟܢܐ ܚܕ ܐܝܬ ܗܘܐ ܕܫܡܗ ܠܥܙܪ ܘܪܡܐ ܗܘܐ ܠܘܬ ܬܪܥܗ ܕܗܘ ܥܬܝܪܐ ܟܕ ܡܡܚܝ ܒܫܘܚܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.21",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "Luke 16:21",
      "text": "ܘܡܬܝܐܒ ܗܘܐ ܕܢܡܠܐ ܟܪܤܗ ܡܢ ܦܪܬܘܬܐ ܕܢܦܠܝܢ ܡܢ ܦܬܘܪܗ ܕܗܘ ܥܬܝܪܐ ܐܠܐ ܐܦ ܟܠܒܐ ܐܬܝܢ ܗܘܘ ܡܠܚܟܝܢ ܫܘܚܢܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.22",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "Luke 16:22",
      "text": "ܗܘܐ ܕܝܢ ܘܡܝܬ ܗܘ ܡܤܟܢܐ ܘܐܘܒܠܘܗܝ ܡܠܐܟܐ ܠܥܘܒܗ ܕܐܒܪܗܡ ܐܦ ܗܘ ܕܝܢ ܥܬܝܪܐ ܡܝܬ ܘܐܬܩܒܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.23",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "Luke 16:23",
      "text": "ܘܟܕ ܡܫܬܢܩ ܒܫܝܘܠ ܐܪܝܡ ܥܝܢܘܗܝ ܡܢ ܪܘܚܩܐ ܘܚܙܐ ܠܐܒܪܗܡ ܘܠܠܥܙܪ ܒܥܘܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.24",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "Luke 16:24",
      "text": "ܘܩܪܐ ܒܩܠܐ ܪܡܐ ܘܐܡܪ ܐܒܝ ܐܒܪܗܡ ܐܬܪܚܡ ܥܠܝ ܘܫܕܪ ܠܠܥܙܪ ܕܢܨܒܘܥ ܪܝܫ ܨܒܥܗ ܒܡܝܐ ܘܢܪܛܒ ܠܝ ܠܫܢܝ ܕܗܐ ܡܫܬܢܩ ܐܢܐ ܒܫܠܗܒܝܬܐ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.25",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 25,
      "referenceLabel": "Luke 16:25",
      "text": "ܐܡܪ ܠܗ ܐܒܪܗܡ ܒܪܝ ܐܬܕܟܪ ܕܩܒܠܬ ܛܒܬܟ ܒܚܝܝܟ ܘܠܥܙܪ ܒܝܫܬܗ ܘܗܫܐ ܗܐ ܡܬܬܢܝܚ ܗܪܟܐ ܘܐܢܬ ܡܫܬܢܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.26",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 26,
      "referenceLabel": "Luke 16:26",
      "text": "ܘܥܡ ܗܠܝܢ ܟܠܗܝܢ ܗܘܬܐ ܪܒܬܐ ܤܝܡܐ ܒܝܢܝܢ ܘܠܟܘܢ ܕܐܝܠܝܢ ܕܨܒܝܢ ܡܟܐ ܕܢܥܒܪܘܢ ܠܘܬܟܘܢ ܠܐ ܢܫܟܚܘܢ ܘܐܦܠܐ ܕܡܢ ܬܡܢ ܢܥܒܪܘܢ ܠܘܬܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.27",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 27,
      "referenceLabel": "Luke 16:27",
      "text": "ܐܡܪ ܠܗ ܡܕܝܢ ܒܥܐ ܐܢܐ ܡܢܟ ܐܒܝ ܕܬܫܕܪܝܘܗܝ ܠܒܝܬ ܐܒܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.16.28",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 28,
      "referenceLabel": "Luke 16:28",
      "text": "ܚܡܫܐ ܓܝܪ ܐܚܝܢ ܐܝܬ ܠܝ ܢܐܙܠ ܢܤܗܕ ܐܢܘܢ ܕܠܐ ܐܦ ܗܢܘܢ ܢܐܬܘܢ ܠܕܘܟܬܐ ܗܕܐ ܕܬܫܢܝܩܐ ܀",
      "paragraphStart": false
