    {
      "id": "peshitta:luke.16.30",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 16,
      "verseNumber": 30,
      "referenceLabel": "Luke 16:30",
      "text": "ܗܘ ܕܝܢ ܐܡܪ ܠܗ ܠܐ ܐܒܝ ܐܒܪܗܡ ܐܠܐ ܐܢ ܐܢܫ ܡܢ ܡܝܬܐ ܢܐܙܠ ܠܘܬܗܘܢ ܬܝܒܝܢ ܀",
      "paragraphStart": false
