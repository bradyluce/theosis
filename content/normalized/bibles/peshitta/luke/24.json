{
  "chapter": {
    "id": "peshitta:luke.24",
    "translationId": "peshitta",
    "bookSlug": "luke",
    "chapterNumber": 24,
    "referenceLabel": "Luke 24",
    "summary": "Source text for Luke 24 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:luke.24.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Luke 24:1",
      "text": "ܒܚܕ ܒܫܒܐ ܕܝܢ ܒܫܦܪܐ ܥܕ ܚܫܘܟ ܐܬܝ ܠܒܝܬ ܩܒܘܪܐ ܘܐܝܬܝ ܗܪܘܡܐ ܗܠܝܢ ܕܛܝܒ ܗܘܝ ܘܐܝܬ ܗܘܝ ܥܡܗܝܢ ܢܫܐ ܐܚܪܢܝܬܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.24.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Luke 24:2",
      "text": "ܘܐܫܟܚ ܟܐܦܐ ܕܡܥܓܠܐ ܡܢ ܒܝܬ ܩܒܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Luke 24:3",
      "text": "ܘܥܠܝܢ ܘܠܐ ܐܫܟܚܝܗܝ ܠܦܓܪܐ ܕܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Luke 24:4",
      "text": "ܘܗܘܐ ܕܟܕ ܗܢܝܢ ܬܡܝܗܢ ܥܠ ܗܕܐ ܗܐ ܬܪܝܢ ܓܒܪܝܢ ܩܡܘ ܠܥܠ ܡܢܗܝܢ ܘܡܒܪܩ ܗܘܐ ܠܒܘܫܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Luke 24:5",
      "text": "ܘܗܘܝ ܒܕܚܠܬܐ ܘܟܦܝ ܐܦܝܗܝܢ ܒܐܪܥܐ ܘܐܡܪܝܢ ܠܗܝܢ ܡܢܐ ܒܥܝܢ ܐܢܬܝܢ ܚܝܐ ܥܡ ܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Luke 24:6",
      "text": "ܠܝܬܘܗܝ ܬܢܢ ܩܡ ܠܗ ܥܗܕܝܢ ܕܡܠܠ ܥܡܟܝܢ ܟܕ ܗܘ ܒܓܠܝܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Luke 24:7",
      "text": "ܘܐܡܪ ܗܘܐ ܕܥܬܝܕ ܗܘ ܒܪܗ ܕܐܢܫܐ ܕܢܫܬܠܡ ܒܐܝܕܝ ܐܢܫܐ ܚܛܝܐ ܘܢܨܛܠܒ ܘܠܬܠܬܐ ܝܘܡܝܢ ܢܩܘܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Luke 24:8",
      "text": "ܘܗܢܝܢ ܐܬܕܟܪܝܢ ܠܡܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Luke 24:9",
      "text": "ܘܗܦܟ ܡܢ ܩܒܪܐ ܘܐܡܪܝܢ ܗܠܝܢ ܟܠܗܝܢ ܠܚܕܥܤܪ ܘܠܫܪܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Luke 24:10",
      "text": "ܐܝܬܝܗܝܢ ܗܘܝ ܕܝܢ ܡܪܝܡ ܡܓܕܠܝܬܐ ܘܝܘܚܢ ܘܡܪܝܡ ܐܡܗ ܕܝܥܩܘܒ ܘܫܪܟܐ ܕܥܡܗܝܢ ܗܠܝܢ ܕܐܡܪ ܗܘܝ ܠܫܠܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 11,
      "referenceLabel": "Luke 24:11",
      "text": "ܘܐܬܚܙܝ ܒܥܝܢܝܗܘܢ ܡܠܐ ܗܠܝܢ ܐܝܟ ܫܢܝܬܐ ܘܠܐ ܗܝܡܢܘ ܐܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 12,
      "referenceLabel": "Luke 24:12",
      "text": "ܫܡܥܘܢ ܕܝܢ ܩܡ ܘܪܗܛ ܠܩܒܪܐ ܘܐܕܝܩ ܚܙܐ ܟܬܢܐ ܕܤܝܡܝܢ ܒܠܚܘܕ ܘܐܙܠ ܟܕ ܡܬܕܡܪ ܒܢܦܫܗ ܥܠ ܡܕܡ ܕܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.13",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 13,
      "referenceLabel": "Luke 24:13",
      "text": "ܘܗܐ ܬܪܝܢ ܡܢܗܘܢ ܒܗ ܒܝܘܡܐ ܐܙܠܝܢ ܗܘܘ ܠܩܪܝܬܐ ܕܫܡܗ ܥܡܐܘܤ ܘܦܪܝܩܐ ܡܢ ܐܘܪܫܠܡ ܐܤܛܕܘܬܐ ܫܬܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 14,
      "referenceLabel": "Luke 24:14",
      "text": "ܘܗܢܘܢ ܡܡܠܠܝܢ ܗܘܘ ܚܕ ܥܡ ܚܕ ܥܠ ܗܠܝܢ ܟܠܗܝܢ ܕܓܕܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 15,
      "referenceLabel": "Luke 24:15",
      "text": "ܘܟܕ ܗܢܘܢ ܡܡܠܠܝܢ ܘܒܥܝܢ ܚܕ ܥܡ ܚܕ ܐܬܐ ܗܘ ܝܫܘܥ ܘܡܛܝ ܐܢܘܢ ܘܡܗܠܟ ܗܘܐ ܥܡܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.16",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 16,
      "referenceLabel": "Luke 24:16",
      "text": "ܘܥܝܢܝܗܘܢ ܐܚܝܕܢ ܗܘܝ ܕܠܐ ܢܤܬܟܠܘܢܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.17",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 17,
      "referenceLabel": "Luke 24:17",
      "text": "ܘܐܡܪ ܠܗܘܢ ܡܢܐ ܐܢܝܢ ܡܠܐ ܗܠܝܢ ܕܡܡܠܠܝܢ ܐܢܬܘܢ ܚܕ ܥܡ ܚܕ ܟܕ ܡܗܠܟܝܢ ܐܢܬܘܢ ܘܟܡܝܪܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.18",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 18,
      "referenceLabel": "Luke 24:18",
      "text": "ܥܢܐ ܚܕ ܡܢܗܘܢ ܕܫܡܗ ܩܠܝܘܦܐ ܘܐܡܪ ܠܗ ܐܢܬ ܗܘ ܟܝ ܒܠܚܘܕܝܟ ܢܘܟܪܝܐ ܡܢ ܐܘܪܫܠܡ ܕܠܐ ܝܕܥ ܐܢܬ ܡܕܡ ܕܗܘܐ ܒܗ ܒܗܢܘܢ ܝܘܡܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.19",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 19,
      "referenceLabel": "Luke 24:19",
      "text": "ܐܡܪ ܠܗܘܢ ܡܢܐ ܐܡܪܝܢ ܠܗ ܥܠ ܝܫܘܥ ܗܘ ܕܡܢ ܢܨܪܬ ܓܒܪܐ ܕܗܘܐ ܢܒܝܐ ܘܚܝܠܬܢ ܗܘܐ ܒܡܠܬܐ ܘܒܥܒܕܐ ܩܕܡ ܐܠܗܐ ܘܩܕܡ ܟܘܠܗ ܥܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.20",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 20,
      "referenceLabel": "Luke 24:20",
      "text": "ܘܐܫܠܡܘܗܝ ܪܒܝ ܟܗܢܐ ܘܩܫܝܫܐ ܠܕܝܢܐ ܕܡܘܬܐ ܘܙܩܦܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.21",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 21,
      "referenceLabel": "Luke 24:21",
      "text": "ܚܢܢ ܕܝܢ ܤܒܪܝܢ ܗܘܝܢ ܕܗܘܝܘ ܥܬܝܕ ܗܘܐ ܕܢܦܪܩܝܘܗܝ ܠܐܝܤܪܝܠ ܘܗܐ ܬܠܬܐ ܝܘܡܝܢ ܗܐ ܡܢ ܕܗܠܝܢ ܟܠܗܝܢ ܗܘܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.22",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 22,
      "referenceLabel": "Luke 24:22",
      "text": "ܐܠܐ ܐܦ ܢܫܐ ܡܢܢ ܐܬܡܗܢ ܩܕܡ ܗܘܝ ܓܝܪ ܠܒܝܬ ܩܒܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.23",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 23,
      "referenceLabel": "Luke 24:23",
      "text": "ܘܟܕ ܠܐ ܐܫܟܚ ܦܓܪܗ ܐܬܝ ܐܡܪܢ ܠܢ ܕܡܠܐܟܐ ܚܙܝܢ ܬܡܢ ܘܐܡܪܝܢ ܥܠܘܗܝ ܕܚܝ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.24",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 24,
      "referenceLabel": "Luke 24:24",
      "text": "ܘܐܦ ܐܢܫܐ ܡܢܢ ܐܙܠܘ ܠܒܝܬ ܩܒܘܪܐ ܘܐܫܟܚܘ ܗܟܢܐ ܐܝܟ ܡܐ ܕܐܡܪ ܢܫܐ ܠܗ ܕܝܢ ܠܐ ܚܙܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.25",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 25,
      "referenceLabel": "Luke 24:25",
      "text": "ܗܝܕܝܢ ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܐܘ ܚܤܝܪܝ ܪܥܝܢܐ ܘܝܩܝܪܝ ܠܒܐ ܠܡܗܝܡܢܘ ܒܟܠܗܝܢ ܐܝܠܝܢ ܕܡܠܠܘ ܢܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.26",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 26,
      "referenceLabel": "Luke 24:26",
      "text": "ܠܐ ܗܘܐ ܗܠܝܢ ܥܬܝܕ ܗܘܐ ܕܢܤܝܒܪ ܡܫܝܚܐ ܘܕܢܥܘܠ ܠܬܫܒܘܚܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.27",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 27,
      "referenceLabel": "Luke 24:27",
      "text": "ܘܫܪܝ ܗܘܐ ܡܢ ܡܘܫܐ ܘܡܢ ܟܠܗܘܢ ܢܒܝܐ ܘܡܦܫܩ ܗܘܐ ܠܗܘܢ ܥܠ ܢܦܫܗ ܡܢ ܟܠܗܘܢ ܟܬܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.28",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 28,
      "referenceLabel": "Luke 24:28",
      "text": "ܘܩܪܒܘ ܗܘܘ ܠܩܪܝܬܐ ܗܝ ܕܐܙܠܝܢ ܗܘܘ ܠܗ ܘܗܘ ܡܤܒܪ ܗܘܐ ܠܗܘܢ ܕܐܝܟ ܕܠܕܘܟܐ ܪܚܝܩܐ ܐܙܠ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.29",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 29,
      "referenceLabel": "Luke 24:29",
      "text": "ܘܐܠܨܘܗܝ ܘܐܡܪܝܢ ܠܗ ܦܘܫ ܠܘܬܢ ܡܛܠ ܕܝܘܡܐ ܗܫܐ ܪܟܢ ܠܗ ܠܡܚܫܟ ܘܥܠ ܕܢܩܘܐ ܠܘܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.30",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 30,
      "referenceLabel": "Luke 24:30",
      "text": "ܘܗܘܐ ܕܟܕ ܐܤܬܡܟ ܥܡܗܘܢ ܢܤܒ ܠܚܡܐ ܘܒܪܟ ܘܩܨܐ ܘܝܗܒ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.31",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 31,
      "referenceLabel": "Luke 24:31",
      "text": "ܘܡܚܕܐ ܐܬܦܬܚ ܥܝܢܝܗܘܢ ܘܐܫܬܘܕܥܘܗܝ ܘܗܘ ܐܫܬܩܠ ܠܗ ܡܢܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.32",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 32,
      "referenceLabel": "Luke 24:32",
      "text": "ܘܐܡܪܝܢ ܗܘܘ ܚܕ ܠܚܕ ܠܐ ܗܘܐ ܠܒܢ ܝܩܝܪ ܗܘܐ ܒܓܘܢ ܟܕ ܡܡܠܠ ܥܡܢ ܒܐܘܪܚܐ ܘܡܦܫܩ ܠܢ ܟܬܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.33",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 33,
      "referenceLabel": "Luke 24:33",
      "text": "ܘܩܡܘ ܒܗ ܒܫܥܬܐ ܘܗܦܟܘ ܠܐܘܪܫܠܡ ܘܐܫܟܚܘ ܠܚܕܥܤܪ ܕܟܢܝܫܝܢ ܘܠܐܝܠܝܢ ܕܥܡܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.34",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 34,
      "referenceLabel": "Luke 24:34",
      "text": "ܟܕ ܐܡܪܝܢ ܕܫܪܝܪܐܝܬ ܩܡ ܡܪܢ ܘܐܬܚܙܝ ܠܫܡܥܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.35",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 35,
      "referenceLabel": "Luke 24:35",
      "text": "ܘܐܦ ܗܢܘܢ ܐܫܬܥܝܘ ܐܝܠܝܢ ܕܗܘܝ ܒܐܘܪܚܐ ܘܐܝܟܢܐ ܐܬܝܕܥ ܠܗܘܢ ܟܕ ܩܨܐ ܠܚܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.36",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 36,
      "referenceLabel": "Luke 24:36",
      "text": "ܘܟܕ ܗܠܝܢ ܡܡܠܠܝܢ ܗܘܘ ܝܫܘܥ ܩܡ ܒܝܢܬܗܘܢ ܘܐܡܪ ܠܗܘܢ ܫܠܡܐ ܥܡܟܘܢ ܐܢܐ ܐܢܐ ܠܐ ܬܕܚܠܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.37",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 37,
      "referenceLabel": "Luke 24:37",
      "text": "ܘܗܢܘܢ ܐܬܪܗܒܘ ܘܗܘܘ ܒܕܚܠܬܐ ܤܒܪܝܢ ܗܘܘ ܓܝܪ ܕܪܘܚܐ ܚܙܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.24.38",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 38,
      "referenceLabel": "Luke 24:38",
