  },
  "verses": [
    {
      "id": "peshitta:luke.10.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Luke 10:1",
      "text": "ܒܬܪ ܗܠܝܢ ܦܪܫ ܝܫܘܥ ܡܢ ܬܠܡܝܕܘܗܝ ܐܚܪܢܐ ܫܒܥܝܢ ܘܫܕܪ ܐܢܘܢ ܬܪܝܢ ܬܪܝܢ ܩܕܡ ܦܪܨܘܦܗ ܠܟܠ ܐܬܪ ܘܡܕܝܢܐ ܕܥܬܝܕ ܗܘܐ ܠܡܐܙܠ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.10.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Luke 10:2",
      "text": "ܘܐܡܪ ܠܗܘܢ ܚܨܕܐ ܤܓܝ ܘܦܥܠܐ ܙܥܘܪܝܢ ܒܥܘ ܗܟܝܠ ܡܢ ܡܪܐ ܚܨܕܐ ܕܢܦܩ ܦܥܠܐ ܠܚܨܕܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Luke 10:3",
      "text": "ܙܠܘ ܗܐ ܐܢܐ ܡܫܕܪ ܐܢܐ ܠܟܘܢ ܐܝܟ ܐܡܪܐ ܒܝܢܝ ܕܐܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Luke 10:4",
      "text": "ܠܐ ܬܫܩܠܘܢ ܠܟܘܢ ܟܝܤܐ ܘܠܐ ܬܪܡܠܐ ܘܠܐ ܡܤܢܐ ܘܒܫܠܡܐ ܕܐܢܫ ܒܐܘܪܚܐ ܠܐ ܬܫܐܠܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Luke 10:5",
      "text": "ܘܠܐܝܢܐ ܒܝܬܐ ܕܥܐܠܝܢ ܐܢܬܘܢ ܠܘܩܕܡ ܐܡܪܘ ܫܠܡܐ ܠܒܝܬܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Luke 10:6",
      "text": "ܘܐܢ ܐܝܬ ܬܡܢ ܒܪ ܫܠܡܐ ܢܬܬܢܝܚ ܥܠܘܗܝ ܫܠܡܟܘܢ ܐܢ ܕܝܢ ܠܐ ܥܠܝܟܘܢ ܢܗܦܘܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Luke 10:7",
      "text": "ܒܗ ܕܝܢ ܒܒܝܬܐ ܗܘܘ ܟܕ ܠܥܤܝܢ ܐܢܬܘܢ ܘܫܬܝܢ ܡܢ ܕܝܠܗܘܢ ܫܘܐ ܗܘ ܓܝܪ ܦܥܠܐ ܐܓܪܗ ܘܠܐ ܬܫܢܘܢ ܡܢ ܒܝܬܐ ܠܒܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Luke 10:8",
      "text": "ܘܠܐܝܕܐ ܡܕܝܢܬܐ ܕܥܐܠܝܢ ܐܢܬܘܢ ܘܡܩܒܠܝܢ ܠܟܘܢ ܠܥܤܘ ܡܕܡ ܕܡܬܬܤܝܡ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Luke 10:9",
      "text": "ܘܐܤܘ ܠܐܝܠܝܢ ܕܟܪܝܗܝܢ ܒܗ ܘܐܡܪܘ ܠܗܘܢ ܩܪܒܬ ܥܠܝܟܘܢ ܡܠܟܘܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Luke 10:10",
      "text": "ܠܐܝܕܐ ܡܕܝܢܬܐ ܕܝܢ ܕܥܐܠܝܢ ܐܢܬܘܢ ܘܠܐ ܢܩܒܠܘܢܟܘܢ ܦܘܩܘ ܠܟܘܢ ܠܫܘܩܐ ܘܐܡܪܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Luke 10:11",
      "text": "ܘܐܦ ܚܠܐ ܕܕܒܩ ܠܢ ܒܪܓܠܝܢ ܡܢ ܡܕܝܢܬܟܘܢ ܢܦܨܝܢ ܚܢܢ ܠܟܘܢ ܒܪܡ ܗܕܐ ܕܥܘ ܕܩܪܒܬ ܠܗ ܥܠܝܟܘܢ ܡܠܟܘܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Luke 10:12",
      "text": "ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܠܤܕܘܡ ܢܗܘܐ ܢܝܚ ܒܝܘܡܐ ܗܘ ܐܘ ܠܡܕܝܢܬܐ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.13",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Luke 10:13",
      "text": "ܘܝ ܠܟܝ ܟܘܪܙܝܢ ܘܝ ܠܟܝ ܒܝܬ ܨܝܕܐ ܕܐܠܘ ܒܨܘܪ ܘܒܨܝܕܢ ܗܘܘ ܚܝܠܐ ܕܗܘܘ ܒܟܝܢ ܟܒܪ ܕܝܢ ܒܤܩܐ ܘܒܩܛܡܐ ܬܒܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Luke 10:14",
      "text": "ܒܪܡ ܠܨܘܪ ܘܠܨܝܕܢ ܢܗܘܐ ܢܝܚ ܒܕܝܢܐ ܐܘ ܠܟܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Luke 10:15",
      "text": "ܘܐܢܬܝ ܟܦܪܢܚܘܡ ܗܝ ܕܥܕܡܐ ܠܫܡܝܐ ܐܬܬܪܝܡܬܝ ܥܕܡܐ ܠܫܝܘܠ ܬܬܚܬܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.16",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Luke 10:16",
      "text": "ܡܢ ܕܠܟܘܢ ܫܡܥ ܠܝ ܫܡܥ ܘܡܢ ܕܠܟܘܢ ܛܠܡ ܠܝ ܗܘ ܛܠܡ ܘܡܢ ܕܠܝ ܛܠܡ ܛܠܡ ܠܡܢ ܕܫܠܚܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.17",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Luke 10:17",
      "text": "ܘܗܦܟܘ ܗܢܘܢ ܫܒܥܝܢ ܕܫܕܪ ܒܚܕܘܬܐ ܪܒܬܐ ܘܐܡܪܝܢ ܠܗ ܡܪܢ ܐܦ ܫܐܕܐ ܡܫܬܥܒܕܝܢ ܠܢ ܒܫܡܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.18",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Luke 10:18",
      "text": "ܗܘ ܕܝܢ ܐܡܪ ܠܗܘܢ ܚܙܐ ܗܘܝܬ ܠܗ ܠܤܛܢܐ ܕܢܦܠ ܐܝܟ ܒܪܩܐ ܡܢ ܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.19",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Luke 10:19",
      "text": "ܗܐ ܝܗܒ ܐܢܐ ܠܟܘܢ ܫܘܠܛܢܐ ܕܗܘܝܬܘܢ ܕܝܫܝܢ ܚܘܘܬܐ ܘܥܩܪܒܐ ܘܟܠܗ ܚܝܠܗ ܕܒܥܠܕܒܒܐ ܘܡܕܡ ܠܐ ܢܗܪܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.20",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Luke 10:20",
      "text": "ܒܪܡ ܒܗܕܐ ܠܐ ܬܚܕܘܢ ܕܫܐܕܐ ܡܫܬܥܒܕܝܢ ܠܟܘܢ ܐܠܐ ܚܕܘ ܕܫܡܗܝܟܘܢ ܐܬܟܬܒܘ ܒܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.21",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Luke 10:21",
      "text": "ܒܗ ܒܫܥܬܐ ܪܘܙ ܝܫܘܥ ܒܪܘܚܐ ܕܩܘܕܫܐ ܘܐܡܪ ܡܘܕܐ ܐܢܐ ܠܟ ܐܒܝ ܡܪܐ ܕܫܡܝܐ ܘܕܐܪܥܐ ܕܟܤܝܬ ܗܠܝܢ ܡܢ ܚܟܝܡܐ ܘܤܟܘܠܬܢܐ ܘܓܠܝܬ ܐܢܝܢ ܠܝܠܘܕܐ ܐܝܢ ܐܒܝ ܕܗܟܢܐ ܗܘܐ ܨܒܝܢܐ ܩܕܡܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.22",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Luke 10:22",
      "text": "ܘܐܬܦܢܝ ܠܘܬ ܬܠܡܝܕܘܗܝ ܘܐܡܪ ܠܗܘܢ ܟܠ ܡܕܡ ܐܫܬܠܡ ܠܝ ܡܢ ܐܒܝ ܘܠܐ ܐܢܫ ܝܕܥ ܡܢܘ ܒܪܐ ܐܠܐ ܐܢ ܐܒܐ ܘܡܢܘ ܐܒܐ ܐܠܐ ܐܢ ܒܪܐ ܘܠܡܢ ܕܐܢ ܢܨܒܐ ܒܪܐ ܕܢܓܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.23",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Luke 10:23",
      "text": "ܘܐܬܦܢܝ ܠܘܬ ܬܠܡܝܕܘܗܝ ܒܠܚܘܕܝܗܘܢ ܘܐܡܪ ܛܘܒܝܗܝܢ ܠܥܝܢܐ ܕܚܙܝܢ ܡܕܡ ܕܐܢܬܘܢ ܚܙܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.24",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Luke 10:24",
      "text": "ܐܡܪ ܐܢܐ ܠܟܘܢ ܓܝܪ ܕܢܒܝܐ ܤܓܝܐܐ ܘܡܠܟܐ ܨܒܘ ܕܢܚܙܘܢ ܡܕܡ ܕܚܙܝܢ ܐܢܬܘܢ ܘܠܐ ܚܙܘ ܘܠܡܫܡܥ ܡܕܡ ܕܐܢܬܘܢ ܫܡܥܝܢ ܘܠܐ ܫܡܥܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.25",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Luke 10:25",
      "text": "ܘܗܐ ܤܦܪܐ ܚܕ ܩܡ ܕܢܢܤܝܘܗܝ ܘܐܡܪ ܡܠܦܢܐ ܡܢܐ ܐܥܒܕ ܕܐܪܬ ܚܝܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.26",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Luke 10:26",
      "text": "ܗܘ ܕܝܢ ܝܫܘܥ ܐܡܪ ܠܗ ܒܢܡܘܤܐ ܐܝܟܢܐ ܟܬܝܒ ܐܝܟܢܐ ܩܪܐ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.27",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Luke 10:27",
      "text": "ܥܢܐ ܘܐܡܪ ܠܗ ܕܬܪܚܡ ܠܡܪܝܐ ܐܠܗܟ ܡܢ ܟܠܗ ܠܒܟ ܘܡܢ ܟܠܗ ܢܦܫܟ ܘܡܢ ܟܠܗ ܚܝܠܟ ܘܡܢ ܟܠܗ ܪܥܝܢܟ ܘܠܩܪܝܒܟ ܐܝܟ ܢܦܫܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.28",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Luke 10:28",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܬܪܝܨܐܝܬ ܐܡܪܬ ܗܕܐ ܥܒܕ ܘܬܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.29",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Luke 10:29",
      "text": "ܗܘ ܕܝܢ ܟܕ ܨܒܐ ܠܡܙܕܩܘ ܢܦܫܗ ܐܡܪ ܠܗ ܘܡܢܘ ܩܪܝܒܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.30",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Luke 10:30",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܓܒܪܐ ܚܕ ܢܚܬ ܗܘܐ ܡܢ ܐܘܪܫܠܡ ܠܐܝܪܝܚܘ ܘܢܦܠܘ ܥܠܘܗܝ ܠܤܛܝܐ ܘܫܠܚܘܗܝ ܘܡܚܐܘܗܝ ܘܫܒܩܘܗܝ ܟܕ ܩܠܝܠ ܩܝܡܐ ܒܗ ܢܦܫܐ ܘܐܙܠܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.31",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Luke 10:31",
      "text": "ܘܓܕܫ ܟܗܢܐ ܚܕ ܢܚܬ ܗܘܐ ܒܐܘܪܚܐ ܗܝ ܘܚܙܝܗܝ ܘܥܒܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.32",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Luke 10:32",
      "text": "ܘܗܟܢܐ ܐܦ ܠܘܝܐ ܐܬܐ ܡܛܐ ܠܗܝ ܕܘܟܬܐ ܘܚܙܝܗܝ ܘܥܒܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.33",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "Luke 10:33",
      "text": "ܐܢܫ ܕܝܢ ܫܡܪܝܐ ܟܕ ܪܕܐ ܗܘܐ ܐܬܐ ܐܝܟܐ ܕܐܝܬܘܗܝ ܗܘܐ ܘܚܙܝܗܝ ܘܐܬܪܚܡ ܥܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.34",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 34,
      "referenceLabel": "Luke 10:34",
      "text": "ܘܐܬܩܪܒ ܘܥܨܒ ܡܚܘܬܗ ܘܢܨܠ ܥܠܝܗܝܢ ܚܡܪܐ ܘܡܫܚܐ ܘܤܡܗ ܥܠ ܚܡܪܗ ܘܐܝܬܝܗ ܠܦܘܬܩܐ ܘܐܬܒܛܠ ܠܗ ܥܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.10.35",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 10,
      "verseNumber": 35,
      "referenceLabel": "Luke 10:35",
      "text": "ܘܠܨܦܪܗ ܕܝܘܡܐ ܐܦܩ ܬܪܝܢ ܕܝܢܪܝܢ ܝܗܒ ܠܦܘܬܩܝܐ ܘܐܡܪ ܠܗ ܝܨܦ ܕܝܠܗ ܘܐܢ ܡܕܡ ܝܬܝܪ ܬܦܩ ܡܐ ܕܗܦܟ ܐܢܐ ܝܗܒ ܐܢܐ ܠܟ ܀",
      "paragraphStart": false
    },
