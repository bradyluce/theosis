{
  "chapter": {
    "id": "peshitta:luke.15",
    "translationId": "peshitta",
    "bookSlug": "luke",
    "chapterNumber": 15,
    "referenceLabel": "Luke 15",
    "summary": "Source text for Luke 15 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:luke.15.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Luke 15:1",
      "text": "ܡܬܩܪܒܝܢ ܗܘܘ ܕܝܢ ܠܘܬܗ ܡܟܤܐ ܘܚܛܝܐ ܕܢܫܡܥܘܢܝܗܝ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.15.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Luke 15:2",
      "text": "ܘܤܦܪܐ ܘܦܪܝܫܐ ܪܛܢܝܢ ܗܘܘ ܘܐܡܪܝܢ ܗܢܐ ܠܚܛܝܐ ܡܩܒܠ ܘܐܟܠ ܥܡܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Luke 15:3",
      "text": "ܘܐܡܪ ܠܗܘܢ ܝܫܘܥ ܡܬܠܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Luke 15:4",
      "text": "ܡܢܘ ܡܢܟܘܢ ܓܒܪܐ ܕܐܝܬ ܠܗ ܡܐܐ ܥܪܒܝܢ ܘܐܢ ܢܐܒܕ ܚܕ ܡܢܗܘܢ ܠܐ ܫܒܩ ܬܫܥܝܢ ܘܬܫܥܐ ܒܕܒܪܐ ܘܐܙܠ ܒܥܐ ܠܗܘ ܕܐܒܕ ܥܕܡܐ ܕܢܫܟܚܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Luke 15:5",
      "text": "ܘܡܐ ܕܐܫܟܚܗ ܚܕܐ ܘܫܩܠ ܠܗ ܥܠ ܟܬܦܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Luke 15:6",
      "text": "ܘܐܬܐ ܠܒܝܬܗ ܘܩܪܐ ܠܪܚܡܘܗܝ ܘܠܫܒܒܘܗܝ ܘܐܡܪ ܠܗܘܢ ܚܕܘ ܥܡܝ ܕܐܫܟܚܬ ܥܪܒܝ ܕܐܒܝܕ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Luke 15:7",
      "text": "ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܗܟܢܐ ܬܗܘܐ ܚܕܘܬܐ ܒܫܡܝܐ ܥܠ ܚܕ ܚܛܝܐ ܕܬܐܒ ܐܘ ܥܠ ܬܫܥܝܢ ܘܬܫܥܐ ܙܕܝܩܝܢ ܕܠܐ ܡܬܒܥܝܐ ܠܗܘܢ ܬܝܒܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Luke 15:8",
      "text": "ܐܘ ܐܝܕܐ ܗܝ ܐܢܬܬܐ ܕܐܝܬ ܠܗ ܥܤܪܐ ܙܘܙܝܢ ܘܬܘܒܕ ܚܕ ܡܢܗܘܢ ܘܠܐ ܡܢܗܪܐ ܫܪܓܐ ܘܚܡܐ ܒܝܬܐ ܘܒܥܝܐ ܠܗ ܒܛܝܠܐܝܬ ܥܕܡܐ ܕܬܫܟܚܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Luke 15:9",
      "text": "ܘܡܐ ܕܐܫܟܚܬܗ ܩܪܝܐ ܠܪܚܡܬܗ ܘܠܫܒܒܬܗ ܘܐܡܪܐ ܠܗܝܢ ܚܕܝܝܢ ܥܡܝ ܕܐܫܟܚܬ ܙܘܙܝ ܕܐܒܝܕ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Luke 15:10",
      "text": "ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܗܟܢܐ ܬܗܘܐ ܚܕܘܬܐ ܩܕܡ ܡܠܐܟܘܗܝ ܕܐܠܗܐ ܥܠ ܚܕ ܚܛܝܐ ܕܬܐܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Luke 15:11",
      "text": "ܘܐܡܪ ܗܘܐ ܠܗܘܢ ܬܘܒ ܝܫܘܥ ܠܓܒܪܐ ܚܕ ܐܝܬ ܗܘܐ ܠܗ ܒܢܝܐ ܬܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Luke 15:12",
      "text": "ܘܐܡܪ ܠܗ ܒܪܗ ܙܥܘܪܐ ܐܒܝ ܗܒ ܠܝ ܦܠܓܘܬܐ ܕܡܛܝܐ ܠܝ ܡܢ ܒܝܬܟ ܘܦܠܓ ܠܗܘܢ ܩܢܝܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.13",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Luke 15:13",
      "text": "ܘܡܢ ܒܬܪ ܝܘܡܬܐ ܩܠܝܠ ܟܢܫ ܗܘ ܒܪܗ ܙܥܘܪܐ ܟܠ ܡܕܡ ܕܡܛܝܗܝ ܘܐܙܠ ܠܐܬܪܐ ܪܚܝܩܐ ܘܬܡܢ ܒܕܪ ܩܢܝܢܗ ܟܕ ܚܝܐ ܦܪܚܐܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Luke 15:14",
      "text": "ܘܟܕ ܓܡܪ ܟܠ ܡܕܡ ܕܐܝܬ ܗܘܐ ܠܗ ܗܘܐ ܟܦܢܐ ܪܒܐ ܒܐܬܪܐ ܗܘ ܘܫܪܝ ܚܤܪ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Luke 15:15",
      "text": "ܘܐܙܠ ܢܩܦ ܠܗ ܠܚܕ ܡܢ ܒܢܝ ܡܕܝܢܬܐ ܕܐܬܪܐ ܗܘ ܘܗܘ ܫܕܪܗ ܠܩܪܝܬܐ ܠܡܪܥܐ ܚܙܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.16",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Luke 15:16",
      "text": "ܘܡܬܪܓܪܓ ܗܘܐ ܠܡܡܠܐ ܟܪܤܗ ܡܢ ܚܪܘܒܐ ܗܢܘܢ ܕܐܟܠܝܢ ܗܘܘ ܚܙܝܪܐ ܘܠܐ ܐܢܫ ܝܗܒ ܗܘܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.17",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Luke 15:17",
      "text": "ܘܟܕ ܐܬܐ ܠܘܬ ܢܦܫܗ ܐܡܪ ܟܡܐ ܗܫܐ ܐܓܝܪܐ ܐܝܬ ܒܝܬ ܐܒܝ ܕܝܬܝܪ ܠܗܘܢ ܠܚܡܐ ܘܐܢܐ ܗܪܟܐ ܠܟܦܢܝ ܐܒܕ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.18",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Luke 15:18",
      "text": "ܐܩܘܡ ܐܙܠ ܠܘܬ ܐܒܝ ܘܐܡܪ ܠܗ ܐܒܝ ܚܛܝܬ ܒܫܡܝܐ ܘܩܕܡܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.19",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Luke 15:19",
      "text": "ܘܠܐ ܡܟܝܠ ܫܘܐ ܐܢܐ ܕܒܪܟ ܐܬܩܪܐ ܥܒܕܝܢܝ ܐܝܟ ܚܕ ܡܢ ܐܓܝܪܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.20",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Luke 15:20",
      "text": "ܘܩܡ ܐܬܐ ܠܘܬ ܐܒܘܗܝ ܘܥܕ ܗܘ ܪܚܝܩ ܚܙܝܗܝ ܐܒܘܗܝ ܘܐܬܪܚܡ ܥܠܘܗܝ ܘܪܗܛ ܢܦܠ ܥܠ ܨܘܪܗ ܘܢܫܩܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.21",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Luke 15:21",
      "text": "ܘܐܡܪ ܠܗ ܒܪܗ ܐܒܝ ܚܛܝܬ ܒܫܡܝܐ ܘܩܕܡܝܟ ܘܠܐ ܫܘܐ ܐܢܐ ܕܒܪܟ ܐܬܩܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.22",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Luke 15:22",
      "text": "ܐܡܪ ܕܝܢ ܐܒܘܗܝ ܠܥܒܕܘܗܝ ܐܦܩܘ ܐܤܛܠܐ ܪܫܝܬܐ ܐܠܒܫܘܗܝ ܘܤܝܡܘ ܥܙܩܬܐ ܒܐܝܕܗ ܘܐܤܐܢܘܗܝ ܡܤܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.23",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Luke 15:23",
      "text": "ܘܐܝܬܘ ܩܛܘܠܘ ܬܘܪܐ ܕܦܛܡܐ ܘܢܐܟܘܠ ܘܢܬܒܤܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.24",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Luke 15:24",
      "text": "ܕܗܢܐ ܒܪܝ ܡܝܬܐ ܗܘܐ ܘܚܝܐ ܘܐܒܝܕܐ ܗܘܐ ܘܐܫܬܟܚ ܘܫܪܝܘ ܠܡܬܒܤܡܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.25",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Luke 15:25",
      "text": "ܗܘ ܕܝܢ ܒܪܗ ܩܫܝܫܐ ܒܩܪܝܬܐ ܗܘܐ ܘܟܕ ܐܬܐ ܘܩܪܒ ܠܘܬ ܒܝܬܐ ܫܡܥ ܩܠ ܙܡܪܐ ܕܤܓܝܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.26",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Luke 15:26",
      "text": "ܘܩܪܐ ܠܚܕ ܡܢ ܛܠܝܐ ܘܫܐܠܗ ܡܢܘ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.27",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Luke 15:27",
      "text": "ܐܡܪ ܠܗ ܐܚܘܟ ܐܬܐ ܘܩܛܠ ܐܒܘܟ ܬܘܪܐ ܕܦܛܡܐ ܕܟܕ ܚܠܝܡ ܐܩܒܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.28",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Luke 15:28",
      "text": "ܘܪܓܙ ܘܠܐ ܨܒܐ ܗܘܐ ܠܡܥܠ ܘܢܦܩ ܐܒܘܗܝ ܒܥܐ ܡܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.29",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Luke 15:29",
      "text": "ܗܘ ܕܝܢ ܐܡܪ ܠܐܒܘܗܝ ܗܐ ܟܡܐ ܫܢܝܢ ܦܠܚ ܐܢܐ ܠܟ ܥܒܕܘܬܐ ܘܠܐ ܡܡܬܘܡ ܥܒܪܬ ܦܘܩܕܢܟ ܘܡܢ ܡܬܘܡ ܓܕܝܐ ܠܐ ܝܗܒܬ ܠܝ ܕܐܬܒܤܡ ܥܡ ܪܚܡܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.30",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Luke 15:30",
      "text": "ܠܗܢܐ ܕܝܢ ܒܪܟ ܟܕ ܦܪܚ ܩܢܝܢܟ ܥܡ ܙܢܝܬܐ ܘܐܬܐ ܢܟܤܬ ܠܗ ܬܘܪܐ ܕܦܛܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.31",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Luke 15:31",
      "text": "ܐܡܪ ܠܗ ܐܒܘܗܝ ܒܪܝ ܐܢܬ ܒܟܠܙܒܢ ܥܡܝ ܐܢܬ ܘܟܠܡܕܡ ܕܝܠܝ ܕܝܠܟ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.15.32",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Luke 15:32",
      "text": "ܠܡܒܤܡ ܕܝܢ ܘܠܐ ܗܘܐ ܠܢ ܘܠܡܚܕܐ ܕܗܢܐ ܐܚܘܟ ܡܝܬܐ ܗܘܐ ܘܚܝܐ ܘܐܒܝܕܐ ܗܘܐ ܘܐܫܬܟܚ ܀",
      "paragraphStart": false
    }
  ]
}
