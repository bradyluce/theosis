  "verses": [
    {
      "id": "peshitta:luke.3.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Luke 3:1",
      "text": "ܒܫܢܬ ܚܡܫܥܤܪܐ ܕܝܢ ܕܡܠܟܘܬܗ ܕܛܝܒܪܝܘܤ ܩܤܪ ܒܗܓܡܢܘܬܐ ܕܦܢܛܝܘܤ ܦܝܠܛܘܤ ܒܝܗܘܕ ܟܕ ܪܫܐ ܪܒܝܥܝܐ ܗܪܘܕܤ ܒܓܠܝܠܐ ܘܦܝܠܝܦܘܤ ܐܚܘܗܝ ܪܫܐ ܪܒܝܥܝܐ ܒܐܝܛܘܪܝܐ ܘܒܐܬܪܐ ܕܛܪܟܘܢܐ ܘܠܘܤܢܝܐ ܪܫܐ ܪܒܝܥܝܐ ܕܐܒܝܠܝܢܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.3.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Luke 3:2",
      "text": "ܒܪܒܘܬ ܟܗܢܘܬܐ ܕܚܢܢ ܘܕܩܝܦܐ ܗܘܬ ܡܠܬܐ ܕܐܠܗܐ ܥܠ ܝܘܚܢܢ ܒܪ ܙܟܪܝܐ ܒܚܘܪܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.3.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Luke 3:3",
      "text": "ܘܐܬܐ ܒܟܠܗ ܐܬܪܐ ܕܚܕܪܝ ܝܘܪܕܢܢ ܟܕ ܡܟܪܙ ܡܥܡܘܕܝܬܐ ܕܬܝܒܘܬܐ ܠܫܘܒܩܢܐ ܕܚܛܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.3.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Luke 3:4",
      "text": "ܐܝܟܢܐ ܕܟܬܝܒ ܒܟܬܒܐ ܕܡܠܐ ܕܐܫܥܝܐ ܢܒܝܐ ܕܐܡܪ ܩܠܐ ܕܩܪܐ ܒܚܘܪܒܐ ܛܝܒܘ ܐܘܪܚܗ ܕܡܪܝܐ ܘܬܪܘܨܘ ܒܦܩܥܬܐ ܫܒܝܠܐ ܠܐܠܗܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.3.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Luke 3:5",
      "text": "ܟܠܗܘܢ ܢܚܠܐ ܢܬܡܠܘܢ ܘܟܠܗܘܢ ܛܘܪܐ ܘܪܡܬܐ ܢܬܡܟܟܘܢ ܘܢܗܘܐ ܥܪܡܐ ܠܫܦܝܐ ܘܐܬܪܐ ܥܤܩܐ ܠܦܩܥܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.3.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Luke 3:6",
      "text": "ܘܢܚܙܐ ܟܠ ܒܤܪ ܚܝܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.3.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Luke 3:7",
      "text": "ܘܐܡܪ ܗܘܐ ܠܟܢܫܐ ܐܝܠܝܢ ܕܐܬܝܢ ܗܘܘ ܠܘܬܗ ܠܡܥܡܕ ܝܠܕܐ ܕܐܟܕܢܐ ܡܢܘ ܚܘܝܟܘܢ ܠܡܥܪܩ ܡܢ ܪܘܓܙܐ ܕܥܬܝܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.3.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Luke 3:8",
      "text": "ܥܒܕܘ ܗܟܝܠ ܦܐܪܐ ܕܫܘܝܢ ܠܬܝܒܘܬܐ ܘܠܐ ܬܫܪܘܢ ܠܡܐܡܪ ܒܢܦܫܟܘܢ ܕܐܒܐ ܐܝܬ ܠܢ ܐܒܪܗܡ ܐܡܪ ܐܢܐ ܠܟܘܢ ܓܝܪ ܕܡܢ ܗܠܝܢ ܟܐܦܐ ܡܫܟܚ ܐܠܗܐ ܠܡܩܡܘ ܒܢܝܐ ܠܐܒܪܗܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.3.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Luke 3:9",
      "text": "ܗܐ ܕܝܢ ܢܪܓܐ ܤܝܡ ܥܠ ܥܩܪܐ ܕܐܝܠܢܐ ܟܠ ܐܝܠܢܐ ܗܟܝܠ ܕܦܐܪܐ ܛܒܐ ܠܐ ܥܒܕ ܡܬܦܤܩ ܘܒܢܘܪܐ ܢܦܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.3.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Luke 3:10",
      "text": "ܘܡܫܐܠܝܢ ܗܘܘ ܠܗ ܟܢܫܐ ܘܐܡܪܝܢ ܡܢܐ ܗܟܝܠ ܢܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.3.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Luke 3:11",
      "text": "ܥܢܐ ܘܐܡܪ ܠܗܘܢ ܡܢ ܕܐܝܬ ܠܗ ܬܪܬܝܢ ܟܘܬܝܢܝܢ ܢܬܠ ܠܡܢ ܕܠܝܬ ܠܗ ܘܡܢ ܕܐܝܬ ܠܗ ܤܝܒܪܬܐ ܗܟܢܐ ܢܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.3.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Luke 3:12",
      "text": "ܘܐܬܘ ܐܦ ܡܟܤܐ ܠܡܥܡܕ ܘܐܡܪܝܢ ܠܗ ܡܠܦܢܐ ܡܢܐ ܢܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.3.13",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Luke 3:13",
      "text": "ܗܘ ܕܝܢ ܐܡܪ ܠܗܘܢ ܠܐ ܬܬܒܥܘܢ ܡܕܡ ܝܬܝܪ ܥܠ ܡܐ ܕܦܩܝܕ ܠܟܘܢ ܠܡܬܒܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.3.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Luke 3:14",
      "text": "ܘܡܫܐܠܝܢ ܗܘܘ ܠܗ ܦܠܚܝ ܐܤܛܪܛܝܐ ܘܐܡܪܝܢ ܡܢܐ ܢܥܒܕ ܐܦ ܚܢܢ ܐܡܪ ܠܗܘܢ ܠܐ ܒܐܢܫ ܬܬܛܓܪܘܢ ܘܠܐܢܫ ܠܐ ܬܥܫܩܘܢ ܘܢܤܦܩܢ ܠܟܘܢ ܐܦܤܘܢܝܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.3.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Luke 3:15",
      "text": "ܟܕ ܕܝܢ ܡܤܒܪ ܗܘܐ ܥܡܐ ܥܠ ܝܘܚܢܢ ܘܟܠܗܘܢ ܡܬܚܫܒܝܢ ܗܘܘ ܒܠܒܗܘܢ ܕܕܠܡܐ ܗܘܝܘ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.3.16",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Luke 3:16",
      "text": "ܥܢܐ ܝܘܚܢܢ ܘܐܡܪ ܠܗܘܢ ܐܢܐ ܗܐ ܡܥܡܕ ܐܢܐ ܠܟܘܢ ܒܡܝܐ ܐܬܐ ܕܝܢ ܗܘ ܕܚܝܠܬܢ ܡܢܝ ܗܘ ܕܠܐ ܫܘܐ ܐܢܐ ܕܐܫܪܐ ܥܪܩܐ ܕܡܤܢܘܗܝ ܗܘ ܢܥܡܕܟܘܢ ܒܪܘܚܐ ܕܩܘܕܫܐ ܘܒܢܘܪܐ ܀",
      "paragraphStart": false
