    {
      "id": "peshitta:luke.6.31",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 31,
      "referenceLabel": "Luke 6:31",
      "text": "ܘܐܝܟܢܐ ܕܨܒܝܢ ܐܢܬܘܢ ܕܢܥܒܕܘܢ ܠܟܘܢ ܒܢܝ ܐܢܫܐ ܗܟܘܬ ܥܒܕܘ ܠܗܘܢ ܐܦ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.32",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 32,
      "referenceLabel": "Luke 6:32",
      "text": "ܐܢ ܓܝܪ ܡܚܒܝܢ ܐܢܬܘܢ ܠܐܝܠܝܢ ܕܡܚܒܝܢ ܠܟܘܢ ܐܝܕܐ ܗܝ ܛܝܒܘܬܟܘܢ ܐܦ ܓܝܪ ܚܛܝܐ ܠܐܝܠܝܢ ܕܡܚܒܝܢ ܠܗܘܢ ܪܚܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.33",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 33,
      "referenceLabel": "Luke 6:33",
      "text": "ܘܐܢ ܥܒܕܝܢ ܐܢܬܘܢ ܕܛܒ ܠܐܝܠܝܢ ܕܡܛܐܒܝܢ ܠܟܘܢ ܐܝܕܐ ܗܝ ܛܝܒܘܬܟܘܢ ܐܦ ܚܛܝܐ ܓܝܪ ܗܟܢܐ ܥܒܕܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.34",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 34,
      "referenceLabel": "Luke 6:34",
      "text": "ܘܐܢ ܡܘܙܦܝܢ ܐܢܬܘܢ ܠܡܢ ܕܤܒܪܝܢ ܐܢܬܘܢ ܕܬܬܦܪܥܘܢ ܡܢܗ ܐܝܕܐ ܗܝ ܛܝܒܘܬܟܘܢ ܐܦ ܚܛܝܐ ܓܝܪ ܠܚܛܝܐ ܡܘܙܦܝܢ ܕܗܟܘܬ ܢܬܦܪܥܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.35",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 35,
      "referenceLabel": "Luke 6:35",
      "text": "ܒܪܡ ܐܚܒܘ ܠܒܥܠܕܒܒܝܟܘܢ ܘܐܛܐܒܘ ܠܗܘܢ ܘܐܘܙܦܘ ܘܠܐ ܬܦܤܩܘܢ ܤܒܪܐ ܕܐܢܫ ܘܢܗܘܐ ܤܓܝ ܐܓܪܟܘܢ ܘܬܗܘܘܢ ܒܢܘܗܝ ܕܪܡܐ ܕܗܘ ܒܤܝܡ ܗܘ ܥܠ ܒܝܫܐ ܘܥܠ ܟܦܘܪܐ ܀",
      "paragraphStart": false
    },
    {
