  },
  "verses": [
    {
      "id": "peshitta:luke.6.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Luke 6:1",
      "text": "ܗܘܐ ܕܝܢ ܒܫܒܬܐ ܟܕ ܡܗܠܟ ܝܫܘܥ ܒܝܬ ܙܪܥܐ ܬܠܡܝܕܘܗܝ ܡܠܓܝܢ ܗܘܘ ܫܒܠܐ ܘܦܪܟܝܢ ܒܐܝܕܝܗܘܢ ܘܐܟܠܝܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.6.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Luke 6:2",
      "text": "ܐܢܫܝܢ ܕܝܢ ܡܢ ܦܪܝܫܐ ܐܡܪܝܢ ܠܗܘܢ ܡܢܐ ܥܒܕܝܢ ܐܢܬܘܢ ܡܕܡ ܕܠܐ ܫܠܝܛ ܠܡܥܒܕ ܒܫܒܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Luke 6:3",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗܘܢ ܘܠܐ ܗܕܐ ܩܪܝܬܘܢ ܡܕܡ ܕܥܒܕ ܕܘܝܕ ܟܕ ܟܦܢ ܗܘ ܘܐܝܠܝܢ ܕܥܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Luke 6:4",
      "text": "ܕܥܠ ܠܒܝܬܗ ܕܐܠܗܐ ܘܠܚܡܐ ܕܦܬܘܪܗ ܕܡܪܝܐ ܢܤܒ ܐܟܠ ܘܝܗܒ ܠܐܝܠܝܢ ܕܥܡܗ ܗܘ ܕܠܐ ܫܠܝܛ ܗܘܐ ܠܡܐܟܠ ܐܠܐ ܠܟܗܢܐ ܒܠܚܘܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Luke 6:5",
      "text": "ܘܐܡܪ ܠܗܘܢ ܕܡܪܗ ܗܘ ܕܫܒܬܐ ܒܪܗ ܕܐܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Luke 6:6",
      "text": "ܗܘܐ ܕܝܢ ܠܫܒܬܐ ܐܚܪܬܐ ܥܠ ܠܟܢܘܫܬܐ ܘܡܠܦ ܗܘܐ ܘܐܝܬ ܗܘܐ ܬܡܢ ܓܒܪܐ ܕܐܝܕܗ ܕܝܡܝܢܐ ܝܒܝܫܐ ܗܘܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Luke 6:7",
      "text": "ܘܤܦܪܐ ܘܦܪܝܫܐ ܢܛܪܝܢ ܗܘܘ ܠܗ ܕܐܢ ܗܘ ܕܡܐܤܐ ܒܫܒܬܐ ܕܢܫܟܚܘܢ ܢܐܟܠܘܢ ܩܪܨܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Luke 6:8",
      "text": "ܗܘ ܕܝܢ ܝܕܥ ܡܚܫܒܬܗܘܢ ܘܐܡܪ ܠܗܘ ܓܒܪܐ ܕܝܒܝܫܐ ܐܝܕܗ ܩܘܡ ܬܐ ܠܟ ܠܡܨܥܬ ܟܢܘܫܬܐ ܘܟܕ ܐܬܐ ܘܩܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Luke 6:9",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܐܫܐܠܟܘܢ ܡܢܐ ܫܠܝܛ ܒܫܒܬܐ ܕܛܒ ܠܡܥܒܕ ܐܘ ܕܒܝܫ ܢܦܫܐ ܠܡܚܝܘ ܐܘ ܠܡܘܒܕܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Luke 6:10",
      "text": "ܘܚܪ ܒܗܘܢ ܒܟܠܗܘܢ ܘܐܡܪ ܠܗ ܦܫܘܛ ܐܝܕܟ ܘܦܫܛ ܘܬܩܢܬ ܐܝܕܗ ܐܝܟ ܚܒܪܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Luke 6:11",
      "text": "ܗܢܘܢ ܕܝܢ ܐܬܡܠܝܘ ܚܤܡܐ ܘܡܡܠܠܝܢ ܗܘܘ ܚܕ ܥܡ ܚܕ ܕܡܢܐ ܢܥܒܕܘܢ ܠܗ ܠܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Luke 6:12",
      "text": "ܗܘܐ ܕܝܢ ܒܝܘܡܬܐ ܗܢܘܢ ܢܦܩ ܝܫܘܥ ܠܛܘܪܐ ܠܡܨܠܝܘ ܘܬܡܢ ܐܓܗ ܗܘܐ ܒܨܠܘܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.13",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Luke 6:13",
      "text": "ܘܟܕ ܢܓܗܬ ܩܪܐ ܠܬܠܡܝܕܘܗܝ ܘܓܒܐ ܡܢܗܘܢ ܬܪܥܤܪ ܗܢܘܢ ܕܫܠܝܚܐ ܫܡܝ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Luke 6:14",
      "text": "ܫܡܥܘܢ ܗܘ ܕܫܡܝ ܟܐܦܐ ܘܐܢܕܪܐܘܤ ܐܚܘܗܝ ܘܝܥܩܘܒ ܘܝܘܚܢܢ ܘܦܝܠܝܦܘܤ ܘܒܪ ܬܘܠܡܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Luke 6:15",
      "text": "ܘܡܬܝ ܘܬܐܘܡܐ ܘܝܥܩܘܒ ܒܪ ܚܠܦܝ ܘܫܡܥܘܢ ܕܡܬܩܪܐ ܛܢܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.16",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Luke 6:16",
      "text": "ܘܝܗܘܕܐ ܒܪ ܝܥܩܘܒ ܘܝܗܘܕܐ ܤܟܪܝܘܛܐ ܗܘ ܕܗܘܐ ܡܫܠܡܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.17",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Luke 6:17",
      "text": "ܘܢܚܬ ܥܡܗܘܢ ܝܫܘܥ ܘܩܡ ܒܦܩܥܬܐ ܘܟܢܫܐ ܤܓܝܐܐ ܕܬܠܡܝܕܘܗܝ ܘܤܘܓܐܐ ܕܟܢܫܐ ܕܥܡܐ ܡܢ ܟܠܗ ܝܗܘܕ ܘܡܢ ܐܘܪܫܠܡ ܘܡܢ ܤܦܪ ܝܡܐ ܕܨܘܪ ܘܕܨܝܕܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.18",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Luke 6:18",
      "text": "ܕܐܬܘ ܕܢܫܡܥܘܢ ܡܠܬܗ ܘܕܢܬܐܤܘܢ ܡܢ ܟܘܪܗܢܝܗܘܢ ܘܐܝܠܝܢ ܕܡܬܐܠܨܝܢ ܡܢ ܪܘܚܐ ܛܢܦܬܐ ܘܡܬܐܤܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.19",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Luke 6:19",
      "text": "ܘܟܠܗ ܟܢܫܐ ܒܥܝܢ ܗܘܘ ܠܡܬܩܪܒܘ ܠܗ ܚܝܠܐ ܓܝܪ ܢܦܩ ܗܘܐ ܡܢܗ ܘܠܟܠܗܘܢ ܡܐܤܐ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.20",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Luke 6:20",
      "text": "ܘܐܪܝܡ ܥܝܢܘܗܝ ܥܠ ܬܠܡܝܕܘܗܝ ܘܐܡܪ ܛܘܒܝܟܘܢ ܡܤܟܢܐ ܕܕܝܠܟܘܢ ܗܝ ܡܠܟܘܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.21",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "Luke 6:21",
      "text": "ܛܘܒܝܟܘܢ ܐܝܠܝܢ ܕܟܦܢܝܢ ܗܫܐ ܕܬܤܒܥܘܢ ܛܘܒܝܟܘܢ ܠܕܒܟܝܢ ܗܫܐ ܕܬܓܚܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.22",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "Luke 6:22",
      "text": "ܛܘܒܝܟܘܢ ܡܐ ܕܤܢܝܢ ܠܟܘܢ ܒܢܝܢܫܐ ܘܡܦܪܫܝܢ ܠܟܘܢ ܘܡܚܤܕܝܢ ܠܟܘܢ ܘܡܦܩܝܢ ܫܡܟܘܢ ܐܝܟ ܒܝܫܐ ܚܠܦ ܒܪܗ ܕܐܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.23",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "Luke 6:23",
      "text": "ܚܕܘ ܒܗܘ ܝܘܡܐ ܘܕܘܨܘ ܕܐܓܪܟܘܢ ܤܓܝ ܒܫܡܝܐ ܗܟܢܐ ܓܝܪ ܥܒܕܝܢ ܗܘܘ ܐܒܗܬܗܘܢ ܠܢܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.24",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "Luke 6:24",
      "text": "ܒܪܡ ܘܝ ܠܟܘܢ ܥܬܝܪܐ ܕܩܒܠܬܘܢ ܒܘܝܐܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.25",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 25,
      "referenceLabel": "Luke 6:25",
      "text": "ܘܝ ܠܟܘܢ ܤܒܥܐ ܕܬܟܦܢܘܢ ܘܝ ܠܟܘܢ ܠܕܓܚܟܝܢ ܗܫܐ ܕܬܒܟܘܢ ܘܬܬܐܒܠܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.26",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 26,
      "referenceLabel": "Luke 6:26",
      "text": "ܘܝ ܠܟܘܢ ܟܕ ܢܗܘܘܢ ܐܡܪܝܢ ܥܠܝܟܘܢ ܒܢܝ ܐܢܫܐ ܕܫܦܝܪ ܗܟܢܐ ܓܝܪ ܥܒܕܝܢ ܗܘܘ ܠܢܒܝܐ ܕܕܓܠܘܬܐ ܐܒܗܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.27",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 27,
      "referenceLabel": "Luke 6:27",
      "text": "ܠܟܘܢ ܕܝܢ ܐܡܪ ܐܢܐ ܠܕܫܡܥܝܢ ܐܚܒܘ ܠܒܥܠܕܒܒܝܟܘܢ ܘܥܒܕܘ ܕܫܦܝܪ ܠܐܝܠܝܢ ܕܤܢܝܢ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.28",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 28,
      "referenceLabel": "Luke 6:28",
      "text": "ܘܒܪܟܘ ܠܐܝܠܝܢ ܕܠܝܛܝܢ ܠܟܘܢ ܘܨܠܘ ܥܠ ܐܝܠܝܢ ܕܕܒܪܝܢ ܠܟܘܢ ܒܩܛܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.29",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 29,
      "referenceLabel": "Luke 6:29",
      "text": "ܘܠܕܡܚܐ ܠܟ ܥܠ ܦܟܟ ܩܪܒ ܠܗ ܐܚܪܢܐ ܘܡܢ ܡܢ ܕܫܩܠ ܡܪܛܘܛܟ ܠܐ ܬܟܠܐ ܐܦ ܟܘܬܝܢܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.6.30",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 6,
      "verseNumber": 30,
      "referenceLabel": "Luke 6:30",
      "text": "ܠܟܠ ܕܫܐܠ ܠܟ ܗܒ ܠܗ ܘܡܢ ܡܢ ܕܫܩܠ ܕܝܠܟ ܠܐ ܬܬܒܥ ܀",
      "paragraphStart": false
