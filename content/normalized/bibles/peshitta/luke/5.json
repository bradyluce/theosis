  "verses": [
    {
      "id": "peshitta:luke.5.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Luke 5:1",
      "text": "ܗܘܐ ܕܝܢ ܟܕ ܟܢܫ ܥܠܘܗܝ ܟܢܫܐ ܠܡܫܡܥ ܡܠܬܐ ܕܐܠܗܐ ܘܗܘ ܩܐܡ ܗܘܐ ܥܠ ܝܕ ܝܡܬܐ ܕܓܢܤܪ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.5.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Luke 5:2",
      "text": "ܚܙܐ ܤܦܝܢܐ ܬܪܬܝܢ ܕܩܝܡܢ ܥܠ ܓܢܒ ܝܡܬܐ ܘܨܝܕܐ ܕܤܠܩܘ ܡܢܗܝܢ ܘܡܫܝܓܝܢ ܡܨܝܕܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Luke 5:3",
      "text": "ܘܚܕܐ ܡܢܗܝܢ ܕܫܡܥܘܢ ܗܘܬ ܟܐܦܐ ܘܤܠܩ ܝܫܘܥ ܝܬܒ ܒܗ ܘܐܡܪ ܕܢܕܒܪܘܢܗ ܩܠܝܠ ܡܢ ܝܒܫܐ ܠܡܝܐ ܘܝܬܒ ܗܘܐ ܘܡܠܦ ܡܢ ܤܦܝܢܬܐ ܠܟܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Luke 5:4",
      "text": "ܘܟܕ ܫܬܩ ܡܢ ܡܡܠܠܗ ܐܡܪ ܠܫܡܥܘܢ ܕܒܪܘ ܠܥܘܡܩܐ ܘܐܪܡܘ ܡܨܝܕܬܟܘܢ ܠܨܝܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Luke 5:5",
      "text": "ܥܢܐ ܫܡܥܘܢ ܘܐܡܪ ܠܗ ܪܒܝ ܠܠܝܐ ܟܠܗ ܠܐܝܢ ܘܡܕܡ ܠܐ ܐܚܕܢ ܥܠ ܡܠܬܟ ܕܝܢ ܪܡܐ ܐܢܐ ܡܨܝܕܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Luke 5:6",
      "text": "ܘܟܕ ܗܕܐ ܥܒܕܘ ܚܒܫܘ ܢܘܢܐ ܤܓܝܐܐ ܕܛܒ ܘܡܨܛܪܝܐ ܗܘܬ ܡܨܝܕܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Luke 5:7",
      "text": "ܘܪܡܙܘ ܠܚܒܪܝܗܘܢ ܕܒܤܦܝܢܬܐ ܐܚܪܬܐ ܕܢܐܬܘܢ ܢܥܕܪܘܢ ܐܢܘܢ ܘܟܕ ܐܬܘ ܡܠܘ ܐܢܝܢ ܤܦܝܢܐ ܬܪܬܝܗܝܢ ܐܝܟ ܕܩܪܝܒܢ ܗܘܝ ܠܡܛܒܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Luke 5:8",
      "text": "ܟܕ ܚܙܐ ܕܝܢ ܫܡܥܘܢ ܟܐܦܐ ܢܦܠ ܩܕܡ ܪܓܠܘܗܝ ܕܝܫܘܥ ܘܐܡܪ ܠܗ ܒܥܐ ܐܢܐ ܡܢܟ ܡܪܝ ܦܪܘܩ ܠܟ ܡܢܝ ܕܓܒܪܐ ܐܢܐ ܚܛܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Luke 5:9",
      "text": "ܬܡܗܐ ܓܝܪ ܐܚܕܗ ܗܘܐ ܘܠܟܠܗܘܢ ܕܥܡܗ ܥܠ ܨܝܕܐ ܗܘ ܕܢܘܢܐ ܕܨܕܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Luke 5:10",
      "text": "ܗܟܘܬ ܕܝܢ ܐܦ ܠܝܥܩܘܒ ܘܠܝܘܚܢܢ ܒܢܝ ܙܒܕܝ ܕܐܝܬܝܗܘܢ ܗܘܘ ܫܘܬܦܐ ܕܫܡܥܘܢ ܐܡܪ ܕܝܢ ܝܫܘܥ ܠܫܡܥܘܢ ܠܐ ܬܕܚܠ ܡܢ ܗܫܐ ܒܢܝ ܐܢܫܐ ܬܗܘܐ ܨܐܕ ܠܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Luke 5:11",
      "text": "ܘܩܪܒܘ ܐܢܝܢ ܤܦܝܢܐ ܠܐܪܥܐ ܘܫܒܩܘ ܟܠ ܡܕܡ ܘܐܬܘ ܒܬܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Luke 5:12",
      "text": "ܘܟܕ ܗܘܐ ܝܫܘܥ ܒܚܕܐ ܡܢ ܡܕܝܢܬܐ ܐܬܐ ܓܒܪܐ ܕܡܠܐ ܟܠܗ ܓܪܒܐ ܚܙܐ ܠܝܫܘܥ ܘܢܦܠ ܥܠ ܐܦܘܗܝ ܘܒܥܐ ܗܘܐ ܡܢܗ ܘܐܡܪ ܠܗ ܡܪܝ ܐܢ ܨܒܐ ܐܢܬ ܡܫܟܚ ܐܢܬ ܠܡܕܟܝܘܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.13",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Luke 5:13",
      "text": "ܘܦܫܛ ܐܝܕܗ ܝܫܘܥ ܩܪܒ ܠܗ ܘܐܡܪ ܠܗ ܨܒܐ ܐܢܐ ܐܬܕܟܐ ܘܒܪ ܫܥܬܗ ܐܙܠ ܡܢܗ ܓܪܒܗ ܘܐܬܕܟܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Luke 5:14",
      "text": "ܘܦܩܕܗ ܕܠܐܢܫ ܠܐ ܬܐܡܪ ܐܠܐ ܙܠ ܚܘܐ ܢܦܫܟ ܠܟܗܢܐ ܘܩܪܒ ܚܠܦ ܬܕܟܝܬܟ ܐܝܟܢܐ ܕܦܩܕ ܡܘܫܐ ܠܤܗܕܘܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Luke 5:15",
      "text": "ܘܢܦܩ ܥܠܘܗܝ ܛܒܐ ܝܬܝܪܐܝܬ ܘܡܬܟܢܫ ܗܘܐ ܥܡܐ ܤܓܝܐܐ ܠܡܫܡܥ ܡܢܗ ܘܠܡܬܐܤܝܘ ܡܢ ܟܘܪܗܢܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.16",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Luke 5:16",
      "text": "ܗܘ ܕܝܢ ܡܫܢܐ ܗܘܐ ܠܕܒܪܐ ܘܡܨܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.17",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Luke 5:17",
      "text": "ܘܗܘܐ ܒܚܕ ܡܢ ܝܘܡܬܐ ܟܕ ܡܠܦ ܗܘܐ ܝܫܘܥ ܝܬܒܝܢ ܗܘܘ ܦܪܝܫܐ ܘܡܠܦܝ ܢܡܘܤܐ ܕܐܬܘ ܗܘܘ ܡܢ ܟܠ ܩܘܪܝܐ ܕܓܠܝܠܐ ܘܕܝܗܘܕ ܘܕܐܘܪܫܠܡ ܘܚܝܠܐ ܕܡܪܝܐ ܐܝܬܘܗܝ ܗܘܐ ܠܡܐܤܝܘܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.18",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Luke 5:18",
      "text": "ܘܐܢܫܐ ܐܝܬܝܘ ܒܥܪܤܐ ܓܒܪܐ ܚܕ ܡܫܪܝܐ ܘܒܥܝܢ ܗܘܘ ܕܢܥܠܘܢ ܢܤܝܡܘܢܝܗܝ ܩܕܡܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.19",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Luke 5:19",
      "text": "ܘܟܕ ܠܐ ܐܫܟܚܘ ܕܐܝܟܢܐ ܢܥܠܘܢܝܗܝ ܡܛܠ ܤܘܓܐܐ ܕܥܡܐ ܤܠܩܘ ܠܗܘܢ ܠܐܓܪܐ ܘܫܒܘܗܝ ܥܡ ܥܪܤܗ ܡܢ ܬܛܠܝܠܐ ܠܡܨܥܬܐ ܩܕܡܘܗܝ ܕܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.20",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Luke 5:20",
      "text": "ܟܕ ܚܙܐ ܕܝܢ ܝܫܘܥ ܗܝܡܢܘܬܗܘܢ ܐܡܪ ܠܗܘ ܡܫܪܝܐ ܓܒܪܐ ܫܒܝܩܝܢ ܠܟ ܚܛܗܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.21",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Luke 5:21",
      "text": "ܘܫܪܝܘ ܤܦܪܐ ܘܦܪܝܫܐ ܡܬܚܫܒܝܢ ܘܐܡܪܝܢ ܡܢܘ ܗܢܐ ܕܡܡܠܠ ܓܘܕܦܐ ܡܢܘ ܡܫܟܚ ܠܡܫܒܩ ܚܛܗܐ ܐܠܐ ܐܢ ܐܠܗܐ ܒܠܚܘܕ ܀",
      "paragraphStart": false
