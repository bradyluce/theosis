    {
      "id": "peshitta:luke.5.31",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "Luke 5:31",
      "text": "ܘܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗܘܢ ܠܐ ܡܬܒܥܐ ܐܤܝܐ ܠܚܠܝܡܐ ܐܠܐ ܠܐܝܠܝܢ ܕܒܝܫ ܒܝܫ ܥܒܝܕܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.5.32",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 32,
      "referenceLabel": "Luke 5:32",
      "text": "ܠܐ ܐܬܝܬ ܕܐܩܪܐ ܠܙܕܝܩܐ ܐܠܐ ܠܚܛܝܐ ܠܬܝܒܘܬܐ ܀",
