    {
      "id": "peshitta:luke.5.30",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "Luke 5:30",
      "text": "ܘܪܛܢܝܢ ܗܘܘ ܤܦܪܐ ܘܦܪܝܫܐ ܘܐܡܪܝܢ ܠܬܠܡܝܕܘܗܝ ܠܡܢܐ ܥܡ ܡܟܤܐ ܘܚܛܝܐ ܐܟܠܝܢ ܐܢܬܘܢ ܘܫܬܝܢ ܀",
      "paragraphStart": false
