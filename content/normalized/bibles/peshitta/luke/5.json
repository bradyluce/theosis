    {
      "id": "peshitta:luke.5.22",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Luke 5:22",
      "text": "ܝܫܘܥ ܕܝܢ ܝܕܥ ܡܚܫܒܬܗܘܢ ܘܥܢܐ ܘܐܡܪ ܠܗܘܢ ܡܢܐ ܡܬܚܫܒܝܢ ܐܢܬܘܢ ܒܠܒܟܘܢ ܀",
      "paragraphStart": false
