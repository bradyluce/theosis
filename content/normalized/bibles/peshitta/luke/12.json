  "verses": [
    {
      "id": "peshitta:luke.12.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Luke 12:1",
      "text": "ܘܟܕ ܐܬܟܢܫܘ ܪܒܘܬܐ ܕܟܢܫܐ ܤܓܝܐܐ ܐܝܟܢܐ ܕܢܕܝܫܘܢ ܚܕ ܠܚܕ ܫܪܝ ܝܫܘܥ ܠܡܐܡܪ ܠܬܠܡܝܕܘܗܝ ܠܘܩܕܡ ܐܙܕܗܪܘ ܒܢܦܫܟܘܢ ܡܢ ܚܡܝܪܐ ܕܦܪܝܫܐ ܕܐܝܬܘܗܝ ܡܤܒ ܒܐܦܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.12.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Luke 12:2",
      "text": "ܠܝܬ ܕܝܢ ܡܕܡ ܕܟܤܐ ܕܠܐ ܢܬܓܠܐ ܘܠܐ ܕܡܛܫܝ ܕܠܐ ܢܬܝܕܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.12.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Luke 12:3",
      "text": "ܟܠ ܓܝܪ ܕܒܚܫܘܟܐ ܐܡܪܬܘܢ ܒܢܗܝܪܐ ܢܫܬܡܥ ܘܡܕܡ ܕܒܬܘܢܐ ܒܐܕܢܐ ܠܚܫܬܘܢ ܥܠ ܐܓܪܐ ܢܬܟܪܙ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.12.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Luke 12:4",
      "text": "ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܝܢ ܠܪܚܡܝ ܠܐ ܬܕܚܠܘܢ ܡܢ ܐܝܠܝܢ ܕܩܛܠܝܢ ܦܓܪܐ ܘܡܢ ܒܬܪܟܢ ܠܝܬ ܠܗܘܢ ܡܕܡ ܝܬܝܪ ܠܡܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.12.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Luke 12:5",
      "text": "ܐܚܘܝܟܘܢ ܕܝܢ ܡܢ ܡܢ ܬܕܚܠܘܢ ܡܢ ܗܘ ܕܡܢ ܒܬܪ ܕܩܛܠ ܫܠܝܛ ܠܡܪܡܝܘ ܒܓܗܢܐ ܐܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܡܢ ܗܢܐ ܕܚܠܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.12.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Luke 12:6",
      "text": "ܠܐ ܚܡܫ ܨܦܪܝܢ ܡܙܕܒܢܢ ܒܬܪܝܢ ܐܤܪܝܢ ܘܚܕܐ ܡܢܗܝܢ ܠܐ ܛܥܝܐ ܩܕܡ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.12.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Luke 12:7",
      "text": "ܕܝܠܟܘܢ ܕܝܢ ܐܦ ܡܢܐ ܕܤܥܪܐ ܕܪܫܟܘܢ ܟܠܗܝܢ ܡܢܝܢ ܐܢܝܢ ܠܐ ܗܟܝܠ ܬܕܚܠܘܢ ܕܡܢ ܤܘܓܐܐ ܕܨܦܪܐ ܡܝܬܪܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.12.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Luke 12:8",
      "text": "ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܝܢ ܕܟܠ ܕܢܘܕܐ ܒܝ ܩܕܡ ܒܢܝܢܫܐ ܐܦ ܒܪܗ ܕܐܢܫܐ ܢܘܕܐ ܒܗ ܩܕܡ ܡܠܐܟܘܗܝ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.12.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Luke 12:9",
      "text": "ܐܝܢܐ ܕܝܢ ܕܟܦܪ ܒܝ ܩܕܡ ܒܢܝܢܫܐ ܢܬܟܦܪ ܒܗ ܩܕܡ ܡܠܐܟܘܗܝ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.12.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Luke 12:10",
      "text": "ܘܟܠ ܕܢܐܡܪ ܡܠܬܐ ܥܠ ܒܪܗ ܕܐܢܫܐ ܢܫܬܒܩ ܠܗ ܡܢ ܕܥܠ ܪܘܚܐ ܕܝܢ ܕܩܘܕܫܐ ܢܓܕܦ ܠܐ ܢܫܬܒܩ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.12.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Luke 12:11",
      "text": "ܡܐ ܕܡܩܪܒܝܢ ܠܟܘܢ ܕܝܢ ܠܟܢܘܫܬܐ ܩܕܡ ܪܫܐ ܘܫܠܝܛܢܐ ܠܐ ܬܐܨܦܘܢ ܐܝܟܢܐ ܬܦܩܘܢ ܪܘܚܐ ܐܘ ܡܢܐ ܬܐܡܪܘܢ ܀",
      "paragraphStart": false
    },
    {
