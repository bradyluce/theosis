      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Luke 12:12",
      "text": "ܪܘܚܐ ܓܝܪ ܕܩܘܕܫܐ ܢܠܦܟܘܢ ܒܗܝ ܫܥܬܐ ܡܕܡ ܕܘܠܐ ܕܬܐܡܪܘܢ ܀",
      "paragraphStart": false
