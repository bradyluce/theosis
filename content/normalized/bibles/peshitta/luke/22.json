{
  "chapter": {
    "id": "peshitta:luke.22",
    "translationId": "peshitta",
    "bookSlug": "luke",
    "chapterNumber": 22,
    "referenceLabel": "Luke 22",
    "summary": "Source text for Luke 22 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:luke.22.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Luke 22:1",
      "text": "ܩܪܝܒ ܗܘܐ ܕܝܢ ܥܕܥܕܐ ܕܦܛܝܪܐ ܕܡܬܩܪܐ ܦܨܚܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.22.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Luke 22:2",
      "text": "ܘܒܥܝܢ ܗܘܘ ܪܒܝ ܟܗܢܐ ܘܤܦܪܐ ܕܐܝܟܢܐ ܢܩܛܠܘܢܝܗܝ ܕܚܠܝܢ ܗܘܘ ܓܝܪ ܡܢ ܥܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Luke 22:3",
      "text": "ܥܠ ܗܘܐ ܕܝܢ ܤܛܢܐ ܒܝܗܘܕܐ ܕܡܬܩܪܐ ܤܟܪܝܘܛܐ ܕܐܝܬܘܗܝ ܗܘܐ ܡܢ ܡܢܝܢܐ ܕܬܪܥܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Luke 22:4",
      "text": "ܘܐܙܠ ܡܠܠ ܥܡ ܪܒܝ ܟܗܢܐ ܘܤܦܪܐ ܘܪܒܝ ܚܝܠܐ ܕܗܝܟܠܐ ܐܝܟ ܕܢܫܠܡܝܘܗܝ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Luke 22:5",
      "text": "ܘܚܕܝܘ ܘܐܩܝܡܘ ܕܢܬܠܘܢ ܠܗ ܟܤܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Luke 22:6",
      "text": "ܘܐܫܬܘܕܝ ܠܗܘܢ ܘܒܥܐ ܗܘܐ ܦܠܥܐ ܕܢܫܠܡܝܘܗܝ ܠܗܘܢ ܒܠܥܕ ܡܢ ܟܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Luke 22:7",
      "text": "ܘܡܛܝ ܝܘܡܐ ܕܦܛܝܪܐ ܕܒܗ ܐܝܬ ܗܘܐ ܥܝܕܐ ܕܢܬܢܟܤ ܦܨܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Luke 22:8",
      "text": "ܘܫܕܪ ܝܫܘܥ ܠܟܐܦܐ ܘܠܝܘܚܢܢ ܘܐܡܪ ܠܗܘܢ ܙܠܘ ܛܝܒܘ ܠܢ ܦܨܚܐ ܕܢܠܥܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Luke 22:9",
      "text": "ܗܢܘܢ ܕܝܢ ܐܡܪܘ ܠܗ ܐܝܟܐ ܨܒܐ ܐܢܬ ܕܢܛܝܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Luke 22:10",
      "text": "ܐܡܪ ܠܗܘܢ ܗܐ ܡܐ ܕܥܐܠܝܢ ܐܢܬܘܢ ܠܡܕܝܢܬܐ ܦܓܥ ܒܟܘܢ ܓܒܪܐ ܕܫܩܝܠ ܓܪܒܐ ܕܡܝܐ ܙܠܘ ܒܬܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Luke 22:11",
      "text": "ܘܐܝܟܐ ܕܥܐܠ ܐܡܪܘ ܠܡܪܗ ܕܒܝܬܐ ܪܒܢ ܐܡܪ ܐܝܢܘ ܒܝܬ ܡܫܪܝܐ ܐܝܟܐ ܕܐܟܘܠ ܦܨܚܐ ܥܡ ܬܠܡܝܕܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Luke 22:12",
      "text": "ܘܗܐ ܗܘ ܡܚܘܐ ܠܟܘܢ ܥܠܝܬܐ ܚܕܐ ܪܒܬܐ ܕܡܫܘܝܐ ܬܡܢ ܛܝܒܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.13",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Luke 22:13",
      "text": "ܘܐܙܠܘ ܐܫܟܚܘ ܐܝܟ ܕܐܡܪ ܠܗܘܢ ܘܛܝܒܘ ܦܨܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Luke 22:14",
      "text": "ܘܟܕ ܗܘܐ ܥܕܢܐ ܐܬܐ ܝܫܘܥ ܐܤܬܡܟ ܘܬܪܥܤܪ ܫܠܝܚܐ ܥܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Luke 22:15",
      "text": "ܘܐܡܪ ܠܗܘܢ ܪܓܬܐ ܪܓܬܢܝ ܕܗܢܐ ܦܨܚܐ ܐܟܘܠ ܥܡܟܘܢ ܩܕܡ ܕܐܚܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.16",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Luke 22:16",
      "text": "ܐܡܪ ܐܢܐ ܠܟܘܢ ܓܝܪ ܕܡܟܝܠ ܠܐ ܐܟܠܝܘܗܝ ܥܕܡܐ ܕܢܫܠܡ ܒܡܠܟܘܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.17",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Luke 22:17",
      "text": "ܘܢܤܒ ܟܤܐ ܘܐܘܕܝ ܘܐܡܪ ܤܒܘ ܗܢܐ ܘܦܠܓܘ ܒܝܢܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.18",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Luke 22:18",
      "text": "ܐܡܪ ܐܢܐ ܓܝܪ ܠܟܘܢ ܕܠܐ ܐܫܬܐ ܡܢ ܝܠܕܐ ܕܓܦܬܐ ܥܕܡܐ ܕܬܐܬܐ ܡܠܟܘܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.19",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Luke 22:19",
      "text": "ܘܢܤܒ ܠܚܡܐ ܘܐܘܕܝ ܘܩܨܐ ܘܝܗܒ ܠܗܘܢ ܘܐܡܪ ܗܢܘ ܦܓܪܝ ܕܥܠ ܐܦܝܟܘܢ ܡܬܝܗܒ ܗܕܐ ܗܘܝܬܘܢ ܥܒܕܝܢ ܠܕܘܟܪܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.20",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Luke 22:20",
      "text": "ܘܗܟܘܬ ܐܦ ܥܠ ܟܤܐ ܡܢ ܒܬܪ ܕܐܚܫܡܘ ܐܡܪ ܗܢܐ ܟܤܐ ܕܝܬܩܐ ܚܕܬܐ ܒܕܡܝ ܕܚܠܦܝܟܘܢ ܡܬܐܫܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.21",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Luke 22:21",
      "text": "ܒܪܡ ܗܐ ܐܝܕܗ ܕܡܫܠܡܢܝ ܥܠ ܦܬܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.22",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Luke 22:22",
      "text": "ܘܒܪܗ ܕܐܢܫܐ ܐܙܠ ܐܝܟܢܐ ܕܐܬܦܪܫ ܒܪܡ ܘܝ ܠܗܘ ܓܒܪܐ ܕܒܐܝܕܗ ܡܫܬܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.23",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Luke 22:23",
      "text": "ܘܫܪܝܘ ܕܢܥܩܒܘܢ ܒܝܢܬܗܘܢ ܕܡܢܘ ܟܝ ܡܢܗܘܢ ܗܘ ܕܗܕܐ ܥܬܝܕ ܠܡܤܥܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.24",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Luke 22:24",
      "text": "ܗܘܐ ܕܝܢ ܐܦ ܚܪܝܢܐ ܒܝܢܬܗܘܢ ܕܡܢ ܐܝܬ ܒܗܘܢ ܕܪܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.25",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Luke 22:25",
      "text": "ܗܘ ܕܝܢ ܝܫܘܥ ܐܡܪ ܠܗܘܢ ܡܠܟܝܗܘܢ ܕܥܡܡܐ ܡܪܝܗܘܢ ܐܢܘܢ ܘܕܫܠܝܛܝܢ ܥܠܝܗܘܢ ܥܒܕܝ ܛܒܬܐ ܡܬܩܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.26",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Luke 22:26",
      "text": "ܐܢܬܘܢ ܕܝܢ ܠܐ ܗܟܢܐ ܐܠܐ ܐܝܢܐ ܕܪܒ ܒܟܘܢ ܢܗܘܐ ܐܝܟ ܙܥܘܪܐ ܘܐܝܢܐ ܕܪܫܐ ܗܘ ܐܝܟ ܡܫܡܫܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.27",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Luke 22:27",
      "text": "ܡܢܘ ܓܝܪ ܪܒ ܗܘ ܕܤܡܝܟ ܐܘ ܗܘ ܕܡܫܡܫ ܠܐ ܗܘܐ ܗܘ ܕܤܡܝܟ ܐܢܐ ܕܝܢ ܐܝܬܝ ܒܝܢܬܟܘܢ ܐܝܟ ܗܘ ܕܡܫܡܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.28",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Luke 22:28",
      "text": "ܐܢܬܘܢ ܐܢܘܢ ܕܝܢ ܕܟܬܪܬܘܢ ܠܘܬܝ ܒܢܤܝܘܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.29",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Luke 22:29",
      "text": "ܘܐܢܐ ܡܫܬܘܕܐ ܐܢܐ ܠܟܘܢ ܐܝܟ ܕܐܫܬܘܕܝ ܠܝ ܐܒܝ ܡܠܟܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.30",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "Luke 22:30",
      "text": "ܕܬܐܟܠܘܢ ܘܬܫܬܘܢ ܥܠ ܦܬܘܪܐ ܕܡܠܟܘܬܐ ܕܝܠܝ ܘܬܬܒܘܢ ܥܠ ܟܘܪܤܘܬܐ ܘܬܕܘܢܘܢ ܬܪܥܤܪ ܫܒܛܐ ܕܐܝܤܪܝܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.31",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 31,
      "referenceLabel": "Luke 22:31",
      "text": "ܘܐܡܪ ܝܫܘܥ ܠܫܡܥܘܢ ܫܡܥܘܢ ܗܐ ܤܛܢܐ ܫܐܠ ܕܢܥܪܘܒܟܘܢ ܐܝܟ ܕܠܚܛܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.32",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 32,
      "referenceLabel": "Luke 22:32",
      "text": "ܘܐܢܐ ܒܥܝܬ ܥܠܝܟ ܕܠܐ ܬܚܤܪ ܗܝܡܢܘܬܟ ܐܦ ܐܢܬ ܒܙܒܢ ܐܬܦܢܝ ܘܫܪܪ ܐܚܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.33",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 33,
      "referenceLabel": "Luke 22:33",
      "text": "ܫܡܥܘܢ ܕܝܢ ܐܡܪ ܠܗ ܡܪܝ ܥܡܟ ܡܛܝܒ ܐܢܐ ܘܠܒܝܬ ܐܤܝܪܐ ܘܠܡܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.34",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 34,
      "referenceLabel": "Luke 22:34",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܐܡܪ ܐܢܐ ܠܟ ܫܡܥܘܢ ܕܠܐ ܢܩܪܐ ܬܪܢܓܠܐ ܝܘܡܢܐ ܥܕܡܐ ܕܬܠܬ ܙܒܢܝܢ ܬܟܦܘܪ ܕܠܐ ܝܕܥ ܐܢܬ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.35",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 35,
      "referenceLabel": "Luke 22:35",
      "text": "ܘܐܡܪ ܠܗܘܢ ܟܕ ܫܕܪܬܟܘܢ ܕܠܐ ܟܝܤܐ ܘܕܠܐ ܬܪܡܠܐ ܘܡܤܢܐ ܠܡܐ ܚܤܪ ܠܟܘܢ ܡܕܡ ܐܡܪܝܢ ܠܗ ܘܠܐ ܡܕܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.36",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 36,
      "referenceLabel": "Luke 22:36",
      "text": "ܐܡܪ ܠܗܘܢ ܡܢ ܗܫܐ ܡܢ ܕܐܝܬ ܠܗ ܟܝܤܐ ܢܤܒ ܘܗܟܢܐ ܐܦ ܬܪܡܠܐ ܘܡܢ ܕܠܝܬ ܠܗ ܤܝܦܐ ܢܙܒܢ ܢܚܬܗ ܘܢܙܒܢ ܠܗ ܤܝܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.37",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 37,
      "referenceLabel": "Luke 22:37",
      "text": "ܐܡܪ ܐܢܐ ܠܟܘܢ ܓܝܪ ܕܐܦ ܗܕܐ ܕܟܬܝܒܐ ܘܠܐ ܕܬܬܡܠܐ ܒܝ ܕܥܡ ܥܘܠܐ ܐܬܡܢܐ ܟܠܗܝܢ ܓܝܪ ܕܥܠܝ ܐܫܬܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.38",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 38,
      "referenceLabel": "Luke 22:38",
      "text": "ܘܗܢܘܢ ܐܡܪܝܢ ܠܗ ܡܪܢ ܗܐ ܗܪܟܐ ܐܝܬ ܬܪܝܢ ܤܝܦܝܢ ܐܡܪ ܠܗܘܢ ܤܦܩܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.39",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 39,
      "referenceLabel": "Luke 22:39",
      "text": "ܘܢܦܩ ܘܐܙܠ ܐܝܟ ܕܡܥܕ ܗܘܐ ܠܛܘܪܐ ܕܒܝܬ ܙܝܬܐ ܘܐܙܠܘ ܒܬܪܗ ܐܦ ܬܠܡܝܕܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.22.40",
