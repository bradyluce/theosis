  "verses": [
    {
      "id": "peshitta:luke.2.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Luke 2:1",
      "text": "ܗܘܐ ܕܝܢ ܒܝܘܡܬܐ ܗܢܘܢ ܘܢܦܩ ܦܘܩܕܢܐ ܡܢ ܐܓܘܤܛܘܤ ܩܤܪ ܕܢܬܟܬܒ ܟܠܗ ܥܡܐ ܕܐܘܚܕܢܗ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.2.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Luke 2:2",
      "text": "ܗܕܐ ܡܟܬܒܢܘܬܐ ܩܕܡܝܬܐ ܗܘܬ ܒܗܓܡܢܘܬܐ ܕܩܘܪܝܢܘܤ ܒܤܘܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.2.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Luke 2:3",
      "text": "ܘܐܙܠ ܗܘܐ ܟܠܢܫ ܕܢܬܟܬܒ ܒܡܕܝܢܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.2.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Luke 2:4",
      "text": "ܤܠܩ ܗܘܐ ܕܝܢ ܐܦ ܝܘܤܦ ܡܢ ܢܨܪܬ ܡܕܝܢܬܐ ܕܓܠܝܠܐ ܠܝܗܘܕ ܠܡܕܝܢܬܗ ܕܕܘܝܕ ܕܡܬܩܪܝܐ ܒܝܬ ܠܚܡ ܡܛܠ ܕܐܝܬܘܗܝ ܗܘܐ ܡܢ ܒܝܬܗ ܘܡܢ ܫܪܒܬܗ ܕܕܘܝܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.2.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Luke 2:5",
      "text": "ܥܡ ܡܪܝܡ ܡܟܝܪܬܗ ܟܕ ܒܛܢܐ ܕܬܡܢ ܢܬܟܬܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.2.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Luke 2:6",
      "text": "ܘܗܘܐ ܕܟܕ ܬܡܢ ܐܢܘܢ ܐܬܡܠܝܘ ܝܘܡܬܗ ܕܬܐܠܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.2.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Luke 2:7",
      "text": "ܘܝܠܕܬ ܒܪܗ ܒܘܟܪܐ ܘܟܪܟܬܗ ܒܥܙܪܘܪܐ ܘܐܪܡܝܬܗ ܒܐܘܪܝܐ ܡܛܠ ܕܠܝܬ ܗܘܐ ܠܗܘܢ ܕܘܟܬܐ ܐܝܟܐ ܕܫܪܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.2.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Luke 2:8",
      "text": "ܪܥܘܬܐ ܕܝܢ ܐܝܬ ܗܘܘ ܒܗ ܒܐܬܪܐ ܕܫܪܝܢ ܗܘܘ ܬܡܢ ܘܢܛܪܝܢ ܡܛܪܬܐ ܕܠܠܝܐ ܥܠ ܡܪܥܝܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.2.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Luke 2:9",
      "text": "ܘܗܐ ܡܠܐܟܐ ܕܐܠܗܐ ܐܬܐ ܠܘܬܗܘܢ ܘܬܫܒܘܚܬܗ ܕܡܪܝܐ ܐܢܗܪܬ ܥܠܝܗܘܢ ܘܕܚܠܘ ܕܚܠܬܐ ܪܒܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.2.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Luke 2:10",
      "text": "ܘܐܡܪ ܠܗܘܢ ܡܠܐܟܐ ܠܐ ܬܕܚܠܘܢ ܗܐ ܓܝܪ ܡܤܒܪ ܐܢܐ ܠܟܘܢ ܚܕܘܬܐ ܪܒܬܐ ܕܬܗܘܐ ܠܟܠܗ ܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.2.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Luke 2:11",
      "text": "ܐܬܝܠܕ ܠܟܘܢ ܓܝܪ ܝܘܡܢܐ ܦܪܘܩܐ ܕܐܝܬܘܗܝ ܡܪܝܐ ܡܫܝܚܐ ܒܡܕܝܢܬܗ ܕܕܘܝܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.2.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Luke 2:12",
      "text": "ܘܗܕܐ ܠܟܘܢ ܐܬܐ ܡܫܟܚܝܢ ܐܢܬܘܢ ܥܘܠܐ ܕܟܪܝܟ ܒܥܙܪܘܪܐ ܘܤܝܡ ܒܐܘܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.2.13",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Luke 2:13",
      "text": "ܘܡܢ ܫܠܝ ܐܬܚܙܝܘ ܥܡ ܡܠܐܟܐ ܚܝܠܘܬܐ ܤܓܝܐܐ ܕܫܡܝܐ ܟܕ ܡܫܒܚܝܢ ܠܐܠܗܐ ܘܐܡܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.2.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Luke 2:14",
      "text": "ܬܫܒܘܚܬܐ ܠܐܠܗܐ ܒܡܪܘܡܐ ܘܥܠ ܐܪܥܐ ܫܠܡܐ ܘܤܒܪܐ ܛܒܐ ܠܒܢܝ ܐܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.2.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Luke 2:15",
      "text": "ܘܗܘܐ ܕܟܕ ܐܙܠܘ ܡܢ ܠܘܬܗܘܢ ܡܠܐܟܐ ܠܫܡܝܐ ܡܠܠܘ ܪܥܘܬܐ ܚܕ ܥܡ ܚܕ ܘܐܡܪܝܢ ܢܪܕܐ ܥܕܡܐ ܠܒܝܬ ܠܚܡ ܘܢܚܙܐ ܠܡܠܬܐ ܗܕܐ ܕܗܘܬ ܐܝܟ ܕܡܪܝܐ ܐܘܕܥ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.2.16",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Luke 2:16",
      "text": "ܘܐܬܘ ܡܤܪܗܒܐܝܬ ܘܐܫܟܚܘ ܠܡܪܝܡ ܘܠܝܘܤܦ ܘܠܥܘܠܐ ܕܤܝܡ ܒܐܘܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.2.17",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Luke 2:17",
      "text": "ܘܟܕ ܚܙܘ ܐܘܕܥܘ ܠܡܠܬܐ ܕܐܬܡܠܠܬ ܥܡܗܘܢ ܥܠܘܗܝ ܥܠ ܛܠܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.2.18",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Luke 2:18",
      "text": "ܘܟܠܗܘܢ ܕܫܡܥܘ ܐܬܕܡܪܘ ܥܠ ܐܝܠܝܢ ܕܐܬܡܠܠ ܠܗܘܢ ܡܢ ܪܥܘܬܐ ܀",
      "paragraphStart": false
