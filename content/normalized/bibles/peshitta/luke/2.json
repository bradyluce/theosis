    {
      "id": "peshitta:luke.2.20",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Luke 2:20",
      "text": "ܘܗܦܟܘ ܪܥܘܬܐ ܗܢܘܢ ܟܕ ܡܫܒܚܝܢ ܘܡܗܠܠܝܢ ܠܐܠܗܐ ܥܠ ܟܠ ܕܚܙܘ ܘܫܡܥܘ ܐܝܟܢܐ ܕܐܬܡܠܠ ܥܡܗܘܢ ܀",
