    {
      "id": "peshitta:luke.2.21",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Luke 2:21",
      "text": "ܘܟܕ ܡܠܘ ܬܡܢܝܐ ܝܘܡܝܢ ܕܢܬܓܙܪ ܛܠܝܐ ܐܬܩܪܝ ܫܡܗ ܝܫܘܥ ܕܐܬܩܪܝ ܡܢ ܡܠܐܟܐ ܩܕܡ ܕܢܬܒܛܢ ܒܟܪܤܐ ܀",
      "paragraphStart": false
