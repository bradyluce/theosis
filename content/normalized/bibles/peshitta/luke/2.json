    {
      "id": "peshitta:luke.2.22",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Luke 2:22",
      "text": "ܘܟܕ ܐܬܡܠܝܘ ܝܘܡܬܐ ܕܬܕܟܝܬܗܘܢ ܐܝܟ ܢܡܘܤܐ ܕܡܘܫܐ ܐܤܩܘܗܝ ܠܐܘܪܫܠܡ ܕܢܩܝܡܘܢܝܗܝ ܩܕܡ ܡܪܝܐ ܀",
      "paragraphStart": false
