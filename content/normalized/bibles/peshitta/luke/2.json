      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 30,
      "referenceLabel": "Luke 2:30",
      "text": "ܕܗܐ ܚܙܝ ܥܝܢܝ ܚܢܢܟ ܀",
