    {
      "id": "peshitta:luke.2.23",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Luke 2:23",
      "text": "ܐܝܟ ܕܟܬܝܒ ܒܢܡܘܤܐ ܕܡܪܝܐ ܕܟܠ ܕܟܪܐ ܦܬܚ ܡܪܒܥܐ ܩܕܝܫܐ ܕܡܪܝܐ ܢܬܩܪܐ ܀",
      "paragraphStart": false
