    "referenceLabel": "Luke 4",
    "summary": "Source text for Luke 4 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:luke.4.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Luke 4:1",
      "text": "ܝܫܘܥ ܕܝܢ ܟܕ ܡܠܐ ܪܘܚܐ ܕܩܘܕܫܐ ܗܦܟ ܡܢ ܝܘܪܕܢܢ ܘܕܒܪܬܗ ܪܘܚܐ ܠܚܘܪܒܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.4.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Luke 4:2",
      "text": "ܝܘܡܬܐ ܐܪܒܥܝܢ ܕܢܬܢܤܐ ܡܢ ܐܟܠܩܪܨܐ ܘܠܐ ܠܥܤ ܡܕܡ ܒܗܢܘܢ ܝܘܡܬܐ ܘܟܕ ܫܠܡ ܐܢܘܢ ܠܚܪܬܐ ܟܦܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Luke 4:3",
      "text": "ܘܐܡܪ ܠܗ ܐܟܠܩܪܨܐ ܐܢ ܒܪܗ ܐܢܬ ܕܐܠܗܐ ܐܡܪ ܠܟܐܦܐ ܗܕܐ ܕܬܗܘܐ ܠܚܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Luke 4:4",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗ ܟܬܝܒ ܗܘ ܕܠܐ ܗܘܐ ܒܠܚܡܐ ܒܠܚܘܕ ܚܝܐ ܒܪܢܫܐ ܐܠܐ ܒܟܠ ܦܬܓܡ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Luke 4:5",
      "text": "ܘܐܤܩܗ ܤܛܢܐ ܠܛܘܪܐ ܪܡܐ ܘܚܘܝܗ ܟܠܗܝܢ ܡܠܟܘܬܐ ܕܐܪܥܐ ܒܥܕܢܐ ܙܥܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Luke 4:6",
      "text": "ܘܐܡܪ ܠܗ ܐܟܠܩܪܨܐ ܠܟ ܐܬܠ ܫܘܠܛܢܐ ܗܢܐ ܟܠܗ ܘܫܘܒܚܗ ܕܠܝ ܡܫܠܡ ܘܠܡܢ ܕܐܨܒܐ ܝܗܒ ܐܢܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Luke 4:7",
      "text": "ܐܢ ܗܟܝܠ ܬܤܓܘܕ ܩܕܡܝ ܕܝܠܟ ܢܗܘܐ ܟܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Luke 4:8",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗ ܟܬܝܒ ܗܘ ܕܠܡܪܝܐ ܐܠܗܟ ܬܤܓܘܕ ܘܠܗ ܒܠܚܘܕܘܗܝ ܬܦܠܘܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Luke 4:9",
      "text": "ܘܐܝܬܝܗ ܠܐܘܪܫܠܡ ܘܐܩܝܡܗ ܥܠ ܟܢܦܐ ܕܗܝܟܠܐ ܘܐܡܪ ܠܗ ܐܢ ܒܪܗ ܐܢܬ ܕܐܠܗܐ ܐܪܡܐ ܢܦܫܟ ܡܟܐ ܠܬܚܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Luke 4:10",
      "text": "ܟܬܝܒ ܓܝܪ ܕܠܡܠܐܟܘܗܝ ܢܦܩܕ ܥܠܝܟ ܕܢܢܛܪܘܢܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Luke 4:11",
      "text": "ܘܥܠ ܕܪܥܝܗܘܢ ܢܫܩܠܘܢܟ ܕܠܐ ܬܬܩܠ ܪܓܠܟ ܒܟܐܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Luke 4:12",
      "text": "ܥܢܐ ܕܝܢ ܝܫܘܥ ܘܐܡܪ ܠܗ ܐܡܝܪ ܗܘ ܕܠܐ ܬܢܤܐ ܠܡܪܝܐ ܐܠܗܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.13",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Luke 4:13",
      "text": "ܘܟܕ ܫܠܡ ܐܟܠܩܪܨܐ ܟܠܗܘܢ ܢܤܝܘܢܘܗܝ ܦܪܩ ܡܢ ܠܘܬܗ ܥܕ ܙܒܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Luke 4:14",
      "text": "ܘܗܦܟ ܝܫܘܥ ܒܚܝܠܐ ܕܪܘܚܐ ܠܓܠܝܠܐ ܘܢܦܩ ܥܠܘܗܝ ܛܒܐ ܒܟܠܗ ܐܬܪܐ ܕܚܕܪܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Luke 4:15",
      "text": "ܘܗܘ ܡܠܦ ܗܘܐ ܒܟܢܘܫܬܗܘܢ ܘܡܫܬܒܚ ܗܘܐ ܡܢ ܟܠ ܐܢܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.16",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Luke 4:16",
      "text": "ܘܐܬܐ ܠܢܨܪܬ ܐܝܟܐ ܕܐܬܪܒܝ ܘܥܠ ܐܝܟܢܐ ܕܡܥܕ ܗܘܐ ܠܟܢܘܫܬܐ ܒܝܘܡܐ ܕܫܒܬܐ ܘܩܡ ܠܡܩܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.17",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Luke 4:17",
      "text": "ܘܐܬܝܗܒ ܠܗ ܤܦܪܐ ܕܐܫܥܝܐ ܢܒܝܐ ܘܦܬܚ ܝܫܘܥ ܤܦܪܐ ܘܐܫܟܚ ܕܘܟܬܐ ܐܝܟܐ ܕܟܬܝܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.18",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Luke 4:18",
      "text": "ܪܘܚܗ ܕܡܪܝܐ ܥܠܝ ܘܡܛܠ ܗܕܐ ܡܫܚܢܝ ܠܡܤܒܪܘ ܠܡܤܟܢܐ ܘܫܠܚܢܝ ܠܡܐܤܝܘ ܠܬܒܝܪܝ ܠܒܐ ܘܠܡܟܪܙܘ ܠܫܒܝܐ ܫܘܒܩܢܐ ܘܠܥܘܝܪܐ ܚܙܝܐ ܘܠܡܫܪܪܘ ܠܬܒܝܪܐ ܒܫܘܒܩܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.19",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Luke 4:19",
      "text": "ܘܠܡܟܪܙܘ ܫܢܬܐ ܡܩܒܠܬܐ ܠܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.20",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Luke 4:20",
      "text": "ܘܟܪܟ ܤܦܪܐ ܘܝܗܒܗ ܠܡܫܡܫܢܐ ܘܐܙܠ ܝܬܒ ܟܠܗܘܢ ܕܝܢ ܕܒܟܢܘܫܬܐ ܥܝܢܝܗܘܢ ܚܝܪܢ ܗܘܝ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.21",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Luke 4:21",
      "text": "ܘܫܪܝ ܠܡܐܡܪ ܠܘܬܗܘܢ ܕܝܘܡܢܐ ܐܫܬܠܡ ܟܬܒܐ ܗܢܐ ܒܐܕܢܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.22",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Luke 4:22",
      "text": "ܘܤܗܕܝܢ ܗܘܘ ܠܗ ܟܠܗܘܢ ܘܡܬܕܡܪܝܢ ܗܘܘ ܒܡܠܐ ܕܛܝܒܘܬܐ ܕܢܦܩܢ ܗܘܝ ܡܢ ܦܘܡܗ ܘܐܡܪܝܢ ܗܘܘ ܠܐ ܗܘܐ ܗܢܐ ܒܪ ܝܘܤܦ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.23",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Luke 4:23",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܟܒܪ ܬܐܡܪܘܢ ܠܝ ܡܬܠܐ ܗܢܐ ܐܤܝܐ ܐܤܐ ܢܦܫܟ ܘܟܠ ܕܫܡܥܢ ܕܥܒܕܬ ܒܟܦܪܢܚܘܡ ܥܒܕ ܐܦ ܗܪܟܐ ܒܡܕܝܢܬܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.24",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Luke 4:24",
      "text": "ܗܘ ܕܝܢ ܐܡܪ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܠܝܬ ܢܒܝܐ ܕܡܬܩܒܠ ܒܡܕܝܢܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.25",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Luke 4:25",
      "text": "ܫܪܪܐ ܓܝܪ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܤܓܝ ܐܪܡܠܬܐ ܐܝܬ ܗܘܝ ܒܐܝܤܪܝܠ ܒܝܘܡܝ ܐܠܝܐ ܢܒܝܐ ܟܕ ܐܬܬܚܕܘ ܫܡܝܐ ܫܢܝܢ ܬܠܬ ܘܝܪܚܐ ܫܬܐ ܘܗܘܐ ܟܦܢܐ ܪܒܐ ܒܟܠܗ ܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.26",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Luke 4:26",
      "text": "ܘܠܘܬ ܚܕܐ ܡܢܗܝܢ ܠܐ ܐܫܬܕܪ ܐܠܝܐ ܐܠܐ ܠܨܪܦܬ ܕܨܝܕܢ ܠܘܬ ܐܢܬܬܐ ܐܪܡܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.27",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Luke 4:27",
      "text": "ܘܤܓܝܐܐ ܓܪܒܐ ܐܝܬ ܗܘܘ ܒܝܬ ܐܝܤܪܝܠ ܒܝܘܡܝ ܐܠܝܫܥ ܢܒܝܐ ܘܚܕ ܡܢܗܘܢ ܠܐ ܐܬܕܟܝ ܐܠܐ ܐܢ ܢܥܡܢ ܐܪܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.28",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "Luke 4:28",
      "text": "ܘܟܕ ܫܡܥܘ ܗܠܝܢ ܗܢܘܢ ܕܒܟܢܘܫܬܐ ܐܬܡܠܝܘ ܚܡܬܐ ܟܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.29",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "Luke 4:29",
      "text": "ܘܩܡܘ ܐܦܩܘܗܝ ܠܒܪ ܡܢ ܡܕܝܢܬܐ ܘܐܝܬܝܘܗܝ ܥܕܡܐ ܠܓܒܝܢܐ ܕܛܘܪܐ ܗܘ ܕܡܕܝܢܬܗܘܢ ܒܢܝܐ ܗܘܬ ܥܠܘܗܝ ܕܢܫܕܘܢܝܗܝ ܡܢ ܫܩܝܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.30",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "Luke 4:30",
      "text": "ܗܘ ܕܝܢ ܥܒܪ ܒܝܢܬܗܘܢ ܘܐܙܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.31",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "Luke 4:31",
      "text": "ܘܢܚܬ ܠܟܦܪܢܚܘܡ ܡܕܝܢܬܐ ܕܓܠܝܠܐ ܘܡܠܦ ܗܘܐ ܠܗܘܢ ܒܫܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.32",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 32,
      "referenceLabel": "Luke 4:32",
      "text": "ܘܬܡܝܗܝܢ ܗܘܘ ܒܝܘܠܦܢܗ ܕܡܫܠܛܐ ܗܘܬ ܡܠܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.33",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 33,
      "referenceLabel": "Luke 4:33",
      "text": "ܘܐܝܬ ܗܘܐ ܒܟܢܘܫܬܐ ܓܒܪܐ ܕܐܝܬ ܗܘܐ ܒܗ ܪܘܚܐ ܕܫܐܕܐ ܛܢܦܐ ܘܙܥܩ ܒܩܠܐ ܪܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.34",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 34,
      "referenceLabel": "Luke 4:34",
      "text": "ܘܐܡܪ ܫܒܘܩܝܢܝ ܡܐ ܠܢ ܘܠܟ ܝܫܘܥ ܢܨܪܝܐ ܐܬܝܬ ܠܡܘܒܕܘܬܢ ܝܕܥ ܐܢܐ ܠܟ ܡܢ ܐܢܬ ܩܕܝܫܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.35",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 35,
      "referenceLabel": "Luke 4:35",
      "text": "ܘܟܐܐ ܒܗ ܝܫܘܥ ܘܐܡܪ ܤܟܘܪ ܦܘܡܟ ܘܦܘܩ ܡܢܗ ܘܫܕܝܗܝ ܫܐܕܐ ܒܡܨܥܬܐ ܘܢܦܩ ܡܢܗ ܟܕ ܠܐ ܤܪܚ ܒܗ ܡܕܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.36",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 36,
      "referenceLabel": "Luke 4:36",
      "text": "ܘܬܡܗܐ ܪܒܐ ܐܚܕ ܠܟܠܢܫ ܘܡܡܠܠܝܢ ܗܘܘ ܥܡ ܚܕܕܐ ܘܐܡܪܝܢ ܡܢܐ ܗܝ ܟܝ ܡܠܬܐ ܗܕܐ ܕܒܫܘܠܛܢܐ ܘܒܚܝܠܐ ܦܩܕܐ ܠܪܘܚܐ ܛܢܦܬܐ ܘܢܦܩܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.37",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 37,
      "referenceLabel": "Luke 4:37",
      "text": "ܘܢܦܩ ܥܠܘܗܝ ܛܒܐ ܒܟܠܗ ܐܬܪܐ ܕܚܕܪܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.4.38",
      "translationId": "peshitta",
      "bookSlug": "luke",
