    },
    {
      "id": "peshitta:luke.18.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Luke 18:11",
      "text": "ܘܗܘ ܦܪܝܫܐ ܩܐܡ ܗܘܐ ܒܝܢܘܗܝ ܠܢܦܫܗ ܘܗܠܝܢ ܡܨܠܐ ܗܘܐ ܐܠܗܐ ܡܘܕܐ ܐܢܐ ܠܟ ܕܠܐ ܗܘܝܬ ܐܝܟ ܫܪܟܐ ܕܐܢܫܐ ܚܛܘܦܐ ܘܥܠܘܒܐ ܘܓܝܪܐ ܘܠܐ ܐܝܟ ܗܢܐ ܡܟܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.18.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Luke 18:12",
      "text": "ܐܠܐ ܨܐܡ ܐܢܐ ܬܪܝܢ ܒܫܒܬܐ ܘܡܥܤܪ ܐܢܐ ܟܠ ܡܕܡ ܕܩܢܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
