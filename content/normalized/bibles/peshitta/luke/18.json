      "verseNumber": 1,
      "referenceLabel": "Luke 18:1",
      "text": "ܐܡܪ ܠܗܘܢ ܕܝܢ ܐܦ ܡܬܠܐ ܕܒܟܠ ܥܕܢ ܢܨܠܘܢ ܘܠܐ ܬܡܐܢ ܠܗܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.18.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Luke 18:2",
      "text": "ܕܝܢܐ ܚܕ ܐܝܬ ܗܘܐ ܒܡܕܝܢܬܐ ܚܕܐ ܕܡܢ ܐܠܗܐ ܠܐ ܕܚܠ ܗܘܐ ܘܡܢ ܒܢܝܢܫܐ ܠܐ ܡܬܟܚܕ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.18.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Luke 18:3",
      "text": "ܐܪܡܠܬܐ ܕܝܢ ܚܕܐ ܐܝܬ ܗܘܬ ܒܡܕܝܢܬܐ ܗܝ ܘܐܬܝܐ ܗܘܬ ܠܘܬܗ ܘܐܡܪܐ ܬܒܥܝܢܝ ܡܢ ܒܥܠ ܕܝܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.18.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Luke 18:4",
      "text": "ܘܠܐ ܨܒܐ ܗܘܐ ܙܒܢܐ ܤܓܝܐܐ ܒܬܪܟܢ ܕܝܢ ܐܡܪ ܒܢܦܫܗ ܐܢ ܡܢ ܐܠܗܐ ܠܐ ܕܚܠ ܐܢܐ ܘܡܢ ܒܢܝܢܫܐ ܠܐ ܡܬܟܚܕ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.18.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Luke 18:5",
      "text": "ܐܦܢ ܡܛܠ ܕܡܠܐܝܐ ܠܝ ܗܕܐ ܐܪܡܠܬܐ ܐܬܒܥܝܗ ܕܠܐ ܒܟܠ ܥܕܢ ܬܗܘܐ ܐܬܝܐ ܡܗܪܐ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.18.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Luke 18:6",
      "text": "ܘܐܡܪ ܡܪܢ ܫܡܥܘ ܡܢܐ ܐܡܪ ܕܝܢܐ ܕܥܘܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.18.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Luke 18:7",
      "text": "ܐܠܗܐ ܕܝܢ ܠܐ ܝܬܝܪܐܝܬ ܢܥܒܕ ܬܒܥܬܐ ܠܓܒܘܗܝ ܕܩܪܝܢ ܠܗ ܒܐܝܡܡܐ ܘܒܠܠܝܐ ܘܡܓܪ ܪܘܚܗ ܥܠܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.18.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Luke 18:8",
      "text": "ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܢܥܒܕ ܬܒܥܬܗܘܢ ܒܥܓܠ ܒܪܡ ܢܐܬܐ ܒܪܗ ܕܐܢܫܐ ܘܢܫܟܚ ܟܝ ܗܝܡܢܘܬܐ ܥܠ ܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.18.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Luke 18:9",
      "text": "ܘܐܡܪ ܗܘܐ ܡܬܠܐ ܗܢܐ ܠܘܩܒܠ ܐܢܫܐ ܐܝܠܝܢ ܕܬܟܝܠܝܢ ܥܠ ܢܦܫܗܘܢ ܕܐܝܬܝܗܘܢ ܙܕܝܩܐ ܘܒܤܝܢ ܥܠ ܟܠܢܫ ܀",
      "paragraphStart": false
