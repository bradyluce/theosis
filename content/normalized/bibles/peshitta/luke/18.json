    {
      "id": "peshitta:luke.18.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Luke 18:10",
      "text": "ܬܪܝܢ ܓܒܪܝܢ ܤܠܩܘ ܠܗܝܟܠܐ ܠܡܨܠܝܘ ܚܕ ܦܪܝܫܐ ܘܐܚܪܢܐ ܡܟܤܐ ܀",
