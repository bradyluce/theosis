    {
      "id": "peshitta:luke.21.31",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Luke 21:31",
      "text": "ܗܟܢܐ ܐܦ ܐܢܬܘܢ ܡܐ ܕܚܙܝܬܘܢ ܗܠܝܢ ܕܗܘܝܢ ܕܥܘ ܕܩܪܝܒܐ ܗܝ ܡܠܟܘܬܐ ܕܐܠܗܐ ܀",
