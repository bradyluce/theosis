  "verses": [
    {
      "id": "peshitta:luke.21.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Luke 21:1",
      "text": "ܚܪ ܕܝܢ ܝܫܘܥ ܒܥܬܝܪܐ ܐܝܠܝܢ ܕܪܡܝܢ ܗܘܘ ܒܝܬ ܓܙܐ ܩܘܪܒܢܝܗܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.21.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Luke 21:2",
      "text": "ܘܚܙܐ ܐܦ ܐܪܡܠܬܐ ܚܕܐ ܡܤܟܢܬܐ ܕܐܪܡܝܬ ܫܡܘܢܐ ܬܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Luke 21:3",
      "text": "ܘܐܡܪ ܫܪܪܐ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܗܕܐ ܐܪܡܠܬܐ ܡܤܟܢܬܐ ܐܪܡܝܬ ܝܬܝܪ ܡܢ ܟܠܢܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Luke 21:4",
      "text": "ܟܠܗܘܢ ܓܝܪ ܗܠܝܢ ܡܢ ܡܐ ܕܝܬܝܪ ܗܘܐ ܠܗܘܢ ܐܪܡܝܘ ܒܝܬ ܩܘܪܒܢܐ ܕܐܠܗܐ ܗܕܐ ܕܝܢ ܡܢ ܚܤܝܪܘܬܗ ܟܠ ܕܩܢܝܐ ܗܘܬ ܐܪܡܝܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Luke 21:5",
      "text": "ܘܟܕ ܐܡܪܝܢ ܗܘܘ ܐܢܫܝܢ ܥܠ ܗܝܟܠܐ ܕܒܟܐܦܐ ܫܦܝܪܬܐ ܘܒܩܘܪܒܢܐ ܡܨܒܬ ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Luke 21:6",
      "text": "ܗܠܝܢ ܕܚܙܝܢ ܐܢܬܘܢ ܢܐܬܘܢ ܝܘܡܬܐ ܕܒܗܘܢ ܠܐ ܬܫܬܒܩ ܟܐܦ ܥܠ ܟܐܦ ܕܠܐ ܬܤܬܬܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Luke 21:7",
      "text": "ܘܡܫܐܠܝܢ ܗܘܘ ܠܗ ܘܐܡܪܝܢ ܡܠܦܢܐ ܐܡܬܝ ܗܠܝܢ ܢܗܘܝܢ ܘܡܢܐ ܗܝ ܐܬܐ ܡܐ ܕܩܪܝܒܢ ܗܠܝܢ ܕܢܗܘܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Luke 21:8",
      "text": "ܗܘ ܕܝܢ ܐܡܪ ܠܗܘܢ ܚܙܘ ܠܡܐ ܬܛܥܘܢ ܤܓܝܐܐ ܓܝܪ ܢܐܬܘܢ ܒܫܡܝ ܘܢܐܡܪܘܢ ܕܐܢܐ ܐܢܐ ܡܫܝܚܐ ܘܙܒܢܐ ܩܪܒ ܠܐ ܕܝܢ ܬܐܙܠܘܢ ܒܬܪܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Luke 21:9",
      "text": "ܘܡܐ ܕܫܡܥܝܢ ܐܢܬܘܢ ܩܪܒܐ ܘܫܓܘܫܝܐ ܠܐ ܬܕܚܠܘܢ ܥܬܝܕܢ ܐܢܝܢ ܓܝܪ ܗܠܝܢ ܠܘܩܕܡ ܠܡܗܘܐ ܐܠܐ ܠܐ ܥܕܟܝܠ ܡܛܬ ܚܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Luke 21:10",
      "text": "ܢܩܘܡ ܓܝܪ ܥܡܐ ܥܠ ܥܡܐ ܘܡܠܟܘ ܥܠ ܡܠܟܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Luke 21:11",
      "text": "ܘܙܘܥܐ ܪܘܪܒܐ ܢܗܘܘܢ ܒܕܘܟܐ ܕܘܟܐ ܘܟܦܢܐ ܘܡܘܬܢܐ ܘܢܗܘܝܢ ܕܚܠܬܐ ܘܤܘܪܕܐ ܘܐܬܘܬܐ ܪܘܪܒܬܐ ܡܢ ܫܡܝܐ ܢܬܚܙܝܢ ܘܤܬܘܐ ܪܘܪܒܐ ܢܗܘܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Luke 21:12",
      "text": "ܩܕܡ ܕܝܢ ܗܠܝܢ ܟܠܗܝܢ ܢܪܡܘܢ ܥܠܝܟܘܢ ܐܝܕܝܐ ܘܢܪܕܦܘܢܟܘܢ ܘܢܫܠܡܘܢܟܘܢ ܠܟܢܘܫܬܐ ܘܠܒܝܬ ܐܤܝܪܐ ܘܢܩܪܒܘܢܟܘܢ ܩܕܡ ܡܠܟܐ ܘܗܓܡܘܢܐ ܡܛܠ ܫܡܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.13",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Luke 21:13",
      "text": "ܗܘܝܐ ܠܟܘܢ ܕܝܢ ܠܤܗܕܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Luke 21:14",
      "text": "ܤܝܡܘ ܕܝܢ ܒܠܒܟܘܢ ܕܠܐ ܬܗܘܘܢ ܡܬܝܠܦܝܢ ܠܡܦܩ ܪܘܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Luke 21:15",
      "text": "ܐܢܐ ܓܝܪ ܐܬܠ ܠܟܘܢ ܦܘܡܐ ܘܚܟܡܬܐ ܐܝܕܐ ܕܠܐ ܢܫܟܚܘܢ ܠܡܩܡ ܠܩܘܒܠܗ ܟܠܗܘܢ ܒܥܠܕܒܒܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.16",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Luke 21:16",
      "text": "ܢܫܠܡܘܢܟܘܢ ܕܝܢ ܐܒܗܝܟܘܢ ܘܐܚܝܟܘܢ ܘܐܚܝܢܝܟܘܢ ܘܪܚܡܝܟܘܢ ܘܢܡܝܬܘܢ ܡܢܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.17",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Luke 21:17",
      "text": "ܘܬܗܘܘܢ ܤܢܝܐܝܢ ܡܢ ܟܠ ܐܢܫ ܡܛܠ ܫܡܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.18",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Luke 21:18",
      "text": "ܘܡܢܬܐ ܡܢ ܪܫܟܘܢ ܠܐ ܬܐܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.19",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Luke 21:19",
      "text": "ܒܡܤܝܒܪܢܘܬܟܘܢ ܕܝܢ ܬܩܢܘܢ ܢܦܫܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.20",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Luke 21:20",
      "text": "ܡܐ ܕܝܢ ܕܚܙܝܬܘܢ ܠܐܘܪܫܠܡ ܕܚܕܝܪܝܢ ܠܗ ܚܝܠܐ ܗܝܕܝܢ ܕܥܘ ܕܩܪܒ ܠܗ ܚܘܪܒܗ ܀",
