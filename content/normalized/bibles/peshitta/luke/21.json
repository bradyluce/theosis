    {
      "id": "peshitta:luke.21.35",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 35,
      "referenceLabel": "Luke 21:35",
      "text": "ܐܝܟ ܨܦܚܬܐ ܓܝܪ ܢܨܦܚ ܥܠ ܟܠܗܘܢ ܐܝܠܝܢ ܕܝܬܒܝܢ ܥܠ ܐܦܝܗ ܕܟܠܗ ܐܪܥܐ ܀",
