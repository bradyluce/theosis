    {
      "id": "peshitta:luke.21.30",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Luke 21:30",
      "text": "ܕܡܐ ܕܡܦܪܥܝܢ ܡܚܕܐ ܡܢܗܘܢ ܡܤܬܟܠܝܢ ܐܢܬܘܢ ܕܩܪܒ ܠܗ ܩܝܛܐ ܀",
