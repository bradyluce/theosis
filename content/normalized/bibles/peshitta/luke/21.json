    {
      "id": "peshitta:luke.21.24",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Luke 21:24",
      "text": "ܘܢܦܠܘܢ ܒܦܘܡܐ ܕܚܪܒܐ ܘܢܫܬܒܘܢ ܠܟܠ ܐܬܪ ܘܐܘܪܫܠܡ ܬܗܘܐ ܡܬܕܝܫܐ ܡܢ ܥܡܡܐ ܥܕܡܐ ܕܢܫܠܡܘܢ ܙܒܢܐ ܕܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.25",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Luke 21:25",
      "text": "ܘܢܗܘܝܢ ܐܬܘܬܐ ܒܫܡܫܐ ܘܒܤܗܪܐ ܘܒܟܘܟܒܐ ܘܒܐܪܥܐ ܐܘܠܨܢܐ ܕܥܡܡܐ ܘܦܘܫܟ ܐܝܕܝܐ ܡܢ ܬܘܗܬܐ ܕܩܠܐ ܕܝܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.26",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Luke 21:26",
      "text": "ܘܙܘܥܐ ܕܡܦܩ ܢܦܫܬܐ ܕܒܢܝܢܫܐ ܡܢ ܕܚܠܬܐ ܕܡܕܡ ܕܥܬܝܕ ܠܡܐܬܐ ܥܠ ܐܪܥܐ ܘܢܬܬܙܝܥܘܢ ܚܝܠܐ ܕܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.27",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Luke 21:27",
      "text": "ܘܗܝܕܝܢ ܢܚܙܘܢܝܗܝ ܠܒܪܗ ܕܐܢܫܐ ܕܐܬܐ ܒܥܢܢܐ ܥܡ ܚܝܠܐ ܤܓܝܐܐ ܘܫܘܒܚܐ ܪܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.28",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Luke 21:28",
      "text": "ܡܐ ܕܝܢ ܕܫܪܝ ܗܠܝܢ ܕܢܗܘܝܢ ܐܬܠܒܒܘ ܘܐܪܝܡܘ ܪܫܝܟܘܢ ܡܛܠ ܕܩܪܒ ܠܗ ܦܘܪܩܢܟܘܢ ܀",
