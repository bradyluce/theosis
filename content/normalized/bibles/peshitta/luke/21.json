    {
      "id": "peshitta:luke.21.29",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Luke 21:29",
      "text": "ܘܐܡܪ ܗܘܐ ܠܗܘܢ ܡܬܠܐ ܚܙܘ ܠܬܬܐ ܘܠܟܠܗܘܢ ܐܝܠܢܐ ܀",
      "paragraphStart": false
