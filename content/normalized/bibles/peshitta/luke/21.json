    {
      "id": "peshitta:luke.21.21",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Luke 21:21",
      "text": "ܗܝܕܝܢ ܐܝܠܝܢ ܕܒܝܗܘܕ ܐܢܘܢ ܢܥܪܩܘܢ ܠܛܘܪܐ ܘܐܝܠܝܢ ܕܒܓܘܗ ܐܢܘܢ ܢܥܪܩܘܢ ܘܕܒܩܘܪܝܐ ܠܐ ܢܥܠܘܢ ܠܗ ܀",
      "paragraphStart": false
