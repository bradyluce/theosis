    {
      "id": "peshitta:luke.21.22",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Luke 21:22",
      "text": "ܕܝܘܡܬܐ ܐܢܘܢ ܗܠܝܢ ܕܬܒܥܬܐ ܕܢܫܠܡ ܟܠ ܡܐ ܕܟܬܝܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.21.23",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Luke 21:23",
      "text": "ܘܝ ܕܝܢ ܠܐܝܠܝܢ ܕܒܛܢܢ ܘܠܐܝܠܝܢ ܕܡܝܢܩܢ ܒܗܢܘܢ ܝܘܡܬܐ ܢܗܘܐ ܓܝܪ ܐܘܠܨܢܐ ܪܒܐ ܒܐܪܥܐ ܘܪܘܓܙܐ ܥܠ ܥܡܐ ܗܢܐ ܀",
      "paragraphStart": false
