    {
      "id": "peshitta:luke.7.16",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Luke 7:16",
      "text": "ܘܐܚܕܬ ܕܚܠܬܐ ܠܐܢܫܐ ܟܠܗܘܢ ܘܡܫܒܚܝܢ ܗܘܘ ܠܐܠܗܐ ܘܐܡܪܝܢ ܕܢܒܝܐ ܪܒܐ ܩܡ ܒܢ ܘܤܥܪ ܐܠܗܐ ܠܥܡܗ ܀",
      "paragraphStart": false
