  "verses": [
    {
      "id": "peshitta:luke.7.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Luke 7:1",
      "text": "ܘܟܕ ܫܠܡ ܡܠܐ ܟܠܗܝܢ ܠܡܫܡܥܬܗ ܕܥܡܐ ܥܠ ܝܫܘܥ ܠܟܦܪܢܚܘܡ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.7.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Luke 7:2",
      "text": "ܥܒܕܗ ܕܝܢ ܕܩܢܛܪܘܢܐ ܚܕ ܥܒܝܕ ܗܘܐ ܒܝܫܐܝܬ ܐܝܢܐ ܕܝܩܝܪ ܗܘܐ ܥܠܘܗܝ ܘܩܪܝܒ ܗܘܐ ܠܡܡܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.7.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Luke 7:3",
      "text": "ܘܫܡܥ ܥܠ ܝܫܘܥ ܘܫܕܪ ܠܘܬܗ ܩܫܝܫܐ ܕܝܗܘܕܝܐ ܘܒܥܐ ܗܘܐ ܡܢܗ ܐܝܟ ܕܢܐܬܐ ܢܚܐ ܠܥܒܕܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.7.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Luke 7:4",
      "text": "ܗܢܘܢ ܕܝܢ ܟܕ ܐܬܘ ܠܘܬ ܝܫܘܥ ܒܥܝܢ ܗܘܘ ܡܢܗ ܒܛܝܠܐܝܬ ܘܐܡܪܝܢ ܫܘܐ ܗܘ ܕܬܥܒܕ ܠܗ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.7.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Luke 7:5",
      "text": "ܪܚܡ ܓܝܪ ܠܥܡܢ ܘܐܦ ܒܝܬ ܟܢܘܫܬܐ ܗܘ ܒܢܐ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.7.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Luke 7:6",
      "text": "ܝܫܘܥ ܕܝܢ ܐܙܠ ܗܘܐ ܥܡܗܘܢ ܟܕ ܕܝܢ ܠܐ ܤܓܝ ܪܚܝܩ ܡܢ ܒܝܬܐ ܫܕܪ ܠܘܬܗ ܩܢܛܪܘܢܐ ܪܚܡܘܗܝ ܘܐܡܪ ܠܗ ܡܪܝ ܠܐ ܬܥܡܠ ܠܐ ܓܝܪ ܫܘܐ ܐܢܐ ܕܬܥܘܠ ܬܚܝܬ ܡܛܠܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.7.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Luke 7:7",
      "text": "ܡܛܠ ܗܘ ܐܢܐ ܠܐ ܫܘܝܬ ܕܠܘܬܟ ܐܬܐ ܐܠܐ ܐܡܪ ܒܡܠܬܐ ܘܢܬܐܤܐ ܛܠܝܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.7.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Luke 7:8",
      "text": "ܐܦ ܐܢܐ ܓܝܪ ܓܒܪܐ ܐܢܐ ܕܡܫܥܒܕ ܐܢܐ ܬܚܝܬ ܫܘܠܛܢܐ ܘܐܝܬ ܬܚܝܬ ܐܝܕܝ ܐܤܛܪܛܝܘܛܐ ܘܐܡܪ ܐܢܐ ܠܗܢܐ ܕܙܠ ܘܐܙܠ ܘܠܐܚܪܢܐ ܕܬܐ ܘܐܬܐ ܘܠܥܒܕܝ ܥܒܕ ܗܕܐ ܘܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.7.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Luke 7:9",
      "text": "ܟܕ ܫܡܥ ܕܝܢ ܝܫܘܥ ܗܠܝܢ ܐܬܕܡܪ ܒܗ ܘܐܬܦܢܝ ܘܐܡܪ ܠܟܢܫܐ ܕܐܬܐ ܒܬܪܗ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܐܦ ܠܐ ܒܝܬ ܐܝܤܪܝܠ ܐܫܟܚܬ ܐܝܟ ܗܕܐ ܗܝܡܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.7.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Luke 7:10",
      "text": "ܘܗܦܟܘ ܗܢܘܢ ܕܐܫܬܕܪܘ ܠܒܝܬܐ ܘܐܫܟܚܘ ܠܥܒܕܐ ܗܘ ܕܟܪܝܗ ܗܘܐ ܟܕ ܚܠܝܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.7.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Luke 7:11",
      "text": "ܘܗܘܐ ܠܝܘܡܐ ܕܒܬܪܗ ܐܙܠ ܗܘܐ ܠܡܕܝܢܬܐ ܕܫܡܗ ܢܐܝܢ ܘܬܠܡܝܕܘܗܝ ܥܡܗ ܘܟܢܫܐ ܤܓܝܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.7.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Luke 7:12",
      "text": "ܘܟܕ ܩܪܒ ܠܬܪܥܐ ܕܡܕܝܢܬܐ ܚܙܐ ܟܕ ܡܠܘܝܢ ܡܝܬܐ ܕܝܚܝܕܝܐ ܗܘܐ ܠܐܡܗ ܘܗܝ ܐܡܗ ܐܪܡܠܬܐ ܗܘܬ ܘܟܢܫܐ ܤܓܝܐܐ ܕܒܢܝ ܡܕܝܢܬܐ ܥܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.7.13",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Luke 7:13",
      "text": "ܚܙܗ ܕܝܢ ܝܫܘܥ ܘܐܬܪܚܡ ܥܠܝܗ ܘܐܡܪ ܠܗ ܠܐ ܬܒܟܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.7.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Luke 7:14",
      "text": "ܘܐܙܠ ܩܪܒ ܠܥܪܤܐ ܘܗܢܘܢ ܕܫܩܝܠܝܢ ܗܘܘ ܠܗ ܩܡܘ ܘܐܡܪ ܥܠܝܡܐ ܠܟ ܐܡܪ ܐܢܐ ܩܘܡ ܀",
      "paragraphStart": false
