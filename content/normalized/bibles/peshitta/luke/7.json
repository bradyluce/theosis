      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Luke 7:23",
      "text": "ܘܛܘܒܘܗܝ ܠܡܢ ܕܠܐ ܢܬܟܫܠ ܒܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.7.24",
