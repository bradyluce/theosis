    {
      "id": "peshitta:luke.7.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Luke 7:15",
      "text": "ܘܝܬܒ ܗܘ ܡܝܬܐ ܘܫܪܝ ܠܡܡܠܠܘ ܘܝܗܒܗ ܠܐܡܗ ܀",
      "paragraphStart": false
