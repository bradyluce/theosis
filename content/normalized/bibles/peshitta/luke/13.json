      "bookSlug": "luke",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Luke 13:9",
      "text": "ܘܐܢ ܥܒܕܬ ܦܐܪܐ ܘܐܠܐ ܠܡܢܚܝ ܬܦܤܩܝܗ ܀",
      "paragraphStart": false
