      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Luke 13:1",
      "text": "ܒܗܘ ܕܝܢ ܙܒܢܐ ܐܬܘ ܐܢܫܝܢ ܐܡܪܘ ܠܗ ܥܠ ܓܠܝܠܝܐ ܗܢܘܢ ܕܦܝܠܛܘܤ ܚܠܛ ܕܡܗܘܢ ܥܡ ܕܒܚܝܗܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.13.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Luke 13:2",
      "text": "ܘܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗܘܢ ܤܒܪܝܢ ܐܢܬܘܢ ܕܗܠܝܢ ܓܠܝܠܝܐ ܚܛܝܝܢ ܗܘܘ ܝܬܝܪ ܡܢ ܟܠܗܘܢ ܓܠܝܠܝܐ ܕܗܟܢܐ ܗܘܐ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.13.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Luke 13:3",
      "text": "ܠܐ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܝܢ ܕܐܦ ܟܠܟܘܢ ܐܠܐ ܬܬܘܒܘܢ ܗܟܢܐ ܬܐܒܕܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.13.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Luke 13:4",
      "text": "ܐܘ ܗܢܘܢ ܬܡܢܬܥܤܪ ܕܢܦܠ ܥܠܝܗܘܢ ܡܓܕܠܐ ܒܫܝܠܘܚܐ ܘܩܛܠ ܐܢܘܢ ܤܒܪܝܢ ܐܢܬܘܢ ܕܚܛܝܝܢ ܗܘܘ ܝܬܝܪ ܡܢ ܟܠܗܘܢ ܒܢܝܢܫܐ ܕܥܡܪܝܢ ܒܐܘܪܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.13.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Luke 13:5",
      "text": "ܠܐ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܝܢ ܕܐܠܐ ܬܬܘܒܘܢ ܟܠܟܘܢ ܐܟܘܬܗܘܢ ܬܐܒܕܘܢ ܀",
      "paragraphStart": false
