      "bookSlug": "luke",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Luke 13:8",
      "text": "ܐܡܪ ܠܗ ܦܠܚܐ ܡܪܝ ܫܒܘܩܝܗ ܐܦ ܗܕܐ ܫܢܬܐ ܥܕ ܐܦܠܚܝܗ ܘܐܙܒܠܝܗ ܀",
      "paragraphStart": false
