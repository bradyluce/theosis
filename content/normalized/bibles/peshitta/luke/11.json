  "verses": [
    {
      "id": "peshitta:luke.11.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Luke 11:1",
      "text": "ܘܗܘܐ ܕܟܕ ܗܘ ܡܨܠܐ ܒܕܘܟܬܐ ܚܕܐ ܟܕ ܫܠܡ ܐܡܪ ܠܗ ܚܕ ܡܢ ܬܠܡܝܕܘܗܝ ܡܪܢ ܐܠܦܝܢ ܠܡܨܠܝܘ ܐܝܟܢܐ ܕܐܦ ܝܘܚܢܢ ܐܠܦ ܠܬܠܡܝܕܘܗܝ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.11.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Luke 11:2",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܐܡܬܝ ܕܡܨܠܝܢ ܐܢܬܘܢ ܗܟܢܐ ܗܘܝܬܘܢ ܐܡܪܝܢ ܐܒܘܢ ܕܒܫܡܝܐ ܢܬܩܕܫ ܫܡܟ ܬܐܬܐ ܡܠܟܘܬܟ ܢܗܘܐ ܨܒܝܢܟ ܐܝܟ ܕܒܫܡܝܐ ܐܦ ܒܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Luke 11:3",
      "text": "ܗܒ ܠܢ ܠܚܡܐ ܕܤܘܢܩܢܢ ܟܠܝܘܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Luke 11:4",
      "text": "ܘܫܒܘܩ ܠܢ ܚܛܗܝܢ ܐܦ ܐܢܚܢܢ ܓܝܪ ܫܒܩܢ ܠܟܠ ܕܚܝܒܝܢ ܠܢ ܘܠܐ ܬܥܠܢ ܠܢܤܝܘܢܐ ܐܠܐ ܦܪܘܩܝܢ ܡܢ ܒܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Luke 11:5",
      "text": "ܘܐܡܪ ܠܗܘܢ ܡܢܘ ܡܢܟܘܢ ܕܐܝܬ ܠܗ ܪܚܡܐ ܘܢܐܙܠ ܠܘܬܗ ܒܦܠܓܘܬ ܠܠܝܐ ܘܢܐܡܪ ܠܗ ܪܚܡܝ ܐܫܐܠܝܢܝ ܬܠܬ ܓܪܝܨܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Luke 11:6",
      "text": "ܡܛܠ ܕܪܚܡܐ ܐܬܐ ܠܘܬܝ ܡܢ ܐܘܪܚܐ ܘܠܝܬ ܠܝ ܡܕܡ ܕܐܤܝܡ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Luke 11:7",
      "text": "ܘܗܘ ܪܚܡܗ ܡܢ ܠܓܘ ܢܥܢܐ ܘܢܐܡܪ ܠܗ ܠܐ ܬܗܪܝܢܝ ܕܗܐ ܬܪܥܐ ܐܚܝܕ ܗܘ ܘܒܢܝ ܥܡܝ ܒܥܪܤܐ ܠܐ ܡܫܟܚ ܐܢܐ ܕܐܩܘܡ ܘܐܬܠ ܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Luke 11:8",
      "text": "ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܐܢ ܡܛܠ ܪܚܡܘܬܐ ܠܐ ܢܬܠ ܠܗ ܡܛܠ ܚܨܝܦܘܬܗ ܢܩܘܡ ܘܢܬܠ ܠܗ ܟܡܐ ܕܡܬܒܥܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Luke 11:9",
      "text": "ܐܦ ܐܢܐ ܐܡܪ ܐܢܐ ܠܟܘܢ ܫܐܠܘ ܘܢܬܝܗܒ ܠܟܘܢ ܒܥܘ ܘܬܫܟܚܘܢ ܩܘܫܘ ܘܢܬܦܬܚ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Luke 11:10",
      "text": "ܟܠ ܓܝܪ ܕܫܐܠ ܢܤܒ ܘܕܒܥܐ ܡܫܟܚ ܘܕܢܩܫ ܡܬܦܬܚ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Luke 11:11",
      "text": "ܐܝܢܐ ܓܝܪ ܡܢܟܘܢ ܐܒܐ ܕܢܫܐܠܝܘܗܝ ܒܪܗ ܠܚܡܐ ܠܡܐ ܟܐܦܐ ܡܘܫܛ ܠܗ ܘܐܢ ܢܘܢܐ ܢܫܐܠܝܘܗܝ ܠܡܐ ܚܠܦ ܢܘܢܐ ܚܘܝܐ ܡܘܫܛ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Luke 11:12",
      "text": "ܘܐܢ ܒܪܬܐ ܢܫܐܠܝܘܗܝ ܠܡܐ ܗܘ ܥܩܪܒܐ ܡܘܫܛ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.13",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Luke 11:13",
      "text": "ܘܐܢ ܐܢܬܘܢ ܕܒܝܫܐ ܐܝܬܝܟܘܢ ܝܕܥܝܢ ܐܢܬܘܢ ܡܘܗܒܬܐ ܛܒܬܐ ܠܡܬܠ ܠܒܢܝܟܘܢ ܟܡܐ ܝܬܝܪܐܝܬ ܐܒܘܟܘܢ ܡܢ ܫܡܝܐ ܢܬܠ ܪܘܚܐ ܕܩܘܕܫܐ ܠܐܝܠܝܢ ܕܫܐܠܝܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Luke 11:14",
      "text": "ܘܟܕ ܡܦܩ ܫܐܕܐ ܕܐܝܬܘܗܝ ܚܪܫܐ ܗܘܐ ܕܟܕ ܢܦܩ ܗܘ ܫܐܕܐ ܡܠܠ ܗܘ ܚܪܫܐ ܘܐܬܕܡܪܘ ܟܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Luke 11:15",
      "text": "ܐܢܫܐ ܕܝܢ ܡܢܗܘܢ ܐܡܪܘ ܒܒܥܠܙܒܘܒ ܪܫܐ ܕܕܝܘܐ ܡܦܩ ܗܢܐ ܕܝܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.16",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Luke 11:16",
      "text": "ܐܚܪܢܐ ܕܝܢ ܟܕ ܡܢܤܝܢ ܠܗ ܐܬܐ ܡܢ ܫܡܝܐ ܫܐܠܝܢ ܗܘܘ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.17",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Luke 11:17",
      "text": "ܝܫܘܥ ܕܝܢ ܕܝܕܥ ܗܘܐ ܡܚܫܒܬܗܘܢ ܐܡܪ ܠܗܘܢ ܟܠ ܡܠܟܘ ܕܬܬܦܠܓ ܥܠ ܢܦܫܗ ܬܚܪܒ ܘܒܝܬܐ ܕܥܠ ܩܢܘܡܗ ܡܬܦܠܓ ܢܦܠ ܀ ܀",
      "paragraphStart": false
    },
    {
