    {
      "id": "peshitta:luke.11.20",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Luke 11:20",
      "text": "ܐܢ ܕܝܢ ܒܨܒܥܐ ܕܐܠܗܐ ܡܦܩ ܐܢܐ ܕܝܘܐ ܩܪܒܬ ܠܗ ܥܠܝܟܘܢ ܡܠܟܘܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.21",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Luke 11:21",
      "text": "ܐܡܬܝ ܕܚܤܝܢܐ ܟܕ ܡܙܝܢ ܢܛܪ ܕܪܬܗ ܒܫܝܢܐ ܗܘ ܩܢܝܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.22",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Luke 11:22",
      "text": "ܐܢ ܕܝܢ ܢܐܬܐ ܡܢ ܕܚܤܝܢ ܡܢܗ ܢܙܟܝܘܗܝ ܟܠܗ ܙܝܢܗ ܫܩܠ ܗܘ ܕܬܟܝܠ ܗܘܐ ܥܠܘܗܝ ܘܒܙܬܗ ܡܦܠܓ ܀",
