    {
      "id": "peshitta:luke.11.23",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Luke 11:23",
      "text": "ܡܢ ܕܠܐ ܗܘܐ ܥܡܝ ܠܘܩܒܠܝ ܗܘ ܘܡܢ ܕܠܐ ܟܢܫ ܥܡܝ ܡܒܕܪܘ ܡܒܕܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.24",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Luke 11:24",
      "text": "ܪܘܚܐ ܛܢܦܬܐ ܡܐ ܕܢܦܩܬ ܡܢ ܒܪ ܐܢܫܐ ܐܙܠܐ ܡܬܟܪܟܐ ܒܐܬܪܘܬܐ ܕܡܝܐ ܠܝܬ ܒܗܘܢ ܕܬܒܥܐ ܠܗ ܢܝܚܐ ܘܡܐ ܕܠܐ ܐܫܟܚܬ ܐܡܪܐ ܐܗܦܘܟ ܠܒܝܬܝ ܐܝܡܟܐ ܕܢܦܩܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.25",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Luke 11:25",
      "text": "ܘܐܢ ܐܬܬ ܐܫܟܚܬܗ ܕܚܡܝܡ ܘܡܨܒܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.26",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Luke 11:26",
      "text": "ܗܝܕܝܢ ܐܙܠܐ ܕܒܪܐ ܫܒܥ ܪܘܚܝܢ ܐܚܪܢܝܢ ܕܒܝܫܢ ܡܢܗ ܘܥܐܠܢ ܘܥܡܪܢ ܬܡܢ ܘܗܘܝܐ ܚܪܬܗ ܕܒܪܢܫܐ ܗܘ ܒܝܫܐ ܡܢ ܩܕܡܝܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.27",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Luke 11:27",
      "text": "ܘܟܕ ܗܠܝܢ ܡܡܠܠ ܗܘܐ ܐܪܝܡܬ ܐܢܬܬܐ ܚܕܐ ܩܠܗ ܡܢ ܟܢܫܐ ܘܐܡܪܬ ܠܗ ܛܘܒܝܗ ܠܟܪܤܐ ܕܛܥܢܬܟ ܘܠܬܕܝܐ ܕܐܝܢܩܘܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.28",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "Luke 11:28",
      "text": "ܐܡܪ ܠܗ ܗܘ ܛܘܒܝܗܘܢ ܠܐܝܠܝܢ ܕܫܡܥܘ ܡܠܬܗ ܕܐܠܗܐ ܘܢܛܪܝܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.29",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "Luke 11:29",
      "text": "ܘܟܕ ܡܬܟܢܫܝܢ ܗܘܘ ܟܢܫܐ ܫܪܝ ܠܡܐܡܪ ܫܪܒܬܐ ܗܕܐ ܒܝܫܬܐ ܐܬܐ ܒܥܝܐ ܘܐܬܐ ܠܐ ܬܬܝܗܒ ܠܗ ܐܠܐ ܐܬܗ ܕܝܘܢܢ ܢܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.30",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "Luke 11:30",
      "text": "ܐܝܟܢܐ ܓܝܪ ܕܗܘܐ ܝܘܢܢ ܐܬܐ ܠܢܝܢܘܝܐ ܗܟܢܐ ܢܗܘܐ ܐܦ ܒܪܗ ܕܐܢܫܐ ܠܫܪܒܬܐ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.31",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "Luke 11:31",
      "text": "ܡܠܟܬܐ ܕܬܝܡܢܐ ܬܩܘܡ ܒܕܝܢܐ ܥܡ ܐܢܫܐ ܕܫܪܒܬܐ ܗܕܐ ܘܬܚܝܒ ܐܢܘܢ ܕܐܬܬ ܡܢ ܥܒܪܝܗ ܕܐܪܥܐ ܕܬܫܡܥ ܚܟܡܬܗ ܕܫܠܝܡܘܢ ܘܗܐ ܕܝܬܝܪ ܡܢ ܫܠܝܡܘܢ ܗܪܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.32",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 11,
      "verseNumber": 32,
      "referenceLabel": "Luke 11:32",
      "text": "ܓܒܪܐ ܢܝܢܘܝܐ ܢܩܘܡܘܢ ܒܕܝܢܐ ܥܡ ܫܪܒܬܐ ܗܕܐ ܘܢܚܝܒܘܢܗ ܕܬܒܘ ܒܟܪܘܙܘܬܗ ܕܝܘܢܢ ܘܗܐ ܕܝܬܝܪ ܡܢ ܝܘܢܢ ܗܪܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.11.33",
