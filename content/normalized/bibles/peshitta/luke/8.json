    {
      "id": "peshitta:luke.8.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Luke 8:14",
      "text": "ܗܘ ܕܝܢ ܕܢܦܠ ܒܝܬ ܟܘܒܐ ܗܠܝܢ ܐܢܘܢ ܐܝܠܝܢ ܕܫܡܥܝܢ ܡܠܬܐ ܘܒܨܦܬܐ ܘܒܥܘܬܪܐ ܘܒܪܓܝܓܬܗ ܕܥܠܡܐ ܡܬܚܢܩܝܢ ܘܦܐܪܐ ܠܐ ܝܗܒܝܢ ܀",
      "paragraphStart": false
