    {
      "id": "peshitta:luke.8.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Luke 8:10",
      "text": "ܗܘ ܕܝܢ ܐܡܪ ܠܗܘܢ ܠܟܘܢ ܗܘ ܝܗܝܒ ܠܡܕܥ ܐܪܙܐ ܕܡܠܟܘܬܗ ܕܐܠܗܐ ܠܗܢܘܢ ܕܝܢ ܫܪܟܐ ܒܦܠܐܬܐ ܡܬܐܡܪ ܕܟܕ ܚܙܝܢ ܠܐ ܢܚܙܘܢ ܘܟܕ ܫܡܥܝܢ ܠܐ ܢܤܬܟܠܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.8.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Luke 8:11",
      "text": "ܗܢܘ ܕܝܢ ܡܬܠܐ ܙܪܥܐ ܐܝܬܘܗܝ ܡܠܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
