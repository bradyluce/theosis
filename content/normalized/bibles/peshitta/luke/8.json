    {
      "id": "peshitta:luke.8.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Luke 8:15",
      "text": "ܗܘ ܕܝܢ ܕܒܐܪܥܐ ܛܒܬܐ ܗܠܝܢ ܐܢܘܢ ܐܝܠܝܢ ܕܒܠܒܐ ܫܦܝܐ ܘܛܒܐ ܫܡܥܝܢ ܡܠܬܐ ܘܐܚܕܝܢ ܘܝܗܒܝܢ ܦܐܪܐ ܒܡܤܝܒܪܢܘܬܐ ܀",
