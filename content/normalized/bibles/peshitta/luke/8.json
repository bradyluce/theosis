      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Luke 8:1",
      "text": "ܘܗܘܐ ܡܢ ܒܬܪ ܗܠܝܢ ܡܬܟܪܟ ܗܘܐ ܝܫܘܥ ܒܡܕܝܢܬܐ ܘܒܩܘܪܝܐ ܘܡܟܪܙ ܗܘܐ ܘܡܤܒܪ ܡܠܟܘܬܐ ܕܐܠܗܐ ܘܬܪܥܤܪܬܗ ܥܡܗ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.8.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Luke 8:2",
      "text": "ܘܢܫܐ ܗܠܝܢ ܕܐܬܐܤܝ ܡܢ ܟܘܪܗܢܐ ܘܡܢ ܪܘܚܐ ܒܝܫܬܐ ܡܪܝܡ ܕܡܬܩܪܝܐ ܡܓܕܠܝܬܐ ܗܝ ܕܫܒܥܐ ܫܐܕܝܢ ܢܦܩܘ ܡܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.8.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Luke 8:3",
      "text": "ܘܝܘܚܢ ܐܢܬܬ ܟܘܙܐ ܪܒܝܬܗ ܕܗܪܘܕܤ ܘܫܘܫܢ ܘܐܚܪܢܝܬܐ ܤܓܝܐܬܐ ܐܝܠܝܢ ܕܡܫܡܫܢ ܗܘܝ ܠܗܘܢ ܡܢ ܩܢܝܢܝܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.8.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Luke 8:4",
      "text": "ܘܟܕ ܟܢܫܐ ܤܓܝܐܐ ܟܢܫ ܗܘܐ ܘܡܢ ܟܠ ܡܕܝܢܢ ܐܬܝܢ ܗܘܘ ܠܘܬܗ ܐܡܪ ܒܡܬܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.8.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Luke 8:5",
      "text": "ܢܦܩ ܙܪܘܥܐ ܠܡܙܪܥ ܙܪܥܗ ܘܟܕ ܙܪܥ ܐܝܬ ܕܢܦܠ ܥܠ ܝܕ ܐܘܪܚܐ ܘܐܬܕܝܫ ܘܐܟܠܬܗ ܦܪܚܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.8.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Luke 8:6",
      "text": "ܘܐܚܪܢܐ ܢܦܠ ܥܠ ܫܘܥܐ ܘܒܪ ܫܥܬܗ ܝܥܐ ܘܕܠܝܬ ܗܘܐ ܠܗ ܬܠܝܠܘܬܐ ܝܒܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.8.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Luke 8:7",
      "text": "ܘܐܚܪܢܐ ܢܦܠ ܒܝܬ ܟܘܒܐ ܘܝܥܘ ܥܡܗ ܟܘܒܐ ܘܚܢܩܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.8.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Luke 8:8",
      "text": "ܘܐܚܪܢܐ ܢܦܠ ܒܐܪܥܐ ܛܒܬܐ ܘܫܦܝܪܬܐ ܘܝܥܐ ܘܥܒܕ ܦܐܪܐ ܚܕ ܒܡܐܐ ܗܠܝܢ ܟܕ ܐܡܪ ܩܥܐ ܗܘܐ ܕܡܢ ܕܐܝܬ ܠܗ ܐܕܢܐ ܕܢܫܡܥ ܢܫܡܥ ܀",
