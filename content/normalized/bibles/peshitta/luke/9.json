    "referenceLabel": "Luke 9",
    "summary": "Source text for Luke 9 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:luke.9.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Luke 9:1",
      "text": "ܘܩܪܐ ܝܫܘܥ ܠܬܪܥܤܪܬܗ ܘܝܗܒ ܠܗܘܢ ܚܝܠܐ ܘܫܘܠܛܢܐ ܥܠ ܟܠܗܘܢ ܫܐܕܐ ܘܟܘܪܗܢܐ ܠܡܐܤܝܘ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.9.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Luke 9:2",
      "text": "ܘܫܕܪ ܐܢܘܢ ܠܡܟܪܙܘ ܡܠܟܘܬܗ ܕܐܠܗܐ ܘܠܡܐܤܝܘ ܟܪܝܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Luke 9:3",
      "text": "ܘܐܡܪ ܠܗܘܢ ܡܕܡ ܠܐ ܬܫܩܠܘܢ ܠܐܘܪܚܐ ܠܐ ܫܒܛܐ ܘܠܐ ܬܪܡܠܐ ܘܠܐ ܠܚܡܐ ܘܠܐ ܟܤܦܐ ܘܠܐ ܬܪܬܝܢ ܟܘܬܝܢܝܢ ܢܗܘܝܢ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Luke 9:4",
      "text": "ܘܠܐܝܢܐ ܒܝܬܐ ܕܥܐܠܝܢ ܐܢܬܘܢ ܠܗ ܬܡܢ ܗܘܘ ܘܡܢ ܬܡܢ ܦܘܩܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Luke 9:5",
      "text": "ܘܠܡܢ ܕܠܐ ܡܩܒܠܝܢ ܠܟܘܢ ܡܐ ܕܢܦܩܝܢ ܐܢܬܘܢ ܡܢ ܡܕܝܢܬܐ ܗܝ ܐܦ ܚܠܐ ܡܢ ܪܓܠܝܟܘܢ ܦܨܘ ܥܠܝܗܘܢ ܠܤܗܕܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Luke 9:6",
      "text": "ܘܢܦܩܘ ܫܠܝܚܐ ܘܡܬܟܪܟܝܢ ܗܘܘ ܒܩܘܪܝܐ ܘܒܡܕܝܢܬܐ ܘܡܤܒܪܝܢ ܗܘܘ ܘܡܐܤܝܢ ܒܟܠ ܕܘܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Luke 9:7",
      "text": "ܫܡܥ ܕܝܢ ܗܪܘܕܤ ܛܛܪܪܟܐ ܟܠܗܝܢ ܕܗܘܝܢ ܗܘܝ ܒܐܝܕܗ ܘܡܬܕܡܪ ܗܘܐ ܡܛܠ ܕܐܡܪܝܢ ܗܘܘ ܐܢܫܝܢ ܕܝܘܚܢܢ ܩܡ ܡܢ ܒܝܬ ܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Luke 9:8",
      "text": "ܐܚܪܢܐ ܕܝܢ ܐܡܪܝܢ ܗܘܘ ܕܐܠܝܐ ܐܬܚܙܝ ܘܐܚܪܢܐ ܕܢܒܝܐ ܡܢ ܢܒܝܐ ܩܕܡܝܐ ܩܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Luke 9:9",
      "text": "ܘܐܡܪ ܗܪܘܕܤ ܪܫܗ ܕܝܘܚܢܢ ܐܢܐ ܦܤܩܬ ܡܢܘ ܕܝܢ ܗܢܐ ܕܗܠܝܢ ܫܡܥ ܐܢܐ ܥܠܘܗܝ ܘܨܒܐ ܗܘܐ ܕܢܚܙܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Luke 9:10",
      "text": "ܘܟܕ ܗܦܟܘ ܫܠܝܚܐ ܐܫܬܥܝܘ ܠܝܫܘܥ ܟܠܡܕܡ ܕܥܒܕܘ ܘܕܒܪ ܐܢܘܢ ܒܠܚܘܕܝܗܘܢ ܠܐܬܪܐ ܚܘܪܒܐ ܕܒܝܬ ܨܝܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Luke 9:11",
      "text": "ܟܢܫܐ ܕܝܢ ܟܕ ܝܕܥܘ ܐܙܠܘ ܒܬܪܗ ܘܩܒܠ ܐܢܘܢ ܘܡܡܠܠ ܗܘܐ ܥܡܗܘܢ ܥܠ ܡܠܟܘܬܐ ܕܐܠܗܐ ܘܠܐܝܠܝܢ ܕܤܢܝܩܝܢ ܗܘܘ ܥܠ ܐܤܝܘܬܐ ܡܐܤܐ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Luke 9:12",
      "text": "ܟܕ ܕܝܢ ܫܪܝ ܝܘܡܐ ܠܡܨܠܐ ܩܪܒܘ ܬܠܡܝܕܘܗܝ ܘܐܡܪܝܢ ܠܗ ܫܪܝ ܠܟܢܫܐ ܕܢܐܙܠܘܢ ܠܩܘܪܝܐ ܕܚܕܪܝܢ ܘܠܟܦܪܘܢܐ ܕܢܫܪܘܢ ܒܗܘܢ ܘܢܫܟܚܘܢ ܠܗܘܢ ܤܝܒܪܬܐ ܡܛܠ ܕܒܐܬܪܐ ܚܘܪܒܐ ܐܝܬܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.13",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Luke 9:13",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܗܒܘ ܠܗܘܢ ܐܢܬܘܢ ܠܡܐܟܠ ܗܢܘܢ ܕܝܢ ܐܡܪܝܢ ܠܝܬ ܠܢ ܝܬܝܪ ܡܢ ܚܡܫܐ ܠܚܡܝܢ ܘܬܪܝܢ ܢܘܢܝܢ ܐܠܐ ܐܢ ܐܙܠܢܢ ܘܙܒܢܢ ܤܝܒܪܬܐ ܠܗܢܐ ܟܠܗ ܥܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Luke 9:14",
      "text": "ܗܘܝܢ ܗܘܘ ܓܝܪ ܐܝܟ ܚܡܫܐ ܐܠܦܝܢ ܓܒܪܝܢ ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܐܤܡܟܘ ܐܢܘܢ ܤܡܟܐ ܚܡܫܝܢ ܐܢܫܝܢ ܒܤܡܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Luke 9:15",
      "text": "ܘܥܒܕܘ ܗܟܘܬ ܬܠܡܝܕܐ ܘܐܤܡܟܘ ܠܟܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.16",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Luke 9:16",
      "text": "ܘܢܤܒ ܝܫܘܥ ܗܢܘܢ ܚܡܫܐ ܠܚܡܝܢ ܘܬܪܝܢ ܢܘܢܝܢ ܘܚܪ ܒܫܡܝܐ ܘܒܪܟ ܘܩܨܐ ܘܝܗܒ ܠܬܠܡܝܕܘܗܝ ܕܢܤܝܡܘܢ ܠܟܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.17",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Luke 9:17",
      "text": "ܘܐܟܠܘ ܟܠܗܘܢ ܘܤܒܥܘ ܘܫܩܠܘ ܩܨܝܐ ܡܕܡ ܕܐܘܬܪܘ ܬܪܥܤܪ ܩܘܦܝܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.18",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Luke 9:18",
      "text": "ܘܟܕ ܡܨܠܐ ܒܠܚܘܕܘܗܝ ܘܬܠܡܝܕܘܗܝ ܥܡܗ ܫܐܠ ܐܢܘܢ ܘܐܡܪ ܡܢܘ ܐܡܪܝܢ ܥܠܝ ܟܢܫܐ ܕܐܝܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.19",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Luke 9:19",
      "text": "ܥܢܘ ܘܐܡܪܝܢ ܠܗ ܕܝܘܚܢܢ ܡܥܡܕܢܐ ܘܐܚܪܢܐ ܕܐܠܝܐ ܐܚܪܢܐ ܕܝܢ ܕܢܒܝܐ ܚܕ ܡܢ ܢܒܝܐ ܩܕܡܝܐ ܩܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.20",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Luke 9:20",
      "text": "ܐܡܪ ܠܗܘܢ ܐܢܬܘܢ ܕܝܢ ܡܢܘ ܐܡܪܝܢ ܐܢܬܘܢ ܕܐܝܬܝ ܥܢܐ ܫܡܥܘܢ ܘܐܡܪ ܡܫܝܚܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.21",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Luke 9:21",
      "text": "ܗܘ ܕܝܢ ܟܐܐ ܒܗܘܢ ܘܙܗܪ ܐܢܘܢ ܕܗܕܐ ܠܐܢܫ ܠܐ ܢܐܡܪܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.22",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "Luke 9:22",
      "text": "ܘܐܡܪ ܠܗܘܢ ܕܥܬܝܕ ܗܘ ܒܪܗ ܕܐܢܫܐ ܕܤܓܝܐܬܐ ܢܚܫ ܘܕܢܤܬܠܐ ܡܢ ܩܫܝܫܐ ܘܪܒܝ ܟܗܢܐ ܘܤܦܪܐ ܘܢܩܛܠܘܢܝܗܝ ܘܠܝܘܡܐ ܕܬܠܬܐ ܢܩܘܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.23",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "Luke 9:23",
      "text": "ܘܐܡܪ ܗܘܐ ܩܕܡ ܟܠܢܫ ܡܢ ܕܨܒܐ ܕܢܐܬܐ ܒܬܪܝ ܢܟܦܘܪ ܒܢܦܫܗ ܘܢܫܩܘܠ ܙܩܝܦܗ ܟܠܝܘܡ ܘܢܐܬܐ ܒܬܪܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.24",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "Luke 9:24",
      "text": "ܡܢ ܓܝܪ ܕܨܒܐ ܕܢܦܫܗ ܢܚܐ ܡܘܒܕ ܠܗ ܡܢ ܕܝܢ ܕܢܘܒܕ ܢܦܫܗ ܡܛܠܬܝ ܗܢܐ ܡܚܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.25",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "Luke 9:25",
      "text": "ܡܢܐ ܓܝܪ ܢܬܥܕܪ ܒܪ ܐܢܫܐ ܕܢܐܬܪ ܥܠܡܐ ܟܠܗ ܢܦܫܗ ܕܝܢ ܢܘܒܕ ܐܘ ܢܚܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.26",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "Luke 9:26",
      "text": "ܡܢ ܕܢܒܗܬ ܒܝ ܕܝܢ ܘܒܡܠܝ ܢܒܗܬ ܒܗ ܒܪܗ ܕܐܢܫܐ ܡܐ ܕܐܬܐ ܒܫܘܒܚܐ ܕܐܒܘܗܝ ܥܡ ܡܠܐܟܘܗܝ ܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.27",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "Luke 9:27",
      "text": "ܫܪܪܐ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܐܝܬ ܐܢܫܐ ܕܩܝܡܝܢ ܗܪܟܐ ܕܠܐ ܢܛܥܡܘܢ ܡܘܬܐ ܥܕܡܐ ܕܢܚܙܘܢ ܡܠܟܘܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.28",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "Luke 9:28",
      "text": "ܗܘܐ ܕܝܢ ܒܬܪ ܡܠܐ ܗܠܝܢ ܐܝܟ ܬܡܢܝܐ ܝܘܡܝܢ ܕܒܪ ܝܫܘܥ ܠܫܡܥܘܢ ܘܠܝܥܩܘܒ ܘܠܝܘܚܢܢ ܘܤܠܩ ܠܛܘܪܐ ܠܡܨܠܝܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.29",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 29,
      "referenceLabel": "Luke 9:29",
      "text": "ܘܟܕ ܗܘ ܡܨܠܐ ܐܬܚܠܦ ܚܙܘܐ ܕܐܦܘܗܝ ܘܢܚܬܘܗܝ ܚܘܪܘ ܘܡܒܪܩܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.30",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 30,
      "referenceLabel": "Luke 9:30",
      "text": "ܘܗܐ ܬܪܝܢ ܓܒܪܝܢ ܡܡܠܠܝܢ ܗܘܘ ܥܡܗ ܕܐܝܬܝܗܘܢ ܡܘܫܐ ܘܐܠܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.31",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 31,
      "referenceLabel": "Luke 9:31",
      "text": "ܕܐܬܚܙܝܘ ܒܬܫܒܘܚܬܐ ܐܡܪܝܢ ܗܘܘ ܕܝܢ ܥܠ ܡܦܩܢܗ ܕܥܬܝܕ ܗܘܐ ܕܢܫܬܠܡ ܒܐܘܪܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.32",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 32,
      "referenceLabel": "Luke 9:32",
      "text": "ܘܝܩܪܘ ܗܘܘ ܠܗܘܢ ܒܫܢܬܐ ܫܡܥܘܢ ܘܗܢܘܢ ܕܥܡܗ ܘܠܡܚܤܢ ܐܬܬܥܝܪܘ ܘܚܙܘ ܫܘܒܚܗ ܘܠܗܢܘܢ ܬܪܝܢ ܐܢܫܝܢ ܕܩܝܡܝܢ ܗܘܘ ܠܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.33",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
      "verseNumber": 33,
      "referenceLabel": "Luke 9:33",
      "text": "ܘܟܕ ܫܪܝܘ ܠܡܦܪܫ ܡܢܗ ܐܡܪ ܫܡܥܘܢ ܠܝܫܘܥ ܪܒܝ ܫܦܝܪ ܗܘ ܠܢ ܕܗܪܟܐ ܢܗܘܐ ܘܢܥܒܕ ܬܠܬ ܡܛܠܝܢ ܠܟ ܚܕܐ ܘܠܡܘܫܐ ܚܕܐ ܘܠܐܠܝܐ ܚܕܐ ܘܠܐ ܝܕܥ ܗܘܐ ܡܢܐ ܐܡܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.9.34",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 9,
