    "bookSlug": "luke",
    "chapterNumber": 20,
    "referenceLabel": "Luke 20",
    "summary": "Source text for Luke 20 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:luke.20.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Luke 20:1",
      "text": "ܘܗܘܐ ܒܚܕ ܡܢ ܝܘܡܬܐ ܟܕ ܡܠܦ ܒܗܝܟܠܐ ܠܥܡܐ ܘܡܤܒܪ ܩܡܘ ܥܠܘܗܝ ܪܒܝ ܟܗܢܐ ܘܤܦܪܐ ܥܡ ܩܫܝܫܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.20.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Luke 20:2",
      "text": "ܘܐܡܪܝܢ ܠܗ ܐܡܪ ܠܢ ܒܐܝܢܐ ܫܘܠܛܢܐ ܗܠܝܢ ܥܒܕ ܐܢܬ ܘܡܢܘ ܗܘ ܕܝܗܒ ܠܟ ܫܘܠܛܢܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Luke 20:3",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗܘܢ ܐܫܐܠܟܘܢ ܐܦ ܐܢܐ ܡܠܬܐ ܘܐܡܪܘ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Luke 20:4",
      "text": "ܡܥܡܘܕܝܬܗ ܕܝܘܚܢܢ ܡܢ ܫܡܝܐ ܗܘܬ ܐܘ ܡܢ ܒܢܝ ܐܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Luke 20:5",
      "text": "ܗܢܘܢ ܕܝܢ ܡܬܚܫܒܝܢ ܗܘܘ ܒܢܦܫܗܘܢ ܘܐܡܪܝܢ ܕܐܢ ܢܐܡܪ ܡܢ ܫܡܝܐ ܐܡܪ ܠܢ ܘܡܛܠ ܡܢܐ ܠܐ ܗܝܡܢܬܘܢܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Luke 20:6",
      "text": "ܐܢ ܕܝܢ ܢܐܡܪ ܡܢ ܒܢܝ ܐܢܫܐ ܪܓܡ ܠܢ ܥܡܐ ܟܠܗ ܡܦܤܝܢ ܓܝܪ ܕܝܘܚܢܢ ܢܒܝܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Luke 20:7",
      "text": "ܘܐܡܪܘ ܠܗ ܕܠܐ ܝܕܥܝܢܢ ܡܢ ܐܝܡܟܐ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Luke 20:8",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܘܠܐ ܐܢܐ ܐܡܪ ܐܢܐ ܠܟܘܢ ܒܐܝܢܐ ܫܘܠܛܢܐ ܗܠܝܢ ܥܒܕ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Luke 20:9",
      "text": "ܘܫܪܝ ܕܢܐܡܪ ܠܥܡܐ ܡܬܠܐ ܗܢܐ ܓܒܪܐ ܚܕ ܢܨܒ ܟܪܡܐ ܘܐܘܚܕܗ ܠܦܠܚܐ ܘܐܒܥܕ ܙܒܢܐ ܤܓܝܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Luke 20:10",
      "text": "ܘܒܙܒܢܐ ܫܕܪ ܥܒܕܗ ܠܘܬ ܦܠܚܐ ܕܢܬܠܘܢ ܠܗ ܡܢ ܦܐܪܐ ܕܟܪܡܐ ܦܠܚܐ ܕܝܢ ܡܚܐܘܗܝ ܘܫܕܪܘܗܝ ܟܕ ܤܪܝܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Luke 20:11",
      "text": "ܘܐܘܤܦ ܘܫܕܪ ܠܥܒܕܗ ܐܚܪܢܐ ܗܢܘܢ ܕܝܢ ܐܦ ܠܗܘ ܡܚܐܘܗܝ ܘܨܥܪܘܗܝ ܘܫܕܪܘܗܝ ܟܕ ܤܪܝܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Luke 20:12",
      "text": "ܘܐܘܤܦ ܘܫܕܪ ܕܬܠܬܐ ܗܢܘܢ ܕܝܢ ܘܐܦ ܠܗܘ ܨܠܦܘܗܝ ܘܐܦܩܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.13",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "Luke 20:13",
      "text": "ܐܡܪ ܡܪܐ ܟܪܡܐ ܡܢܐ ܐܥܒܕ ܐܫܕܪ ܒܪܝ ܚܒܝܒܐ ܟܒܪ ܢܚܙܘܢܝܗܝ ܘܢܬܟܚܕܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 14,
      "referenceLabel": "Luke 20:14",
      "text": "ܟܕ ܚܙܐܘܗܝ ܕܝܢ ܦܠܚܐ ܡܬܚܫܒܝܢ ܗܘܘ ܒܢܦܫܗܘܢ ܘܐܡܪܝܢ ܗܢܘ ܝܪܬܐ ܬܘ ܢܩܛܠܝܘܗܝ ܘܬܗܘܐ ܝܪܬܘܬܐ ܕܝܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 15,
      "referenceLabel": "Luke 20:15",
      "text": "ܘܐܦܩܘܗܝ ܠܒܪ ܡܢ ܟܪܡܐ ܘܩܛܠܘܗܝ ܡܢܐ ܗܟܝܠ ܢܥܒܕ ܠܗܘܢ ܡܪܐ ܟܪܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.16",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 16,
      "referenceLabel": "Luke 20:16",
      "text": "ܢܐܬܐ ܘܢܘܒܕ ܠܦܠܚܐ ܗܢܘܢ ܘܢܬܠ ܟܪܡܐ ܠܐܚܪܢܐ ܟܕ ܫܡܥܘ ܕܝܢ ܐܡܪܘ ܠܐ ܬܗܘܐ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.17",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 17,
      "referenceLabel": "Luke 20:17",
      "text": "ܗܘ ܕܝܢ ܚܪ ܒܗܘܢ ܘܐܡܪ ܘܡܢܐ ܗܝ ܗܝ ܕܟܬܝܒܐ ܕܟܐܦܐ ܕܐܤܠܝܘ ܒܢܝܐ ܗܝ ܗܘܬ ܠܪܝܫ ܩܪܢܐ ܕܙܘܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.18",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 18,
      "referenceLabel": "Luke 20:18",
      "text": "ܘܟܠ ܕܢܦܠ ܥܠ ܗܝ ܟܐܦܐ ܢܬܪܥܥ ܘܟܠ ܡܢ ܕܗܝ ܬܦܠ ܥܠܘܗܝ ܬܕܪܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.19",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 19,
      "referenceLabel": "Luke 20:19",
      "text": "ܒܥܘ ܗܘܘ ܕܝܢ ܪܒܝ ܟܗܢܐ ܘܤܦܪܐ ܕܢܪܡܘܢ ܥܠܘܗܝ ܐܝܕܝܐ ܒܗܝ ܫܥܬܐ ܘܕܚܠܘ ܡܢ ܥܡܐ ܝܕܥܘ ܓܝܪ ܕܥܠܝܗܘܢ ܐܡܪ ܡܬܠܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.20",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 20,
      "referenceLabel": "Luke 20:20",
      "text": "ܘܫܕܪܘ ܠܘܬܗ ܓܫܘܫܐ ܕܡܬܕܡܝܢ ܒܙܕܝܩܐ ܕܢܐܚܕܘܢܝܗܝ ܒܡܠܬܐ ܘܢܫܠܡܘܢܝܗܝ ܠܕܝܢܐ ܘܠܫܘܠܛܢܗ ܕܗܓܡܘܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.21",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 21,
      "referenceLabel": "Luke 20:21",
      "text": "ܘܫܐܠܘܗܝ ܘܐܡܪܝܢ ܠܗ ܡܠܦܢܐ ܝܕܥܝܢܢ ܕܬܪܝܨܐܝܬ ܡܡܠܠ ܐܢܬ ܘܡܠܦ ܘܠܐ ܢܤܒ ܐܢܬ ܒܐܦܐ ܐܠܐ ܒܩܘܫܬܐ ܐܘܪܚܐ ܕܐܠܗܐ ܡܠܦ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.22",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 22,
      "referenceLabel": "Luke 20:22",
      "text": "ܫܠܝܛ ܠܢ ܕܢܬܠ ܟܤܦ ܪܫܐ ܠܩܤܪ ܐܘ ܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.23",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 23,
      "referenceLabel": "Luke 20:23",
      "text": "ܗܘ ܕܝܢ ܐܤܬܟܠ ܚܪܥܘܬܗܘܢ ܘܐܡܪ ܡܢܐ ܡܢܤܝܢ ܐܢܬܘܢ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.24",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 24,
      "referenceLabel": "Luke 20:24",
      "text": "ܚܘܐܘܢܝ ܕܝܢܪܐ ܕܡܢ ܐܝܬ ܒܗ ܨܠܡܐ ܘܟܬܝܒܬܐ ܗܢܘܢ ܕܝܢ ܐܡܪܘ ܕܩܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.25",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 25,
      "referenceLabel": "Luke 20:25",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܗܒܘ ܗܟܝܠ ܕܩܤܪ ܠܩܤܪ ܘܕܐܠܗܐ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.26",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 26,
      "referenceLabel": "Luke 20:26",
      "text": "ܘܠܐ ܐܫܟܚܘ ܠܡܐܚܕ ܡܢܗ ܡܠܬܐ ܩܕܡ ܥܡܐ ܘܐܬܕܡܪܘ ܥܠ ܦܬܓܡܗ ܘܫܬܩܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.27",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 27,
      "referenceLabel": "Luke 20:27",
      "text": "ܩܪܒܘ ܕܝܢ ܐܢܫܝܢ ܡܢ ܙܕܘܩܝܐ ܗܢܘܢ ܕܐܡܪܝܢ ܕܩܝܡܬܐ ܠܝܬ ܘܫܐܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.28",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 28,
      "referenceLabel": "Luke 20:28",
      "text": "ܘܐܡܪܝܢ ܠܗ ܡܠܦܢܐ ܡܘܫܐ ܟܬܒ ܠܢ ܕܐܢ ܐܢܫ ܢܡܘܬ ܐܚܘܗܝ ܕܐܝܬ ܠܗ ܐܢܬܬܐ ܕܠܐ ܒܢܝܐ ܢܤܒ ܐܚܘܗܝ ܐܢܬܬܗ ܘܢܩܝܡ ܙܪܥܐ ܠܐܚܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.29",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 29,
      "referenceLabel": "Luke 20:29",
      "text": "ܫܒܥܐ ܕܝܢ ܐܚܝܢ ܐܝܬ ܗܘܘ ܩܕܡܝܐ ܢܤܒ ܐܢܬܬܐ ܘܡܝܬ ܕܠܐ ܒܢܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.30",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 30,
      "referenceLabel": "Luke 20:30",
      "text": "ܘܢܤܒܗ ܕܬܪܝܢ ܠܐܢܬܬܗ ܘܗܢܐ ܡܝܬ ܕܠܐ ܒܢܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.31",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 31,
      "referenceLabel": "Luke 20:31",
      "text": "ܘܕܬܠܬܐ ܬܘܒ ܢܤܒܗ ܘܗܟܘܬ ܘܐܦ ܫܒܥܬܝܗܘܢ ܘܡܝܬܘ ܘܠܐ ܫܒܩܘ ܒܢܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.32",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 32,
      "referenceLabel": "Luke 20:32",
      "text": "ܘܡܝܬܬ ܒܚܪܬܐ ܐܦ ܐܢܬܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.33",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 33,
      "referenceLabel": "Luke 20:33",
      "text": "ܒܩܝܡܬܐ ܗܟܝܠ ܕܐܝܢܐ ܡܢܗܘܢ ܬܗܘܐ ܐܢܬܬܐ ܫܒܥܬܝܗܘܢ ܓܝܪ ܢܤܒܘܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.34",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 34,
      "referenceLabel": "Luke 20:34",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܒܢܘܗܝ ܕܥܠܡܐ ܗܢܐ ܢܤܒܝܢ ܢܫܐ ܘܢܫܐ ܗܘܝܢ ܠܓܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.35",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 35,
      "referenceLabel": "Luke 20:35",
      "text": "ܗܢܘܢ ܕܝܢ ܕܠܗܘ ܥܠܡܐ ܫܘܘ ܘܠܩܝܡܬܐ ܕܡܢ ܒܝܬ ܡܝܬܐ ܠܐ ܢܤܒܝܢ ܢܫܐ ܘܐܦ ܠܐ ܢܫܐ ܗܘܝܢ ܠܓܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.36",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 36,
      "referenceLabel": "Luke 20:36",
      "text": "ܐܦܠܐ ܓܝܪ ܬܘܒ ܠܡܡܬ ܡܫܟܚܝܢ ܐܝܟ ܡܠܐܟܐ ܐܢܘܢ ܓܝܪ ܘܒܢܝܐ ܐܝܬܝܗܘܢ ܕܐܠܗܐ ܡܛܠ ܕܗܘܘ ܒܢܝܐ ܕܩܝܡܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.37",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 37,
      "referenceLabel": "Luke 20:37",
      "text": "ܕܩܝܡܝܢ ܕܝܢ ܡܝܬܐ ܐܦ ܡܘܫܐ ܒܕܩ ܐܕܟܪ ܓܝܪ ܒܤܢܝܐ ܟܕ ܐܡܪ ܡܪܝܐ ܐܠܗܗ ܕܐܒܪܗܡ ܘܐܠܗܗ ܕܐܝܤܚܩ ܘܐܠܗܗ ܕܝܥܩܘܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.20.38",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 20,
