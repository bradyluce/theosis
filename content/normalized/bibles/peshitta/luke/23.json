{
  "chapter": {
    "id": "peshitta:luke.23",
    "translationId": "peshitta",
    "bookSlug": "luke",
    "chapterNumber": 23,
    "referenceLabel": "Luke 23",
    "summary": "Source text for Luke 23 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:luke.23.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Luke 23:1",
      "text": "ܘܩܡܘ ܟܠܗ ܟܢܫܗܘܢ ܘܐܝܬܝܘܗܝ ܠܘܬ ܦܝܠܛܘܤ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.23.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Luke 23:2",
      "text": "ܘܫܪܝܘ ܐܟܠܝܢ ܩܪܨܘܗܝ ܘܐܡܪܝܢ ܠܗܢܐ ܐܫܟܚܢ ܕܡܛܥܐ ܥܡܢ ܘܟܠܐ ܕܟܤܦ ܪܫܐ ܠܩܤܪ ܠܐ ܢܬܠ ܘܐܡܪ ܥܠ ܢܦܫܗ ܕܡܠܟܐ ܗܘ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Luke 23:3",
      "text": "ܦܝܠܛܘܤ ܕܝܢ ܫܐܠܗ ܘܐܡܪ ܠܗ ܐܢܬ ܗܘ ܡܠܟܐ ܕܝܗܘܕܝܐ ܐܡܪ ܠܗ ܐܢܬ ܐܡܪܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Luke 23:4",
      "text": "ܘܐܡܪ ܦܝܠܛܘܤ ܠܪܒܝ ܟܗܢܐ ܘܠܟܢܫܐ ܐܢܐ ܡܕܡ ܥܠܬܐ ܠܐ ܡܫܟܚ ܐܢܐ ܥܠ ܓܒܪܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Luke 23:5",
      "text": "ܗܢܘܢ ܕܝܢ ܡܙܥܩܝܢ ܗܘܘ ܘܐܡܪܝܢ ܕܫܓܫܗ ܠܥܡܢ ܟܕ ܡܠܦ ܒܟܠܗ ܝܗܘܕ ܘܫܪܝ ܡܢ ܓܠܝܠܐ ܘܥܕܡܐ ܠܗܪܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Luke 23:6",
      "text": "ܦܝܠܛܘܤ ܕܝܢ ܟܕ ܫܡܥ ܫܡܐ ܕܓܠܝܠܐ ܫܐܠ ܕܐܢ ܓܒܪܐ ܗܘ ܓܠܝܠܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Luke 23:7",
      "text": "ܘܟܕ ܝܕܥ ܕܡܢ ܬܚܝܬ ܫܘܠܛܢܐ ܗܘ ܕܗܪܘܕܤ ܫܕܪܗ ܠܘܬܗ ܕܗܪܘܕܤ ܡܛܠ ܕܒܐܘܪܫܠܡ ܗܘܐ ܒܗܢܘܢ ܝܘܡܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Luke 23:8",
      "text": "ܗܪܘܕܤ ܕܝܢ ܟܕ ܚܙܝܗܝ ܠܝܫܘܥ ܚܕܝ ܛܒ ܨܒܐ ܗܘܐ ܓܝܪ ܠܡܚܙܝܗ ܡܢ ܙܒܢܐ ܤܓܝܐܐ ܡܛܠ ܕܫܡܥ ܗܘܐ ܥܠܘܗܝ ܤܓܝܐܬܐ ܘܡܤܒܪ ܗܘܐ ܕܡܕܡ ܐܬܐ ܢܚܙܐ ܡܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Luke 23:9",
      "text": "ܘܡܠܐ ܤܓܝܐܬܐ ܡܫܐܠ ܗܘܐ ܠܗ ܝܫܘܥ ܕܝܢ ܡܕܡ ܦܬܓܡܐ ܠܐ ܐܬܝܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Luke 23:10",
      "text": "ܩܝܡܝܢ ܗܘܘ ܕܝܢ ܪܒܝ ܟܗܢܐ ܘܤܦܪܐ ܘܥܙܝܙܐܝܬ ܐܟܠܝܢ ܗܘܘ ܩܪܨܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "Luke 23:11",
      "text": "ܗܪܘܕܤ ܕܝܢ ܫܛܗ ܗܘ ܘܦܠܚܘܗܝ ܘܟܕ ܡܒܙܚ ܐܠܒܫܗ ܢܚܬܐ ܕܙܚܘܪܝܬܐ ܘܫܕܪܗ ܠܘܬ ܦܝܠܛܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "Luke 23:12",
      "text": "ܘܒܗܘ ܝܘܡܐ ܗܘܘ ܪܚܡܐ ܦܝܠܛܘܤ ܘܗܪܘܕܤ ܥܡ ܚܕܕܐ ܒܥܠܕܒܒܘܬܐ ܗܘܬ ܓܝܪ ܡܢ ܩܕܝܡ ܒܝܢܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.13",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "Luke 23:13",
      "text": "ܩܪܐ ܕܝܢ ܦܝܠܛܘܤ ܠܪܒܝ ܟܗܢܐ ܘܠܐܪܟܘܢܐ ܘܠܥܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "Luke 23:14",
      "text": "ܘܐܡܪ ܠܗܘܢ ܩܪܒܬܘܢ ܠܝ ܓܒܪܐ ܗܢܐ ܐܝܟ ܡܗܦܟ ܥܡܟܘܢ ܘܗܐ ܐܢܐ ܥܩܒܬܗ ܠܥܢܝܟܘܢ ܘܥܠܬܐ ܡܕܡ ܠܐ ܐܫܟܚܬ ܒܓܒܪܐ ܗܢܐ ܡܢ ܟܠ ܕܡܪܫܝܢ ܐܢܬܘܢ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "Luke 23:15",
      "text": "ܐܠܐ ܐܦܠܐ ܗܪܘܕܤ ܫܕܪܬܗ ܓܝܪ ܠܘܬܗ ܘܗܐ ܠܐ ܡܕܡ ܕܫܘܐ ܠܡܘܬܐ ܤܥܝܪ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.16",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "Luke 23:16",
      "text": "ܐܪܕܝܘܗܝ ܗܟܝܠ ܘܐܫܒܩܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.17",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "Luke 23:17",
      "text": "ܥܝܕܐ ܓܝܪ ܐܝܬ ܗܘܐ ܕܢܫܪܐ ܠܗܘܢ ܚܕ ܒܥܕܥܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.18",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 18,
      "referenceLabel": "Luke 23:18",
      "text": "ܩܥܘ ܕܝܢ ܟܠܗ ܟܢܫܐ ܘܐܡܪܝܢ ܫܩܘܠܝܗܝ ܠܗܢܐ ܘܫܪܝ ܠܢ ܠܒܪ ܐܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.19",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 19,
      "referenceLabel": "Luke 23:19",
      "text": "ܗܘ ܐܝܢܐ ܕܡܛܠ ܐܤܛܤܝܤ ܕܗܘܬ ܒܡܕܝܢܬܐ ܘܩܛܠܐ ܪܡܐ ܗܘܐ ܒܝܬ ܐܤܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.20",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 20,
      "referenceLabel": "Luke 23:20",
      "text": "ܬܘܒ ܕܝܢ ܡܠܠ ܥܡܗܘܢ ܦܝܠܛܘܤ ܟܕ ܨܒܐ ܕܢܫܪܐ ܠܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.21",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 21,
      "referenceLabel": "Luke 23:21",
      "text": "ܗܢܘܢ ܕܝܢ ܩܥܝܢ ܗܘܘ ܘܐܡܪܝܢ ܙܩܘܦܝܗܝ ܙܩܘܦܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.22",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 22,
      "referenceLabel": "Luke 23:22",
      "text": "ܗܘ ܕܝܢ ܕܬܠܬ ܙܒܢܝܢ ܐܡܪ ܠܗܘܢ ܡܢܐ ܓܝܪ ܕܒܝܫ ܥܒܕ ܗܢܐ ܡܕܡ ܥܠܬܐ ܕܫܘܝܐ ܠܡܘܬܐ ܠܐ ܐܫܟܚܬ ܒܗ ܐܪܕܝܘܗܝ ܗܟܝܠ ܘܐܫܒܩܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.23",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 23,
      "referenceLabel": "Luke 23:23",
      "text": "ܗܢܘܢ ܕܝܢ ܬܟܒܝܢ ܗܘܘ ܒܩܠܐ ܪܡܐ ܘܫܐܠܝܢ ܗܘܘ ܠܗ ܕܢܙܩܦܘܢܝܗܝ ܘܥܫܢ ܗܘܐ ܩܠܗܘܢ ܕܝܠܗܘܢ ܘܕܪܒܝ ܟܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.24",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 24,
      "referenceLabel": "Luke 23:24",
      "text": "ܦܝܠܛܘܤ ܕܝܢ ܦܩܕ ܕܬܗܘܐ ܫܐܠܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.25",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 25,
      "referenceLabel": "Luke 23:25",
      "text": "ܘܫܪܐ ܠܗܘܢ ܠܗܘ ܕܡܛܠ ܐܤܛܤܝܤ ܘܩܛܠܐ ܪܡܐ ܗܘܐ ܒܝܬ ܐܤܝܪܐ ܗܘ ܕܫܐܠܘ ܠܝܫܘܥ ܕܝܢ ܐܫܠܡ ܠܨܒܝܢܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.26",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 26,
      "referenceLabel": "Luke 23:26",
      "text": "ܘܟܕ ܡܘܒܠܝܢ ܠܗ ܐܚܕܘ ܠܫܡܥܘܢ ܩܘܪܝܢܝܐ ܕܐܬܐ ܡܢ ܩܪܝܬܐ ܘܤܡܘ ܥܠܘܗܝ ܙܩܝܦܐ ܕܢܛܥܢ ܒܬܪܗ ܕܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.27",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 27,
      "referenceLabel": "Luke 23:27",
      "text": "ܘܐܬܐ ܗܘܐ ܒܬܪܗ ܤܘܓܐܐ ܕܥܡܐ ܘܢܫܐ ܐܝܠܝܢ ܕܡܪܩܕܢ ܗܘܝ ܘܐܠܝܢ ܥܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.28",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 28,
      "referenceLabel": "Luke 23:28",
      "text": "ܘܐܬܦܢܝ ܝܫܘܥ ܠܘܬܗܝܢ ܘܐܡܪ ܒܢܬ ܐܘܪܫܠܡ ܠܐ ܬܒܟܝܢ ܥܠܝ ܒܪܡ ܥܠ ܢܦܫܟܝܢ ܒܟܝܝܢ ܘܥܠ ܒܢܝܟܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.29",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 29,
      "referenceLabel": "Luke 23:29",
      "text": "ܕܗܐ ܐܬܝܢ ܝܘܡܬܐ ܕܒܗܘܢ ܢܐܡܪܘܢ ܛܘܒܝܗܝܢ ܠܥܩܪܬܐ ܘܠܟܪܤܬܐ ܕܠܐ ܝܠܕ ܘܠܬܕܝܐ ܕܠܐ ܐܝܢܩܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.30",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 30,
      "referenceLabel": "Luke 23:30",
      "text": "ܗܝܕܝܢ ܬܫܪܘܢ ܠܡܐܡܪ ܠܛܘܪܐ ܕܦܠܘ ܥܠܝܢ ܘܠܪܡܬܐ ܕܟܤܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.31",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 31,
      "referenceLabel": "Luke 23:31",
      "text": "ܕܐܢ ܒܩܝܤܐ ܪܛܝܒܐ ܗܠܝܢ ܥܒܕܝܢ ܒܝܒܝܫܐ ܡܢܐ ܢܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.32",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 32,
      "referenceLabel": "Luke 23:32",
      "text": "ܘܐܬܝܢ ܗܘܘ ܥܡܗ ܬܪܝܢ ܐܚܪܢܝܢ ܥܒܕܝ ܒܝܫܬܐ ܕܢܬܩܛܠܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.33",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 33,
      "referenceLabel": "Luke 23:33",
      "text": "ܘܟܕ ܐܬܘ ܠܕܘܟܬܐ ܚܕܐ ܕܡܬܩܪܝܐ ܩܪܩܦܬܐ ܙܩܦܘܗܝ ܬܡܢ ܘܠܗܢܘܢ ܥܒܕܝ ܒܝܫܬܐ ܚܕ ܡܢ ܝܡܝܢܗ ܘܚܕ ܡܢ ܤܡܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.34",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 34,
      "referenceLabel": "Luke 23:34",
      "text": "ܗܘ ܕܝܢ ܝܫܘܥ ܐܡܪ ܗܘܐ ܐܒܐ ܫܒܘܩ ܠܗܘܢ ܠܐ ܓܝܪ ܝܕܥܝܢ ܡܢܐ ܥܒܕܝܢ ܘܦܠܓܘ ܢܚܬܘܗܝ ܘܐܪܡܝܘ ܥܠܝܗܘܢ ܦܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.35",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 35,
      "referenceLabel": "Luke 23:35",
      "text": "ܩܐܡ ܗܘܐ ܕܝܢ ܥܡܐ ܘܚܙܐ ܘܡܡܝܩܝܢ ܗܘܘ ܒܗ ܐܦ ܐܪܟܘܢܐ ܘܐܡܪܝܢ ܠܐܚܪܢܐ ܐܚܝ ܢܚܐ ܢܦܫܗ ܐܢ ܗܘܝܘ ܡܫܝܚܐ ܓܒܝܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.36",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 36,
      "referenceLabel": "Luke 23:36",
      "text": "ܘܡܒܙܚܝܢ ܗܘܘ ܒܗ ܐܦ ܐܤܛܪܛܝܘܛܐ ܟܕ ܩܪܒܝܢ ܠܘܬܗ ܘܡܩܪܒܝܢ ܠܗ ܚܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.37",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 37,
      "referenceLabel": "Luke 23:37",
      "text": "ܘܐܡܪܝܢ ܠܗ ܐܢ ܐܢܬ ܗܘ ܡܠܟܐ ܕܝܗܘܕܝܐ ܐܚܐ ܢܦܫܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.23.38",
      "translationId": "peshitta",
