      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 36,
      "referenceLabel": "Luke 19:36",
      "text": "ܟܕ ܕܝܢ ܐܙܠ ܦܪܤܝܢ ܗܘܘ ܡܐܢܝܗܘܢ ܒܐܘܪܚܐ ܀",
      "paragraphStart": false
