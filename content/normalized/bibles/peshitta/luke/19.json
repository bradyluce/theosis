    {
      "id": "peshitta:luke.19.35",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 35,
      "referenceLabel": "Luke 19:35",
      "text": "ܘܐܝܬܝܘܗܝ ܠܘܬ ܝܫܘܥ ܘܐܪܡܝܘ ܥܠ ܥܝܠܐ ܡܐܢܝܗܘܢ ܘܐܪܟܒܘܗܝ ܠܝܫܘܥ ܥܠܘܗܝ ܀",
      "paragraphStart": false
