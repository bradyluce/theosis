    {
      "id": "peshitta:luke.19.33",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 33,
      "referenceLabel": "Luke 19:33",
      "text": "ܘܟܕ ܫܪܝܢ ܠܗ ܠܥܝܠܐ ܐܡܪܝܢ ܠܗܘܢ ܡܪܘܗܝ ܡܢܐ ܫܪܝܢ ܐܢܬܘܢ ܥܝܠܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.34",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 34,
      "referenceLabel": "Luke 19:34",
      "text": "ܘܐܡܪܘ ܠܗܘܢ ܕܠܡܪܢ ܡܬܒܥܐ ܀",
