  "verses": [
    {
      "id": "peshitta:luke.19.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Luke 19:1",
      "text": "ܘܟܕ ܥܠ ܝܫܘܥ ܘܥܒܪ ܒܐܝܪܝܚܘ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.19.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Luke 19:2",
      "text": "ܓܒܪܐ ܚܕ ܕܫܡܗ ܙܟܝ ܥܬܝܪܐ ܗܘܐ ܘܪܒ ܡܟܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Luke 19:3",
      "text": "ܘܨܒܐ ܗܘܐ ܕܢܚܙܐ ܠܝܫܘܥ ܕܡܢܘ ܘܠܐ ܡܫܟܚ ܗܘܐ ܡܢ ܟܢܫܐ ܡܛܠ ܕܒܩܘܡܬܗ ܙܥܘܪ ܗܘܐ ܙܟܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Luke 19:4",
      "text": "ܘܪܗܛ ܩܕܡܗ ܠܝܫܘܥ ܘܤܠܩ ܠܗ ܠܬܬܐ ܦܟܝܗܬܐ ܕܢܚܙܝܘܗܝ ܡܛܠ ܕܗܟܘܬ ܥܬܝܕ ܗܘܐ ܕܢܥܒܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Luke 19:5",
      "text": "ܘܟܕ ܐܬܐ ܠܗܝ ܕܘܟܬܐ ܝܫܘܥ ܚܙܝܗܝ ܘܐܡܪ ܠܗ ܐܤܬܪܗܒ ܚܘܬ ܙܟܝ ܝܘܡܢܐ ܓܝܪ ܘܠܐ ܕܒܒܝܬܟ ܐܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Luke 19:6",
      "text": "ܘܐܤܬܪܗܒ ܢܚܬ ܘܩܒܠܗ ܟܕ ܚܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Luke 19:7",
      "text": "ܟܕ ܚܙܘ ܕܝܢ ܟܠܗܘܢ ܪܛܢܝܢ ܗܘܘ ܘܐܡܪܝܢ ܕܠܘܬ ܓܒܪܐ ܚܛܝܐ ܥܠ ܫܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Luke 19:8",
      "text": "ܩܡ ܕܝܢ ܙܟܝ ܘܐܡܪ ܠܝܫܘܥ ܗܐ ܡܪܝ ܦܠܓܘܬ ܢܟܤܝ ܝܗܒ ܐܢܐ ܠܡܤܟܢܐ ܘܠܟܠܢܫ ܡܕܡ ܕܓܠܙܬ ܚܕ ܒܐܪܒܥܐ ܦܪܥ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Luke 19:9",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܝܘܡܢܐ ܗܘܘ ܚܝܐ ܠܒܝܬܐ ܗܢܐ ܡܛܠ ܕܐܦ ܗܢܐ ܒܪܗ ܗܘ ܕܐܒܪܗܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Luke 19:10",
      "text": "ܐܬܐ ܓܝܪ ܒܪܗ ܕܐܢܫܐ ܕܢܒܥܐ ܘܢܚܐ ܗܘ ܡܕܡ ܕܐܒܝܕ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Luke 19:11",
      "text": "ܘܟܕ ܫܡܥܝܢ ܗܘܘ ܗܠܝܢ ܐܘܤܦ ܠܡܐܡܪ ܡܬܠܐ ܡܛܠ ܕܩܪܝܒ ܗܘܐ ܠܐܘܪܫܠܡ ܘܤܒܪܝܢ ܗܘܘ ܕܒܗܝ ܫܥܬܐ ܥܬܝܕܐ ܕܬܬܓܠܐ ܡܠܟܘܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Luke 19:12",
      "text": "ܘܐܡܪ ܓܒܪܐ ܚܕ ܒܪ ܛܘܗܡܐ ܪܒܐ ܐܙܠ ܠܐܬܪܐ ܪܚܝܩܐ ܕܢܤܒ ܠܗ ܡܠܟܘܬܐ ܘܢܗܦܘܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.13",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Luke 19:13",
      "text": "ܘܩܪܐ ܥܤܪܐ ܥܒܕܘܗܝ ܘܝܗܒ ܠܗܘܢ ܥܤܪܐ ܡܢܝܢ ܘܐܡܪ ܠܗܘܢ ܐܬܬܓܪܘ ܥܕ ܐܬܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Luke 19:14",
      "text": "ܒܢܝ ܡܕܝܢܬܗ ܕܝܢ ܤܢܝܢ ܗܘܘ ܠܗ ܘܫܕܪܘ ܐܝܙܓܕܐ ܒܬܪܗ ܘܐܡܪܝܢ ܠܐ ܨܒܝܢ ܚܢܢ ܕܢܡܠܟ ܥܠܝܢ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Luke 19:15",
      "text": "ܘܟܕ ܢܤܒ ܡܠܟܘܬܐ ܘܗܦܟ ܐܡܪ ܕܢܩܪܘܢ ܠܗ ܗܢܘܢ ܥܒܕܘܗܝ ܕܝܗܒ ܠܗܘܢ ܟܤܦܐ ܕܢܕܥ ܡܢܐ ܟܠ ܚܕ ܚܕ ܡܢܗܘܢ ܐܬܬܓܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.16",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "Luke 19:16",
      "text": "ܘܐܬܐ ܩܕܡܝܐ ܘܐܡܪ ܡܪܝ ܡܢܝܟ ܥܤܪܐ ܡܢܝܢ ܐܘܬܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.17",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "Luke 19:17",
      "text": "ܐܡܪ ܠܗ ܐܝܘ ܥܒܕܐ ܛܒܐ ܕܒܩܠܝܠ ܐܫܬܟܚܬ ܡܗܝܡܢ ܬܗܘܐ ܫܠܝܛ ܥܠ ܥܤܪܐ ܟܪܟܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.18",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "Luke 19:18",
      "text": "ܘܐܬܐ ܕܬܪܝܢ ܘܐܡܪ ܡܪܝ ܡܢܝܟ ܚܡܫܐ ܡܢܝܢ ܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.19",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "Luke 19:19",
      "text": "ܐܡܪ ܐܦ ܠܗܢܐ ܐܦ ܐܢܬ ܬܗܘܐ ܫܠܝܛ ܥܠ ܚܡܫܐ ܟܪܟܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.20",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "Luke 19:20",
      "text": "ܘܐܬܐ ܐܚܪܢܐ ܘܐܡܪ ܡܪܝ ܗܐ ܡܢܝܟ ܗܘ ܕܐܝܬ ܗܘܐ ܠܘܬܝ ܟܕ ܤܝܡ ܒܤܕܘܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.21",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "Luke 19:21",
      "text": "ܕܚܠܬ ܓܝܪ ܡܢܟ ܕܓܒܪܐ ܐܢܬ ܩܫܝܐ ܘܫܩܠ ܐܢܬ ܡܕܡ ܕܠܐ ܤܡܬ ܘܚܨܕ ܐܢܬ ܡܕܡ ܕܠܐ ܙܪܥܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.22",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 22,
      "referenceLabel": "Luke 19:22",
      "text": "ܐܡܪ ܠܗ ܡܢ ܦܘܡܟ ܐܕܘܢܟ ܥܒܕܐ ܒܝܫܐ ܝܕܥ ܗܘܝܬ ܠܝ ܕܓܒܪܐ ܐܢܐ ܩܫܝܐ ܘܫܩܠ ܐܢܐ ܡܕܡ ܕܠܐ ܤܡܬ ܘܚܨܕ ܐܢܐ ܡܕܡ ܕܠܐ ܙܪܥܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.23",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 23,
      "referenceLabel": "Luke 19:23",
      "text": "ܠܡܢܐ ܠܐ ܝܗܒܬ ܟܤܦܝ ܥܠ ܦܬܘܪܐ ܘܐܢܐ ܐܬܐ ܗܘܝܬ ܬܒܥ ܠܗ ܥܡ ܪܒܝܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.24",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 24,
      "referenceLabel": "Luke 19:24",
      "text": "ܘܠܗܢܘܢ ܕܩܝܡܝܢ ܩܕܡܘܗܝ ܐܡܪ ܤܒܘ ܡܢܗ ܡܢܝܐ ܘܗܒܘ ܠܗܘ ܕܐܝܬ ܠܘܬܗ ܥܤܪܐ ܡܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.25",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 25,
      "referenceLabel": "Luke 19:25",
      "text": "ܐܡܪܝܢ ܠܗ ܡܪܢ ܐܝܬ ܠܘܬܗ ܥܤܪܐ ܡܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.26",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 26,
      "referenceLabel": "Luke 19:26",
      "text": "ܐܡܪ ܠܗܘܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܠܟܠ ܡܢ ܕܐܝܬ ܠܗ ܢܬܝܗܒ ܠܗ ܘܡܢ ܗܘ ܕܠܝܬ ܠܗ ܐܦ ܗܘ ܕܐܝܬ ܠܗ ܢܬܢܤܒ ܡܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.27",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 27,
      "referenceLabel": "Luke 19:27",
      "text": "ܒܪܡ ܠܗܢܘܢ ܒܥܠܕܒܒܝ ܐܝܠܝܢ ܕܠܐ ܨܒܘ ܕܐܡܠܟ ܥܠܝܗܘܢ ܐܝܬܘ ܐܢܘܢ ܘܩܛܠܘ ܐܢܘܢ ܩܕܡܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.28",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 28,
      "referenceLabel": "Luke 19:28",
      "text": "ܘܟܕ ܐܡܪ ܗܠܝܢ ܝܫܘܥ ܢܦܩ ܠܩܕܡܘܗܝ ܕܢܐܙܠ ܠܐܘܪܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.29",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 29,
      "referenceLabel": "Luke 19:29",
      "text": "ܘܟܕ ܡܛܝ ܠܒܝܬ ܦܓܐ ܘܒܝܬ ܥܢܝܐ ܥܠ ܓܢܒ ܛܘܪܐ ܕܡܬܩܪܐ ܕܒܝܬ ܙܝܬܐ ܫܕܪ ܬܪܝܢ ܡܢ ܬܠܡܝܕܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.30",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 30,
      "referenceLabel": "Luke 19:30",
      "text": "ܘܐܡܪ ܠܗܘܢ ܙܠܘ ܠܩܪܝܬܐ ܗܝ ܕܠܩܘܒܠܢ ܘܟܕ ܥܐܠܝܢ ܐܢܬܘܢ ܠܗ ܗܐ ܡܫܟܚܝܢ ܐܢܬܘܢ ܥܝܠܐ ܕܐܤܝܪ ܕܐܢܫ ܡܡܬܘܡ ܠܐ ܪܟܒ ܥܠܘܗܝ ܫܪܘ ܐܝܬܐܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.31",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 31,
      "referenceLabel": "Luke 19:31",
      "text": "ܘܐܢ ܐܢܫ ܡܫܐܠ ܠܟܘܢ ܠܡܢܐ ܫܪܝܢ ܐܢܬܘܢ ܠܗ ܗܟܢܐ ܐܡܪܘ ܠܗ ܠܡܪܢ ܡܬܒܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.19.32",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 32,
      "referenceLabel": "Luke 19:32",
      "text": "ܘܐܙܠܘ ܗܢܘܢ ܕܐܫܬܕܪܘ ܘܐܫܟܚܘ ܐܝܟܢܐ ܕܐܡܪ ܠܗܘܢ ܀",
      "paragraphStart": false
