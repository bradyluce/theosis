{
  "chapter": {
    "id": "peshitta:luke.14",
    "translationId": "peshitta",
    "bookSlug": "luke",
    "chapterNumber": 14,
    "referenceLabel": "Luke 14",
    "summary": "Source text for Luke 14 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:luke.14.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Luke 14:1",
      "text": "ܘܗܘܐ ܕܟܕ ܥܠ ܠܒܝܬܐ ܕܚܕ ܡܢ ܪܫܐ ܕܦܪܝܫܐ ܕܢܐܟܘܠ ܠܚܡܐ ܒܝܘܡܐ ܕܫܒܬܐ ܘܗܢܘܢ ܢܛܪܝܢ ܗܘܘ ܠܗ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.14.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Luke 14:2",
      "text": "ܘܗܐ ܓܒܪܐ ܚܕ ܕܟܢܝܫ ܗܘܐ ܡܝܐ ܐܝܬ ܗܘܐ ܩܕܡܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Luke 14:3",
      "text": "ܘܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܤܦܪܐ ܘܠܦܪܝܫܐ ܕܐܢ ܫܠܝܛ ܒܫܒܬܐ ܠܡܐܤܝܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Luke 14:4",
      "text": "ܗܢܘܢ ܕܝܢ ܫܬܩܘ ܘܐܚܕܗ ܗܘ ܘܐܤܝܗ ܘܫܪܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Luke 14:5",
      "text": "ܘܐܡܪ ܠܗܘܢ ܡܢܘ ܡܢܟܘܢ ܕܢܦܠ ܒܪܗ ܐܘ ܬܘܪܗ ܒܒܪܐ ܒܝܘܡܐ ܕܫܒܬܐ ܘܠܐ ܡܚܕܐ ܕܠܐ ܡܤܩ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Luke 14:6",
      "text": "ܘܠܐ ܐܫܟܚܘ ܠܡܬܠ ܠܗ ܦܬܓܡܐ ܥܠ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Luke 14:7",
      "text": "ܘܐܡܪ ܗܘܐ ܡܬܠܐ ܠܘܬ ܗܢܘܢ ܕܡܙܡܢܝܢ ܬܡܢ ܥܠ ܕܚܙܐ ܗܘܐ ܠܗܘܢ ܕܡܓܒܝܢ ܕܘܟܝܬܐ ܕܪܝܫ ܤܡܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Luke 14:8",
      "text": "ܐܡܬܝ ܕܡܙܕܡܢ ܐܢܬ ܡܢ ܐܢܫ ܠܒܝܬ ܡܫܬܘܬܐ ܠܐ ܬܐܙܠ ܬܤܬܡܟ ܠܟ ܒܪܝܫ ܤܡܟܐ ܕܠܡܐ ܢܗܘܐ ܡܙܡܢ ܬܡܢ ܐܢܫ ܕܡܝܩܪ ܡܢܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Luke 14:9",
      "text": "ܘܢܐܬܐ ܗܘ ܡܢ ܕܠܟ ܘܠܗ ܩܪܐ ܘܢܐܡܪ ܠܟ ܕܗܒ ܕܘܟܬܐ ܠܗܢܐ ܘܬܒܗܬ ܟܕ ܩܐܡ ܐܢܬ ܘܐܚܕ ܐܢܬ ܕܘܟܬܐ ܐܚܪܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Luke 14:10",
      "text": "ܐܠܐ ܡܐ ܕܐܙܕܡܢܬ ܙܠ ܐܤܬܡܟ ܠܟ ܒܚܪܬܐ ܕܡܐ ܕܐܬܐ ܗܘ ܕܩܪܟ ܢܐܡܪ ܠܟ ܪܚܡܝ ܐܬܥܠܐ ܠܥܠ ܘܐܤܬܡܟ ܘܬܗܘܐ ܠܟ ܬܫܒܘܚܬܐ ܩܕܡ ܟܠܗܘܢ ܕܤܡܝܟܝܢ ܥܡܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Luke 14:11",
      "text": "ܡܛܠ ܕܟܠ ܕܢܪܝܡ ܢܦܫܗ ܢܬܡܟܟ ܘܟܠ ܕܢܡܟ ܢܦܫܗ ܢܬܬܪܝܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Luke 14:12",
      "text": "ܐܡܪ ܕܝܢ ܐܦ ܠܗܘ ܕܩܪܝܗܝ ܡܐ ܕܥܒܕ ܐܢܬ ܫܪܘܬܐ ܐܘ ܐܚܫܡܝܬܐ ܠܐ ܬܗܘܐ ܩܪܐ ܪܚܡܝܟ ܐܦܠܐ ܐܚܝܟ ܐܘ ܐܚܝܢܝܟ ܘܠܐ ܫܒܒܝܟ ܥܬܝܪܐ ܕܠܡܐ ܘܐܦ ܗܢܘܢ ܢܩܪܘܢܟ ܘܢܗܘܐ ܠܟ ܦܘܪܥܢܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.13",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Luke 14:13",
      "text": "ܐܠܐ ܡܐ ܕܥܒܕ ܐܢܬ ܩܘܒܠܐ ܩܪܝ ܠܡܤܟܢܐ ܤܓܝܦܐ ܚܓܝܤܐ ܤܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Luke 14:14",
      "text": "ܘܛܘܒܝܟ ܕܠܝܬ ܠܗܘܢ ܕܢܦܪܥܘܢܟ ܢܗܘܐ ܓܝܪ ܦܘܪܥܢܟ ܒܩܝܡܐ ܕܙܕܝܩܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Luke 14:15",
      "text": "ܟܕ ܫܡܥ ܕܝܢ ܚܕ ܡܢ ܗܢܘܢ ܕܤܡܝܟܝܢ ܗܠܝܢ ܐܡܪ ܠܗ ܛܘܒܘܗܝ ܠܡܢ ܕܢܐܟܘܠ ܠܚܡܐ ܒܡܠܟܘܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.16",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Luke 14:16",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܓܒܪܐ ܚܕ ܥܒܕ ܐܚܫܡܝܬܐ ܪܒܬܐ ܘܩܪܐ ܠܤܓܝܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.17",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Luke 14:17",
      "text": "ܘܫܕܪ ܥܒܕܗ ܒܥܕܢܐ ܕܐܚܫܡܝܬܐ ܕܢܐܡܪ ܠܐܝܠܝܢ ܕܩܪܝܢ ܗܐ ܟܠܡܕܡ ܡܛܝܒ ܠܟܘܢ ܬܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.18",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Luke 14:18",
      "text": "ܘܫܪܝܘ ܡܢ ܚܕ ܟܠܗܘܢ ܠܡܫܬܐܠܘ ܐܡܪ ܠܗ ܩܕܡܝܐ ܩܪܝܬܐ ܙܒܢܬ ܘܐܠܝܨ ܐܢܐ ܕܐܦܘܩ ܐܚܙܝܗ ܒܥܐ ܐܢܐ ܡܢܟ ܫܒܘܩܝܢܝ ܕܡܫܬܐܠ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.19",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Luke 14:19",
      "text": "ܐܚܪܢܐ ܐܡܪ ܚܡܫܐ ܙܘܓܝܢ ܬܘܪܐ ܙܒܢܬ ܘܐܙܠ ܐܢܐ ܕܐܒܩܐ ܐܢܘܢ ܒܥܐ ܐܢܐ ܡܢܟ ܫܒܘܩܝܢܝ ܕܡܫܬܐܠ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.20",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Luke 14:20",
      "text": "ܘܐܚܪܢܐ ܐܡܪ ܐܢܬܬܐ ܢܤܒܬ ܘܡܛܠ ܗܕܐ ܠܐ ܡܫܟܚ ܐܢܐ ܕܐܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.21",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Luke 14:21",
      "text": "ܘܐܬܐ ܗܘ ܥܒܕܐ ܘܐܡܪ ܠܡܪܗ ܗܠܝܢ ܗܝܕܝܢ ܪܓܙ ܡܪܐ ܒܝܬܐ ܘܐܡܪ ܠܥܒܕܗ ܦܘܩ ܒܥܓܠ ܠܫܘܩܐ ܘܠܒܪܝܬܐ ܕܡܕܝܢܬܐ ܘܐܥܠ ܠܟܐ ܠܡܤܟܢܐ ܘܠܡܟܐܒܐ ܘܠܡܚܓܪܐ ܘܠܥܘܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.22",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Luke 14:22",
      "text": "ܘܐܡܪ ܥܒܕܐ ܡܪܝ ܗܘܐ ܐܝܟ ܕܦܩܕܬ ܘܬܘܒ ܐܝܬ ܐܬܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.23",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Luke 14:23",
      "text": "ܘܐܡܪ ܡܪܐ ܠܥܒܕܗ ܦܘܩ ܠܐܘܪܚܬܐ ܘܠܒܝܬ ܤܝܓܐ ܘܐܠܘܨ ܕܢܥܠܘܢ ܕܢܬܡܠܐ ܒܝܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.24",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Luke 14:24",
      "text": "ܐܡܪ ܐܢܐ ܠܟܘܢ ܓܝܪ ܕܚܕ ܡܢ ܗܢܘܢ ܐܢܫܐ ܕܩܪܝܢ ܗܘܘ ܠܐ ܢܛܥܡܘܢ ܡܢ ܐܚܫܡܝܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.25",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Luke 14:25",
      "text": "ܘܟܕ ܐܙܠܝܢ ܗܘܘ ܥܡܗ ܟܢܫܐ ܤܓܝܐܐ ܐܬܦܢܝ ܘܐܡܪ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.26",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Luke 14:26",
      "text": "ܡܢ ܕܐܬܐ ܠܘܬܝ ܘܠܐ ܤܢܐ ܠܐܒܘܗܝ ܘܠܐܡܗ ܘܠܐܚܘܗܝ ܘܠܐܚܘܬܗ ܘܠܐܢܬܬܗ ܘܠܒܢܘܗܝ ܘܐܦ ܠܢܦܫܗ ܬܠܡܝܕܐ ܠܐ ܡܫܟܚ ܕܢܗܘܐ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.27",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Luke 14:27",
      "text": "ܘܡܢ ܕܠܐ ܫܩܠ ܨܠܝܒܗ ܘܐܬܐ ܒܬܪܝ ܬܠܡܝܕܐ ܠܐ ܡܫܟܚ ܕܢܗܘܐ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.28",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "Luke 14:28",
      "text": "ܡܢܘ ܓܝܪ ܡܢܟܘܢ ܕܨܒܐ ܕܢܒܢܐ ܡܓܕܠܐ ܘܠܐ ܠܘܩܕܡ ܝܬܒ ܚܫܒ ܢܦܩܬܗ ܐܢ ܐܝܬ ܠܗ ܠܡܫܠܡܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.29",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "Luke 14:29",
      "text": "ܕܠܐ ܟܕ ܢܤܝܡ ܫܬܐܤܬܐ ܘܠܐ ܢܫܟܚ ܠܡܫܠܡܘ ܟܠ ܕܚܙܝܢ ܢܗܘܘܢ ܡܒܙܚܝܢ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.30",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "Luke 14:30",
      "text": "ܘܐܡܪܝܢ ܕܗܢܐ ܓܒܪܐ ܫܪܝ ܠܡܒܢܐ ܘܠܐ ܐܫܟܚ ܠܡܫܠܡܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.31",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "Luke 14:31",
      "text": "ܐܘ ܡܢܘ ܡܠܟܐ ܕܐܙܠ ܠܩܪܒܐ ܠܡܬܟܬܫܘ ܥܡ ܡܠܟܐ ܚܒܪܗ ܘܠܐ ܠܘܩܕܡ ܡܬܪܥܐ ܕܐܢ ܡܫܟܚ ܒܥܤܪܐ ܐܠܦܝܢ ܠܡܐܪܥ ܠܗܘ ܕܐܬܐ ܥܠܘܗܝ ܒܥܤܪܝܢ ܐܠܦܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.32",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "Luke 14:32",
      "text": "ܘܐܢ ܕܝܢ ܠܐ ܥܕ ܗܘ ܪܚܝܩ ܡܢܗ ܡܫܕܪ ܐܝܙܓܕܐ ܘܒܥܐ ܥܠ ܫܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.33",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "Luke 14:33",
      "text": "ܗܟܢܐ ܟܠܢܫ ܡܢܟܘܢ ܕܠܐ ܫܒܩ ܟܠܗ ܩܢܝܢܗ ܠܐ ܡܫܟܚ ܕܢܗܘܐ ܠܝ ܬܠܡܝܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.34",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "Luke 14:34",
      "text": "ܫܦܝܪܐ ܗܝ ܡܠܚܐ ܐܢ ܕܝܢ ܐܦ ܡܠܚܐ ܬܦܟܗ ܒܡܢܐ ܬܬܡܠܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.14.35",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "Luke 14:35",
      "text": "ܠܐ ܠܐܪܥܐ ܘܠܐ ܠܙܒܠܐ ܐܙܠܐ ܠܒܪ ܫܕܝܢ ܠܗ ܡܢ ܕܐܝܬ ܠܗ ܐܕܢܐ ܕܢܫܡܥ ܢܫܡܥ ܀",
      "paragraphStart": false
    }
  ]
}
