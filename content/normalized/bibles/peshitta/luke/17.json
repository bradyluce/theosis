    {
      "id": "peshitta:luke.17.22",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 22,
      "referenceLabel": "Luke 17:22",
      "text": "ܘܐܡܪ ܠܬܠܡܝܕܘܗܝ ܢܐܬܘܢ ܝܘܡܬܐ ܕܬܬܪܓܪܓܘܢ ܠܡܚܙܐ ܚܕ ܡܢ ܝܘܡܬܐ ܕܒܪܗ ܕܐܢܫܐ ܘܠܐ ܬܚܙܘܢ ܀",
