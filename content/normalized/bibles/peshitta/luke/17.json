    {
      "id": "peshitta:luke.17.18",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 18,
      "referenceLabel": "Luke 17:18",
      "text": "ܠܡܐ ܦܪܫܘ ܕܢܐܬܘܢ ܢܬܠܘܢ ܬܫܒܘܚܬܐ ܠܐܠܗܐ ܐܠܐ ܗܢܐ ܕܡܢ ܥܡܐ ܗܘ ܢܘܟܪܝܐ ܀",
      "paragraphStart": false
