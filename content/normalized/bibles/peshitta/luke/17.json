    {
      "id": "peshitta:luke.17.30",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 30,
      "referenceLabel": "Luke 17:30",
      "text": "ܗܟܢܐ ܢܗܘܐ ܒܝܘܡܐ ܕܡܬܓܠܐ ܒܪܗ ܕܐܢܫܐ ܀",
