  "verses": [
    {
      "id": "peshitta:luke.17.1",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Luke 17:1",
      "text": "ܘܐܡܪ ܗܘܐ ܝܫܘܥ ܠܬܠܡܝܕܘܗܝ ܠܐ ܡܫܟܚܐ ܕܠܐ ܢܐܬܘܢ ܡܟܫܘܠܐ ܘܝ ܕܝܢ ܠܗܘ ܕܒܐܝܕܗ ܢܐܬܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.17.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Luke 17:2",
      "text": "ܦܩܚ ܗܘܐ ܠܗ ܐܠܘ ܪܚܝܐ ܕܚܡܪܐ ܬܠܝܐ ܒܨܘܪܗ ܘܫܕܐ ܒܝܡܐ ܐܘ ܕܢܟܫܠ ܠܚܕ ܡܢ ܗܠܝܢ ܙܥܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.17.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Luke 17:3",
      "text": "ܐܙܕܗܪܘ ܒܢܦܫܟܘܢ ܐܢ ܢܚܛܐ ܐܚܘܟ ܟܐܝ ܒܗ ܘܐܢ ܬܐܒ ܫܒܘܩ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.17.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Luke 17:4",
      "text": "ܘܐܢ ܫܒܥ ܙܒܢܝܢ ܒܝܘܡܐ ܢܤܟܠ ܒܟ ܘܫܒܥ ܙܒܢܝܢ ܒܝܘܡܐ ܢܬܦܢܐ ܠܘܬܟ ܘܢܐܡܪ ܕܬܐܒ ܐܢܐ ܫܒܘܩ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.17.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Luke 17:5",
      "text": "ܘܐܡܪܘ ܫܠܝܚܐ ܠܡܪܢ ܐܘܤܦ ܠܢ ܗܝܡܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.17.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Luke 17:6",
      "text": "ܐܡܪ ܠܗܘܢ ܐܢ ܐܝܬ ܗܘܬ ܠܟܘܢ ܗܝܡܢܘܬܐ ܐܝܟ ܦܪܕܬܐ ܕܚܪܕܠܐ ܐܡܪܝܢ ܗܘܝܬܘܢ ܠܬܘܬܐ ܗܢܐ ܕܐܬܥܩܪ ܘܐܬܢܨܒ ܒܝܡܐ ܘܡܫܬܡܥ ܗܘܐ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.17.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Luke 17:7",
      "text": "ܡܢܘ ܕܝܢ ܡܢܟܘܢ ܕܐܝܬ ܠܗ ܥܒܕܐ ܕܕܒܪ ܦܕܢܐ ܐܘ ܕܪܥܐ ܥܢܐ ܘܐܢ ܢܐܬܐ ܡܢ ܚܩܠܐ ܐܡܪ ܠܗ ܡܚܕܐ ܥܒܪ ܐܤܬܡܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.17.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Luke 17:8",
      "text": "ܐܠܐ ܐܡܪ ܠܗ ܛܝܒ ܠܝ ܡܕܡ ܕܐܚܫܡ ܘܐܤܘܪ ܚܨܝܟ ܫܡܫܝܢܝ ܥܕܡܐ ܕܐܠܥܤ ܘܐܫܬܐ ܘܒܬܪܟܢ ܐܦ ܐܢܬ ܬܠܥܤ ܘܬܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.17.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Luke 17:9",
      "text": "ܠܡܐ ܛܝܒܘܬܗ ܡܩܒܠ ܕܗܘ ܥܒܕܐ ܕܥܒܕ ܡܕܡ ܕܐܬܦܩܕ ܠܗ ܠܐ ܤܒܪ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.17.10",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Luke 17:10",
      "text": "ܗܟܢܐ ܐܦ ܐܢܬܘܢ ܡܐ ܕܥܒܕܬܘܢ ܟܠܗܝܢ ܐܝܠܝܢ ܕܦܩܝܕܢ ܠܟܘܢ ܐܡܪܘ ܕܥܒܕܐ ܚܢܢ ܒܛܝܠܐ ܕܡܕܡ ܕܚܝܒܝܢ ܗܘܝܢ ܠܡܥܒܕ ܥܒܕܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.17.11",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Luke 17:11",
      "text": "ܘܗܘܐ ܕܟܕ ܐܙܠ ܝܫܘܥ ܠܐܘܪܫܠܡ ܥܒܪ ܗܘܐ ܒܝܬ ܫܡܪܝܐ ܠܓܠܝܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.17.12",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Luke 17:12",
      "text": "ܘܟܕ ܩܪܝܒ ܠܡܥܠ ܠܩܪܝܬܐ ܚܕܐ ܐܪܥܘܗܝ ܥܤܪܐ ܐܢܫܝܢ ܓܪܒܐ ܘܩܡܘ ܡܢ ܪܘܚܩܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.17.13",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Luke 17:13",
      "text": "ܘܐܪܝܡܘ ܩܠܗܘܢ ܘܐܡܪܝܢ ܪܒܢ ܝܫܘܥ ܐܬܪܚܡ ܥܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.17.14",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Luke 17:14",
      "text": "ܘܟܕ ܚܙܐ ܐܢܘܢ ܐܡܪ ܠܗܘܢ ܙܠܘ ܚܘܘ ܢܦܫܟܘܢ ܠܟܗܢܐ ܘܟܕ ܐܙܠܝܢ ܐܬܕܟܝܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.17.15",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Luke 17:15",
      "text": "ܚܕ ܕܝܢ ܡܢܗܘܢ ܟܕ ܚܙܐ ܕܐܬܕܟܝ ܗܦܟ ܠܗ ܘܒܩܠܐ ܪܡܐ ܡܫܒܚ ܗܘܐ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.17.16",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Luke 17:16",
      "text": "ܘܢܦܠ ܥܠ ܐܦܘܗܝ ܩܕܡ ܪܓܠܘܗܝ ܕܝܫܘܥ ܟܕ ܡܘܕܐ ܠܗ ܘܗܘ ܗܢܐ ܫܡܪܝܐ ܗܘܐ ܀",
      "paragraphStart": false
