    {
      "id": "peshitta:luke.17.21",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 21,
      "referenceLabel": "Luke 17:21",
      "text": "ܘܠܐ ܐܡܪܝܢ ܗܐ ܗܪܟܐ ܗܝ ܘܗܐ ܗܪ ܬܡܢ ܗܝ ܗܐ ܓܝܪ ܡܠܟܘܬܗ ܕܐܠܗܐ ܠܓܘ ܡܢܟܘܢ ܗܝ ܀",
      "paragraphStart": false
