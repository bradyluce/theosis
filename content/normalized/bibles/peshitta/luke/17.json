    {
      "id": "peshitta:luke.17.17",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 17,
      "referenceLabel": "Luke 17:17",
      "text": "ܥܢܐ ܕܝܢ ܝܫܘܥ ܘܐܡܪ ܠܐ ܗܘܐ ܥܤܪܐ ܗܘܝܢ ܗܠܝܢ ܕܐܬܕܟܝܘ ܐܝܟܐ ܐܢܘܢ ܬܫܥܐ ܀",
