    {
      "id": "peshitta:luke.17.19",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 19,
      "referenceLabel": "Luke 17:19",
      "text": "ܘܐܡܪ ܠܗ ܩܘܡ ܙܠ ܗܝܡܢܘܬܟ ܐܚܝܬܟ ܀",
