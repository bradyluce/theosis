    {
      "id": "peshitta:luke.17.20",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 20,
      "referenceLabel": "Luke 17:20",
      "text": "ܘܟܕ ܫܐܠܘܗܝ ܠܝܫܘܥ ܡܢ ܦܪܝܫܐ ܐܡܬܝ ܐܬܝܐ ܡܠܟܘܬܗ ܕܐܠܗܐ ܥܢܐ ܘܐܡܪ ܠܗܘܢ ܠܐ ܐܬܝܐ ܡܠܟܘܬܗ ܕܐܠܗܐ ܒܢܛܘܪܬܐ ܀",
