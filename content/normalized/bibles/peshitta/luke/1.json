      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Luke 1:10",
      "text": "ܘܟܠܗ ܟܢܫܐ ܕܥܡܐ ܡܨܠܐ ܗܘܐ ܠܒܪ ܒܥܕܢܐ ܕܒܤܡܐ ܀",
      "paragraphStart": false
