      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Luke 1:1",
      "text": "ܡܛܠ ܕܤܓܝܐܐ ܨܒܘ ܕܢܟܬܒܘܢ ܬܫܥܝܬܐ ܕܤܘܥܪܢܐ ܐܝܠܝܢ ܕܚܢܢ ܡܦܤܝܢ ܚܢܢ ܒܗܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:luke.1.2",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Luke 1:2",
      "text": "ܐܝܟ ܡܕܡ ܕܐܫܠܡܘ ܠܢ ܗܢܘܢ ܕܡܢ ܩܕܝܡ ܗܘܘ ܚܙܝܐ ܘܡܫܡܫܢܐ ܕܝܠܗ ܕܡܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.1.3",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Luke 1:3",
      "text": "ܐܬܚܙܝ ܐܦ ܠܝ ܡܛܠ ܕܩܪܝܒ ܗܘܝܬ ܝܨܝܦܐܝܬ ܠܟܠܗܘܢ ܕܟܠ ܡܕܡ ܒܛܟܤܗ ܐܟܬܘܒ ܠܟ ܢܨܝܚܐ ܬܐܘܦܝܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.1.4",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Luke 1:4",
      "text": "ܕܬܕܥ ܫܪܪܐ ܕܡܠܐ ܕܐܬܬܠܡܕܬ ܠܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.1.5",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Luke 1:5",
      "text": "ܗܘܐ ܒܝܘܡܬܗ ܕܗܪܘܕܤ ܡܠܟܐ ܕܝܗܘܕܐ ܟܗܢܐ ܚܕ ܕܫܡܗ ܗܘܐ ܙܟܪܝܐ ܡܢ ܬܫܡܫܬܐ ܕܒܝܬ ܐܒܝܐ ܘܐܢܬܬܗ ܡܢ ܒܢܬܗ ܕܐܗܪܘܢ ܫܡܗ ܗܘܐ ܐܠܝܫܒܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.1.6",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Luke 1:6",
      "text": "ܬܪܝܗܘܢ ܕܝܢ ܙܕܝܩܝܢ ܗܘܘ ܩܕܡ ܐܠܗܐ ܘܡܗܠܟܝܢ ܒܟܠܗܘܢ ܦܘܩܕܢܘܗܝ ܘܒܟܐܢܘܬܗ ܕܡܪܝܐ ܕܠܐ ܥܕܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.1.7",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Luke 1:7",
      "text": "ܒܪܐ ܕܝܢ ܠܝܬ ܗܘܐ ܠܗܘܢ ܡܛܠ ܕܐܠܝܫܒܥ ܥܩܪܬܐ ܗܘܬ ܘܬܪܝܗܘܢ ܤܓܝܐܝ ܒܝܘܡܬܗܘܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.1.8",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Luke 1:8",
      "text": "ܗܘܐ ܗܘܐ ܕܝܢ ܟܕ ܡܟܗܢ ܗܘܐ ܒܛܟܤܐ ܕܬܫܡܫܬܗ ܩܕܡ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:luke.1.9",
      "translationId": "peshitta",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Luke 1:9",
      "text": "ܒܥܝܕܐ ܕܟܗܢܘܬܐ ܡܛܝܗܝ ܕܢܤܝܡ ܒܤܡܐ ܘܥܠ ܠܗܝܟܠܗ ܕܡܪܝܐ ܀",
