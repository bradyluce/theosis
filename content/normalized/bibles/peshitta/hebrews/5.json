{
  "chapter": {
    "id": "peshitta:hebrews.5",
    "translationId": "peshitta",
    "bookSlug": "hebrews",
    "chapterNumber": 5,
    "referenceLabel": "Hebrews 5",
    "summary": "Source text for Hebrews 5 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:hebrews.5.1",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 5:1",
      "text": "ܟܠ ܪܒ ܟܘܡܪܐ ܓܝܪ ܕܡܢ ܒܢܝܢܫܐ ܗܘܐ ܚܠܦ ܒܢܝܢܫܐ ܩܐܡ ܥܠ ܐܝܠܝܢ ܕܕܐܠܗܐ ܐܢܝܢ ܕܢܩܪܒ ܩܘܪܒܢܐ ܘܕܒܚܐ ܚܠܦ ܚܛܗܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:hebrews.5.2",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 5:2",
      "text": "ܐܝܢܐ ܕܡܫܟܚ ܕܢܡܟ ܢܦܫܗ ܘܢܚܫ ܥܡ ܐܝܠܝܢ ܕܠܐ ܝܕܥܝܢ ܘܛܥܝܢ ܡܛܠ ܕܐܦ ܗܘ ܟܪܝܗܘܬܐ ܠܒܝܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.5.3",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 5:3",
      "text": "ܘܡܛܠܬܗ ܚܝܒ ܗܘ ܕܐܝܟܢܐ ܕܚܠܦ ܥܡܐ ܗܟܢܐ ܐܦ ܚܠܦ ܢܦܫܗ ܢܩܪܒ ܥܠ ܚܛܗܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.5.4",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 5:4",
      "text": "ܘܠܐ ܗܘܐ ܠܢܦܫܗ ܐܢܫ ܢܤܒ ܐܝܩܪܐ ܐܠܐ ܐܝܢܐ ܕܡܬܩܪܐ ܡܢ ܐܠܗܐ ܐܝܟܢܐ ܕܐܗܪܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.5.5",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 5:5",
      "text": "ܗܟܢܐ ܐܦ ܡܫܝܚܐ ܠܐ ܗܘܐ ܢܦܫܗ ܫܒܚ ܕܢܗܘܐ ܪܒ ܟܘܡܪܐ ܐܠܐ ܗܘ ܕܐܡܪ ܠܗ ܕܒܪܝ ܐܢܬ ܐܢܐ ܝܘܡܢܐ ܝܠܕܬܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.5.6",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 5:6",
      "text": "ܐܝܟ ܕܐܦ ܒܕܘܟܬܐ ܐܚܪܬܐ ܐܡܪ ܕܐܢܬ ܗܘ ܟܘܡܪܐ ܠܥܠܡ ܒܕܡܘܬܗ ܕܡܠܟܝܙܕܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.5.7",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 5:7",
      "text": "ܐܦ ܟܕ ܒܤܪܐ ܠܒܝܫ ܗܘܐ ܒܥܘܬܐ ܘܬܟܫܦܬܐ ܒܓܥܬܐ ܚܝܠܬܢܝܬܐ ܘܒܕܡܥܐ ܩܪܒ ܗܘܐ ܠܡܢ ܕܡܫܟܚ ܗܘܐ ܡܢ ܡܘܬܐ ܕܢܚܝܘܗܝ ܘܐܫܬܡܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.5.8",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 5:8",
      "text": "ܘܟܕ ܛܒ ܒܪܐ ܐܝܬܘܗܝ ܡܢ ܕܚܠܬܐ ܘܚܫܐ ܕܤܒܠ ܝܠܦܗ ܠܡܫܬܡܥܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.5.9",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 5:9",
      "text": "ܘܗܟܢܐ ܐܬܓܡܪ ܘܗܘܐ ܠܟܠܗܘܢ ܐܝܠܝܢ ܕܡܫܬܡܥܝܢ ܠܗ ܥܠܬܐ ܕܚܝܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.5.10",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 5:10",
      "text": "ܘܐܫܬܡܗ ܡܢ ܐܠܗܐ ܪܒ ܟܘܡܪܐ ܒܕܡܘܬܗ ܕܡܠܟܝܙܕܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.5.11",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 5:11",
      "text": "ܥܠܘܗܝ ܕܝܢ ܥܠ ܗܢܐ ܡܠܟܝܙܕܩ ܤܓܝܐܐ ܗܝ ܠܢ ܡܠܬܐ ܠܡܐܡܪܗ ܘܥܤܩܐ ܠܡܦܫܩܘܬܗ ܡܛܠ ܕܗܘܝܬܘܢ ܠܟܘܢ ܟܪܝܗܐ ܒܡܫܡܥܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.5.12",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 5:12",
      "text": "ܚܝܒܝܢ ܗܘܝܬܘܢ ܓܝܪ ܡܠܦܢܐ ܠܡܗܘܐ ܡܛܠ ܕܙܒܢܐ ܠܟܘܢ ܒܝܘܠܦܢܐ ܗܫܐ ܕܝܢ ܬܘܒ ܤܢܝܩܝܢ ܐܢܬܘܢ ܕܬܐܠܦܘܢ ܐܝܠܝܢ ܐܢܝܢ ܟܬܝܒܬܐ ܩܕܡܝܬܐ ܕܪܝܫ ܡܠܘܗܝ ܕܐܠܗܐ ܘܗܘܝܬܘܢ ܠܟܘܢ ܤܢܝܩܐ ܥܠ ܚܠܒܐ ܘܠܐ ܥܠ ܡܐܟܘܠܬܐ ܫܪܝܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.5.13",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 5:13",
      "text": "ܟܠܢܫ ܕܝܢ ܕܡܐܟܘܠܬܗ ܚܠܒܐ ܗܘ ܠܐ ܡܦܤ ܒܡܠܬܐ ܕܟܐܢܘܬܐ ܡܛܠ ܕܫܒܪܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.5.14",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 5:14",
      "text": "ܕܓܡܝܪܐ ܗܝ ܕܝܢ ܡܐܟܘܠܬܐ ܫܪܝܪܬܐ ܐܝܠܝܢ ܕܡܛܠ ܕܡܕܪܫܝܢ ܐܬܢܦܩܘ ܪܓܫܝܗܘܢ ܠܡܦܪܫ ܛܒܬܐ ܘܒܝܫܬܐ ܀",
      "paragraphStart": false
    }
  ]
}
