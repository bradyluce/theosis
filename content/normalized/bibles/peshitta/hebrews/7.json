{
  "chapter": {
    "id": "peshitta:hebrews.7",
    "translationId": "peshitta",
    "bookSlug": "hebrews",
    "chapterNumber": 7,
    "referenceLabel": "Hebrews 7",
    "summary": "Source text for Hebrews 7 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:hebrews.7.1",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 7:1",
      "text": "ܗܢܐ ܕܝܢ ܡܠܟܝܙܕܩ ܐܝܬܘܗܝ ܡܠܟ ܫܠܝV ܟܘܡܪܐ ܕܐܠܗܐ ܡܪܝܡܐ ܘܗܘ ܐܪܥܗ ܠܐܒܪܗV ܟܕ ܗܦܟ ܡܢ ܚܪܒܐ ܕܡܠܟܐ ܘܒܪܟܗ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:hebrews.7.2",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 7:2",
      "text": "ܘܠܗ ܦܪܫ ܐܒܪܗV ܡܥܤܪܐ ܡܢ ܟܠܡܕV ܕܐܝܬ ܗܘܐ ܥܡܗ ܡܬܦܫܩ ܕܝܢ ܫܡܗ ܡܠܟܐ ܕܟܐܢܘܬܐ ܘܬܘܒ ܡܠܟ ܫܠܝV ܕܐܝܬܘܗܝ ܡܠܟܐ ܕܫܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.3",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 7:3",
      "text": "ܕܠܐ ܐܒܘܗܝ ܘܠܐ ܐܡܗ ܐܬܟܬܒܘ ܒܫܪܒܬܐ ܘܠܐ ܪܝܫܝܬܐ ܕܝܘܡܘܗܝ ܘܠܐ ܫܘܠܡܐ ܕܚܝܘܗܝ ܐܠܐ ܒܕܡܘܬܐ ܕܒܪܗ ܕܐܠܗܐ ܡܩܘܝܐ ܟܘܡܪܘܬܗ ܠܥܠV ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.4",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 7:4",
      "text": "ܚܙܘ ܕܝܢ ܟܡܐ ܪܒ ܗܢܐ ܕܐܒܪܗV ܪܝܫ ܐܒܗܬܐ ܠܗ ܝܗܒ ܡܥܤܪܐ ܕܪܫܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.5",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 7:5",
      "text": "ܐܝܠܝܢ ܓܝܪ ܡܢ ܒܢܝ ܠܘܝ ܕܡܩܒܠܝܢ ܗܘܘ ܟܘܡܪܘܬܐ ܦܘܩܕܢܐ ܐܝܬ ܗܘܐ ܠܗܘܢ ܕܢܡܘܤܐ ܕܢܤܒܘܢ ܡܥܤܪܐ ܡܢ ܥܡܐ ܗܢܘܢ ܡܢ ܐܚܝܗܘܢ ܟܕ ܐܦ ܗܢܘܢ ܡܢ ܚܨܗ ܕܐܒܪܗV ܢܦܩܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.6",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 7:6",
      "text": "ܗܢܐ ܕܝܢ ܕܠܐ ܟܬܝܒ ܒܫܪܒܬܗܘܢ ܡܥܤܪܐ ܫܩܠ ܡܢ ܐܒܪܗV ܘܒܪܟܗ ܠܗܘ ܕܩܒܠ ܡܘܠܟܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.7",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 7:7",
      "text": "ܕܠܐ ܚܪܝܢܐ ܕܝܢ ܗܘ ܕܒܨܝܪ ܡܬܒܪܟ ܡܢ ܗܘ ܕܡܝܬܪ ܡܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.8",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 7:8",
      "text": "ܘܗܪܟܐ ܒܢܝܢܫܐ ܕܡܝܬܝܢ ܢܤܒܝܢ ܡܥܤܪܐ ܠܗܠ ܕܝܢ ܗܘ ܕܐܤܗܕ ܥܠܘܗܝ ܟܬܒܐ ܕܚܝ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.9",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 7:9",
      "text": "ܘܐܝܟ ܐܢܫ ܢܐܡܪ ܒܝܕ ܐܒܪܗV ܐܦ ܠܘܝ ܗܘ ܕܡܥܤܪܐ ܢܤܒ ܗܘܐ ܐܦ ܗܘ ܐܬܥܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.10",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 7:10",
      "text": "ܥܕܟܝܠ ܓܝܪ ܒܚܨܗ ܗܘܐ ܕܐܒܘܗܝ ܟܕ ܐܪܥܗ ܠܡܠܟܝܙܕܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.11",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 7:11",
      "text": "ܐܠܘ ܗܟܝܠ ܓܡܝܪܘܬܐ ܒܝܕ ܟܘܡܪܘܬܐ ܕܠܘܝܐ ܐܝܬܝܗ ܗܘܬ ܕܒܗ ܤܝV ܢܡܘܤܐ ܠܥܡܐ ܠܡܢܐ ܡܬܒܥܐ ܗܘܐ ܟܘܡܪܐ ܐܚܪܢܐ ܕܢܩܘV ܒܕܡܘܬܗ ܕܡܠܟܝܙܕܩ ܐܡܪ ܕܝܢ ܕܒܕܡܘܬܗ ܕܐܗܪܘܢ ܢܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.12",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 7:12",
      "text": "ܐܠܐ ܐܝܟܢܐ ܕܗܘܐ ܫܘܚܠܦܐ ܒܟܘܡܪܘܬܐ ܗܟܢܐ ܗܘܐ ܫܘܚܠܦܐ ܐܦ ܒܢܡܘܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.13",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 7:13",
      "text": "ܗܘ ܓܝܪ ܕܐܬܐܡܪ ܥܠܘܗܝ ܗܠܝܢ ܡܢ ܫܪܒܬܐ ܗܘ ܐܚܪܬܐ ܐܬܝܠܕ ܕܐܢܫ ܡܡܬܘV ܡܢܗ ܠܐ ܫܡܫ ܒܡܕܒܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.14",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 7:14",
      "text": "ܓܠܝܐ ܗܝ ܓܝܪ ܕܡܢ ܝܗܘܕܐ ܕܢܚ ܡܪܢ ܡܢ ܫܪܒܬܐ ܕܠܐ ܐܡܪ ܥܠܝܗ ܡܘܫܐ ܡܕV ܥܠ ܟܘܡܪܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.15",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 7:15",
      "text": "ܘܝܬܝܪܐܝܬ ܬܘܒ ܝܕܝܥܐ ܒܗܝ ܕܐܡܪ ܕܒܕܡܘܬܗ ܕܡܠܟܝܙܕܩ ܩܐV ܟܘܡܪܐ ܐܚܪܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.16",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 7:16",
      "text": "ܗܘ ܕܠܐ ܗܘܐ ܒܢܡܘܤܐ ܕܦܘܩܕܢܐ ܦܓܪܢܝܐ ܗܘܐ ܐܠܐ ܒܚܝܠܐ ܕܚܝܐ ܕܠܐ ܡܫܬܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.17",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 7:17",
      "text": "ܡܤܗܕ ܓܝܪ ܥܠܘܗܝ ܕܐܢܬ ܗܘ ܟܘܡܪܐ ܠܥܠV ܒܕܡܘܬܗ ܕܡܠܟܝܙܕܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.18",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 7:18",
      "text": "ܫܘܚܠܦܐ ܕܝܢ ܕܗܘܐ ܠܦܘܩܕܢܐ ܩܕܡܝܐ ܡܛܠ ܡܚܝܠܘܬܗ ܘܕܝܘܬܪܢ ܠܝܬ ܗܘܐ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.19",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 7:19",
      "text": "ܡܕV ܓܝܪ ܠܐ ܓܡܪ ܢܡܘܤܐ ܥܠ ܕܝܢ ܚܠܦܘܗܝ ܤܒܪܐ ܕܡܝܬܪ ܡܢܗ ܕܒܗ ܡܬܩܪܒܝܢܢ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.20",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Hebrews 7:20",
      "text": "ܘܫܪܪܗ ܠܢ ܒܡܘܡܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.21",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Hebrews 7:21",
      "text": "ܗܢܘܢ ܓܝܪ ܕܠܐ ܡܘܡܬܐ ܗܘܘ ܟܘܡܪܐ ܗܢܐ ܕܝܢ ܒܡܘܡܬܐ ܐܝܟ ܕܐܡܪ ܠܗ ܒܝܕ ܕܘܝܕ ܕܝܡܐ ܡܪܝܐ ܘܠܐ ܢܕܓܠ ܕܐܢܬ ܗܘ ܟܘܡܪܐ ܠܥܠV ܒܕܡܘܬܗ ܕܡܠܟܝܙܕܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.22",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Hebrews 7:22",
      "text": "ܗܢܐ ܟܠܗ ܡܝܬܪܐ ܕܝܬܩܐ ܗܕܐ ܕܗܘܐ ܒܗ ܥܪܒܐ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.23",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Hebrews 7:23",
      "text": "ܘܗܢܘܢ ܗܘܘ ܟܘܡܪܐ ܤܓܝܐܐ ܡܛܠ ܕܡܝܬܝܢ ܗܘܘ ܘܠܐ ܡܫܬܒܩܝܢ ܗܘܘ ܕܢܩܘܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.24",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Hebrews 7:24",
      "text": "ܗܢܐ ܕܝܢ ܡܛܠ ܕܠܥܠV ܩܝV ܠܐ ܥܒܪܐ ܟܘܡܪܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.25",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Hebrews 7:25",
      "text": "ܘܡܫܟܚ ܠܡܚܝܘ ܠܥܠV ܠܐܝܠܝܢ ܕܡܬܩܪܒܝܢ ܒܐܝܕܗ ܠܐܠܗܐ ܚܝ ܗܘ ܓܝܪ ܒܟܠܙܒܢ ܘܡܤܩ ܨܠܘܬܐ ܚܠܦܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.26",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "Hebrews 7:26",
      "text": "ܕܐܝܟ ܗܢܐ ܓܝܪ ܟܘܡܪܐ ܐܦ ܙܕܩ ܗܘܐ ܠܢ ܕܟܝܐ ܕܠܐ ܒܝܫܘ ܘܕܠܐ ܛܘܠܫܐ ܕܦܪܝܩ ܡܢ ܚܛܗܐ ܘܡܪܝV ܠܥܠ ܡܢ ܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.27",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "Hebrews 7:27",
      "text": "ܘܠܝܬ ܠܗ ܐܘܠܨܢܐ ܟܠܝܘV ܐܝܟ ܪܒܝ ܟܘܡܪܐ ܕܠܘܩܕV ܚܠܦ ܚܛܗܘܗܝ ܢܩܪܒ ܕܒܚܐ ܘܗܝܕܝܢ ܚܠܦ ܥܡܐ ܗܕܐ ܓܝܪ ܥܒܕܗ ܚܕܐ ܙܒܢ ܒܢܦܫܗ ܕܩܪܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.7.28",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "Hebrews 7:28",
      "text": "ܢܡܘܤܐ ܓܝܪ ܒܢܝܢܫܐ ܗܘ ܟܪܝܗܐ ܡܩܝV ܟܘܡܪܐ ܡܠܬܐ ܕܝܢ ܕܡܘܡܬܐ ܕܗܘܬ ܒܬܪ ܢܡܘܤܐ ܒܪܐ ܓܡܝܪܐ ܠܥܠV ܀",
      "paragraphStart": false
    }
  ]
}
