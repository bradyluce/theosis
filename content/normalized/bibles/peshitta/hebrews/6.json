{
  "chapter": {
    "id": "peshitta:hebrews.6",
    "translationId": "peshitta",
    "bookSlug": "hebrews",
    "chapterNumber": 6,
    "referenceLabel": "Hebrews 6",
    "summary": "Source text for Hebrews 6 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:hebrews.6.1",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 6:1",
      "text": "ܡܛܠ ܗܢܐ ܢܫܒܘܩ ܫܘܪܝܐ ܕܡܠܬܗ ܕܡܫܝܚܐ ܘܢܐܬܐ ܠܓܡܝܪܘܬܐ ܐܘ ܠܡܐ ܬܘܒ ܫܬܐܤܬܐ ܐܚܪܬܐ ܡܪܡܝܬܘܢ ܠܬܝܒܘܬܐ ܡܢ ܥܒܕܐ ܡܝܬܐ ܘܠܗܝܡܢܘܬܐ ܕܒܐܠܗܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:hebrews.6.2",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 6:2",
      "text": "ܘܠܝܘܠܦܢܐ ܕܡܥܡܘܕܝܬܐ ܘܕܤܝܡ ܐܝܕܐ ܘܠܩܝܡܬܐ ܕܡܢ ܒܝܬ ܡܝܬܐ ܘܠܕܝܢܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.6.3",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 6:3",
      "text": "ܐܢ ܡܪܝܐ ܡܦܤ ܢܥܒܕ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.6.4",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 6:4",
      "text": "ܐܠܐ ܠܐ ܡܫܟܚܝܢ ܗܢܘܢ ܕܚܕܐ ܙܒܢ ܠܡܥܡܘܕܝܬܐ ܢܚܬܘ ܘܛܥܡܘ ܡܘܗܒܬܐ ܕܡܢ ܫܡܝܐ ܘܢܤܒܘ ܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.6.5",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 6:5",
      "text": "ܘܛܥܡܘ ܡܠܬܐ ܛܒܬܐ ܕܐܠܗܐ ܘܚܝܠܐ ܕܥܠܡܐ ܕܥܬܝܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.6.6",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 6:6",
      "text": "ܕܬܘܒ ܢܚܛܘܢ ܕܡܢ ܕܪܝܫ ܢܬܚܕܬܘܢ ܠܬܝܒܘܬܐ ܘܡܢ ܕܪܝܫ ܢܙܩܦܘܢ ܠܒܪܗ ܕܐܠܗܐ ܘܢܨܥܪܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.6.7",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 6:7",
      "text": "ܐܪܥܐ ܓܝܪ ܕܐܫܬܝܬ ܡܛܪܐ ܕܐܬܐ ܠܗ ܙܒܢܝܢ ܤܓܝܐܢ ܘܐܘܥܝܬ ܥܤܒܐ ܕܚܫܚ ܠܗܢܘܢ ܕܡܛܠܬܗܘܢ ܡܬܦܠܚܐ ܡܩܒܠܐ ܒܘܪܟܬܐ ܡܢ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.6.8",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 6:8",
      "text": "ܐܢ ܗܘ ܕܝܢ ܕܬܦܩ ܩܘܪܛܒܐ ܘܕܪܕܪܐ ܗܘܝܐ ܠܗ ܡܤܠܝܬܐ ܘܠܐ ܪܚܝܩܐ ܡܢ ܠܘܛܬܐ ܐܠܐ ܚܪܬܗ ܝܩܕܢܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.6.9",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 6:9",
      "text": "ܡܦܝܤܝܢܢ ܕܝܢ ܥܠܝܟܘܢ ܐܚܝ ܐܝܠܝܢ ܕܫܦܝܪܢ ܘܩܪܝܒܢ ܠܚܝܐ ܐܦܢ ܗܟܢܐ ܡܡܠܠܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.6.10",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 6:10",
      "text": "ܠܐ ܗܘܐ ܓܝܪ ܥܘܠ ܐܠܗܐ ܕܢܛܥܐ ܥܒܕܝܟܘܢ ܘܚܘܒܟܘܢ ܗܘ ܕܚܘܝܬܘܢ ܒܫܡܗ ܕܫܡܫܬܘܢ ܠܩܕܝܫܐ ܘܡܫܡܫܝܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.6.11",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 6:11",
      "text": "ܨܒܝܢܢ ܕܝܢ ܕܐܢܫ ܐܢܫ ܡܢܟܘܢ ܗܝ ܗܕܐ ܚܦܝܛܘܬܐ ܢܚܘܐ ܠܫܘܡܠܝܐ ܕܤܒܪܟܘܢ ܥܕܡܐ ܠܚܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.6.12",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 6:12",
      "text": "ܘܕܠܐ ܬܬܩܛܥ ܠܟܘܢ ܐܠܐ ܕܬܗܘܘܢ ܡܡܪܝܢܐ ܠܗܢܘܢ ܕܒܗܝܡܢܘܬܐ ܘܒܢܓܝܪܘܬ ܪܘܚܐ ܗܘܘ ܝܪܬܐ ܕܡܘܠܟܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.6.13",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 6:13",
      "text": "ܠܐܒܪܗܡ ܓܝܪ ܟܕ ܡܠܟ ܠܗ ܐܠܗܐ ܡܛܠ ܕܠܝܬ ܗܘܐ ܠܗ ܕܪܒ ܡܢܗ ܕܢܐܡܐ ܒܗ ܝܡܐ ܒܢܦܫܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.6.14",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 6:14",
      "text": "ܘܐܡܪ ܕܡܒܪܟܘ ܐܒܪܟܟ ܘܡܤܓܝܘ ܐܤܓܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.6.15",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 6:15",
      "text": "ܘܗܟܢܐ ܐܓܪ ܪܘܚܗ ܘܩܒܠ ܡܘܠܟܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.6.16",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 6:16",
      "text": "ܒܢܝܢܫܐ ܓܝܪ ܒܕܪܒ ܡܢܗܘܢ ܝܡܝܢ ܘܥܠ ܟܠ ܚܪܝܢ ܕܗܘܐ ܒܝܢܬܗܘܢ ܫܘܠܡܐ ܫܪܝܪܐ ܒܡܘܡܬܐ ܗܘܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.6.17",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 6:17",
      "text": "ܡܛܠ ܗܢܐ ܝܬܝܪܐܝܬ ܨܒܐ ܐܠܗܐ ܕܢܚܘܐ ܠܝܪܬܐ ܕܡܘܠܟܢܐ ܕܫܘܘܕܝܗ ܠܐ ܡܫܬܚܠܦ ܘܚܒܫܗ ܒܡܘܡܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.6.18",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 6:18",
      "text": "ܕܒܬܪܬܝܢ ܨܒܘܢ ܕܠܐ ܡܫܬܚܠܦܢ ܕܠܐ ܡܫܟܚ ܐܠܗܐ ܕܢܕܓܠ ܒܗܝܢ ܒܘܝܐܐ ܪܒܐ ܢܗܘܐ ܠܢ ܕܐܬܓܘܤܢ ܒܗ ܘܢܐܚܘܕ ܤܒܪܐ ܕܡܠܝܟ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.6.19",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 6:19",
      "text": "ܗܘ ܕܐܝܬܘܗܝ ܠܢ ܐܝܟ ܐܘܩܝܢܐ ܕܠܒܝܟ ܒܢܦܫܢ ܕܠܐ ܬܬܙܝܥ ܘܥܐܠ ܠܓܘ ܡܢ ܐܦܝ ܬܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.6.20",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Hebrews 6:20",
      "text": "ܟܪ ܕܩܕV ܥܠ ܚܠܦܝܢ ܝܫܘܥ ܘܗܘܐ ܟܘܡܪܐ ܠܥܠV ܒܕܡܘܬܗ ܕܡܠܟܝܙܕܩ ܀",
      "paragraphStart": false
    }
  ]
}
