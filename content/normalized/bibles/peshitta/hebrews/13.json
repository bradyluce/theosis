{
  "chapter": {
    "id": "peshitta:hebrews.13",
    "translationId": "peshitta",
    "bookSlug": "hebrews",
    "chapterNumber": 13,
    "referenceLabel": "Hebrews 13",
    "summary": "Source text for Hebrews 13 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:hebrews.13.1",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 13:1",
      "text": "ܚܘܒܐ ܕܐܚܐ ܢܟܬܪ ܒܟܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:hebrews.13.2",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 13:2",
      "text": "ܘܪܚܡܬܐ ܕܐܟܤܢܝܐ ܠܐ ܬܛܥܘܢ ܒܗܕܐ ܓܝܪ ܫܘܘ ܐܢܫܐ ܕܟܕ ܠܐ ܪܓܝܫܝܢ ܢܩܒܠܘܢ ܡܠܐܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.3",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 13:3",
      "text": "ܥܗܕܘ ܠܐܝܠܝܢ ܕܐܤܝܪܝܢ ܐܝܟ ܗܘ ܕܥܡܗܘܢ ܐܤܝܪܝܢ ܐܢܬܘܢ ܐܬܕܟܪܘ ܠܐܝܠܝܢ ܕܐܠܝܨܝܢ ܐܝܟ ܐܢܫܐ ܕܒܤܪܐ ܠܒܝܫܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.4",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 13:4",
      "text": "ܡܝܩܪ ܗܘ ܙܘܘܓܐ ܒܟܠ ܘܥܪܤܗܘܢ ܕܟܝܐ ܗܝ ܠܙܢܝܐ ܕܝܢ ܘܠܓܝܪܐ ܕܐܢ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.5",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 13:5",
      "text": "ܠܐ ܗܘܐ ܪܚܡ ܟܤܦܐ ܪܥܝܢܟܘܢ ܐܠܐ ܢܤܦܩ ܠܟܘܢ ܡܕܡ ܕܐܝܬ ܠܟܘܢ ܗܘ ܓܝܪ ܡܪܝܐ ܐܡܪ ܕܠܐ ܐܫܒܩܟ ܘܠܐ ܐܪܦܐ ܒܟ ܐܝܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.6",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 13:6",
      "text": "ܘܐܝܬ ܠܢ ܕܢܐܡܪ ܬܟܝܠܐܝܬ ܡܪܝ ܡܥܕܪܢܝ ܠܐ ܐܕܚܠ ܡܢܐ ܥܒܕ ܠܝ ܒܪܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.7",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 13:7",
      "text": "ܗܘܝܬܘܢ ܥܗܕܝܢ ܠܡܕܒܪܢܝܟܘܢ ܐܝܠܝܢ ܕܡܠܠܘ ܥܡܟܘܢ ܡܠܬܐ ܕܐܠܗܐ ܐܬܒܩܘ ܒܫܘܠܡܐ ܕܕܘܒܪܝܗܘܢ ܘܡܪܘ ܒܗܝܡܢܘܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.8",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 13:8",
      "text": "ܝܫܘܥ ܡܫܝܚܐ ܐܬܡܠܝ ܘܝܘܡܢܐ ܗܘܝܘ ܘܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.9",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 13:9",
      "text": "ܠܝܘܠܦܢܐ ܢܘܟܪܝܐ ܘܡܫܚܠܦܐ ܠܐ ܬܬܕܒܪܘܢ ܫܦܝܪ ܗܘ ܓܝܪ ܕܒܛܝܒܘܬܐ ܢܫܪܪ ܠܒܘܬܢ ܘܠܐ ܒܡܐܟܠܬܐ ܡܛܠ ܕܠܐ ܐܬܥܕܪܘ ܐܝܠܝܢ ܕܗܠܟܘ ܒܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.10",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 13:10",
      "text": "ܐܝܬ ܠܢ ܕܝܢ ܡܕܒܚܐ ܕܠܐ ܫܠܝܛ ܠܡܐܟܠ ܡܢܗ ܠܗܢܘܢ ܕܒܡܫܟܢܐ ܡܫܡܫܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.11",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 13:11",
      "text": "ܚܝܘܬܐ ܓܝܪ ܗܠܝܢ ܕܡܥܠ ܗܘܐ ܕܡܗܝܢ ܪܒ ܟܘܡܪܐ ܠܒܝܬ ܡܩܕܫܐ ܚܠܦ ܚܛܗܐ ܒܤܪܗܝܢ ܝܩܕ ܗܘܐ ܠܒܪ ܡܢ ܡܫܪܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.12",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 13:12",
      "text": "ܡܛܠ ܗܢܐ ܐܦ ܝܫܘܥ ܕܢܩܕܫ ܠܥܡܗ ܒܕܡܗ ܠܒܪ ܡܢ ܡܕܝܢܬܐ ܚܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.13",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 13:13",
      "text": "ܘܐܦ ܚܢܢ ܗܟܝܠ ܢܦܘܩ ܠܘܬܗ ܠܒܪ ܡܢ ܡܫܪܝܬܐ ܟܕ ܫܩܝܠܝܢܢ ܚܤܕܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.14",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 13:14",
      "text": "ܠܝܬ ܠܢ ܓܝܪ ܡܕܝܢܬܐ ܕܡܩܘܝܐ ܗܪܟܐ ܐܠܐ ܠܐܝܕܐ ܕܥܬܝܕܐ ܡܤܟܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.15",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 13:15",
      "text": "ܘܒܐܝܕܗ ܢܤܩ ܕܒܚܐ ܕܬܫܒܘܚܬܐ ܒܟܠܙܒܢ ܠܐܠܗܐ ܕܐܝܬܝܗ ܦܐܪܐ ܕܤܦܘܬܐ ܕܡܘܕܝܢ ܠܫܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.16",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 13:16",
      "text": "ܘܠܐ ܬܛܥܘܢ ܡܪܚܡܢܘܬܐ ܘܫܘܬܦܘܬܐ ܕܡܤܟܢܐ ܒܗܠܝܢ ܓܝܪ ܕܒܚܐ ܫܦܪ ܐܢܫ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.17",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 13:17",
      "text": "ܐܬܛܦܝܤܘ ܠܡܕܒܪܢܝܟܘܢ ܘܐܫܬܡܥܘ ܠܗܘܢ ܗܢܘܢ ܓܝܪ ܫܗܪܝܢ ܚܠܦ ܢܦܫܬܟܘܢ ܐܝܟ ܐܢܫܐ ܕܝܗܒܝܢ ܚܘܫܒܢܟܘܢ ܕܒܚܕܘܬܐ ܢܗܘܘܢ ܥܒܕܝܢ ܗܕܐ ܘܠܐ ܒܬܢܚܬܐ ܡܛܠ ܕܠܐ ܦܩܚܐ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.18",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 13:18",
      "text": "ܨܠܘ ܥܠܝܢ ܬܟܝܠܝܢܢ ܓܝܪ ܕܬܐܪܬܐ ܛܒܬܐ ܐܝܬ ܠܢ ܕܒܟܠܡܕܡ ܨܒܝܢܢ ܕܫܦܝܪ ܢܬܕܒܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.19",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 13:19",
      "text": "ܝܬܝܪܐܝܬ ܒܥܐ ܐܢܐ ܡܢܟܘܢ ܕܬܥܒܕܘܢ ܗܕܐ ܕܒܥܓܠ ܐܬܦܢܐ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.20",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Hebrews 13:20",
      "text": "ܐܠܗܐ ܕܝܢ ܕܫܠܡܐ ܗܘ ܕܐܤܩ ܡܢ ܒܝܬ ܡܝܬܐ ܠܪܥܝܐ ܪܒܐ ܕܡܪܥܝܬܐ ܒܕܡܐ ܕܕܝܬܩܐ ܕܠܥܠܡ ܕܐܝܬܘܗܝ ܝܫܘܥ ܡܫܝܚܐ ܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.21",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Hebrews 13:21",
      "text": "ܗܘ ܢܓܡܘܪܟܘܢ ܒܟܠ ܥܒܕ ܛܒ ܕܬܥܒܕܘܢ ܨܒܝܢܗ ܘܗܘ ܢܤܥܘܪ ܒܢ ܡܕܡ ܕܫܦܝܪ ܩܕܡܘܗܝ ܒܝܕ ܝܫܘܥ ܡܫܝܚܐ ܕܠܗ ܫܘܒܚܐ ܠܥܠܡ ܥܠܡܝܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.22",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Hebrews 13:22",
      "text": "ܒܥܐ ܐܢܐ ܕܝܢ ܡܢܟܘܢ ܐܚܝ ܕܬܓܪܘܢ ܪܘܚܟܘܢ ܒܡܠܬܐ ܕܒܘܝܐܐ ܡܛܠ ܕܒܙܥܘܪܝܬܐ ܗܘ ܟܬܒܬ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.23",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Hebrews 13:23",
      "text": "ܕܥܘ ܕܝܢ ܠܐܚܘܢ ܛܝܡܬܐܘܤ ܕܐܫܬܪܝ ܘܐܢ ܒܥܓܠ ܢܐܬܐ ܥܡܗ ܐܚܙܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.24",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Hebrews 13:24",
      "text": "ܫܐܠܘ ܒܫܠܡܐ ܕܟܠܗܘܢ ܡܕܒܪܢܝܟܘܢ ܘܕܟܠܗܘܢ ܩܕܝܫܐ ܫܐܠܝܢ ܒܫܠܡܟܘܢ ܟܠܗܘܢ ܕܡܢ ܐܝܛܠܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.13.25",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Hebrews 13:25",
      "text": "ܛܝܒܘܬܐ ܥܡ ܟܠܟܘܢ ܐܡܝܢ ܀ ܀ ܫܥܡܐܐ ܀",
      "paragraphStart": false
    }
  ]
}
