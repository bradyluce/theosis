{
  "chapter": {
    "id": "peshitta:hebrews.2",
    "translationId": "peshitta",
    "bookSlug": "hebrews",
    "chapterNumber": 2,
    "referenceLabel": "Hebrews 2",
    "summary": "Source text for Hebrews 2 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:hebrews.2.1",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 2:1",
      "text": "ܡܛܠ ܗܢܐ ܚܝܒܝܢܢ ܕܝܬܝܪܐܝܬ ܢܗܘܐ ܙܗܝܪܝܢ ܒܡܕܡ ܕܫܡܥܢ ܕܠܐ ܢܦܠ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:hebrews.2.2",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 2:2",
      "text": "ܐܢ ܓܝܪ ܡܠܬܐ ܕܐܬܡܠܠܬ ܒܝܕ ܡܠܐܟܐ ܐܫܬܪܪܬ ܘܟܠ ܕܫܡܥܗ ܘܥܒܪ ܥܠܝܗ ܩܒܠ ܦܘܪܥܢܐ ܒܟܐܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.2.3",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 2:3",
      "text": "ܐܝܟܢܐ ܚܢܢ ܢܥܪܘܩ ܐܢ ܢܒܤܐ ܥܠ ܐܝܠܝܢ ܕܗܢܘܢ ܐܢܘܢ ܚܝܝܢ ܗܢܘܢ ܕܫܪܝܘ ܡܢ ܡܪܢ ܠܡܬܡܠܠܘ ܘܡܢ ܐܝܠܝܢ ܕܡܢܗ ܫܡܥܘ ܒܢ ܐܫܬܪܪܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.2.4",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 2:4",
      "text": "ܟܕ ܤܗܕ ܥܠܝܗܘܢ ܐܠܗܐ ܒܐܬܘܬܐ ܘܒܬܕܡܪܬܐ ܘܒܚܝܠܐ ܡܫܚܠܦܐ ܘܒܦܘܠܓܐ ܕܪܘܚܐ ܕܩܘܕܫܐ ܕܐܬܝܗܒܘ ܐܝܟ ܨܒܝܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.2.5",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 2:5",
      "text": "ܠܐ ܗܘܐ ܓܝܪ ܠܡܠܐܟܐ ܫܥܒܕ ܥܠܡܐ ܕܥܬܝܕ ܕܥܠܘܗܝ ܡܡܠܠܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.2.6",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 2:6",
      "text": "ܐܠܐ ܐܝܟ ܕܡܤܗܕ ܟܬܒܐ ܘܐܡܪ ܡܢܘ ܓܒܪܐ ܕܥܗܕܬܝܗܝ ܘܒܪܗ ܕܐܢܫܐ ܕܤܥܪܬܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.2.7",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 2:7",
      "text": "ܐܡܟܬܝܗܝ ܩܠܝܠ ܡܢ ܡܠܐܟܐ ܬܫܒܘܚܬܐ ܘܐܝܩܪܐ ܤܡܬ ܒܪܝܫܗ ܘܐܫܠܛܬܝܗܝ ܒܥܒܕܐ ܕܐܝܕܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.2.8",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 2:8",
      "text": "ܘܟܠ ܡܕܡ ܫܥܒܕܬ ܬܚܝܬ ܪܓܠܘܗܝ ܒܗܝ ܕܝܢ ܕܟܠ ܡܕܡ ܫܥܒܕ ܠܗ ܠܐ ܫܒܩ ܡܕܡ ܕܠܐ ܡܫܥܒܕ ܗܫܐ ܕܝܢ ܠܐ ܥܕܟܝܠ ܚܙܝܢܢ ܕܟܠ ܡܕܡ ܡܫܥܒܕ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.2.9",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 2:9",
      "text": "ܗܘ ܕܝܢ ܕܡܟ ܩܠܝܠ ܡܢ ܡܠܐܟܐ ܚܙܝܢܢ ܕܗܘܝܘ ܝܫܘܥ ܡܛܠ ܚܫܐ ܕܡܘܬܗ ܘܬܫܒܘܚܬܐ ܘܐܝܩܪܐ ܤܝܡ ܒܪܝܫܗ ܗܘ ܓܝܪ ܒܛܝܒܘܬܗ ܐܠܗܐ ܚܠܦ ܟܠܢܫ ܛܥܡ ܡܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.2.10",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 2:10",
      "text": "ܝܐܐ ܗܘܐ ܓܝܪ ܠܗܘ ܕܟܠ ܒܐܝܕܗ ܘܟܠ ܡܛܠܬܗ ܘܒܢܝܐ ܤܓܝܐܐ ܐܥܠ ܠܬܫܒܘܚܬܐ ܕܠܪܝܫܐ ܕܚܝܝܗܘܢ ܒܚܫܗ ܢܓܡܪܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.2.11",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 2:11",
      "text": "ܗܘ ܓܝܪ ܕܩܕܫ ܘܗܢܘܢ ܕܐܬܩܕܫܘ ܡܢ ܚܕ ܐܢܘܢ ܟܠܗܘܢ ܡܛܠ ܗܢܐ ܠܐ ܒܗܬ ܕܢܩܪܐ ܐܢܘܢ ܐܚܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.2.12",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 2:12",
      "text": "ܟܕ ܐܡܪ ܐܤܒܪ ܫܡܟ ܠܐܚܝ ܘܒܓܘܗ ܕܥܕܬܐ ܐܫܒܚܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.2.13",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 2:13",
      "text": "ܘܬܘܒ ܕܐܢܐ ܐܗܘܐ ܬܟܝܠ ܥܠܘܗܝ ܘܬܘܒ ܗܐ ܐܢܐ ܘܒܢܝܐ ܕܝܗܒ ܠܝ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.2.14",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 2:14",
      "text": "ܡܛܠ ܓܝܪ ܕܒܢܝܐ ܐܫܬܘܬܦܘ ܒܒܤܪܐ ܘܕܡܐ ܐܦ ܗܘ ܒܗ ܒܕܡܘܬܐ ܐܫܬܘܬܦ ܒܗܝܢ ܒܗܠܝܢ ܕܒܡܘܬܗ ܢܒܛܠ ܠܡܢ ܕܐܚܝܕ ܫܘܠܛܢܐ ܕܡܘܬܐ ܕܐܝܬܘܗܝ ܤܛܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.2.15",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 2:15",
      "text": "ܘܢܫܪܐ ܠܗܢܘܢ ܐܝܠܝܢ ܕܒܕܚܠܬܐ ܕܡܘܬܐ ܒܟܠܗܘܢ ܚܝܝܗܘܢ ܡܫܥܒܕܝܢ ܗܘܘ ܠܥܒܕܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.2.16",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 2:16",
      "text": "ܠܐ ܗܘܐ ܓܝܪ ܥܠ ܡܠܐܟܐ ܡܫܠܛ ܗܘܐ ܡܘܬܐ ܐܠܐ ܥܠ ܙܪܥܗ ܕܐܒܪܗܡ ܡܫܠܛ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.2.17",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 2:17",
      "text": "ܡܛܠ ܗܢܐ ܙܕܩ ܗܘܐ ܕܒܟܠ ܡܕܡ ܢܬܕܡܐ ܠܐܚܘܗܝ ܕܢܗܘܐ ܡܪܚܡܢܐ ܘܪܒ ܟܘܡܪܐ ܡܗܝܡܢܐ ܒܕܐܠܗܐ ܘܢܗܘܐ ܡܚܤܐ ܥܠ ܚܛܗܘܗܝ ܕܥܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.2.18",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 2:18",
      "text": "ܒܗܝ ܓܝܪ ܕܗܘ ܚܫ ܘܐܬܢܤܝ ܡܫܟܚ ܕܢܥܕܪ ܠܐܝܠܝܢ ܕܡܬܢܤܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
