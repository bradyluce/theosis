    "referenceLabel": "Hebrews 8",
    "summary": "Source text for Hebrews 8 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:hebrews.8.1",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 8:1",
      "text": "ܪܝܫܐ ܕܝܢ ܕܟܠܗܝܢ ܐܝܬ ܠܢ ܪܒ ܟܘܡܪܐ ܐܝܢܐ ܕܝܬܒ ܡܢ ܝܡܝܢܐ ܕܟܘܪܤܝܐ ܕܪܒܘܬܐ ܒܫܡܝܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:hebrews.8.2",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 8:2",
      "text": "ܘܗܘܐ ܡܫܡܫܢܐ ܕܒܝܬ ܩܘܕܫܐ ܘܕܡܫܟܢܐ ܕܫܪܪܐ ܗܘ ܕܩܒܥ ܐܠܗܐ ܘܠܐ ܒܪܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.8.3",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 8:3",
      "text": "ܟܠ ܪܒ ܟܘܡܪܐ ܓܝܪ ܕܩܐV ܕܢܩܪܒ ܩܘܪܒܢܐ ܘܕܒܚܐ ܡܛܠ ܗܢܐ ܙܕܩܐ ܗܘܬ ܐܦ ܠܗܢܐ ܕܢܗܘܐ ܐܝܬ ܠܗ ܡܕV ܕܢܩܪܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.8.4",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 8:4",
      "text": "ܘܐܠܘ ܒܐܪܥܐ ܗܘܐ ܐܦܠܐ ܟܘܡܪܐ ܗܘܐ ܗܘܐ ܡܛܠ ܕܐܝܬܝܗܘܢ ܗܘܘ ܟܘܡܪܐ ܕܡܩܪܒܝܢ ܗܘܘ ܩܘܪܒܢܐ ܐܝܟ ܕܒܢܡܘܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.8.5",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 8:5",
      "text": "ܗܢܘܢ ܕܡܫܡܫܝܢ ܠܕܡܘܬܐ ܘܠܛܠܢܝܬܐ ܕܗܠܝܢ ܕܒܫܡܝܐ ܐܝܟ ܕܐܬܐܡܪ ܠܡܘܫܐ ܟܕ ܥܒܕ ܗܘܐ ܡܫܟܢܐ ܕܚܙܝ ܘܥܒܕ ܟܠܡܕV ܒܕܡܘܬܐ ܗܝ ܕܐܬܚܙܝܬ ܠܟ ܒܛܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.8.6",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 8:6",
      "text": "ܗܫܐ ܕܝܢ ܬܫܡܫܬܐ ܕܡܝܬܪܐ ܡܢ ܗܝ ܩܒܠ ܝܫܘܥ ܡܫܝܚܐ ܐܟܡܐ ܕܡܝܬܪܐ ܐܦ ܕܝܬܝܩܐ ܗܝ ܕܥܒܝܕ ܒܗ ܡܨܥܝܐ ܘܒܫܘܘܕܝܐ ܕܡܝܬܪܝܢ ܡܢ ܕܗܝ ܐܬܝܗܒܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.8.7",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 8:7",
      "text": "ܐܠܘ ܓܝܪ ܐܝܬܝܗ ܗܘܬ ܩܕܡܝܬܐ ܕܠܐ ܪܫܝܢ ܠܝܬ ܗܘܐ ܐܬܪܐ ܠܗܕܐ ܕܬܪܬܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.8.8",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 8:8",
      "text": "ܪܫܐ ܠܗܘܢ ܓܝܪ ܘܐܡܪ ܕܗܐ ܝܘܡܬܐ ܐܬܝܢ ܐܡܪ ܡܪܝܐ ܘܐܓܡܘܪ ܥܠ ܒܝܬܐ ܕܒܝܬ ܐܝܤܪܝܠ ܘܥܠ ܒܝܬܐ ܕܒܝܬ ܝܗܘܕܐ ܕܝܬܩܐ ܚܕܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.8.9",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 8:9",
      "text": "ܠܐ ܐܝܟ ܗܝ ܕܝܬܩܐ ܕܝܗܒܬ ܠܐܒܗܝܗܘܢ ܒܝܘܡܐ ܕܐܚܕܬ ܒܐܝܕܗܘܢ ܘܐܦܩܬ ܐܢܘܢ ܡܢ ܐܪܥܐ ܕܡܨܪܝܢ ܡܛܠ ܕܗܢܘܢ ܠܐ ܩܘܝܘ ܒܕܝܬܩܐ ܕܝܠܝ ܐܦ ܐܢܐ ܒܤܝܬ ܒܗܘܢ ܐܡܪ ܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.8.10",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 8:10",
      "text": "ܗܕܐ ܕܝܢ ܕܝܬܩܐ ܕܐܬܠ ܠܒܝܬܐ ܕܒܝܬ ܐܝܤܪܝܠ ܒܬܪ ܝܘܡܬܐ ܗܢܘܢ ܐܡܪ ܡܪܝܐ ܐܬܠܝܘܗܝ ܠܢܡܘܤܝ ܒܡܕܥܝܗܘܢ ܘܥܠ ܠܒܘܬܗܘܢ ܐܟܬܒܝܘܗܝ ܘܐܗܘܐ ܠܗܘܢ ܐܢܐ ܐܠܗܐ ܘܗܢܘܢ ܢܗܘܘܢ ܠܝ ܥܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.8.11",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 8:11",
      "text": "ܘܠܐ ܢܠܦ ܐܢܫ ܠܒܪ ܡܕܝܢܬܗ ܐܦܠܐ ܠܐܚܘܗܝ ܘܢܐܡܪ ܕܕܥ ܠܡܪܝܐ ܡܛܠ ܕܟܠܗܘܢ ܢܕܥܘܢܢܝ ܡܢ ܙܥܘܪܗܘܢ ܘܥܕܡܐ ܠܩܫܝܫܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.8.12",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 8:12",
      "text": "ܘܐܚܤܐ ܐܢܘܢ ܡܢ ܥܘܠܗܘܢ ܘܚܛܗܝܗܘܢ ܬܘܒ ܠܐ ܐܬܕܟܪ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.8.13",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 8:13",
      "text": "ܒܗܝ ܕܐܡܪ ܚܕܬܐ ܠܩܕܡܝܬܐ ܐܥܬܩܗ ܘܐܝܢܐ ܕܥܬܩ ܘܤܐܒ ܩܪܝܒ ܗܘ ܠܚܒܠܐ ܀",
      "paragraphStart": false
    }
  ]
}
