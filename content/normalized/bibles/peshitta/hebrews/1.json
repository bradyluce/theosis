{
  "chapter": {
    "id": "peshitta:hebrews.1",
    "translationId": "peshitta",
    "bookSlug": "hebrews",
    "chapterNumber": 1,
    "referenceLabel": "Hebrews 1",
    "summary": "Source text for Hebrews 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:hebrews.1.1",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 1:1",
      "text": "ܒܟܠ ܡܢܘܢ ܘܒܟܠ ܕܡܘܢ ܡܠܠ ܐܠܗܐ ܥܡ ܐܒܗܝܢ ܒܢܒܝܐ ܡܢ ܩܕܝܡ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:hebrews.1.2",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 1:2",
      "text": "ܘܒܗܠܝܢ ܝܘܡܬܐ ܐܚܪܝܐ ܡܠܠ ܥܡܢ ܒܒܪܗ ܕܠܗ ܤܡ ܝܪܬܐ ܕܟܠܡܕܡ ܘܒܗ ܥܒܕ ܠܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.1.3",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 1:3",
      "text": "ܕܗܘܝܘ ܨܡܚܐ ܕܫܘܒܚܗ ܘܨܠܡܐ ܕܐܝܬܘܬܗ ܘܐܚܝܕ ܟܠ ܒܚܝܠܐ ܕܡܠܬܗ ܘܗܘ ܒܩܢܘܡܗ ܥܒܕ ܕܘܟܝܐ ܕܚܛܗܝܢ ܘܝܬܒ ܥܠ ܝܡܝܢܐ ܕܪܒܘܬܐ ܒܡܪܘܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.1.4",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 1:4",
      "text": "ܘܗܢܐ ܟܠܗ ܝܪܒ ܡܢ ܡܠܐܟܐ ܐܝܟ ܡܐ ܕܡܝܬܪ ܫܡܐ ܕܝܪܬ ܡܢ ܕܝܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.1.5",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 1:5",
      "text": "ܠܐܝܢܐ ܓܝܪ ܡܢ ܡܠܐܟܐ ܡܡܬܘܡ ܐܡܪ ܐܠܗܐ ܕܒܪܝ ܐܢܬ ܐܢܐ ܝܘܡܢܐ ܝܠܕܬܟ ܘܬܘܒ ܕܐܢܐ ܐܗܘܐ ܠܗ ܠܐܒܐ ܘܗܘ ܢܗܘܐ ܠܝ ܠܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.1.6",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 1:6",
      "text": "ܬܘܒ ܕܝܢ ܐܡܬܝ ܕܡܥܠ ܒܘܟܪܐ ܠܥܠܡܐ ܐܡܪ ܕܠܗ ܢܤܓܕܘܢ ܟܠܗܘܢ ܡܠܐܟܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.1.7",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 1:7",
      "text": "ܥܠ ܡܠܐܟܐ ܕܝܢ ܗܟܢܐ ܐܡܪ ܕܥܒܕ ܡܠܐܟܘܗܝ ܪܘܚ ܘܡܫܡܫܢܘܗܝ ܢܘܪ ܝܩܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.1.8",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 1:8",
      "text": "ܥܠ ܒܪܐ ܕܝܢ ܐܡܪ ܕܟܘܪܤܝܟ ܕܝܠܟ ܐܠܗܐ ܠܥܠܡ ܥܠܡܝܢ ܫܒܛܐ ܦܫܝܛܐ ܫܒܛܐ ܕܡܠܟܘܬܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.1.9",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 1:9",
      "text": "ܪܚܡܬ ܟܐܢܘܬܐ ܘܤܢܝܬ ܥܘܠܐ ܡܛܠ ܗܢܐ ܡܫܚܟ ܐܠܗܐ ܐܠܗܟ ܡܫܚܐ ܕܚܕܘܬܐ ܝܬܝܪ ܡܢ ܚܒܪܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.1.10",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 1:10",
      "text": "ܘܬܘܒ ܐܢܬ ܡܢ ܒܪܝܫܝܬ ܤܡܬ ܫܬܐܤܝܗ ܕܐܪܥܐ ܘܫܡܝܐ ܥܒܕ ܐܝܕܝܟ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.1.11",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 1:11",
      "text": "ܗܢܘܢ ܢܥܒܪܘܢ ܘܐܢܬ ܩܝܡ ܐܢܬ ܘܟܠܗܘܢ ܐܝܟ ܢܚܬܐ ܢܒܠܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.1.12",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 1:12",
      "text": "ܘܐܝܟ ܬܟܤܝܬܐ ܬܥܘܦ ܐܢܘܢ ܗܢܘܢ ܢܬܚܠܦܘܢ ܘܐܢܬ ܐܝܟ ܕܐܝܬܝܟ ܐܢܬ ܘܫܢܝܟ ܠܐ ܢܓܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.1.13",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 1:13",
      "text": "ܠܡܢ ܕܝܢ ܡܢ ܡܠܐܟܐ ܡܡܬܘܡ ܐܡܪ ܕܬܒ ܡܢ ܝܡܝܢܝ ܥܕܡܐ ܕܐܤܝܡ ܒܥܠܕܒܒܝܟ ܟܘܒܫܐ ܬܚܝܬ ܪܓܠܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.1.14",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 1:14",
      "text": "ܠܐ ܗܐ ܟܠܗܘܢ ܐܝܬܝܗܘܢ ܪܘܚܐ ܕܬܫܡܫܬܐ ܕܡܫܬܕܪܝܢ ܒܬܫܡܫܬܐ ܡܛܠ ܐܝܠܝܢ ܕܥܬܝܕܝܢ ܠܡܐܪܬ ܚܝܐ ܀",
      "paragraphStart": false
    }
  ]
}
