{
  "chapter": {
    "id": "peshitta:hebrews.3",
    "translationId": "peshitta",
    "bookSlug": "hebrews",
    "chapterNumber": 3,
    "referenceLabel": "Hebrews 3",
    "summary": "Source text for Hebrews 3 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:hebrews.3.1",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 3:1",
      "text": "ܡܟܝܠ ܐܚܝ ܩܕܝܫܐ ܕܐܬܩܪܝܬܘܢ ܒܩܪܝܢܐ ܕܡܢ ܫܡܝܐ ܚܙܐܘܗܝ ܠܗܢܐ ܫܠܝܚܐ ܘܪܒ ܟܘܡܪܐ ܕܬܘܕܝܬܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:hebrews.3.2",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 3:2",
      "text": "ܕܡܗܝܡܢ ܠܡܢ ܕܥܒܕܗ ܐܝܟ ܡܘܫܐ ܒܟܠܗ ܒܝܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.3.3",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 3:3",
      "text": "ܤܓܝܐܐ ܗܝ ܓܝܪ ܬܫܒܘܚܬܗ ܕܗܢܐ ܛܒ ܡܢ ܕܡܘܫܐ ܐܝܟܢܐ ܕܤܓܝ ܐܝܩܪܐ ܕܒܢܝܗ ܕܒܝܬܐ ܛܒ ܡܢ ܒܢܝܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.3.4",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 3:4",
      "text": "ܟܠ ܒܝܬܐ ܓܝܪ ܡܢ ܐܢܫ ܗܘ ܡܬܒܢܐ ܗܘ ܕܝܢ ܕܒܢܐ ܟܠ ܐܠܗܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.3.5",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 3:5",
      "text": "ܘܡܘܫܐ ܐܝܟ ܥܒܕܐ ܐܬܗܝܡܢ ܒܒܝܬܐ ܟܠܗ ܠܤܗܕܘܬܐ ܕܐܝܠܝܢ ܕܥܬܝܕܢ ܗܘܝ ܠܡܬܡܠܠܘ ܒܐܝܕܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.3.6",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 3:6",
      "text": "ܡܫܝܚܐ ܕܝܢ ܐܝܟ ܒܪܐ ܥܠ ܒܝܬܗ ܘܐܝܬܘܗܝ ܒܝܬܗ ܚܢܢ ܐܢ ܥܕܡܐ ܠܚܪܬܐ ܢܐܚܘܕ ܓܠܝܘܬ ܐܦܐ ܘܫܘܒܗܪܐ ܕܤܒܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.3.7",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 3:7",
      "text": "ܡܛܠ ܕܐܡܪܬ ܪܘܚܐ ܕܩܘܕܫܐ ܕܝܘܡܢܐ ܐܢ ܒܩܠܗ ܬܫܡܥܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.3.8",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 3:8",
      "text": "ܠܐ ܬܩܫܘܢ ܠܒܘܬܟܘܢ ܠܡܪܓܙܘܬܗ ܐܝܟ ܡܡܪܡܪܢܐ ܘܐܝܟ ܝܘܡܐ ܕܢܤܝܘܢܐ ܕܒܡܕܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.3.9",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 3:9",
      "text": "ܕܢܤܝܘܢܝ ܐܒܗܝܟܘܢ ܘܒܩܘ ܚܙܘ ܥܒܕܝ ܐܪܒܥܝܢ ܫܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.3.10",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 3:10",
      "text": "ܡܛܠ ܗܢܐ ܡܐܢܬ ܠܝ ܒܕܪܐ ܗܘ ܘܐܡܪܬ ܕܥܡܐ ܗܘ ܕܛܥܐ ܠܒܗܘܢ ܘܗܢܘܢ ܠܐ ܝܕܥܘ ܐܘܪܚܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.3.11",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 3:11",
      "text": "ܘܐܝܟ ܕܝܡܝܬ ܒܪܘܓܙܝ ܕܠܐ ܢܥܠܘܢ ܠܢܝܚܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.3.12",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 3:12",
      "text": "ܐܙܕܗܪܘ ܗܟܝܠ ܐܚܝ ܕܠܡܐ ܢܗܘܐ ܒܐܢܫ ܡܢܟܘܢ ܠܒܐ ܒܝܫܐ ܕܠܐ ܡܗܝܡܢ ܘܬܦܪܩܘܢ ܡܢ ܐܠܗܐ ܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.3.13",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 3:13",
      "text": "ܐܠܐ ܒܥܘ ܡܢ ܢܦܫܟܘܢ ܟܠܗܘܢ ܝܘܡܬܐ ܥܕܡܐ ܠܝܘܡܐ ܕܡܬܩܪܐ ܝܘܡܢܐ ܕܠܐ ܢܬܩܫܐ ܐܢܫ ܡܢܟܘܢ ܒܛܥܝܘܬܐ ܕܚܛܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.3.14",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 3:14",
      "text": "ܐܬܚܠܛܢ ܓܝܪ ܥܡ ܡܫܝܚܐ ܐܢ ܡܢ ܪܝܫܝܬܐ ܘܥܕܡܐ ܠܐܚܪܝܬܐ ܒܗ ܒܩܝܡܐ ܗܢܐ ܫܪܝܪܐ ܢܚܡܤܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.3.15",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 3:15",
      "text": "ܐܝܟܢܐ ܕܐܡܝܪ ܕܝܘܡܢܐ ܐܢ ܒܪܬ ܩܠܗ ܬܫܡܥܘܢ ܠܐ ܬܩܫܘܢ ܠܒܘܬܟܘܢ ܠܡܪܓܙܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.3.16",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 3:16",
      "text": "ܡܢ ܐܢܘܢ ܓܝܪ ܗܢܘܢ ܕܫܡܥܘ ܘܐܪܓܙܘܗܝ ܠܐ ܟܠܗܘܢ ܗܠܝܢ ܕܢܦܩܘ ܡܢ ܡܨܪܝܢ ܒܝܕ ܡܘܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.3.17",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 3:17",
      "text": "ܘܒܐܝܠܝܢ ܡܐܢܬ ܠܗ ܐܪܒܥܝܢ ܫܢܝܢ ܐܠܐ ܒܗܢܘܢ ܕܚܛܘ ܘܓܪܡܝܗܘܢ ܢܦܠܘ ܒܡܕܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.3.18",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 3:18",
      "text": "ܘܥܠ ܐܝܠܝܢ ܝܡܐ ܕܠܐ ܢܥܠܘܢ ܠܢܝܚܬܗ ܐܠܐ ܥܠ ܗܢܘܢ ܕܠܐ ܐܬܛܦܝܤܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.3.19",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 3:19",
      "text": "ܘܚܙܝܢܢ ܕܠܐ ܐܫܟܚܘ ܠܡܥܠ ܡܛܠ ܕܠܐ ܗܝܡܢܘ ܀",
      "paragraphStart": false
    }
  ]
}
