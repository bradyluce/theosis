{
  "chapter": {
    "id": "peshitta:hebrews.12",
    "translationId": "peshitta",
    "bookSlug": "hebrews",
    "chapterNumber": 12,
    "referenceLabel": "Hebrews 12",
    "summary": "Source text for Hebrews 12 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:hebrews.12.1",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 12:1",
      "text": "ܡܛܠ ܗܢܐ ܐܦ ܚܢܢ ܕܐܝܬ ܠܢ ܗܠܝܢ ܟܠܗܘܢ ܤܗܕܐ ܕܐܝܟ ܥܢܢܐ ܚܕܝܪܝܢ ܠܢ ܢܫܕܐ ܡܢܢ ܟܠ ܝܘܩܪܝܢ ܐܦ ܚܛܝܬܐ ܕܒܟܠܙܒܢ ܡܛܝܒܐ ܗܝ ܠܢ ܘܒܡܤܝܒܪܢܘܬܐ ܢܪܗܛܝܘܗܝ ܠܐܓܘܢܐ ܗܢܐ ܕܤܝܡ ܠܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:hebrews.12.2",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 12:2",
      "text": "ܘܢܚܘܪ ܒܝܫܘܥ ܕܗܘ ܗܘܐ ܪܝܫܐ ܘܓܡܘܪܐ ܠܗܝܡܢܘܬܢ ܕܚܠܦ ܚܕܘܬܐ ܕܐܝܬ ܗܘܐ ܠܗ ܤܝܒܪ ܨܠܝܒܐ ܘܥܠ ܒܗܬܬܐ ܐܡܤܪ ܘܥܠ ܝܡܝܢܐ ܕܟܘܪܤܝܗ ܕܐܠܗܐ ܝܬܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.3",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 12:3",
      "text": "ܚܙܘ ܗܟܝܠ ܟܡܐ ܤܝܒܪ ܡܢ ܚܛܝܐ ܗܢܘܢ ܕܗܢܘܢ ܗܘܘ ܤܩܘܒܠܐ ܠܢܦܫܗܘܢ ܕܠܐ ܬܡܐܢ ܠܟܘܢ ܘܠܐ ܬܬܪܦܐ ܢܦܫܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.4",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 12:4",
      "text": "ܠܐ ܥܕܟܝܠ ܡܛܝܬܘܢ ܥܕܡܐ ܠܕܡܐ ܒܐܓܘܢܐ ܕܠܘܩܒܠ ܚܛܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.5",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 12:5",
      "text": "ܘܛܥܝܬܘܢܝܗܝ ܠܝܘܠܦܢܐ ܐܝܢܐ ܕܐܝܟ ܕܠܒܢܝܐ ܐܡܪ ܠܟܘܢ ܒܪܝ ܠܐ ܬܗܡܐ ܡܢ ܡܪܕܘܬܗ ܕܡܪܝܐ ܘܠܐ ܬܪܦܐ ܢܦܫܟ ܐܡܬܝ ܕܡܢܗ ܡܬܟܘܢ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.6",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 12:6",
      "text": "ܠܡܢ ܕܪܚܡ ܓܝܪ ܡܪܝܐ ܪܕܐ ܠܗ ܘܡܢܓܕ ܠܒܢܝܐ ܐܝܠܝܢ ܕܗܘ ܨܒܐ ܒܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.7",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 12:7",
      "text": "ܤܝܒܪܘ ܗܟܝܠ ܡܪܕܘܬܐ ܡܛܠ ܕܐܝܟ ܕܠܘܬ ܒܢܝܐ ܤܥܪ ܨܐܕܝܟܘܢ ܐܠܗܐ ܐܝܢܘ ܓܝܪ ܒܪܐ ܕܠܐ ܪܕܐ ܠܗ ܐܒܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.8",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 12:8",
      "text": "ܘܐܢ ܕܠܐ ܡܪܕܘܬܐ ܐܢܬܘܢ ܗܝ ܕܒܗ ܡܬܪܕܐ ܟܠܢܫ ܗܘܝܬܘܢ ܠܟܘܢ ܢܘܟܪܝܐ ܘܠܐ ܒܢܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.9",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 12:9",
      "text": "ܘܐܢ ܐܒܗܝܢ ܕܒܤܪܐ ܪܕܝܢ ܗܘܘ ܠܢ ܘܒܗܬܝܢ ܗܘܝܢ ܡܢܗܘܢ ܟܡܐ ܗܟܝܠ ܚܝܒܝܢܢ ܕܢܫܬܥܒܕ ܠܐܒܘܗܝܢ ܕܪܘܚܬܐ ܘܢܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.10",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 12:10",
      "text": "ܗܢܘܢ ܓܝܪ ܠܙܒܢ ܗܘ ܙܥܘܪ ܐܝܟ ܕܨܒܝܢ ܗܘܘ ܪܕܝܢ ܗܘܘ ܠܢ ܐܠܗܐ ܕܝܢ ܠܥܘܕܪܢܢ ܕܢܫܬܘܬܦ ܠܩܕܝܫܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.11",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 12:11",
      "text": "ܟܠ ܡܪܕܘܬܐ ܕܝܢ ܒܙܒܢܗ ܠܐ ܡܤܬܒܪܐ ܕܕܚܕܘܬܐ ܗܝ ܐܠܐ ܕܟܪܝܘܬܐ ܠܚܪܬܐ ܕܝܢ ܦܐܪܐ ܕܫܠܡܐ ܘܕܙܕܝܩܘܬܐ ܝܗܒܐ ܠܐܝܠܝܢ ܕܒܗ ܐܬܕܪܫܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.12",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 12:12",
      "text": "ܡܛܠ ܗܢܐ ܐܝܕܝܟܘܢ ܡܫܪܝܬܐ ܘܒܘܪܟܝܟܘܢ ܪܥܠܬܐ ܫܪܪܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.13",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 12:13",
      "text": "ܘܫܒܝܠܐ ܬܪܝܨܐ ܥܒܕܘ ܠܪܓܠܝܟܘܢ ܕܗܕܡܐ ܕܚܓܝܪ ܠܐ ܢܛܥܫ ܐܠܐ ܢܬܐܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.14",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 12:14",
      "text": "ܗܪܛܘ ܒܬܪ ܫܠܡܐ ܥܡ ܟܠ ܐܢܫ ܘܒܬܪ ܩܕܝܫܘܬܐ ܕܒܠܥܕܝܗ ܐܢܫ ܠܡܪܢ ܠܐ ܚܙܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.15",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 12:15",
      "text": "ܘܗܘܝܬܘܢ ܙܗܝܪܝܢ ܕܠܡܐ ܐܢܫ ܢܫܬܟܚ ܒܟܘܢ ܕܚܤܝܪ ܡܢ ܛܝܒܘܬܐ ܕܐܠܗܐ ܐܘ ܕܠܡܐ ܥܩܪܐ ܕܡܪܪܐ ܢܦܩ ܥܘܦܝܐ ܘܢܗܪܟܘܢ ܘܒܗ ܤܓܝܐܐ ܢܤܬܝܒܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.16",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 12:16",
      "text": "ܐܘ ܠܡܐ ܐܢܫ ܢܫܬܟܚ ܒܟܘܢ ܕܙܢܝ ܘܪܦܐ ܐܝܟ ܥܤܘ ܕܒܚܕܐ ܡܐܟܘܠܬܐ ܙܒܢ ܒܘܟܪܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.17",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 12:17",
      "text": "ܝܕܥܝܢ ܐܢܬܘܢ ܓܝܪ ܕܐܦ ܡܢ ܒܬܪܟܢ ܨܒܐ ܗܘܐ ܕܢܐܪܬ ܒܘܪܟܬܐ ܘܐܤܬܠܝ ܐܬܪܐ ܓܝܪ ܠܬܝܒܘܬܐ ܠܐ ܐܫܟܚ ܟܕ ܒܕܡܥܐ ܒܥܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.18",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 12:18",
      "text": "ܠܐ ܓܝܪ ܐܬܩܪܒܬܘܢ ܠܢܘܪܐ ܕܝܩܕܐ ܘܡܬܓܫܐ ܐܦܠܐ ܠܚܫܘܟܐ ܘܠܥܪܦܠܐ ܘܠܥܪܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.19",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 12:19",
      "text": "ܘܠܐ ܠܩܠܐ ܕܩܪܢܐ ܘܠܩܠܐ ܕܡܠܐ ܗܘ ܕܗܢܘܢ ܕܫܡܥܘܗܝ ܐܫܬܐܠܘ ܕܠܐ ܢܬܬܘܤܦ ܢܬܡܠܠ ܥܡܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.20",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Hebrews 12:20",
      "text": "ܠܐ ܓܝܪ ܡܫܟܚܝܢ ܗܘܘ ܠܡܤܝܒܪܘ ܡܕܡ ܕܐܬܦܩܕܘ ܕܐܦܢ ܚܝܘܬܐ ܬܬܩܪܒ ܠܘܬ ܛܘܪܐ ܬܬܪܓܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.21",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Hebrews 12:21",
      "text": "ܘܗܟܢܐ ܕܚܝܠ ܗܘܐ ܚܙܘܐ ܕܡܘܫܐ ܐܡܪ ܕܕܚܝܠ ܐܢܐ ܘܪܬܝܬ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.22",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Hebrews 12:22",
      "text": "ܐܢܬܘܢ ܕܝܢ ܐܬܩܪܒܬܘܢ ܠܛܘܪܐ ܕܨܗܝܘܢ ܘܠܡܕܝܢܬܐ ܕܐܠܗܐ ܚܝܐ ܠܐܘܪܫܠܡ ܕܒܫܡܝܐ ܘܠܟܢܫܐ ܕܪܒܘܬܐ ܕܡܠܐܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.23",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Hebrews 12:23",
      "text": "ܘܠܥܕܬܐ ܕܒܘܟܪܐ ܕܡܬܟܬܒܝܢ ܒܫܡܝܐ ܘܠܐܠܗܐ ܕܝܢܐ ܕܟܠ ܘܠܪܘܚܬܐ ܕܟܐܢܐ ܕܐܬܓܡܪܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.24",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Hebrews 12:24",
      "text": "ܘܠܝܫܘܥ ܡܨܥܝܐ ܕܕܝܬܩܐ ܚܕܬܐ ܘܠܪܤܤ ܕܡܗ ܕܡܡܠܠ ܛܒ ܡܢ ܗܘ ܕܗܒܝܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.25",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Hebrews 12:25",
      "text": "ܐܙܕܗܪܘ ܗܟܝܠ ܕܠܡܐ ܬܫܬܐܠܘܢ ܡܢ ܡܢ ܕܡܠܠ ܥܡܟܘܢ ܐܢ ܓܝܪ ܗܢܘܢ ܠܐ ܐܬܦܨܝܘ ܕܐܫܬܐܠܘ ܡܢ ܕܡܠܠ ܥܡܗܘܢ ܒܐܪܥܐ ܚܕ ܟܡܐ ܚܢܢ ܐܢ ܢܫܬܐܠ ܡܢ ܡܢ ܕܡܠܠ ܥܡܢ ܡܢ ܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.26",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "Hebrews 12:26",
      "text": "ܐܝܢܐ ܕܩܠܗ ܐܪܥܐ ܐܙܝܥ ܗܫܐ ܕܝܢ ܡܠܟ ܘܐܡܪ ܕܬܘܒ ܚܕܐ ܙܒܢ ܐܢܐ ܐܙܝܥ ܠܐ ܒܠܚܘܕ ܐܪܥܐ ܐܠܐ ܐܦ ܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.27",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "Hebrews 12:27",
      "text": "ܗܕܐ ܕܝܢ ܕܐܡܪ ܚܕܐ ܙܒܢ ܡܚܘܝܐ ܫܘܚܠܦܐ ܕܗܢܘܢ ܕܡܬܙܝܥܝܢ ܡܛܠ ܕܥܒܝܕܐ ܐܢܘܢ ܕܢܩܘܘܢ ܗܢܘܢ ܕܠܐ ܡܬܙܝܥܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.28",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "Hebrews 12:28",
      "text": "ܡܛܠ ܗܟܝܠ ܕܩܒܠܢ ܡܠܟܘܬܐ ܕܠܐ ܡܬܙܝܥܐ ܢܐܚܘܕ ܛܝܒܘܬܐ ܕܒܗ ܢܫܡܫ ܘܢܫܦܪ ܠܐܠܗܐ ܒܬܚܡܨܬܐ ܘܒܕܚܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.12.29",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 29,
      "referenceLabel": "Hebrews 12:29",
      "text": "ܐܠܗܢ ܓܝܪ ܢܘܪܐ ܗܘ ܐܟܠܬܐ ܀",
      "paragraphStart": false
    }
  ]
}
