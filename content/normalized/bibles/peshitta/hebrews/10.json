{
  "chapter": {
    "id": "peshitta:hebrews.10",
    "translationId": "peshitta",
    "bookSlug": "hebrews",
    "chapterNumber": 10,
    "referenceLabel": "Hebrews 10",
    "summary": "Source text for Hebrews 10 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:hebrews.10.1",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 10:1",
      "text": "ܢܡܘܤܐ ܓܝܪ ܛܠܢܝܬܐ ܐܝܬ ܗܘܐ ܒܗ ܕܛܒܬܐ ܕܥܬܝܕܢ ܠܐ ܗܘܐ ܩܢܘܡܐ ܕܝܠܗܝܢ ܕܨܒܘܬܐ ܡܛܠ ܗܢܐ ܟܕ ܒܟܠ ܫܢܐ ܗܢܘܢ ܟܕ ܗܢܘܢ ܕܒܚܐ ܡܬܩܪܒܝܢ ܗܘܘ ܠܐ ܡܡܬܘV ܐܫܟܚܘ ܕܢܓܡܪܘܢ ܠܐܝܠܝܢ ܕܡܩܪܒܝܢ ܠܗܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:hebrews.10.2",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 10:2",
      "text": "ܐܠܘ ܓܝܪ ܓܡܪܝܢ ܗܘܘ ܟܒܪ ܕܝܢ ܐܬܬܢܝܚܘ ܡܢ ܩܘܪܒܢܝܗܘܢ ܡܛܠ ܕܠܐ ܡܟܝܠ ܛܪܝܐ ܗܘܬ ܠܗܘܢ ܬܐܪܬܗܘܢ ܒܚܛܗܐ ܠܐܝܠܝܢ ܕܚܕܐ ܙܒܢ ܐܬܕܟܝܘ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.3",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 10:3",
      "text": "ܐܠܐ ܒܗܘܢ ܒܕܒܚܐ ܡܕܟܪܝܢ ܚܛܗܝܗܘܢ ܒܟܠ ܫܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.4",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 10:4",
      "text": "ܠܐ ܓܝܪ ܡܫܟܚ ܕܡܐ ܕܬܘܪܐ ܘܕܨܦܪܝܐ ܠܡܕܟܝܘ ܚܛܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.5",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 10:5",
      "text": "ܡܛܠ ܗܢܐ ܟܕ ܥܐܠ ܠܥܠܡܐ ܐܡܪ ܒܕܒܚܐ ܘܩܘܪܒܢܐ ܠܐ ܨܒܝܬ ܦܓܪܐ ܕܝܢ ܐܠܒܫܬܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.6",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 10:6",
      "text": "ܘܝܩܕܐ ܫܠܡܐ ܕܚܠܦ ܚܛܗܐ ܠܐ ܫܐܠܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.7",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 10:7",
      "text": "ܗܝܕܝܢ ܐܡܪܬ ܕܗܐ ܐܢܐ ܐܬܐ ܐܢܐ ܕܒܪܝܫ ܟܬܒܐ ܟܬܝܒ ܥܠܝ ܕܐܥܒܕ ܨܒܝܢܟ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.8",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 10:8",
      "text": "ܡܢ ܠܥܠ ܐܡܪ ܕܕܒܚܐ ܘܩܘܪܒܢܐ ܘܝܩܕܐ ܫܠܡܐ ܕܚܠܦ ܚܛܗܐ ܠܐ ܨܒܝܬ ܗܢܘܢ ܕܡܬܩܪܒܝܢ ܗܘܘ ܒܢܡܘܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.9",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 10:9",
      "text": "ܘܒܬܪܗ ܐܡܪ ܕܗܐ ܐܬܐ ܐܢܐ ܕܐܥܒܕ ܨܒܝܢܟ ܐܠܗܐ ܒܗܕܐ ܒܛܠ ܠܩܕܡܝܬܐ ܕܢܩܝܡ ܠܕܬܪܬܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.10",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 10:10",
      "text": "ܒܗܢܐ ܓܝܪ ܨܒܝܢܗ ܐܬܩܕܫܢ ܒܩܘܪܒܢܐ ܕܦܓܪܗ ܕܝܫܘܥ ܡܫܝܚܐ ܕܚܕܐ ܙܒܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.11",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 10:11",
      "text": "ܟܠ ܪܒ ܟܘܡܪܐ ܓܝܪ ܕܩܐܡ ܗܘܐ ܘܡܫܡܫ ܟܠܝܘܡ ܗܢܘܢ ܒܗܢܘܢ ܕܒܚܐ ܡܩܪܒ ܗܘܐ ܐܝܠܝܢ ܕܡܢ ܡܬܘܡ ܠܐ ܡܫܟܚܝܢ ܗܘܘ ܠܡܕܟܝܘ ܚܛܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.12",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 10:12",
      "text": "ܗܢܐ ܕܝܢ ܚܕ ܕܒܚܐ ܩܪܒ ܚܠܦ ܚܛܗܐ ܘܝܬܒ ܥܠ ܝܡܝܢܐ ܕܐܠܗܐ ܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.13",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 10:13",
      "text": "ܘܡܩܘܐ ܡܟܝܠ ܥܕܡܐ ܕܢܬܬܤܝܡܘܢ ܒܥܠܕܒܒܘܗܝ ܟܘܒܫܐ ܬܚܝܬ ܪܓܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.14",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 10:14",
      "text": "ܒܚܕ ܓܝܪ ܩܘܪܒܢܐ ܓܡܪ ܠܐܝܠܝܢ ܕܡܬܩܕܫܝܢ ܒܗ ܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.15",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 10:15",
      "text": "ܤܗܕܐ ܠܢ ܕܝܢ ܐܦ ܪܘܚܐ ܕܩܘܕܫܐ ܕܐܡܪܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.16",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 10:16",
      "text": "ܗܕܐ ܗܝ ܕܝܬܩܐ ܕܐܬܠ ܠܗܘܢ ܡܢ ܒܬܪ ܝܘܡܬܐ ܗܢܘܢ ܐܡܪ ܡܪܝܐ ܐܬܠܝܘܗܝ ܠܢܡܘܤܝ ܒܡܕܥܝܗܘܢ ܘܥܠ ܠܒܘܬܗܘܢ ܐܟܬܒܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.17",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 10:17",
      "text": "ܘܥܘܠܗܘܢ ܘܚܛܗܝܗܘܢ ܠܐ ܐܬܕܟܪ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.18",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 10:18",
      "text": "ܐܝܟܐ ܕܝܢ ܕܐܝܬ ܫܘܒܩܢܐ ܕܚܛܗܐ ܠܐ ܡܬܒܥܐ ܩܘܪܒܢܐ ܕܚܠܦ ܚܛܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.19",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 10:19",
      "text": "ܐܝܬ ܠܢ ܗܟܝܠ ܐܚܝ ܓܠܝܘܬ ܐܦܐ ܒܡܥܠܢܐ ܕܒܝܬ ܩܘܕܫܐ ܒܕܡܗ ܕܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.20",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Hebrews 10:20",
      "text": "ܘܐܘܪܚܐ ܕܚܝܐ ܕܚܕܬ ܠܢ ܗܫܐ ܒܐܦܝ ܬܪܥܐ ܕܐܝܬܘܗܝ ܒܤܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.21",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Hebrews 10:21",
      "text": "ܘܐܝܬ ܠܢ ܟܘܡܪܐ ܪܒܐ ܥܠ ܒܝܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.22",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Hebrews 10:22",
      "text": "ܢܩܪܘܒ ܗܟܝܠ ܒܠܒܐ ܫܪܝܪܐ ܘܒܬܘܟܠܢܐ ܕܗܝܡܢܘܬܐ ܟܕ ܪܤܝܤܝܢ ܠܒܘܬܢ ܘܕܟܝܢ ܡܢ ܬܐܪܬܐ ܒܝܫܬܐ ܘܡܤܚܝ ܦܓܪܢ ܒܡܝܐ ܕܟܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.23",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Hebrews 10:23",
      "text": "ܘܢܚܡܤܢ ܒܬܘܕܝܬܐ ܕܤܒܪܢ ܘܠܐ ܢܨܛܠܐ ܡܗܝܡܢ ܗܘ ܓܝܪ ܡܢ ܕܡܠܟ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.24",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Hebrews 10:24",
      "text": "ܘܢܚܘܪ ܚܕ ܒܚܕ ܒܓܘܪܓܐ ܕܚܘܒܐ ܘܕܥܒܕܐ ܛܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.25",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Hebrews 10:25",
      "text": "ܘܠܐ ܢܗܘܐ ܫܒܩܝܢ ܟܢܘܫܝܢ ܐܝܟ ܕܐܝܬ ܥܝܕܐ ܠܐܢܫ ܐܢܫ ܐܠܐ ܒܥܘ ܚܕ ܡܢ ܚܕ ܝܬܝܪܐܝܬ ܟܡܐ ܕܚܙܝܬܘܢ ܕܩܪܒ ܝܘܡܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.26",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Hebrews 10:26",
      "text": "ܐܢ ܓܝܪ ܒܨܒܝܢܗ ܢܚܛܐ ܐܢܫ ܡܢ ܒܬܪ ܕܩܒܠ ܝܕܥܬܐ ܕܫܪܪܐ ܠܝܬ ܡܟܝܠ ܕܒܚܬܐ ܕܬܬܩܪܒ ܚܠܦ ܚܛܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.27",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Hebrews 10:27",
      "text": "ܐܠܐ ܥܬܝܕ ܗܘ ܕܝܢܐ ܕܚܝܠܐ ܘܛܢܢܐ ܕܢܘܪܐ ܕܐܟܠ ܠܒܥܠܕܒܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.28",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Hebrews 10:28",
      "text": "ܐܢ ܓܝܪ ܐܝܢܐ ܕܥܒܪ ܥܠ ܢܡܘܤܐ ܕܡܘܫܐ ܥܠ ܦܘܡ ܬܪܝܢ ܘܬܠܬܐ ܤܗܕܝܢ ܕܠܐ ܪܚܡܝܢ ܡܐܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.29",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Hebrews 10:29",
      "text": "ܟܡܐ ܤܒܪܝܢ ܐܢܬܘܢ ܝܬܝܪܐܝܬ ܡܤܡ ܒܪܫܐ ܢܩܒܠ ܐܝܢܐ ܕܕܫܗ ܠܒܪܗ ܕܐܠܗܐ ܘܚܫܒ ܕܡܐ ܕܕܝܬܩܐ ܕܝܠܗ ܐܝܟ ܕܟܠܢܫ ܕܒܗ ܐܬܩܕܫ ܘܨܥܪ ܠܪܘܚܐ ܕܛܝܒܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.30",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Hebrews 10:30",
      "text": "ܝܕܥܝܢܢ ܠܗܘ ܕܐܡܪ ܕܕܝܠܝ ܗܝ ܬܒܥܬܐ ܘܐܢܐ ܐܦܪܘܥ ܘܬܘܒ ܕܢܕܘܢ ܡܪܝܐ ܠܥܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.31",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Hebrews 10:31",
      "text": "ܕܚܠܬܐ ܗܝ ܪܒܬܐ ܠܡܦܠ ܒܐܝܕܘܗܝ ܕܐܠܗܐ ܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.32",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Hebrews 10:32",
      "text": "ܐܬܕܟܪܘ ܗܟܝܠ ܠܝܘܡܬܐ ܩܕܡܝܐ ܗܢܘܢ ܕܒܗܘܢ ܩܒܠܬܘܢ ܡܥܡܘܕܝܬܐ ܘܐܓܘܢܐ ܪܒܐ ܤܝܒܪܬܘܢ ܕܚܫܐ ܒܚܤܕܐ ܘܒܐܘܠܨܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.33",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "Hebrews 10:33",
      "text": "ܘܕܗܘܝܬܘܢ ܚܙܘܢܐ ܘܐܦ ܐܫܬܘܬܦܬܘܢ ܠܐܢܫܐ ܕܗܠܝܢ ܤܝܒܪܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.34",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 34,
      "referenceLabel": "Hebrews 10:34",
      "text": "ܘܟܐܒ ܠܟܘܢ ܥܠ ܐܝܠܝܢ ܕܐܤܝܪܝܢ ܘܚܛܘܦܝܐ ܕܢܟܤܝܟܘܢ ܒܚܕܘܬܐ ܤܝܒܪܬܘܢ ܡܛܠ ܕܝܕܥܝܢ ܐܢܬܘܢ ܕܐܝܬ ܠܟܘܢ ܩܢܝܢܐ ܒܫܡܝܐ ܕܡܝܬܪ ܗܘ ܘܠܐ ܥܒܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.35",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 35,
      "referenceLabel": "Hebrews 10:35",
      "text": "ܠܐ ܗܟܝܠ ܬܘܒܕܘܢ ܓܠܝܘܬ ܐܦܐ ܕܐܝܬ ܠܟܘܢ ܕܥܬܝܕ ܠܗ ܐܓܪܐ ܤܓܝܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.10.36",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 36,
      "referenceLabel": "Hebrews 10:36",
      "text": "ܡܤܝܒܪܢܘܬܐ ܗܘ ܓܝܪ ܡܬܒܥܝܐ ܠܟܘܢ ܕܬܥܒܕܘܢ ܨܒܝܢܐ ܕܐܠܗܐ ܘܬܤܒܘܢ ܡܘܠܟܢܐ ܀",
      "paragraphStart": false
    },
    {
