{
  "chapter": {
    "id": "peshitta:hebrews.11",
    "translationId": "peshitta",
    "bookSlug": "hebrews",
    "chapterNumber": 11,
    "referenceLabel": "Hebrews 11",
    "summary": "Source text for Hebrews 11 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:hebrews.11.1",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 11:1",
      "text": "ܐܝܬܝܗ ܕܝܢ ܗܝܡܢܘܬܐ ܦܝܤܐ ܥܠ ܐܝܠܝܢ ܕܐܝܬܝܗܝܢ ܒܤܒܪܐ ܐܝܟ ܗܘ ܕܗܘܝ ܠܗܝܢ ܒܤܘܥܪܢܐ ܘܓܠܝܢܐ ܕܐܝܠܝܢ ܕܠܐ ܡܬܚܙܝܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:hebrews.11.2",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 11:2",
      "text": "ܘܒܗܕܐ ܗܘܬ ܤܗܕܘܬܐ ܥܠ ܩܫܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.3",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 11:3",
      "text": "ܒܗܝܡܢܘܬܐ ܓܝܪ ܡܤܬܟܠܝܢܢ ܕܐܬܬܩܢܘ ܥܠܡܐ ܒܡܠܬܐ ܕܐܠܗܐ ܘܗܠܝܢ ܕܡܬܚܙܝܢ ܗܘܝ ܡܢ ܐܝܠܝܢ ܕܠܐ ܡܬܚܙܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.4",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 11:4",
      "text": "ܒܗܝܡܢܘܬܐ ܩܪܒ ܗܒܝܠ ܕܒܚܬܐ ܕܡܝܬܪܐ ܛܒ ܡܢ ܕܩܐܝܢ ܠܐܠܗܐ ܘܡܛܠܬܗ ܗܘܬ ܥܠܘܗܝ ܤܗܕܘܬܐ ܕܟܐܢܐ ܗܘ ܘܤܗܕ ܥܠ ܩܘܪܒܢܗ ܐܠܗܐ ܘܡܛܠܬܗ ܐܦ ܟܕ ܡܝܝܬ ܡܡܠܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.5",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 11:5",
      "text": "ܒܗܝܡܢܘܬܐ ܐܫܬܢܝ ܚܢܘܟ ܘܡܘܬܐ ܠܐ ܛܥܡ ܘܠܐ ܐܫܬܟܚ ܡܛܠ ܕܫܢܝܗ ܐܠܗܐ ܡܢ ܩܕܡ ܕܢܫܢܝܘܗܝ ܓܝܪ ܗܘܬ ܥܠܘܗܝ ܤܗܕܘܬܐ ܕܫܦܪ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.6",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 11:6",
      "text": "ܕܠܐ ܗܝܡܢܘܬܐ ܕܝܢ ܠܐ ܐܢܫ ܡܫܟܚ ܕܢܫܦܪ ܠܐܠܗܐ ܚܝܒ ܗܘ ܓܝܪ ܡܢ ܕܡܬܩܪܒ ܠܘܬ ܐܠܗܐ ܕܢܗܝܡܢ ܕܐܝܬܘܗܝ ܘܠܐܝܠܝܢ ܕܒܥܝܢ ܠܗ ܗܘܐ ܦܪܘܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.7",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 11:7",
      "text": "ܒܗܝܡܢܘܬܐ ܢܘܚ ܟܕ ܐܬܡܠܠ ܥܡܗ ܥܠ ܐܝܠܝܢ ܕܠܐ ܡܬܚܙܝܢ ܗܘܝ ܕܚܠ ܘܥܒܕ ܠܗ ܩܒܘܬܐ ܠܚܝܐ ܕܒܢܝ ܒܝܬܗ ܕܒܗ ܚܝܒܗ ܠܥܠܡܐ ܘܗܘܐ ܝܪܬܐ ܕܟܐܢܘܬܐ ܕܒܗܝܡܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.8",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 11:8",
      "text": "ܒܗܝܡܢܘܬܐ ܐܒܪܗܡ ܟܕ ܐܬܩܪܝ ܐܫܬܡܥ ܕܢܦܘܩ ܠܐܬܪܐ ܗܘ ܕܥܬܝܕ ܗܘܐ ܕܢܤܒ ܠܝܪܬܘܬܐ ܘܢܦܩ ܟܕ ܠܐ ܝܕܥ ܗܘܐ ܠܐܝܟܐ ܐܙܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.9",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 11:9",
      "text": "ܒܗܝܡܢܘܬܐ ܗܘܐ ܬܘܬܒܐ ܒܐܪܥܐ ܗܝ ܕܐܬܡܠܟܬ ܠܗ ܐܝܟ ܕܒܢܘܟܪܝܬܐ ܘܒܡܫܟܢܐ ܥܡܪ ܥܡ ܐܝܤܚܩ ܘܝܥܩܘܒ ܒܢܝ ܝܪܬܘܬܐ ܕܝܠܗ ܕܡܘܠܟܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.10",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 11:10",
      "text": "ܡܤܟܐ ܗܘܐ ܓܝܪ ܠܡܕܝܢܬܐ ܕܫܬܐܤܬܐ ܐܝܬ ܠܗ ܕܐܘܡܢܗ ܘܥܒܘܕܗ ܐܠܗܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.11",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 11:11",
      "text": "ܒܗܝܡܢܘܬܐ ܐܦ ܤܪܐ ܕܥܩܪܬܐ ܗܘܬ ܢܤܒܬ ܚܝܠܐ ܕܬܩܒܠ ܙܪܥܐ ܘܕܠܐ ܒܙܒܢܐ ܕܫܢܝܗ ܝܠܕܬ ܥܠ ܕܐܫܪܬ ܕܡܗܝܡܢ ܗܘ ܗܘ ܕܡܠܟ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.12",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 11:12",
      "text": "ܡܛܠ ܗܢܐ ܡܢ ܚܕ ܕܒܛܠ ܒܤܝܒܘܬܐ ܐܬܝܠܕܘ ܤܓܝܐܐ ܐܝܟ ܟܘܟܒܐ ܕܒܫܡܝܐ ܘܐܝܟ ܚܠܐ ܕܥܠ ܤܦܬܗ ܕܝܡܐ ܕܡܢܝܢ ܠܝܬ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.13",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 11:13",
      "text": "ܒܗܝܡܢܘܬܐ ܡܝܬܘ ܗܠܝܢ ܟܠܗܘܢ ܘܠܐ ܢܤܒܘ ܡܘܠܟܢܗܘܢ ܐܠܐ ܡܢ ܪܘܚܩܐ ܚܙܐܘܗܝ ܘܚܕܝܘ ܒܗ ܘܐܘܕܝܘ ܕܐܟܤܢܝܐ ܐܢܘܢ ܘܬܘܬܒܐ ܒܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.14",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 11:14",
      "text": "ܐܝܠܝܢ ܕܝܢ ܕܗܠܝܢ ܐܡܪܝܢ ܡܚܘܝܢ ܕܠܡܕܝܢܬܗܘܢ ܒܥܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.15",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 11:15",
      "text": "ܘܐܠܘ ܠܡܕܝܢܬܐ ܗܝ ܕܢܦܩܘ ܡܢܗ ܒܥܝܢ ܗܘܘ ܐܝܬ ܗܘܐ ܠܗܘܢ ܙܒܢܐ ܕܬܘܒ ܢܗܦܟܘܢ ܢܐܙܠܘܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.16",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 11:16",
      "text": "ܗܫܐ ܕܝܢ ܝܕܝܥܐ ܕܠܕܛܒܐ ܡܢܗ ܪܓܝܢ ܗܘܘ ܠܗܝ ܕܐܝܬܝܗ ܒܫܡܝܐ ܡܛܠ ܗܢܐ ܠܐ ܢܟܦ ܐܠܗܐ ܕܐܠܗܗܘܢ ܢܬܩܪܐ ܛܝܒ ܠܗܘܢ ܓܝܪ ܡܕܝܢܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.17",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 11:17",
      "text": "ܒܗܝܡܢܘܬܐ ܩܪܒ ܐܒܪܗܡ ܠܐܝܤܚܩ ܒܢܤܝܘܢܗ ܘܠܝܚܝܕܗ ܐܤܩ ܠܡܕܒܚܐ ܠܗܘ ܕܩܒܠ ܗܘܐ ܒܡܘܠܟܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.18",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 11:18",
      "text": "ܐܬܐܡܪ ܗܘܐ ܠܗ ܓܝܪ ܕܒܐܝܤܚܩ ܢܬܩܪܐ ܠܟ ܙܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.19",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 11:19",
      "text": "ܘܐܬܪܥܝ ܗܘܐ ܒܢܦܫܗ ܕܡܛܝܐ ܒܐܝܕܘܗܝ ܕܐܠܗܐ ܐܦ ܡܢ ܡܝܬܐ ܠܡܩܡܘ ܘܡܛܠ ܗܢܐ ܒܡܬܠܐ ܐܬܝܗܒ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.20",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Hebrews 11:20",
      "text": "ܒܗܝܡܢܘܬܐ ܕܡܕܡ ܕܥܬܝܕ ܗܘܐ ܒܪܟ ܐܝܤܚܩ ܠܝܥܩܘܒ ܘܠܥܤܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.21",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Hebrews 11:21",
      "text": "ܒܗܝܡܢܘܬܐ ܟܕ ܡܐܬ ܝܥܩܘܒ ܒܪܟ ܠܟܠ ܚܕ ܚܕ ܡܢ ܒܢܘܗܝ ܕܝܘܤܦ ܘܤܓܕ ܥܠ ܪܝܫ ܚܘܛܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.22",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Hebrews 11:22",
      "text": "ܒܗܝܡܢܘܬܐ ܝܘܤܦ ܟܕ ܡܐܬ ܥܗܕ ܠܡܦܩܬܐ ܕܒܢܝ ܐܝܤܪܝܠ ܘܦܩܕ ܥܠ ܓܪܡܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.23",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Hebrews 11:23",
      "text": "ܒܗܝܡܢܘܬܐ ܐܒܗܘܗܝ ܕܡܘܫܐ ܛܫܝܘܗܝ ܟܕ ܐܬܝܠܕ ܝܪܚܐ ܬܠܬܐ ܕܚܙܘ ܕܫܦܝܪ ܗܘܐ ܛܠܝܐ ܘܠܐ ܕܚܠܘ ܡܢ ܦܘܩܕܢܐ ܕܡܠܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.24",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Hebrews 11:24",
      "text": "ܒܗܝܡܢܘܬܐ ܡܘܫܐ ܟܕ ܗܘܐ ܓܒܪܐ ܟܦܪ ܕܠܐ ܢܬܩܪܐ ܒܪܐ ܠܒܪܬܗ ܕܦܪܥܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.25",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Hebrews 11:25",
      "text": "ܘܓܒܐ ܠܗ ܕܒܐܘܠܨܢܐ ܥܡ ܥܡܗ ܕܐܠܗܐ ܢܗܘܐ ܘܠܐ ܕܙܒܢ ܙܥܘܪ ܢܬܒܤܡ ܒܚܛܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.26",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Hebrews 11:26",
      "text": "ܘܐܬܪܥܝ ܕܡܝܬܪ ܗܘ ܥܘܬܪܐ ܕܚܤܕܗ ܕܡܫܝܚܐ ܛܒ ܡܢ ܤܝܡܬܗ ܕܡܨܪܝܢ ܚܐܪ ܗܘܐ ܓܝܪ ܒܦܘܪܥܢ ܐܓܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.27",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Hebrews 11:27",
      "text": "ܒܗܝܡܢܘܬܐ ܫܒܩܗ ܠܡܨܪܝܢ ܘܠܐ ܕܚܠ ܡܢ ܚܡܬܗ ܕܡܠܟܐ ܘܤܝܒܪ ܐܝܟ ܗܘ ܕܚܙܐ ܗܘܐ ܠܐܠܗܐ ܕܠܐ ܡܬܚܙܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.28",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "Hebrews 11:28",
      "text": "ܒܗܝܡܢܘܬܐ ܥܒܕ ܦܨܚܐ ܘܪܤܤ ܕܡܐ ܕܠܐ ܢܬܩܪܒ ܠܗܘܢ ܗܘ ܕܡܚܒܠ ܗܘܐ ܒܘܟܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.29",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "Hebrews 11:29",
      "text": "ܒܗܝܡܢܘܬܐ ܥܒܪܘ ܝܡܐ ܕܤܘܦ ܐܝܟ ܕܥܠ ܐܪܥܐ ܝܒܝܫܬܐ ܘܒܗ ܐܬܒܠܥܘ ܡܨܪܝܐ ܟܕ ܐܡܪܚܘ ܥܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.30",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "Hebrews 11:30",
      "text": "ܒܗܝܡܢܘܬܐ ܫܘܪܝܗ ܕܐܝܪܝܚܘ ܢܦܠܘ ܡܢ ܕܐܬܟܪܟܘ ܫܒܥܐ ܝܘܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.31",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "Hebrews 11:31",
      "text": "ܒܗܝܡܢܘܬܐ ܪܚܒ ܙܢܝܬܐ ܠܐ ܐܒܕܬ ܥܡ ܗܢܘܢ ܕܠܐ ܐܫܬܡܥܘ ܕܩܒܠܬ ܠܓܫܘܫܐ ܒܫܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.32",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 32,
      "referenceLabel": "Hebrews 11:32",
      "text": "ܘܡܢܐ ܬܘܒ ܐܡܪ ܙܥܘܪ ܗܘ ܠܝ ܓܝܪ ܙܒܢܐ ܕܐܫܬܥܐ ܥܠ ܓܕܥܘܢ ܘܥܠ ܒܪܩ ܘܥܠ ܫܡܫܘܢ ܘܥܠ ܢܦܬܚ ܘܥܠ ܕܘܝܕ ܘܥܠ ܫܡܘܐܝܠ ܘܥܠ ܫܪܟܐ ܕܢܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.11.33",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
