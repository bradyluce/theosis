{
  "chapter": {
    "id": "peshitta:hebrews.4",
    "translationId": "peshitta",
    "bookSlug": "hebrews",
    "chapterNumber": 4,
    "referenceLabel": "Hebrews 4",
    "summary": "Source text for Hebrews 4 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:hebrews.4.1",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 4:1",
      "text": "ܢܕܚܠ ܗܟܝܠ ܕܠܡܐ ܟܕ ܩܝܡ ܡܘܠܟܢܐ ܕܡܥܠܬܐ ܕܠܢܝܚܬܗ ܢܫܬܟܚ ܐܢܫ ܡܢܟܘܢ ܕܦܐܫ ܡܢ ܕܠܡܥܠ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:hebrews.4.2",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 4:2",
      "text": "ܐܦ ܚܢܢ ܓܝܪ ܐܤܬܒܪܢ ܐܝܟ ܕܐܦ ܗܢܘܢ ܐܠܐ ܠܐ ܐܘܬܪܬ ܐܢܘܢ ܠܗܢܘܢ ܡܠܬܐ ܕܫܡܥܘ ܡܛܠ ܕܠܐ ܡܡܙܓܐ ܗܘܬ ܒܗܝܡܢܘܬܐ ܠܗܢܘܢ ܕܫܡܥܘܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.4.3",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 4:3",
      "text": "ܥܐܠܝܢܢ ܕܝܢ ܠܢܝܚܬܐ ܚܢܢ ܐܝܠܝܢ ܕܗܝܡܢܢ ܐܝܟܢܐ ܕܝܢ ܐܡܪ ܐܝܟ ܕܝܡܝܬ ܒܪܘܓܙܝ ܕܠܐ ܢܥܠܘܢ ܠܢܝܚܬܝ ܕܗܐ ܥܒܕܘܗܝ ܕܐܠܗܐ ܡܢ ܫܘܪܝܗ ܕܥܠܡܐ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.4.4",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 4:4",
      "text": "ܐܝܟ ܕܐܡܪ ܥܠ ܫܒܬܐ ܕܐܬܢܝܚ ܐܠܗܐ ܒܝܘܡܐ ܫܒܝܥܝܐ ܡܢ ܥܒܕܘܗܝ ܟܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.4.5",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 4:5",
      "text": "ܘܗܪܟܐ ܬܘܒ ܐܡܪ ܕܠܐ ܢܥܠܘܢ ܠܢܝܚܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.4.6",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 4:6",
      "text": "ܡܛܠ ܗܟܝܠ ܕܐܝܬ ܗܘܐ ܐܬܪܐ ܕܐܢܫ ܐܢܫ ܢܥܘܠ ܠܗ ܘܗܢܘܢ ܕܐܤܬܒܪܘ ܩܕܡܝܐ ܠܐ ܥܠܘ ܒܕܠܐ ܐܬܛܦܝܤܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.4.7",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 4:7",
      "text": "ܬܘܒ ܝܘܡܐ ܐܚܪܢܐ ܤܐܡ ܡܢ ܒܬܪ ܙܒܢܐ ܤܓܝܐܐ ܐܝܟܢܐ ܕܡܢ ܠܥܠ ܟܬܝܒ ܕܐܡܪ ܕܘܝܕ ܕܝܘܡܢܐ ܐܢ ܒܩܠܗ ܬܫܡܥܘܢ ܠܐ ܬܩܫܘܢ ܠܒܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.4.8",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 4:8",
      "text": "ܐܠܘ ܓܝܪ ܝܫܘܥ ܒܪ ܢܘܢ ܐܢܝܚ ܗܘܐ ܐܢܘܢ ܠܐ ܐܡܪ ܗܘܐ ܡܢ ܒܬܪܟܢ ܥܠ ܝܘܡܐ ܐܚܪܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.4.9",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 4:9",
      "text": "ܡܕܝܢ ܩܝܡ ܗܘ ܠܡܫܒܬܘ ܠܥܡܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.4.10",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 4:10",
      "text": "ܐܝܢܐ ܓܝܪ ܕܥܠ ܠܢܝܚܬܗ ܐܬܬܢܝܚ ܐܦ ܗܘ ܡܢ ܥܒܕܘܗܝ ܐܝܟ ܕܐܠܗܐ ܡܢ ܕܝܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.4.11",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 4:11",
      "text": "ܢܬܚܦܛ ܗܟܝܠ ܕܢܥܘܠ ܠܗܝ ܢܝܚܬܐ ܕܠܐ ܢܦܠ ܒܕܡܘܬܐ ܕܗܢܘܢ ܕܠܐ ܐܬܛܦܝܤܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.4.12",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 4:12",
      "text": "ܚܝܐ ܗܝ ܓܝܪ ܡܠܬܗ ܕܐܠܗܐ ܘܟܠ ܤܥܪܐ ܘܚܪܝܦܐ ܛܒ ܡܢ ܤܦܤܪܐ ܕܬܪܝܢ ܦܘܡܝܗ ܘܥܐܠܐ ܥܕܡܐ ܠܦܘܪܫܢܐ ܕܢܦܫܐ ܘܕܪܘܚܐ ܘܕܫܪܝܬܐ ܘܕܡܘܚܐ ܘܕܓܪܡܐ ܘܕܝܢܐ ܡܚܫܒܬܐ ܘܬܪܥܝܬܐ ܕܠܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.4.13",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 4:13",
      "text": "ܘܠܝܬ ܒܪܝܬܐ ܕܛܫܝܐ ܡܢ ܩܕܡܝܗ ܐܠܐ ܟܠ ܡܕܡ ܥܪܛܠ ܘܓܠܐ ܩܕܡ ܥܝܢܘܗܝ ܕܠܗ ܝܗܒܝܢܢ ܦܬܓܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.4.14",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 4:14",
      "text": "ܡܛܠ ܕܐܝܬ ܠܢ ܗܟܝܠ ܪܒ ܟܘܡܪܐ ܪܒܐ ܝܫܘܥ ܡܫܝܚܐ ܒܪܗ ܕܐܠܗܐ ܕܤܠܩ ܠܫܡܝܐ ܢܚܡܤܢ ܒܬܘܕܝܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.4.15",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 4:15",
      "text": "ܠܐ ܓܝܪ ܐܝܬ ܠܢ ܪܒܟܘܡܪܐ ܕܠܐ ܡܨܐ ܕܢܚܫ ܥܡ ܟܪܝܗܘܬܢ ܐܠܐ ܕܡܢܤܝ ܒܟܠܡܕܡ ܐܟܘܬܢ ܤܛܪ ܡܢ ܚܛܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.4.16",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 4:16",
      "text": "ܢܬܩܪܒ ܗܟܝܠ ܒܓܠܐ ܥܝܢ ܠܟܘܪܤܝܐ ܕܛܝܒܘܬܗ ܕܢܤܒ ܪܚܡܐ ܘܢܫܟܚ ܛܝܒܘܬܐ ܠܥܘܕܪܢܐ ܒܙܒܢܐ ܕܐܘܠܨܢܐ ܀",
      "paragraphStart": false
    }
  ]
}
