{
  "chapter": {
    "id": "peshitta:hebrews.9",
    "translationId": "peshitta",
    "bookSlug": "hebrews",
    "chapterNumber": 9,
    "referenceLabel": "Hebrews 9",
    "summary": "Source text for Hebrews 9 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:hebrews.9.1",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 9:1",
      "text": "ܒܩܕܡܝܬܐ ܕܝܢ ܐܝܬ ܗܘܐ ܒܗ ܦܘܩܕܐ ܕܬܫܡܫܬܐ ܘܒܝܬ ܩܘܕܫܐ ܥܠܡܢܝܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:hebrews.9.2",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 9:2",
      "text": "ܡܫܟܢܐ ܓܝܪ ܩܕܡܝܐ ܕܐܬܥܒܕ ܐܝܬ ܗܘܐ ܒܗ ܡܢܪܬܐ ܘܦܬܘܪܐ ܘܠܚV ܐܦܐ ܘܡܬܩܪܐ ܗܘܐ ܒܝܬ ܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.3",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 9:3",
      "text": "ܡܫܟܢܐ ܕܝܢ ܓܘܝܐ ܕܠܓܘ ܡܢ ܐܦܝ ܬܪܥܐ ܕܬܪܝܢ ܡܬܩܪܐ ܗܘܐ ܩܕܘܫ ܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.4",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 9:4",
      "text": "ܘܐܝܬ ܗܘܐ ܒܗ ܒܝܬ ܒܤܡܐ ܕܕܗܒܐ ܘܩܒܘܬܐ ܕܕܝܬܩܐ ܕܩܪܝܡܐ ܟܠܗ ܒܕܗܒܐ ܘܐܝܬ ܒܗ ܩܤܛܐ ܕܕܗܒܐ ܗܝ ܕܐܝܬ ܗܘܐ ܒܗ ܡܢܢܐ ܘܫܒܛܐ ܕܐܗܪܘܢ ܗܘ ܕܐܦܪܥ ܘܠܘܚܐ ܕܕܝܬܩܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.5",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 9:5",
      "text": "ܘܠܥܠ ܡܢܗ ܟܪܘܒܐ ܕܫܘܒܚܐ ܕܡܛܠܝܢ ܥܠ ܚܘܤܝܐ ܠܐ ܗܘܐ ܕܝܢ ܙܒܢܐ ܗܘ ܕܢܐܡܪ ܥܠ ܚܕܐ ܚܕܐ ܡܢ ܗܠܝܢ ܕܗܟܢܐ ܡܬܩܢܢ ܗܘܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.6",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 9:6",
      "text": "ܘܠܡܫܟܢܐ ܒܪܝܐ ܒܟܠܙܒܢ ܥܐܠܝܢ ܗܘܘ ܟܘܡܪܐ ܘܡܫܠܡܝܢ ܗܘܘ ܬܫܡܫܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.7",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 9:7",
      "text": "ܠܡܫܟܢܐ ܕܝܢ ܕܠܓܘ ܡܢܗ ܚܕܐ ܗܘ ܒܫܢܬܐ ܒܠܚܘܕܘܗܝ ܥܐܠ ܗܘܐ ܪܒܟܘܡܪܐ ܒܕܡܐ ܗܘ ܕܡܩܪܒ ܗܘܐ ܚܠܦ ܢܦܫܗ ܘܚܠܦ ܤܟܠܘܬܗ ܕܥܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.8",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 9:8",
      "text": "ܒܗܕܐ ܕܝܢ ܡܘܕܥܐ ܗܘܬ ܪܘܚܐ ܕܩܘܕܫܐ ܕܠܐ ܐܬܓܠܝܬ ܥܕܟܝܠ ܐܘܪܚܐ ܕܩܕܝܫܐ ܟܡܐ ܙܒܢܐ ܕܐܝܬ ܗܘܐ ܩܝܡܐ ܠܡܫܟܢܐ ܩܕܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.9",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 9:9",
      "text": "ܘܐܝܬܘܗܝ ܗܘܐ ܡܬܠܐ ܗܢܐ ܠܙܒܢܐ ܗܘ ܕܒܗ ܩܘܪܒܢܐ ܘܕܒܚܐ ܡܬܩܪܒܝܢ ܗܘܘ ܐܝܠܝܢ ܕܠܐ ܡܫܟܚܝܢ ܗܘܘ ܠܡܓܡܪ ܬܐܪܬܗ ܕܡܢ ܕܡܩܪܒ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.10",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 9:10",
      "text": "ܐܠܐ ܒܡܐܟܠܐ ܘܒܡܫܬܝܐ ܒܠܚܘܕ ܘܒܡܥܡܘܕܝܬܐ ܕܙܢܝܢ ܙܢܝܢ ܕܐܝܬܝܗܝܢ ܦܘܩܕܐ ܕܒܤܪܐ ܕܤܝܡܝܢ ܥܕܡܐ ܠܙܒܢܐ ܕܬܘܪܨܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.11",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 9:11",
      "text": "ܡܫܝܚܐ ܕܝܢ ܕܐܬܐ ܗܘܐ ܪܒܟܘܡܪܐ ܕܛܒܬܐ ܕܤܥܪ ܘܥܠ ܠܡܫܟܢܐ ܪܒܐ ܘܡܫܠܡܢܐ ܕܠܐ ܥܒܝܕ ܒܐܝܕܝܐ ܘܠܐ ܗܘܐ ܡܢ ܗܠܝܢ ܒܪܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.12",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 9:12",
      "text": "ܘܠܐ ܥܠ ܒܕܡܐ ܕܨܦܪܝܐ ܘܕܥܓܠܐ ܐܠܐ ܒܕܡܐ ܕܢܦܫܗ ܥܠ ܚܕܐ ܙܒܢ ܠܒܝܬ ܡܩܕܫܐ ܘܐܫܟܚ ܦܘܪܩܢܐ ܕܠܥܠV ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.13",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 9:13",
      "text": "ܐܢ ܓܝܪ ܕܡܐ ܕܨܦܪܝܐ ܘܕܥܓܠܐ ܘܩܛܡܐ ܕܥܓܠܬܐ ܡܬܪܤܤ ܗܘܐ ܥܠ ܐܝܠܝܢ ܕܡܬܛܡܐܝܢ ܗܘܘ ܘܡܩܕܫ ܠܗܘܢ ܠܕܘܟܝܐ ܕܒܤܪܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.14",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 9:14",
      "text": "ܟܡܐ ܗܟܝܠ ܝܬܝܪܐܝܬ ܕܡܗ ܕܡܫܝܚܐ ܕܒܪܘܚܐ ܕܠܥܠV ܢܦܫܗ ܩܪܒ ܕܠܐ ܡܘV ܠܐܠܗܐ ܢܕܟܐ ܬܐܪܬܢ ܡܢ ܥܒܕܐ ܡܝܬܐ ܕܢܫܡܫ ܠܐܠܗܐ ܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.15",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 9:15",
      "text": "ܡܛܠ ܗܢܐ ܗܘ ܗܘܐ ܡܨܥܝܐ ܕܕܝܬܩܐ ܚܕܬܐ ܕܒܡܘܬܗ ܗܘ ܗܘܐ ܦܘܪܩܢܐ ܠܐܝܠܝܢ ܕܥܒܪܘ ܥܠ ܕܝܬܩܐ ܩܕܡܝܬܐ ܕܢܤܒܘܢ ܡܘܠܟܢܐ ܐܝܠܝܢ ܕܐܬܩܪܝܘ ܠܝܪܬܘܬܐ ܕܠܥܠV ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.16",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 9:16",
      "text": "ܐܝܟܐ ܓܝܪ ܕܐܝܬ ܕܝܬܩܐ ܡܘܬܐ ܗܘ ܡܚܘܝܐ ܕܗܘ ܕܥܒܕܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.17",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 9:17",
      "text": "ܥܠ ܡܝܬܐ ܕܝܢ ܒܠܚܘܕ ܡܫܬܪܪܐ ܡܛܠ ܕܟܡܐ ܕܚܝ ܗܘ ܕܥܒܕܗ ܠܝܬ ܒܗ ܚܫܚܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.18",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 9:18",
      "text": "ܡܛܠ ܗܢܐ ܐܦܠܐ ܩܕܡܝܬܐ ܕܠܐ ܕܡܐ ܐܫܬܪܪܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.19",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 9:19",
      "text": "ܟܕ ܐܬܦܩܕ ܓܝܪ ܟܠܗ ܦܘܩܕܢܐ ܡܢ ܡܘܫܐ ܠܥܡܐ ܟܠܗ ܒܢܡܘܤܐ ܢܤܒ ܗܘܐ ܡܘܫܐ ܕܡܐ ܕܥܓܠܬܐ ܘܡܝܐ ܒܥܡܪܐ ܕܙܚܘܪܝܬܐ ܘܙܘܦܐ ܘܪܤ ܥܠ ܤܦܪܐ ܘܥܠ ܥܡܐ ܟܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.20",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Hebrews 9:20",
      "text": "ܘܐܡܪ ܠܗܘܢ ܗܢܐ ܗܘ ܕܡܐ ܕܕܝܬܩܐ ܗܝ ܕܐܬܦܩܕܬ ܠܟܘܢ ܡܢ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.21",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Hebrews 9:21",
      "text": "ܐܦ ܥܠ ܡܫܟܢܐ ܘܥܠ ܟܠܗܘܢ ܡܐܢܐ ܕܬܫܡܫܬܐ ܡܢܗ ܡܢ ܕܡܐ ܪܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.22",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "Hebrews 9:22",
      "text": "ܡܛܠ ܕܟܠܡܕV ܒܕܡܐ ܗܘ ܡܬܕܟܐ ܒܢܡܘܤܐ ܘܕܠܐ ܫܘܦܥ ܕܡܐ ܠܝܬ ܫܘܒܩܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.23",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "Hebrews 9:23",
      "text": "ܐܢܢܩܐ ܗܝ ܓܝܪ ܕܗܠܝܢ ܕܕܡܘܬܐ ܐܢܝܢ ܕܫܡܝܢܝܬܐ ܒܗܠܝܢ ܡܬܕܟܝܢ ܗܠܝܢ ܕܝܢ ܫܡܝܢܝܬܐ ܒܕܒܚܐ ܕܡܝܬܪܝܢ ܡܢ ܗܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.24",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "Hebrews 9:24",
      "text": "ܠܐ ܗܘܐ ܓܝܪ ܠܒܝܬ ܡܩܕܫܐ ܕܥܒܝܕ ܒܐܝܕܝܐ ܥܠ ܡܫܝܚܐ ܕܐܝܬܘܗܝ ܕܡܘܬܐ ܕܗܘ ܫܪܝܪܐ ܐܠܐ ܠܗ ܠܫܡܝܐ ܥܠ ܕܢܬܚܙܐ ܩܕV ܦܪܨܘܦܗ ܕܐܠܗܐ ܚܠܦܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.25",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "Hebrews 9:25",
      "text": "ܐܦܠܐ ܕܢܩܪܒ ܢܦܫܗ ܙܒܢܬܐ ܤܓܝܐܬܐ ܐܝܟ ܕܥܒܕ ܗܘܐ ܪܒ ܟܘܡܪܐ ܘܥܐܠ ܒܟܠ ܫܢܐ ܠܒܝܬ ܡܩܕܫܐ ܒܕܡܐ ܕܠܐ ܕܝܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.26",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "Hebrews 9:26",
      "text": "ܘܐܢ ܠܐ ܚܝܒ ܗܘܐ ܕܙܒܢܬܐ ܤܓܝܐܬܐ ܢܚܫ ܡܢ ܫܘܪܝܗ ܕܥܠܡܐ ܗܫܐ ܕܝܢ ܒܚܪܬܗ ܕܥܠܡܐ ܚܕܐ ܗܘ ܙܒܢ ܩܪܒ ܢܦܫܗ ܒܕܒܝܚܘܬܗ ܕܢܒܛܠܝܗ ܠܚܛܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.27",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "Hebrews 9:27",
      "text": "ܘܐܝܟܢܐ ܕܤܝV ܠܒܢܝܢܫܐ ܕܚܕܐ ܙܒܢ ܢܡܘܬܘܢ ܘܡܢ ܒܬܪ ܡܘܬܗܘܢ ܕܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:hebrews.9.28",
      "translationId": "peshitta",
      "bookSlug": "hebrews",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "Hebrews 9:28",
      "text": "ܗܟܢܐ ܐܦ ܡܫܝܚܐ ܚܕܐ ܙܒܢ ܐܬܩܪܒ ܘܒܩܢܘܡܗ ܕܒܚ ܚܛܗܐ ܕܤܓܝܐܐ ܕܬܪܬܝܢ ܕܝܢ ܙܒܢܝܢ ܕܠܐ ܚܛܗܝܢ ܡܬܚܙܐ ܠܚܝܝܗܘܢ ܕܐܝܠܝܢ ܕܡܤܟܝܢ ܠܗ ܀",
      "paragraphStart": false
    }
  ]
}
