{
  "chapter": {
    "id": "peshitta:philemon.1",
    "translationId": "peshitta",
    "bookSlug": "philemon",
    "chapterNumber": 1,
    "referenceLabel": "Philemon 1",
    "summary": "Source text for Philemon 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:philemon.1.1",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Philemon 1:1",
      "text": "ܦܘܠܘܤ ܐܤܝܪܗ ܕܝܫܘܥ ܡܫܝܚܐ ܘܛܝܡܬܐܘܤ ܐܚܐ ܠܦܝܠܡܘܢ ܚܒܝܒܐ ܘܦܠܚܐ ܕܥܡܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:philemon.1.2",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Philemon 1:2",
      "text": "ܘܠܐܦܝܐ ܚܒܝܒܬܢ ܘܠܐܪܟܝܦܘܤ ܦܠܚܐ ܕܥܡܢ ܘܠܥܕܬܐ ܕܒܒܝܬܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.3",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Philemon 1:3",
      "text": "ܛܝܒܘܬܐ ܥܡܟܘܢ ܘܫܠܡܐ ܡܢ ܐܠܗܐ ܐܒܘܢ ܘܡܢ ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.4",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Philemon 1:4",
      "text": "ܡܘܕܐ ܐܢܐ ܠܐܠܗܝ ܒܟܠܙܒܢ ܘܡܬܕܟܪ ܐܢܐ ܠܟ ܒܨܠܘܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.5",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Philemon 1:5",
      "text": "ܗܐ ܡܢ ܕܫܡܥܬ ܗܝܡܢܘܬܟ ܘܚܘܒܐ ܕܐܝܬ ܠܟ ܠܘܬ ܡܪܢ ܝܫܘܥ ܘܠܘܬ ܟܠܗܘܢ ܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.6",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Philemon 1:6",
      "text": "ܕܬܗܘܐ ܫܘܬܦܘܬܐ ܕܗܝܡܢܘܬܟ ܝܗܒܐ ܦܐܪܐ ܒܥܒܕܐ ܘܒܝܕܥܬܐ ܕܟܠ ܛܒܢ ܕܐܝܬ ܠܟܘܢ ܒܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.7",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Philemon 1:7",
      "text": "ܚܕܘܬܐ ܓܝܪ ܤܓܝܐܬܐ ܐܝܬ ܠܢ ܘܒܘܝܐܐ ܕܒܝܕ ܚܘܒܟ ܐܬܬܢܝܚܘ ܪܚܡܐ ܕܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.8",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Philemon 1:8",
      "text": "ܡܛܠ ܗܕܐ ܦܪܗܤܝܐ ܤܓܝܐܬܐ ܐܝܬ ܠܝ ܒܡܫܝܚܐ ܕܐܦܩܘܕ ܠܟ ܐܝܠܝܢ ܕܙܕܩܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.9",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Philemon 1:9",
      "text": "ܡܛܠ ܚܘܒܐ ܕܝܢ ܡܒܥܐ ܗܘ ܒܥܐ ܐܢܐ ܡܢܟ ܐܢܐ ܦܘܠܘܤ ܕܐܝܬܝ ܤܒܐ ܐܝܟ ܕܝܕܥ ܐܢܬ ܗܫܐ ܕܝܢ ܐܦ ܐܤܝܪܐ ܕܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.10",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Philemon 1:10",
      "text": "ܘܒܥܐ ܐܢܐ ܡܢܟ ܥܠ ܒܪܝ ܐܝܢܐ ܕܝܠܕܬ ܒܐܤܘܪܝ ܐܢܤܝܡܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.11",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Philemon 1:11",
      "text": "ܗܘ ܕܒܙܒܢ ܠܝܬ ܗܘܐ ܠܟ ܒܗ ܚܫܚܘ ܗܫܐ ܕܝܢ ܐܦ ܠܟ ܐܦ ܠܝ ܛܒ ܚܫܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.12",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Philemon 1:12",
      "text": "ܘܫܕܪܬܗ ܠܟ ܐܢܬ ܕܝܢ ܐܝܟ ܕܠܝܠܕܐ ܕܝܠܝ ܗܟܢܐ ܩܒܠܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.13",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Philemon 1:13",
      "text": "ܨܒܐ ܗܘܝܬ ܓܝܪ ܕܠܘܬܝ ܐܚܕܝܘܗܝ ܕܢܗܘܐ ܡܫܡܫ ܠܝ ܚܠܦܝܟ ܒܐܤܘܪܐ ܕܐܘܢܓܠܝܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.14",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Philemon 1:14",
      "text": "ܒܠܥܕ ܡܠܟܟ ܕܝܢ ܠܐ ܨܒܝܬ ܡܕܡ ܠܡܥܒܕ ܕܠܐ ܐܝܟ ܕܒܩܛܝܪܐ ܬܗܘܐ ܛܒܬܟ ܐܠܐ ܒܨܒܝܢܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.15",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Philemon 1:15",
      "text": "ܟܒܪ ܕܝܢ ܐܦ ܡܛܠ ܗܕܐ ܫܢܝ ܕܫܥܬܐ ܕܠܥܠܡ ܬܐܚܕܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.16",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Philemon 1:16",
      "text": "ܠܐ ܡܟܝܠ ܐܝܟ ܥܒܕܐ ܐܠܐ ܝܬܝܪ ܡܢ ܥܒܕܐ ܐܚܐ ܚܒܝܒܐ ܕܝܠܝ ܚܕ ܟܡܐ ܕܝܠܟ ܘܒܒܤܪ ܘܒܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.17",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Philemon 1:17",
      "text": "ܐܢ ܗܟܝܠ ܐܝܬܝܟ ܠܝ ܫܘܬܦܐ ܩܒܠܝܗܝ ܐܝܟ ܕܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.18",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Philemon 1:18",
      "text": "ܘܐܢ ܡܕܡ ܚܤܪܟ ܐܘ ܚܝܒ ܗܕܐ ܥܠܝ ܚܫܘܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.19",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Philemon 1:19",
      "text": "ܐܢܐ ܦܘܠܘܤ ܟܬܒܬ ܒܐܝܕܝ ܐܢܐ ܦܪܥ ܐܢܐ ܕܠܐ ܐܡܪ ܠܟ ܕܐܦ ܢܦܫܟ ܚܝܒ ܐܢܬ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.20",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Philemon 1:20",
      "text": "ܐܝܢ ܐܚܝ ܐܢܐ ܐܬܬܢܝܚ ܒܟ ܒܡܪܢ ܐܢܝܚ ܪܚܡܝ ܒܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.21",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Philemon 1:21",
      "text": "ܡܛܠ ܕܬܟܝܠ ܐܢܐ ܕܫܡܥ ܐܢܬ ܠܝ ܟܬܒܬ ܠܟ ܘܝܕܥ ܐܢܐ ܕܝܬܝܪ ܡܢ ܡܐ ܕܐܡܪ ܐܢܐ ܥܒܕ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.22",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Philemon 1:22",
      "text": "ܒܚܕܐ ܕܝܢ ܐܦ ܛܝܒ ܠܝ ܒܝܬ ܡܫܪܝܐ ܡܤܒܪ ܐܢܐ ܓܝܪ ܕܒܨܠܘܬܟܘܢ ܡܬܝܗܒ ܐܢܐ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.23",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Philemon 1:23",
      "text": "ܫܐܠ ܒܫܠܡܟ ܐܦܦܪܐ ܫܒܝܐ ܕܥܡܝ ܒܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.24",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Philemon 1:24",
      "text": "ܘܡܪܩܘܤ ܘܐܪܤܛܪܟܘܤ ܘܕܡܐ ܘܠܘܩܐ ܡܥܕܪܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philemon.1.25",
      "translationId": "peshitta",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Philemon 1:25",
      "text": "ܛܝܒܘܬܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܥܡ ܪܘܚܟܘܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
