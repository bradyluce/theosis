      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 10:1",
      "text": "ܐܢܐ ܕܝܢ ܦܘܠܘܤ ܒܥܐ ܐܢܐ ܡܢܟܘܢ ܒܢܝܚܘܬܗ ܘܒܡܟܝܟܘܬܗ ܕܡܫܝܚܐ ܕܐܦܢ ܒܐܦܝܢ ܡܟܝܟ ܐܢܐ ܠܘܬܟܘܢ ܐܠܐ ܟܕ ܪܚܝܩ ܐܢܐ ܬܟܝܠ ܐܢܐ ܥܠܝܟܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-corinthians.10.2",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 10:2",
      "text": "ܒܥܐ ܐܢܐ ܕܝܢ ܡܢܟܘܢ ܕܠܐ ܡܐ ܕܐܬܝܬ ܐܬܐܠܨ ܒܬܘܟܠܢܐ ܕܐܝܬ ܠܝ ܕܐܫܝܚ ܐܝܟ ܕܡܬܪܥܐ ܐܢܐ ܥܠ ܐܢܫܐ ܐܝܠܝܢ ܕܚܫܒܝܢ ܠܢ ܕܐܝܟ ܕܒܒܤܪ ܡܗܠܟܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.10.3",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 10:3",
      "text": "ܐܦܢ ܒܒܤܪ ܓܝܪ ܡܗܠܟܝܢ ܚܢܢ ܐܠܐ ܠܐ ܗܘܐ ܕܒܤܪܐ ܦܠܚܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.10.4",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 10:4",
      "text": "ܙܝܢܐ ܓܝܪ ܕܦܠܚܘܬܢ ܠܐ ܗܘܐ ܕܒܤܪܐ ܐܠܐ ܕܚܝܠܐ ܕܐܠܗܐ ܘܒܗ ܟܒܫܝܢܢ ܚܤܢܐ ܡܪܝܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.10.5",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 10:5",
      "text": "ܘܤܬܪܝܢܢ ܡܚܫܒܬܐ ܘܟܠ ܪܘܡܐ ܕܡܬܬܪܝܡ ܠܘܩܒܠ ܝܕܥܬܗ ܕܐܠܗܐ ܘܫܒܝܢܢ ܟܠ ܬܪܥܝܢ ܠܡܫܡܥܬܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.10.6",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 10:6",
      "text": "ܘܡܛܝܒܝܢܢ ܠܡܥܒܕ ܬܒܥܬܐ ܡܢ ܐܝܠܝܢ ܕܠܐ ܡܫܬܡܥܝܢ ܡܐ ܕܐܬܡܠܝܬ ܡܫܬܡܥܢܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.10.7",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 10:7",
      "text": "ܒܦܪܨܘܦܐ ܚܝܪܝܢ ܐܢܬܘܢ ܐܢ ܐܢܫ ܬܟܝܠ ܥܠ ܢܦܫܗ ܕܕܡܫܝܚܐ ܗܘ ܗܢܐ ܢܕܥ ܡܢ ܢܦܫܗ ܕܐܝܟ ܕܗܘ ܕܡܫܝܚܐ ܗܟܢܐ ܐܦ ܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.10.8",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 10:8",
      "text": "ܐܢ ܓܝܪ ܐܦ ܡܕܡ ܝܬܝܪ ܐܫܬܒܗܪ ܥܠ ܫܘܠܛܢܐ ܕܝܗܒ ܠܝ ܡܪܢ ܠܐ ܒܗܬ ܐܢܐ ܡܛܠ ܕܠܒܢܝܢܐ ܗܘ ܕܝܠܟܘܢ ܝܗܒ ܠܢ ܘܠܐ ܠܤܘܚܦܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.10.9",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 10:9",
      "text": "ܡܗܡܐ ܐܢܐ ܕܝܢ ܕܠܐ ܐܤܬܒܪ ܐܝܟ ܗܘ ܕܡܕܚܠܘ ܡܕܚܠ ܐܢܐ ܠܟܘܢ ܒܐܓܪܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.10.10",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 10:10",
      "text": "ܡܛܠ ܕܐܝܬ ܐܢܫܐ ܕܐܡܪܝܢ ܕܐܓܪܬܐ ܝܩܝܪܢ ܘܚܤܝܢܢ ܡܐܬܝܗ ܕܝܢ ܕܓܘܫܡܐ ܟܪܝܗ ܘܡܠܬܗ ܫܝܛܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.10.11",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 10:11",
      "text": "ܐܠܐ ܗܕܐ ܢܬܪܥܐ ܡܢ ܕܗܟܢܐ ܐܡܪ ܕܐܝܟܢܐ ܕܐܝܬܝܢ ܒܡܠܬܐ ܕܐܓܪܬܢ ܟܕ ܪܚܝܩܝܢܢ ܗܟܢܐ ܐܝܬܝܢ ܐܦ ܡܐ ܕܩܪܝܒܝܢܢ ܒܥܒܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.10.12",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 10:12",
      "text": "ܠܐ ܓܝܪ ܡܡܪܚܝܢܢ ܕܢܚܫܘܒ ܐܘ ܕܢܦܚܡ ܢܦܫܢ ܥܡ ܗܢܘܢ ܕܡܫܒܗܪܝܢ ܢܦܫܗܘܢ ܐܠܐ ܡܛܠ ܕܗܢܘܢ ܒܗܘܢ ܠܗܘܢ ܡܦܚܡܝܢ ܠܐ ܡܤܬܟܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.10.13",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 10:13",
      "text": "ܚܢܢ ܕܝܢ ܠܐ ܡܫܬܒܗܪܝܢܢ ܝܬܝܪ ܡܢ ܡܫܘܚܬܢ ܐܠܐ ܒܡܫܘܚܬܐ ܕܬܚܘܡܐ ܕܦܠܓ ܠܢ ܐܠܗܐ ܕܢܡܛܐ ܐܦ ܥܕܡܐ ܠܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.10.14",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 10:14",
      "text": "ܠܐ ܗܘܐ ܓܝܪ ܐܝܟ ܕܠܐ ܡܬܡܛܝܢܢ ܠܘܬܟܘܢ ܡܬܚܝܢܢ ܢܦܫܢ ܥܕܡܐ ܓܝܪ ܠܘܬܟܘܢ ܡܛܝܢ ܒܤܒܪܬܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.10.15",
