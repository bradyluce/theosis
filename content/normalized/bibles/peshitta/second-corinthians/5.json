  "verses": [
    {
      "id": "peshitta:second-corinthians.5.1",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 5:1",
      "text": "ܝܕܥܝܢܢ ܓܝܪ ܕܐܢ ܒܝܬܢ ܕܒܐܪܥܐ ܗܢܐ ܕܦܓܪܐ ܢܫܬܪܐ ܐܠܐ ܐܝܬ ܠܢ ܒܢܝܢܐ ܕܡܢ ܐܠܗܐ ܒܝܬܐ ܕܠܐ ܒܥܒܕ ܐܝܕܝܐ ܒܫܡܝܐ ܠܥܠܡ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-corinthians.5.2",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 5:2",
      "text": "ܐܦ ܥܠ ܗܕܐ ܓܝܪ ܡܬܬܢܚܝܢܢ ܘܤܘܝܢܢ ܕܢܠܒܫ ܒܝܬܢ ܕܡܢ ܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.5.3",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 5:3",
      "text": "ܐܠܐ ܐܦ ܡܐ ܕܠܒܫܢ ܢܫܬܟܚ ܠܢ ܥܪܛܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.5.4",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 5:4",
      "text": "ܟܕ ܐܝܬܝܢ ܓܝܪ ܗܫܐ ܒܗܢܐ ܒܝܬܐ ܡܬܬܢܚܝܢܢ ܡܢ ܝܘܩܪܗ ܘܠܐ ܨܒܝܢܢ ܠܡܫܠܚܗ ܐܠܐ ܕܢܠܒܫ ܠܥܠ ܡܢܗ ܕܬܬܒܠܥ ܡܝܬܘܬܗ ܒܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.5.5",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 5:5",
      "text": "ܘܕܡܥܬܕ ܠܢ ܠܗ ܠܗܕܐ ܐܠܗܐ ܗܘ ܗܘ ܕܝܗܒ ܠܢ ܪܗܒܘܢܐ ܕܪܘܚܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.5.6",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 5:6",
      "text": "ܡܛܠ ܕܝܕܥܝܢܢ ܗܟܝܠ ܘܡܦܤܝܢܢ ܕܟܡܐ ܕܒܦܓܪܐ ܫܪܝܢܢ ܥܢܝܕܝܢܢ ܡܢ ܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.5.7",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 5:7",
      "text": "ܒܗܝܡܢܘܬܐ ܗܘ ܓܝܪ ܡܗܠܟܝܢܢ ܘܠܐ ܒܚܙܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.5.8",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 5:8",
      "text": "ܡܛܠ ܗܢܐ ܬܟܝܠܝܢܢ ܘܡܤܘܚܝܢܢ ܕܢܥܢܕ ܡܢ ܦܓܪܐ ܘܢܗܘܐ ܠܘܬ ܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.5.9",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 5:9",
      "text": "ܘܡܬܚܦܛܝܢܢ ܕܐܢ ܥܢܘܕܐ ܚܢܢ ܘܐܢ ܥܡܘܪܐ ܠܗ ܗܘܝܢ ܫܦܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.5.10",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 5:10",
      "text": "ܟܠܢ ܓܝܪ ܥܬܝܕܝܢܢ ܠܡܩܡ ܩܕܡ ܒܝܡ ܕܡܫܝܚܐ ܕܢܬܦܪܥ ܐܢܫ ܐܢܫ ܒܦܓܪܗ ܡܕܡ ܕܥܒܝܕ ܠܗ ܐܢ ܕܛܒ ܘܐܢ ܕܒܝܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.5.11",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 5:11",
      "text": "ܡܛܠ ܕܝܕܥܝܢܢ ܗܟܝܠ ܕܚܠܬܗ ܕܡܪܢ ܠܒܢܝܢܫܐ ܗܘ ܡܦܝܤܝܢܢ ܠܐܠܗܐ ܕܝܢ ܓܠܝܢܢ ܤܒܪ ܐܢܐ ܕܝܢ ܕܐܦ ܠܡܕܥܝܟܘܢ ܕܝܠܟܘܢ ܓܠܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.5.12",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 5:12",
      "text": "ܠܐ ܗܘܐ ܬܘܒ ܢܦܫܢ ܡܫܒܚܝܢܢ ܠܟܘܢ ܐܠܐ ܥܠܬܐ ܗܘ ܝܗܒܝܢܢ ܠܟܘܢ ܕܗܘܝܬܘܢ ܡܫܬܒܗܪܝܢ ܒܢ ܠܘܬ ܗܢܘܢ ܕܒܐܦܐ ܗܘ ܡܫܬܒܗܪܝܢ ܘܠܐ ܒܠܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.5.13",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 5:13",
      "text": "ܐܢ ܓܝܪ ܫܛܝܢܢ ܠܐܠܗܐ ܘܐܢ ܬܩܢܝܢܢ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.5.14",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 5:14",
      "text": "ܚܘܒܗ ܓܝܪ ܕܡܫܝܚܐ ܐܠܨ ܠܢ ܕܪܢܝܢܢ ܗܕܐ ܕܚܕ ܚܠܦ ܟܠܢܫ ܡܝܬ ܡܕܝܢ ܟܠܢܫ ܡܝܬ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.5.15",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 5:15",
      "text": "ܘܚܠܦ ܟܠܢܫ ܗܘ ܡܝܬ ܕܐܝܠܝܢ ܕܚܝܝܢ ܠܐ ܠܢܦܫܗܘܢ ܢܚܘܢ ܐܠܐ ܠܗܘ ܐܝܢܐ ܕܥܠ ܐܦܝܗܘܢ ܡܝܬ ܘܩܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.5.16",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 5:16",
      "text": "ܘܡܟܝܠ ܚܢܢ ܠܐܢܫ ܒܦܓܪ ܠܐ ܝܕܥܝܢܢ ܘܐܢ ܝܕܥܢ ܒܦܓܪ ܠܡܫܝܚܐ ܐܠܐ ܡܢ ܗܫܐ ܠܐ ܝܕܥܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.5.17",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 5:17",
      "text": "ܟܠ ܡܢ ܕܒܡܫܝܚܐ ܗܘ ܗܟܝܠ ܒܪܝܬܐ ܗܘ ܚܕܬܐ ܥܬܝܩܬܐ ܥܒܪ ܠܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.5.18",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "2 Corinthians 5:18",
      "text": "ܘܟܠ ܡܕܡ ܗܘܐ ܚܕܬܐ ܡܢ ܐܠܗܐ ܗܘ ܕܪܥܝܢ ܠܗ ܒܡܫܝܚܐ ܘܝܗܒ ܠܢ ܬܫܡܫܬܐ ܕܬܪܥܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.5.19",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "2 Corinthians 5:19",
      "text": "ܐܠܗܐ ܗܘܐ ܓܝܪ ܒܡܫܝܚܐ ܗܘ ܕܪܥܝ ܠܥܠܡܐ ܥܡ ܪܒܘܬܗ ܘܠܐ ܚܫܒ ܠܗܘܢ ܚܛܗܝܗܘܢ ܘܤܡ ܒܢ ܕܝܠܢ ܡܠܬܐ ܕܬܪܥܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.5.20",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "2 Corinthians 5:20",
      "text": "ܐܝܙܓܕܐ ܚܢܢ ܗܟܝܠ ܚܠܦ ܡܫܝܚܐ ܘܐܝܟ ܗܘ ܕܐܠܗܐ ܒܥܐ ܡܢܟܘܢ ܒܐܝܕܢ ܚܠܦ ܡܫܝܚܐ ܗܟܝܠ ܒܥܝܢܢ ܐܬܪܥܘ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.5.21",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "2 Corinthians 5:21",
      "text": "ܗܘ ܓܝܪ ܕܠܐ ܝܕܥ ܗܘܐ ܚܛܝܬܐ ܡܛܠܬܟܘܢ ܚܛܝܬܐ ܥܒܕܗ ܕܚܢܢ ܢܗܘܐ ܒܗ ܙܕܝܩܘܬܐ ܕܐܠܗܐ ܀",
