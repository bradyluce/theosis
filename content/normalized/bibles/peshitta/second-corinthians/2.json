  "verses": [
    {
      "id": "peshitta:second-corinthians.2.1",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 2:1",
      "text": "ܕܢܬ ܕܝܢ ܗܕܐ ܒܢܦܫܝ ܕܠܐ ܬܘܒ ܒܟܪܝܘܬܐ ܐܬܐ ܠܘܬܟܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-corinthians.2.2",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 2:2",
      "text": "ܐܢ ܐܢܐ ܓܝܪ ܡܟܪܐ ܐܢܐ ܠܟܘܢ ܡܢܘ ܢܚܕܝܢܝ ܐܠܐ ܗܘ ܕܐܢܐ ܐܟܪܝܬ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.2.3",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 2:3",
      "text": "ܘܕܟܬܒܬ ܠܟܘܢ ܗܝ ܗܕܐ ܕܠܐ ܟܕ ܐܬܐ ܢܟܪܘܢ ܠܝ ܗܢܘܢ ܐܝܠܝܢ ܕܘܠܐ ܗܘܐ ܠܗܘܢ ܕܗܢܘܢ ܢܚܕܘܢܢܝ ܬܟܝܠ ܐܢܐ ܕܝܢ ܥܠ ܟܠܟܘܢ ܕܚܕܘܬܝ ܕܟܠܟܘܢ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.2.4",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 2:4",
      "text": "ܘܡܢ ܐܘܠܨܢܐ ܪܒܐ ܘܡܢ ܐܢܘܤܝܐ ܕܠܒܐ ܟܬܒܬ ܠܟܘܢ ܗܠܝܢ ܒܕܡܥܐ ܤܓܝܐܬܐ ܠܐ ܡܛܠ ܕܬܟܪܐ ܠܟܘܢ ܐܠܐ ܡܛܠ ܕܬܕܥܘܢ ܚܘܒܐ ܝܬܝܪܐ ܕܐܝܬ ܠܝ ܠܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.2.5",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 2:5",
      "text": "ܐܢ ܕܝܢ ܐܢܫ ܐܟܪܝ ܠܐ ܗܘܐ ܠܝ ܐܟܪܝ ܐܠܐ ܒܨܝܪܐ ܩܠܝܠ ܠܟܠܟܘܢ ܕܠܐ ܬܐܩܪ ܡܠܬܐ ܥܠܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.2.6",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 2:6",
      "text": "ܟܕܘ ܠܗ ܕܝܢ ܠܗܢܐ ܟܐܬܐ ܕܡܢ ܤܓܝܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.2.7",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 2:7",
      "text": "ܘܡܟܝܠ ܐܚܪܢܝܐܝܬ ܘܠܐ ܕܬܫܒܩܘܢ ܠܗ ܘܬܒܝܐܘܢܗ ܕܠܡܐ ܒܟܪܝܘܬܐ ܝܬܝܪܬܐ ܢܬܒܠܥ ܠܗ ܗܘ ܡܢ ܕܗܟܢܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.2.8",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 2:8",
      "text": "ܡܛܠ ܗܢܐ ܒܥܐ ܐܢܐ ܡܢܟܘܢ ܕܬܫܪܪܘܢ ܒܗ ܚܘܒܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.2.9",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 2:9",
      "text": "ܡܛܠ ܗܢܐ ܓܝܪ ܟܬܒܬ ܐܦ ܕܐܕܥ ܒܢܤܝܢܐ ܐܢ ܒܟܠܡܕܡ ܡܫܬܡܥܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.2.10",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 2:10",
      "text": "ܠܡܢ ܕܐܢܬܘܢ ܕܝܢ ܫܒܩܝܢ ܐܢܬܘܢ ܐܦ ܐܢܐ ܐܦ ܐܢܐ ܓܝܪ ܡܕܡ ܕܫܒܩܬ ܠܡܢ ܕܫܒܩܬ ܡܛܠܬܟܘܢ ܗܘ ܫܒܩܬ ܒܦܪܨܘܦܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.2.11",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 2:11",
      "text": "ܕܠܐ ܢܥܠܒܢ ܤܛܢܐ ܝܕܥܝܢܢ ܓܝܪ ܡܚܫܒܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.2.12",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 2:12",
      "text": "ܟܕ ܐܬܝܬ ܕܝܢ ܠܛܪܘܐܤ ܒܤܒܪܬܗ ܕܡܫܝܚܐ ܘܐܬܦܬܚ ܠܝ ܬܪܥܐ ܒܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.2.13",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 2:13",
      "text": "ܠܐ ܗܘܐ ܠܝ ܢܝܚܐ ܒܪܘܚܝ ܕܠܐ ܐܫܟܚܬ ܠܛܛܘܤ ܐܚܝ ܐܠܐ ܫܪܝܬ ܐܢܘܢ ܘܢܦܩܬ ܠܝ ܠܡܩܕܘܢܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.2.14",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 2:14",
      "text": "ܛܝܒܘ ܕܝܢ ܠܐܠܗܐ ܕܒܟܠ ܙܒܢ ܚܙܬܐ ܥܒܕ ܠܢ ܒܡܫܝܚܐ ܘܓܠܐ ܒܢ ܪܝܚܐ ܕܝܕܥܬܗ ܒܟܠ ܐܬܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.2.15",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 2:15",
      "text": "ܪܝܚܐ ܚܢܢ ܓܝܪ ܒܤܝܡܐ ܒܡܫܝܚܐ ܠܐܠܗܐ ܒܐܝܠܝܢ ܕܚܐܝܢ ܘܒܐܝܠܝܢ ܕܐܒܕܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.2.16",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 2:16",
      "text": "ܠܐܝܠܝܢ ܕܪܝܚܐ ܕܡܘܬܐ ܠܡܘܬܐ ܘܠܐܝܠܝܢ ܕܪܝܚܐ ܕܚܝܐ ܠܚܝܐ ܘܠܗܠܝܢ ܡܢܘ ܢܫܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.2.17",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 2:17",
      "text": "ܠܐ ܗܘܝܢ ܓܝܪ ܐܝܟ ܫܪܟܐ ܕܡܡܙܓܝܢ ܡܠܘܗܝ ܕܐܠܗܐ ܐܠܐ ܐܝܟ ܕܒܫܪܪܐ ܘܐܝܟ ܕܡܢ ܐܠܗܐ ܩܕܡ ܐܠܗܐ ܒܡܫܝܚܐ ܡܡܠܠܝܢܢ ܀",
      "paragraphStart": false
    }
  ]
