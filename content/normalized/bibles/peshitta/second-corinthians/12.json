    "chapterNumber": 12,
    "referenceLabel": "2 Corinthians 12",
    "summary": "Source text for 2 Corinthians 12 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:second-corinthians.12.1",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 12:1",
      "text": "ܠܡܫܬܒܗܪܘ ܘܠܐ ܐܠܐ ܠܐ ܦܩܚ ܐܬܐ ܐܢܐ ܠܝ ܓܝܪ ܠܚܙܘܢܐ ܘܠܓܠܝܢܘܗܝ ܕܡܪܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-corinthians.12.2",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 12:2",
      "text": "ܝܕܥܢܐ ܓܒܪܐ ܒܡܫܝܚܐ ܡܢ ܩܕܡ ܐܪܒܥܤܪܐ ܫܢܝܢ ܐܢ ܒܦܓܪ ܕܝܢ ܘܐܢ ܕܠܐ ܦܓܪ ܠܐ ܝܕܥ ܐܢܐ ܐܠܗܐ ܗܘ ܝܕܥ ܕܐܬܚܛܦ ܗܘ ܗܢܐ ܥܕܡܐ ܫܡܝܐ ܕܬܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.12.3",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 12:3",
      "text": "ܘܝܕܥ ܐܢܐ ܠܗ ܠܗܢܐ ܒܪܢܫܐ ܐܢ ܒܦܓܪ ܕܝܢ ܘܐܢ ܕܠܐ ܦܓܪ ܠܐ ܝܕܥ ܐܢܐ ܐܠܗܐ ܗܘ ܝܕܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.12.4",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 12:4",
      "text": "ܕܐܬܚܛܦ ܠܦܪܕܝܤܐ ܘܫܡܥ ܡܠܐ ܕܠܐ ܡܬܡܠܠܢ ܐܝܠܝܢ ܕܠܐ ܫܠܝܛ ܠܒܪܢܫܐ ܠܡܡܠܠܘ ܐܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.12.5",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 12:5",
      "text": "ܥܠ ܗܢܐ ܐܫܬܒܗܪ ܥܠ ܢܦܫܝ ܕܝܢ ܠܐ ܐܫܬܒܗܪ ܐܠܐ ܐܢ ܒܟܘܪܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.12.6",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 12:6",
      "text": "ܐܢ ܐܨܒܐ ܓܝܪ ܕܐܫܬܒܗܪ ܠܐ ܗܘܐ ܐܢܐ ܫܛܝܐ ܫܪܪܐ ܗܘ ܓܝܪ ܐܡܪ ܐܢܐ ܚܐܤܢܐ ܕܝܢ ܕܠܡܐ ܐܢܫ ܢܬܪܥܐ ܥܠܝ ܝܬܝܪ ܡܢ ܡܐ ܕܚܙܐ ܠܝ ܘܕܫܡܥ ܡܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.12.7",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 12:7",
      "text": "ܘܕܠܐ ܐܬܪܝܡ ܒܝܬܝܪܘܬܐ ܕܓܠܝܢܐ ܐܫܬܠܡ ܠܝ ܫܦܝܐ ܠܒܤܪܝ ܡܠܐܟܗ ܕܤܛܢܐ ܕܢܗܘܐ ܡܩܦܚ ܠܝ ܕܠܐ ܐܬܪܝܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.12.8",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 12:8",
      "text": "ܘܥܠ ܗܢܐ ܬܠܬ ܙܒܢܝܢ ܒܥܝܬ ܡܢ ܡܪܝ ܕܢܦܪܩ ܡܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.12.9",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 12:9",
      "text": "ܘܐܡܪ ܠܝ ܤܦܩܐ ܠܟ ܛܝܒܘܬܝ ܚܝܠܝ ܓܝܪ ܒܟܪܝܗܘܬܐ ܗܘ ܡܬܓܡܪ ܚܕܝܐܝܬ ܗܟܝܠ ܐܫܬܒܗܪ ܒܟܘܪܗܢܝ ܕܢܓܢ ܥܠܝ ܚܝܠܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.12.10",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 12:10",
      "text": "ܡܛܠ ܗܢܐ ܨܒܐ ܐܢܐ ܒܟܘܪܗܢܐ ܒܨܥܪܐ ܒܐܘܠܨܢܐ ܒܪܕܘܦܝܐ ܒܚܒܘܫܝܐ ܕܥܠ ܐܦܝ ܡܫܝܚܐ ܐܡܬܝ ܕܟܪܝܗ ܐܢܐ ܓܝܪ ܗܝܕܝܢ ܗܘ ܚܝܠܬܢ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.12.11",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 12:11",
      "text": "ܗܐ ܗܘܝܬ ܚܤܝܪ ܪܥܝܢܐ ܒܫܘܒܗܪܝ ܕܐܢܬܘܢ ܐܠܨܬܘܢܢܝ ܚܝܒܝܢ ܗܘܝܬܘܢ ܓܝܪ ܕܐܢܬܘܢ ܬܤܗܕܘܢ ܥܠܝ ܡܛܠ ܕܠܐ ܒܨܪܬ ܡܕܡ ܡܢ ܫܠܝܚܐ ܐܝܠܝܢ ܕܛܒ ܡܝܬܪܝܢ ܘܐܦܢ ܠܐ ܗܘܝܬ ܡܕܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.12.12",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 12:12",
      "text": "ܐܬܘܬܐ ܕܫܠܝܚܐ ܥܒܕܬ ܒܝܢܬܟܘܢ ܒܟܠ ܡܤܝܒܪܢܘ ܘܒܓܒܪܘܬܐ ܘܒܬܕܡܪܬܐ ܘܒܚܝܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.12.13",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 12:13",
      "text": "ܒܡܢܐ ܓܝܪ ܐܬܒܨܪܬܘܢ ܡܢ ܥܕܬܐ ܐܚܪܢܝܬܐ ܐܠܐ ܐܢ ܒܗܕܐ ܕܐܢܐ ܠܐ ܝܩܪܬ ܥܠܝܟܘܢ ܫܒܘܩܘ ܠܝ ܗܕܐ ܤܟܠܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.12.14",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 12:14",
      "text": "ܗܐ ܗܕܐ ܕܬܠܬ ܗܝ ܙܒܢܝܢ ܕܡܛܝܒ ܐܢܐ ܕܐܬܐ ܠܘܬܟܘܢ ܘܠܐ ܐܩܪ ܥܠܝܟܘܢ ܡܛܠ ܕܠܐ ܒܥܐ ܐܢܐ ܕܝܠܟܘܢ ܐܠܐ ܠܟܘܢ ܠܐ ܓܝܪ ܚܝܒܝܢ ܒܢܝܐ ܠܡܤܡ ܤܝܡܬܐ ܠܐܒܗܐ ܐܠܐ ܐܒܗܐ ܠܒܢܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.12.15",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 12:15",
      "text": "ܐܢܐ ܕܝܢ ܚܕܝܐܝܬ ܘܢܦܩܬܐ ܐܦܩ ܘܐܦ ܩܢܘܡܝ ܐܬܠ ܥܠ ܐܦܝ ܢܦܫܬܟܘܢ ܐܦܢ ܟܕ ܝܬܝܪܐܝܬ ܡܚܒ ܐܢܐ ܠܟܘܢ ܐܢܬܘܢ ܒܨܝܪܐܝܬ ܡܚܒܝܢ ܐܢܬܘܢ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.12.16",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 12:16",
      "text": "ܘܟܒܪ ܐܢܐ ܠܐ ܝܩܪܬ ܥܠܝܟܘܢ ܐܠܐ ܐܝܟ ܓܒܪܐ ܚܪܥܐ ܒܢܟܠܐ ܓܢܒܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.12.17",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 12:17",
      "text": "ܠܡܐ ܒܝܕ ܐܢܫ ܐܚܪܝܢ ܕܫܕܪܬ ܠܘܬܟܘܢ ܐܬܝܥܢܬ ܥܠܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.12.18",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "2 Corinthians 12:18",
      "text": "ܡܢ ܛܛܘܤ ܒܥܝܬ ܘܫܕܪܬ ܥܡܗ ܠܐܚܐ ܠܡܐ ܡܕܡ ܐܬܝܥܢ ܥܠܝܟܘܢ ܛܛܘܤ ܠܘ ܒܚܕܐ ܪܘܚܐ ܗܠܟܢ ܘܒܗܝܢ ܒܥܩܒܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.12.19",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "2 Corinthians 12:19",
      "text": "ܠܡܐ ܬܘܒ ܤܒܪܝܢ ܐܢܬܘܢ ܕܠܟܘܢ ܢܦܩܝܢܢ ܪܘܚܐ ܩܕܡ ܐܠܗܐ ܒܡܫܝܚܐ ܡܡܠܠܝܢܢ ܘܟܠܗܝܢ ܚܒܝܒܝ ܡܛܠ ܒܢܝܢܐ ܗܘ ܕܝܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.12.20",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "2 Corinthians 12:20",
      "text": "ܕܚܠ ܐܢܐ ܓܝܪ ܕܠܡܐ ܐܬܐ ܠܘܬܟܘܢ ܘܠܐ ܐܫܟܚܟܘܢ ܐܝܟ ܕܨܒܐ ܐܢܐ ܘܐܫܬܟܚ ܠܟܘܢ ܐܦ ܐܢܐ ܐܝܟ ܡܐ ܕܠܐ ܨܒܝܬܘܢ ܕܠܡܐ ܚܪܝܢܐ ܘܚܤܡܐ ܘܚܡܬܐ ܘܥܨܝܢܐ ܘܡܐܟܠ ܩܪܨܐ ܘܪܛܢܐ ܘܚܬܝܪܘܬܐ ܘܫܓܘܫܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.12.21",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "2 Corinthians 12:21",
      "text": "ܕܠܡܐ ܟܕ ܐܬܐ ܠܘܬܟܘܢ ܢܡܟܟܢܝ ܐܠܗܝ ܘܐܬܐܒܠ ܥܠ ܤܓܝܐܐ ܐܝܠܝܢ ܕܚܛܘ ܘܠܐ ܬܒܘ ܡܢ ܛܢܦܘܬܐ ܘܡܢ ܙܢܝܘܬܐ ܘܡܢ ܦܚܙܘܬܐ ܕܥܒܕܘ ܀",
      "paragraphStart": false
    }
  ]
