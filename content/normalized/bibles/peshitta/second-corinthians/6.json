      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "2 Corinthians 6:18",
      "text": "ܘܐܗܘܐ ܠܟܘܢ ܠܐܒܐ ܘܐܢܬܘܢ ܬܗܘܘܢ ܠܝ ܠܒܢܝܐ ܘܠܒܢܬܐ ܐܡܪ ܡܪܝܐ ܕܟܠ ܐܚܝܕ ܀",
      "paragraphStart": false
    }
