      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 6:1",
      "text": "ܘܐܝܟ ܡܥܕܪܢܐ ܒܥܝܢܢ ܡܢܟܘܢ ܕܠܐ ܬܤܬܪܩ ܒܟܘܢ ܛܝܒܘܬܐ ܕܐܠܗܐ ܕܩܒܠܬܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-corinthians.6.2",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 6:2",
      "text": "ܐܡܪ ܓܝܪ ܕܒܙܒܢܐ ܡܩܒܠܐ ܥܢܝܬܟ ܘܒܝܘܡܐ ܕܚܝܐ ܥܕܪܬܟ ܗܐ ܗܫܐ ܙܒܢܐ ܡܩܒܠܐ ܘܗܐ ܗܫܐ ܝܘܡܐ ܕܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.6.3",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 6:3",
      "text": "ܠܡܐ ܒܡܕܡ ܬܬܠܘܢ ܠܐܢܫ ܥܠܬܐ ܕܬܘܩܠܬܐ ܕܠܐ ܢܗܘܐ ܡܘܡܐ ܒܬܫܡܫܬܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.6.4",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 6:4",
      "text": "ܐܠܐ ܒܟܠ ܡܕܡ ܢܚܘܐ ܢܦܫܢ ܕܡܫܡܫܢܐ ܚܢܢ ܕܐܠܗܐ ܒܡܤܝܒܪܢܘܬܐ ܤܓܝܐܬܐ ܒܐܘܠܨܢܐ ܒܐܢܢܩܤ ܒܚܒܘܫܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.6.5",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 6:5",
      "text": "ܒܢܓܕܐ ܒܐܤܘܪܐ ܒܫܓܘܫܝܐ ܒܠܐܘܬܐ ܒܫܗܪܐ ܒܨܘܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.6.6",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 6:6",
      "text": "ܒܕܟܝܘܬܐ ܒܝܕܥܬܐ ܒܢܓܝܪܘܬ ܪܘܚܐ ܒܒܤܝܡܘܬܐ ܒܪܘܚܐ ܕܩܘܕܫܐ ܒܚܘܒܐ ܕܠܐ ܢܟܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.6.7",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 6:7",
      "text": "ܒܡܠܬܐ ܕܩܘܫܬܐ ܒܚܝܠܐ ܕܐܠܗܐ ܒܙܝܢܐ ܕܙܕܝܩܘܬܐ ܕܒܝܡܝܢܐ ܘܒܤܡܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.6.8",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 6:8",
      "text": "ܒܫܘܒܚܐ ܘܒܨܥܪܐ ܒܩܘܠܤܐ ܘܒܓܘܢܝܐ ܐܝܟ ܡܛܥܝܢܐ ܘܫܪܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.6.9",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 6:9",
      "text": "ܐܝܟ ܠܐ ܝܕܝܥܐ ܘܝܕܝܥܝܢܢ ܐܝܟ ܡܝܬܝܢܢ ܘܗܐ ܚܝܝܢ ܚܢܢ ܐܝܟ ܕܡܬܪܕܝܢܢ ܘܠܐ ܡܝܬܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.6.10",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 6:10",
      "text": "ܐܝܟ ܕܟܪܝܐ ܠܢ ܘܒܟܠܙܒܢ ܚܕܝܢܢ ܐܝܟ ܡܤܟܢܐ ܘܠܤܓܝܐܐ ܡܥܬܪܝܢܢ ܐܝܟ ܕܡܕܡ ܠܝܬ ܠܢ ܘܟܠ ܡܕܡ ܐܚܝܕܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.6.11",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 6:11",
      "text": "ܦܘܡܢ ܦܬܝܚ ܗܘ ܠܘܬܟܘܢ ܩܘܪܢܬܝܐ ܘܠܒܢ ܪܘܝܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.6.12",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 6:12",
      "text": "ܠܐ ܐܠܝܨܝܬܘܢ ܒܢ ܐܠܝܨܝܬܘܢ ܕܝܢ ܒܪܚܡܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.6.13",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 6:13",
      "text": "ܐܝܟ ܕܠܒܢܝܐ ܕܝܢ ܐܡܪ ܐܢܐ ܦܘܪܥܘܢܝ ܚܘܒܠܝ ܕܠܘܬܟܘܢ ܘܪܘܚܘ ܚܘܒܟܘܢ ܠܘܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.6.14",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 6:14",
      "text": "ܘܠܐ ܬܗܘܘܢ ܒܢܝ ܙܘܓܐ ܠܐܝܠܝܢ ܕܠܐ ܡܗܝܡܢܝܢ ܐܝܕܐ ܓܝܪ ܫܘܬܦܘܬܐ ܐܝܬ ܠܙܕܝܩܘܬܐ ܥܡ ܥܘܠܐ ܐܘ ܐܝܢܐ ܚܘܠܛܢܐ ܐܝܬ ܠܢܗܝܪܐ ܥܡ ܚܫܘܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.6.15",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 6:15",
      "text": "ܐܘ ܐܝܕܐ ܫܠܡܘܬܐ ܐܝܬ ܠܡܫܝܚܐ ܥܡ ܤܛܢܐ ܐܘ ܐܝܕܐ ܡܢܬܐ ܐܝܬ ܠܕܡܗܝܡܢ ܥܡ ܕܠܐ ܡܗܝܡܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.6.16",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 6:16",
      "text": "ܐܝܕܐ ܕܝܢ ܐܘܝܘܬܐ ܐܝܬ ܠܗܝܟܠܗ ܕܐܠܗܐ ܥܡ ܕܫܐܕܐ ܐܢܬܘܢ ܕܝܢ ܗܝܟܠܗ ܐܢܬܘܢ ܕܐܠܗܐ ܚܝܐ ܐܝܟܢܐ ܕܐܡܝܪ ܕܐܥܡܪ ܒܗܘܢ ܘܐܗܠܟ ܒܗܘܢ ܘܐܗܘܐ ܐܠܗܗܘܢ ܘܗܢܘܢ ܢܗܘܘܢ ܠܝ ܥܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.6.17",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 6:17",
      "text": "ܡܛܠ ܗܢܐ ܦܘܩܘ ܡܢ ܒܝܢܬܗܘܢ ܘܐܬܦܪܫܘ ܡܢܗܘܢ ܐܡܪ ܡܪܝܐ ܘܠܛܡܐܐ ܠܐ ܬܬܩܪܒܘܢ ܘܐܢܐ ܐܩܒܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
