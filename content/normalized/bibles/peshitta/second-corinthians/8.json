    "chapterNumber": 8,
    "referenceLabel": "2 Corinthians 8",
    "summary": "Source text for 2 Corinthians 8 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:second-corinthians.8.1",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 8:1",
      "text": "ܡܘܕܥܝܢܢ ܠܟܘܢ ܕܝܢ ܐܚܝܢ ܛܝܒܘܬܗ ܕܐܠܗܐ ܕܐܬܝܗܒܬ ܒܥܕܬܐ ܕܡܩܕܘܢܝܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-corinthians.8.2",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 8:2",
      "text": "ܕܒܒܘܩܝܐ ܤܓܝܐܐ ܕܐܘܠܨܢܗܘܢ ܝܬܝܪܘܬܐ ܗܘܬ ܠܚܕܘܬܗܘܢ ܘܥܘܡܩܐ ܕܡܤܟܢܘܬܗܘܢ ܐܬܝܬܪ ܒܥܘܬܪܐ ܕܦܫܝܛܘܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.3",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 8:3",
      "text": "ܤܗܕ ܐܢܐ ܓܝܪ ܕܐܝܟ ܚܝܠܗܘܢ ܘܝܬܝܪ ܡܢ ܚܝܠܗܘܢ ܒܨܒܝܢ ܢܦܫܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.4",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 8:4",
      "text": "ܒܥܘ ܡܢܢ ܒܒܥܘܬܐ ܤܓܝܐܬܐ ܕܢܫܬܘܬܦܘܢ ܒܛܝܒܘܬܐ ܕܬܫܡܫܬܐ ܕܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.5",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 8:5",
      "text": "ܘܠܐ ܐܝܟ ܡܐ ܕܤܒܪܝܢ ܗܘܝܢ ܐܠܐ ܢܦܫܗܘܢ ܐܫܠܡܘ ܠܘܩܕܡ ܠܡܪܢ ܘܐܦ ܠܢ ܒܨܒܝܢܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.6",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 8:6",
      "text": "ܕܚܢܢ ܢܒܥܐ ܡܢ ܛܛܘܤ ܕܐܝܟ ܕܫܪܝ ܗܟܢܐ ܢܫܠܡ ܒܟܘܢ ܐܦ ܛܝܒܘܬܐ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.7",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 8:7",
      "text": "ܐܠܐ ܐܝܟܢܐ ܕܒܟܠܡܕܡ ܡܬܝܬܪܝܢ ܐܢܬܘܢ ܒܗܝܡܢܘܬܐ ܘܒܡܠܬܐ ܘܒܝܕܥܬܐ ܘܒܟܠ ܚܦܝܛܘ ܘܒܚܘܒܢ ܕܠܘܬܟܘܢ ܗܟܢܐ ܐܦ ܒܗܕܐ ܛܝܒܘܬܐ ܬܬܝܬܪܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.8",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 8:8",
      "text": "ܠܐ ܗܘܐ ܡܦܩܕ ܦܩܕ ܐܢܐ ܠܟܘܢ ܐܠܐ ܒܚܦܝܛܘܬܐ ܕܚܒܪܝܟܘܢ ܫܪܪܐ ܕܚܘܒܟܘܢ ܡܢܤܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.9",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 8:9",
      "text": "ܝܕܥܝܢ ܐܢܬܘܢ ܓܝܪ ܛܝܒܘܬܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܕܡܛܠܬܟܘܢ ܐܬܡܤܟܢ ܟܕ ܐܝܬܘܗܝ ܥܬܝܪܐ ܕܐܢܬܘܢ ܒܡܤܟܢܘܬܗ ܬܥܬܪܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.10",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 8:10",
      "text": "ܡܡܠܟ ܕܝܢ ܡܠܟ ܐܢܐ ܠܟܘܢ ܗܕܐ ܕܡܥܕܪܐ ܠܟܘܢ ܡܛܠ ܕܡܢ ܐܫܬܩܕܝ ܫܪܝܬܘܢ ܠܘ ܠܡܨܒܐ ܒܠܚܘܕ ܐܠܐ ܐܦ ܠܡܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.11",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 8:11",
      "text": "ܗܫܐ ܕܝܢ ܫܠܡܘ ܒܥܒܕܐ ܗܘ ܡܕܡ ܕܨܒܝܬܘܢ ܕܐܝܟܢܐ ܕܗܘܐ ܠܟܘܢ ܤܘܘܚܐ ܠܡܨܒܐ ܗܟܢܐ ܒܥܒܕܐ ܬܫܠܡܘܢ ܡܢ ܡܐ ܕܐܝܬ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.12",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 8:12",
      "text": "ܐܢ ܓܝܪ ܨܒܝܢܐ ܐܝܬܘܗܝ ܐܝܟ ܡܐ ܕܐܝܬ ܠܗ ܗܟܘܬ ܡܬܩܒܠ ܠܐ ܗܘܐ ܐܝܟ ܡܐ ܕܠܝܬ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.13",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 8:13",
      "text": "ܠܐ ܗܘܐ ܓܝܪ ܕܠܐܚܪܢܐ ܬܗܘܐ ܪܘܚܬܐ ܘܠܟܘܢ ܐܘܠܨܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.14",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 8:14",
      "text": "ܐܠܐ ܒܫܘܝܘܬܐ ܗܘܘ ܒܙܒܢܐ ܗܢܐ ܕܝܬܝܪܘܬܟܘܢ ܕܝܠܟܘܢ ܬܗܘܐ ܠܚܤܝܪܘܬܗܘܢ ܕܗܠܝܢ ܕܐܦ ܝܬܝܪܘܬܗܘܢ ܕܗܢܘܢ ܬܗܘܐ ܠܚܤܝܪܘܬܟܘܢ ܕܝܠܟܘܢ ܕܬܗܘܐ ܫܘܝܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.15",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 8:15",
      "text": "ܐܝܟ ܕܟܬܝܒ ܕܗܘ ܕܐܤܓܝ ܫܩܠ ܠܐ ܐܬܝܬܪ ܠܗ ܘܗܘ ܕܩܠܝܠ ܫܩܠ ܠܐ ܐܬܒܨܪ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.16",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 8:16",
      "text": "ܛܝܒܘ ܕܝܢ ܠܐܠܗܐ ܕܝܗܒܗ ܚܦܝܛܘܬܐ ܗܕܐ ܚܠܦܝܟܘܢ ܒܠܒܗ ܕܛܛܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.17",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 8:17",
      "text": "ܒܥܘܬܢ ܓܝܪ ܩܒܠ ܘܡܛܠ ܕܛܒ ܒܛܝܠ ܠܗ ܡܢ ܨܒܝܢܗ ܢܦܩ ܨܐܕܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.18",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "2 Corinthians 8:18",
      "text": "ܫܕܪܢ ܕܝܢ ܥܡܗ ܠܐܚܘܢ ܐܝܢܐ ܕܬܫܒܘܚܬܗ ܒܐܘܢܓܠܝܘܢ ܒܟܠܗܝܢ ܥܕܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.19",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "2 Corinthians 8:19",
      "text": "ܗܟܢܐ ܕܐܦ ܡܓܒܐ ܓܒܐ ܡܢ ܥܕܬܐ ܕܢܦܘܩ ܥܡܢ ܒܛܝܒܘܬܐ ܗܕܐ ܕܡܫܬܡܫܐ ܡܢܢ ܠܫܘܒܚܗ ܕܝܠܗ ܕܐܠܗܐ ܘܠܠܘܒܒܢ ܕܝܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.20",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "2 Corinthians 8:20",
      "text": "ܩܢܝܛܝܢܢ ܕܝܢ ܒܗܕܐ ܕܠܐ ܐܢܫ ܢܤܝܡ ܒܢ ܡܘܡܐ ܒܗܕܐ ܪܒܘܬܐ ܕܡܫܬܡܫܐ ܡܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.21",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "2 Corinthians 8:21",
      "text": "ܝܨܝܦܝܢܢ ܓܝܪ ܕܫܦܝܪܬܐ ܠܐ ܩܕܡ ܐܠܗܐ ܒܠܚܘܕ ܐܠܐ ܐܦ ܩܕܡ ܒܢܝܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.22",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "2 Corinthians 8:22",
      "text": "ܫܕܪܢ ܕܝܢ ܥܡܗܘܢ ܐܦ ܠܐܚܘܢ ܐܝܢܐ ܕܠܢ ܒܩܐ ܒܟܠܙܒܢ ܒܤܓܝܐܬܐ ܕܚܦܝܛܐ ܗܘ ܗܫܐ ܕܝܢ ܝܬܝܪܐܝܬ ܚܦܝܛ ܒܬܘܟܠܢܐ ܤܓܝܐܐ ܕܥܠܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.23",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "2 Corinthians 8:23",
      "text": "ܐܢ ܗܟܝܠ ܛܛܘܤ ܫܘܬܦܐ ܗܘ ܕܝܠܝ ܘܡܥܕܪܢܐ ܒܟܘܢ ܘܐܢ ܐܚܝܢ ܐܚܪܢܐ ܫܠܝܚܐ ܐܢܘܢ ܕܥܕܬܐ ܕܫܘܒܚܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.8.24",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "2 Corinthians 8:24",
      "text": "ܡܟܝܠ ܬܚܘܝܬܐ ܕܚܘܒܟܘܢ ܘܫܘܒܗܪܢ ܕܒܟܘܢ ܒܗܘܢ ܚܘܘ ܒܦܪܨܘܦ ܥܕܬܐ ܟܠܗܝܢ ܀",
      "paragraphStart": false
    }
