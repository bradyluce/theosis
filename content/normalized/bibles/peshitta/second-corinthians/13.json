    "referenceLabel": "2 Corinthians 13",
    "summary": "Source text for 2 Corinthians 13 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:second-corinthians.13.1",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 13:1",
      "text": "ܗܕܐ ܕܬܠܬ ܗܝ ܙܒܢܝܢ ܕܐܬܐ ܐܢܐ ܠܘܬܟܘܢ ܕܥܠ ܦܘܡ ܬܪܝܢ ܘܬܠܬܐ ܤܗܕܝܢ ܬܩܘܡ ܟܠ ܡܠܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-corinthians.13.2",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 13:2",
      "text": "ܡܢ ܩܕܝܡ ܐܡܪܬ ܗܘܝܬ ܠܟܘܢ ܘܬܘܒ ܡܩܕܡ ܐܢܐ ܐܡܪ ܐܢܐ ܠܟܘܢ ܐܝܟ ܕܐܦ ܬܪܬܝܢ ܙܒܢܝܢ ܕܗܘܝܬ ܠܘܬܟܘܢ ܐܡܪܬ ܠܟܘܢ ܘܐܦ ܗܫܐ ܟܕ ܪܚܝܩ ܐܢܐ ܟܬܒܢܐ ܠܗܠܝܢ ܕܚܛܘ ܘܠܫܪܟܐ ܕܐܚܪܢܐ ܕܐܢ ܐܬܐ ܬܘܒ ܠܐ ܐܚܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.13.3",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 13:3",
      "text": "ܡܛܠ ܕܒܘܩܝܐ ܒܥܝܬܘܢ ܕܡܫܝܚܐ ܕܡܡܠܠ ܒܝ ܗܘ ܕܠܐ ܗܘܐ ܡܚܝܠ ܒܟܘܢ ܐܠܐ ܚܝܠܬܢ ܗܘ ܒܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.13.4",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 13:4",
      "text": "ܐܦܢ ܐܙܕܩܦ ܓܝܪ ܒܡܚܝܠܘܬܐ ܐܠܐ ܚܝ ܗܘ ܒܚܝܠܐ ܕܐܠܗܐ ܘܐܦ ܚܢܢ ܡܚܝܠܝܢܢ ܥܡܗ ܐܠܐ ܚܝܝܢ ܚܢܢ ܥܡܗ ܒܚܝܠܐ ܕܐܠܗܐ ܕܒܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.13.5",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 13:5",
      "text": "ܢܦܫܟܘܢ ܒܩܘ ܐܢ ܒܗ ܒܗܝܡܢܘܬܐ ܩܝܡܝܢ ܐܢܬܘܢ ܢܦܫܟܘܢ ܐܤܘ ܐܘ ܠܐ ܡܫܬܘܕܥܝܬܘܢ ܕܝܫܘܥ ܡܫܝܚܐ ܒܟܘܢ ܗܘ ܘܐܢ ܠܐ ܡܤܠܝܐ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.13.6",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 13:6",
      "text": "ܡܤܒܪ ܐܢܐ ܕܝܢ ܕܬܕܥܘܢ ܕܚܢܢ ܠܐ ܗܘܝܢ ܡܤܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.13.7",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 13:7",
      "text": "ܒܥܐ ܐܢܐ ܕܝܢ ܡܢ ܐܠܗܐ ܕܠܐ ܢܗܘܐ ܒܟܘܢ ܡܕܡ ܕܒܝܫ ܐܝܟ ܕܒܘܩܝܢ ܕܝܠܢ ܢܬܚܙܐ ܐܠܐ ܕܐܢܬܘܢ ܬܗܘܘܢ ܤܥܪܝܢ ܛܒܬܐ ܘܚܢܢ ܢܗܘܐ ܐܝܟ ܡܤܠܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.13.8",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 13:8",
      "text": "ܠܐ ܓܝܪ ܡܫܟܚܝܢܢ ܕܢܥܒܕ ܡܕܡ ܠܘܩܒܠ ܩܘܫܬܐ ܐܠܐ ܚܠܦ ܩܘܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.13.9",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 13:9",
      "text": "ܚܕܝܢܢ ܕܝܢ ܡܐ ܕܚܢܢ ܟܪܝܗܝܢ ܘܐܢܬܘܢ ܚܝܠܬܢܝܢ ܗܕܐ ܓܝܪ ܐܦ ܡܨܠܝܢܢ ܕܐܢܬܘܢ ܬܬܓܡܪܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.13.10",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 13:10",
      "text": "ܡܛܠ ܗܢܐ ܟܕ ܪܚܝܩ ܐܢܐ ܗܠܝܢ ܟܬܒ ܐܢܐ ܕܠܐ ܡܐ ܕܐܬܝܬ ܩܫܝܐܝܬ ܐܤܥܘܪ ܐܝܟ ܫܘܠܛܢܐ ܕܝܗܒ ܠܝ ܡܪܝ ܠܒܢܝܢܟܘܢ ܘܠܐ ܠܤܘܚܦܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.13.11",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 13:11",
      "text": "ܡܟܝܠ ܐܚܝ ܚܕܘ ܘܐܬܓܡܪܘ ܘܐܬܒܝܐܘ ܘܐܘܝܘܬܐ ܘܫܝܢܐ ܢܗܘܐ ܒܟܘܢ ܘܐܠܗܐ ܕܚܘܒܐ ܘܕܫܠܡܘܬܐ ܢܗܘܐ ܥܡܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.13.12",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 13:12",
      "text": "ܫܐܠܘ ܒܫܠܡܐ ܚܕ ܕܚܕ ܒܢܘܫܩܬܐ ܩܕܝܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.13.13",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 13:13",
      "text": "ܫܐܠܝܢ ܒܫܠܡܟܘܢ ܟܠܗܘܢ ܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.13.14",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 13:14",
      "text": "ܫܠܡܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܘܚܘܒܗ ܕܐܠܗܐ ܘܫܘܬܦܘܬܐ ܕܪܘܚܐ ܕܩܘܕܫܐ ܥܡ ܟܠܟܘܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
