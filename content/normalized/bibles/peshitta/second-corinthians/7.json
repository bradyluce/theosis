  "verses": [
    {
      "id": "peshitta:second-corinthians.7.1",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 7:1",
      "text": "ܡܛܠ ܕܐܝܬ ܠܢ ܗܟܝܠ ܗܠܝܢ ܡܘܠܟܢܐ ܚܒܝܒܝ ܢܕܟܐ ܢܦܫܢ ܡܢ ܟܠܗ ܛܡܐܘܬܐ ܕܒܤܪܐ ܘܕܪܘܚܐ ܘܢܦܠܘܚ ܩܕܝܫܘܬܐ ܒܕܚܠܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-corinthians.7.2",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 7:2",
      "text": "ܤܝܒܪܘܢ ܐܚܝܢ ܒܐܢܫ ܠܐ ܐܥܘܠܢ ܠܐܢܫ ܠܐ ܚܒܠܢ ܠܐܢܫ ܠܐ ܥܠܒܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.7.3",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 7:3",
      "text": "ܠܐ ܗܘܐ ܠܡܚܝܒܘܬܟܘܢ ܐܡܪ ܐܢܐ ܩܕܡܬ ܓܝܪ ܐܡܪܬ ܕܒܠܒܢ ܐܢܬܘܢ ܠܡܡܬ ܐܟܚܕܐ ܘܠܡܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.7.4",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 7:4",
      "text": "ܦܪܗܤܝܐ ܤܓܝܐܬܐ ܐܝܬ ܠܝ ܠܘܬܟܘܢ ܘܤܓܝ ܐܝܬ ܠܝ ܒܟܘܢ ܫܘܒܗܪܐ ܘܡܠܐ ܐܢܐ ܒܘܝܐܐ ܘܤܘܓܐܐ ܡܬܝܬܪܐ ܒܝ ܚܕܘܬܐ ܒܟܠܗܘܢ ܐܘܠܨܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.7.5",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 7:5",
      "text": "ܐܦ ܡܢ ܕܐܬܝܢ ܓܝܪ ܠܡܩܕܘܢܝܐ ܐܦܠܐ ܚܕ ܢܝܚ ܗܘܐ ܠܦܓܪܢ ܐܠܐ ܒܟܠ ܡܕܡ ܐܬܐܠܨܢ ܡܢ ܠܒܪ ܩܪܒܐ ܘܡܢ ܠܓܘ ܕܚܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.7.6",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 7:6",
      "text": "ܐܠܐ ܐܠܗܐ ܗܘ ܕܡܒܝܐ ܠܡܟܝܟܐ ܒܝܐܢ ܒܡܐܬܝܬܗ ܕܛܛܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.7.7",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 7:7",
      "text": "ܘܠܐ ܒܠܚܘܕ ܒܡܐܬܝܬܗ ܐܠܐ ܐܦ ܒܢܝܚܗ ܗܘ ܕܐܬܢܝܚ ܒܟܘܢ ܤܒܪܢ ܓܝܪ ܥܠ ܚܘܒܟܘܢ ܕܠܘܬܢ ܘܥܠ ܐܒܠܟܘܢ ܘܛܢܢܟܘܢ ܕܥܠ ܐܦܝܢ ܘܟܕ ܫܡܥܬ ܚܕܘܬܐ ܤܓܝܐܬܐ ܗܘܬ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.7.8",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 7:8",
      "text": "ܕܐܦܢ ܐܟܪܝܬ ܠܟܘܢ ܒܐܓܪܬܐ ܠܐ ܬܘܝܐ ܠܝ ܢܦܫܝ ܐܦܢ ܬܘܝܐ ܗܘܬ ܚܙܐ ܐܢܐ ܓܝܪ ܕܗܝ ܐܓܪܬܐ ܐܦܢ ܕܫܥܬܐ ܐܟܪܝܬ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.7.9",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 7:9",
      "text": "ܐܠܐ ܚܕܘܬܐ ܤܓܝܐܬܐ ܥܒܕܬ ܠܝ ܠܐ ܥܠ ܕܟܪܝܬ ܠܟܘܢ ܐܠܐ ܡܛܠ ܕܟܪܝܘܬܟܘܢ ܠܬܝܒܘܬܐ ܐܝܬܝܬܟܘܢ ܟܪܝܬ ܠܟܘܢ ܓܝܪ ܒܕܐܠܗܐ ܐܝܟܢܐ ܕܒܡܕܡ ܠܐ ܬܚܤܪܘܢ ܡܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.7.10",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 7:10",
      "text": "ܟܪܝܘܬܐ ܓܝܪ ܕܡܛܠ ܐܠܗܐ ܬܘܬ ܢܦܫܐ ܥܒܕܐ ܕܠܐ ܗܦܟܐ ܘܡܦܢܝܐ ܠܚܝܐ ܟܪܝܘܬܐ ܕܝܢ ܕܥܠܡܐ ܡܘܬܐ ܗܘ ܥܒܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.7.11",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 7:11",
      "text": "ܗܐ ܓܝܪ ܗܝ ܗܕܐ ܕܐܬܬܥܝܩܬܘܢ ܡܛܠ ܐܠܗܐ ܟܡܐ ܐܥܒܕܬ ܒܟܘܢ ܚܦܝܛܘܬܐ ܘܡܦܩ ܒܪܘܚܐ ܘܪܘܓܙܐ ܘܕܚܠܬܐ ܘܚܘܒܐ ܘܛܢܢܐ ܘܬܒܥܬܐ ܘܒܟܠܡܕܡ ܚܘܝܬܘܢ ܢܦܫܟܘܢ ܕܕܟܝܢ ܐܢܬܘܢ ܒܗ ܒܨܒܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.7.12",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 7:12",
      "text": "ܬܗܘܐ ܕܝܢ ܗܕܐ ܕܟܬܒܬ ܠܟܘܢ ܕܠܐ ܗܘܐ ܡܛܠ ܡܤܟܠܢܐ ܐܦ ܠܐ ܡܛܠ ܗܘ ܡܢ ܕܡܤܟܠ ܒܗ ܐܠܐ ܡܛܠ ܕܬܬܝܕܥ ܩܕܡ ܐܠܗܐ ܚܦܝܛܘܬܟܘܢ ܕܡܛܠܬܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.7.13",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 7:13",
      "text": "ܡܛܠ ܗܢܐ ܐܬܒܝܐܢ ܘܥܡ ܒܘܝܐܢ ܝܬܝܪܐܝܬ ܚܕܝܢ ܒܚܕܘܬܗ ܕܛܛܘܤ ܕܐܬܢܝܚܬ ܪܘܚܗ ܥܡ ܟܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.7.14",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 7:14",
      "text": "ܕܒܡܕܡ ܕܐܫܬܒܗܪܬ ܠܗ ܥܠ ܐܦܝܟܘܢ ܠܐ ܒܗܬܬ ܐܠܐ ܐܝܟ ܕܟܠ ܡܕܡ ܩܘܫܬܐ ܡܠܠܢ ܥܡܟܘܢ ܗܟܢܐ ܐܦ ܫܘܒܗܪܢ ܕܠܘܬ ܛܛܘܤ ܒܩܘܫܬܐ ܐܫܬܟܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.7.15",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 7:15",
      "text": "ܐܦ ܪܚܡܘܗܝ ܝܬܝܪܐܝܬ ܤܓܝܘ ܥܠܝܟܘܢ ܟܕ ܡܬܕܟܪ ܡܫܬܡܥܢܘܬܐ ܕܟܠܟܘܢ ܕܒܕܚܠܬܐ ܘܒܪܬܝܬܐ ܩܒܠܬܘܢܝܗܝ ܀",
      "paragraphStart": false
    },
    {
