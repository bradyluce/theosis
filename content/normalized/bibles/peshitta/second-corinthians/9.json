    "referenceLabel": "2 Corinthians 9",
    "summary": "Source text for 2 Corinthians 9 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:second-corinthians.9.1",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 9:1",
      "text": "ܥܠ ܬܫܡܫܬܐ ܕܝܢ ܕܩܕܝܫܐ ܝܬܝܪܬܐ ܥܒܕ ܐܢܐ ܐܢ ܟܬܒ ܐܢܐ ܠܟܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-corinthians.9.2",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 9:2",
      "text": "ܝܕܥ ܐܢܐ ܓܝܪ ܛܘܝܒܗ ܕܪܥܝܢܟܘܢ ܘܡܛܠ ܗܢܐ ܐܫܬܒܗܪܬ ܒܟܘܢ ܠܡܩܕܘܢܝܐ ܕܐܟܐܝܐ ܥܬܝܕܐ ܗܝ ܡܢ ܐܫܬܩܕܝ ܘܛܢܢܐ ܕܝܠܟܘܢ ܠܤܓܝܐܐ ܓܪܓ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.9.3",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 9:3",
      "text": "ܫܕܪܬ ܕܝܢ ܠܐܚܐ ܕܠܐ ܢܤܬܪܩ ܫܘܒܗܪܢ ܕܐܫܬܒܗܪܢ ܒܟܘܢ ܥܠ ܗܕܐ ܨܒܘܬܐ ܕܐܝܟܢܐ ܕܐܡܪܬ ܬܗܘܘܢ ܡܛܝܒܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.9.4",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 9:4",
      "text": "ܕܠܡܐ ܢܐܬܘܢ ܥܡܝ ܡܩܕܘܢܝܐ ܘܢܫܟܚܘܢܟܘܢ ܟܕ ܠܐ ܥܬܝܕܝܢ ܐܢܬܘܢ ܘܢܒܗܬ ܚܢܢ ܕܠܐ ܢܐܡܪ ܕܐܢܬܘܢ ܬܒܗܬܘܢ ܒܫܘܒܗܪܐ ܗܘ ܕܐܫܬܒܗܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.9.5",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 9:5",
      "text": "ܡܛܠ ܗܢܐ ܐܬܒܛܠ ܠܝ ܕܐܒܥܐ ܡܢ ܐܚܝ ܗܠܝܢ ܕܢܐܬܘܢ ܩܕܡܝ ܠܘܬܟܘܢ ܘܢܥܬܕܘܢ ܒܘܪܟܬܐ ܗܝ ܕܡܢ ܩܕܝܡ ܐܫܬܡܥܬܘܢ ܕܬܗܘܐ ܡܛܝܒܐ ܗܟܢܐ ܐܝܟ ܒܘܪܟܬܐ ܠܐ ܗܘܐ ܐܝܟ ܝܥܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.9.6",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 9:6",
      "text": "ܗܕܐ ܕܝܢ ܡܢ ܕܙܪܥ ܒܚܘܤܢܐ ܐܦ ܒܚܘܤܢܐ ܚܨܕ ܘܡܢ ܕܙܪܥ ܒܒܘܪܟܬܐ ܒܒܘܪܟܬܐ ܢܚܨܘܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.9.7",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 9:7",
      "text": "ܟܠ ܐܢܫ ܐܝܟ ܕܐܝܬ ܒܪܥܝܢܗ ܠܐ ܐܝܟ ܕܡܢ ܟܪܝܘܬܐ ܐܘ ܐܝܟ ܕܡܢ ܩܛܝܪܐ ܠܝܗܘܒܐ ܗܘ ܓܝܪ ܚܕܝܐ ܪܚܡ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.9.8",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 9:8",
      "text": "ܡܛܝܐ ܗܝ ܕܝܢ ܒܐܝܕܝ ܐܠܗܐ ܟܠ ܛܝܒܘ ܕܢܝܬܪ ܒܟܘܢ ܕܒܟܠܙܒܢ ܒܟܠܡܕܡ ܗܘ ܡܐ ܕܤܦܩ ܠܟܘܢ ܢܗܘܐ ܠܟܘܢ ܘܬܬܝܬܪܘܢ ܒܟܠ ܥܒܕ ܛܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.9.9",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 9:9",
      "text": "ܐܝܟ ܕܟܬܝܒ ܕܒܕܪ ܘܝܗܒ ܠܡܤܟܢܐ ܘܙܕܝܩܘܬܗ ܩܝܡܐ ܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.9.10",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 9:10",
      "text": "ܗܘ ܕܝܢ ܕܝܗܒ ܙܪܥܐ ܠܙܪܘܥܐ ܘܠܚܡܐ ܠܡܐܟܘܠܬܐ ܗܘ ܢܬܠ ܘܢܤܓܐ ܙܪܥܟܘܢ ܘܢܪܒܐ ܦܐܪܐ ܕܙܕܝܩܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.9.11",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 9:11",
      "text": "ܕܒܟܠ ܡܕܡ ܬܥܬܪܘܢ ܒܟܠܗ ܦܫܝܛܘܬܐ ܕܗܝ ܓܡܪܐ ܒܐܝܕܢ ܬܘܕܝܬܐ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.9.12",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 9:12",
      "text": "ܡܛܠ ܕܦܘܠܚܢܐ ܕܬܫܡܫܬܐ ܗܕܐ ܠܐ ܗܘܐ ܒܠܚܘܕ ܚܤܝܪܘܬܐ ܕܩܕܝܫܐ ܡܡܠܐ ܐܠܐ ܐܦ ܡܝܬܪ ܒܬܘܕܝܬܐ ܤܓܝܐܬܐ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.9.13",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 9:13",
      "text": "ܡܛܠ ܒܘܩܝܐ ܓܝܪ ܕܬܫܡܫܬܐ ܗܕܐ ܠܐܠܗܐ ܡܫܒܚܝܢ ܕܐܫܬܥܒܕܬܘܢ ܠܬܘܕܝܬܐ ܕܤܒܪܬܗ ܕܡܫܝܚܐ ܘܐܫܬܘܬܦܬܘܢ ܒܦܫܝܛܘܬܟܘܢ ܥܡܗܘܢ ܘܥܡ ܟܠܢܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.9.14",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 9:14",
      "text": "ܘܨܠܘܬܐ ܡܩܪܒܝܢ ܚܠܦܝܟܘܢ ܒܚܘܒܐ ܤܓܝܐܐ ܡܛܠ ܤܘܓܐܐ ܕܛܝܒܘܬܗ ܕܐܠܗܐ ܕܥܠܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.9.15",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 9:15",
      "text": "ܛܝܒܘ ܕܝܢ ܠܐܠܗܐ ܥܠ ܡܘܗܒܬܗ ܕܠܐ ܡܬܡܠܠܐ ܀",
      "paragraphStart": false
    }
  ]
