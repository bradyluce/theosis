      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 3:1",
      "text": "ܡܫܪܝܢܢ ܠܢ ܬܘܒ ܡܢ ܕܪܝܫ ܕܢܚܘܝܟܘܢ ܡܢܐ ܚܢܢ ܐܘ ܕܠܡܐ ܤܢܝܩܝܢܢ ܐܝܟ ܐܚܪܢܐ ܕܐܓܪܬܐ ܕܦܘܩܕܐ ܢܬܟܬܒܢ ܠܟܘܢ ܥܠܝܢ ܐܘ ܕܐܢܬܘܢ ܬܟܬܒܘܢ ܬܦܩܕܘܢ ܥܠܝܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-corinthians.3.2",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 3:2",
      "text": "ܐܓܪܬܢ ܕܝܢ ܕܝܠܢ ܐܢܬܘܢ ܐܢܘܢ ܕܟܬܝܒܐ ܒܠܒܢ ܘܝܕܝܥܐ ܘܡܬܩܪܝܐ ܡܢ ܟܠܢܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.3.3",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 3:3",
      "text": "ܝܕܥܝܬܘܢ ܓܝܪ ܕܐܓܪܬܗ ܐܢܬܘܢ ܕܡܫܝܚܐ ܕܐܫܬܡܫܬ ܡܢܢ ܕܟܬܝܒܐ ܠܐ ܒܕܝܘܬܐ ܐܠܐ ܒܪܘܚܐ ܕܐܠܗܐ ܚܝܐ ܠܐ ܒܠܘܚܐ ܕܟܐܦܐ ܐܠܐ ܒܠܘܚܐ ܕܠܒܐ ܕܒܤܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.3.4",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 3:4",
      "text": "ܬܘܟܠܢܐ ܕܝܢ ܗܟܢܐ ܐܝܬ ܠܢ ܒܡܫܝܚܐ ܠܘܬ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.3.5",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 3:5",
      "text": "ܠܘ ܕܚܢܢ ܤܦܩܝܢܢ ܕܢܬܪܥܐ ܡܕܡ ܐܝܟ ܕܡܢ ܢܦܫܢ ܐܠܐ ܚܝܠܢ ܡܢ ܐܠܗܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.3.6",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 3:6",
      "text": "ܗܘ ܕܐܫܘܝܢ ܕܢܗܘܐ ܡܫܡܫܢܐ ܕܕܝܬܩܐ ܚܕܬܐ ܠܐ ܒܟܬܒܐ ܐܠܐ ܒܪܘܚܐ ܟܬܒܐ ܓܝܪ ܩܛܠ ܪܘܚܐ ܕܝܢ ܡܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.3.7",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 3:7",
      "text": "ܐܢ ܕܝܢ ܬܫܡܫܬܐ ܕܡܘܬܐ ܒܟܬܒܐ ܐܬܪܫܡܬ ܒܟܐܦܐ ܘܗܘܬ ܒܬܫܒܘܚܬܐ ܐܝܟܢܐ ܕܠܐ ܢܫܟܚܘܢ ܒܢܝ ܐܝܤܪܝܠ ܠܡܚܪ ܒܦܪܨܘܦܗ ܕܡܘܫܐ ܡܛܠ ܫܘܒܚܐ ܕܦܪܨܘܦܗ ܗܘ ܕܐܬܒܛܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.3.8",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 3:8",
      "text": "ܐܝܟܢܐ ܗܟܝܠ ܬܫܡܫܬܐ ܕܪܘܚܐ ܠܐ ܝܬܝܪܐܝܬ ܬܗܘܐ ܒܫܘܒܚܐ ܀",
      "paragraphStart": false
    },
    {
