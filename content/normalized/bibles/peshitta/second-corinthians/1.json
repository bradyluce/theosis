{
  "chapter": {
    "id": "peshitta:second-corinthians.1",
    "translationId": "peshitta",
    "bookSlug": "second-corinthians",
    "chapterNumber": 1,
    "referenceLabel": "2 Corinthians 1",
    "summary": "Source text for 2 Corinthians 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:second-corinthians.1.1",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 1:1",
      "text": "ܦܘܠܘܤ ܫܠܝܚܐ ܕܝܫܘܥ ܡܫܝܚܐ ܒܨܒܝܢܗ ܕܐܠܗܐ ܘܛܝܡܬܐܘܤ ܐܚܐ ܠܥܕܬܐ ܕܐܠܗܐ ܕܐܝܬ ܒܩܘܪܢܬܘܤ ܘܠܟܠܗܘܢ ܩܕܝܫܐ ܕܐܝܬ ܒܐܟܐܝܐ ܟܠܗ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-corinthians.1.2",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 1:2",
      "text": "ܛܝܒܘܬܐ ܥܡܟܘܢ ܘܫܠܡܐ ܡܢ ܐܠܗܐ ܐܒܘܢ ܘܡܢ ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.3",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 1:3",
      "text": "ܡܒܪܟ ܗܘ ܐܠܗܐ ܐܒܘܗܝ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܐܒܐ ܕܪܚܡܐ ܘܐܠܗܐ ܕܟܠ ܒܘܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.4",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 1:4",
      "text": "ܗܘ ܕܡܒܝܐ ܠܢ ܒܟܠܗܘܢ ܐܘܠܨܢܝܢ ܕܐܦ ܚܢܢ ܢܫܟܚ ܢܒܝܐ ܠܐܝܠܝܢ ܕܒܟܠ ܐܘܠܨܢܝܢ ܐܢܘܢ ܒܗܘ ܒܘܝܐܐ ܕܚܢܢ ܡܬܒܝܐܝܢܢ ܡܢ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.5",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 1:5",
      "text": "ܐܝܟܢܐ ܓܝܪ ܕܡܬܝܬܪܝܢ ܒܢ ܚܫܘܗܝ ܕܡܫܝܚܐ ܗܟܢܐ ܒܝܕ ܡܫܝܚܐ ܡܬܝܬܪ ܐܦ ܒܘܝܐܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.6",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 1:6",
      "text": "ܐܦܢ ܕܝܢ ܡܬܐܠܨܝܢܢ ܥܠ ܐܦܝ ܒܘܝܐܟܘܢ ܗܘ ܘܥܠ ܐܦܝ ܚܝܝܟܘܢ ܡܬܐܠܨܝܢܢ ܘܐܢ ܡܬܒܝܐܝܢܢ ܡܛܠ ܕܐܢܬܘܢ ܬܬܒܝܐܘܢ ܘܬܗܘܐ ܒܟܘܢ ܚܦܝܛܘܬܐ ܕܬܤܝܒܪܘܢ ܐܢܘܢ ܠܚܫܐ ܗܢܘܢ ܕܐܦ ܚܢܢ ܚܫܝܢܢ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.7",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 1:7",
      "text": "ܘܤܒܪܢ ܕܥܠܝܟܘܢ ܫܪܝܪ ܗܘ ܝܕܥܝܢܢ ܓܝܪ ܕܐܢ ܫܘܬܦܝܢ ܐܢܬܘܢ ܒܚܫܐ ܫܘܬܦܝܢ ܐܢܬܘܢ ܐܦ ܒܒܘܝܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.8",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 1:8",
      "text": "ܨܒܝܢܢ ܕܝܢ ܕܬܕܥܘܢ ܐܚܝܢ ܥܠ ܐܘܠܨܢܐ ܕܗܘܐ ܠܢ ܒܐܤܝܐ ܕܪܘܪܒܐܝܬ ܐܬܐܠܨܢ ܝܬܝܪ ܡܢ ܚܝܠܢ ܥܕܡܐ ܕܩܪܝܒܝܢ ܗܘܘ ܚܝܝܢ ܠܡܬܛܠܩܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.9",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 1:9",
      "text": "ܘܥܠ ܢܦܫܢ ܦܤܩܢ ܡܘܬܐ ܕܠܐ ܢܗܘܐ ܠܢ ܬܘܟܠܢܐ ܥܠ ܢܦܫܢ ܐܠܐ ܥܠ ܐܠܗܐ ܗܘ ܕܡܩܝܡ ܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.10",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 1:10",
      "text": "ܗܘ ܕܡܢ ܡܘܬܐ ܚܤܝܢܐ ܦܪܩܢ ܘܬܘܒ ܡܤܒܪܝܢܢ ܕܦܪܩ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.11",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 1:11",
      "text": "ܒܡܥܕܪܢܘܬܐ ܕܒܥܘܬܟܘܢ ܕܥܠ ܐܦܝܢ ܕܬܗܘܐ ܡܘܗܒܬܗ ܕܠܘܬܢ ܛܝܒܘܬܐ ܕܥܒܝܕܐ ܒܐܦܝ ܤܓܝܐܐ ܘܤܓܝܐܐ ܢܘܕܘܢ ܠܗ ܥܠ ܐܦܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.12",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 1:12",
      "text": "ܫܘܒܗܪܢ ܓܝܪ ܗܢܘ ܤܗܕܘܬܐ ܕܪܥܝܢܢ ܕܒܦܫܝܛܘܬܐ ܘܒܕܟܝܘܬܐ ܘܒܛܝܒܘܬܐ ܕܐܠܗܐ ܐܬܗܦܟܢ ܒܥܠܡܐ ܘܠܐ ܒܚܟܡܬܐ ܕܦܓܪܐ ܘܝܬܝܪܐܝܬ ܠܘܬܟܘܢ ܕܝܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.13",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 1:13",
      "text": "ܠܐ ܗܘܐ ܐܚܪܢܝܢ ܟܬܒܝܢܢ ܠܟܘܢ ܐܠܐ ܐܝܠܝܢ ܕܝܕܥܝܢ ܐܢܬܘܢ ܐܦ ܡܫܬܘܕܥܝܢ ܐܢܬܘܢ ܬܟܝܠ ܐܢܐ ܕܝܢ ܕܥܕܡܐ ܠܐܚܪܝܬܐ ܬܫܬܘܕܥܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.14",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 1:14",
      "text": "ܐܝܟܢܐ ܕܐܦ ܐܫܬܘܕܥܬܘܢ ܩܠܝܠ ܡܢ ܤܓܝ ܕܫܘܒܗܪܟܘܢ ܚܢܢ ܐܝܟ ܕܐܦ ܐܢܬܘܢ ܕܝܠܢ ܒܝܘܡܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.15",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 1:15",
      "text": "ܘܒܗܢܐ ܬܘܟܠܢܐ ܨܒܐ ܗܘܝܬ ܡܢ ܩܕܝܡ ܕܐܬܐ ܠܘܬܟܘܢ ܕܐܥܝܦܐܝܬ ܬܩܒܠܘܢ ܛܝܒܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.16",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 1:16",
      "text": "ܘܐܥܒܪ ܥܠܝܟܘܢ ܠܡܩܕܘܢܝܐ ܘܬܘܒ ܡܢ ܡܩܕܘܢܝܐ ܠܘܬܟܘܢ ܐܬܐ ܘܐܢܬܘܢ ܬܠܘܘܢܢܝ ܠܝܗܘܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.17",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 1:17",
      "text": "ܗܕܐ ܗܟܝܠ ܕܐܬܪܥܝܬ ܠܡܐ ܐܝܟ ܡܤܪܗܒܐ ܐܬܪܥܝܬ ܐܘ ܕܠܡܐ ܕܒܤܪ ܐܢܝܢ ܐܝܠܝܢ ܕܡܬܪܥܐ ܐܢܐ ܡܛܠ ܕܘܠܐ ܗܘܐ ܕܢܗܘܐ ܒܗܝܢ ܐܝܢ ܐܝܢ ܘܠܐ ܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.18",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "2 Corinthians 1:18",
      "text": "ܡܗܝܡܢ ܗܘ ܐܠܗܐ ܕܠܐ ܗܘܬ ܡܠܬܢ ܕܠܘܬܟܘܢ ܐܝܢ ܘܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.19",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "2 Corinthians 1:19",
      "text": "ܒܪܗ ܓܝܪ ܕܐܠܗܐ ܝܫܘܥ ܡܫܝܚܐ ܗܘ ܕܒܐܝܕܢ ܐܬܟܪܙ ܠܟܘܢ ܒܝ ܘܒܤܠܘܢܘܤ ܘܒܛܝܡܬܐܘܤ ܠܐ ܗܘܐ ܐܝܢ ܘܠܐ ܐܠܐ ܐܝܢ ܗܘܐ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.20",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "2 Corinthians 1:20",
      "text": "ܟܠܗܘܢ ܓܝܪ ܡܘܠܟܢܘܗܝ ܕܐܠܗܐ ܒܗ ܗܘ ܒܡܫܝܚܐ ܐܝܢ ܗܘܘ ܡܛܠ ܗܢܐ ܒܐܝܕܗ ܝܗܒܝܢܢ ܐܡܝܢ ܠܬܫܒܘܚܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.21",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "2 Corinthians 1:21",
      "text": "ܐܠܗܐ ܗܘ ܕܝܢ ܡܫܪܪ ܠܢ ܥܡܟܘܢ ܒܡܫܝܚܐ ܗܘ ܕܗܘ ܡܫܚܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.22",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "2 Corinthians 1:22",
      "text": "ܘܚܬܡܢ ܘܝܗܒ ܪܗܒܘܢܐ ܕܪܘܚܗ ܒܠܒܘܬܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.23",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "2 Corinthians 1:23",
      "text": "ܐܢܐ ܕܝܢ ܠܐܠܗܐ ܡܤܗܕ ܐܢܐ ܥܠ ܢܦܫܝ ܕܡܛܠ ܕܚܐܤ ܐܢܐ ܥܠܝܟܘܢ ܠܐ ܐܬܝܬ ܠܩܘܪܢܬܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.1.24",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "2 Corinthians 1:24",
      "text": "ܠܐ ܗܘܐ ܡܛܠ ܕܡܪܝ ܗܝܡܢܘܬܟܘܢ ܚܢܢ ܐܠܐ ܡܥܕܪܢܐ ܚܢܢ ܕܚܕܘܬܟܘܢ ܒܗܝܡܢܘܬܐ ܗܘ ܓܝܪ ܩܝܡܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    }
  ]
