  "verses": [
    {
      "id": "peshitta:second-corinthians.4.1",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 4:1",
      "text": "ܡܛܠ ܗܢܐ ܠܐ ܡܐܢܐ ܠܢ ܒܬܫܡܫܬܐ ܗܕܐ ܕܐܚܝܕܝܢܢ ܐܝܟ ܪܚܡܐ ܕܗܘܘ ܥܠܝܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-corinthians.4.2",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 4:2",
      "text": "ܐܠܐ ܐܤܠܝܢܢ ܟܤܝܬܗ ܕܒܗܬܬܐ ܘܠܐ ܡܗܠܟܝܢܢ ܒܚܪܥܘܬܐ ܘܠܐ ܢܟܠܝܢܢ ܡܠܬܗ ܕܐܠܗܐ ܐܠܐ ܒܓܠܝܘܬܐ ܕܫܪܪܐ ܡܚܘܝܢܢ ܢܦܫܢ ܠܟܠܗܘܢ ܪܥܝܢܐ ܕܒܢܝܢܫܐ ܩܕܡ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.4.3",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 4:3",
      "text": "ܘܐܢ ܕܝܢ ܡܟܤܝ ܗܘ ܐܘܢܓܠܝܘܢ ܕܝܠܢ ܠܐܝܠܝܢ ܕܐܒܕܝܢ ܗܘ ܡܟܤܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.4.4",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 4:4",
      "text": "ܐܝܠܝܢ ܕܐܠܗܗ ܕܥܠܡܐ ܗܢܐ ܥܘܪ ܡܕܥܝܗܘܢ ܥܠ ܕܠܐ ܡܗܝܡܢܝܢ ܕܠܐ ܢܕܢܚ ܠܗܘܢ ܢܘܗܪܗ ܕܐܘܢܓܠܝܘܢ ܕܫܘܒܚܗ ܕܡܫܝܚܐ ܕܗܘܝܘ ܕܡܘܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.4.5",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 4:5",
      "text": "ܠܐ ܗܘܐ ܓܝܪ ܢܦܫܢ ܡܟܪܙܝܢܢ ܐܠܐ ܠܡܫܝܚܐ ܝܫܘܥ ܡܪܢ ܠܢܦܫܢ ܕܝܢ ܕܥܒܕܝܟܘܢ ܚܢܢ ܡܛܠ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.4.6",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 4:6",
      "text": "ܡܛܠ ܕܐܠܗܐ ܗܘ ܕܐܡܪ ܕܡܢ ܚܫܘܟܐ ܢܘܗܪܐ ܢܕܢܚ ܗܘ ܕܢܚ ܒܠܒܘܬܢ ܕܢܬܢܗܪ ܒܝܕܥܬܐ ܕܫܘܒܚܗ ܕܐܠܗܐ ܒܦܪܨܘܦܗ ܕܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.4.7",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 4:7",
      "text": "ܐܝܬ ܠܢ ܕܝܢ ܤܝܡܬܐ ܗܕܐ ܒܡܐܢܐ ܕܚܨܦܐ ܕܪܒܘܬܐ ܕܚܝܠܐ ܡܢ ܐܠܗܐ ܬܗܘܐ ܘܠܐ ܡܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.4.8",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 4:8",
      "text": "ܒܟܠܡܕܡ ܓܝܪ ܡܬܐܠܨܝܢܢ ܐܠܐ ܠܐ ܡܬܚܢܩܝܢܢ ܡܬܛܪܦܝܢܢ ܐܠܐ ܠܐ ܚܝܒܝܢ ܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.4.9",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 4:9",
      "text": "ܡܬܪܕܦܝܢܢ ܐܠܐ ܠܐ ܡܫܬܒܩܝܢܢ ܡܤܬܚܦܝܢܢ ܐܠܐ ܠܐ ܐܒܕܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.4.10",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 4:10",
      "text": "ܒܟܠܙܒܢ ܡܝܬܘܬܗ ܕܝܫܘܥ ܒܦܓܪܝܢ ܫܩܝܠܝܢܢ ܕܐܦ ܚܝܘܗܝ ܕܝܫܘܥ ܒܦܓܪܝܢ ܢܬܓܠܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.4.11",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 4:11",
      "text": "ܐܢ ܚܢܢ ܓܝܪ ܚܝܐ ܠܡܘܬܐ ܡܫܬܠܡܝܢܢ ܡܛܠ ܝܫܘܥ ܗܟܢܐ ܐܦ ܚܝܘܗܝ ܕܝܫܘܥ ܢܬܓܠܘܢ ܒܦܓܪܢ ܗܢܐ ܕܡܐܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.4.12",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 4:12",
      "text": "ܗܫܐ ܡܘܬܐ ܒܢ ܡܬܚܦܛ ܘܚܝܐ ܒܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.4.13",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 4:13",
      "text": "ܐܦ ܚܢܢ ܗܟܝܠ ܕܚܕܐ ܗܝ ܪܘܚܐ ܕܗܝܡܢܘܬܐ ܐܝܬ ܠܢ ܐܝܟ ܕܟܬܝܒ ܕܗܝܡܢܬ ܡܛܠ ܗܢܐ ܐܦ ܡܠܠܬ ܡܗܝܡܢܝܢܢ ܡܛܠ ܗܢܐ ܐܦ ܡܡܠܠܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.4.14",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 4:14",
      "text": "ܘܝܕܥܝܢܢ ܕܗܘ ܡܢ ܕܐܩܝܡ ܠܡܪܢ ܝܫܘܥ ܐܦ ܠܢ ܒܝܕ ܝܫܘܥ ܢܩܝܡ ܘܢܩܪܒܢ ܥܡܟܘܢ ܠܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.4.15",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 4:15",
      "text": "ܟܠܡܕܡ ܓܝܪ ܡܛܠܬܟܘܢ ܗܘ ܕܟܕ ܡܬܝܬܪܐ ܛܝܒܘܬܐ ܒܝܕ ܤܓܝܐܐ ܬܤܓܐ ܬܘܕܝܬܐ ܠܫܘܒܚܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.4.16",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 4:16",
      "text": "ܡܛܠ ܗܢܐ ܠܐ ܡܐܢܐ ܠܢ ܐܦ ܐܢ ܒܪܢܫܢ ܓܝܪ ܒܪܝܐ ܡܬܚܒܠ ܐܠܐ ܕܡܢ ܠܓܘ ܡܬܚܕܬ ܝܘܡ ܡܢ ܝܘܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.4.17",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 4:17",
      "text": "ܐܘܠܨܢܗ ܓܝܪ ܕܙܒܢܐ ܗܢܐ ܟܕ ܛܒ ܙܥܘܪ ܘܩܠܝܠ ܫܘܒܚܐ ܪܒܐ ܕܠܐ ܤܟܐ ܠܥܠܡ ܥܠܡܝܢ ܡܛܝܒ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-corinthians.4.18",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "2 Corinthians 4:18",
      "text": "ܕܠܐ ܚܕܝܢܢ ܒܗܠܝܢ ܕܡܬܚܙܝܢ ܐܠܐ ܒܗܠܝܢ ܕܠܐ ܡܬܚܙܝܢ ܕܡܬܚܙܝܢ ܓܝܪ ܕܙܒܢܐ ܐܢܝܢ ܕܠܐ ܡܬܚܙܝܢ ܕܝܢ ܕܠܥܠܡ ܐܢܝܢ ܀",
      "paragraphStart": false
    }
