    {
      "id": "peshitta:second-corinthians.11.3",
      "translationId": "peshitta",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 11:3",
      "text": "ܕܚܠ ܐܢܐ ܕܝܢ ܕܠܡܐ ܐܝܟ ܕܐܛܥܝ ܚܘܝܐ ܠܚܘܐ ܒܢܟܝܠܘܬܗ ܗܟܢܐ ܢܬܚܒܠܘܢ ܪܥܝܢܝܟܘܢ ܡܢ ܦܫܝܛܘܬܐ ܕܠܘܬ ܡܫܝܚܐ ܀",
      "paragraphStart": false
