{
  "chapter": {
    "id": "peshitta:second-peter.1",
    "translationId": "peshitta",
    "bookSlug": "second-peter",
    "chapterNumber": 1,
    "referenceLabel": "2 Peter 1",
    "summary": "Source text for 2 Peter 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:second-peter.1.1",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "2 Peter 1:1",
      "text": "ܫܡܥܘܢ ܦܛܪܘܤ ܥܒܕܐ ܘܫܠܝܚܐ ܕܝܫܘܥ ܡܫܝܚܐ ܠܐܝܠܝܢ ܕܠܗܝܡܢܘܬܐ ܫܘܝܬ ܒܐܝܩܪܐ ܥܡܢ ܐܫܬܘܝܘ ܒܙܕܝܩܘܬܐ ܕܡܪܢ ܘܦܪܘܩܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-peter.1.2",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "2 Peter 1:2",
      "text": "ܛܝܒܘܬܐ ܘܫܠܡܐ ܢܤܓܐ ܠܟܘܢ ܒܫܘܘܕܥܐ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.1.3",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "2 Peter 1:3",
      "text": "ܐܝܟ ܡܢ ܕܟܠܗܝܢ ܐܝܠܝܢ ܕܐܝܬܝܗܝܢ ܕܚܝܠܐ ܐܠܗܝܐ ܠܘܬ ܚܝܐ ܘܕܚܠܬ ܐܠܗܐ ܝܗܒ ܒܝܕ ܫܘܘܕܥܐ ܕܗܘ ܕܩܪܐ ܠܢ ܒܬܫܒܘܚܬܐ ܕܝܠܗ ܘܡܝܬܪܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.1.4",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "2 Peter 1:4",
      "text": "ܕܒܐܝܕܝܗܝܢ ܫܘܘܕܝܐ ܪܘܪܒܐ ܘܝܩܝܪܐ ܠܟܘܢ ܝܗܒ ܕܒܝܕ ܗܠܝܢ ܬܗܘܘܢ ܫܘܬܦܐ ܕܟܝܢܐ ܐܠܗܝܐ ܟܕ ܥܪܩܝܢ ܐܢܬܘܢ ܡܢ ܚܒܠܐ ܕܪܓܝܓܬܐ ܕܒܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.1.5",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "2 Peter 1:5",
      "text": "ܘܗܝ ܕܝܢ ܗܕܐ ܟܕ ܫܩܠܛܥܢܐ ܟܠܗ ܡܥܠܝܢ ܐܢܬܘܢ ܐܘܤܦܘ ܥܠ ܗܝܡܢܘܬܟܘܢ ܡܝܬܪܘܬܐ ܥܠ ܕܝܢ ܡܝܬܪܘܬܐ ܝܕܥܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.1.6",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "2 Peter 1:6",
      "text": "ܥܠ ܕܝܢ ܝܕܥܬܐ ܡܚܡܤܢܢܘܬܐ ܥܠ ܕܝܢ ܡܚܡܤܢܢܘܬܐ ܡܤܝܒܪܢܘܬܐ ܥܠ ܕܝܢ ܡܤܝܒܪܢܘܬܐ ܕܚܠܬ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.1.7",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "2 Peter 1:7",
      "text": "ܥܠ ܕܝܢ ܕܚܠܬ ܐܠܗܐ ܪܚܡܬ ܐܚܘܬܐ ܥܠ ܕܝܢ ܪܚܡܬ ܐܚܘܬܐ ܚܘܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.1.8",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "2 Peter 1:8",
      "text": "ܗܠܝܢ ܓܝܪ ܟܕ ܫܟܝܚܢ ܠܟܘܢ ܘܝܬܝܪܢ ܠܐ ܗܘܐ ܒܛܝܠܐ ܐܦܠܐ ܕܠܐ ܦܐܪܐ ܡܩܝܡܢ ܠܟܘܢ ܒܫܘܘܕܥܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.1.9",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "2 Peter 1:9",
      "text": "ܗܘ ܓܝܪ ܕܠܐ ܫܟܝܚܢ ܠܗ ܗܠܝܢ ܤܡܝܐ ܐܝܬܘܗܝ ܕܠܐ ܚܙܐ ܕܛܥܐ ܕܘܟܝܐ ܕܚܛܗܘܗܝ ܩܕܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.1.10",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "2 Peter 1:10",
      "text": "ܘܥܠ ܗܝ ܝܬܝܪܐܝܬ ܐܚܝ ܝܨܦܘ ܕܒܝܕ ܥܒܕܝܟܘܢ ܛܒܐ ܩܪܝܬܟܘܢ ܘܓܒܝܬܟܘܢ ܡܫܪܪܬܐ ܬܥܒܕܘܢ ܟܕ ܓܝܪ ܗܠܝܢ ܥܒܕܝܢ ܐܢܬܘܢ ܠܐ ܡܬܘܡ ܡܫܬܪܥܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.1.11",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "2 Peter 1:11",
      "text": "ܗܟܢܐ ܓܝܪ ܥܬܝܪܐܝܬ ܡܬܝܗܒܐ ܠܟܘܢ ܡܥܠܬܐ ܕܡܠܟܘܬܐ ܕܠܥܠܡ ܕܡܪܢ ܘܦܪܘܩܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.1.12",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "2 Peter 1:12",
      "text": "ܘܥܠ ܗܕܐ ܠܐ ܡܡܐܢ ܐܢܐ ܡܢ ܕܡܥܗܕ ܐܢܐ ܠܟܘܢ ܐܡܝܢܐܝܬ ܥܠ ܗܠܝܢ ܟܕ ܛܒ ܐܦ ܝܕܥܝܢ ܐܢܬܘܢ ܘܤܡܝܟܝܢ ܐܢܬܘܢ ܥܠ ܫܪܪܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.1.13",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "2 Peter 1:13",
      "text": "ܕܟܐܢܐ ܕܝܢ ܐܤܬܒܪܬ ܠܝ ܕܟܡܐ ܕܐܝܬܝ ܒܦܓܪܐ ܗܢܐ ܐܥܝܪܟܘܢ ܒܥܘܗܕܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.1.14",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "2 Peter 1:14",
      "text": "ܟܕ ܝܕܥ ܐܢܐ ܕܥܘܢܕܢܐ ܕܦܓܪܝ ܒܥܓܠ ܗܘܐ ܐܝܟܢܐ ܕܐܦ ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܐܘܕܥܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.1.15",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "2 Peter 1:15",
      "text": "ܝܨܦ ܐܢܐ ܕܝܢ ܕܐܦ ܐܡܝܢܐܝܬ ܗܘܐ ܐܝܬ ܠܟܘܢ ܕܐܦ ܡܢ ܒܬܪ ܡܦܩܢܐ ܕܝܠܝ ܥܘܗܕܢܐ ܕܗܠܝܢ ܬܗܘܘܢ ܥܒܕܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.1.16",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "2 Peter 1:16",
      "text": "ܠܐ ܗܘܐ ܓܝܪ ܟܕ ܒܬܪ ܡܬܠܐ ܕܥܒܝܕܝܢ ܒܐܘܡܢܘܬܐ ܐܙܠܝܢܢ ܐܘܕܥܢܟܘܢ ܚܝܠܗ ܘܡܐܬܝܬܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܐܠܐ ܟܕ ܚܙܝܐ ܗܘܝܢ ܕܪܒܘܬܐ ܕܝܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.1.17",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "2 Peter 1:17",
      "text": "ܟܕ ܓܝܪ ܢܤܒ ܡܢ ܐܠܗܐ ܐܒܐ ܐܝܩܪܐ ܘܬܫܒܘܚܬܐ ܟܕ ܩܠܐ ܐܬܐ ܠܗ ܕܐܝܟ ܗܢܐ ܡܢ ܬܫܒܘܚܬܐ ܦܐܝܬ ܒܪܒܘܬܗ ܕܗܢܘ ܒܪܝ ܗܘ ܚܒܝܒܐ ܗܘ ܕܒܗ ܐܨܛܒܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.1.18",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "2 Peter 1:18",
      "text": "ܐܦ ܚܢܢ ܠܗ ܠܗܢܐ ܩܠܐ ܫܡܥܢܢ ܡܢ ܫܡܝܐ ܕܐܬܐ ܠܗ ܟܕ ܐܝܬܝܢ ܗܘܝܢ ܥܡܗ ܒܛܘܪܐ ܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.1.19",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "2 Peter 1:19",
      "text": "ܘܐܝܬ ܠܢ ܕܫܪܝܪܐ ܐܦ ܡܠܬܐ ܕܢܒܝܘܬܐ ܗܝ ܕܫܦܝܪ ܥܒܕܝܢ ܐܢܬܘܢ ܟܕ ܒܗ ܚܝܪܝܢ ܐܢܬܘܢ ܐܝܟ ܕܒܫܪܓܐ ܕܡܢܗܪ ܒܐܬܪܐ ܥܡܘܛܐ ܥܕܡܐ ܕܐܝܡܡܐ ܢܢܗܪ ܘܫܡܫܐ ܢܕܢܚ ܒܠܒܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.1.20",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "2 Peter 1:20",
      "text": "ܟܕ ܗܕܐ ܠܘܩܕܡ ܝܕܥܝܢ ܐܢܬܘܢ ܕܟܠ ܢܒܝܘܬܐ ܫܪܝܐ ܕܟܬܒܐ ܕܝܠܗ ܠܐ ܗܘܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.1.21",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "2 Peter 1:21",
      "text": "ܠܐ ܗܘܐ ܓܝܪ ܒܨܒܝܢܐ ܕܒܪܢܫܐ ܐܬܬ ܡܢ ܡܬܘܡ ܢܒܝܘܬܐ ܐܠܐ ܟܕ ܡܢ ܪܘܚܐ ܩܕܝܫܐ ܡܬܢܓܕܝܢ ܡܠܠܘ ܩܕܝܫܐ ܒܢܝܢܫܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    }
  ]
}
