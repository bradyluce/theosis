    "referenceLabel": "2 Peter 2",
    "summary": "Source text for 2 Peter 2 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:second-peter.2.1",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "2 Peter 2:1",
      "text": "ܗܘܘ ܕܝܢ ܐܦ ܢܒܝܐ ܕܓܠܐ ܒܥܡܐ ܐܝܟ ܕܐܦ ܒܟܘܢ ܢܗܘܘܢ ܡܠܦܢܐ ܕܓܠܐ ܐܝܠܝܢ ܕܡܥܠܝܢ ܗܪܤܝܤ ܕܐܒܕܢܐ ܘܒܡܪܐ ܕܙܒܢ ܐܢܘܢ ܟܦܪܝܢ ܟܕ ܡܝܬܝܢ ܥܠ ܢܦܫܗܘܢ ܐܒܕܢܐ ܡܤܪܗܒܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-peter.2.2",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "2 Peter 2:2",
      "text": "ܘܤܓܝܐܐ ܢܐܙܠܘܢ ܒܬܪ ܛܢܦܘܬܐ ܕܝܠܗܘܢ ܗܠܝܢ ܕܡܛܠܬܗܘܢ ܐܘܪܚܐ ܕܫܪܪܐ ܬܬܓܕܦ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.3",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "2 Peter 2:3",
      "text": "ܘܒܥܠܘܒܘܬܐ ܘܒܡܠܐ ܕܒܕܝܐ ܢܬܬܓܪܘܢ ܒܟܘܢ ܗܠܝܢ ܕܕܝܢܗܘܢ ܡܢ ܩܕܝܡ ܠܐ ܒܛܠ ܘܐܒܕܢܗܘܢ ܠܐ ܢܐܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.4",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "2 Peter 2:4",
      "text": "ܐܢ ܓܝܪ ܐܠܗܐ ܥܠ ܡܠܐܟܐ ܕܚܛܘ ܠܐ ܚܤ ܐܠܐ ܒܫܫܠܬܐ ܕܥܡܛܢܐ ܥܓܢ ܐܢܘܢ ܒܬܚܬܝܬܐ ܘܐܫܠܡ ܐܢܘܢ ܕܢܬܢܛܪܘܢ ܠܕܝܢܐ ܕܫܘܢܩܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.5",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "2 Peter 2:5",
      "text": "ܘܥܠ ܥܠܡܐ ܩܕܡܝܐ ܠܐ ܚܤ ܐܠܐ ܠܢܘܚ ܕܬܡܢܝܐ ܟܪܘܙܐ ܕܟܐܢܘܬܐ ܢܛܪ ܟܕ ܛܘܦܢܐ ܥܠ ܥܠܡܐ ܕܪܫܝܥܐ ܐܝܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.6",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "2 Peter 2:6",
      "text": "ܘܟܕ ܠܡܕܝܢܬܐ ܕܤܕܘܡ ܘܕܥܡܘܪܐ ܐܘܩܕ ܘܒܗܦܘܟܝܐ ܚܝܒ ܐܢܝܢ ܟܕ ܬܚܘܝܬܐ ܠܪܫܝܥܐ ܕܥܬܝܕܝܢ ܕܢܗܘܘܢ ܤܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.7",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "2 Peter 2:7",
      "text": "ܐܦ ܠܠܘܛ ܙܕܝܩܐ ܕܡܬܩܦܚ ܗܘܐ ܡܢ ܗܘܦܟܐ ܕܒܛܢܦܘܬܐ ܕܗܠܝܢ ܕܕܠܐ ܢܡܘܤܐ ܐܝܬܝܗܘܢ ܗܘܘ ܦܨܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.8",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "2 Peter 2:8",
      "text": "ܒܚܙܬܐ ܓܝܪ ܘܒܫܡܥܐ ܟܕ ܥܡܪ ܗܘܐ ܟܐܢܐ ܗܘ ܒܝܢܬܗܘܢ ܝܘܡ ܡܢ ܝܘܡ ܠܢܦܫܗ ܙܕܝܩܬܐ ܒܥܒܕܐ ܕܠܐ ܢܡܘܤ ܡܫܢܩ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.9",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "2 Peter 2:9",
      "text": "ܝܕܥ ܗܘ ܡܪܝܐ ܕܢܦܪܘܩ ܡܢ ܐܘܠܨܢܐ ܠܐܝܠܝܢ ܕܕܚܠܝܢ ܠܗ ܠܥܘܠܐ ܕܝܢ ܠܝܘܡܐ ܕܕܝܢܐ ܟܕ ܡܫܬܢܩܝܢ ܢܛܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.10",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "2 Peter 2:10",
      "text": "ܝܬܝܪܐܝܬ ܕܝܢ ܠܐܝܠܝܢ ܕܒܬܪ ܒܤܪܐ ܒܪܓܬܐ ܕܛܡܐܘܬܐ ܐܙܠܝܢ ܘܥܠ ܡܪܘܬܐ ܡܒܤܪܝܢ ܡܪܚܐ ܘܡܫܩܠܐ ܕܡܢ ܬܫܒܘܚܬܐ ܠܐ ܙܝܥܝܢ ܟܕ ܡܓܕܦܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.11",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "2 Peter 2:11",
      "text": "ܐܝܟܐ ܕܡܠܐܟܐ ܕܒܚܝܠܐ ܘܒܥܘܫܢܐ ܪܘܪܒܝܢ ܡܢܗܘܢ ܠܐ ܡܝܬܝܢ ܥܠܝܗܘܢ ܡܢ ܡܪܝܐ ܕܝܢܐ ܕܓܘܕܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.12",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "2 Peter 2:12",
      "text": "ܗܠܝܢ ܕܝܢ ܕܐܝܟ ܚܝܘܬܐ ܚܪܫܬܐ ܗܘܘ ܒܟܝܢܐ ܠܚܪܒܐ ܘܠܚܒܠܐ ܟܕ ܒܐܝܠܝܢ ܕܠܐ ܝܕܥܝܢ ܡܓܕܦܝܢ ܒܚܒܠܐ ܕܝܠܗܘܢ ܢܬܚܒܠܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.13",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "2 Peter 2:13",
      "text": "ܟܕ ܐܝܠܝܢ ܕܗܘܐ ܒܗܘܢ ܥܘܠܐ ܐܓܪܐ ܕܥܘܠܐ ܗܢܝܘܬܐ ܚܫܝܒ ܠܗܘܢ ܒܘܤܡܐ ܕܗܘܐ ܒܐܝܡܡܐ ܡܟܬܡܐ ܘܡܠܝܝ ܡܘܡܐ ܕܟܕ ܡܬܒܤܡܝܢ ܒܢܝܚܬܗܘܢ ܡܬܦܢܩܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.14",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "2 Peter 2:14",
      "text": "ܟܕ ܥܝܢܐ ܐܝܬ ܠܗܘܢ ܕܡܠܝܢ ܓܘܪܐ ܘܚܛܗܐ ܕܠܐ ܡܘܦܝܢ ܟܕ ܡܫܕܠܝܢ ܠܢܦܫܬܐ ܕܠܐ ܤܡܝܟܢ ܘܠܒܐ ܕܡܕܪܫ ܒܥܠܘܒܘܬܐ ܐܝܬ ܠܗܘܢ ܒܢܝܐ ܕܠܘܛܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.15",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "2 Peter 2:15",
      "text": "ܕܟܕ ܫܒܩܘ ܐܘܪܚܐ ܬܪܝܨܬܐ ܫܓܘ ܘܐܙܠܘ ܒܐܘܪܚܐ ܕܒܠܥܡ ܒܪ ܒܥܘܪ ܗܘ ܕܐܓܪܐ ܕܥܘܠܐ ܐܚܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.16",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "2 Peter 2:16",
      "text": "ܡܟܤܢܘܬܐ ܕܝܢ ܕܗܘܬ ܠܗ ܠܡܬܥܒܪܢܘܬܗ ܐܬܢܐ ܕܠܐ ܩܠܐ ܕܒܩܠܐ ܕܒܢܝܢܫܐ ܡܠܠܬ ܟܠܬ ܠܫܛܝܘܬܗ ܕܢܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.17",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "2 Peter 2:17",
      "text": "ܗܠܝܢ ܐܢܘܢ ܡܥܝܢܐ ܕܠܐ ܡܝܐ ܥܢܢܐ ܕܡܢ ܥܠܥܠܐ ܡܬܪܕܦܢ ܗܠܝܢ ܕܥܡܛܢܐ ܕܚܫܘܟܐ ܢܛܝܪ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.18",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "2 Peter 2:18",
      "text": "ܟܕ ܓܝܪ ܓܘܢܚܐ ܕܤܪܝܩܘܬܐ ܡܡܠܠܝܢ ܡܫܕܠܝܢ ܒܪܓܝܓܬܐ ܛܢܦܬܐ ܕܒܤܪܐ ܠܐܝܠܝܢ ܕܒܡܠܐ ܩܠܝܠ ܥܪܩܝܢ ܡܢ ܐܝܠܝܢ ܕܒܛܥܝܘܬܐ ܡܬܗܦܟܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.19",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "2 Peter 2:19",
      "text": "ܘܚܐܪܘܬܐ ܠܗܘܢ ܡܫܬܘܕܝܢ ܟܕ ܗܢܘܢ ܥܒܕܐ ܐܝܬܝܗܘܢ ܕܚܒܠܐ ܠܗܘ ܓܝܪ ܡܕܡ ܕܐܢܫ ܙܟܐ ܠܗ ܠܗܢܐ ܐܦ ܡܫܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.20",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "2 Peter 2:20",
      "text": "ܐܢ ܓܝܪ ܟܕ ܥܪܩܘ ܡܢ ܛܢܦܘܬܗ ܕܥܠܡܐ ܒܫܘܘܕܥܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܘܦܪܘܩܢ ܒܗܝܢ ܒܗܠܝܢ ܟܕ ܡܬܥܪܙܠܝܢ ܬܘܒ ܡܙܕܟܝܢ ܗܘܬ ܠܗ ܚܪܬܗܘܢ ܕܒܝܫܐ ܡܢ ܩܕܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.21",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "2 Peter 2:21",
      "text": "ܦܩܚ ܗܘܐ ܠܗܘܢ ܓܝܪ ܕܠܐ ܢܫܬܘܕܥܘܢ ܠܐܘܪܚܐ ܕܙܕܝܩܘܬܐ ܐܘ ܕܟܕ ܐܫܬܘܕܥܘ ܠܒܬܪܐ ܢܗܦܟܘܢ ܡܢ ܦܘܩܕܢܐ ܩܕܝܫܐ ܕܐܫܬܠܡ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.2.22",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "2 Peter 2:22",
      "text": "ܓܕܫ ܠܗܘܢ ܕܝܢ ܗܠܝܢ ܕܡܬܠܐ ܫܪܝܪܐ ܕܟܠܒܐ ܕܗܦܟ ܥܠ ܬܝܘܒܗ ܘܚܙܝܪܬܐ ܕܤܚܬ ܒܥܘܪܓܠܐ ܕܤܝܢܐ ܀",
      "paragraphStart": false
    }
  ]
