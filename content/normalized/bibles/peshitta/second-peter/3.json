    "summary": "Source text for 2 Peter 3 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:second-peter.3.1",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "2 Peter 3:1",
      "text": "ܗܕܐ ܡܢ ܟܕܘ ܚܒܝܒܝ ܐܓܪܬܐ ܕܬܪܬܝܢ ܟܬܒ ܐܢܐ ܠܟܘܢ ܗܠܝܢ ܕܒܗܝܢ ܡܥܝܪ ܐܢܐ ܒܥܘܗܕܢܐ ܠܪܥܝܢܟܘܢ ܫܦܝܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-peter.3.2",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "2 Peter 3:2",
      "text": "ܕܬܬܥܗܕܘܢ ܠܡܠܐ ܕܩܕܡ ܐܬܐܡܪ ܡܢ ܢܒܝܐ ܩܕܝܫܐ ܘܠܦܘܩܕܢܗ ܕܡܪܢ ܘܦܪܘܩܢ ܕܒܝܕ ܫܠܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.3.3",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "2 Peter 3:3",
      "text": "ܟܕ ܗܕܐ ܠܘܩܕܡ ܝܕܥܝܢ ܐܢܬܘܢ ܕܢܐܬܘܢ ܒܚܪܬܐ ܕܝܘܡܬܐ ܡܒܙܚܢܐ ܕܡܒܙܚܝܢ ܟܕ ܐܝܟ ܪܓܝܓܬܐ ܕܝܠܗܘܢ ܡܗܠܟܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.3.4",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "2 Peter 3:4",
      "text": "ܘܐܡܪܝܢ ܕܐܝܟܐ ܐܝܬܘܗܝ ܡܘܠܟܢܐ ܕܡܐܬܝܬܗ ܡܢ ܟܕ ܓܝܪ ܐܒܗܬܢ ܫܟܒܘ ܟܠܡܕܡ ܗܟܢܐ ܡܟܬܪ ܡܢ ܫܘܪܝܗ ܕܒܪܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.3.5",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "2 Peter 3:5",
      "text": "ܛܥܝܐ ܠܗܘܢ ܓܝܪ ܗܕܐ ܟܕ ܨܒܝܢ ܕܫܡܝܐ ܐܝܬܝܗܘܢ ܗܘܘ ܡܢ ܩܕܝܡ ܘܐܪܥܐ ܡܢ ܡܝܐ ܘܒܝܕ ܡܝܐ ܩܡܬ ܒܡܠܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.3.6",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "2 Peter 3:6",
      "text": "ܗܠܝܢ ܕܒܐܝܕܝܗܘܢ ܥܠܡܐ ܕܗܝܕܝܢ ܛܦ ܒܡܝܐ ܘܐܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.3.7",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "2 Peter 3:7",
      "text": "ܫܡܝܐ ܕܝܢ ܕܗܫܐ ܘܐܪܥܐ ܒܡܠܬܐ ܕܝܠܗ ܐܤܝܢܝܢ ܟܕ ܠܢܘܪܐ ܡܬܢܛܪܝܢ ܠܝܘܡܐ ܕܕܝܢܐ ܘܕܐܒܕܢܐ ܕܒܢܝܢܫܐ ܪܫܝܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.3.8",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "2 Peter 3:8",
      "text": "ܗܕܐ ܕܝܢ ܚܕܐ ܠܐ ܬܛܥܝܟܘܢ ܚܒܝܒܝ ܕܚܕ ܝܘܡܐ ܠܡܪܝܐ ܐܝܟ ܐܠܦ ܫܢܝܢ ܐܝܬܘܗܝ ܘܐܠܦ ܫܢܝܢ ܐܝܟ ܝܘܡܐ ܚܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.3.9",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "2 Peter 3:9",
      "text": "ܠܐ ܡܫܬܘܚܪ ܡܪܝܐ ܒܡܘܠܟܢܘܗܝ ܐܝܟ ܕܐܢܫܝܢ ܫܘܘܚܪܐ ܡܤܒܪܝܢ ܐܠܐ ܡܓܪ ܪܘܚܗ ܡܛܠܬܟܘܢ ܒܕܠܐ ܨܒܐ ܕܐܢܫ ܢܐܒܕ ܐܠܐ ܟܠܢܫ ܠܬܝܒܘܬܐ ܢܐܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.3.10",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "2 Peter 3:10",
      "text": "ܐܬܐ ܕܝܢ ܝܘܡܗ ܕܡܪܝܐ ܐܝܟ ܓܢܒܐ ܗܘ ܕܒܗ ܫܡܝܐ ܡܢ ܫܠܝ ܥܒܪܝܢ ܐܤܛܘܟܤܐ ܕܝܢ ܟܕ ܝܩܕܝܢ ܢܫܬܪܘܢ ܘܐܪܥܐ ܘܥܒܕܐ ܕܒܗ ܬܫܬܟܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.3.11",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "2 Peter 3:11",
      "text": "ܟܕ ܗܟܝܠ ܗܠܝܢ ܟܠܗܘܢ ܡܫܬܪܝܢ ܕܐܝܟ ܐܝܠܝܢ ܙܕܩ ܠܟܘܢ ܕܬܗܘܘܢ ܒܗܘܦܟܝܟܘܢ ܩܕܝܫܐ ܘܒܕܚܠܬ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.3.12",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "2 Peter 3:12",
      "text": "ܟܕ ܡܤܟܝܢ ܐܢܬܘܢ ܘܤܘܚܝܢ ܐܢܬܘܢ ܠܡܐܬܝܬܐ ܕܝܘܡܗ ܕܐܠܗܐ ܗܘ ܕܒܗ ܫܡܝܐ ܟܕ ܡܬܒܚܪܝܢ ܒܢܘܪܐ ܢܫܬܪܘܢ ܘܐܤܛܘܟܤܐ ܟܕ ܝܩܕܝܢ ܢܫܘܚܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.3.13",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "2 Peter 3:13",
      "text": "ܠܫܡܝܐ ܕܝܢ ܚܕܬܐ ܘܐܪܥܐ ܚܕܬܐ ܐܝܟ ܡܘܠܟܢܐ ܕܝܠܗ ܡܤܟܝܢܢ ܗܠܝܢ ܕܒܗܘܢ ܙܕܝܩܘܬܐ ܥܡܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.3.14",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "2 Peter 3:14",
      "text": "ܡܛܠ ܗܢܐ ܚܒܝܒܝ ܟܕ ܠܗܠܝܢ ܡܤܟܝܢ ܐܢܬܘܢ ܝܨܦܘ ܕܕܠܐ ܟܘܬܡܐ ܘܕܠܐ ܡܘܡܐ ܠܗ ܬܫܬܟܚܘܢ ܒܫܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.3.15",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "2 Peter 3:15",
      "text": "ܘܠܡܓܪܬ ܪܘܚܗ ܕܡܪܝܐ ܦܘܪܩܢܐ ܬܚܫܒܘܢ ܐܝܟܢܐ ܕܐܦ ܐܚܘܢ ܚܒܝܒܐ ܦܘܠܘܤ ܐܝܟ ܚܟܡܬܐ ܕܐܬܝܗܒܬ ܠܗ ܟܬܒ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.3.16",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "2 Peter 3:16",
      "text": "ܐܝܟܢܐ ܕܒܟܠܗܝܢ ܐܓܪܬܗ ܡܠܠ ܒܗܝܢ ܥܠ ܗܠܝܢ ܐܝܠܝܢ ܕܐܝܬ ܒܗܝܢ ܡܕܡ ܕܥܤܝܩ ܠܤܘܟܠܐ ܗܠܝܢ ܕܐܝܠܝܢ ܕܕܠܐ ܝܘܠܦܢܐ ܐܢܘܢ ܘܠܐ ܤܡܝܟܝܢ ܡܥܩܡܝܢ ܠܗܝܢ ܐܝܟ ܕܐܦ ܠܗܠܝܢ ܟܬܒܐ ܕܫܪܟܐ ܠܘܬ ܐܒܕܢܐ ܕܝܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.3.17",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "2 Peter 3:17",
      "text": "ܐܢܬܘܢ ܗܟܝܠ ܚܒܝܒܝ ܟܕ ܩܕܡܝܢ ܐܢܬܘܢ ܝܕܥܝܢ ܛܪܘ ܢܦܫܟܘܢ ܕܕܠܡܐ ܟܕ ܐܙܠܝܢ ܐܢܬܘܢ ܒܬܪ ܛܥܝܘܬܐ ܕܐܝܠܝܢ ܕܕܠܐ ܢܡܘܤ ܐܢܘܢ ܬܦܠܘܢ ܡܢ ܤܡܟܐ ܕܝܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-peter.3.18",
      "translationId": "peshitta",
      "bookSlug": "second-peter",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "2 Peter 3:18",
      "text": "ܗܘܝܬܘܢ ܕܝܢ ܡܬܪܒܝܢ ܒܛܝܒܘܬܐ ܘܒܝܕܥܬܐ ܕܡܪܢ ܘܦܪܘܩܢ ܝܫܘܥ ܡܫܝܚܐ ܘܕܐܠܗܐ ܐܒܐ ܕܠܗ ܬܫܒܘܚܬܐ ܐܦ ܗܫܐ ܘܒܟܠܙܒܢ ܘܠܝܘܡܝ ܥܠܡܐ ܐܡܝܢ ܀",
      "paragraphStart": false
    }
  ]
