{
  "chapter": {
    "id": "peshitta:second-john.1",
    "translationId": "peshitta",
    "bookSlug": "second-john",
    "chapterNumber": 1,
    "referenceLabel": "2 John 1",
    "summary": "Source text for 2 John 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:second-john.1.1",
      "translationId": "peshitta",
      "bookSlug": "second-john",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "2 John 1:1",
      "text": "ܩܫܝܫܐ ܠܓܒܝܬܐ ܩܘܪܝܐ ܘܠܒܢܝܗ ܐܝܠܝܢ ܕܐܢܐ ܡܚܒ ܐܢܐ ܒܫܪܪܐ ܠܐ ܗܘܐ ܕܝܢ ܐܢܐ ܒܠܚܘܕܝ ܐܠܐ ܟܠܗܘܢ ܐܝܠܝܢ ܕܝܕܥܘܗܝ ܠܫܪܪܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-john.1.2",
      "translationId": "peshitta",
      "bookSlug": "second-john",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "2 John 1:2",
      "text": "ܡܛܠ ܫܪܪܐ ܐܝܢܐ ܕܡܩܘܐ ܒܢ ܘܥܡܢ ܐܝܬܘܗܝ ܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-john.1.3",
      "translationId": "peshitta",
      "bookSlug": "second-john",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "2 John 1:3",
      "text": "ܬܗܘܐ ܥܡܢ ܛܝܒܘܬܐ ܘܪܚܡܐ ܘܫܠܡܐ ܡܢ ܐܠܗܐ ܐܒܐ ܘܡܢ ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܒܪܗ ܕܐܒܐ ܒܫܪܪܐ ܘܒܚܘܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-john.1.4",
      "translationId": "peshitta",
      "bookSlug": "second-john",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "2 John 1:4",
      "text": "ܚܕܝܬ ܤܓܝ ܕܐܫܟܚܬ ܡܢ ܒܢܝܟܝ ܕܡܗܠܟܝܢ ܒܫܪܪܐ ܐܝܟܢܐ ܕܦܘܩܕܢܐ ܢܤܒܢܢ ܡܢ ܐܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-john.1.5",
      "translationId": "peshitta",
      "bookSlug": "second-john",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "2 John 1:5",
      "text": "ܘܗܫܐ ܡܦܝܤ ܐܢܐ ܠܟܝ ܩܘܪܝܐ ܠܐ ܗܘܐ ܐܝܟ ܦܘܩܕܢܐ ܚܕܬܐ ܟܬܒ ܐܢܐ ܠܟܝ ܐܠܐ ܗܘ ܕܐܝܬ ܗܘܐ ܠܢ ܡܢ ܫܘܪܝܐ ܕܢܚܒ ܚܕ ܠܚܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-john.1.6",
      "translationId": "peshitta",
      "bookSlug": "second-john",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "2 John 1:6",
      "text": "ܘܗܢܐ ܐܝܬܘܗܝ ܚܘܒܐ ܕܢܗܠܟ ܐܝܟ ܦܘܩܕܢܘܗܝ ܗܢܐ ܦܘܩܕܢܐ ܐܝܬܘܗܝ ܐܝܟ ܡܐ ܕܫܡܥܬܘܢ ܡܢ ܫܘܪܝܐ ܕܒܗ ܗܘܝܬܘܢ ܡܗܠܟܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-john.1.7",
      "translationId": "peshitta",
      "bookSlug": "second-john",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "2 John 1:7",
      "text": "ܡܛܠ ܕܤܓܝܐܐ ܡܛܥܝܢܐ ܢܦܩܘ ܒܗ ܒܥܠܡܐ ܐܝܠܝܢ ܕܠܐ ܡܘܕܝܢ ܕܝܫܘܥ ܡܫܝܚܐ ܐܬܐ ܒܒܤܪ ܗܢܐ ܐܝܬܘܗܝ ܡܛܥܝܢܐ ܘܐܢܛܝܟܪܝܤܛܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-john.1.8",
      "translationId": "peshitta",
      "bookSlug": "second-john",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "2 John 1:8",
      "text": "ܐܙܕܗܪܘ ܒܢܦܫܟܘܢ ܕܠܐ ܬܘܒܕܘܢ ܡܕܡ ܕܦܠܚܬܘܢ ܐܠܐ ܐܓܪܐ ܡܫܠܡܢܐ ܬܬܦܪܥܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-john.1.9",
      "translationId": "peshitta",
      "bookSlug": "second-john",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "2 John 1:9",
      "text": "ܟܠ ܐܝܢܐ ܕܥܒܪ ܘܠܐ ܡܩܘܐ ܒܝܘܠܦܢܗ ܕܡܫܝܚܐ ܐܠܗܐ ܠܝܬ ܒܗ ܗܘ ܕܡܩܘܐ ܒܝܘܠܦܢܗ ܗܢܐ ܘܠܐܒܐ ܘܠܒܪܐ ܐܝܬ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-john.1.10",
      "translationId": "peshitta",
      "bookSlug": "second-john",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "2 John 1:10",
      "text": "ܐܢ ܐܢܫ ܐܬܐ ܠܘܬܟܘܢ ܘܗܢܐ ܝܘܠܦܢܐ ܠܐ ܡܝܬܐ ܠܐ ܬܩܒܠܘܢܝܗܝ ܒܒܝܬܐ ܘܚܕܝ ܠܟ ܠܐ ܬܐܡܪܘܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-john.1.11",
      "translationId": "peshitta",
      "bookSlug": "second-john",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "2 John 1:11",
      "text": "ܗܘ ܓܝܪ ܕܐܡܪ ܠܗ ܚܕܝ ܠܟ ܡܫܘܬܦ ܗܘ ܠܥܒܕܘܗܝ ܒܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-john.1.12",
      "translationId": "peshitta",
      "bookSlug": "second-john",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "2 John 1:12",
      "text": "ܟܕ ܤܓܝܐܬܐ ܐܝܬ ܗܘܐ ܠܝ ܠܡܟܬܒ ܠܟܘܢ ܠܐ ܒܥܝܬ ܕܒܝܕ ܟܪܛܝܤܐ ܘܕܝܘܬܐ ܐܠܐ ܡܤܒܪ ܐܢܐ ܕܐܬܐ ܠܘܬܟܘܢ ܘܦܘܡܐ ܠܘܬ ܦܘܡܐ ܢܡܠܠ ܕܚܕܘܬܐ ܕܝܠܢ ܬܗܘܐ ܡܫܡܠܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-john.1.13",
      "translationId": "peshitta",
      "bookSlug": "second-john",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "2 John 1:13",
      "text": "ܫܐܠܝܢ ܫܠܡܟܝ ܒܢܝܐ ܕܚܬܟܝ ܓܒܝܬܐ ܐܡܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
