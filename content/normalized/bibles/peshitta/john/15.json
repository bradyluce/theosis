{
  "chapter": {
    "id": "peshitta:john.15",
    "translationId": "peshitta",
    "bookSlug": "john",
    "chapterNumber": 15,
    "referenceLabel": "John 15",
    "summary": "Source text for John 15 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.15.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "John 15:1",
      "text": "ܐܢܐ ܐܢܐ ܓܦܬܐ ܕܫܪܪܐ ܘܐܒܝ ܗܘ ܦܠܚܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.15.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "John 15:2",
      "text": "ܟܠ ܫܒܫܬܐ ܕܒܝ ܦܐܪܐ ܠܐ ܝܗܒܐ ܫܩܠ ܠܗ ܘܐܝܕܐ ܕܝܗܒܐ ܦܐܪܐ ܡܕܟܐ ܠܗ ܕܦܐܪܐ ܤܓܝܐܐ ܬܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "John 15:3",
      "text": "ܐܢܬܘܢ ܡܢ ܟܕܘ ܕܟܝܢ ܐܢܬܘܢ ܡܛܠ ܡܠܬܐ ܕܡܠܠܬ ܥܡܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "John 15:4",
      "text": "ܩܘܘ ܒܝ ܘܐܢܐ ܒܟܘܢ ܐܝܟܢܐ ܕܫܒܫܬܐ ܠܐ ܡܫܟܚܐ ܕܬܬܠ ܦܐܪܐ ܡܢ ܢܦܫܗ ܐܠܐ ܡܩܘܝܐ ܒܓܦܬܐ ܗܟܢܐ ܐܦ ܠܐ ܐܢܬܘܢ ܐܠܐ ܬܩܘܘܢ ܒܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "John 15:5",
      "text": "ܐܢܐ ܐܢܐ ܓܦܬܐ ܘܐܢܬܘܢ ܫܒܫܬܐ ܡܢ ܕܡܩܘܐ ܒܝ ܘܐܢܐ ܒܗ ܗܢܐ ܡܝܬܐ ܦܐܪܐ ܤܓܝܐܐ ܡܛܠ ܕܕܠܐ ܐܢܐ ܠܐ ܡܫܟܚܝܢ ܐܢܬܘܢ ܠܡܥܒܕ ܡܕܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "John 15:6",
      "text": "ܐܠܐ ܕܝܢ ܐܢܫ ܡܩܘܐ ܒܝ ܡܫܬܕܐ ܠܒܪ ܐܝܟ ܫܒܫܬܐ ܕܝܒܫܐ ܘܠܩܛܝܢ ܪܡܝܢ ܠܗ ܒܢܘܪܐ ܕܬܐܩܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "John 15:7",
      "text": "ܐܢ ܕܝܢ ܬܩܘܘܢ ܒܝ ܘܡܠܝ ܢܩܘܝܢ ܒܟܘܢ ܟܠ ܡܐ ܕܬܨܒܘܢ ܠܡܫܐܠ ܢܗܘܐ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "John 15:8",
      "text": "ܒܗܕܐ ܡܫܬܒܚ ܐܒܐ ܕܦܐܪܐ ܤܓܝܐܐ ܬܝܬܘܢ ܘܬܗܘܘܢ ܬܠܡܝܕܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "John 15:9",
      "text": "ܐܝܟܢܐ ܕܐܚܒܢܝ ܐܒܝ ܐܦ ܐܢܐ ܐܚܒܬܟܘܢ ܩܘܘ ܒܪܚܡܬܝ ܕܝܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "John 15:10",
      "text": "ܐܢ ܦܘܩܕܢܝ ܬܛܪܘܢ ܬܩܘܘܢ ܒܚܘܒܐ ܕܝܠܝ ܐܝܟܢܐ ܕܐܢܐ ܢܛܪܬ ܦܘܩܕܢܘܗܝ ܕܐܒܝ ܘܡܩܘܐ ܐܢܐ ܒܚܘܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "John 15:11",
      "text": "ܗܠܝܢ ܡܠܠܬ ܥܡܟܘܢ ܕܚܕܘܬܝ ܬܗܘܐ ܒܟܘܢ ܘܬܫܬܡܠܐ ܚܕܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "John 15:12",
      "text": "ܗܢܘ ܦܘܩܕܢܝ ܕܬܚܒܘܢ ܚܕ ܠܚܕ ܐܝܟܢܐ ܕܐܢܐ ܐܚܒܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "John 15:13",
      "text": "ܚܘܒܐ ܕܪܒ ܡܢ ܗܢܐ ܠܝܬ ܕܐܢܫ ܢܦܫܗ ܢܤܝܡ ܚܠܦ ܪܚܡܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "John 15:14",
      "text": "ܐܢܬܘܢ ܪܚܡܝ ܐܢܬܘܢ ܐܢ ܬܥܒܕܘܢ ܟܠ ܕܡܦܩܕ ܐܢܐ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "John 15:15",
      "text": "ܠܐ ܡܟܝܠ ܩܪܐ ܐܢܐ ܠܟܘܢ ܥܒܕܐ ܡܛܠ ܕܥܒܕܐ ܠܐ ܝܕܥ ܡܢܐ ܥܒܕ ܡܪܗ ܪܚܡܝ ܕܝܢ ܩܪܝܬܟܘܢ ܡܛܠ ܕܟܠ ܕܫܡܥܬ ܡܢ ܐܒܝ ܐܘܕܥܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "John 15:16",
      "text": "ܠܐ ܗܘܐ ܐܢܬܘܢ ܓܒܝܬܘܢܢܝ ܐܠܐ ܐܢܐ ܗܘ ܓܒܝܬܟܘܢ ܘܤܡܬܟܘܢ ܕܐܦ ܐܢܬܘܢ ܬܐܙܠܘܢ ܬܝܬܘܢ ܦܐܪܐ ܘܦܐܪܝܟܘܢ ܢܩܘܘܢ ܕܟܠ ܕܬܫܐܠܘܢ ܠܐܒܝ ܒܫܡܝ ܢܬܠ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "John 15:17",
      "text": "ܗܠܝܢ ܡܦܩܕ ܐܢܐ ܠܟܘܢ ܕܬܚܒܘܢ ܚܕ ܠܚܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "John 15:18",
      "text": "ܘܐܢ ܥܠܡܐ ܤܢܐ ܠܟܘܢ ܕܥܘ ܕܩܕܡܝܟܘܢ ܠܝ ܤܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "John 15:19",
      "text": "ܘܐܠܘ ܡܢ ܥܠܡܐ ܗܘܝܬܘܢ ܥܠܡܐ ܠܕܝܠܗ ܪܚܡ ܗܘܐ ܐܠܐ ܠܐ ܗܘܝܬܘܢ ܡܢ ܥܠܡܐ ܐܢܐ ܓܝܪ ܓܒܝܬܟܘܢ ܡܢ ܥܠܡܐ ܡܛܠ ܗܢܐ ܤܢܐ ܠܟܘܢ ܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "John 15:20",
      "text": "ܥܗܕܘ ܡܠܬܐ ܕܐܢܐ ܐܡܪܬ ܠܟܘܢ ܕܠܝܬ ܥܒܕܐ ܕܪܒ ܡܢ ܡܪܗ ܐܢ ܠܝ ܪܕܦܘ ܐܦ ܠܟܘܢ ܢܪܕܦܘܢ ܘܐܢ ܡܠܬܝ ܢܛܪܘ ܐܦ ܕܝܠܟܘܢ ܢܛܪܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "John 15:21",
      "text": "ܐܠܐ ܗܠܝܢ ܟܠܗܝܢ ܢܥܒܕܘܢ ܒܟܘܢ ܡܛܠ ܫܡܝ ܕܝܠܝ ܕܠܐ ܝܕܥܝܢ ܠܡܢ ܕܫܕܪܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "John 15:22",
      "text": "ܐܠܘ ܐܢܐ ܠܐ ܐܬܝܬ ܡܠܠܬ ܥܡܗܘܢ ܠܝܬ ܗܘܬ ܠܗܘܢ ܚܛܝܬܐ ܗܫܐ ܕܝܢ ܠܝܬ ܠܗܘܢ ܥܠܬܐ ܥܠ ܐܦܝ ܚܛܝܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "John 15:23",
      "text": "ܡܢ ܕܠܝ ܤܢܐ ܘܐܦ ܠܐܒܝ ܤܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "John 15:24",
      "text": "ܘܐܠܘ ܥܒܕܐ ܠܐ ܥܒܕܬ ܠܥܢܝܗܘܢ ܐܝܠܝܢ ܕܐܢܫ ܐܚܪܝܢ ܠܐ ܥܒܕ ܠܝܬ ܗܘܐ ܠܗܘܢ ܚܛܝܬܐ ܗܫܐ ܕܝܢ ܘܚܙܘ ܘܤܢܘ ܐܦ ܠܝ ܘܐܦ ܠܐܒܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "John 15:25",
      "text": "ܕܬܬܡܠܐ ܡܠܬܐ ܕܟܬܝܒܐ ܒܢܡܘܤܗܘܢ ܕܤܢܐܘܢܝ ܡܓܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.26",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "John 15:26",
      "text": "ܡܐ ܕܝܢ ܕܐܬܐ ܦܪܩܠܛܐ ܗܘ ܕܐܢܐ ܡܫܕܪ ܐܢܐ ܠܟܘܢ ܡܢ ܠܘܬ ܐܒܝ ܪܘܚܐ ܕܫܪܪܐ ܗܘ ܕܡܢ ܠܘܬ ܐܒܝ ܢܦܩ ܗܘ ܢܤܗܕ ܥܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.15.27",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "John 15:27",
      "text": "ܐܦ ܐܢܬܘܢ ܤܗܕܝܢ ܐܢܬܘܢ ܕܡܢ ܫܘܪܝܐ ܥܡܝ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    }
  ]
}
