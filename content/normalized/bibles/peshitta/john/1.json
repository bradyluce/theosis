{
  "chapter": {
    "id": "peshitta:john.1",
    "translationId": "peshitta",
    "bookSlug": "john",
    "chapterNumber": 1,
    "referenceLabel": "John 1",
    "summary": "Source text for John 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.1.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "John 1:1",
      "text": "ܒܪܫܝܬ ܐܝܬܘܗܝ ܗܘܐ ܡܠܬܐ ܘܗܘ ܡܠܬܐ ܐܝܬܘܗܝ ܗܘܐ ܠܘܬ ܐܠܗܐ ܘܐܠܗܐ ܐܝܬܘܗܝ ܗܘܐ ܗܘ ܡܠܬܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.1.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "John 1:2",
      "text": "ܗܢܐ ܐܝܬܘܗܝ ܗܘܐ ܒܪܫܝܬ ܠܘܬ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "John 1:3",
      "text": "ܟܠ ܒܐܝܕܗ ܗܘܐ ܘܒܠܥܕܘܗܝ ܐܦܠܐ ܚܕܐ ܗܘܬ ܡܕܡ ܕܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "John 1:4",
      "text": "ܒܗ ܚܝܐ ܗܘܐ ܘܚܝܐ ܐܝܬܝܗܘܢ ܢܘܗܪܐ ܕܒܢܝܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "John 1:5",
      "text": "ܘܗܘ ܢܘܗܪܐ ܒܚܫܘܟܐ ܡܢܗܪ ܘܚܫܘܟܐ ܠܐ ܐܕܪܟܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "John 1:6",
      "text": "ܗܘܐ ܒܪܢܫܐ ܕܐܫܬܕܪ ܡܢ ܐܠܗܐ ܫܡܗ ܝܘܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "John 1:7",
      "text": "ܗܢܐ ܐܬܐ ܠܤܗܕܘܬܐ ܕܢܤܗܕ ܥܠ ܢܘܗܪܐ ܕܟܠܢܫ ܢܗܝܡܢ ܒܐܝܕܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "John 1:8",
      "text": "ܠܐ ܗܘ ܗܘܐ ܢܘܗܪܐ ܐܠܐ ܕܢܤܗܕ ܥܠ ܢܘܗܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "John 1:9",
      "text": "ܐܝܬܘܗܝ ܗܘܐ ܓܝܪ ܢܘܗܪܐ ܕܫܪܪܐ ܕܡܢܗܪ ܠܟܠܢܫ ܕܐܬܐ ܠܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "John 1:10",
      "text": "ܒܥܠܡܐ ܗܘܐ ܘܥܠܡܐ ܒܐܝܕܗ ܗܘܐ ܘܥܠܡܐ ܠܐ ܝܕܥܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "John 1:11",
      "text": "ܠܕܝܠܗ ܐܬܐ ܘܕܝܠܗ ܠܐ ܩܒܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "John 1:12",
      "text": "ܐܝܠܝܢ ܕܝܢ ܕܩܒܠܘܗܝ ܝܗܒ ܠܗܘܢ ܫܘܠܛܢܐ ܕܒܢܝܐ ܕܐܠܗܐ ܢܗܘܘܢ ܠܐܝܠܝܢ ܕܡܗܝܡܢܝܢ ܒܫܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "John 1:13",
      "text": "ܐܝܠܝܢ ܕܠܘ ܡܢ ܕܡܐ ܘܠܐ ܡܢ ܨܒܝܢܐ ܕܒܤܪܐ ܘܠܐ ܡܢ ܨܒܝܢܐ ܕܓܒܪܐ ܐܠܐ ܡܢ ܐܠܗܐ ܐܬܝܠܕܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "John 1:14",
      "text": "ܘܡܠܬܐ ܒܤܪܐ ܗܘܐ ܘܐܓܢ ܒܢ ܘܚܙܝܢ ܫܘܒܚܗ ܫܘܒܚܐ ܐܝܟ ܕܝܚܝܕܝܐ ܕܡܢ ܐܒܐ ܕܡܠܐ ܛܝܒܘܬܐ ܘܩܘܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "John 1:15",
      "text": "ܝܘܚܢܢ ܤܗܕ ܥܠܘܗܝ ܘܩܥܐ ܘܐܡܪ ܗܢܘ ܗܘ ܕܐܡܪܬ ܕܒܬܪܝ ܐܬܐ ܘܗܘܐ ܠܗ ܩܕܡܝ ܡܛܠ ܕܩܕܡܝ ܗܘ ܡܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "John 1:16",
      "text": "ܘܡܢ ܡܠܝܘܬܗ ܚܢܢ ܟܠܢ ܢܤܒܢ ܘܛܝܒܘܬܐ ܚܠܦ ܛܝܒܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "John 1:17",
      "text": "ܡܛܠ ܕܢܡܘܤܐ ܒܝܕ ܡܘܫܐ ܐܬܝܗܒ ܫܪܪܐ ܕܝܢ ܘܛܝܒܘܬܐ ܒܝܕ ܝܫܘܥ ܡܫܝܚܐ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "John 1:18",
      "text": "ܐܠܗܐ ܠܐ ܚܙܐ ܐܢܫ ܡܡܬܘܡ ܝܚܝܕܝܐ ܐܠܗܐ ܗܘ ܕܐܝܬܘܗܝ ܒܥܘܒܐ ܕܐܒܘܗܝ ܗܘ ܐܫܬܥܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "John 1:19",
      "text": "ܘܗܕܐ ܗܝ ܤܗܕܘܬܗ ܕܝܘܚܢܢ ܟܕ ܫܕܪܘ ܠܘܬܗ ܝܗܘܕܝܐ ܡܢ ܐܘܪܫܠܡ ܟܗܢܐ ܘܠܘܝܐ ܕܢܫܐܠܘܢܝܗܝ ܐܢܬ ܡܢ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "John 1:20",
      "text": "ܘܐܘܕܝ ܘܠܐ ܟܦܪ ܘܐܘܕܝ ܕܠܘ ܐܢܐ ܐܢܐ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "John 1:21",
      "text": "ܘܫܐܠܘܗܝ ܬܘܒ ܡܢܐ ܗܟܝܠ ܐܠܝܐ ܐܢܬ ܘܐܡܪ ܠܐ ܐܝܬܝ ܢܒܝܐ ܐܢܬ ܘܐܡܪ ܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "John 1:22",
      "text": "ܘܐܡܪܘ ܠܗ ܘܡܢܘ ܐܢܬ ܕܢܬܠ ܦܬܓܡܐ ܠܐܝܠܝܢ ܕܫܕܪܘܢ ܡܢܐ ܐܡܪ ܐܢܬ ܥܠ ܢܦܫܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "John 1:23",
      "text": "ܐܡܪ ܐܢܐ ܩܠܐ ܕܩܪܐ ܒܡܕܒܪܐ ܕܐܫܘܘ ܐܘܪܚܗ ܕܡܪܝܐ ܐܝܟܢܐ ܕܐܡܪ ܐܫܥܝܐ ܢܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "John 1:24",
      "text": "ܗܢܘܢ ܕܝܢ ܕܐܫܬܕܪܘ ܡܢ ܦܪܝܫܐ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "John 1:25",
      "text": "ܘܫܐܠܘܗܝ ܘܐܡܪܘ ܠܗ ܡܢܐ ܗܟܝܠ ܡܥܡܕ ܐܢܬ ܐܢ ܐܢܬ ܠܐ ܐܝܬܝܟ ܡܫܝܚܐ ܘܠܐ ܐܠܝܐ ܘܠܐ ܢܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.26",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "John 1:26",
      "text": "ܥܢܐ ܝܘܚܢܢ ܘܐܡܪ ܠܗܘܢ ܐܢܐ ܡܥܡܕ ܐܢܐ ܒܡܝܐ ܒܝܢܬܟܘܢ ܕܝܢ ܩܐܡ ܗܘ ܕܐܢܬܘܢ ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.27",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "John 1:27",
      "text": "ܗܢܘ ܗܘ ܕܒܬܪܝ ܐܬܐ ܘܗܘܐ ܠܗ ܩܕܡܝ ܗܘ ܕܐܢܐ ܠܐ ܫܘܐ ܐܢܐ ܕܐܫܪܐ ܥܪܩܐ ܕܡܤܢܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.28",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "John 1:28",
      "text": "ܗܠܝܢ ܒܒܝܬ ܥܢܝܐ ܗܘܝ ܒܥܒܪܐ ܕܝܘܪܕܢܢ ܐܝܟܐ ܕܡܥܡܕ ܗܘܐ ܝܘܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.29",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "John 1:29",
      "text": "ܘܠܝܘܡܐ ܕܒܬܪܗ ܚܙܐ ܝܘܚܢܢ ܠܝܫܘܥ ܕܐܬܐ ܠܘܬܗ ܘܐܡܪ ܗܐ ܐܡܪܗ ܕܐܠܗܐ ܗܘ ܕܫܩܠ ܚܛܝܬܗ ܕܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.30",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "John 1:30",
      "text": "ܗܢܘ ܕܐܢܐ ܐܡܪܬ ܥܠܘܗܝ ܕܒܬܪܝ ܐܬܐ ܓܒܪܐ ܘܗܘܐ ܠܗ ܩܕܡܝ ܡܛܠ ܕܩܕܡܝ ܗܘ ܡܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.31",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "John 1:31",
      "text": "ܘܐܢܐ ܠܐ ܝܕܥ ܗܘܝܬ ܠܗ ܐܠܐ ܕܢܬܝܕܥ ܠܐܝܤܪܝܠ ܡܛܠ ܗܢܐ ܐܬܝܬ ܐܢܐ ܕܒܡܝܐ ܐܥܡܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.32",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "John 1:32",
      "text": "ܘܐܤܗܕ ܝܘܚܢܢ ܘܐܡܪ ܕܚܙܝܬ ܠܪܘܚܐ ܕܢܚܬܐ ܡܢ ܫܡܝܐ ܐܝܟ ܝܘܢܐ ܘܩܘܝܬ ܥܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.33",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "John 1:33",
      "text": "ܘܐܢܐ ܠܐ ܝܕܥ ܗܘܝܬ ܠܗ ܐܠܐ ܡܢ ܕܫܕܪܢܝ ܕܐܥܡܕ ܒܡܝܐ ܗܘ ܐܡܪ ܠܝ ܕܐܝܢܐ ܕܚܙܐ ܐܢܬ ܕܢܚܬܐ ܪܘܚܐ ܘܡܩܘܝܐ ܥܠܘܗܝ ܗܢܘ ܡܥܡܕ ܒܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.34",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "John 1:34",
      "text": "ܘܐܢܐ ܚܙܝܬ ܘܐܤܗܕܬ ܕܗܢܘ ܒܪܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.35",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "John 1:35",
      "text": "ܘܠܝܘܡܐ ܐܚܪܢܐ ܩܐܡ ܗܘܐ ܝܘܚܢܢ ܘܬܪܝܢ ܡܢ ܬܠܡܝܕܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.36",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "John 1:36",
      "text": "ܘܚܪ ܒܝܫܘܥ ܟܕ ܡܗܠܟ ܘܐܡܪ ܗܐ ܐܡܪܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.37",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "John 1:37",
      "text": "ܘܫܡܥܘ ܬܪܝܗܘܢ ܬܠܡܝܕܘܗܝ ܟܕ ܐܡܪ ܘܐܙܠܘ ܠܗܘܢ ܒܬܪܗ ܕܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.38",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "John 1:38",
      "text": "ܘܐܬܦܢܝ ܝܫܘܥ ܘܚܙܐ ܐܢܘܢ ܕܐܬܝܢ ܒܬܪܗ ܘܐܡܪ ܠܗܘܢ ܡܢܐ ܒܥܝܢ ܐܢܬܘܢ ܐܡܪܝܢ ܠܗ ܪܒܢ ܐܝܟܐ ܗܘܐ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.39",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "John 1:39",
      "text": "ܐܡܪ ܠܗܘܢ ܬܘ ܘܬܚܙܘܢ ܗܢܘܢ ܕܝܢ ܐܬܘ ܘܚܙܘ ܐܝܟܐ ܕܗܘܐ ܘܠܘܬܗ ܗܘܘ ܝܘܡܐ ܗܘ ܘܐܝܬ ܗܘܝ ܐܝܟ ܫܥܐ ܥܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.1.40",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "John 1:40",
