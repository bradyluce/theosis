{
  "chapter": {
    "id": "peshitta:john.6",
    "translationId": "peshitta",
    "bookSlug": "john",
    "chapterNumber": 6,
    "referenceLabel": "John 6",
    "summary": "Source text for John 6 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.6.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "John 6:1",
      "text": "ܒܬܪ ܗܠܝܢ ܐܙܠ ܝܫܘܥ ܠܥܒܪܐ ܕܝܡܐ ܕܓܠܝܠܐ ܕܛܒܪܝܘܤ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.6.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "John 6:2",
      "text": "ܘܐܙܠܘ ܒܬܪܗ ܟܢܫܐ ܤܓܝܐܐ ܡܛܠ ܕܚܙܝܢ ܗܘܘ ܐܬܘܬܐ ܕܥܒܕ ܒܟܪܝܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "John 6:3",
      "text": "ܘܤܠܩ ܝܫܘܥ ܠܛܘܪܐ ܘܬܡܢ ܝܬܒ ܗܘܐ ܥܡ ܬܠܡܝܕܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "John 6:4",
      "text": "ܩܪܝܒ ܗܘܐ ܕܝܢ ܥܕܥܕܐ ܕܦܨܚܐ ܕܝܗܘܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "John 6:5",
      "text": "ܘܐܪܝܡ ܥܝܢܘܗܝ ܝܫܘܥ ܘܚܙܐ ܟܢܫܐ ܤܓܝܐܐ ܕܐܬܐ ܠܘܬܗ ܘܐܡܪ ܠܦܝܠܝܦܘܤ ܐܝܡܟܐ ܢܙܒܢ ܠܚܡܐ ܕܢܐܟܠܘܢ ܗܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "John 6:6",
      "text": "ܗܕܐ ܕܝܢ ܐܡܪ ܟܕ ܡܢܤܐ ܠܗ ܗܘ ܓܝܪ ܝܕܥ ܗܘܐ ܡܢܐ ܥܬܝܕ ܠܡܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "John 6:7",
      "text": "ܐܡܪ ܠܗ ܦܝܠܝܦܘܤ ܕܡܐܬܝܢ ܕܝܢܪܝܢ ܠܚܡܐ ܠܐ ܤܦܩ ܠܗܘܢ ܟܕ ܩܠܝܠ ܩܠܝܠ ܚܕ ܚܕ ܡܢܗܘܢ ܢܤܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "John 6:8",
      "text": "ܐܡܪ ܠܗ ܚܕ ܡܢ ܬܠܡܝܕܘܗܝ ܐܢܕܪܐܘܤ ܐܚܘܗܝ ܕܫܡܥܘܢ ܟܐܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "John 6:9",
      "text": "ܐܝܬ ܬܢܢ ܛܠܝܐ ܚܕ ܕܐܝܬ ܥܠܘܗܝ ܚܡܫ ܓܪܝܨܢ ܕܤܥܪܐ ܘܬܪܝܢ ܢܘܢܝܢ ܐܠܐ ܗܠܝܢ ܡܢܐ ܐܢܘܢ ܠܗܠܝܢ ܟܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "John 6:10",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܥܒܕܘ ܐܢܫܐ ܟܠܗܘܢ ܕܢܤܬܡܟܘܢ ܥܤܒܐ ܕܝܢ ܤܓܝ ܗܘܐ ܒܗ ܒܕܘܟܬܐ ܗܝ ܘܐܤܬܡܟܘ ܓܒܪܐ ܒܡܢܝܢܐ ܚܡܫܐ ܐܠܦܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "John 6:11",
      "text": "ܘܫܩܠ ܝܫܘܥ ܠܚܡܐ ܘܒܪܟ ܘܦܠܓ ܠܗܢܘܢ ܕܤܡܝܟܝܢ ܘܗܟܢܐ ܐܦ ܡܢ ܢܘܢܐ ܟܡܐ ܕܨܒܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "John 6:12",
      "text": "ܘܟܕ ܤܒܥܘ ܐܡܪ ܠܬܠܡܝܕܘܗܝ ܟܢܫܘ ܩܨܝܐ ܕܝܬܪܘ ܕܠܐ ܢܐܒܕ ܡܕܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "John 6:13",
      "text": "ܘܟܢܫܘ ܘܡܠܘ ܬܪܥܤܪ ܩܘܦܝܢܝܢ ܩܨܝܐ ܐܝܠܝܢ ܕܝܬܪܘ ܠܗܢܘܢ ܕܐܟܠܘ ܡܢ ܚܡܫܐ ܠܚܡܝܢ ܕܤܥܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "John 6:14",
      "text": "ܗܢܘܢ ܕܝܢ ܐܢܫܐ ܕܚܙܘ ܐܬܐ ܕܥܒܕ ܝܫܘܥ ܐܡܪܝܢ ܗܘܘ ܫܪܝܪܐܝܬ ܗܢܘ ܢܒܝܐ ܕܐܬܐ ܠܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "John 6:15",
      "text": "ܝܫܘܥ ܕܝܢ ܝܕܥ ܕܥܬܝܕܝܢ ܕܢܐܬܘܢ ܢܚܛܦܘܢܝܗܝ ܘܢܥܒܕܘܢܝܗܝ ܡܠܟܐ ܘܫܢܝ ܠܗ ܠܛܘܪܐ ܗܘ ܒܠܚܘܕܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "John 6:16",
      "text": "ܘܟܕ ܗܘܐ ܪܡܫܐ ܢܚܬܘ ܬܠܡܝܕܘܗܝ ܠܝܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "John 6:17",
      "text": "ܘܝܬܒܘ ܒܤܦܝܢܬܐ ܘܐܬܝܢ ܗܘܘ ܠܥܒܪܐ ܠܟܦܪܢܚܘܡ ܘܚܫܟܬ ܗܘܬ ܠܗ ܘܠܐ ܐܬܝ ܗܘܐ ܠܘܬܗܘܢ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "John 6:18",
      "text": "ܝܡܐ ܕܝܢ ܐܙܕܩܦ ܗܘܐ ܥܠܝܗܘܢ ܡܛܠ ܕܪܘܚܐ ܪܒܬܐ ܢܫܒܬ ܗܘܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "John 6:19",
      "text": "ܘܕܒܪܘ ܐܝܟ ܐܤܛܕܘܬܐ ܥܤܪܝܢ ܘܚܡܫܐ ܐܘ ܬܠܬܝܢ ܘܚܙܘ ܠܝܫܘܥ ܟܕ ܡܗܠܟ ܥܠ ܝܡܬܐ ܘܟܕ ܩܪܒ ܠܘܬ ܤܦܝܢܬܗܘܢ ܕܚܠܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "John 6:20",
      "text": "ܗܘ ܕܝܢ ܝܫܘܥ ܐܡܪ ܠܗܘܢ ܐܢܐ ܐܢܐ ܠܐ ܬܕܚܠܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "John 6:21",
      "text": "ܘܨܒܘ ܗܘܘ ܕܢܩܒܠܘܢܝܗܝ ܒܤܦܝܢܬܐ ܘܒܗ ܒܫܥܬܐ ܤܦܝܢܬܐ ܗܝ ܗܘܬ ܠܘܬ ܐܪܥܐ ܗܝ ܕܐܙܠܝܢ ܗܘܘ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "John 6:22",
      "text": "ܘܠܝܘܡܐ ܕܒܬܪܗ ܗܘ ܟܢܫܐ ܕܩܐܡ ܗܘܐ ܒܥܒܪܐ ܕܝܡܐ ܚܙܘ ܕܤܦܝܢܬܐ ܐܚܪܬܐ ܠܝܬ ܗܘܐ ܬܡܢ ܐܠܐ ܐܢ ܗܝ ܕܤܠܩܘ ܠܗ ܬܠܡܝܕܐ ܘܕܠܐ ܥܠ ܗܘܐ ܥܡܗܘܢ ܝܫܘܥ ܥܡ ܬܠܡܝܕܘܗܝ ܠܤܦܝܢܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "John 6:23",
      "text": "ܐܬܝ ܗܘܝ ܕܝܢ ܐܠܦܐ ܐܚܪܢܝܬܐ ܡܢ ܛܒܪܝܘܤ ܥܠ ܓܢܒ ܕܘܟܬܐ ܗܝ ܕܐܟܠܘ ܒܗ ܠܚܡܐ ܟܕ ܒܪܟ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "John 6:24",
      "text": "ܘܟܕ ܚܙܐ ܗܘ ܟܢܫܐ ܕܠܐ ܗܘܐ ܬܡܢ ܝܫܘܥ ܐܦܠܐ ܬܠܡܝܕܘܗܝ ܤܠܩܘ ܠܗܠܝܢ ܐܠܦܐ ܘܐܬܘ ܠܟܦܪܢܚܘܡ ܘܒܥܝܢ ܗܘܘ ܠܗ ܠܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 25,
      "referenceLabel": "John 6:25",
      "text": "ܘܟܕ ܐܫܟܚܘܗܝ ܒܥܒܪܐ ܕܝܡܐ ܐܡܪܝܢ ܠܗ ܪܒܢ ܐܡܬܝ ܐܬܝܬ ܠܗܪܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.26",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 26,
      "referenceLabel": "John 6:26",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗܘܢ ܐܡܝܢ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܒܥܝܢ ܐܢܬܘܢ ܠܝ ܠܐ ܗܘܐ ܡܛܠ ܕܚܙܝܬܘܢ ܐܬܘܬܐ ܐܠܐ ܕܐܟܠܬܘܢ ܠܚܡܐ ܘܤܒܥܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.27",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 27,
      "referenceLabel": "John 6:27",
      "text": "ܠܐ ܬܦܠܚܘܢ ܡܐܟܘܠܬܐ ܕܐܒܕܐ ܐܠܐ ܡܐܟܘܠܬܐ ܕܡܩܘܝܐ ܠܚܝܐ ܕܠܥܠܡ ܐܝܕܐ ܕܒܪܗ ܕܐܢܫܐ ܢܬܠ ܠܟܘܢ ܠܗܢܐ ܓܝܪ ܐܒܐ ܚܬܡ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.28",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 28,
      "referenceLabel": "John 6:28",
      "text": "ܐܡܪܝܢ ܠܗ ܡܢܐ ܢܥܒܕ ܕܢܦܠܘܚ ܥܒܕܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.29",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 29,
      "referenceLabel": "John 6:29",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗܘܢ ܗܢܘ ܥܒܕܐ ܕܐܠܗܐ ܕܬܗܝܡܢܘܢ ܒܡܢ ܕܗܘ ܫܕܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.30",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 30,
      "referenceLabel": "John 6:30",
      "text": "ܐܡܪܝܢ ܠܗ ܡܢܐ ܐܬܐ ܥܒܕ ܐܢܬ ܕܢܚܙܐ ܘܢܗܝܡܢ ܒܟ ܡܢܐ ܤܥܪ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.31",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 31,
      "referenceLabel": "John 6:31",
      "text": "ܐܒܗܝܢ ܡܢܢܐ ܐܟܠܘ ܒܡܕܒܪܐ ܐܝܟܢܐ ܕܟܬܝܒ ܕܠܚܡܐ ܡܢ ܫܡܝܐ ܝܗܒ ܠܗܘܢ ܠܡܐܟܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.32",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 32,
      "referenceLabel": "John 6:32",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܐܡܝܢ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܠܐ ܗܘܐ ܡܘܫܐ ܝܗܒ ܠܟܘܢ ܠܚܡܐ ܡܢ ܫܡܝܐ ܐܠܐ ܐܒܝ ܝܗܒ ܠܟܘܢ ܠܚܡܐ ܕܩܘܫܬܐ ܡܢ ܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.33",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 33,
      "referenceLabel": "John 6:33",
      "text": "ܠܚܡܗ ܓܝܪ ܕܐܠܗܐ ܐܝܬܘܗܝ ܗܘ ܕܢܚܬ ܡܢ ܫܡܝܐ ܘܝܗܒ ܚܝܐ ܠܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.34",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 34,
      "referenceLabel": "John 6:34",
      "text": "ܐܡܪܝܢ ܠܗ ܡܪܢ ܒܟܠܙܒܢ ܗܒ ܠܢ ܠܚܡܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.35",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 35,
      "referenceLabel": "John 6:35",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܐܢܐ ܐܢܐ ܠܚܡܐ ܕܚܝܐ ܡܢ ܕܐܬܐ ܠܘܬܝ ܠܐ ܢܟܦܢ ܘܡܢ ܕܡܗܝܡܢ ܒܝ ܠܐ ܢܨܗܐ ܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.36",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 36,
      "referenceLabel": "John 6:36",
      "text": "ܐܠܐ ܐܡܪܬ ܠܟܘܢ ܕܚܙܝܬܘܢܢܝ ܘܠܐ ܡܗܝܡܢܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.6.37",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 37,
      "referenceLabel": "John 6:37",
      "text": "ܟܠ ܕܝܗܒ ܠܝ ܐܒܝ ܠܘܬܝ ܢܐܬܐ ܘܡܢ ܕܠܘܬܝ ܢܐܬܐ ܠܐ ܐܦܩܗ ܠܒܪ ܀",
      "paragraphStart": false
    },
    {
