    "referenceLabel": "John 3",
    "summary": "Source text for John 3 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.3.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "John 3:1",
      "text": "ܐܝܬ ܗܘܐ ܕܝܢ ܬܡܢ ܚܕ ܓܒܪܐ ܡܢ ܦܪܝܫܐ ܢܝܩܕܡܘܤ ܫܡܗ ܗܘܐ ܐܪܟܘܢܐ ܕܝܗܘܕܝܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.3.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "John 3:2",
      "text": "ܗܢܐ ܐܬܐ ܠܘܬ ܝܫܘܥ ܒܠܠܝܐ ܘܐܡܪ ܠܗ ܪܒܝ ܝܕܥܝܢܢ ܕܡܢ ܐܠܗܐ ܐܫܬܕܪܬ ܡܠܦܢܐ ܠܐ ܓܝܪ ܐܢܫ ܡܫܟܚ ܗܠܝܢ ܐܬܘܬܐ ܠܡܥܒܕ ܕܐܢܬ ܥܒܕ ܐܢܬ ܐܠܐ ܡܢ ܕܐܠܗܐ ܥܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "John 3:3",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗ ܐܡܝܢ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟ ܕܐܢ ܐܢܫ ܠܐ ܡܬܝܠܕ ܡܢ ܕܪܝܫ ܠܐ ܡܫܟܚ ܕܢܚܙܐ ܡܠܟܘܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "John 3:4",
      "text": "ܐܡܪ ܠܗ ܢܝܩܕܡܘܤ ܐܝܟܢܐ ܡܫܟܚ ܕܢܬܝܠܕ ܓܒܪܐ ܤܒܐ ܕܠܡܐ ܡܫܟܚ ܬܘܒ ܠܟܪܤܐ ܕܐܡܗ ܕܬܪܬܝܢ ܙܒܢܝܢ ܠܡܥܠ ܘܢܬܝܠܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "John 3:5",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗ ܐܡܝܢ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟ ܕܐܢ ܐܢܫ ܠܐ ܡܬܝܠܕ ܡܢ ܡܝܐ ܘܪܘܚܐ ܠܐ ܡܫܟܚ ܕܢܥܘܠ ܠܡܠܟܘܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "John 3:6",
      "text": "ܡܕܡ ܕܝܠܝܕ ܡܢ ܒܤܪܐ ܒܤܪܐ ܗܘ ܘܡܕܡ ܕܝܠܝܕ ܡܢ ܪܘܚܐ ܪܘܚܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "John 3:7",
      "text": "ܠܐ ܬܬܕܡܪ ܕܐܡܪܬ ܠܟ ܕܘܠܐ ܠܟܘܢ ܠܡܬܝܠܕܘ ܡܢ ܕܪܝܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "John 3:8",
      "text": "ܪܘܚܐ ܐܬܪ ܕܨܒܝܐ ܢܫܒܐ ܘܩܠܗ ܫܡܥ ܐܢܬ ܐܠܐ ܠܐ ܝܕܥ ܐܢܬ ܐܝܡܟܐ ܐܬܝܐ ܘܠܐܝܟܐ ܐܙܠܐ ܗܟܢܐ ܐܝܬܘܗܝ ܟܠܢܫ ܕܝܠܝܕ ܡܢ ܪܘܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "John 3:9",
      "text": "ܥܢܐ ܢܝܩܕܡܘܤ ܘܐܡܪ ܠܗ ܐܝܟܢܐ ܡܫܟܚܢ ܗܠܝܢ ܠܡܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "John 3:10",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗ ܐܢܬ ܗܘ ܡܠܦܢܗ ܕܐܝܤܪܝܠ ܘܗܠܝܢ ܠܐ ܝܕܥ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "John 3:11",
      "text": "ܐܡܝܢ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟ ܕܡܕܡ ܕܝܕܥܝܢ ܚܢܢ ܡܡܠܠܝܢ ܚܢܢ ܘܡܕܡ ܕܚܙܝܢ ܡܤܗܕܝܢ ܐܢܚܢܢ ܘܤܗܕܘܬܢ ܠܐ ܡܩܒܠܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "John 3:12",
      "text": "ܐܢ ܕܒܐܪܥܐ ܐܡܪܬ ܠܟܘܢ ܘܠܐ ܡܗܝܡܢܝܢ ܐܢܬܘܢ ܐܝܟܢܐ ܐܢ ܐܡܪ ܠܟܘܢ ܕܒܫܡܝܐ ܬܗܝܡܢܘܢܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "John 3:13",
      "text": "ܘܠܐ ܐܢܫ ܤܠܩ ܠܫܡܝܐ ܐܠܐ ܗܘ ܕܢܚܬ ܡܢ ܫܡܝܐ ܒܪܗ ܕܐܢܫܐ ܗܘ ܕܐܝܬܘܗܝ ܒܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "John 3:14",
      "text": "ܘܐܝܟܢܐ ܕܐܪܝܡ ܡܘܫܐ ܚܘܝܐ ܒܡܕܒܪܐ ܗܟܢܐ ܥܬܝܕ ܠܡܬܬܪܡܘ ܒܪܗ ܕܐܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "John 3:15",
      "text": "ܕܟܠ ܐܢܫ ܕܡܗܝܡܢ ܒܗ ܠܐ ܢܐܒܕ ܐܠܐ ܢܗܘܘܢ ܠܗ ܚܝܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "John 3:16",
      "text": "ܗܟܢܐ ܓܝܪ ܐܚܒ ܐܠܗܐ ܠܥܠܡܐ ܐܝܟܢܐ ܕܠܒܪܗ ܝܚܝܕܝܐ ܢܬܠ ܕܟܠ ܡܢ ܕܡܗܝܡܢ ܒܗ ܠܐ ܢܐܒܕ ܐܠܐ ܢܗܘܘܢ ܠܗ ܚܝܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "John 3:17",
      "text": "ܠܐ ܓܝܪ ܫܕܪ ܐܠܗܐ ܠܒܪܗ ܠܥܠܡܐ ܕܢܕܘܢܝܘܗܝ ܠܥܠܡܐ ܐܠܐ ܕܢܚܐ ܠܥܠܡܐ ܒܐܝܕܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "John 3:18",
      "text": "ܡܢ ܕܡܗܝܡܢ ܒܗ ܠܐ ܡܬܬܕܝܢ ܘܡܢ ܕܠܐ ܡܗܝܡܢ ܡܢ ܟܕܘ ܕܝܢ ܗܘ ܕܠܐ ܗܝܡܢ ܒܫܡܗ ܕܝܚܝܕܝܐ ܒܪܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "John 3:19",
      "text": "ܗܢܘ ܕܝܢ ܕܝܢܐ ܕܢܘܗܪܐ ܐܬܐ ܠܥܠܡܐ ܘܐܚܒܘ ܒܢܝܢܫܐ ܠܚܫܘܟܐ ܝܬܝܪ ܡܢ ܕܠܢܘܗܪܐ ܐܝܬܝܗܘܢ ܗܘܘ ܓܝܪ ܥܒܕܝܗܘܢ ܒܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "John 3:20",
      "text": "ܟܠ ܓܝܪ ܕܤܢܝܬܐ ܥܒܕ ܤܢܐ ܠܢܘܗܪܐ ܘܠܐ ܐܬܐ ܠܢܘܗܪܐ ܕܠܐ ܢܬܟܤܤܘܢ ܥܒܕܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "John 3:21",
      "text": "ܗܘ ܕܝܢ ܕܥܒܕ ܫܪܪܐ ܐܬܐ ܠܘܬ ܢܘܗܪܐ ܕܢܬܝܕܥܘܢ ܥܒܕܘܗܝ ܕܒܐܠܗܐ ܥܒܝܕܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "John 3:22",
      "text": "ܒܬܪ ܗܠܝܢ ܐܬܐ ܝܫܘܥ ܘܬܠܡܝܕܘܗܝ ܠܐܪܥܐ ܕܝܗܘܕ ܘܬܡܢ ܡܬܗܦܟ ܗܘܐ ܥܡܗܘܢ ܘܡܥܡܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "John 3:23",
      "text": "ܐܦ ܝܘܚܢܢ ܕܝܢ ܡܥܡܕ ܗܘܐ ܒܥܝܢ ܝܘܢ ܕܥܠ ܓܢܒ ܫܠܝܡ ܡܛܠ ܕܡܝܐ ܐܝܬ ܗܘܘ ܬܡܢ ܤܓܝܐܐ ܘܐܬܝܢ ܗܘܘ ܘܥܡܕܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "John 3:24",
      "text": "ܠܐ ܓܝܪ ܥܕܟܝܠ ܢܦܠ ܗܘܐ ܝܘܚܢܢ ܒܝܬ ܐܤܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "John 3:25",
      "text": "ܗܘܬ ܗܘܬ ܕܝܢ ܒܥܬܐ ܠܚܕ ܡܢ ܬܠܡܝܕܘܗܝ ܕܝܘܚܢܢ ܥܡ ܝܗܘܕܝܐ ܚܕ ܥܠ ܬܕܟܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.26",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "John 3:26",
      "text": "ܘܐܬܘ ܠܘܬ ܝܘܚܢܢ ܘܐܡܪܘ ܠܗ ܪܒܢ ܗܘ ܕܥܡܟ ܗܘܐ ܒܥܒܪܐ ܕܝܘܪܕܢܢ ܕܐܢܬ ܤܗܕܬ ܥܠܘܗܝ ܗܐ ܐܦ ܗܘ ܡܥܡܕ ܘܤܓܝܐܐ ܐܬܝܢ ܠܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.27",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "John 3:27",
      "text": "ܥܢܐ ܝܘܚܢܢ ܘܐܡܪ ܠܗܘܢ ܠܐ ܡܫܟܚ ܒܪܢܫܐ ܠܡܤܒ ܡܢ ܨܒܘܬ ܢܦܫܗ ܡܕܡ ܐܠܐ ܐܢ ܐܬܝܗܒ ܠܗ ܡܢ ܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.28",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "John 3:28",
      "text": "ܐܢܬܘܢ ܤܗܕܝܢ ܐܢܬܘܢ ܠܝ ܕܐܡܪܬ ܕܐܢܐ ܠܐ ܗܘܝܬ ܡܫܝܚܐ ܐܠܐ ܫܠܝܚܐ ܐܢܐ ܕܩܕܡܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.29",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "John 3:29",
      "text": "ܡܢ ܕܐܝܬ ܠܗ ܟܠܬܐ ܚܬܢܐ ܗܘ ܪܚܡܗ ܕܝܢ ܕܚܬܢܐ ܗܘ ܕܩܐܡ ܘܨܐܬ ܠܗ ܚܕܘܬܐ ܪܒܬܐ ܚܕܐ ܡܛܠ ܩܠܗ ܕܚܬܢܐ ܗܕܐ ܗܟܝܠ ܚܕܘܬܐ ܕܝܠܝ ܗܐ ܡܡܠܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.30",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "John 3:30",
      "text": "ܠܗܘ ܗܘ ܘܠܐ ܠܡܪܒܐ ܘܠܝ ܠܡܒܨܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.31",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "John 3:31",
      "text": "ܗܘ ܓܝܪ ܕܡܢ ܠܥܠ ܐܬܐ ܠܥܠ ܡܢ ܟܠ ܗܘ ܘܗܘ ܕܡܢ ܐܪܥܐ ܡܢ ܐܪܥܐ ܗܘ ܘܡܢ ܐܪܥܐ ܡܡܠܠ ܗܘ ܕܡܢ ܫܡܝܐ ܐܬܐ ܠܥܠ ܡܢ ܟܠ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.32",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "John 3:32",
      "text": "ܘܡܕܡ ܕܚܙܐ ܘܫܡܥ ܡܤܗܕ ܘܤܗܕܘܬܗ ܠܐ ܐܢܫ ܡܩܒܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.33",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "John 3:33",
      "text": "ܗܘ ܕܝܢ ܕܩܒܠ ܤܗܕܘܬܗ ܚܬܡ ܕܐܠܗܐ ܫܪܝܪܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.34",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "John 3:34",
      "text": "ܐܝܢܐ ܓܝܪ ܕܐܠܗܐ ܫܕܪܗ ܡܠܐ ܗܘ ܕܐܠܗܐ ܡܡܠܠ ܠܐ ܗܘܐ ܓܝܪ ܒܟܝܠܐ ܝܗܒ ܐܠܗܐ ܪܘܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.3.35",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "John 3:35",
      "text": "ܐܒܐ ܡܚܒ ܠܒܪܐ ܘܟܠ ܡܕܡ ܝܗܒ ܒܐܝܕܘܗܝ ܀",
      "paragraphStart": false
