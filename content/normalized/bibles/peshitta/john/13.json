    "translationId": "peshitta",
    "bookSlug": "john",
    "chapterNumber": 13,
    "referenceLabel": "John 13",
    "summary": "Source text for John 13 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.13.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "John 13:1",
      "text": "ܩܕܡ ܕܝܢ ܥܐܕܐ ܕܦܨܚܐ ܝܕܥ ܗܘܐ ܝܫܘܥ ܕܡܛܬ ܫܥܬܐ ܕܢܫܢܐ ܡܢ ܗܢܐ ܥܠܡܐ ܠܘܬ ܐܒܘܗܝ ܘܐܚܒ ܠܕܝܠܗ ܕܒܗܢܐ ܥܠܡܐ ܘܥܕܡܐ ܠܚܪܬܐ ܐܚܒ ܐܢܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.13.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "John 13:2",
      "text": "ܘܟܕ ܗܘܬ ܚܫܡܝܬܐ ܪܡܐ ܗܘܐ ܠܗ ܠܤܛܢܐ ܒܠܒܗ ܕܝܗܘܕܐ ܒܪ ܫܡܥܘܢ ܤܟܪܝܘܛܐ ܕܢܫܠܡܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "John 13:3",
      "text": "ܗܘ ܕܝܢ ܝܫܘܥ ܡܛܠ ܕܝܕܥ ܗܘܐ ܕܟܠ ܡܕܡ ܝܗܒ ܐܒܐ ܒܐܝܕܘܗܝ ܘܕܡܢ ܐܠܗܐ ܢܦܩ ܘܠܘܬ ܐܠܗܐ ܐܙܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "John 13:4",
      "text": "ܩܡ ܡܢ ܚܫܡܝܬܐ ܘܤܡ ܢܚܬܘܗܝ ܘܫܩܠ ܤܕܘܢܐ ܡܚܐ ܒܚܨܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "John 13:5",
      "text": "ܘܐܪܡܝ ܡܝܐ ܒܡܫܓܬܐ ܘܫܪܝ ܠܡܫܓܘ ܪܓܠܐ ܕܬܠܡܝܕܘܗܝ ܘܡܫܘܐ ܗܘܐ ܒܤܕܘܢܐ ܕܡܚܐ ܒܚܨܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "John 13:6",
      "text": "ܟܕ ܕܝܢ ܐܬܐ ܠܘܬ ܫܡܥܘܢ ܟܐܦܐ ܐܡܪ ܠܗ ܫܡܥܘܢ ܐܢܬ ܡܪܝ ܪܓܠܝ ܡܫܝܓ ܐܢܬ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "John 13:7",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗ ܡܕܡ ܕܥܒܕ ܐܢܐ ܐܢܬ ܠܐ ܝܕܥ ܐܢܬ ܗܫܐ ܒܬܪܟܢ ܕܝܢ ܬܕܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "John 13:8",
      "text": "ܐܡܪ ܠܗ ܫܡܥܘܢ ܟܐܦܐ ܠܥܠܡ ܠܐ ܡܫܝܓ ܐܢܬ ܠܝ ܪܓܠܝ ܐܡܪ ܠܗ ܝܫܘܥ ܐܢ ܠܐ ܡܫܝܓ ܐܢܐ ܠܟ ܠܝܬ ܠܟ ܥܡܝ ܡܢܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "John 13:9",
      "text": "ܐܡܪ ܠܗ ܫܡܥܘܢ ܟܐܦܐ ܡܕܝܢ ܡܪܝ ܠܐ ܒܠܚܘܕ ܪܓܠܝ ܬܫܝܓ ܠܝ ܐܠܐ ܐܦ ܐܝܕܝ ܐܦ ܪܫܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "John 13:10",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܗܘ ܕܤܚܐ ܠܐ ܤܢܝܩ ܐܠܐ ܪܓܠܘܗܝ ܒܠܚܘܕ ܢܫܝܓ ܟܠܗ ܓܝܪ ܕܟܐ ܗܘ ܐܦ ܐܢܬܘܢ ܟܠܟܘܢ ܕܟܝܐ ܐܢܬܘܢ ܐܠܐ ܠܐ ܟܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "John 13:11",
      "text": "ܝܕܥ ܗܘܐ ܓܝܪ ܝܫܘܥ ܠܗܘ ܕܡܫܠܡ ܠܗ ܡܛܠ ܗܢܐ ܐܡܪ ܕܠܐ ܗܘܐ ܟܠܟܘܢ ܕܟܝܐ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "John 13:12",
      "text": "ܟܕ ܕܝܢ ܐܫܝܓ ܪܓܠܝܗܘܢ ܫܩܠ ܢܚܬܘܗܝ ܘܐܤܬܡܟ ܘܐܡܪ ܠܗܘܢ ܝܕܥܝܢ ܐܢܬܘܢ ܡܢܐ ܥܒܕܬ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "John 13:13",
      "text": "ܐܢܬܘܢ ܩܪܝܢ ܐܢܬܘܢ ܠܝ ܪܒܢ ܘܡܪܢ ܘܫܦܝܪ ܐܡܪܝܢ ܐܢܬܘܢ ܐܝܬܝ ܓܝܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "John 13:14",
      "text": "ܐܢ ܐܢܐ ܗܟܝܠ ܡܪܟܘܢ ܘܪܒܟܘܢ ܐܫܝܓܬ ܠܟܘܢ ܪܓܠܝܟܘܢ ܟܡܐ ܐܢܬܘܢ ܚܝܒܝܢ ܐܢܬܘܢ ܕܬܫܝܓܘܢ ܪܓܠܐ ܚܕ ܕܚܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "John 13:15",
      "text": "ܗܢܐ ܓܝܪ ܛܘܦܤܐ ܝܗܒܬ ܠܟܘܢ ܕܐܝܟܢܐ ܕܐܢܐ ܥܒܕܬ ܠܟܘܢ ܐܦ ܐܢܬܘܢ ܬܥܒܕܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "John 13:16",
      "text": "ܐܡܝܢ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܠܝܬ ܥܒܕܐ ܕܪܒ ܡܢ ܡܪܗ ܘܠܐ ܫܠܝܚܐ ܕܪܒ ܡܢ ܡܢ ܕܫܕܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "John 13:17",
      "text": "ܐܢ ܗܠܝܢ ܬܕܥܘܢ ܛܘܒܢܐ ܐܢܬܘܢ ܐܢ ܬܥܒܕܘܢ ܐܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "John 13:18",
      "text": "ܠܐ ܗܘܐ ܥܠ ܟܠܟܘܢ ܐܡܪ ܐܢܐ ܝܕܥ ܐܢܐ ܓܝܪ ܠܐܝܠܝܢ ܕܓܒܝܬ ܐܠܐ ܕܟܬܒܐ ܢܫܠܡ ܕܗܘ ܕܐܟܠ ܥܡܝ ܠܚܡܐ ܐܪܝܡ ܥܠܝ ܥܩܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "John 13:19",
      "text": "ܡܢ ܗܫܐ ܐܡܪ ܐܢܐ ܠܟܘܢ ܡܢ ܩܕܡ ܕܢܗܘܐ ܕܡܐ ܕܗܘܐ ܬܗܝܡܢܘܢ ܕܐܢܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "John 13:20",
      "text": "ܐܡܝܢ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܡܢ ܕܡܩܒܠ ܠܡܢ ܕܡܫܕܪ ܐܢܐ ܠܝ ܡܩܒܠ ܘܡܢ ܕܠܝ ܡܩܒܠ ܡܩܒܠ ܠܡܢ ܕܫܕܪܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "John 13:21",
      "text": "ܗܠܝܢ ܐܡܪ ܝܫܘܥ ܘܐܬܥܙܙ ܒܪܘܚܗ ܘܐܤܗܕ ܘܐܡܪ ܐܡܝܢ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܚܕ ܡܢܟܘܢ ܢܫܠܡܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "John 13:22",
      "text": "ܚܪܘ ܕܝܢ ܬܠܡܝܕܐ ܚܕ ܒܚܕ ܡܛܠ ܕܠܐ ܝܕܥܝܢ ܗܘܘ ܕܥܠ ܡܢܘ ܐܡܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "John 13:23",
      "text": "ܐܝܬ ܗܘܐ ܕܝܢ ܡܢ ܬܠܡܝܕܘܗܝ ܚܕ ܕܤܡܝܟ ܗܘܐ ܒܥܘܒܗ ܗܘ ܕܪܚܡ ܗܘܐ ܠܗ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "John 13:24",
      "text": "ܠܗܢܐ ܪܡܙ ܫܡܥܘܢ ܟܐܦܐ ܕܢܫܐܠܝܘܗܝ ܕܡܢܘ ܗܘ ܕܐܡܪ ܥܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "John 13:25",
      "text": "ܘܢܦܠ ܗܘ ܬܠܡܝܕܐ ܥܠ ܚܕܝܗ ܕܝܫܘܥ ܘܐܡܪ ܠܗ ܡܪܝ ܡܢܘ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.26",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 26,
      "referenceLabel": "John 13:26",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܗܘ ܗܘ ܕܨܒܥ ܐܢܐ ܠܚܡܐ ܝܗܒ ܐܢܐ ܠܗ ܘܨܒܥ ܝܫܘܥ ܠܚܡܐ ܘܝܗܒ ܠܝܗܘܕܐ ܒܪ ܫܡܥܘܢ ܤܟܪܝܘܛܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.27",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 27,
      "referenceLabel": "John 13:27",
      "text": "ܘܒܬܪ ܠܚܡܐ ܗܝܕܝܢ ܐܬܥܠܠ ܒܗ ܤܛܢܐ ܘܐܡܪ ܠܗ ܝܫܘܥ ܡܕܡ ܕܥܒܕ ܐܢܬ ܥܒܕ ܒܥܓܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.28",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 28,
      "referenceLabel": "John 13:28",
      "text": "ܗܕܐ ܕܝܢ ܠܐ ܐܢܫ ܝܕܥ ܡܢ ܗܢܘܢ ܤܡܝܟܐ ܕܥܠ ܡܢܐ ܐܡܪ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.29",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 29,
      "referenceLabel": "John 13:29",
      "text": "ܐܢܫܝܢ ܓܝܪ ܤܒܪܘ ܡܛܠ ܕܓܠܘܤܩܡܐ ܨܐܕܘܗܝ ܗܘܐ ܕܝܗܘܕܐ ܕܡܦܩܕ ܦܩܕ ܠܗ ܕܢܙܒܢ ܡܕܡ ܕܡܬܒܥܐ ܠܥܕܥܕܐ ܐܘ ܕܢܬܠ ܡܕܡ ܠܡܤܟܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.30",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 30,
      "referenceLabel": "John 13:30",
      "text": "ܗܘ ܕܝܢ ܝܗܘܕܐ ܢܤܒ ܠܚܡܐ ܒܪ ܫܥܬܗ ܘܢܦܩ ܠܗ ܠܒܪ ܠܠܝܐ ܗܘܐ ܕܝܢ ܟܕ ܢܦܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.31",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 31,
      "referenceLabel": "John 13:31",
      "text": "ܘܐܡܪ ܝܫܘܥ ܗܫܐ ܐܫܬܒܚ ܒܪܗ ܕܐܢܫܐ ܘܐܠܗܐ ܐܫܬܒܚ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.32",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 32,
      "referenceLabel": "John 13:32",
      "text": "ܘܐܢ ܐܠܗܐ ܐܫܬܒܚ ܒܗ ܘܐܦ ܐܠܗܐ ܡܫܒܚ ܠܗ ܒܗ ܘܡܚܕܐ ܡܫܒܚ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.33",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 33,
      "referenceLabel": "John 13:33",
      "text": "ܒܢܝ ܩܠܝܠ ܐܚܪܝܢ ܥܡܟܘܢ ܐܢܐ ܘܬܒܥܘܢܢܝ ܘܐܝܟܢܐ ܕܐܡܪܬ ܠܝܗܘܕܝܐ ܕܠܐܝܟܐ ܕܐܢܐ ܐܙܠ ܐܢܐ ܐܢܬܘܢ ܠܐ ܡܫܟܚܝܢ ܐܢܬܘܢ ܠܡܐܬܐ ܘܐܦ ܠܟܘܢ ܐܡܪ ܐܢܐ ܗܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.34",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 34,
      "referenceLabel": "John 13:34",
      "text": "ܦܘܩܕܢܐ ܚܕܬܐ ܝܗܒ ܐܢܐ ܠܟܘܢ ܕܗܘܝܬܘܢ ܡܚܒܝܢ ܚܕ ܠܚܕ ܐܝܟܢܐ ܕܐܢܐ ܐܚܒܬܟܘܢ ܐܦ ܐܢܬܘܢ ܬܚܒܘܢ ܚܕ ܠܚܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.35",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 35,
      "referenceLabel": "John 13:35",
      "text": "ܒܗܕܐ ܢܕܥ ܟܠ ܐܢܫ ܕܬܠܡܝܕܝ ܐܢܬܘܢ ܐܢ ܚܘܒܐ ܢܗܘܐ ܒܟܘܢ ܚܕ ܠܘܬ ܚܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.13.36",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 13,
