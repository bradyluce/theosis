{
  "chapter": {
    "id": "peshitta:john.16",
    "translationId": "peshitta",
    "bookSlug": "john",
    "chapterNumber": 16,
    "referenceLabel": "John 16",
    "summary": "Source text for John 16 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.16.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "John 16:1",
      "text": "ܗܠܝܢ ܡܠܠܬ ܥܡܟܘܢ ܕܠܐ ܬܬܟܫܠܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.16.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "John 16:2",
      "text": "ܢܦܩܘܢܟܘܢ ܓܝܪ ܡܢ ܟܢܘܫܬܗܘܢ ܘܬܐܬܐ ܫܥܬܐ ܕܟܠ ܕܢܩܛܘܠܟܘܢ ܢܤܒܪ ܕܩܘܪܒܢܐ ܡܩܪܒ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "John 16:3",
      "text": "ܘܗܠܝܢ ܢܥܒܕܘܢ ܡܛܠ ܕܠܐ ܝܕܥܘ ܘܠܐ ܠܐܒܝ ܘܠܐ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "John 16:4",
      "text": "ܗܠܝܢ ܡܠܠܬ ܥܡܟܘܢ ܕܡܐ ܕܐܬܐ ܥܕܢܗܝܢ ܬܥܗܕܘܢ ܐܢܝܢ ܕܐܢܐ ܐܡܪܬ ܠܟܘܢ ܗܠܝܢ ܕܝܢ ܡܢ ܩܕܝܡ ܠܐ ܐܡܪܬ ܠܟܘܢ ܕܥܡܟܘܢ ܗܘܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "John 16:5",
      "text": "ܗܫܐ ܕܝܢ ܐܙܠ ܐܢܐ ܠܘܬ ܡܢ ܕܫܕܪܢܝ ܘܠܐ ܐܢܫ ܡܢܟܘܢ ܡܫܐܠ ܠܝ ܠܐܝܟܐ ܐܙܠ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "John 16:6",
      "text": "ܐܡܪܬ ܠܟܘܢ ܓܝܪ ܗܠܝܢ ܘܐܬܬ ܟܪܝܘܬܐ ܘܡܠܬ ܠܒܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "John 16:7",
      "text": "ܐܠܐ ܐܢܐ ܫܪܪܐ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܦܩܚ ܠܟܘܢ ܕܐܢܐ ܐܙܠ ܐܢ ܓܝܪ ܐܢܐ ܠܐ ܐܙܠ ܐܢܐ ܦܪܩܠܛܐ ܠܐ ܐܬܐ ܠܘܬܟܘܢ ܐܢ ܕܝܢ ܐܙܠ ܐܫܕܪܝܘܗܝ ܠܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "John 16:8",
      "text": "ܘܡܐ ܕܐܬܐ ܗܘ ܢܟܤܝܘܗܝ ܠܥܠܡܐ ܥܠ ܚܛܝܬܐ ܘܥܠ ܙܕܝܩܘܬܐ ܘܥܠ ܕܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "John 16:9",
      "text": "ܥܠ ܚܛܝܬܐ ܕܠܐ ܡܗܝܡܢܝܢ ܒܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "John 16:10",
      "text": "ܥܠ ܙܕܝܩܘܬܐ ܕܝܢ ܕܠܘܬ ܐܒܝ ܐܙܠ ܐܢܐ ܘܠܐ ܬܘܒ ܚܙܝܢ ܐܢܬܘܢ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "John 16:11",
      "text": "ܥܠ ܕܝܢܐ ܕܝܢ ܕܐܪܟܘܢܐ ܕܥܠܡܐ ܗܢܐ ܕܝܢ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "John 16:12",
      "text": "ܬܘܒ ܤܓܝ ܐܝܬ ܠܝ ܠܡܐܡܪ ܠܟܘܢ ܐܠܐ ܠܐ ܡܫܟܚܝܢ ܐܢܬܘܢ ܠܡܐܚܕ ܗܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "John 16:13",
      "text": "ܡܐ ܕܐܬܐ ܕܝܢ ܪܘܚܐ ܕܫܪܪܐ ܗܘ ܢܕܒܪܟܘܢ ܒܟܠܗ ܫܪܪܐ ܠܐ ܓܝܪ ܢܡܠܠ ܡܢ ܪܥܝܢ ܢܦܫܗ ܐܠܐ ܟܠ ܕܢܫܡܥ ܗܘ ܢܡܠܠ ܘܥܬܝܕܬܐ ܢܘܕܥܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "John 16:14",
      "text": "ܘܗܘ ܢܫܒܚܢܝ ܡܛܠ ܕܡܢ ܕܝܠܝ ܢܤܒ ܘܢܚܘܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "John 16:15",
      "text": "ܟܠ ܡܕܡ ܕܐܝܬ ܠܐܒܝ ܕܝܠܝ ܗܘ ܡܛܠ ܗܢܐ ܐܡܪܬ ܠܟܘܢ ܕܡܢ ܕܝܠܝ ܢܤܒ ܘܢܚܘܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "John 16:16",
      "text": "ܩܠܝܠ ܘܠܐ ܬܚܙܘܢܢܝ ܘܬܘܒ ܩܠܝܠ ܘܬܚܙܘܢܢܝ ܕܐܙܠ ܐܢܐ ܠܘܬ ܐܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "John 16:17",
      "text": "ܘܐܡܪܘ ܗܘܘ ܬܠܡܝܕܘܗܝ ܚܕ ܠܚܕ ܡܢܐ ܗܝ ܗܕܐ ܕܐܡܪ ܠܢ ܕܩܠܝܠ ܘܠܐ ܬܚܙܘܢܢܝ ܘܬܘܒ ܩܠܝܠ ܘܬܚܙܘܢܢܝ ܘܕܐܙܠ ܐܢܐ ܠܘܬ ܐܒܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "John 16:18",
      "text": "ܘܐܡܪܝܢ ܗܘܘ ܡܢܐ ܗܝ ܗܕܐ ܩܠܝܠ ܕܐܡܪ ܠܐ ܝܕܥܝܢܢ ܡܢܐ ܡܡܠܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "John 16:19",
      "text": "ܝܫܘܥ ܕܝܢ ܝܕܥ ܕܒܥܝܢ ܗܘܘ ܠܡܫܐܠܘܬܗ ܘܐܡܪ ܠܗܘܢ ܥܠ ܗܕܐ ܒܥܝܢ ܐܢܬܘܢ ܥܡ ܚܕܕܐ ܕܐܡܪܬ ܠܟܘܢ ܕܩܠܝܠ ܘܠܐ ܬܚܙܘܢܢܝ ܘܬܘܒ ܩܠܝܠ ܘܬܚܙܘܢܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "John 16:20",
      "text": "ܐܡܝܢ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܬܒܟܘܢ ܐܢܬܘܢ ܘܬܐܠܘܢ ܘܥܠܡܐ ܢܚܕܐ ܘܠܟܘܢ ܬܟܪܐ ܐܠܐ ܟܪܝܘܬܟܘܢ ܠܚܕܘܬܐ ܬܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "John 16:21",
      "text": "ܐܢܬܬܐ ܡܐ ܕܝܠܕܐ ܟܪܝܐ ܠܗ ܕܡܛܐ ܝܘܡܐ ܕܡܘܠܕܗ ܡܐ ܕܝܠܕܬ ܕܝܢ ܒܪܐ ܠܐ ܥܗܕܐ ܐܘܠܨܢܗ ܡܛܠ ܚܕܘܬܐ ܕܐܬܝܠܕ ܒܪܢܫܐ ܒܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "John 16:22",
      "text": "ܐܦ ܐܢܬܘܢ ܗܫܐ ܟܪܝܐ ܠܟܘܢ ܬܘܒ ܕܝܢ ܐܚܙܝܟܘܢ ܘܢܚܕܐ ܠܒܟܘܢ ܘܚܕܘܬܟܘܢ ܠܐ ܐܢܫ ܢܤܒ ܡܢܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "John 16:23",
      "text": "ܘܒܗܘ ܝܘܡܐ ܠܝ ܠܐ ܬܫܐܠܘܢ ܡܕܡ ܐܡܝܢ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܟܠ ܡܕܡ ܕܬܫܐܠܘܢ ܠܐܒܝ ܒܫܡܝ ܢܬܠ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "John 16:24",
      "text": "ܥܕܡܐ ܠܗܫܐ ܠܐ ܫܐܠܬܘܢ ܡܕܡ ܒܫܡܝ ܫܐܠܘ ܘܬܤܒܘܢ ܕܬܗܘܐ ܚܕܘܬܟܘܢ ܡܫܡܠܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 25,
      "referenceLabel": "John 16:25",
      "text": "ܗܠܝܢ ܒܦܠܐܬܐ ܡܠܠܬ ܥܡܟܘܢ ܐܬܝܐ ܕܝܢ ܫܥܬܐ ܐܡܬܝ ܕܠܐ ܐܡܠܠ ܥܡܟܘܢ ܒܦܠܐܬܐ ܐܠܐ ܥܝܢ ܒܓܠܐ ܐܒܕܩ ܠܟܘܢ ܥܠ ܐܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.26",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 26,
      "referenceLabel": "John 16:26",
      "text": "ܒܗܘ ܝܘܡܐ ܕܬܫܐܠܘܢ ܒܫܡܝ ܘܠܐ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܐܢܐ ܐܒܥܐ ܡܢ ܐܒܐ ܥܠܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.27",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 27,
      "referenceLabel": "John 16:27",
      "text": "ܗܘ ܓܝܪ ܐܒܐ ܪܚܡ ܠܟܘܢ ܕܐܢܬܘܢ ܪܚܡܬܘܢܢܝ ܘܗܝܡܢܬܘܢ ܕܐܢܐ ܡܢ ܠܘܬ ܐܠܗܐ ܢܦܩܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.28",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 28,
      "referenceLabel": "John 16:28",
      "text": "ܢܦܩܬ ܡܢ ܠܘܬ ܐܒܐ ܘܐܬܝܬ ܠܥܠܡܐ ܘܬܘܒ ܫܒܩ ܐܢܐ ܠܥܠܡܐ ܘܐܙܠ ܐܢܐ ܠܝ ܠܘܬ ܐܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.29",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 29,
      "referenceLabel": "John 16:29",
      "text": "ܐܡܪܝܢ ܠܗ ܬܠܡܝܕܘܗܝ ܗܐ ܗܫܐ ܓܠܝܐܝܬ ܡܡܠܠ ܐܢܬ ܘܦܠܐܬܐ ܘܠܐ ܚܕܐ ܐܡܪ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.30",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 30,
      "referenceLabel": "John 16:30",
      "text": "ܗܫܐ ܝܕܥܝܢ ܚܢܢ ܕܟܠ ܡܕܡ ܝܕܥ ܐܢܬ ܘܠܐ ܤܢܝܩ ܐܢܬ ܕܐܢܫ ܢܫܐܠܟ ܒܗܕܐ ܡܗܝܡܢܝܢ ܚܢܢ ܕܡܢ ܐܠܗܐ ܢܦܩܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.31",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 31,
      "referenceLabel": "John 16:31",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܗܝܡܢܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.32",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 32,
      "referenceLabel": "John 16:32",
      "text": "ܕܗܐ ܐܬܝܐ ܫܥܬܐ ܘܗܫܐ ܐܬܬ ܕܬܬܒܕܪܘܢ ܐܢܫ ܠܐܬܪܗ ܘܬܫܒܩܘܢܢܝ ܒܠܚܘܕܝ ܘܠܐ ܗܘܝܬ ܒܠܚܘܕܝ ܕܐܒܐ ܥܡܝ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.16.33",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 33,
      "referenceLabel": "John 16:33",
      "text": "ܗܠܝܢ ܐܡܪܬ ܠܟܘܢ ܕܒܝ ܢܗܘܐ ܠܟܘܢ ܫܠܡܐ ܒܥܠܡܐ ܗܘܐ ܠܟܘܢ ܐܘܠܨܢܐ ܐܠܐ ܐܬܠܒܒܘ ܐܢܐ ܙܟܝܬܗ ܠܥܠܡܐ ܀",
      "paragraphStart": false
    }
  ]
}
