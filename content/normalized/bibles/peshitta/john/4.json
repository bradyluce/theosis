{
  "chapter": {
    "id": "peshitta:john.4",
    "translationId": "peshitta",
    "bookSlug": "john",
    "chapterNumber": 4,
    "referenceLabel": "John 4",
    "summary": "Source text for John 4 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.4.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "John 4:1",
      "text": "ܝܕܥ ܕܝܢ ܝܫܘܥ ܕܫܡܥܘ ܦܪܝܫܐ ܕܬܠܡܝܕܐ ܤܓܝܐܐ ܥܒܕ ܘܡܥܡܕ ܝܬܝܪ ܡܢ ܝܘܚܢܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.4.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "John 4:2",
      "text": "ܟܕ ܠܐ ܗܘܐ ܗܘ ܝܫܘܥ ܡܥܡܕ ܗܘܐ ܐܠܐ ܬܠܡܝܕܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "John 4:3",
      "text": "ܘܫܒܩܗ ܠܝܗܘܕ ܘܐܙܠ ܠܗ ܬܘܒ ܠܓܠܝܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "John 4:4",
      "text": "ܡܥܒܕܐ ܗܘܬ ܠܗ ܕܝܢ ܕܢܐܬܐ ܢܥܒܪ ܥܠ ܒܝܬ ܫܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "John 4:5",
      "text": "ܘܐܬܐ ܠܡܕܝܢܬܐ ܕܫܡܪܝܐ ܕܡܬܩܪܝܐ ܫܟܪ ܥܠ ܓܢܒ ܩܪܝܬܐ ܕܝܗܒ ܗܘܐ ܝܥܩܘܒ ܠܝܘܤܦ ܒܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "John 4:6",
      "text": "ܘܐܝܬ ܗܘܐ ܬܡܢ ܡܥܝܢܐ ܕܡܝܐ ܕܝܥܩܘܒ ܗܘ ܕܝܢ ܝܫܘܥ ܠܐܐ ܗܘܐ ܡܢ ܥܡܠܐ ܕܐܘܪܚܐ ܘܝܬܒ ܗܘܐ ܠܗ ܥܠ ܡܥܝܢܐ ܘܐܝܬ ܗܘܝ ܫܬ ܫܥܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "John 4:7",
      "text": "ܘܐܬܬ ܐܢܬܬܐ ܡܢ ܫܡܪܝܢ ܕܬܡܠܐ ܡܝܐ ܘܐܡܪ ܠܗ ܝܫܘܥ ܗܒ ܠܝ ܡܝܐ ܐܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "John 4:8",
      "text": "ܬܠܡܝܕܘܗܝ ܓܝܪ ܥܠܘ ܗܘܘ ܠܡܕܝܢܬܐ ܕܢܙܒܢܘܢ ܠܗܘܢ ܤܝܒܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "John 4:9",
      "text": "ܐܡܪܐ ܠܗ ܗܝ ܐܢܬܬܐ ܫܡܪܝܬܐ ܐܝܟܢܐ ܐܢܬ ܝܗܘܕܝܐ ܐܢܬ ܘܡܢܝ ܫܐܠ ܐܢܬ ܠܡܫܬܐ ܕܐܝܬܝ ܐܢܬܬܐ ܫܡܪܝܬܐ ܠܐ ܓܝܪ ܡܬܚܫܚܝܢ ܝܗܘܕܝܐ ܥܡ ܫܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "John 4:10",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗ ܐܠܘ ܝܕܥܐ ܗܘܝܬܝ ܡܘܗܒܬܐ ܕܐܠܗܐ ܘܡܢܘ ܗܢܐ ܕܐܡܪ ܠܟܝ ܗܒ ܠܝ ܐܫܬܐ ܐܢܬܝ ܫܐܠܐ ܗܘܝܬܝ ܠܗ ܘܝܗܒ ܗܘܐ ܠܟܝ ܡܝܐ ܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "John 4:11",
      "text": "ܐܡܪܐ ܠܗ ܐܢܬܬܐ ܗܝ ܡܪܝ ܠܐ ܕܘܠܐ ܐܝܬ ܠܟ ܘܒܪܐ ܥܡܝܩܐ ܐܝܡܟܐ ܠܟ ܡܝܐ ܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "John 4:12",
      "text": "ܠܡܐ ܐܢܬ ܪܒ ܐܢܬ ܡܢ ܐܒܘܢ ܝܥܩܘܒ ܗܘ ܕܗܘ ܝܗܒ ܠܢ ܒܪܐ ܗܕܐ ܘܗܘ ܡܢܗ ܐܫܬܝ ܘܒܢܘܗܝ ܘܥܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "John 4:13",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗ ܟܠ ܕܢܫܬܐ ܡܢ ܗܠܝܢ ܡܝܐ ܬܘܒ ܢܨܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "John 4:14",
      "text": "ܟܠ ܕܝܢ ܕܢܫܬܐ ܡܢ ܡܝܐ ܕܐܢܐ ܐܬܠ ܠܗ ܠܐ ܢܨܗܐ ܠܥܠܡ ܐܠܐ ܡܝܐ ܗܢܘܢ ܕܝܗܒ ܐܢܐ ܠܗ ܢܗܘܘܢ ܒܗ ܡܥܝܢܐ ܕܡܝܐ ܕܢܒܥܝܢ ܠܚܝܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "John 4:15",
      "text": "ܐܡܪܐ ܠܗ ܐܢܬܬܐ ܗܝ ܡܪܝ ܗܒ ܠܝ ܡܢ ܗܠܝܢ ܡܝܐ ܕܠܐ ܬܘܒ ܐܨܗܐ ܘܠܐ ܗܘܝܬ ܐܬܝܐ ܕܠܝܐ ܡܢ ܗܪܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "John 4:16",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܙܠܝ ܩܪܝ ܠܒܥܠܟܝ ܘܬܝ ܠܗܪܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "John 4:17",
      "text": "ܐܡܪܐ ܠܗ ܠܝܬ ܠܝ ܒܥܠܐ ܐܡܪ ܠܗ ܝܫܘܥ ܫܦܝܪ ܐܡܪܬܝ ܕܠܝܬ ܠܝ ܒܥܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "John 4:18",
      "text": "ܚܡܫܐ ܓܝܪ ܒܥܠܝܢ ܗܘܘ ܠܟܝ ܘܗܢܐ ܕܐܝܬ ܠܟܝ ܗܫܐ ܠܐ ܗܘܐ ܒܥܠܟܝ ܗܕܐ ܫܪܝܪܬܐ ܐܡܪܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "John 4:19",
      "text": "ܐܡܪܐ ܠܗ ܗܝ ܐܢܬܬܐ ܡܪܝ ܚܙܝܐ ܐܢܐ ܕܢܒܝܐ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "John 4:20",
      "text": "ܐܒܗܝܢ ܒܗܢܐ ܛܘܪܐ ܤܓܕܘ ܘܐܢܬܘܢ ܐܡܪܝܢ ܐܢܬܘܢ ܕܒܐܘܪܫܠܡ ܗܘ ܐܬܪ ܕܘܠܐ ܠܡܤܓܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "John 4:21",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܐܢܬܬܐ ܗܝܡܢܝܢܝ ܕܐܬܝܐ ܫܥܬܐ ܕܠܐ ܒܗܢܐ ܛܘܪܐ ܘܐܦ ܠܐ ܒܐܘܪܫܠܡ ܬܤܓܕܘܢ ܠܐܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "John 4:22",
      "text": "ܐܢܬܘܢ ܤܓܕܝܢ ܐܢܬܘܢ ܠܡܕܡ ܕܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܚܢܢ ܕܝܢ ܤܓܕܝܢ ܚܢܢ ܠܡܐ ܕܝܕܥܝܢ ܚܢܢ ܕܚܝܐ ܡܢ ܝܗܘܕܝܐ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "John 4:23",
      "text": "ܐܠܐ ܐܬܝܐ ܫܥܬܐ ܘܗܫܐ ܐܝܬܝܗ ܐܡܬܝ ܕܤܓܘܕܐ ܫܪܝܪܐ ܢܤܓܕܘܢ ܠܐܒܐ ܒܪܘܚܐ ܘܒܫܪܪܐ ܐܦ ܐܒܐ ܓܝܪ ܕܐܝܟ ܗܠܝܢ ܗܘ ܤܓܘܕܐ ܒܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "John 4:24",
      "text": "ܪܘܚܐ ܗܘ ܓܝܪ ܐܠܗܐ ܘܐܝܠܝܢ ܕܤܓܕܝܢ ܠܗ ܒܪܘܚܐ ܘܒܫܪܪܐ ܘܠܐ ܕܢܤܓܕܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "John 4:25",
      "text": "ܐܡܪܐ ܠܗ ܐܢܬܬܐ ܗܝ ܝܕܥܐ ܐܢܐ ܕܡܫܝܚܐ ܐܬܐ ܘܡܐ ܕܐܬܐ ܗܘ ܡܠܦ ܠܢ ܟܠܡܕܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.26",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "John 4:26",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܐܢܐ ܐܢܐ ܕܡܡܠܠ ܐܢܐ ܥܡܟܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.27",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "John 4:27",
      "text": "ܘܟܕ ܡܡܠܠ ܐܬܘ ܬܠܡܝܕܘܗܝ ܘܡܬܕܡܪܝܢ ܗܘܘ ܕܥܡ ܐܢܬܬܐ ܡܡܠܠ ܠܐ ܕܝܢ ܐܢܫ ܐܡܪ ܡܢܐ ܒܥܐ ܐܢܬ ܐܘ ܡܢܐ ܡܡܠܠ ܐܢܬ ܥܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.28",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "John 4:28",
      "text": "ܘܫܒܩܬ ܩܘܠܬܗ ܐܢܬܬܐ ܘܐܙܠܬ ܠܡܕܝܢܬܐ ܘܐܡܪܐ ܠܐܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.29",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "John 4:29",
      "text": "ܬܘ ܚܙܘ ܓܒܪܐ ܕܐܡܪ ܠܝ ܟܠ ܡܕܡ ܕܥܒܕܬ ܠܡܐ ܗܘܝܘ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.30",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "John 4:30",
      "text": "ܘܢܦܩܘ ܐܢܫܐ ܡܢ ܡܕܝܢܬܐ ܘܐܬܝܢ ܗܘܘ ܠܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.31",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "John 4:31",
      "text": "ܘܒܝܢܬ ܗܠܝܢ ܒܥܝܢ ܗܘܘ ܡܢܗ ܬܠܡܝܕܘܗܝ ܘܐܡܪܝܢ ܠܗ ܪܒܢ ܠܥܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.32",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 32,
      "referenceLabel": "John 4:32",
      "text": "ܗܘ ܕܝܢ ܐܡܪ ܠܗܘܢ ܐܝܬ ܠܝ ܡܐܟܘܠܬܐ ܕܐܟܘܠ ܐܝܕܐ ܕܐܢܬܘܢ ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.33",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 33,
      "referenceLabel": "John 4:33",
      "text": "ܐܡܪܝܢ ܬܠܡܝܕܐ ܒܝܢܝܗܘܢ ܠܡܐ ܐܢܫ ܐܝܬܝ ܠܗ ܡܕܡ ܠܡܐܟܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.34",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 34,
      "referenceLabel": "John 4:34",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܡܐܟܘܠܬܝ ܕܝܠܝ ܐܝܬܝܗ ܕܐܥܒܕ ܨܒܝܢܗ ܕܡܢ ܕܫܕܪܢܝ ܘܐܫܠܡܝܘܗܝ ܠܥܒܕܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.35",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 35,
      "referenceLabel": "John 4:35",
      "text": "ܠܐ ܐܢܬܘܢ ܐܡܪܝܢ ܕܒܬܪ ܐܪܒܥܐ ܝܪܚܝܢ ܐܬܐ ܚܨܕܐ ܗܐ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܐܪܝܡܘ ܥܝܢܝܟܘܢ ܘܚܙܘ ܐܪܥܬܐ ܕܚܘܪ ܘܡܛܝ ܠܚܨܕܐ ܡܢ ܟܕܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.36",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 36,
      "referenceLabel": "John 4:36",
      "text": "ܘܐܝܢܐ ܕܚܨܕ ܐܓܪܐ ܢܤܒ ܘܟܢܫ ܦܐܪܐ ܠܚܝܐ ܕܠܥܠܡ ܘܙܪܘܥܐ ܘܚܨܘܕܐ ܐܟܚܕܐ ܢܚܕܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.37",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 37,
      "referenceLabel": "John 4:37",
      "text": "ܒܗܕܐ ܓܝܪ ܐܝܬܝܗ ܡܠܬܐ ܕܫܪܪܐ ܕܐܚܪܝܢ ܗܘ ܙܪܥ ܘܐܚܪܝܢ ܚܨܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.4.38",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 38,
      "referenceLabel": "John 4:38",
