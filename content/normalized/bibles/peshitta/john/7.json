{
  "chapter": {
    "id": "peshitta:john.7",
    "translationId": "peshitta",
    "bookSlug": "john",
    "chapterNumber": 7,
    "referenceLabel": "John 7",
    "summary": "Source text for John 7 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.7.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "John 7:1",
      "text": "ܒܬܪ ܗܠܝܢ ܡܗܠܟ ܗܘܐ ܝܫܘܥ ܒܓܠܝܠܐ ܠܐ ܓܝܪ ܨܒܐ ܗܘܐ ܠܡܗܠܟܘ ܒܝܗܘܕ ܡܛܠ ܕܝܗܘܕܝܐ ܒܥܝܢ ܗܘܘ ܠܡܩܛܠܗ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.7.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "John 7:2",
      "text": "ܘܩܪܝܒ ܗܘܐ ܥܕܥܕܐ ܕܡܛܠܐ ܕܝܗܘܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "John 7:3",
      "text": "ܘܐܡܪܘ ܠܗ ܐܚܘܗܝ ܠܝܫܘܥ ܫܢܐ ܠܟ ܡܟܐ ܘܙܠ ܠܝܗܘܕ ܕܢܚܙܘܢ ܬܠܡܝܕܝܟ ܥܒܕܐ ܕܥܒܕ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "John 7:4",
      "text": "ܠܝܬ ܓܝܪ ܐܢܫ ܕܥܒܕ ܡܕܡ ܒܛܘܫܝܐ ܘܨܒܐ ܗܘ ܕܒܓܠܝܐ ܢܗܘܐ ܐܢ ܗܠܝܢ ܥܒܕ ܐܢܬ ܚܘܐ ܢܦܫܟ ܠܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "John 7:5",
      "text": "ܐܦ ܠܐ ܓܝܪ ܐܚܘܗܝ ܗܝܡܢܘ ܗܘܘ ܒܗ ܒܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "John 7:6",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܙܒܢܝ ܕܝܠܝ ܥܕܡܐ ܠܗܫܐ ܠܐ ܡܛܐ ܙܒܢܟܘܢ ܕܝܢ ܕܝܠܟܘܢ ܒܟܠ ܥܕܢ ܡܛܝܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "John 7:7",
      "text": "ܠܐ ܡܫܟܚ ܥܠܡܐ ܠܡܤܢܟܘܢ ܠܝ ܕܝܢ ܤܢܐ ܡܛܠ ܕܐܢܐ ܡܤܗܕ ܐܢܐ ܥܠܘܗܝ ܕܥܒܕܘܗܝ ܒܝܫܝܢ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "John 7:8",
      "text": "ܐܢܬܘܢ ܤܩܘ ܠܥܕܥܕܐ ܗܢܐ ܐܢܐ ܠܐ ܤܠܩ ܐܢܐ ܗܫܐ ܠܥܕܥܕܐ ܗܢܐ ܡܛܠ ܕܙܒܢܐ ܕܝܠܝ ܠܐ ܥܕܟܝܠ ܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "John 7:9",
      "text": "ܗܠܝܢ ܐܡܪ ܘܦܫ ܠܗ ܒܓܠܝܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "John 7:10",
      "text": "ܟܕ ܕܝܢ ܤܠܩܘ ܐܚܘܗܝ ܠܥܕܥܕܐ ܗܝܕܝܢ ܐܦ ܗܘ ܤܠܩ ܠܐ ܒܓܠܝܐ ܐܠܐ ܐܝܟ ܕܒܛܘܫܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "John 7:11",
      "text": "ܝܗܘܕܝܐ ܕܝܢ ܒܥܝܢ ܗܘܘ ܠܗ ܒܥܕܥܕܐ ܘܐܡܪܝܢ ܗܘܘ ܐܝܟܘ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "John 7:12",
      "text": "ܘܪܛܢܐ ܤܓܝܐܐ ܡܛܠܬܗ ܐܝܬ ܗܘܐ ܒܟܢܫܐ ܐܝܬ ܗܘܘ ܓܝܪ ܕܐܡܪܝܢ ܕܛܒ ܗܘ ܘܐܚܪܢܐ ܐܡܪܝܢ ܗܘܘ ܠܐ ܐܠܐ ܡܛܥܐ ܠܥܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "John 7:13",
      "text": "ܠܐ ܕܝܢ ܐܢܫ ܓܠܝܐܝܬ ܡܡܠܠ ܗܘܐ ܥܠܘܗܝ ܡܛܠ ܕܚܠܬܐ ܕܝܗܘܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "John 7:14",
      "text": "ܟܕ ܕܝܢ ܦܠܓܘ ܝܘܡܬܐ ܕܥܕܥܕܐ ܤܠܩ ܝܫܘܥ ܠܗܝܟܠܐ ܘܡܠܦ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "John 7:15",
      "text": "ܘܡܬܕܡܪܝܢ ܗܘܘ ܝܗܘܕܝܐ ܘܐܡܪܝܢ ܐܝܟܢܐ ܝܕܥ ܗܢܐ ܤܦܪܐ ܟܕ ܠܐ ܝܠܦ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "John 7:16",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܝܘܠܦܢܝ ܠܐ ܗܘܐ ܕܝܠܝ ܐܠܐ ܕܗܘ ܕܫܕܪܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "John 7:17",
      "text": "ܡܢ ܕܨܒܐ ܕܢܥܒܕ ܨܒܝܢܗ ܡܤܬܟܠ ܝܘܠܦܢܝ ܐܢ ܡܢ ܐܠܗܐ ܗܘ ܐܘ ܐܢܐ ܡܢ ܨܒܘܬ ܢܦܫܝ ܡܡܠܠ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "John 7:18",
      "text": "ܡܢ ܕܡܢ ܨܒܘܬ ܪܥܝܢܗ ܡܡܠܠ ܫܘܒܚܐ ܠܢܦܫܗ ܒܥܐ ܗܘ ܕܝܢ ܕܫܘܒܚܐ ܕܡܢ ܕܫܕܪܗ ܒܥܐ ܫܪܝܪ ܗܘ ܘܥܘܠܐ ܒܠܒܗ ܠܐ ܐܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "John 7:19",
      "text": "ܠܐ ܗܘܐ ܡܘܫܐ ܝܗܒ ܠܟܘܢ ܢܡܘܤܐ ܘܠܐ ܐܢܫ ܡܢܟܘܢ ܢܛܪ ܢܡܘܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "John 7:20",
      "text": "ܡܢܐ ܒܥܝܢ ܐܢܬܘܢ ܠܡܩܛܠܢܝ ܥܢܐ ܟܢܫܐ ܘܐܡܪܝܢ ܕܝܘܐ ܐܝܬ ܠܟ ܡܢܘ ܒܥܐ ܠܡܩܛܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "John 7:21",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗܘܢ ܚܕ ܥܒܕܐ ܥܒܕܬ ܘܟܠܟܘܢ ܡܬܕܡܪܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "John 7:22",
      "text": "ܡܛܠ ܗܢܐ ܡܘܫܐ ܝܗܒ ܠܟܘܢ ܓܙܘܪܬܐ ܠܐ ܗܘܐ ܡܛܠ ܕܡܢܗ ܗܝ ܡܢ ܡܘܫܐ ܐܠܐ ܕܡܢ ܐܒܗܬܐ ܗܝ ܘܒܫܒܬܐ ܓܙܪܝܢ ܐܢܬܘܢ ܒܪܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "John 7:23",
      "text": "ܐܢ ܒܪܢܫܐ ܡܬܓܙܪ ܒܝܘܡܐ ܕܫܒܬܐ ܡܛܠ ܕܠܐ ܢܫܬܪܐ ܢܡܘܤܐ ܕܡܘܫܐ ܥܠܝ ܪܛܢܝܢ ܐܢܬܘܢ ܕܟܠܗ ܒܪܢܫܐ ܐܚܠܡܬ ܒܝܘܡܐ ܕܫܒܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "John 7:24",
      "text": "ܠܐ ܬܗܘܘܢ ܕܝܢܝܢ ܒܡܤܒ ܒܐܦܐ ܐܠܐ ܕܝܢܐ ܟܐܢܐ ܕܘܢܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "John 7:25",
      "text": "ܘܐܡܪܝܢ ܗܘܘ ܐܢܫܐ ܡܢ ܐܘܪܫܠܡ ܠܘ ܗܢܘ ܗܘ ܕܒܥܝܢ ܠܡܩܛܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.26",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "John 7:26",
      "text": "ܘܗܐ ܓܠܝܐܝܬ ܡܡܠܠ ܘܡܕܡ ܠܐ ܐܡܪܝܢ ܠܗ ܕܠܡܐ ܝܕܥܘ ܩܫܝܫܝܢ ܕܗܢܘ ܫܪܝܪܐܝܬ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.27",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "John 7:27",
      "text": "ܐܠܐ ܠܗܢܐ ܝܕܥܝܢ ܚܢܢ ܡܢ ܐܝܡܟܐ ܗܘ ܡܫܝܚܐ ܕܝܢ ܐܡܬܝ ܕܐܬܐ ܠܐ ܐܢܫ ܝܕܥ ܡܢ ܐܝܡܟܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.28",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "John 7:28",
      "text": "ܘܐܪܝܡ ܝܫܘܥ ܩܠܗ ܟܕ ܡܠܦ ܒܗܝܟܠܐ ܘܐܡܪ ܘܠܝ ܝܕܥܝܢ ܐܢܬܘܢ ܘܡܢ ܐܝܡܟܐ ܐܢܐ ܝܕܥܝܢ ܐܢܬܘܢ ܘܡܢ ܨܒܘܬ ܢܦܫܝ ܠܐ ܐܬܝܬ ܐܠܐ ܫܪܝܪ ܗܘ ܡܢ ܕܫܕܪܢܝ ܗܘ ܕܐܢܬܘܢ ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.29",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "John 7:29",
      "text": "ܐܢܐ ܕܝܢ ܝܕܥ ܐܢܐ ܠܗ ܕܡܢ ܠܘܬܗ ܐܢܐ ܘܗܘ ܫܕܪܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.30",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 30,
      "referenceLabel": "John 7:30",
      "text": "ܘܒܥܘ ܠܡܐܚܕܗ ܘܠܐ ܐܢܫ ܐܪܡܝ ܥܠܘܗܝ ܐܝܕܝܐ ܡܛܠ ܕܠܐ ܥܕܟܝܠ ܐܬܬ ܗܘܬ ܫܥܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.31",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 31,
      "referenceLabel": "John 7:31",
      "text": "ܤܓܝܐܐ ܕܝܢ ܡܢ ܟܢܫܐ ܗܝܡܢܘ ܒܗ ܘܐܡܪܝܢ ܡܫܝܚܐ ܡܐ ܕܐܬܐ ܠܡܐ ܕܝܬܝܪܢ ܡܢ ܗܠܝܢ ܐܬܘܬܐ ܕܥܒܕ ܗܢܐ ܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.32",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 32,
      "referenceLabel": "John 7:32",
      "text": "ܘܫܡܥܘ ܦܪܝܫܐ ܠܟܢܫܐ ܕܡܡܠܠܝܢ ܥܠܘܗܝ ܗܠܝܢ ܘܫܕܪܘ ܗܢܘܢ ܘܪܒܝ ܟܗܢܐ ܕܚܫܐ ܕܢܐܚܕܘܢܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.33",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 33,
      "referenceLabel": "John 7:33",
      "text": "ܘܐܡܪ ܝܫܘܥ ܩܠܝܠ ܬܘܒ ܙܒܢܐ ܥܡܟܘܢ ܐܢܐ ܘܐܙܠ ܐܢܐ ܠܘܬ ܡܢ ܕܫܕܪܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.34",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 34,
      "referenceLabel": "John 7:34",
      "text": "ܘܬܒܥܘܢܢܝ ܘܠܐ ܬܫܟܚܘܢܢܝ ܘܐܝܟܐ ܕܐܢܐ ܐܝܬܝ ܠܐ ܡܫܟܚܝܢ ܐܢܬܘܢ ܠܡܐܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.35",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 35,
      "referenceLabel": "John 7:35",
      "text": "ܐܡܪܝܢ ܝܗܘܕܝܐ ܒܢܦܫܗܘܢ ܠܐܝܟܐ ܥܬܝܕ ܗܢܐ ܠܡܐܙܠ ܕܚܢܢ ܠܐ ܡܫܟܚܝܢ ܚܢܢ ܠܗ ܠܡܐ ܟܝ ܠܐܬܪܘܬܐ ܕܥܡܡܐ ܥܬܝܕ ܕܢܐܙܠ ܘܢܠܦ ܠܚܢܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.36",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 36,
      "referenceLabel": "John 7:36",
      "text": "ܡܢܐ ܗܝ ܗܕܐ ܡܠܬܐ ܕܐܡܪ ܕܬܒܥܘܢܢܝ ܘܠܐ ܬܫܟܚܘܢܢܝ ܘܐܝܟܐ ܕܐܢܐ ܐܝܬܝ ܐܢܬܘܢ ܠܐ ܡܫܟܚܝܢ ܐܢܬܘܢ ܠܡܐܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.7.37",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 37,
      "referenceLabel": "John 7:37",
