{
  "chapter": {
    "id": "peshitta:john.21",
    "translationId": "peshitta",
    "bookSlug": "john",
    "chapterNumber": 21,
    "referenceLabel": "John 21",
    "summary": "Source text for John 21 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.21.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "John 21:1",
      "text": "ܒܬܪ ܗܠܝܢ ܚܘܝ ܬܘܒ ܢܦܫܗ ܝܫܘܥ ܠܬܠܡܝܕܘܗܝ ܥܠ ܝܡܐ ܕܛܝܒܪܝܘܤ ܚܘܝ ܕܝܢ ܗܟܢܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.21.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "John 21:2",
      "text": "ܐܝܬܝܗܘܢ ܗܘܘ ܐܟܚܕܐ ܫܡܥܘܢ ܟܐܦܐ ܘܬܐܘܡܐ ܕܡܬܐܡܪ ܬܐܡܐ ܘܢܬܢܝܐܝܠ ܗܘ ܕܡܢ ܩܛܢܐ ܕܓܠܝܠܐ ܘܒܢܝ ܙܒܕܝ ܘܬܪܝܢ ܐܚܪܢܝܢ ܡܢ ܬܠܡܝܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "John 21:3",
      "text": "ܐܡܪ ܠܗܘܢ ܫܡܥܘܢ ܟܐܦܐ ܐܙܠ ܐܢܐ ܐܨܘܕ ܢܘܢܐ ܐܡܪܝܢ ܠܗ ܐܦ ܚܢܢ ܐܬܝܢܢ ܥܡܟ ܘܢܦܩܘ ܘܤܠܩܘ ܠܤܦܝܢܬܐ ܘܒܗܘ ܠܠܝܐ ܡܕܡ ܠܐ ܨܕܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "John 21:4",
      "text": "ܟܕ ܕܝܢ ܗܘܐ ܨܦܪܐ ܩܡ ܝܫܘܥ ܥܠ ܝܕ ܝܡܐ ܘܠܐ ܝܕܥܘ ܬܠܡܝܕܐ ܕܝܫܘܥ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "John 21:5",
      "text": "ܘܐܡܪ ܠܗܘܢ ܝܫܘܥ ܛܠܝܐ ܠܡܐ ܐܝܬ ܠܟܘܢ ܡܕܡ ܠܡܠܥܤ ܐܡܪܝܢ ܠܗ ܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "John 21:6",
      "text": "ܐܡܪ ܠܗܘܢ ܐܪܡܘ ܡܨܝܕܬܟܘܢ ܡܢ ܓܒܐ ܕܝܡܝܢܐ ܕܤܦܝܢܬܐ ܘܡܫܟܚܝܢ ܐܢܬܘܢ ܘܐܪܡܝܘ ܘܠܐ ܐܫܟܚܘ ܠܡܓܕܗ ܠܡܨܝܕܬܐ ܡܢ ܤܘܓܐܐ ܕܢܘܢܐ ܕܐܚܕܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "John 21:7",
      "text": "ܘܐܡܪ ܬܠܡܝܕܐ ܗܘ ܕܪܚܡ ܗܘܐ ܠܗ ܝܫܘܥ ܠܟܐܦܐ ܗܢܐ ܡܪܢ ܗܘ ܫܡܥܘܢ ܕܝܢ ܟܕ ܫܡܥ ܕܡܪܢ ܗܘ ܢܤܒ ܟܘܬܝܢܗ ܡܚܐ ܒܚܨܘܗܝ ܡܛܠ ܕܥܪܛܠܝܐ ܗܘܐ ܘܫܕܐ ܢܦܫܗ ܒܝܡܐ ܕܢܐܬܐ ܠܘܬ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "John 21:8",
      "text": "ܐܚܪܢܐ ܕܝܢ ܬܠܡܝܕܐ ܒܤܦܝܢܬܐ ܐܬܘ ܠܐ ܓܝܪ ܪܚܝܩܝܢ ܗܘܘ ܤܓܝ ܡܢ ܐܪܥܐ ܐܠܐ ܐܝܟ ܡܐܬܝܢ ܐܡܝܢ ܘܢܓܕܝܢ ܗܘܘ ܠܗ ܠܡܨܝܕܬܐ ܗܝ ܕܢܘܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "John 21:9",
      "text": "ܟܕ ܕܝܢ ܤܠܩܘ ܠܐܪܥܐ ܚܙܘ ܓܘܡܪܐ ܟܕ ܤܝܡܢ ܘܢܘܢܐ ܟܕ ܤܝܡ ܥܠܝܗܝܢ ܘܠܚܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "John 21:10",
      "text": "ܘܐܡܪ ܠܗܘܢ ܝܫܘܥ ܐܝܬܘ ܡܢ ܗܢܘܢ ܢܘܢܐ ܕܨܕܬܘܢ ܗܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "John 21:11",
      "text": "ܘܤܠܩ ܫܡܥܘܢ ܟܐܦܐ ܘܢܓܕܗ ܠܡܨܝܕܬܐ ܠܐܪܥܐ ܟܕ ܡܠܝܐ ܢܘܢܐ ܪܘܪܒܐ ܡܐܐ ܘܚܡܫܝܢ ܘܬܠܬܐ ܘܒܗܢܐ ܟܠܗ ܝܘܩܪܐ ܠܐ ܐܨܛܪܝܬ ܡܨܝܕܬܐ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "John 21:12",
      "text": "ܘܐܡܪ ܠܗܘܢ ܝܫܘܥ ܬܘ ܐܫܬܪܘ ܐܢܫ ܕܝܢ ܡܢ ܬܠܡܝܕܐ ܠܐ ܡܡܪܚ ܗܘܐ ܕܢܫܐܠܝܘܗܝ ܕܡܢܘ ܕܝܕܥܝܢ ܗܘܘ ܕܡܪܢ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "John 21:13",
      "text": "ܩܪܒ ܕܝܢ ܝܫܘܥ ܘܫܩܠ ܠܚܡܐ ܘܢܘܢܐ ܘܝܗܒ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "John 21:14",
      "text": "ܗܕܐ ܕܬܠܬ ܙܒܢܝܢ ܐܬܚܙܝ ܝܫܘܥ ܠܬܠܡܝܕܘܗܝ ܟܕ ܩܡ ܡܢ ܒܝܬ ܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "John 21:15",
      "text": "ܟܕ ܕܝܢ ܐܫܬܪܝܘ ܐܡܪ ܝܫܘܥ ܠܫܡܥܘܢ ܟܐܦܐ ܫܡܥܘܢ ܒܪ ܝܘܢܐ ܪܚܡ ܐܢܬ ܠܝ ܝܬܝܪ ܡܢ ܗܠܝܢ ܐܡܪ ܠܗ ܐܝܢ ܡܪܝ ܐܢܬ ܝܕܥ ܐܢܬ ܕܪܚܡ ܐܢܐ ܠܟ ܐܡܪ ܠܗ ܪܥܝ ܠܝ ܐܡܪܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "John 21:16",
      "text": "ܐܡܪ ܠܗ ܬܘܒ ܕܬܪܬܝܢ ܙܒܢܝܢ ܫܡܥܘܢ ܒܪ ܝܘܢܐ ܪܚܡ ܐܢܬ ܠܝ ܐܡܪ ܠܗ ܐܝܢ ܡܪܝ ܐܢܬ ܝܕܥ ܐܢܬ ܕܪܚܡ ܐܢܐ ܠܟ ܐܡܪ ܠܗ ܝܫܘܥ ܪܥܝ ܠܝ ܥܪܒܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "John 21:17",
      "text": "ܐܡܪ ܠܗ ܕܬܠܬ ܙܒܢܝܢ ܫܡܥܘܢ ܒܪ ܝܘܢܐ ܪܚܡ ܐܢܬ ܠܝ ܘܟܪܝܬ ܠܗ ܠܟܐܦܐ ܕܐܡܪ ܠܗ ܕܬܠܬ ܙܒܢܝܢ ܕܪܚܡ ܐܢܬ ܠܝ ܘܐܡܪ ܠܗ ܡܪܝ ܟܠ ܡܕܡ ܐܢܬ ܚܟܡ ܐܢܬ ܐܢܬ ܝܕܥ ܐܢܬ ܕܪܚܡ ܐܢܐ ܠܟ ܐܡܪ ܠܗ ܝܫܘܥ ܪܥܝ ܠܝ ܢܩܘܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "John 21:18",
      "text": "ܐܡܝܢ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟ ܕܟܕ ܛܠܐ ܗܘܝܬ ܐܢܬ ܠܢܦܫܟ ܐܤܪ ܗܘܝܬ ܚܨܝܟ ܘܡܗܠܟ ܗܘܝܬ ܠܐܝܟܐ ܕܨܒܐ ܐܢܬ ܡܐ ܕܝܢ ܕܤܐܒܬ ܬܦܫܘܛ ܐܝܕܝܟ ܘܐܚܪܝܢ ܢܐܤܘܪ ܠܟ ܚܨܝܟ ܘܢܘܒܠܟ ܠܐܝܟܐ ܕܠܐ ܨܒܐ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "John 21:19",
      "text": "ܗܕܐ ܕܝܢ ܐܡܪ ܕܢܚܘܐ ܒܐܝܢܐ ܡܘܬܐ ܥܬܝܕ ܕܢܫܒܚ ܠܐܠܗܐ ܘܟܕ ܐܡܪ ܗܠܝܢ ܐܡܪ ܠܗ ܬܐ ܒܬܪܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "John 21:20",
      "text": "ܘܐܬܦܢܝ ܫܡܥܘܢ ܟܐܦܐ ܘܚܙܐ ܠܬܠܡܝܕܐ ܗܘ ܕܪܚܡ ܗܘܐ ܝܫܘܥ ܕܐܬܐ ܒܬܪܗ ܗܘ ܕܢܦܠ ܗܘܐ ܒܚܫܡܝܬܐ ܥܠ ܚܕܝܗ ܕܝܫܘܥ ܘܐܡܪ ܡܪܝ ܡܢܘ ܡܫܠܡ ܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "John 21:21",
      "text": "ܠܗܢܐ ܟܕ ܚܙܐ ܟܐܦܐ ܐܡܪ ܠܝܫܘܥ ܡܪܝ ܘܗܢܐ ܡܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "John 21:22",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܐܢ ܨܒܐ ܐܢܐ ܕܢܩܘܐ ܗܢܐ ܥܕܡܐ ܕܐܬܐ ܐܢܐ ܠܟ ܡܐ ܠܟ ܐܢܬ ܬܐ ܒܬܪܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "John 21:23",
      "text": "ܘܢܦܩܬ ܗܕܐ ܡܠܬܐ ܒܝܬ ܐܚܐ ܕܗܘ ܬܠܡܝܕܐ ܠܐ ܡܐܬ ܝܫܘܥ ܕܝܢ ܠܐ ܗܘܐ ܕܠܐ ܡܐܬ ܐܡܪ ܐܠܐ ܕܐܢ ܨܒܐ ܐܢܐ ܕܢܩܘܐ ܗܢܐ ܥܕܡܐ ܕܐܬܐ ܐܢܐ ܠܟ ܡܐ ܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "John 21:24",
      "text": "ܗܢܘ ܬܠܡܝܕܐ ܕܐܤܗܕ ܥܠ ܗܠܝܢ ܟܠܗܝܢ ܘܐܦ ܟܬܒ ܐܢܝܢ ܘܝܕܥܝܢ ܚܢܢ ܕܫܪܝܪܐ ܗܝ ܤܗܕܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.21.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "John 21:25",
      "text": "ܐܝܬ ܕܝܢ ܐܦ ܐܚܪܢܝܬܐ ܤܓܝܐܬܐ ܕܥܒܕ ܝܫܘܥ ܐܝܠܝܢ ܕܐܠܘ ܚܕܐ ܚܕܐ ܡܬܟܬܒܢ ܗܘܝ ܐܦ ܠܐ ܗܘ ܥܠܡܐ ܐܝܟ ܕܤܒܪ ܐܢܐ ܤܦܩ ܗܘܐ ܠܟܬܒܐ ܕܡܬܟܬܒܝܢ ܗܘܘ ܀ ܀ ܀",
      "paragraphStart": false
    }
  ]
}
