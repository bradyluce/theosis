    "chapterNumber": 18,
    "referenceLabel": "John 18",
    "summary": "Source text for John 18 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.18.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "John 18:1",
      "text": "ܗܠܝܢ ܐܡܪ ܝܫܘܥ ܘܢܦܩ ܥܡ ܬܠܡܝܕܘܗܝ ܠܥܒܪܐ ܕܪܓܠܬܐ ܕܩܕܪܘܢ ܐܬܪ ܕܐܝܬ ܗܘܬ ܓܢܬܐ ܐܝܟܐ ܕܥܠ ܗܘ ܘܬܠܡܝܕܘܗܝ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.18.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "John 18:2",
      "text": "ܝܕܥ ܗܘܐ ܕܝܢ ܐܦ ܝܗܘܕܐ ܡܫܠܡܢܐ ܠܕܘܟܬܐ ܗܝ ܡܛܠ ܕܤܓܝ ܙܒܢܐ ܟܢܫ ܗܘܐ ܬܡܢ ܝܫܘܥ ܥܡ ܬܠܡܝܕܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "John 18:3",
      "text": "ܗܘ ܗܟܝܠ ܝܗܘܕܐ ܕܒܪ ܐܤܦܝܪ ܘܡܢ ܠܘܬ ܪܒܝ ܟܗܢܐ ܘܦܪܝܫܐ ܕܒܪ ܕܚܫܐ ܘܐܬܐ ܠܬܡܢ ܥܡ ܢܦܛܪܐ ܘܠܡܦܝܕܐ ܘܙܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "John 18:4",
      "text": "ܝܫܘܥ ܕܝܢ ܕܝܕܥ ܗܘܐ ܟܠ ܡܕܡ ܕܐܬܐ ܥܠܘܗܝ ܢܦܩ ܘܐܡܪ ܠܗܘܢ ܠܡܢ ܒܥܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "John 18:5",
      "text": "ܐܡܪܝܢ ܠܗ ܠܝܫܘܥ ܢܨܪܝܐ ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܐܢܐ ܐܢܐ ܩܐܡ ܗܘܐ ܕܝܢ ܐܦ ܝܗܘܕܐ ܡܫܠܡܢܐ ܥܡܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "John 18:6",
      "text": "ܘܟܕ ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܕܐܢܐ ܐܢܐ ܐܙܠܘ ܠܒܤܬܪܗܘܢ ܘܢܦܠܘ ܥܠ ܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "John 18:7",
      "text": "ܬܘܒ ܫܐܠ ܐܢܘܢ ܝܫܘܥ ܠܡܢ ܒܥܝܢ ܐܢܬܘܢ ܗܢܘܢ ܕܝܢ ܐܡܪܘ ܠܝܫܘܥ ܢܨܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "John 18:8",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܐܡܪܬ ܠܟܘܢ ܕܐܢܐ ܐܢܐ ܘܐܢ ܠܝ ܒܥܝܢ ܐܢܬܘܢ ܫܒܘܩܘ ܠܗܠܝܢ ܐܙܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "John 18:9",
      "text": "ܕܬܫܠܡ ܡܠܬܐ ܕܐܡܪ ܕܐܝܠܝܢ ܕܝܗܒܬ ܠܝ ܠܐ ܐܘܒܕܬ ܡܢܗܘܢ ܐܦܠܐ ܚܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "John 18:10",
      "text": "ܫܡܥܘܢ ܕܝܢ ܟܐܦܐ ܐܝܬ ܗܘܐ ܥܠܘܗܝ ܤܦܤܪܐ ܘܫܡܛܗ ܘܡܚܝܗܝ ܠܥܒܕܗ ܕܪܒ ܟܗܢܐ ܘܫܩܠܗ ܐܕܢܗ ܕܝܡܝܢܐ ܫܡܗ ܕܝܢ ܕܥܒܕܐ ܡܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "John 18:11",
      "text": "ܘܐܡܪ ܝܫܘܥ ܠܟܐܦܐ ܤܝܡ ܤܦܤܪܐ ܒܚܠܬܗ ܟܤܐ ܕܝܗܒ ܠܝ ܐܒܝ ܠܐ ܐܫܬܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "John 18:12",
      "text": "ܗܝܕܝܢ ܐܤܦܝܪ ܘܟܠܝܪܟܐ ܘܕܚܫܐ ܕܝܗܘܕܝܐ ܐܚܕܘܗܝ ܠܝܫܘܥ ܘܐܤܪܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "John 18:13",
      "text": "ܘܐܝܬܝܘܗܝ ܠܘܬ ܚܢܢ ܠܘܩܕܡ ܡܛܠ ܕܚܡܘܗܝ ܗܘܐ ܕܩܝܦܐ ܗܘ ܕܐܝܬܘܗܝ ܗܘܐ ܪܒ ܟܗܢܐ ܕܫܢܬܐ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "John 18:14",
      "text": "ܐܝܬܘܗܝ ܗܘܐ ܕܝܢ ܩܝܦܐ ܗܘ ܕܡܠܟ ܠܝܗܘܕܝܐ ܕܦܩܚ ܕܚܕ ܓܒܪܐ ܢܡܘܬ ܚܠܦ ܥܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "John 18:15",
      "text": "ܫܡܥܘܢ ܕܝܢ ܟܐܦܐ ܘܚܕ ܡܢ ܬܠܡܝܕܐ ܐܚܪܢܐ ܐܬܝܢ ܗܘܘ ܒܬܪܗ ܕܝܫܘܥ ܠܗܘ ܕܝܢ ܬܠܡܝܕܐ ܝܕܥ ܗܘܐ ܠܗ ܪܒ ܟܗܢܐ ܘܥܠ ܥܡ ܝܫܘܥ ܠܕܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 16,
      "referenceLabel": "John 18:16",
      "text": "ܫܡܥܘܢ ܕܝܢ ܩܐܡ ܗܘܐ ܠܒܪ ܠܘܬ ܬܪܥܐ ܘܢܦܩ ܗܘ ܬܠܡܝܕܐ ܐܚܪܢܐ ܕܝܕܥ ܗܘܐ ܠܗ ܪܒ ܟܗܢܐ ܘܐܡܪ ܠܢܛܪܬ ܬܪܥܐ ܘܐܥܠܗ ܠܫܡܥܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 17,
      "referenceLabel": "John 18:17",
      "text": "ܐܡܪܬ ܕܝܢ ܥܠܝܡܬܐ ܢܛܪܬ ܬܪܥܐ ܠܫܡܥܘܢ ܠܡܐ ܐܦ ܐܢܬ ܡܢ ܬܠܡܝܕܘܗܝ ܐܢܬ ܕܗܢܐ ܓܒܪܐ ܐܡܪ ܠܗ ܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 18,
      "referenceLabel": "John 18:18",
      "text": "ܘܩܝܡܝܢ ܗܘܘ ܥܒܕܐ ܘܕܚܫܐ ܘܤܝܡܝܢ ܗܘܘ ܢܘܪܐ ܕܢܫܚܢܘܢ ܡܛܠ ܕܩܪܝܫ ܗܘܐ ܩܐܡ ܗܘܐ ܕܝܢ ܐܦ ܫܡܥܘܢ ܥܡܗܘܢ ܘܫܚܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 19,
      "referenceLabel": "John 18:19",
      "text": "ܪܒ ܟܗܢܐ ܕܝܢ ܫܐܠܗ ܠܝܫܘܥ ܥܠ ܬܠܡܝܕܘܗܝ ܘܥܠ ܝܘܠܦܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 20,
      "referenceLabel": "John 18:20",
      "text": "ܘܐܡܪ ܠܗ ܝܫܘܥ ܐܢܐ ܥܝܢ ܒܓܠܐ ܡܠܠܬ ܥܡ ܥܡܐ ܘܒܟܠܙܒܢ ܐܠܦܬ ܒܟܢܘܫܬܐ ܘܒܗܝܟܠܐ ܐܝܟܐ ܕܟܠܗܘܢ ܝܗܘܕܝܐ ܡܬܟܢܫܝܢ ܘܡܕܡ ܒܛܘܫܝܐ ܠܐ ܡܠܠܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 21,
      "referenceLabel": "John 18:21",
      "text": "ܡܢܐ ܡܫܐܠ ܐܢܬ ܠܝ ܫܐܠ ܠܗܢܘܢ ܕܫܡܥܘ ܡܢܐ ܡܠܠܬ ܥܡܗܘܢ ܗܐ ܗܢܘܢ ܝܕܥܝܢ ܟܠ ܡܕܡ ܕܐܡܪܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 22,
      "referenceLabel": "John 18:22",
      "text": "ܘܟܕ ܗܠܝܢ ܐܡܪ ܚܕ ܡܢ ܕܚܫܐ ܕܩܐܡ ܗܘܐ ܡܚܝܗܝ ܥܠ ܦܟܗ ܠܝܫܘܥ ܘܐܡܪ ܠܗ ܗܟܢܐ ܝܗܒ ܐܢܬ ܦܬܓܡܐ ܠܪܒ ܟܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 23,
      "referenceLabel": "John 18:23",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗ ܐܢ ܒܝܫܐܝܬ ܡܠܠܬ ܐܤܗܕ ܥܠ ܒܝܫܬܐ ܘܐܢ ܕܝܢ ܫܦܝܪ ܠܡܢܐ ܡܚܝܬܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 24,
      "referenceLabel": "John 18:24",
      "text": "ܚܢܢ ܕܝܢ ܫܕܪ ܠܝܫܘܥ ܟܕ ܐܤܝܪ ܠܘܬ ܩܝܦܐ ܪܒ ܟܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 25,
      "referenceLabel": "John 18:25",
      "text": "ܘܫܡܥܘܢ ܟܐܦܐ ܩܐܡ ܗܘܐ ܘܫܚܢ ܘܐܡܪܝܢ ܠܗ ܠܡܐ ܐܦ ܐܢܬ ܚܕ ܡܢ ܬܠܡܝܕܘܗܝ ܐܢܬ ܘܗܘ ܟܦܪ ܘܐܡܪ ܠܐ ܗܘܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.26",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 26,
      "referenceLabel": "John 18:26",
      "text": "ܐܡܪ ܠܗ ܚܕ ܡܢ ܥܒܕܐ ܕܪܒ ܟܗܢܐ ܐܚܝܢܗ ܕܗܘ ܕܦܤܩ ܗܘܐ ܫܡܥܘܢ ܐܕܢܗ ܠܐ ܐܢܐ ܚܙܝܬܟ ܥܡܗ ܒܓܢܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.27",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 27,
      "referenceLabel": "John 18:27",
      "text": "ܘܬܘܒ ܟܦܪ ܫܡܥܘܢ ܘܒܗ ܒܫܥܬܐ ܩܪܐ ܬܪܢܓܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.28",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 28,
      "referenceLabel": "John 18:28",
      "text": "ܐܝܬܝܘܗܝ ܕܝܢ ܠܝܫܘܥ ܡܢ ܠܘܬ ܩܝܦܐ ܠܦܪܛܘܪܝܢ ܘܐܝܬܘܗܝ ܗܘܐ ܨܦܪܐ ܘܗܢܘܢ ܠܐ ܥܠܘ ܠܦܪܛܘܪܝܢ ܕܠܐ ܢܬܛܘܫܘܢ ܥܕ ܐܟܠܝܢ ܦܨܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.29",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 29,
      "referenceLabel": "John 18:29",
      "text": "ܢܦܩ ܕܝܢ ܦܝܠܛܘܤ ܠܒܪ ܠܘܬܗܘܢ ܘܐܡܪ ܠܗܘܢ ܡܢܐ ܡܐܟܠ ܩܪܨܐ ܐܝܬ ܠܟܘܢ ܥܠ ܓܒܪܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.30",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 30,
      "referenceLabel": "John 18:30",
      "text": "ܥܢܘ ܘܐܡܪܝܢ ܠܗ ܐܠܘ ܠܐ ܥܒܕ ܒܝܫܬܐ ܗܘܐ ܐܦܠܐ ܠܟ ܡܫܠܡܝܢ ܗܘܝܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.31",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 31,
      "referenceLabel": "John 18:31",
      "text": "ܐܡܪ ܠܗܘܢ ܦܝܠܛܘܤ ܕܘܒܪܘܗܝ ܐܢܬܘܢ ܘܕܘܢܘܗܝ ܐܝܟ ܢܡܘܤܟܘܢ ܐܡܪܝܢ ܠܗ ܝܗܘܕܝܐ ܠܐ ܫܠܝܛ ܠܢ ܠܡܩܛܠ ܠܐܢܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.32",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 32,
      "referenceLabel": "John 18:32",
      "text": "ܕܬܫܠܡ ܡܠܬܐ ܕܐܡܪ ܝܫܘܥ ܟܕ ܡܘܕܥ ܒܐܝܢܐ ܡܘܬܐ ܥܬܝܕ ܕܢܡܘܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.33",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 33,
      "referenceLabel": "John 18:33",
      "text": "ܥܠ ܕܝܢ ܦܝܠܛܘܤ ܠܦܪܛܘܪܝܢ ܘܩܪܐ ܠܝܫܘܥ ܘܐܡܪ ܠܗ ܐܢܬ ܗܘ ܡܠܟܗܘܢ ܕܝܗܘܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.18.34",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 18,
      "verseNumber": 34,
      "referenceLabel": "John 18:34",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܡܢ ܢܦܫܟ ܐܡܪܬ ܗܕܐ ܐܘ ܐܚܪܢܐ ܐܡܪܘ ܠܟ ܥܠܝ ܀",
