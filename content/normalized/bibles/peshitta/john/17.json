{
  "chapter": {
    "id": "peshitta:john.17",
    "translationId": "peshitta",
    "bookSlug": "john",
    "chapterNumber": 17,
    "referenceLabel": "John 17",
    "summary": "Source text for John 17 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.17.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "John 17:1",
      "text": "ܗܠܝܢ ܡܠܠ ܝܫܘܥ ܘܐܪܝܡ ܥܝܢܘܗܝ ܠܫܡܝܐ ܘܐܡܪ ܐܒܝ ܐܬܬ ܫܥܬܐ ܫܒܚ ܒܪܟ ܕܒܪܟ ܢܫܒܚܟ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.17.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "John 17:2",
      "text": "ܐܝܟܢܐ ܕܝܗܒܬ ܠܗ ܫܘܠܛܢܐ ܥܠ ܟܠ ܒܤܪ ܕܟܠ ܡܐ ܕܝܗܒܬ ܠܗ ܢܬܠ ܠܗ ܚܝܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "John 17:3",
      "text": "ܗܠܝܢ ܐܢܘܢ ܕܝܢ ܚܝܐ ܕܠܥܠܡ ܕܢܕܥܘܢܟ ܕܐܢܬ ܐܢܬ ܐܠܗܐ ܕܫܪܪܐ ܒܠܚܘܕܝܟ ܘܡܢ ܕܫܕܪܬ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "John 17:4",
      "text": "ܐܢܐ ܫܒܚܬܟ ܒܐܪܥܐ ܥܒܕܐ ܗܘ ܕܝܗܒܬ ܠܝ ܕܐܥܒܕ ܫܠܡܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "John 17:5",
      "text": "ܘܗܫܐ ܫܒܚܝܢܝ ܐܢܬ ܐܒܝ ܠܘܬܟ ܒܗܘ ܫܘܒܚܐ ܕܐܝܬ ܗܘܐ ܠܝ ܠܘܬܟ ܡܢ ܩܕܡ ܕܢܗܘܐ ܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "John 17:6",
      "text": "ܐܘܕܥܬ ܫܡܟ ܠܒܢܝ ܐܢܫܐ ܗܢܘܢ ܕܝܗܒܬ ܠܝ ܡܢ ܥܠܡܐ ܕܝܠܟ ܗܘܘ ܘܠܝ ܝܗܒܬ ܐܢܘܢ ܘܢܛܪܘ ܡܠܬܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "John 17:7",
      "text": "ܗܫܐ ܝܕܥܬ ܕܟܠ ܡܐ ܕܝܗܒܬ ܠܝ ܡܢ ܠܘܬܟ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "John 17:8",
      "text": "ܕܡܠܐ ܕܝܗܒܬ ܠܝ ܝܗܒܬ ܠܗܘܢ ܘܗܢܘܢ ܩܒܠܘ ܘܝܕܥܘ ܫܪܝܪܐܝܬ ܕܡܢ ܠܘܬܟ ܢܦܩܬ ܘܗܝܡܢܘ ܕܐܢܬ ܫܕܪܬܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "John 17:9",
      "text": "ܘܐܢܐ ܥܠܝܗܘܢ ܒܥܐ ܐܢܐ ܠܐ ܗܘܐ ܥܠ ܥܠܡܐ ܒܥܐ ܐܢܐ ܐܠܐ ܥܠ ܗܢܘܢ ܕܝܗܒܬ ܠܝ ܕܕܝܠܟ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "John 17:10",
      "text": "ܘܟܠ ܡܕܡ ܕܕܝܠܝ ܗܘ ܕܝܠܟ ܗܘ ܘܕܝܠܟ ܕܝܠܝ ܗܘ ܘܡܫܒܚ ܐܢܐ ܒܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "John 17:11",
      "text": "ܡܟܝܠ ܠܐ ܗܘܝܬ ܒܥܠܡܐ ܘܗܠܝܢ ܒܥܠܡܐ ܐܢܘܢ ܘܐܢܐ ܠܘܬܟ ܐܬܐ ܐܢܐ ܐܒܐ ܩܕܝܫܐ ܛܪ ܐܢܘܢ ܒܫܡܟ ܗܘ ܕܝܗܒܬ ܠܝ ܕܢܗܘܘܢ ܚܕ ܐܝܟܢܐ ܕܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "John 17:12",
      "text": "ܟܕ ܥܡܗܘܢ ܗܘܝܬ ܒܥܠܡܐ ܐܢܐ ܢܛܪ ܗܘܝܬ ܠܗܘܢ ܒܫܡܟ ܠܐܝܠܝܢ ܕܝܗܒܬ ܠܝ ܢܛܪܬ ܘܐܢܫ ܡܢܗܘܢ ܠܐ ܐܒܕ ܐܠܐ ܒܪܗ ܕܐܒܕܢܐ ܕܢܬܡܠܐ ܟܬܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "John 17:13",
      "text": "ܗܫܐ ܕܝܢ ܠܘܬܟ ܐܬܐ ܐܢܐ ܘܗܠܝܢ ܡܡܠܠ ܐܢܐ ܒܥܠܡܐ ܕܬܗܘܐ ܚܕܘܬܝ ܡܫܡܠܝܐ ܒܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "John 17:14",
      "text": "ܐܢܐ ܝܗܒܬ ܠܗܘܢ ܡܠܬܟ ܘܥܠܡܐ ܤܢܐ ܐܢܘܢ ܕܠܐ ܗܘܘ ܡܢ ܥܠܡܐ ܐܝܟܢܐ ܕܐܢܐ ܠܐ ܗܘܝܬ ܡܢ ܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "John 17:15",
      "text": "ܠܐ ܗܘܐ ܕܬܫܩܘܠ ܐܢܘܢ ܡܢ ܥܠܡܐ ܒܥܐ ܐܢܐ ܐܠܐ ܕܬܛܪ ܐܢܘܢ ܡܢ ܒܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "John 17:16",
      "text": "ܠܐ ܗܘܘ ܓܝܪ ܡܢ ܥܠܡܐ ܐܝܟܢܐ ܕܐܢܐ ܠܐ ܗܘܝܬ ܡܢ ܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 17,
      "referenceLabel": "John 17:17",
      "text": "ܐܒܐ ܩܕܫ ܐܢܘܢ ܒܫܪܪܟ ܕܡܠܬܟ ܕܝܠܟ ܫܪܪܐ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 18,
      "referenceLabel": "John 17:18",
      "text": "ܐܝܟܢܐ ܕܠܝ ܫܕܪܬ ܠܥܠܡܐ ܐܦ ܐܢܐ ܫܕܪܬ ܐܢܘܢ ܠܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 19,
      "referenceLabel": "John 17:19",
      "text": "ܘܥܠ ܐܦܝܗܘܢ ܐܢܐ ܡܩܕܫ ܐܢܐ ܢܦܫܝ ܕܢܗܘܘܢ ܐܦ ܗܢܘܢ ܡܩܕܫܝܢ ܒܫܪܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 20,
      "referenceLabel": "John 17:20",
      "text": "ܘܠܐ ܗܘܐ ܥܠ ܐܦܝ ܗܠܝܢ ܒܥܐ ܐܢܐ ܒܠܚܘܕ ܐܠܐ ܐܦ ܥܠ ܐܦܝ ܐܝܠܝܢ ܕܡܗܝܡܢܝܢ ܒܝ ܒܡܠܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 21,
      "referenceLabel": "John 17:21",
      "text": "ܕܟܠܗܘܢ ܢܗܘܘܢ ܚܕ ܐܝܟܢܐ ܕܐܢܬ ܐܒܝ ܒܝ ܘܐܢܐ ܒܟ ܕܐܦ ܗܢܘܢ ܒܢ ܚܕ ܢܗܘܘܢ ܕܢܗܝܡܢ ܥܠܡܐ ܕܐܢܬ ܫܕܪܬܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 22,
      "referenceLabel": "John 17:22",
      "text": "ܘܐܢܐ ܫܘܒܚܐ ܕܝܗܒܬ ܠܝ ܝܗܒܬ ܠܗܘܢ ܕܢܗܘܘܢ ܚܕ ܐܝܟܢܐ ܕܚܢܢ ܚܕ ܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 23,
      "referenceLabel": "John 17:23",
      "text": "ܐܢܐ ܒܗܘܢ ܘܐܢܬ ܒܝ ܕܢܗܘܘܢ ܓܡܝܪܝܢ ܠܚܕ ܘܕܢܕܥ ܥܠܡܐ ܕܐܢܬ ܫܕܪܬܢܝ ܘܕܐܚܒܬ ܐܢܘܢ ܐܝܟܢܐ ܕܐܦ ܠܝ ܐܚܒܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 24,
      "referenceLabel": "John 17:24",
      "text": "ܐܒܐ ܗܢܘܢ ܕܝܗܒܬ ܠܝ ܨܒܐ ܐܢܐ ܕܐܬܪ ܕܐܢܐ ܐܦ ܗܢܘܢ ܢܗܘܘܢ ܥܡܝ ܕܢܗܘܘܢ ܚܙܝܢ ܫܘܒܚܐ ܕܝܠܝ ܗܘ ܕܝܗܒܬ ܠܝ ܕܐܚܒܬܢܝ ܡܢ ܩܕܡ ܬܪܡܝܬܗ ܕܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 25,
      "referenceLabel": "John 17:25",
      "text": "ܐܒܝ ܟܐܢܐ ܘܥܠܡܐ ܠܐ ܝܕܥܟ ܐܢܐ ܕܝܢ ܝܕܥܬܟ ܘܗܢܘܢ ܝܕܥܘ ܕܐܢܬ ܫܕܪܬܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.17.26",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 26,
      "referenceLabel": "John 17:26",
      "text": "ܘܐܘܕܥܬ ܐܢܘܢ ܫܡܟ ܘܡܘܕܥ ܐܢܐ ܕܚܘܒܐ ܗܘ ܕܐܚܒܬܢܝ ܢܗܘܐ ܒܗܘܢ ܘܐܢܐ ܐܗܘܐ ܒܗܘܢ ܀",
      "paragraphStart": false
    }
  ]
}
