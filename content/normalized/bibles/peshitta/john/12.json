{
  "chapter": {
    "id": "peshitta:john.12",
    "translationId": "peshitta",
    "bookSlug": "john",
    "chapterNumber": 12,
    "referenceLabel": "John 12",
    "summary": "Source text for John 12 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.12.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "John 12:1",
      "text": "ܝܫܘܥ ܕܝܢ ܩܕܡ ܫܬܐ ܝܘܡܝܢ ܕܦܨܚܐ ܐܬܐ ܠܒܝܬ ܥܢܝܐ ܐܝܟܐ ܕܐܝܬܘܗܝ ܗܘܐ ܠܥܙܪ ܗܘ ܕܐܩܝܡ ܡܢ ܒܝܬ ܡܝܬܐ ܗܘ ܝܫܘܥ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.12.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "John 12:2",
      "text": "ܘܥܒܕܘ ܠܗ ܬܡܢ ܚܫܡܝܬܐ ܘܡܪܬܐ ܡܫܡܫܐ ܗܘܬ ܘܠܥܙܪ ܚܕ ܡܢ ܤܡܝܟܐ ܗܘܐ ܕܥܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "John 12:3",
      "text": "ܡܪܝܡ ܕܝܢ ܫܩܠܬ ܫܛܝܦܬܐ ܕܒܤܡܐ ܕܢܪܕܝܢ ܪܫܝܐ ܤܓܝ ܕܡܝܐ ܘܡܫܚܬ ܪܓܠܘܗܝ ܕܝܫܘܥ ܘܫܘܝܬ ܒܤܥܪܗ ܪܓܠܘܗܝ ܘܐܬܡܠܝ ܒܝܬܐ ܡܢ ܪܝܚܗ ܕܒܤܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "John 12:4",
      "text": "ܘܐܡܪ ܝܗܘܕܐ ܤܟܪܝܘܛܐ ܚܕ ܡܢ ܬܠܡܝܕܘܗܝ ܗܘ ܕܥܬܝܕ ܗܘܐ ܕܢܫܠܡܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "John 12:5",
      "text": "ܠܡܢܐ ܠܐ ܐܙܕܒܢ ܡܫܚܐ ܗܢܐ ܒܬܠܬ ܡܐܐ ܕܝܢܪܝܢ ܘܐܬܝܗܒ ܠܡܤܟܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "John 12:6",
      "text": "ܗܕܐ ܕܝܢ ܐܡܪ ܠܐ ܗܘܐ ܡܛܠ ܕܥܠ ܡܤܟܢܐ ܒܛܝܠ ܗܘܐ ܠܗ ܐܠܐ ܡܛܠ ܕܓܢܒܐ ܗܘܐ ܘܓܠܘܤܩܡܐ ܠܘܬܗ ܗܘܐ ܘܡܕܡ ܕܢܦܠ ܗܘܐ ܒܗ ܗܘ ܛܥܝܢ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "John 12:7",
      "text": "ܐܡܪ ܕܝܢ ܝܫܘܥ ܫܒܘܩܝܗ ܠܝܘܡܐ ܕܩܒܘܪܝ ܢܛܪܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "John 12:8",
      "text": "ܒܟܠܙܒܢ ܓܝܪ ܡܤܟܢܐ ܐܝܬ ܠܟܘܢ ܥܡܟܘܢ ܠܝ ܕܝܢ ܠܐ ܒܟܠܙܒܢ ܐܝܬ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "John 12:9",
      "text": "ܘܫܡܥܘ ܟܢܫܐ ܤܓܝܐܐ ܡܢ ܝܗܘܕܝܐ ܕܬܡܢ ܗܘ ܝܫܘܥ ܘܐܬܘ ܠܐ ܡܛܠ ܝܫܘܥ ܒܠܚܘܕ ܐܠܐ ܐܦ ܕܢܚܙܘܢ ܠܠܥܙܪ ܗܘ ܕܐܩܝܡ ܡܢ ܒܝܬ ܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "John 12:10",
      "text": "ܘܐܬܪܥܝܘ ܗܘܘ ܪܒܝ ܟܗܢܐ ܕܐܦ ܠܠܥܙܪ ܢܩܛܠܘܢܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "John 12:11",
      "text": "ܡܛܠ ܕܤܓܝܐܐ ܡܢ ܝܗܘܕܝܐ ܡܛܠܬܗ ܐܙܠܝܢ ܗܘܘ ܘܡܗܝܡܢܝܢ ܒܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "John 12:12",
      "text": "ܘܠܝܘܡܐ ܐܚܪܢܐ ܟܢܫܐ ܤܓܝܐܐ ܐܝܢܐ ܕܐܬܐ ܗܘܐ ܠܥܕܥܕܐ ܟܕ ܫܡܥܘ ܕܝܫܘܥ ܐܬܐ ܠܐܘܪܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "John 12:13",
      "text": "ܫܩܠܘ ܤܘܟܐ ܕܕܩܠܐ ܘܢܦܩܘ ܠܐܘܪܥܗ ܘܩܥܝܢ ܗܘܘ ܘܐܡܪܝܢ ܐܘܫܥܢܐ ܒܪܝܟ ܗܘ ܕܐܬܐ ܒܫܡܗ ܕܡܪܝܐ ܡܠܟܐ ܕܐܝܤܪܝܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "John 12:14",
      "text": "ܐܫܟܚ ܕܝܢ ܝܫܘܥ ܚܡܪܐ ܘܝܬܒ ܥܠܘܗܝ ܐܝܟܢܐ ܕܟܬܝܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "John 12:15",
      "text": "ܠܐ ܬܕܚܠܝܢ ܒܪܬ ܨܗܝܘܢ ܗܐ ܡܠܟܟܝ ܐܬܐ ܠܟܝ ܘܪܟܝܒ ܥܠ ܥܝܠܐ ܒܪ ܐܬܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "John 12:16",
      "text": "ܗܠܝܢ ܕܝܢ ܠܐ ܝܕܥܘ ܬܠܡܝܕܘܗܝ ܒܗܘ ܙܒܢܐ ܐܠܐ ܟܕ ܐܫܬܒܚ ܝܫܘܥ ܐܬܕܟܪܘ ܬܠܡܝܕܘܗܝ ܕܗܠܝܢ ܟܬܝܒܢ ܗܘܝ ܥܠܘܗܝ ܘܗܠܝܢ ܥܒܕܘ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "John 12:17",
      "text": "ܘܤܗܕ ܗܘܐ ܟܢܫܐ ܗܘ ܕܥܡܗ ܗܘܐ ܕܩܪܐ ܠܠܥܙܪ ܡܢ ܩܒܪܐ ܘܐܩܝܡܗ ܡܢ ܒܝܬ ܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "John 12:18",
      "text": "ܘܡܛܠ ܗܕܐ ܢܦܩܘ ܠܩܘܒܠܗ ܟܢܫܐ ܤܓܝܐܐ ܕܫܡܥܘ ܕܐܬܐ ܗܕܐ ܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "John 12:19",
      "text": "ܦܪܝܫܐ ܕܝܢ ܐܡܪܝܢ ܗܘܘ ܚܕ ܠܚܕ ܚܙܝܢ ܐܢܬܘܢ ܕܠܐ ܡܘܬܪܝܢ ܐܢܬܘܢ ܡܕܡ ܕܗܐ ܥܠܡܐ ܟܠܗ ܐܙܠ ܠܗ ܒܬܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "John 12:20",
      "text": "ܐܝܬ ܗܘܘ ܕܝܢ ܐܦ ܡܢ ܥܡܡܐ ܐܢܫܐ ܒܗܘܢ ܕܤܠܩܘ ܠܡܤܓܕ ܒܥܕܥܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "John 12:21",
      "text": "ܗܠܝܢ ܐܬܘ ܩܪܒܘ ܠܘܬ ܦܝܠܝܦܘܤ ܗܘ ܕܡܢ ܒܝܬ ܨܝܕܐ ܕܓܠܝܠܐ ܘܫܐܠܘܗܝ ܘܐܡܪܝܢ ܠܗ ܡܪܝ ܨܒܝܢ ܚܢܢ ܢܚܙܐ ܠܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "John 12:22",
      "text": "ܘܐܬܐ ܗܘ ܦܝܠܝܦܘܤ ܘܐܡܪ ܠܐܢܕܪܐܘܤ ܘܐܢܕܪܐܘܤ ܘܦܝܠܝܦܘܤ ܐܡܪܘ ܠܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "John 12:23",
      "text": "ܝܫܘܥ ܕܝܢ ܥܢܐ ܘܐܡܪ ܠܗܘܢ ܐܬܬ ܫܥܬܐ ܕܢܫܬܒܚ ܒܪܗ ܕܐܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "John 12:24",
      "text": "ܐܡܝܢ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܦܪܕܬܐ ܕܚܛܬܐ ܐܠܐ ܢܦܠܐ ܘܡܝܬܐ ܒܐܪܥܐ ܒܠܚܘܕܝܗ ܦܝܫܐ ܐܢ ܕܝܢ ܡܝܬܐ ܦܐܪܐ ܤܓܝܐܐ ܡܝܬܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "John 12:25",
      "text": "ܡܢ ܕܪܚܡ ܢܦܫܗ ܢܘܒܕܝܗ ܘܡܢ ܕܤܢܐ ܢܦܫܗ ܒܥܠܡܐ ܗܢܐ ܢܛܪܝܗ ܠܚܝܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.26",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "John 12:26",
      "text": "ܐܢ ܠܝ ܐܢܫ ܡܫܡܫ ܢܐܬܐ ܒܬܪܝ ܘܐܝܟܐ ܕܐܢܐ ܐܝܬܝ ܬܡܢ ܢܗܘܐ ܐܦ ܡܫܡܫܢܝ ܡܢ ܕܠܝ ܡܫܡܫ ܢܝܩܪܝܘܗܝ ܐܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.27",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "John 12:27",
      "text": "ܗܫܐ ܢܦܫܝ ܗܐ ܫܓܝܫܐ ܘܡܢܐ ܐܡܪ ܐܒܝ ܦܨܢܝ ܡܢ ܗܕܐ ܫܥܬܐ ܐܠܐ ܡܛܠ ܗܢܐ ܐܬܝܬ ܠܗܕܐ ܫܥܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.28",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "John 12:28",
      "text": "ܐܒܐ ܫܒܚ ܫܡܟ ܘܩܠܐ ܐܫܬܡܥ ܡܢ ܫܡܝܐ ܫܒܚܬ ܘܬܘܒ ܡܫܒܚ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.29",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 29,
      "referenceLabel": "John 12:29",
      "text": "ܘܟܢܫܐ ܕܩܐܡ ܗܘܐ ܫܡܥܘ ܘܐܡܪܝܢ ܪܥܡܐ ܗܘܐ ܐܚܪܢܐ ܕܝܢ ܐܡܪܝܢ ܡܠܐܟܐ ܡܠܠ ܥܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.30",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 30,
      "referenceLabel": "John 12:30",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗܘܢ ܠܐ ܗܘܐ ܡܛܠܬܝ ܗܘܐ ܩܠܐ ܗܢܐ ܐܠܐ ܡܛܠܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.31",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 31,
      "referenceLabel": "John 12:31",
      "text": "ܗܫܐ ܕܝܢܗ ܗܘ ܕܥܠܡܐ ܗܢܐ ܗܫܐ ܐܪܟܘܢܐ ܕܥܠܡܐ ܗܢܐ ܡܫܬܕܐ ܠܒܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.32",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 32,
      "referenceLabel": "John 12:32",
      "text": "ܘܐܢܐ ܡܐ ܕܐܬܬܪܝܡܬ ܡܢ ܐܪܥܐ ܐܓܕ ܟܠܢܫ ܠܘܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.33",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 33,
      "referenceLabel": "John 12:33",
      "text": "ܗܕܐ ܕܝܢ ܐܡܪ ܕܢܚܘܐ ܒܐܝܢܐ ܡܘܬܐ ܡܐܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.34",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 34,
      "referenceLabel": "John 12:34",
      "text": "ܐܡܪܝܢ ܠܗ ܟܢܫܐ ܚܢܢ ܫܡܥܢ ܡܢ ܢܡܘܤܐ ܕܡܫܝܚܐ ܠܥܠܡ ܡܩܘܐ ܐܝܟܢܐ ܐܡܪ ܐܢܬ ܕܥܬܝܕ ܗܘ ܕܢܬܬܪܝܡ ܒܪܗ ܕܐܢܫܐ ܡܢܘ ܗܢܐ ܒܪܗ ܕܐܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.35",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 35,
      "referenceLabel": "John 12:35",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܩܠܝܠ ܐܚܪܝܢ ܙܒܢܐ ܢܘܗܪܐ ܥܡܟܘܢ ܗܘ ܗܠܟܘ ܥܕ ܐܝܬ ܠܟܘܢ ܢܘܗܪܐ ܕܠܐ ܚܫܘܟܐ ܢܕܪܟܟܘܢ ܘܡܢ ܕܡܗܠܟ ܒܚܫܘܟܐ ܠܐ ܝܕܥ ܠܐܝܟܐ ܐܙܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.36",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 36,
      "referenceLabel": "John 12:36",
      "text": "ܥܕ ܐܝܬ ܠܟܘܢ ܢܘܗܪܐ ܗܝܡܢܘ ܒܢܘܗܪܐ ܕܒܢܘܗܝ ܕܢܘܗܪܐ ܬܗܘܘܢ ܗܠܝܢ ܡܠܠ ܝܫܘܥ ܘܐܙܠ ܐܬܛܫܝ ܡܢܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.12.37",
      "translationId": "peshitta",
      "bookSlug": "john",
