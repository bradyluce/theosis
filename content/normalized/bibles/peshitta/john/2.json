{
  "chapter": {
    "id": "peshitta:john.2",
    "translationId": "peshitta",
    "bookSlug": "john",
    "chapterNumber": 2,
    "referenceLabel": "John 2",
    "summary": "Source text for John 2 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.2.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "John 2:1",
      "text": "ܘܠܝܘܡܐ ܕܬܠܬܐ ܗܘܬ ܡܫܬܘܬܐ ܒܩܛܢܐ ܡܕܝܢܬܐ ܕܓܠܝܠܐ ܘܐܡܗ ܕܝܫܘܥ ܬܡܢ ܗܘܬ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.2.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "John 2:2",
      "text": "ܘܐܦ ܗܘ ܝܫܘܥ ܘܬܠܡܝܕܘܗܝ ܐܬܩܪܝܘ ܠܗ ܠܡܫܬܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "John 2:3",
      "text": "ܘܚܤܪ ܗܘܐ ܚܡܪܐ ܘܐܡܪܐ ܠܗ ܐܡܗ ܠܝܫܘܥ ܚܡܪܐ ܠܝܬ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "John 2:4",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܡܐ ܠܝ ܘܠܟܝ ܐܢܬܬܐ ܠܐ ܥܕܟܝܠ ܐܬܬ ܫܥܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "John 2:5",
      "text": "ܐܡܪܐ ܐܡܗ ܠܡܫܡܫܢܐ ܡܕܡ ܕܐܡܪ ܠܟܘܢ ܥܒܕܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "John 2:6",
      "text": "ܐܝܬ ܗܘܝ ܕܝܢ ܬܡܢ ܐܓܢܐ ܕܟܐܦܐ ܫܬ ܕܤܝܡܢ ܠܬܕܟܝܬܐ ܕܝܗܘܕܝܐ ܕܐܚܕܢ ܬܪܝܢ ܬܪܝܢ ܪܒܥܝܢ ܐܘ ܬܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "John 2:7",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܡܠܘ ܐܢܝܢ ܡܝܐ ܠܐܓܢܐ ܘܡܠܘ ܐܢܝܢ ܥܕܡܐ ܠܥܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "John 2:8",
      "text": "ܐܡܪ ܠܗܘܢ ܙܠܘܥܘ ܡܟܝܠ ܘܐܝܬܘ ܠܪܝܫ ܤܡܟܐ ܘܐܝܬܝܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "John 2:9",
      "text": "ܘܟܕ ܛܥܡ ܗܘ ܪܝܫ ܤܡܟܐ ܡܝܐ ܗܢܘܢ ܕܗܘܘ ܚܡܪܐ ܘܠܐ ܝܕܥ ܗܘܐ ܡܢ ܐܝܡܟܐ ܗܘܐ ܡܫܡܫܢܐ ܕܝܢ ܝܕܥܝܢ ܗܘܘ ܕܗܢܘܢ ܡܠܘ ܐܢܘܢ ܠܡܝܐ ܩܪܐ ܪܝܫ ܤܡܟܐ ܠܚܬܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "John 2:10",
      "text": "ܘܐܡܪ ܠܗ ܟܠ ܐܢܫ ܠܘܩܕܡ ܚܡܪܐ ܛܒܐ ܡܝܬܐ ܘܡܐ ܕܪܘܝܘ ܗܝܕܝܢ ܐܝܢܐ ܕܒܨܝܪ ܐܢܬ ܕܝܢ ܢܛܪܬܝܗܝ ܠܚܡܪܐ ܛܒܐ ܥܕܡܐ ܠܗܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "John 2:11",
      "text": "ܗܕܐ ܗܝ ܐܬܐ ܩܕܡܝܬܐ ܕܥܒܕ ܝܫܘܥ ܒܩܛܢܐ ܕܓܠܝܠܐ ܘܐܘܕܥ ܫܘܒܚܗ ܘܗܝܡܢܘ ܒܗ ܬܠܡܝܕܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "John 2:12",
      "text": "ܒܬܪ ܗܕܐ ܢܚܬ ܠܟܦܪܢܚܘܡ ܗܘ ܘܐܡܗ ܘܐܚܘܗܝ ܘܬܠܡܝܕܘܗܝ ܘܬܡܢ ܗܘܘ ܩܠܝܠ ܝܘܡܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "John 2:13",
      "text": "ܘܩܪܝܒ ܗܘܐ ܦܨܚܐ ܕܝܗܘܕܝܐ ܘܤܠܩ ܠܐܘܪܫܠܡ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "John 2:14",
      "text": "ܘܐܫܟܚ ܒܗܝܟܠܐ ܠܗܠܝܢ ܕܡܙܒܢܝܢ ܬܘܪܐ ܘܥܪܒܐ ܘܝܘܢܐ ܘܠܡܥܪܦܢܐ ܕܝܬܒܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "John 2:15",
      "text": "ܘܥܒܕ ܠܗ ܦܪܓܠܐ ܡܢ ܚܒܠܐ ܘܠܟܠܗܘܢ ܐܦܩ ܡܢ ܗܝܟܠܐ ܘܠܥܪܒܐ ܘܠܬܘܪܐ ܘܠܡܥܪܦܢܐ ܘܐܫܕ ܥܘܪܦܢܗܘܢ ܘܦܬܘܪܝܗܘܢ ܗܦܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "John 2:16",
      "text": "ܘܠܗܢܘܢ ܕܡܙܒܢܝܢ ܝܘܢܐ ܐܡܪ ܫܩܘܠܘ ܗܠܝܢ ܡܟܐ ܘܠܐ ܬܥܒܕܘܢܗ ܠܒܝܬܗ ܕܐܒܝ ܒܝܬ ܬܐܓܘܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "John 2:17",
      "text": "ܘܐܬܕܟܪܘ ܬܠܡܝܕܘܗܝ ܕܟܬܝܒ ܕܛܢܢܗ ܕܒܝܬܟ ܐܟܠܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "John 2:18",
      "text": "ܥܢܘ ܕܝܢ ܝܗܘܕܝܐ ܘܐܡܪܘ ܠܗ ܡܢܐ ܐܬܐ ܡܚܘܐ ܐܢܬ ܠܢ ܕܗܠܝܢ ܥܒܕ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "John 2:19",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗܘܢ ܤܬܘܪܘ ܗܝܟܠܐ ܗܢܐ ܘܠܬܠܬܐ ܝܘܡܝܢ ܐܢܐ ܡܩܝܡ ܐܢܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "John 2:20",
      "text": "ܐܡܪܝܢ ܠܗ ܝܗܘܕܝܐ ܠܐܪܒܥܝܢ ܘܫܬ ܫܢܝܢ ܐܬܒܢܝ ܗܝܟܠܐ ܗܢܐ ܘܐܢܬ ܠܬܠܬܐ ܝܘܡܝܢ ܡܩܝܡ ܐܢܬ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "John 2:21",
      "text": "ܗܘ ܕܝܢ ܐܡܪ ܗܘܐ ܥܠ ܗܝܟܠܐ ܕܦܓܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "John 2:22",
      "text": "ܟܕ ܩܡ ܕܝܢ ܡܢ ܒܝܬ ܡܝܬܐ ܐܬܕܟܪܘ ܬܠܡܝܕܘܗܝ ܕܗܕܐ ܐܡܪ ܗܘܐ ܘܗܝܡܢܘ ܠܟܬܒܐ ܘܠܡܠܬܐ ܕܐܡܪ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "John 2:23",
      "text": "ܟܕ ܐܝܬܘܗܝ ܗܘܐ ܕܝܢ ܝܫܘܥ ܒܐܘܪܫܠܡ ܒܦܨܚܐ ܒܥܕܥܕܐ ܤܓܝܐܐ ܗܝܡܢܘ ܒܗ ܕܚܙܘ ܐܬܘܬܐ ܕܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "John 2:24",
      "text": "ܗܘ ܕܝܢ ܝܫܘܥ ܠܐ ܡܗܝܡܢ ܗܘܐ ܠܗܘܢ ܢܦܫܗ ܡܛܠ ܕܗܘ ܝܕܥ ܗܘܐ ܠܟܠܢܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.2.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "John 2:25",
      "text": "ܘܠܐ ܤܢܝܩ ܗܘܐ ܕܐܢܫ ܢܤܗܕ ܠܗ ܥܠ ܟܠ ܒܪܢܫ ܗܘ ܓܝܪ ܝܕܥ ܗܘܐ ܡܢܐ ܐܝܬ ܒܒܪܢܫܐ ܀",
      "paragraphStart": false
    }
  ]
}
