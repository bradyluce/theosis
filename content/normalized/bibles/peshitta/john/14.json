{
  "chapter": {
    "id": "peshitta:john.14",
    "translationId": "peshitta",
    "bookSlug": "john",
    "chapterNumber": 14,
    "referenceLabel": "John 14",
    "summary": "Source text for John 14 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.14.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "John 14:1",
      "text": "ܠܐ ܢܬܕܘܕ ܠܒܟܘܢ ܗܝܡܢܘ ܒܐܠܗܐ ܘܒܝ ܗܝܡܢܘ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.14.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "John 14:2",
      "text": "ܤܓܝܐܝܢ ܐܢܘܢ ܐܘܢܐ ܒܝܬ ܐܒܝ ܘܐܠܐ ܐܡܪ ܗܘܝܬ ܠܟܘܢ ܕܐܙܠ ܐܢܐ ܕܐܛܝܒ ܠܟܘܢ ܐܬܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "John 14:3",
      "text": "ܘܐܢ ܐܙܠ ܐܛܝܒ ܠܟܘܢ ܐܬܪܐ ܬܘܒ ܐܬܐ ܘܐܕܒܪܟܘܢ ܠܘܬܝ ܕܐܝܟܐ ܕܐܢܐ ܐܝܬܝ ܐܦ ܐܢܬܘܢ ܬܗܘܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "John 14:4",
      "text": "ܘܠܐܝܟܐ ܕܐܙܠ ܐܢܐ ܝܕܥܝܢ ܐܢܬܘܢ ܘܐܘܪܚܐ ܝܕܥܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "John 14:5",
      "text": "ܐܡܪ ܠܗ ܬܐܘܡܐ ܡܪܢ ܠܐ ܝܕܥܝܢܢ ܠܐܝܟܐ ܐܙܠ ܐܢܬ ܘܐܝܟܢܐ ܡܫܟܚܝܢ ܚܢܢ ܐܘܪܚܐ ܠܡܕܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "John 14:6",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܐܢܐ ܐܢܐ ܐܘܪܚܐ ܘܫܪܪܐ ܘܚܝܐ ܠܐ ܐܢܫ ܐܬܐ ܠܘܬ ܐܒܝ ܐܠܐ ܐܢ ܒܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "John 14:7",
      "text": "ܐܠܘ ܠܝ ܝܕܥܝܢ ܗܘܝܬܘܢ ܐܦ ܠܐܒܝ ܝܕܥܝܢ ܗܘܝܬܘܢ ܘܡܢ ܗܫܐ ܝܕܥܝܢ ܐܢܬܘܢ ܠܗ ܘܚܙܝܬܘܢܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "John 14:8",
      "text": "ܐܡܪ ܠܗ ܦܝܠܝܦܘܤ ܡܪܢ ܚܘܢ ܐܒܐ ܘܟܕܘ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "John 14:9",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܗܢܐ ܟܠܗ ܙܒܢܐ ܥܡܟܘܢ ܐܢܐ ܘܠܐ ܝܕܥܬܢܝ ܦܝܠܝܦܐ ܡܢ ܕܠܝ ܚܙܐ ܚܙܐ ܠܐܒܐ ܘܐܝܟܢܐ ܐܢܬ ܐܡܪ ܐܢܬ ܚܘܢ ܐܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "John 14:10",
      "text": "ܠܐ ܡܗܝܡܢ ܐܢܬ ܕܐܢܐ ܒܐܒܝ ܘܐܒܝ ܒܝ ܡܠܐ ܐܝܠܝܢ ܕܐܢܐ ܡܡܠܠ ܐܢܐ ܡܢ ܢܦܫܝ ܠܐ ܡܡܠܠ ܐܢܐ ܐܒܝ ܕܝܢ ܕܒܝ ܥܡܪ ܗܘ ܥܒܕ ܥܒܕܐ ܗܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "John 14:11",
      "text": "ܗܝܡܢܘ ܕܐܢܐ ܒܐܒܝ ܘܐܒܝ ܒܝ ܘܐܠܐ ܐܦܢ ܡܛܠ ܥܒܕܐ ܗܝܡܢܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "John 14:12",
      "text": "ܐܡܝܢ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܡܢ ܕܡܗܝܡܢ ܒܝ ܥܒܕܐ ܐܝܠܝܢ ܕܐܢܐ ܥܒܕ ܐܢܐ ܐܦ ܗܘ ܢܥܒܕ ܘܕܝܬܝܪܝܢ ܡܢ ܗܠܝܢ ܢܥܒܕ ܕܐܢܐ ܠܘܬ ܐܒܐ ܐܙܠ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "John 14:13",
      "text": "ܘܡܕܡ ܕܬܫܐܠܘܢ ܒܫܡܝ ܐܥܒܕ ܠܟܘܢ ܕܢܫܬܒܚ ܐܒܐ ܒܒܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "John 14:14",
      "text": "ܘܐܢ ܬܫܐܠܘܢܢܝ ܒܫܡܝ ܐܢܐ ܥܒܕܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "John 14:15",
      "text": "ܐܢ ܪܚܡܝܢ ܐܢܬܘܢ ܠܝ ܦܘܩܕܢܝ ܛܪܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "John 14:16",
      "text": "ܘܐܢܐ ܐܒܥܐ ܡܢ ܐܒܝ ܘܐܚܪܢܐ ܦܪܩܠܛܐ ܢܬܠ ܠܟܘܢ ܕܢܗܘܐ ܥܡܟܘܢ ܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "John 14:17",
      "text": "ܪܘܚܐ ܕܫܪܪܐ ܗܘ ܕܥܠܡܐ ܠܐ ܡܫܟܚ ܠܡܩܒܠܘܬܗ ܡܛܠ ܕܠܐ ܚܙܝܗܝ ܘܠܐ ܝܕܥܗ ܐܢܬܘܢ ܕܝܢ ܝܕܥܝܢ ܐܢܬܘܢ ܠܗ ܕܠܘܬܟܘܢ ܥܡܪ ܘܒܟܘܢ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "John 14:18",
      "text": "ܠܐ ܫܒܩ ܐܢܐ ܠܟܘܢ ܝܬܡܐ ܐܬܐ ܐܢܐ ܓܝܪ ܠܘܬܟܘܢ ܩܠܝܠ ܐܚܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "John 14:19",
      "text": "ܘܥܠܡܐ ܠܐ ܚܙܐ ܠܝ ܐܢܬܘܢ ܕܝܢ ܬܚܙܘܢܢܝ ܕܐܢܐ ܚܝ ܐܦ ܐܢܬܘܢ ܬܚܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "John 14:20",
      "text": "ܒܗܘ ܝܘܡܐ ܬܕܥܘܢ ܕܐܢܐ ܒܐܒܝ ܘܐܢܬܘܢ ܒܝ ܐܢܬܘܢ ܘܐܢܐ ܒܟܘܢ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "John 14:21",
      "text": "ܡܢ ܕܐܝܬ ܠܘܬܗ ܦܘܩܕܢܝ ܘܢܛܪ ܠܗܘܢ ܗܘ ܗܘ ܡܚܒ ܠܝ ܗܘ ܕܝܢ ܕܪܚܡ ܠܝ ܢܬܪܚܡ ܡܢ ܐܒܝ ܘܐܢܐ ܐܪܚܡܝܘܗܝ ܘܐܚܘܝܘܗܝ ܢܦܫܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "John 14:22",
      "text": "ܐܡܪ ܠܗ ܝܗܘܕܐ ܠܐ ܗܘܐ ܤܟܪܝܘܛܐ ܡܪܝ ܡܢܘ ܠܢ ܥܬܝܕ ܐܢܬ ܠܡܚܘܝܘ ܢܦܫܟ ܘܠܐ ܗܘܐ ܠܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "John 14:23",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗ ܡܢ ܕܪܚܡ ܠܝ ܡܠܬܝ ܢܛܪ ܘܐܒܝ ܢܪܚܡܝܘܗܝ ܘܠܘܬܗ ܐܬܝܢ ܚܢܢ ܘܐܘܢܐ ܠܘܬܗ ܥܒܕܝܢ ܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "John 14:24",
      "text": "ܗܘ ܕܝܢ ܕܠܐ ܪܚܡ ܠܝ ܡܠܬܝ ܠܐ ܢܛܪ ܘܡܠܬܐ ܗܕܐ ܕܫܡܥܝܢ ܐܢܬܘܢ ܠܐ ܗܘܬ ܕܝܠܝ ܐܠܐ ܕܐܒܐ ܕܫܕܪܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "John 14:25",
      "text": "ܗܠܝܢ ܡܠܠܬ ܥܡܟܘܢ ܟܕ ܠܘܬܟܘܢ ܐܝܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.26",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "John 14:26",
      "text": "ܗܘ ܕܝܢ ܦܪܩܠܛܐ ܪܘܚܐ ܕܩܘܕܫܐ ܗܘ ܕܡܫܕܪ ܐܒܝ ܒܫܡܝ ܗܘ ܢܠܦܟܘܢ ܟܠܡܕܡ ܘܗܘ ܢܥܗܕܟܘܢ ܟܠ ܡܐ ܕܐܡܪ ܐܢܐ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.27",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "John 14:27",
      "text": "ܫܠܡܐ ܫܒܩ ܐܢܐ ܠܟܘܢ ܫܠܡܐ ܕܝܠܝ ܝܗܒ ܐܢܐ ܠܟܘܢ ܠܐ ܗܘܐ ܐܝܟܢܐ ܕܝܗܒ ܥܠܡܐ ܐܢܐ ܝܗܒ ܐܢܐ ܠܟܘܢ ܠܐ ܢܬܕܘܕ ܠܒܟܘܢ ܘܠܐ ܢܕܚܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.28",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "John 14:28",
      "text": "ܫܡܥܬܘܢ ܕܐܢܐ ܐܡܪܬ ܠܟܘܢ ܕܐܙܠ ܐܢܐ ܘܐܬܐ ܐܢܐ ܠܘܬܟܘܢ ܐܠܘ ܪܚܡܝܢ ܗܘܝܬܘܢ ܠܝ ܚܕܝܢ ܗܘܝܬܘܢ ܕܐܙܠ ܐܢܐ ܠܘܬ ܐܒܝ ܕܐܒܝ ܪܒ ܗܘ ܡܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.29",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "John 14:29",
      "text": "ܘܗܫܐ ܗܐ ܐܡܪܬ ܠܟܘܢ ܥܕܠܐ ܢܗܘܐ ܕܡܐ ܕܗܘܐ ܬܗܝܡܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.30",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "John 14:30",
      "text": "ܡܟܝܠ ܠܐ ܐܡܠܠ ܥܡܟܘܢ ܤܓܝܐܬܐ ܐܬܐ ܓܝܪ ܐܪܟܘܢܗ ܕܥܠܡܐ ܘܒܝ ܠܝܬ ܠܗ ܡܕܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.14.31",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "John 14:31",
      "text": "ܐܠܐ ܕܢܕܥ ܥܠܡܐ ܕܪܚܡ ܐܢܐ ܠܐܒܝ ܘܐܝܟܢܐ ܕܦܩܕܢܝ ܐܒܝ ܗܟܘܬ ܥܒܕ ܐܢܐ ܩܘܡܘ ܢܐܙܠ ܡܟܐ ܀",
      "paragraphStart": false
    }
  ]
}
