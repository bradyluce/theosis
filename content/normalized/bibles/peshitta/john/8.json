{
  "chapter": {
    "id": "peshitta:john.8",
    "translationId": "peshitta",
    "bookSlug": "john",
    "chapterNumber": 8,
    "referenceLabel": "John 8",
    "summary": "Source text for John 8 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.8.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "John 8:1",
      "text": "ܝܫܘܥ ܕܝܢ ܐܙܠ ܠܛܘܪܐ ܕܙܝܬܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.8.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "John 8:2",
      "text": "ܒܨܦܪܐ ܕܝܢ ܬܘܒ ܐܬܐ ܠܗܝܟܠܐ ܘܟܠܗ ܥܡܐ ܐܬܐ ܗܘܐ ܠܘܬܗ ܘܟܕ ܝܬܒ ܡܠܦ ܗܘܐ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "John 8:3",
      "text": "ܐܝܬܝܘ ܕܝܢ ܤܦܪܐ ܘܦܪܝܫܐ ܠܐܢܬܬܐ ܕܐܬܬܚܕܬ ܒܓܘܪܐ ܘܟܕ ܐܩܝܡܘܗ ܒܡܨܥܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "John 8:4",
      "text": "ܐܡܪܝܢ ܠܗ ܡܠܦܢܐ ܗܕܐ ܐܢܬܬܐ ܐܬܬܚܕܬ ܓܠܝܐܝܬ ܒܗ ܒܤܘܥܪܢܐ ܕܓܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "John 8:5",
      "text": "ܘܒܢܡܘܤܐ ܕܝܢ ܕܡܘܫܐ ܦܩܕ ܕܠܕܐܝܟ ܗܠܝܢ ܢܪܓܘܡ ܐܢܬ ܗܟܝܠ ܡܢܐ ܐܡܪ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "John 8:6",
      "text": "ܗܕܐ ܐܡܪܘ ܟܕ ܡܢܤܝܢ ܠܗ ܐܝܟܢܐ ܕܬܗܘܐ ܠܗܘܢ ܕܢܩܛܪܓܘܢܝܗܝ ܝܫܘܥ ܕܝܢ ܟܕ ܠܬܚܬ ܐܬܓܗܢ ܡܟܬܒ ܗܘܐ ܥܠ ܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "John 8:7",
      "text": "ܟܕ ܕܝܢ ܟܬܪܘ ܟܕ ܡܫܐܠܝܢ ܠܗ ܐܬܦܫܛ ܘܐܡܪ ܠܗܘܢ ܐܝܢܐ ܡܢܟܘܢ ܕܐܝܬܘܗܝ ܕܠܐ ܚܛܗ ܩܕܡܝܐ ܢܫܕܐ ܥܠܝܗ ܟܐܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "John 8:8",
      "text": "ܘܬܘܒ ܟܕ ܐܬܓܗܢ ܟܬܒ ܗܘܐ ܥܠ ܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "John 8:9",
      "text": "ܗܢܘܢ ܕܝܢ ܟܕ ܫܡܥܘ ܢܦܩܝܢ ܗܘܘ ܚܕ ܚܕ ܟܕ ܫܪܝܘ ܡܢ ܩܫܝܫܐ ܘܐܫܬܒܩܬ ܐܢܬܬܐ ܠܚܘܕܝܗ ܟܕ ܐܝܬܝܗ ܒܡܨܥܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "John 8:10",
      "text": "ܟܕ ܕܝܢ ܐܬܦܫܛ ܝܫܘܥ ܐܡܪ ܠܗ ܠܐܢܬܬܐ ܐܝܟܐ ܐܝܬܝܗܘܢ ܠܐ ܐܢܫ ܚܝܒܟܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "John 8:11",
      "text": "ܗܝ ܕܝܢ ܐܡܪܬ ܘܠܐ ܐܢܫ ܡܪܝܐ ܐܡܪ ܕܝܢ ܝܫܘܥ ܐܦܠܐ ܐܢܐ ܡܚܝܒ ܐܢܐ ܠܟܝ ܙܠܝ ܘܡܢ ܗܫܐ ܬܘܒ ܠܐ ܬܚܛܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "John 8:12",
      "text": "ܬܘܒ ܕܝܢ ܡܠܠ ܥܡܗܘܢ ܝܫܘܥ ܘܐܡܪ ܐܢܐ ܐܢܐ ܢܘܗܪܗ ܕܥܠܡܐ ܡܢ ܕܒܬܪܝ ܐܬܐ ܠܐ ܢܗܠܟ ܒܚܫܘܟܐ ܐܠܐ ܢܫܟܚ ܠܗ ܢܘܗܪܐ ܕܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "John 8:13",
      "text": "ܐܡܪܝܢ ܠܗ ܦܪܝܫܐ ܐܢܬ ܥܠ ܢܦܫܟ ܡܤܗܕ ܐܢܬ ܤܗܕܘܬܟ ܠܐ ܗܘܬ ܫܪܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "John 8:14",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗܘܢ ܐܦܢ ܐܢܐ ܡܤܗܕ ܐܢܐ ܥܠ ܢܦܫܝ ܫܪܝܪܐ ܗܝ ܤܗܕܘܬܝ ܡܛܠ ܕܕܝܕܥ ܐܢܐ ܡܢ ܐܝܡܟܐ ܐܬܝܬ ܘܠܐܝܟܐ ܐܙܠ ܐܢܐ ܐܢܬܘܢ ܕܝܢ ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܡܢ ܐܝܡܟܐ ܐܬܝܬ ܘܠܐ ܠܐܝܟܐ ܐܙܠ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "John 8:15",
      "text": "ܐܢܬܘܢ ܦܓܪܢܐܝܬ ܕܝܢܝܢ ܐܢܬܘܢ ܐܢܐ ܠܐܢܫ ܠܐ ܕܐܢ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "John 8:16",
      "text": "ܘܐܢ ܕܐܢ ܐܢܐ ܕܝܢ ܕܝܢܝ ܫܪܝܪ ܗܘ ܡܛܠ ܕܠܐ ܗܘܝܬ ܒܠܚܘܕܝ ܐܠܐ ܐܢܐ ܘܐܒܝ ܕܫܕܪܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "John 8:17",
      "text": "ܘܒܢܡܘܤܟܘܢ ܕܝܢ ܟܬܝܒ ܕܤܗܕܘܬܐ ܕܬܪܝܢ ܓܒܪܝܢ ܫܪܝܪܐ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "John 8:18",
      "text": "ܐܢܐ ܐܢܐ ܕܤܗܕ ܐܢܐ ܥܠ ܢܦܫܝ ܘܐܒܝ ܕܫܕܪܢܝ ܤܗܕ ܥܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "John 8:19",
      "text": "ܐܡܪܝܢ ܠܗ ܐܝܟܘ ܐܒܘܟ ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗܘܢ ܘܠܐ ܠܝ ܝܕܥܝܢ ܐܢܬܘܢ ܘܠܐ ܠܐܒܝ ܐܠܘ ܠܝ ܝܕܥܝܢ ܗܘܝܬܘܢ ܐܦ ܠܐܒܝ ܝܕܥܝܢ ܗܘܝܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "John 8:20",
      "text": "ܗܠܝܢ ܡܠܐ ܡܠܠ ܒܝܬ ܓܙܐ ܟܕ ܡܠܦ ܒܗܝܟܠܐ ܘܠܐ ܐܢܫ ܐܚܕܗ ܠܐ ܓܝܪ ܥܕܟܝܠ ܐܬܬ ܗܘܬ ܫܥܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "John 8:21",
      "text": "ܐܡܪ ܠܗܘܢ ܬܘܒ ܝܫܘܥ ܐܢܐ ܐܙܠ ܐܢܐ ܘܬܒܥܘܢܢܝ ܘܬܡܘܬܘܢ ܒܚܛܗܝܟܘܢ ܘܐܝܟܐ ܕܐܢܐ ܐܙܠ ܐܢܐ ܐܢܬܘܢ ܠܐ ܡܫܟܚܝܢ ܐܢܬܘܢ ܠܡܐܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "John 8:22",
      "text": "ܐܡܪܝܢ ܝܗܘܕܝܐ ܠܡܐ ܟܝ ܢܦܫܗ ܩܛܠ ܕܐܡܪ ܕܐܝܟܐ ܕܐܢܐ ܐܙܠ ܐܢܐ ܐܢܬܘܢ ܠܐ ܡܫܟܚܝܢ ܐܢܬܘܢ ܠܡܐܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "John 8:23",
      "text": "ܘܐܡܪ ܠܗܘܢ ܐܢܬܘܢ ܡܢ ܕܠܬܚܬ ܐܢܬܘܢ ܘܐܢܐ ܡܢ ܕܠܥܠ ܐܢܐ ܐܢܬܘܢ ܡܢ ܗܢܐ ܐܢܬܘܢ ܥܠܡܐ ܐܢܐ ܠܐ ܗܘܝܬ ܡܢ ܗܢܐ ܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "John 8:24",
      "text": "ܐܡܪܬ ܠܟܘܢ ܕܬܡܘܬܘܢ ܒܚܛܗܝܟܘܢ ܐܠܐ ܓܝܪ ܬܗܝܡܢܘܢ ܕܐܢܐ ܐܢܐ ܬܡܘܬܘܢ ܒܚܛܗܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 25,
      "referenceLabel": "John 8:25",
      "text": "ܐܡܪܝܢ ܝܗܘܕܝܐ ܐܢܬ ܡܢ ܐܢܬ ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܐܦܢ ܕܫܪܝܬ ܕܐܡܠܠ ܥܡܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.26",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 26,
      "referenceLabel": "John 8:26",
      "text": "ܤܓܝ ܐܝܬ ܠܝ ܥܠܝܟܘܢ ܠܡܐܡܪ ܘܠܡܕܢ ܐܠܐ ܡܢ ܕܫܕܪܢܝ ܫܪܝܪ ܗܘ ܘܐܢܐ ܐܝܠܝܢ ܕܫܡܥܬ ܡܢܗ ܗܠܝܢ ܗܘ ܡܡܠܠ ܐܢܐ ܒܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.27",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 27,
      "referenceLabel": "John 8:27",
      "text": "ܘܠܐ ܝܕܥܘ ܕܥܠ ܐܒܐ ܐܡܪ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.28",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 28,
      "referenceLabel": "John 8:28",
      "text": "ܐܡܪ ܠܗܘܢ ܬܘܒ ܝܫܘܥ ܐܡܬܝ ܕܬܪܝܡܘܢܗ ܠܒܪܗ ܕܐܢܫܐ ܗܝܕܝܢ ܬܕܥܘܢ ܕܐܢܐ ܐܢܐ ܘܡܕܡ ܡܢ ܨܒܘܬ ܢܦܫܝ ܠܐ ܥܒܕ ܐܢܐ ܐܠܐ ܐܝܟܢܐ ܕܐܠܦܢܝ ܐܒܝ ܗܟܘܬ ܗܘ ܡܡܠܠ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.29",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 29,
      "referenceLabel": "John 8:29",
      "text": "ܘܡܢ ܕܫܕܪܢܝ ܥܡܝ ܐܝܬܘܗܝ ܘܠܐ ܫܒܩܢܝ ܒܠܚܘܕܝ ܐܒܝ ܡܛܠ ܕܐܢܐ ܡܕܡ ܕܫܦܪ ܠܗ ܥܒܕ ܐܢܐ ܒܟܠܙܒܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.30",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 30,
      "referenceLabel": "John 8:30",
      "text": "ܟܕ ܗܠܝܢ ܡܡܠܠ ܗܘܐ ܤܓܝܐܐ ܗܝܡܢܘ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.31",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 31,
      "referenceLabel": "John 8:31",
      "text": "ܘܐܡܪ ܝܫܘܥ ܠܗܢܘܢ ܝܗܘܕܝܐ ܕܗܝܡܢܘ ܒܗ ܐܢ ܐܢܬܘܢ ܬܟܬܪܘܢ ܒܡܠܬܝ ܫܪܝܪܐܝܬ ܬܠܡܝܕܝ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.32",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 32,
      "referenceLabel": "John 8:32",
      "text": "ܘܬܕܥܘܢ ܫܪܪܐ ܘܗܘ ܫܪܪܐ ܢܚܪܪܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.33",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 33,
      "referenceLabel": "John 8:33",
      "text": "ܐܡܪܝܢ ܠܗ ܙܪܥܗ ܚܢܢ ܕܐܒܪܗܡ ܘܡܢ ܡܬܘܡ ܥܒܕܘܬܐ ܠܐܢܫ ܠܐ ܦܠܝܚܐ ܠܢ ܐܝܟܢܐ ܐܡܪ ܐܢܬ ܕܬܗܘܘܢ ܒܢܝ ܚܐܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.34",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 34,
      "referenceLabel": "John 8:34",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܐܡܝܢ ܐܡܝܢ ܐܡܪܢܐ ܠܟܘܢ ܕܟܠܡܢ ܕܥܒܕ ܚܛܝܬܐ ܥܒܕܗ ܗܘ ܕܚܛܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.35",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 35,
      "referenceLabel": "John 8:35",
      "text": "ܘܥܒܕܐ ܠܐ ܡܩܘܐ ܠܥܠܡ ܒܒܝܬܐ ܒܪܐ ܕܝܢ ܠܥܠܡ ܡܩܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.36",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 36,
      "referenceLabel": "John 8:36",
      "text": "ܐܢ ܗܘ ܗܟܝܠ ܕܒܪܐ ܢܚܪܪܟܘܢ ܫܪܝܪܐܝܬ ܬܗܘܘܢ ܒܢܝ ܚܐܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.8.37",
      "translationId": "peshitta",
