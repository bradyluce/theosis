{
  "chapter": {
    "id": "peshitta:john.20",
    "translationId": "peshitta",
    "bookSlug": "john",
    "chapterNumber": 20,
    "referenceLabel": "John 20",
    "summary": "Source text for John 20 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.20.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "John 20:1",
      "text": "ܒܚܕ ܒܫܒܐ ܕܝܢ ܐܬܬ ܡܪܝܡ ܡܓܕܠܝܬܐ ܒܨܦܪܐ ܥܕ ܚܫܘܟ ܠܒܝܬ ܩܒܘܪܐ ܘܚܙܬ ܠܟܐܦܐ ܕܫܩܝܠܐ ܡܢ ܩܒܪܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.20.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "John 20:2",
      "text": "ܘܪܗܛܬ ܐܬܬ ܠܘܬ ܫܡܥܘܢ ܟܐܦܐ ܘܠܘܬ ܗܘ ܬܠܡܝܕܐ ܐܚܪܢܐ ܕܪܚܡ ܗܘܐ ܝܫܘܥ ܘܐܡܪܐ ܠܗܘܢ ܕܫܩܠܘܗܝ ܠܡܪܢ ܡܢ ܗܘ ܒܝܬ ܩܒܘܪܐ ܘܠܐ ܝܕܥܐ ܐܢܐ ܐܝܟܐ ܤܡܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "John 20:3",
      "text": "ܘܢܦܩ ܫܡܥܘܢ ܘܗܘ ܬܠܡܝܕܐ ܐܚܪܢܐ ܘܐܬܝܢ ܗܘܘ ܠܒܝܬ ܩܒܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "John 20:4",
      "text": "ܘܪܗܛܝܢ ܗܘܘ ܬܪܝܗܘܢ ܐܟܚܕܐ ܗܘ ܕܝܢ ܬܠܡܝܕܐ ܪܗܛ ܩܕܡܗ ܠܫܡܥܘܢ ܘܐܬܐ ܩܕܡܝܐ ܠܒܝܬ ܩܒܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "John 20:5",
      "text": "ܘܐܕܝܩ ܚܙܐ ܟܬܢܐ ܟܕ ܤܝܡܝܢ ܡܥܠ ܕܝܢ ܠܐ ܥܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "John 20:6",
      "text": "ܐܬܐ ܕܝܢ ܫܡܥܘܢ ܒܬܪܗ ܘܥܠ ܠܒܝܬ ܩܒܘܪܐ ܘܚܙܐ ܟܬܢܐ ܟܕ ܤܝܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "John 20:7",
      "text": "ܘܤܘܕܪܐ ܗܘ ܕܚܙܝܩ ܗܘܐ ܒܪܫܗ ܠܐ ܥܡ ܟܬܢܐ ܐܠܐ ܟܕ ܟܪܝܟ ܘܤܝܡ ܠܤܛܪ ܒܚܕܐ ܕܘܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "John 20:8",
      "text": "ܗܝܕܝܢ ܥܠ ܐܦ ܗܘ ܬܠܡܝܕܐ ܕܐܬܐ ܩܕܡܝܐ ܠܒܝܬ ܩܒܘܪܐ ܘܚܙܐ ܘܗܝܡܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "John 20:9",
      "text": "ܠܐ ܓܝܪ ܥܕܟܝܠ ܝܕܥܝܢ ܗܘܘ ܡܢ ܟܬܒܐ ܕܥܬܝܕ ܗܘܐ ܠܡܩܡ ܡܢ ܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "John 20:10",
      "text": "ܘܐܙܠܘ ܗܢܘܢ ܬܠܡܝܕܐ ܬܘܒ ܠܕܘܟܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "John 20:11",
      "text": "ܡܪܝܡ ܕܝܢ ܩܝܡܐ ܗܘܬ ܠܘܬ ܩܒܪܐ ܘܒܟܝܐ ܘܟܕ ܒܟܝܐ ܐܕܝܩܬ ܒܩܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "John 20:12",
      "text": "ܘܚܙܬ ܬܪܝܢ ܡܠܐܟܐ ܒܚܘܪܐ ܕܝܬܒܝܢ ܚܕ ܡܢ ܐܤܕܘܗܝ ܘܚܕ ܡܢ ܪܓܠܘܗܝ ܐܝܟܐ ܕܤܝܡ ܗܘܐ ܦܓܪܗ ܕܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "John 20:13",
      "text": "ܘܐܡܪܝܢ ܠܗ ܐܢܬܬܐ ܡܢܐ ܒܟܝܐ ܐܢܬܝ ܐܡܪܐ ܠܗܘܢ ܕܫܩܠܘܗܝ ܠܡܪܝ ܘܠܐ ܝܕܥܐ ܐܢܐ ܐܝܟܐ ܤܡܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 14,
      "referenceLabel": "John 20:14",
      "text": "ܗܕܐ ܐܡܪܬ ܘܐܬܦܢܝܬ ܠܒܤܬܪܗ ܘܚܙܬ ܠܝܫܘܥ ܕܩܐܡ ܘܠܐ ܝܕܥܐ ܗܘܬ ܕܝܫܘܥ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 15,
      "referenceLabel": "John 20:15",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܐܢܬܬܐ ܡܢܐ ܒܟܝܐ ܐܢܬܝ ܘܠܡܢ ܒܥܝܐ ܐܢܬܝ ܗܝ ܕܝܢ ܤܒܪܬ ܕܓܢܢܐ ܗܘ ܘܐܡܪܐ ܠܗ ܡܪܝ ܐܢ ܐܢܬ ܫܩܠܬܝܗܝ ܐܡܪ ܠܝ ܐܝܟܐ ܤܡܬܝܗܝ ܐܙܠ ܐܫܩܠܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 16,
      "referenceLabel": "John 20:16",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܡܪܝܡ ܘܐܬܦܢܝܬ ܘܐܡܪܐ ܠܗ ܥܒܪܐܝܬ ܪܒܘܠܝ ܕܡܬܐܡܪ ܡܠܦܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 17,
      "referenceLabel": "John 20:17",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܠܐ ܬܬܩܪܒܝܢ ܠܝ ܠܐ ܓܝܪ ܥܕܟܝܠ ܤܠܩܬ ܠܘܬ ܐܒܝ ܙܠܝ ܕܝܢ ܠܘܬ ܐܚܝ ܘܐܡܪܝ ܠܗܘܢ ܤܠܩ ܐܢܐ ܠܘܬ ܐܒܝ ܘܐܒܘܟܘܢ ܘܐܠܗܝ ܘܐܠܗܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 18,
      "referenceLabel": "John 20:18",
      "text": "ܗܝܕܝܢ ܐܬܬ ܡܪܝܡ ܡܓܕܠܝܬܐ ܘܤܒܪܬ ܠܬܠܡܝܕܐ ܕܚܙܬ ܠܡܪܢ ܘܕܗܠܝܢ ܐܡܪ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 19,
      "referenceLabel": "John 20:19",
      "text": "ܟܕ ܗܘܐ ܕܝܢ ܪܡܫܐ ܕܝܘܡܐ ܗܘ ܕܚܕ ܒܫܒܐ ܘܬܪܥܐ ܐܚܝܕܝܢ ܗܘܘ ܕܐܝܟܐ ܕܐܝܬܝܗܘܢ ܗܘܘ ܬܠܡܝܕܐ ܡܛܠ ܕܚܠܬܐ ܕܝܗܘܕܝܐ ܐܬܐ ܝܫܘܥ ܩܡ ܒܝܢܬܗܘܢ ܘܐܡܪ ܠܗܘܢ ܫܠܡܐ ܥܡܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 20,
      "referenceLabel": "John 20:20",
      "text": "ܗܕܐ ܐܡܪ ܘܚܘܝ ܐܢܘܢ ܐܝܕܘܗܝ ܘܤܛܪܗ ܘܚܕܝܘ ܬܠܡܝܕܐ ܕܚܙܘ ܠܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 21,
      "referenceLabel": "John 20:21",
      "text": "ܐܡܪ ܠܗܘܢ ܕܝܢ ܬܘܒ ܝܫܘܥ ܫܠܡܐ ܥܡܟܘܢ ܐܝܟܢܐ ܕܫܕܪܢܝ ܐܒܝ ܐܦ ܐܢܐ ܡܫܕܪ ܐܢܐ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 22,
      "referenceLabel": "John 20:22",
      "text": "ܘܟܕ ܐܡܪ ܗܠܝܢ ܢܦܚ ܒܗܘܢ ܘܐܡܪ ܠܗܘܢ ܩܒܠܘ ܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 23,
      "referenceLabel": "John 20:23",
      "text": "ܐܢ ܬܫܒܩܘܢ ܚܛܗܐ ܠܐܢܫ ܢܫܬܒܩܘܢ ܠܗ ܘܐܢ ܬܐܚܕܘܢ ܕܐܢܫ ܐܚܝܕܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 24,
      "referenceLabel": "John 20:24",
      "text": "ܬܐܘܡܐ ܕܝܢ ܚܕ ܡܢ ܬܪܥܤܪܬܐ ܗܘ ܕܡܬܐܡܪ ܬܐܡܐ ܠܐ ܗܘܐ ܬܡܢ ܗܘܐ ܥܡܗܘܢ ܟܕ ܐܬܐ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 25,
      "referenceLabel": "John 20:25",
      "text": "ܘܐܡܪܝܢ ܠܗ ܬܠܡܝܕܐ ܚܙܝܢ ܠܡܪܢ ܗܘ ܕܝܢ ܐܡܪ ܠܗܘܢ ܐܠܐ ܚܙܐ ܐܢܐ ܒܐܝܕܘܗܝ ܕܘܟܝܬܐ ܕܨܨܐ ܘܪܡܐ ܐܢܐ ܒܗܝܢ ܨܒܥܬܝ ܘܡܘܫܛ ܐܢܐ ܐܝܕܝ ܒܕܦܢܗ ܠܐ ܡܗܝܡܢ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.26",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 26,
      "referenceLabel": "John 20:26",
      "text": "ܘܒܬܪ ܬܡܢܝܐ ܝܘܡܝܢ ܬܘܒ ܠܓܘ ܗܘܘ ܬܠܡܝܕܐ ܘܬܐܘܡܐ ܥܡܗܘܢ ܘܐܬܐ ܝܫܘܥ ܟܕ ܐܚܝܕܝܢ ܬܪܥܐ ܩܡ ܒܡܨܥܬܐ ܘܐܡܪ ܠܗܘܢ ܫܠܡܐ ܥܡܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.27",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 27,
      "referenceLabel": "John 20:27",
      "text": "ܘܐܡܪ ܠܬܐܘܡܐ ܐܝܬܐ ܨܒܥܟ ܠܗܪܟܐ ܘܚܙܝ ܐܝܕܝ ܘܐܝܬܐ ܐܝܕܟ ܘܐܘܫܛ ܒܓܒܝ ܘܠܐ ܬܗܘܐ ܠܐ ܡܗܝܡܢܐ ܐܠܐ ܡܗܝܡܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.28",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 28,
      "referenceLabel": "John 20:28",
      "text": "ܘܥܢܐ ܬܐܘܡܐ ܘܐܡܪ ܠܗ ܡܪܝ ܘܐܠܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.29",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 29,
      "referenceLabel": "John 20:29",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܗܫܐ ܕܚܙܝܬܢܝ ܗܝܡܢܬ ܛܘܒܝܗܘܢ ܠܐܝܠܝܢ ܕܠܐ ܚܙܐܘܢܝ ܘܗܝܡܢܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.30",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 30,
      "referenceLabel": "John 20:30",
      "text": "ܤܓܝܐܬܐ ܕܝܢ ܐܬܘܬܐ ܐܚܪܢܝܬܐ ܥܒܕ ܝܫܘܥ ܩܕܡ ܬܠܡܝܕܘܗܝ ܐܝܠܝܢ ܕܠܐ ܟܬܝܒܢ ܒܟܬܒܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.20.31",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 20,
      "verseNumber": 31,
      "referenceLabel": "John 20:31",
      "text": "ܐܦ ܗܠܝܢ ܕܝܢ ܕܟܬܝܒܢ ܕܬܗܝܡܢܘܢ ܕܝܫܘܥ ܗܘ ܡܫܝܚܐ ܒܪܗ ܕܐܠܗܐ ܘܡܐ ܕܗܝܡܢܬܘܢ ܢܗܘܘܢ ܠܟܘܢ ܒܫܡܗ ܚܝܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    }
  ]
}
