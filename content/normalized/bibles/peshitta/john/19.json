  },
  "verses": [
    {
      "id": "peshitta:john.19.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "John 19:1",
      "text": "ܗܝܕܝܢ ܦܝܠܛܘܤ ܢܓܕܗ ܠܝܫܘܥ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.19.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "John 19:2",
      "text": "ܘܐܤܛܪܛܝܘܛܐ ܓܕܠܘ ܟܠܝܠܐ ܡܢ ܟܘܒܐ ܘܤܡܘ ܠܗ ܒܪܫܗ ܘܟܤܝܘܗܝ ܢܚܬܐ ܕܐܪܓܘܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "John 19:3",
      "text": "ܘܐܡܪܝܢ ܗܘܘ ܫܠܡ ܠܟ ܡܠܟܐ ܕܝܗܘܕܝܐ ܘܡܚܝܢ ܗܘܘ ܠܗ ܥܠ ܦܟܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "John 19:4",
      "text": "ܘܢܦܩ ܦܝܠܛܘܤ ܬܘܒ ܠܒܪ ܘܐܡܪ ܠܗܘܢ ܗܐ ܡܦܩ ܐܢܐ ܠܗ ܠܟܘܢ ܠܒܪ ܕܬܕܥܘܢ ܕܠܐ ܡܫܟܚ ܐܢܐ ܒܬܪܗ ܐܦܠܐ ܚܕܐ ܥܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "John 19:5",
      "text": "ܘܢܦܩ ܝܫܘܥ ܠܒܪ ܟܕ ܐܝܬ ܥܠܘܗܝ ܟܠܝܠܐ ܕܟܘܒܐ ܘܢܚܬܐ ܕܐܪܓܘܢܐ ܘܐܡܪ ܠܗܘܢ ܦܝܠܛܘܤ ܗܐ ܓܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "John 19:6",
      "text": "ܟܕ ܕܝܢ ܚܙܐܘܗܝ ܪܒܝ ܟܗܢܐ ܘܕܚܫܐ ܩܥܘ ܘܐܡܪܝܢ ܨܠܘܒܝܗܝ ܨܠܘܒܝܗܝ ܐܡܪ ܠܗܘܢ ܦܝܠܛܘܤ ܕܒܪܘ ܐܢܬܘܢ ܘܙܘܩܦܘܗܝ ܐܢܐ ܓܝܪ ܠܐ ܡܫܟܚ ܐܢܐ ܒܗ ܥܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "John 19:7",
      "text": "ܐܡܪܝܢ ܠܗ ܝܗܘܕܝܐ ܠܢ ܢܡܘܤܐ ܐܝܬ ܠܢ ܘܐܝܟ ܕܒܢܡܘܤܢ ܚܝܒ ܗܘ ܡܘܬܐ ܕܥܒܕ ܢܦܫܗ ܒܪܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "John 19:8",
      "text": "ܟܕ ܫܡܥ ܕܝܢ ܦܝܠܛܘܤ ܗܕܐ ܡܠܬܐ ܝܬܝܪܐܝܬ ܕܚܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "John 19:9",
      "text": "ܘܥܠ ܬܘܒ ܠܦܪܛܘܪܝܢ ܘܐܡܪ ܠܝܫܘܥ ܐܝܡܟܐ ܐܢܬ ܝܫܘܥ ܕܝܢ ܦܬܓܡܐ ܠܐ ܝܗܒ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "John 19:10",
      "text": "ܐܡܪ ܠܗ ܦܝܠܛܘܤ ܥܡܝ ܠܐ ܡܡܠܠ ܐܢܬ ܠܐ ܝܕܥ ܐܢܬ ܕܫܠܝܛ ܐܢܐ ܕܐܫܪܝܟ ܘܫܠܝܛ ܐܢܐ ܕܐܙܩܦܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "John 19:11",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܠܝܬ ܗܘܐ ܠܟ ܥܠܝ ܫܘܠܛܢܐ ܐܦ ܠܐ ܚܕ ܐܠܘ ܠܐ ܝܗܝܒ ܗܘܐ ܠܟ ܡܢ ܠܥܠ ܡܛܠ ܗܢܐ ܗܘ ܡܢ ܕܐܫܠܡܢܝ ܠܟ ܪܒܐ ܗܝ ܚܛܝܬܗ ܡܢ ܕܝܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "John 19:12",
      "text": "ܘܡܛܠ ܗܕܐ ܨܒܐ ܗܘܐ ܦܝܠܛܘܤ ܕܢܫܪܝܘܗܝ ܝܗܘܕܝܐ ܕܝܢ ܩܥܝܢ ܗܘܘ ܕܐܢ ܠܗܢܐ ܫܪܐ ܐܢܬ ܠܐ ܗܘܝܬ ܪܚܡܗ ܕܩܤܪ ܟܠ ܡܢ ܓܝܪ ܕܢܦܫܗ ܡܠܟܐ ܥܒܕ ܤܩܘܒܠܐ ܗܘ ܕܩܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "John 19:13",
      "text": "ܟܕ ܫܡܥ ܕܝܢ ܦܝܠܛܘܤ ܗܕܐ ܡܠܬܐ ܐܦܩܗ ܠܝܫܘܥ ܠܒܪ ܘܝܬܒ ܥܠ ܒܝܡ ܒܕܘܟܬܐ ܕܡܬܩܪܝܐ ܪܨܝܦܬܐ ܕܟܐܦܐ ܥܒܪܐܝܬ ܕܝܢ ܡܬܐܡܪܐ ܓܦܝܦܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "John 19:14",
      "text": "ܘܥܪܘܒܬܐ ܗܘܬ ܕܦܨܚܐ ܘܐܝܬ ܗܘܝ ܐܝܟ ܫܥܐ ܫܬ ܘܐܡܪ ܠܝܗܘܕܝܐ ܗܐ ܡܠܟܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "John 19:15",
      "text": "ܗܢܘܢ ܕܝܢ ܩܥܝܢ ܗܘܘ ܫܩܘܠܝܗܝ ܫܩܘܠܝܗܝ ܨܠܘܒܝܗܝ ܨܠܘܒܝܗܝ ܐܡܪ ܠܗܘܢ ܦܝܠܛܘܤ ܠܡܠܟܟܘܢ ܐܙܩܘܦ ܐܡܪܝܢ ܪܒܝ ܟܗܢܐ ܠܝܬ ܠܢ ܡܠܟܐ ܐܠܐ ܐܢ ܩܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "John 19:16",
      "text": "ܗܝܕܝܢ ܐܫܠܡܗ ܠܗܘܢ ܕܢܙܩܦܘܢܝܗܝ ܘܕܒܪܘܗܝ ܠܝܫܘܥ ܘܐܦܩܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "John 19:17",
      "text": "ܟܕ ܫܩܝܠ ܙܩܝܦܗ ܠܕܘܟܬܐ ܕܡܬܩܪܝܐ ܩܪܩܦܬܐ ܥܒܪܐܝܬ ܕܝܢ ܡܬܐܡܪܐ ܓܓܘܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "John 19:18",
      "text": "ܐܬܪ ܕܙܩܦܘܗܝ ܘܥܡܗ ܬܪܝܢ ܐܚܪܢܝܢ ܚܕ ܡܟܐ ܘܚܕ ܡܟܐ ܘܠܝܫܘܥ ܒܡܨܥܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "John 19:19",
      "text": "ܘܟܬܒ ܐܦ ܠܘܚܐ ܦܝܠܛܘܤ ܘܤܡ ܥܠ ܙܩܝܦܗ ܟܬܝܒ ܗܘܐ ܕܝܢ ܗܟܢܐ ܗܢܐ ܝܫܘܥ ܢܨܪܝܐ ܡܠܟܐ ܕܝܗܘܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "John 19:20",
      "text": "ܘܠܗܢܐ ܕܦܐ ܤܓܝܐܐ ܡܢ ܝܗܘܕܝܐ ܩܪܐܘܗܝ ܡܛܠ ܕܩܪܝܒܐ ܗܘܬ ܠܡܕܝܢܬܐ ܕܘܟܬܐ ܕܐܙܕܩܦ ܒܗ ܝܫܘܥ ܘܟܬܝܒܐ ܗܘܐ ܥܒܪܐܝܬ ܘܝܘܢܐܝܬ ܘܪܗܘܡܐܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "John 19:21",
      "text": "ܘܐܡܪܘ ܪܒܝ ܟܗܢܐ ܠܦܝܠܛܘܤ ܠܐ ܬܟܬܘܒ ܕܡܠܟܐ ܗܘ ܕܝܗܘܕܝܐ ܐܠܐ ܕܗܘ ܐܡܪ ܕܡܠܟܐ ܐܢܐ ܕܝܗܘܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 22,
      "referenceLabel": "John 19:22",
      "text": "ܐܡܪ ܦܝܠܛܘܤ ܡܕܡ ܕܟܬܒܬ ܟܬܒܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 23,
      "referenceLabel": "John 19:23",
      "text": "ܐܤܛܪܛܝܘܛܐ ܕܝܢ ܟܕ ܙܩܦܘܗܝ ܠܝܫܘܥ ܫܩܠܘ ܢܚܬܘܗܝ ܘܥܒܕܘ ܠܐܪܒܥ ܡܢܘܢ ܡܢܬܐ ܠܚܕ ܡܢ ܐܤܛܪܛܝܘܛܐ ܟܘܬܝܢܗ ܕܝܢ ܐܝܬܝܗ ܗܘܬ ܕܠܐ ܚܝܛܐ ܡܢ ܠܥܠ ܙܩܝܪܬܐ ܟܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 24,
      "referenceLabel": "John 19:24",
      "text": "ܘܐܡܪܘ ܚܕ ܠܚܕ ܠܐ ܢܤܕܩܝܗ ܐܠܐ ܢܦܤ ܥܠܝܗ ܡܦܤ ܕܡܢܘ ܬܗܘܐ ܘܫܠܡ ܟܬܒܐ ܕܐܡܪ ܕܦܠܓܘ ܢܚܬܝ ܒܝܢܬܗܘܢ ܘܥܠ ܠܒܘܫܝ ܐܪܡܝܘ ܦܤܐ ܗܠܝܢ ܥܒܕܘ ܐܤܛܪܛܝܘܛܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 25,
      "referenceLabel": "John 19:25",
      "text": "ܩܝܡܢ ܗܘܝ ܕܝܢ ܠܘܬ ܙܩܝܦܗ ܕܝܫܘܥ ܐܡܗ ܘܚܬܗ ܕܐܡܗ ܘܡܪܝܡ ܗܝ ܕܩܠܝܘܦܐ ܘܡܪܝܡ ܡܓܕܠܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.26",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 26,
      "referenceLabel": "John 19:26",
      "text": "ܝܫܘܥ ܕܝܢ ܚܙܐ ܠܐܡܗ ܘܠܬܠܡܝܕܐ ܗܘ ܕܪܚܡ ܗܘܐ ܕܩܐܡ ܘܐܡܪ ܠܐܡܗ ܐܢܬܬܐ ܗܐ ܒܪܟܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.27",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 27,
      "referenceLabel": "John 19:27",
      "text": "ܘܐܡܪ ܠܬܠܡܝܕܐ ܗܘ ܗܐ ܐܡܟ ܘܡܢ ܗܝ ܫܥܬܐ ܕܒܪܗ ܬܠܡܝܕܐ ܗܘ ܠܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.28",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 28,
      "referenceLabel": "John 19:28",
      "text": "ܒܬܪ ܗܠܝܢ ܝܕܥ ܝܫܘܥ ܕܟܠܡܕܡ ܐܫܬܠܡ ܘܕܢܬܡܠܐ ܟܬܒܐ ܐܡܪ ܨܗܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.29",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 29,
      "referenceLabel": "John 19:29",
      "text": "ܘܡܐܢܐ ܤܝܡ ܗܘܐ ܕܡܠܐ ܚܠܐ ܗܢܘܢ ܕܝܢ ܡܠܘ ܐܤܦܘܓܐ ܡܢ ܚܠܐ ܘܤܡܘ ܥܠ ܙܘܦܐ ܘܩܪܒܘ ܠܘܬ ܦܘܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.30",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 30,
      "referenceLabel": "John 19:30",
      "text": "ܟܕ ܕܝܢ ܫܩܠ ܗܘ ܚܠܐ ܝܫܘܥ ܐܡܪ ܗܐ ܡܫܠܡ ܘܐܪܟܢ ܪܫܗ ܘܐܫܠܡ ܪܘܚܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.31",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 31,
      "referenceLabel": "John 19:31",
      "text": "ܝܗܘܕܝܐ ܕܝܢ ܡܛܠ ܕܥܪܘܒܬܐ ܗܘܬ ܐܡܪܝܢ ܠܐ ܢܒܘܬܘܢ ܦܓܪܐ ܗܠܝܢ ܥܠ ܙܩܝܦܝܗܘܢ ܡܛܠ ܕܫܒܬܐ ܢܓܗܐ ܝܘܡܐ ܗܘܐ ܓܝܪ ܪܒܐ ܝܘܡܐ ܕܫܒܬܐ ܗܝ ܘܒܥܘ ܡܢ ܦܝܠܛܘܤ ܕܢܬܒܪܘܢ ܫܩܝܗܘܢ ܕܗܢܘܢ ܙܩܝܦܐ ܘܢܚܬܘܢ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.32",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 32,
      "referenceLabel": "John 19:32",
      "text": "ܘܐܬܘ ܐܤܛܪܛܝܘܛܐ ܘܬܒܪܘ ܫܩܘܗܝ ܕܩܕܡܝܐ ܘܕܗܘ ܐܚܪܢܐ ܕܐܙܕܩܦ ܥܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.19.33",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 19,
      "verseNumber": 33,
      "referenceLabel": "John 19:33",
      "text": "ܘܟܕ ܐܬܘ ܠܘܬ ܝܫܘܥ ܚܙܘ ܕܡܝܬ ܠܗ ܡܢ ܟܕܘ ܘܠܐ ܬܒܪܘ ܫܩܘܗܝ ܀",
      "paragraphStart": false
