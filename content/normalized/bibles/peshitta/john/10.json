{
  "chapter": {
    "id": "peshitta:john.10",
    "translationId": "peshitta",
    "bookSlug": "john",
    "chapterNumber": 10,
    "referenceLabel": "John 10",
    "summary": "Source text for John 10 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.10.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "John 10:1",
      "text": "ܐܡܝܢ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܡܢ ܕܠܐ ܥܐܠ ܡܢ ܬܪܥܐ ܠܛܝܪܐ ܕܥܢܐ ܐܠܐ ܤܠܩ ܡܢ ܕܘܟܐ ܐܚܪܢܝܐ ܗܘ ܓܢܒܐ ܗܘ ܘܓܝܤܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.10.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "John 10:2",
      "text": "ܗܘ ܕܝܢ ܕܥܐܠ ܡܢ ܬܪܥܐ ܪܥܝܐ ܗܘ ܕܥܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "John 10:3",
      "text": "ܘܠܗܢܐ ܢܛܪ ܬܪܥܐ ܦܬܚ ܠܗ ܬܪܥܐ ܘܥܢܐ ܫܡܥܐ ܩܠܗ ܘܥܪܒܘܗܝ ܩܪܐ ܒܫܡܗܝܗܘܢ ܘܡܦܩ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "John 10:4",
      "text": "ܘܡܐ ܕܐܦܩ ܥܢܗ ܩܕܡܝܗ ܐܙܠ ܘܥܪܒܘܗܝ ܕܝܠܗ ܐܙܠܝܢ ܒܬܪܗ ܡܛܠ ܕܝܕܥܝܢ ܩܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "John 10:5",
      "text": "ܒܬܪ ܢܘܟܪܝܐ ܕܝܢ ܠܐ ܐܙܠܐ ܥܢܐ ܐܠܐ ܥܪܩܐ ܡܢܗ ܕܠܐ ܝܕܥܐ ܩܠܗ ܕܢܘܟܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "John 10:6",
      "text": "ܗܕܐ ܦܠܐܬܐ ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܗܢܘܢ ܕܝܢ ܠܐ ܝܕܥܘ ܡܢܐ ܡܠܠ ܥܡܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "John 10:7",
      "text": "ܐܡܪ ܠܗܘܢ ܕܝܢ ܬܘܒ ܝܫܘܥ ܐܡܝܢ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܐܢܐ ܐܢܐ ܬܪܥܗ ܕܥܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "John 10:8",
      "text": "ܘܟܠܗܘܢ ܐܝܠܝܢ ܕܐܬܘ ܓܢܒܐ ܐܢܘܢ ܘܓܝܤܐ ܐܠܐ ܠܐ ܫܡܥܬ ܐܢܘܢ ܥܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "John 10:9",
      "text": "ܐܢܐ ܐܢܐ ܬܪܥܐ ܘܒܝ ܐܢ ܐܢܫ ܢܥܘܠ ܢܚܐ ܘܢܥܘܠ ܘܢܦܘܩ ܘܪܥܝܐ ܢܫܟܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "John 10:10",
      "text": "ܓܢܒܐ ܠܐ ܐܬܐ ܐܠܐ ܕܢܓܢܘܒ ܘܕܢܩܛܘܠ ܘܕܢܘܒܕ ܐܢܐ ܐܬܝܬ ܕܚܝܐ ܢܗܘܘܢ ܠܗܘܢ ܘܡܕܡ ܕܝܬܝܪ ܢܗܘܐ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "John 10:11",
      "text": "ܐܢܐ ܐܢܐ ܪܥܝܐ ܛܒܐ ܪܥܝܐ ܛܒܐ ܢܦܫܗ ܤܐܡ ܚܠܦ ܥܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "John 10:12",
      "text": "ܐܓܝܪܐ ܕܝܢ ܕܠܐ ܗܘܐ ܪܥܝܐ ܘܠܘ ܕܝܠܗ ܐܢܘܢ ܥܪܒܐ ܡܐ ܕܚܙܐ ܕܐܒܐ ܕܐܬܐ ܫܒܩ ܥܢܐ ܘܥܪܩ ܘܐܬܐ ܕܐܒܐ ܚܛܦ ܘܡܒܕܪ ܠܗ ܠܥܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "John 10:13",
      "text": "ܐܓܝܪܐ ܕܝܢ ܥܪܩ ܡܛܠ ܕܐܓܝܪܐ ܗܘ ܘܠܐ ܒܛܝܠ ܠܗ ܥܠ ܥܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "John 10:14",
      "text": "ܐܢܐ ܐܢܐ ܪܥܝܐ ܛܒܐ ܘܝܕܥ ܐܢܐ ܠܕܝܠܝ ܘܡܬܝܕܥ ܐܢܐ ܡܢ ܕܝܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "John 10:15",
      "text": "ܐܝܟܢܐ ܕܝܕܥ ܠܝ ܐܒܝ ܘܐܢܐ ܝܕܥ ܐܢܐ ܠܐܒܝ ܘܢܦܫܝ ܤܐܡ ܐܢܐ ܚܠܦ ܥܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "John 10:16",
      "text": "ܐܝܬ ܠܝ ܕܝܢ ܐܦ ܥܪܒܐ ܐܚܪܢܐ ܐܝܠܝܢ ܕܠܐ ܗܘܘ ܡܢ ܛܝܪܐ ܗܢܐ ܘܐܦ ܠܗܘܢ ܘܠܐ ܠܝ ܠܡܝܬܝܘ ܐܢܘܢ ܘܢܫܡܥܘܢ ܩܠܝ ܘܬܗܘܐ ܥܢܐ ܟܠܗ ܚܕܐ ܘܚܕ ܪܥܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "John 10:17",
      "text": "ܡܛܠ ܗܢܐ ܐܒܝ ܪܚܡ ܠܝ ܕܐܢܐ ܤܐܡ ܐܢܐ ܢܦܫܝ ܕܬܘܒ ܐܤܒܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "John 10:18",
      "text": "ܠܐ ܗܘܐ ܐܢܫ ܫܩܠ ܠܗ ܡܢܝ ܐܠܐ ܐܢܐ ܤܐܡ ܐܢܐ ܠܗ ܡܢ ܨܒܝܢܝ ܫܠܝܛ ܐܢܐ ܓܝܪ ܕܐܤܝܡܝܗ ܘܫܠܝܛ ܐܢܐ ܕܬܘܒ ܐܤܒܝܗ ܕܗܢܐ ܦܘܩܕܢܐ ܩܒܠܬ ܡܢ ܐܒܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "John 10:19",
      "text": "ܘܗܘܬ ܬܘܒ ܦܠܓܘܬܐ ܒܝܢܝ ܝܗܘܕܝܐ ܡܛܠ ܡܠܐ ܗܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "John 10:20",
      "text": "ܘܐܡܪܝܢ ܗܘܘ ܤܓܝܐܐ ܡܢܗܘܢ ܕܕܝܘܐ ܐܝܬ ܠܗ ܘܡܫܢܐ ܫܢܐ ܡܢܐ ܫܡܥܝܢ ܐܢܬܘܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "John 10:21",
      "text": "ܐܚܪܢܐ ܕܝܢ ܐܡܪܝܢ ܗܘܘ ܗܠܝܢ ܡܠܐ ܠܐ ܗܘܝ ܕܕܝܘܢܐ ܠܡܐ ܕܝܘܐ ܡܫܟܚ ܥܝܢܐ ܕܤܡܝܐ ܠܡܦܬܚܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "John 10:22",
      "text": "ܗܘܐ ܕܝܢ ܥܐܕܐ ܕܚܘܕܬܐ ܒܐܘܪܫܠܡ ܘܤܬܘܐ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "John 10:23",
      "text": "ܘܡܗܠܟ ܗܘܐ ܝܫܘܥ ܒܗܝܟܠܐ ܒܐܤܛܘܐ ܕܫܠܝܡܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "John 10:24",
      "text": "ܘܚܕܪܘܗܝ ܝܗܘܕܝܐ ܘܐܡܪܝܢ ܠܗ ܥܕܡܐ ܠܐܡܬܝ ܢܤܒ ܐܢܬ ܢܦܫܢ ܐܢ ܐܢܬ ܗܘ ܡܫܝܚܐ ܐܡܪ ܠܢ ܓܠܝܐܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "John 10:25",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗܘܢ ܐܡܪܬ ܠܟܘܢ ܘܠܐ ܡܗܝܡܢܝܢ ܐܢܬܘܢ ܘܥܒܕܐ ܕܐܢܐ ܥܒܕ ܐܢܐ ܒܫܡܗ ܕܐܒܝ ܗܢܘܢ ܤܗܕܝܢ ܥܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.26",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "John 10:26",
      "text": "ܐܠܐ ܐܢܬܘܢ ܠܐ ܡܗܝܡܢܝܢ ܐܢܬܘܢ ܡܛܠ ܕܠܐ ܗܘܝܬܘܢ ܡܢ ܥܪܒܝ ܐܝܟܢܐ ܕܐܡܪܬ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.27",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "John 10:27",
      "text": "ܥܪܒܐ ܕܝܠܝ ܩܠܝ ܫܡܥܝܢ ܘܐܢܐ ܝܕܥ ܐܢܐ ܠܗܘܢ ܘܗܢܘܢ ܐܬܝܢ ܒܬܪܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.28",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "John 10:28",
      "text": "ܘܐܢܐ ܝܗܒ ܐܢܐ ܠܗܘܢ ܚܝܐ ܕܠܥܠܡ ܘܠܐ ܢܐܒܕܘܢ ܠܥܠܡ ܘܠܐ ܐܢܫ ܢܚܛܘܦ ܐܢܘܢ ܡܢ ܐܝܕܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.29",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "John 10:29",
      "text": "ܐܒܝ ܓܝܪ ܕܝܗܒ ܠܝ ܡܢ ܟܠ ܪܒ ܗܘ ܘܠܐ ܐܢܫ ܡܫܟܚ ܕܡܢ ܐܝܕܗ ܕܐܒܝ ܢܚܛܘܦ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.30",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "John 10:30",
      "text": "ܐܢܐ ܘܐܒܝ ܚܕ ܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.31",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "John 10:31",
      "text": "ܘܫܩܠܘ ܬܘܒ ܝܗܘܕܝܐ ܟܐܦܐ ܠܡܪܓܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.32",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "John 10:32",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܤܓܝܐܐ ܥܒܕܐ ܫܦܝܪܐ ܡܢ ܠܘܬ ܐܒܝ ܚܘܝܬܟܘܢ ܡܛܠ ܐܝܢܐ ܥܒܕܐ ܡܢܗܘܢ ܪܓܡܝܢ ܐܢܬܘܢ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.33",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "John 10:33",
      "text": "ܐܡܪܝܢ ܠܗ ܝܗܘܕܝܐ ܠܐ ܗܘܐ ܡܛܠ ܥܒܕܐ ܫܦܝܪܐ ܪܓܡܝܢ ܚܢܢ ܠܟ ܐܠܐ ܡܛܠ ܕܡܓܕܦ ܐܢܬ ܘܟܕ ܐܝܬܝܟ ܒܪ ܐܢܫܐ ܥܒܕ ܐܢܬ ܢܦܫܟ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.34",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 34,
      "referenceLabel": "John 10:34",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܠܐ ܗܘܐ ܗܟܢܐ ܟܬܝܒ ܒܢܡܘܤܟܘܢ ܕܐܢܐ ܐܡܪܬ ܕܐܠܗܐ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.35",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 35,
      "referenceLabel": "John 10:35",
      "text": "ܐܢ ܠܗܢܘܢ ܐܡܪ ܐܠܗܐ ܡܛܠ ܕܠܘܬܗܘܢ ܗܘܬ ܡܠܬܐ ܕܐܠܗܐ ܘܠܐ ܡܫܟܚ ܟܬܒܐ ܕܢܫܬܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.36",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 36,
      "referenceLabel": "John 10:36",
      "text": "ܠܐܝܢܐ ܕܐܒܐ ܩܕܫܗ ܘܫܕܪܗ ܠܥܠܡܐ ܐܢܬܘܢ ܐܡܪܝܢ ܐܢܬܘܢ ܕܡܓܕܦ ܐܢܬ ܥܠ ܕܐܡܪܬ ܠܟܘܢ ܕܒܪܗ ܐܢܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.37",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 37,
      "referenceLabel": "John 10:37",
      "text": "ܐܠܐ ܥܒܕ ܐܢܐ ܥܒܕܐ ܕܐܒܝ ܠܐ ܬܗܝܡܢܘܢܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.10.38",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 10,
