{
  "chapter": {
    "id": "peshitta:john.9",
    "translationId": "peshitta",
    "bookSlug": "john",
    "chapterNumber": 9,
    "referenceLabel": "John 9",
    "summary": "Source text for John 9 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.9.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "John 9:1",
      "text": "ܘܟܕ ܥܒܪ ܚܙܐ ܓܒܪܐ ܤܡܝܐ ܕܡܢ ܟܪܤ ܐܡܗ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.9.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "John 9:2",
      "text": "ܘܫܐܠܘܗܝ ܬܠܡܝܕܘܗܝ ܘܐܡܪܝܢ ܪܒܢ ܡܢܘ ܚܛܐ ܗܢܐ ܐܘ ܐܒܗܘܗܝ ܕܟܕ ܤܡܐ ܢܬܝܠܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "John 9:3",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܠܐ ܗܘ ܚܛܐ ܘܠܐ ܐܒܗܘܗܝ ܐܠܐ ܕܢܬܚܙܘܢ ܒܗ ܥܒܕܘܗܝ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "John 9:4",
      "text": "ܠܝ ܘܠܐ ܠܡܥܒܕ ܥܒܕܐ ܕܡܢ ܕܫܕܪܢܝ ܥܕ ܐܝܡܡܐ ܗܘ ܐܬܐ ܠܠܝܐ ܕܐܢܫ ܠܐ ܡܫܟܚ ܠܡܦܠܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "John 9:5",
      "text": "ܟܡܐ ܕܒܥܠܡܐ ܐܢܐ ܢܘܗܪܗ ܐܢܐ ܕܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "John 9:6",
      "text": "ܘܟܕ ܐܡܪ ܗܠܝܢ ܪܩ ܥܠ ܐܪܥܐ ܘܓܒܠ ܛܝܢܐ ܡܢ ܪܘܩܗ ܘܛܫ ܥܠ ܥܝܢܘܗܝ ܕܗܘ ܤܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "John 9:7",
      "text": "ܘܐܡܪ ܠܗ ܙܠ ܐܫܝܓ ܒܡܥܡܘܕܝܬܐ ܕܫܝܠܘܚܐ ܘܐܙܠ ܐܫܝܓ ܘܐܬܐ ܟܕ ܚܙܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "John 9:8",
      "text": "ܫܒܒܘܗܝ ܕܝܢ ܘܐܝܠܝܢ ܕܚܙܐ ܗܘܐ ܠܗܘܢ ܡܢ ܩܕܝܡ ܕܚܕܪ ܗܘܐ ܐܡܪܝܢ ܗܘܘ ܠܐ ܗܘܐ ܗܢܘ ܗܘ ܕܝܬܒ ܗܘܐ ܘܚܕܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "John 9:9",
      "text": "ܐܝܬ ܕܐܡܪܝܢ ܗܘܘ ܕܗܘܝܘ ܘܐܝܬ ܕܐܡܪܝܢ ܗܘܘ ܠܐ ܐܠܐ ܡܕܡܐ ܕܡܐ ܠܗ ܗܘ ܕܝܢ ܐܡܪ ܗܘܐ ܕܐܢܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "John 9:10",
      "text": "ܐܡܪܝܢ ܠܗ ܐܝܟܢܐ ܐܬܦܬܚ ܥܝܢܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "John 9:11",
      "text": "ܥܢܐ ܘܐܡܪ ܠܗܘܢ ܓܒܪܐ ܕܫܡܗ ܝܫܘܥ ܥܒܕ ܛܝܢܐ ܘܛܫ ܠܝ ܥܠ ܥܝܢܝ ܘܐܡܪ ܠܝ ܙܠ ܐܫܝܓ ܒܡܝܐ ܕܫܝܠܘܚܐ ܘܐܙܠܬ ܐܫܝܓܬ ܘܐܬܚܙܝ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "John 9:12",
      "text": "ܐܡܪܝܢ ܠܗ ܐܝܟܘ ܐܡܪ ܠܗܘܢ ܠܐ ܝܕܥ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "John 9:13",
      "text": "ܘܐܝܬܝܘܗܝ ܠܗܘ ܕܡܢ ܩܕܝܡ ܤܡܝܐ ܗܘܐ ܠܘܬ ܦܪܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "John 9:14",
      "text": "ܐܝܬܝܗ ܗܘܬ ܕܝܢ ܫܒܬܐ ܟܕ ܥܒܕ ܛܝܢܐ ܝܫܘܥ ܘܦܬܚ ܠܗ ܥܝܢܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "John 9:15",
      "text": "ܘܬܘܒ ܫܐܠܘܗܝ ܦܪܝܫܐ ܐܝܟܢܐ ܐܬܚܙܝ ܠܟ ܗܘ ܕܝܢ ܐܡܪ ܠܗܘܢ ܛܝܢܐ ܤܡ ܥܠ ܥܝܢܝ ܘܐܫܝܓܬ ܘܐܬܚܙܝ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "John 9:16",
      "text": "ܘܐܡܪܝܢ ܗܘܘ ܐܢܫܐ ܡܢ ܦܪܝܫܐ ܗܢܐ ܓܒܪܐ ܠܐ ܗܘܐ ܡܢ ܐܠܗܐ ܗܘ ܕܫܒܬܐ ܠܐ ܢܛܪ ܐܚܪܢܐ ܕܝܢ ܐܡܪܝܢ ܗܘܘ ܐܝܟܢܐ ܡܫܟܚ ܓܒܪܐ ܚܛܝܐ ܗܠܝܢ ܐܬܘܬܐ ܠܡܥܒܕ ܘܦܠܓܘܬܐ ܐܝܬ ܗܘܬ ܒܝܢܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "John 9:17",
      "text": "ܐܡܪܝܢ ܬܘܒ ܠܗܘ ܤܡܝܐ ܐܢܬ ܡܢܐ ܐܡܪ ܐܢܬ ܥܠܘܗܝ ܕܦܬܚ ܠܟ ܥܝܢܝܟ ܐܡܪ ܠܗܘܢ ܐܢܐ ܐܡܪ ܐܢܐ ܕܢܒܝܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "John 9:18",
      "text": "ܠܐ ܕܝܢ ܗܝܡܢܘ ܗܘܘ ܥܠܘܗܝ ܝܗܘܕܝܐ ܕܤܡܝܐ ܗܘܐ ܘܚܙܐ ܥܕܡܐ ܕܩܪܘ ܠܐܒܗܘܗܝ ܕܗܘ ܕܚܙܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "John 9:19",
      "text": "ܘܫܐܠܘ ܐܢܘܢ ܐܢ ܗܢܘ ܒܪܟܘܢ ܗܘ ܕܐܢܬܘܢ ܐܡܪܝܢ ܐܢܬܘܢ ܕܟܕ ܤܡܐ ܐܬܝܠܕ ܐܝܟܢܐ ܗܫܐ ܚܙܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "John 9:20",
      "text": "ܥܢܘ ܕܝܢ ܐܒܗܘܗܝ ܘܐܡܪܘ ܝܕܥܝܢܢ ܕܗܢܘ ܒܪܢ ܘܕܟܕ ܤܡܐ ܐܬܝܠܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "John 9:21",
      "text": "ܐܝܟܢܐ ܕܝܢ ܗܫܐ ܚܙܐ ܐܘ ܡܢܘ ܦܬܚ ܠܗ ܥܝܢܘܗܝ ܠܐ ܝܕܥܝܢܢ ܐܦ ܗܘ ܥܠ ܠܗ ܠܫܢܘܗܝ ܠܗ ܫܐܠܘ ܗܘ ܚܠܦ ܢܦܫܗ ܢܡܠܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "John 9:22",
      "text": "ܗܠܝܢ ܐܡܪܘ ܐܒܗܘܗܝ ܡܛܠ ܕܕܚܠܝܢ ܗܘܘ ܡܢ ܝܗܘܕܝܐ ܦܤܩܘ ܗܘܘ ܓܝܪ ܝܗܘܕܝܐ ܕܐܢ ܐܢܫ ܢܘܕܐ ܒܗ ܕܡܫܝܚܐ ܗܘ ܢܦܩܘܢܝܗܝ ܡܢ ܟܢܘܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "John 9:23",
      "text": "ܡܛܠ ܗܢܐ ܐܡܪܘ ܐܒܗܘܗܝ ܕܥܠ ܠܗ ܠܫܢܘܗܝ ܠܗ ܫܐܠܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "John 9:24",
      "text": "ܘܩܪܐܘܗܝ ܠܓܒܪܐ ܕܬܪܬܝܢ ܙܒܢܝܢ ܠܗܘ ܕܐܝܬܘܗܝ ܗܘܐ ܤܡܝܐ ܘܐܡܪܝܢ ܠܗ ܫܒܚ ܠܐܠܗܐ ܚܢܢ ܓܝܪ ܝܕܥܝܢܢ ܕܗܢܐ ܓܒܪܐ ܚܛܝܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "John 9:25",
      "text": "ܥܢܐ ܗܘ ܘܐܡܪ ܠܗܘܢ ܐܢ ܚܛܝܐ ܗܘ ܠܐ ܝܕܥ ܐܢܐ ܚܕܐ ܕܝܢ ܝܕܥ ܐܢܐ ܕܤܡܝܐ ܗܘܝܬ ܘܗܫܐ ܗܐ ܚܙܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.26",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "John 9:26",
      "text": "ܐܡܪܝܢ ܠܗ ܬܘܒ ܡܢܐ ܥܒܕ ܠܟ ܐܝܟܢܐ ܦܬܚ ܠܟ ܥܝܢܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.27",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "John 9:27",
      "text": "ܐܡܪ ܠܗܘܢ ܐܡܪܬ ܠܟܘܢ ܘܠܐ ܫܡܥܬܘܢ ܡܢܐ ܬܘܒ ܨܒܝܢ ܐܢܬܘܢ ܠܡܫܡܥ ܠܡܐ ܐܦ ܐܢܬܘܢ ܬܠܡܝܕܐ ܨܒܝܢ ܐܢܬܘܢ ܠܡܗܘܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.28",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "John 9:28",
      "text": "ܗܢܘܢ ܕܝܢ ܨܚܝܘܗܝ ܘܐܡܪܝܢ ܠܗ ܐܢܬ ܗܘ ܬܠܡܝܕܗ ܕܗܘ ܚܢܢ ܓܝܪ ܬܠܡܝܕܐ ܚܢܢ ܕܡܘܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.29",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 29,
      "referenceLabel": "John 9:29",
      "text": "ܘܝܕܥܝܢܢ ܕܥܡ ܡܘܫܐ ܐܠܗܐ ܡܠܠ ܠܗܢܐ ܕܝܢ ܠܐ ܝܕܥܝܢܢ ܡܢ ܐܝܡܟܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.30",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 30,
      "referenceLabel": "John 9:30",
      "text": "ܥܢܐ ܗܘ ܓܒܪܐ ܘܐܡܪ ܠܗܘܢ ܒܗܕܐ ܗܘ ܗܟܝܠ ܠܡܬܕܡܪܘ ܕܐܢܬܘܢ ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܡܢ ܐܝܡܟܐ ܗܘ ܘܥܝܢܝ ܕܝܠܝ ܦܬܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.31",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 31,
      "referenceLabel": "John 9:31",
      "text": "ܝܕܥܝܢ ܚܢܢ ܕܝܢ ܕܐܠܗܐ ܒܩܠܐ ܕܚܛܝܐ ܠܐ ܫܡܥ ܐܠܐ ܠܡܢ ܕܕܚܠ ܡܢܗ ܘܥܒܕ ܨܒܝܢܗ ܠܗܘ ܗܘ ܫܡܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.32",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 32,
      "referenceLabel": "John 9:32",
      "text": "ܡܢ ܥܠܡ ܠܐ ܐܫܬܡܥܬ ܕܦܬܚ ܐܢܫ ܥܝܢܐ ܕܤܡܝܐ ܕܐܬܝܠܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.33",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 33,
      "referenceLabel": "John 9:33",
      "text": "ܐܠܘ ܠܐ ܡܢ ܐܠܗܐ ܗܘܐ ܗܢܐ ܠܐ ܡܫܟܚ ܗܘܐ ܗܕܐ ܠܡܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.34",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 34,
      "referenceLabel": "John 9:34",
      "text": "ܥܢܘ ܘܐܡܪܝܢ ܠܗ ܐܢܬ ܟܠܟ ܒܚܛܗܐ ܐܬܝܠܕܬ ܘܐܢܬ ܡܠܦ ܐܢܬ ܠܢ ܘܐܦܩܘܗܝ ܠܒܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.35",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 35,
      "referenceLabel": "John 9:35",
      "text": "ܘܫܡܥ ܝܫܘܥ ܕܐܦܩܘܗܝ ܠܒܪ ܘܐܫܟܚܗ ܘܐܡܪ ܠܗ ܐܢܬ ܡܗܝܡܢ ܐܢܬ ܒܒܪܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.36",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 36,
      "referenceLabel": "John 9:36",
      "text": "ܥܢܐ ܗܘ ܕܐܬܐܤܝ ܘܐܡܪ ܡܢܘ ܡܪܝ ܕܐܗܝܡܢ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.37",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 37,
      "referenceLabel": "John 9:37",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܚܙܝܬܝܗܝ ܘܗܘ ܕܡܡܠܠ ܥܡܟ ܗܘܝܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.9.38",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 9,
