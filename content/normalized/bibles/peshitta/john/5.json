    "bookSlug": "john",
    "chapterNumber": 5,
    "referenceLabel": "John 5",
    "summary": "Source text for John 5 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.5.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "John 5:1",
      "text": "ܒܬܪ ܗܠܝܢ ܗܘܐ ܥܕܥܕܐ ܕܝܗܘܕܝܐ ܘܤܠܩ ܝܫܘܥ ܠܐܘܪܫܠܡ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.5.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "John 5:2",
      "text": "ܐܝܬ ܗܘܐ ܕܝܢ ܬܡܢ ܒܐܘܪܫܠܡ ܕܘܟܬܐ ܚܕܐ ܕܡܥܡܘܕܝܬܐ ܕܡܬܩܪܝܐ ܥܒܪܐܝܬ ܒܝܬ ܚܤܕܐ ܘܐܝܬ ܗܘܐ ܒܗ ܚܡܫܐ ܐܤܛܘܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "John 5:3",
      "text": "ܘܒܗܠܝܢ ܪܡܝܢ ܗܘܘ ܥܡܐ ܤܓܝܐܐ ܕܟܪܝܗܐ ܘܤܡܝܐ ܘܚܓܝܤܐ ܘܝܒܝܫܐ ܘܡܤܟܝܢ ܗܘܘ ܠܙܘܥܐ ܕܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "John 5:4",
      "text": "ܡܠܐܟܐ ܓܝܪ ܒܙܒܢ ܙܒܢ ܢܚܬ ܗܘܐ ܠܗ ܠܡܥܡܘܕܝܬܐ ܘܡܙܝܥ ܗܘܐ ܠܗܘܢ ܠܡܝܐ ܘܐܝܢܐ ܕܩܕܡܝܐ ܢܚܬ ܗܘܐ ܡܢ ܒܬܪ ܙܘܥܐ ܕܡܝܐ ܡܬܚܠܡ ܗܘܐ ܟܠ ܟܐܒܐ ܐܝܢܐ ܕܐܝܬ ܗܘܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "John 5:5",
      "text": "ܐܝܬ ܗܘܐ ܕܝܢ ܬܡܢ ܓܒܪܐ ܚܕ ܕܬܠܬܝܢ ܘܬܡܢܐ ܫܢܝܢ ܐܝܬܘܗܝ ܗܘܐ ܒܟܘܪܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "John 5:6",
      "text": "ܠܗܢܐ ܚܙܐ ܝܫܘܥ ܕܪܡܐ ܘܝܕܥ ܕܙܒܢܐ ܤܓܝܐܐ ܐܝܬ ܠܗ ܘܐܡܪ ܠܗ ܨܒܐ ܐܢܬ ܕܬܬܚܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "John 5:7",
      "text": "ܥܢܐ ܗܘ ܟܪܝܗܐ ܘܐܡܪ ܐܝܢ ܡܪܝ ܠܝܬ ܠܝ ܕܝܢ ܐܢܫ ܕܡܐ ܕܐܬܬܙܝܥܘ ܡܝܐ ܢܪܡܝܢܝ ܒܡܥܡܘܕܝܬܐ ܐܠܐ ܥܕ ܐܢܐ ܐܬܐ ܐܢܐ ܐܚܪܝܢ ܡܢ ܩܕܡܝ ܢܚܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "John 5:8",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܩܘܡ ܫܩܘܠ ܥܪܤܟ ܘܗܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "John 5:9",
      "text": "ܘܒܪ ܫܥܬܗ ܐܬܚܠܡ ܓܒܪܐ ܗܘ ܘܩܡ ܫܩܠ ܥܪܤܗ ܘܗܠܟ ܘܗܘ ܗܘ ܝܘܡܐ ܫܒܬܐ ܗܘܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "John 5:10",
      "text": "ܘܐܡܪܝܢ ܠܗ ܝܗܘܕܝܐ ܠܗܘ ܕܐܬܐܤܝ ܫܒܬܐ ܗܝ ܠܐ ܫܠܝܛ ܠܟ ܕܬܫܩܘܠ ܥܪܤܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "John 5:11",
      "text": "ܗܘ ܕܝܢ ܥܢܐ ܘܐܡܪ ܠܗܘܢ ܗܘ ܕܥܒܕܢܝ ܚܠܝܡܐ ܗܘ ܐܡܪ ܠܝ ܕܫܩܘܠ ܥܪܤܟ ܘܗܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "John 5:12",
      "text": "ܘܫܐܠܘܗܝ ܡܢܘ ܗܢܐ ܓܒܪܐ ܕܐܡܪ ܠܟ ܕܫܩܘܠ ܥܪܤܟ ܘܗܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "John 5:13",
      "text": "ܗܘ ܕܝܢ ܕܐܬܐܤܝ ܠܐ ܝܕܥ ܗܘܐ ܡܢܘ ܝܫܘܥ ܓܝܪ ܐܬܓܢܝ ܗܘܐ ܠܗ ܒܟܢܫܐ ܤܓܝܐܐ ܕܐܝܬ ܗܘܐ ܒܕܘܟܬܐ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "John 5:14",
      "text": "ܒܬܪ ܙܒܢ ܐܫܟܚܗ ܝܫܘܥ ܒܗܝܟܠܐ ܘܐܡܪ ܠܗ ܗܐ ܚܠܝܡ ܐܢܬ ܬܘܒ ܠܐ ܬܚܛܐ ܕܠܡܐ ܢܗܘܐ ܠܟ ܡܕܡ ܕܒܝܫ ܡܢ ܩܕܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "John 5:15",
      "text": "ܘܐܙܠ ܗܘ ܓܒܪܐ ܘܐܡܪ ܠܝܗܘܕܝܐ ܕܝܫܘܥ ܗܘ ܗܘ ܕܐܚܠܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "John 5:16",
      "text": "ܘܡܛܠ ܗܕܐ ܪܕܦܝܢ ܗܘܘ ܝܗܘܕܝܐ ܠܝܫܘܥ ܘܒܥܝܢ ܗܘܘ ܠܡܩܛܠܗ ܕܗܠܝܢ ܥܒܕ ܗܘܐ ܒܫܒܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "John 5:17",
      "text": "ܗܘ ܕܝܢ ܝܫܘܥ ܐܡܪ ܠܗܘܢ ܐܒܝ ܥܕܡܐ ܠܗܫܐ ܥܒܕ ܐܦ ܐܢܐ ܥܒܕ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "John 5:18",
      "text": "ܘܡܛܠ ܗܕܐ ܝܬܝܪܐܝܬ ܒܥܝܢ ܗܘܘ ܝܗܘܕܝܐ ܠܡܩܛܠܗ ܠܐ ܒܠܚܘܕ ܕܫܪܐ ܗܘܐ ܫܒܬܐ ܐܠܐ ܐܦ ܕܥܠ ܐܠܗܐ ܕܐܒܘܗܝ ܐܝܬܘܗܝ ܐܡܪ ܗܘܐ ܘܡܫܘܐ ܗܘܐ ܢܦܫܗ ܥܡ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "John 5:19",
      "text": "ܥܢܐ ܕܝܢ ܝܫܘܥ ܘܐܡܪ ܠܗܘܢ ܐܡܝܢ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܠܐ ܡܫܟܚ ܒܪܐ ܥܒܕ ܡܕܡ ܡܢ ܨܒܘܬ ܢܦܫܗ ܐܠܐ ܡܕܡ ܕܚܙܐ ܠܐܒܐ ܕܥܒܕ ܐܝܠܝܢ ܓܝܪ ܕܐܒܐ ܥܒܕ ܗܠܝܢ ܐܦ ܒܪܐ ܐܟܘܬܗ ܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "John 5:20",
      "text": "ܐܒܐ ܓܝܪ ܪܚܡ ܠܒܪܗ ܘܟܠܡܕܡ ܕܥܒܕ ܡܚܘܐ ܠܗ ܘܕܝܬܝܪܝܢ ܡܢ ܗܠܝܢ ܥܒܕܐ ܡܚܘܐ ܠܗ ܕܐܢܬܘܢ ܬܬܕܡܪܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "John 5:21",
      "text": "ܐܝܟܢܐ ܓܝܪ ܕܐܒܐ ܡܩܝܡ ܡܝܬܐ ܘܡܚܐ ܠܗܘܢ ܗܟܢܐ ܐܦ ܒܪܐ ܠܐܝܠܝܢ ܕܨܒܐ ܡܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "John 5:22",
      "text": "ܠܐ ܗܘܐ ܓܝܪ ܐܒܐ ܕܐܢ ܠܐܢܫ ܐܠܐ ܟܠܗ ܕܝܢܐ ܝܗܒܗ ܠܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "John 5:23",
      "text": "ܕܟܠܢܫ ܢܝܩܪ ܠܒܪܐ ܐܝܟ ܕܡܝܩܪ ܠܐܒܐ ܗܘ ܕܠܐ ܡܝܩܪ ܠܒܪܐ ܠܐ ܡܝܩܪ ܠܐܒܐ ܕܫܕܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "John 5:24",
      "text": "ܐܡܝܢ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܡܢ ܕܫܡܥ ܡܠܬܝ ܘܡܗܝܡܢ ܠܡܢ ܕܫܕܪܢܝ ܐܝܬ ܠܗ ܚܝܐ ܕܠܥܠܡ ܘܠܕܝܢܐ ܠܐ ܐܬܐ ܐܠܐ ܫܢܝ ܠܗ ܡܢ ܡܘܬܐ ܠܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "John 5:25",
      "text": "ܐܡܝܢ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܐܬܝܐ ܫܥܬܐ ܐܦ ܗܫܐ ܐܝܬܝܗ ܐܡܬܝ ܕܡܝܬܐ ܢܫܡܥܘܢ ܩܠܗ ܕܒܪܗ ܕܐܠܗܐ ܘܗܢܘܢ ܕܫܡܥܝܢ ܢܚܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.26",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "John 5:26",
      "text": "ܐܝܟܢܐ ܓܝܪ ܕܠܐܒܐ ܐܝܬ ܚܝܐ ܒܩܢܘܡܗ ܗܟܢܐ ܝܗܒ ܐܦ ܠܒܪܐ ܕܢܗܘܘܢ ܚܝܐ ܒܩܢܘܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.27",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "John 5:27",
      "text": "ܘܐܫܠܛܗ ܕܢܗܘܐ ܥܒܕ ܐܦ ܕܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.28",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "John 5:28",
      "text": "ܕܒܪܗ ܗܘ ܕܝܢ ܕܐܢܫܐ ܠܐ ܬܬܕܡܪܘܢ ܒܗܕܐ ܕܐܬܝܐ ܫܥܬܐ ܐܡܬܝ ܕܟܠܗܘܢ ܐܝܠܝܢ ܕܒܩܒܪܐ ܐܢܘܢ ܢܫܡܥܘܢ ܩܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.29",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "John 5:29",
      "text": "ܘܢܦܩܘܢ ܐܝܠܝܢ ܕܥܒܕܘ ܛܒܬܐ ܠܩܝܡܬܐ ܕܚܝܐ ܘܐܝܠܝܢ ܕܥܒܕܘ ܒܝܫܬܐ ܠܩܝܡܬܐ ܕܕܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.30",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "John 5:30",
      "text": "ܠܐ ܡܫܟܚ ܐܢܐ ܡܕܡ ܡܢ ܨܒܘܬ ܢܦܫܝ ܠܡܥܒܕ ܐܠܐ ܐܝܟܢܐ ܕܫܡܥ ܐܢܐ ܕܐܢ ܐܢܐ ܘܕܝܢܝ ܟܐܝܢ ܗܘ ܠܐ ܓܝܪ ܒܥܐ ܐܢܐ ܨܒܝܢܝ ܐܠܐ ܨܒܝܢܗ ܕܡܢ ܕܫܕܪܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.31",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "John 5:31",
      "text": "ܐܢ ܐܢܐ ܡܤܗܕ ܐܢܐ ܥܠ ܢܦܫܝ ܤܗܕܘܬܝ ܠܐ ܗܘܬ ܫܪܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.32",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 32,
      "referenceLabel": "John 5:32",
      "text": "ܐܚܪܝܢ ܗܘ ܗܘ ܕܡܤܗܕ ܥܠܝ ܘܝܕܥ ܐܢܐ ܕܫܪܝܪܐ ܗܝ ܤܗܕܘܬܗ ܕܡܤܗܕ ܥܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.33",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 33,
      "referenceLabel": "John 5:33",
      "text": "ܐܢܬܘܢ ܫܕܪܬܘܢ ܠܘܬ ܝܘܚܢܢ ܘܐܤܗܕ ܥܠ ܫܪܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.5.34",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 34,
      "referenceLabel": "John 5:34",
      "text": "ܐܢܐ ܕܝܢ ܠܐ ܗܘܐ ܡܢ ܒܪܢܫܐ ܢܤܒ ܐܢܐ ܤܗܕܘܬܐ ܐܠܐ ܗܠܝܢ ܐܡܪ ܐܢܐ ܕܐܢܬܘܢ ܬܚܘܢ ܀",
      "paragraphStart": false
    },
    {
