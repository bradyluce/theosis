{
  "chapter": {
    "id": "peshitta:john.11",
    "translationId": "peshitta",
    "bookSlug": "john",
    "chapterNumber": 11,
    "referenceLabel": "John 11",
    "summary": "Source text for John 11 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:john.11.1",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "John 11:1",
      "text": "ܐܝܬ ܗܘܐ ܕܝܢ ܚܕ ܕܟܪܝܗ ܠܥܙܪ ܡܢ ܒܝܬ ܥܢܝܐ ܩܪܝܬܐ ܐܚܘܗ ܕܡܪܝܡ ܘܕܡܪܬܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:john.11.2",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "John 11:2",
      "text": "ܡܪܝܡ ܕܝܢ ܗܕܐ ܐܝܬܝܗ ܗܝ ܕܡܫܚܬ ܒܒܤܡܐ ܪܓܠܘܗܝ ܕܝܫܘܥ ܘܫܘܝܬ ܒܤܥܪܗ ܐܚܘܗ ܗܘܐ ܕܗܕܐ ܠܥܙܪ ܕܟܪܝܗ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.3",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "John 11:3",
      "text": "ܘܫܕܪܝܢ ܬܪܬܝܗܝܢ ܐܚܘܬܗ ܠܘܬ ܝܫܘܥ ܘܐܡܪܢ ܡܪܢ ܗܐ ܗܘ ܕܪܚܡ ܐܢܬ ܟܪܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.4",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "John 11:4",
      "text": "ܝܫܘܥ ܕܝܢ ܐܡܪ ܗܢܐ ܟܘܪܗܢܐ ܠܐ ܗܘܐ ܕܡܘܬܐ ܐܠܐ ܚܠܦ ܬܫܒܘܚܬܐ ܕܐܠܗܐ ܕܢܫܬܒܚ ܒܪܗ ܕܐܠܗܐ ܡܛܠܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.5",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "John 11:5",
      "text": "ܡܚܒ ܗܘܐ ܕܝܢ ܗܘ ܝܫܘܥ ܠܡܪܬܐ ܘܠܡܪܝܡ ܘܠܠܥܙܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.6",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "John 11:6",
      "text": "ܘܟܕ ܫܡܥ ܕܟܪܝܗ ܟܬܪ ܒܕܘܟܬܐ ܕܐܝܬܘܗܝ ܗܘܐ ܬܪܝܢ ܝܘܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.7",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "John 11:7",
      "text": "ܘܒܬܪܟܢ ܐܡܪ ܠܬܠܡܝܕܘܗܝ ܬܘ ܢܐܙܠ ܬܘܒ ܠܝܗܘܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.8",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "John 11:8",
      "text": "ܐܡܪܝܢ ܠܗ ܬܠܡܝܕܘܗܝ ܪܒܢ ܗܫܐ ܝܗܘܕܝܐ ܒܥܝܢ ܗܘܘ ܠܡܪܓܡܟ ܘܬܘܒ ܐܙܠ ܐܢܬ ܠܬܡܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.9",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "John 11:9",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܠܐ ܬܪܬܥܤܪܐ ܫܥܝܢ ܐܝܬ ܒܝܘܡܐ ܘܐܢ ܐܢܫ ܡܗܠܟ ܒܐܝܡܡܐ ܠܐ ܡܬܬܩܠ ܡܛܠ ܕܚܙܐ ܢܘܗܪܗ ܕܥܠܡܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.10",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "John 11:10",
      "text": "ܐܢ ܐܢܫ ܕܝܢ ܒܠܠܝܐ ܢܗܠܟ ܡܬܬܩܠ ܡܛܠ ܕܢܗܝܪܐ ܠܝܬ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.11",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "John 11:11",
      "text": "ܗܠܝܢ ܐܡܪ ܝܫܘܥ ܘܒܬܪܟܢ ܐܡܪ ܠܗܘܢ ܠܥܙܪ ܪܚܡܢ ܫܟܒ ܐܠܐ ܐܙܠ ܐܢܐ ܕܐܥܝܪܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.12",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "John 11:12",
      "text": "ܐܡܪܝܢ ܠܗ ܬܠܡܝܕܘܗܝ ܡܪܢ ܐܢ ܕܡܟ ܡܬܚܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.13",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "John 11:13",
      "text": "ܗܘ ܕܝܢ ܝܫܘܥ ܐܡܪ ܥܠ ܡܘܬܗ ܘܗܢܘܢ ܤܒܪܘ ܕܥܠ ܡܕܡܟܐ ܗܘ ܕܫܢܬܐ ܐܡܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.14",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "John 11:14",
      "text": "ܗܝܕܝܢ ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܦܫܝܩܐܝܬ ܠܥܙܪ ܡܝܬ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.15",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "John 11:15",
      "text": "ܘܚܕܐ ܐܢܐ ܕܠܐ ܗܘܝܬ ܬܡܢ ܡܛܠܬܟܘܢ ܕܬܗܝܡܢܘܢ ܐܠܐ ܗܠܟܘ ܠܬܡܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.16",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "John 11:16",
      "text": "ܐܡܪ ܬܐܘܡܐ ܕܡܬܐܡܪ ܬܐܡܐ ܠܬܠܡܝܕܐ ܚܒܪܘܗܝ ܢܐܙܠ ܐܦ ܚܢܢ ܢܡܘܬ ܥܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.17",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "John 11:17",
      "text": "ܘܐܬܐ ܝܫܘܥ ܠܒܝܬ ܥܢܝܐ ܘܐܫܟܚ ܕܐܪܒܥܐ ܠܗ ܝܘܡܝܢ ܕܐܝܬܘܗܝ ܒܒܝܬ ܩܒܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.18",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "John 11:18",
      "text": "ܐܝܬܝܗ ܗܘܬ ܕܝܢ ܒܝܬ ܥܢܝܐ ܥܠ ܓܢܒ ܐܘܪܫܠܡ ܟܕ ܦܪܝܩܐ ܡܢܗ ܐܝܟ ܐܤܛܕܘܬܐ ܚܡܫܬܥܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.19",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "John 11:19",
      "text": "ܘܤܓܝܐܐ ܡܢ ܝܗܘܕܝܐ ܐܬܝܐܝܢ ܗܘܘ ܠܘܬ ܡܪܬܐ ܘܡܪܝܡ ܕܢܡܠܘܢ ܒܠܒܗܝܢ ܡܛܠ ܐܚܘܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.20",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "John 11:20",
      "text": "ܡܪܬܐ ܕܝܢ ܟܕ ܫܡܥܬ ܕܝܫܘܥ ܐܬܐ ܢܦܩܬ ܠܐܘܪܥܗ ܡܪܝܡ ܕܝܢ ܒܒܝܬܐ ܝܬܒܐ ܗܘܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.21",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "John 11:21",
      "text": "ܘܐܡܪܬ ܡܪܬܐ ܠܝܫܘܥ ܡܪܝ ܐܠܘ ܬܢܢ ܗܘܝܬ ܠܐ ܡܐܬ ܗܘܐ ܐܚܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.22",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "John 11:22",
      "text": "ܐܠܐ ܐܦ ܗܫܐ ܝܕܥܐ ܐܢܐ ܕܟܡܐ ܕܬܫܐܠ ܠܐܠܗܐ ܝܗܒ ܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.23",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "John 11:23",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܩܐܡ ܐܚܘܟܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.24",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "John 11:24",
      "text": "ܐܡܪܐ ܠܗ ܡܪܬܐ ܝܕܥܐܢܐ ܕܩܐܡ ܒܢܘܚܡܐ ܒܝܘܡܐ ܐܚܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.25",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "John 11:25",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܐܢܐ ܐܢܐ ܢܘܚܡܐ ܘܚܝܐ ܡܢ ܕܡܗܝܡܢ ܒܝ ܐܦܢ ܢܡܘܬ ܢܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.26",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "John 11:26",
      "text": "ܘܟܠ ܕܚܝ ܘܡܗܝܡܢ ܒܝ ܠܥܠܡ ܠܐ ܢܡܘܬ ܡܗܝܡܢܬܝ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.27",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "John 11:27",
      "text": "ܐܡܪܐ ܠܗ ܐܝܢ ܡܪܝ ܐܢܐ ܡܗܝܡܢܐ ܐܢܐ ܕܐܢܬ ܗܘ ܡܫܝܚܐ ܒܪܗ ܕܐܠܗܐ ܕܐܬܐ ܠܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.28",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "John 11:28",
      "text": "ܘܟܕ ܐܡܪܬ ܗܠܝܢ ܐܙܠܬ ܩܪܬ ܠܡܪܝܡ ܚܬܗ ܟܤܝܐܝܬ ܘܐܡܪܐ ܠܗ ܪܒܢ ܐܬܐ ܘܩܪܐ ܠܟܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.29",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "John 11:29",
      "text": "ܘܡܪܝܡ ܟܕ ܫܡܥܬ ܩܡܬ ܥܓܠ ܘܐܬܝܐ ܗܘܬ ܠܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.30",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "John 11:30",
      "text": "ܗܘ ܕܝܢ ܝܫܘܥ ܠܐ ܥܕܟܝܠ ܐܬܐ ܗܘܐ ܠܩܪܝܬܐ ܐܠܐ ܒܗ ܗܘܐ ܒܗܝ ܕܘܟܬܐ ܕܐܪܥܬܗ ܡܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.31",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "John 11:31",
      "text": "ܐܦ ܗܢܘܢ ܕܝܢ ܝܗܘܕܝܐ ܕܐܝܬ ܗܘܘ ܥܡܗ ܒܒܝܬܐ ܕܡܒܝܐܝܢ ܗܘܘ ܠܗ ܕܚܙܘ ܠܡܪܝܡ ܕܥܓܠ ܩܡܬ ܢܦܩܬ ܐܙܠܘ ܠܗܘܢ ܒܬܪܗ ܤܒܪܘ ܓܝܪ ܕܠܩܒܪܐ ܐܙܠܐ ܠܡܒܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.32",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 32,
      "referenceLabel": "John 11:32",
      "text": "ܗܝ ܕܝܢ ܡܪܝܡ ܟܕ ܐܬܬ ܐܝܟܐ ܕܐܝܬܘܗܝ ܗܘܐ ܝܫܘܥ ܘܚܙܬܗ ܢܦܠܬ ܥܠ ܪܓܠܘܗܝ ܘܐܡܪܐ ܠܗ ܐܠܘ ܬܢܢ ܗܘܝܬ ܡܪܝ ܠܐ ܡܐܬ ܗܘܐ ܐܚܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.33",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 33,
      "referenceLabel": "John 11:33",
      "text": "ܝܫܘܥ ܕܝܢ ܟܕ ܚܙܗ ܕܒܟܝܐ ܘܠܝܗܘܕܝܐ ܗܢܘܢ ܕܐܬܘ ܥܡܗ ܕܒܟܝܢ ܐܬܥܙܙ ܒܪܘܚܗ ܘܐܙܝܥ ܢܦܫܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.34",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 34,
      "referenceLabel": "John 11:34",
      "text": "ܘܐܡܪ ܐܝܟܐ ܤܡܬܘܢܝܗܝ ܘܐܡܪܝܢ ܠܗ ܡܪܢ ܬܐ ܚܙܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.35",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 35,
      "referenceLabel": "John 11:35",
      "text": "ܘܐܬܝܢ ܗܘܝ ܕܡܥܘܗܝ ܕܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.36",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 36,
      "referenceLabel": "John 11:36",
      "text": "ܘܐܡܪܝܢ ܗܘܘ ܝܗܘܕܝܐ ܚܙܘ ܟܡܐ ܪܚܡ ܗܘܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.37",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 37,
      "referenceLabel": "John 11:37",
      "text": "ܐܢܫܝܢ ܕܝܢ ܡܢܗܘܢ ܐܡܪܘ ܠܐ ܡܫܟܚ ܗܘܐ ܗܢܐ ܕܦܬܚ ܥܝܢܘܗܝ ܕܗܘ ܤܡܝܐ ܢܥܒܕ ܕܐܦ ܗܢܐ ܠܐ ܢܡܘܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.38",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 38,
      "referenceLabel": "John 11:38",
      "text": "ܝܫܘܥ ܕܝܢ ܟܕ ܡܬܥܙܙ ܒܝܢܘܗܝ ܘܠܗ ܐܬܐ ܠܒܝܬ ܩܒܘܪܐ ܘܗܘ ܒܝܬ ܩܒܘܪܐ ܐܝܬܘܗܝ ܗܘܐ ܡܥܪܬܐ ܘܟܐܦܐ ܤܝܡܐ ܗܘܬ ܥܠ ܬܪܥܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.39",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 39,
      "referenceLabel": "John 11:39",
      "text": "ܘܐܡܪ ܝܫܘܥ ܫܩܘܠܘ ܟܐܦܐ ܗܕܐ ܐܡܪܐ ܠܗ ܡܪܬܐ ܚܬܗ ܕܗܘ ܡܝܬܐ ܡܪܝ ܡܢ ܟܕܘ ܤܪܝ ܠܗ ܐܪܒܥܐ ܠܗ ܓܝܪ ܝܘܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:john.11.40",
      "translationId": "peshitta",
      "bookSlug": "john",
      "chapterNumber": 11,
      "verseNumber": 40,
