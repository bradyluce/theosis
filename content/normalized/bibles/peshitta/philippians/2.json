{
  "chapter": {
    "id": "peshitta:philippians.2",
    "translationId": "peshitta",
    "bookSlug": "philippians",
    "chapterNumber": 2,
    "referenceLabel": "Philippians 2",
    "summary": "Source text for Philippians 2 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:philippians.2.1",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Philippians 2:1",
      "text": "ܐܢ ܐܝܬ ܠܟܘܢ ܗܟܝܠ ܒܘܝܐܐ ܒܡܫܝܚܐ ܘܐܢ ܡܡܠܐ ܒܠܒܐ ܒܚܘܒܐ ܘܐܢ ܫܘܬܦܘܬܐ ܕܪܘܚܐ ܘܐܢ ܪܘܚܦܐ ܘܪܚܡܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:philippians.2.2",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Philippians 2:2",
      "text": "ܫܠܡܘ ܚܕܘܬܝ ܕܚܕ ܪܥܝܢܐ ܢܗܘܐ ܠܟܘܢ ܘܚܕ ܚܘܒܐ ܘܚܕܐ ܢܦܫ ܘܚܕܐ ܬܪܥܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.3",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Philippians 2:3",
      "text": "ܘܡܕܡ ܒܚܪܝܢܐ ܐܘ ܒܬܫܒܘܚܬܐ ܤܪܝܩܬܐ ܠܐ ܬܥܒܕܘܢ ܐܠܐ ܒܡܟܝܟܘܬ ܪܥܝܢܐ ܟܠܢܫ ܠܚܒܪܗ ܐܝܟ ܕܡܝܬܪ ܡܢܗ ܢܚܫܘܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.4",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Philippians 2:4",
      "text": "ܘܠܐ ܐܢܫ ܕܢܦܫܗ ܢܐܨܦ ܐܠܐ ܟܠܢܫ ܐܦ ܕܚܒܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.5",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Philippians 2:5",
      "text": "ܘܗܕܐ ܐܬܪܥܘ ܒܢܦܫܟܘܢ ܗܝ ܕܐܦ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.6",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Philippians 2:6",
      "text": "ܗܘ ܕܟܕ ܐܝܬܘܗܝ ܒܕܡܘܬܐ ܕܐܠܗܐ ܠܐ ܗܘܐ ܚܛܘܦܝܐ ܚܫܒܗ ܗܕܐ ܕܐܝܬܘܗܝ ܦܚܡܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.7",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Philippians 2:7",
      "text": "ܐܠܐ ܢܦܫܗ ܤܪܩ ܘܕܡܘܬܐ ܕܥܒܕܐ ܢܤܒ ܘܗܘܐ ܒܕܡܘܬܐ ܕܒܢܝܢܫܐ ܘܒܐܤܟܡܐ ܐܫܬܟܚ ܐܝܟ ܒܪܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.8",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Philippians 2:8",
      "text": "ܘܡܟܟ ܢܦܫܗ ܘܐܫܬܡܥ ܥܕܡܐ ܠܡܘܬܐ ܡܘܬܐ ܕܝܢ ܕܙܩܝܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.9",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Philippians 2:9",
      "text": "ܡܛܠ ܗܢܐ ܐܦ ܐܠܗܐ ܐܤܓܝ ܪܡܪܡܗ ܘܝܗܒ ܠܗ ܫܡܐ ܕܡܝܬܪ ܡܢ ܟܠ ܫܡܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.10",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Philippians 2:10",
      "text": "ܕܒܫܡܗ ܕܝܫܘܥ ܟܠ ܒܪܘܟ ܬܟܘܦ ܕܒܫܡܝܐ ܘܒܐܪܥܐ ܘܕܠܬܚܬ ܡܢ ܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.11",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Philippians 2:11",
      "text": "ܘܟܠ ܠܫܢ ܢܘܕܐ ܕܡܪܝܐ ܗܘ ܝܫܘܥ ܡܫܝܚܐ ܠܫܘܒܚܐ ܕܐܠܗܐ ܐܒܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.12",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Philippians 2:12",
      "text": "ܡܟܝܠ ܚܒܝܒܝ ܐܝܟܢܐ ܕܒܟܠܙܒܢ ܐܫܬܡܥܬܘܢ ܠܐ ܟܕ ܩܪܝܒ ܐܢܐ ܠܟܘܢ ܒܠܚܘܕ ܐܠܐ ܗܫܐ ܕܪܚܝܩ ܐܢܐ ܡܢܟܘܢ ܝܬܝܪܐܝܬ ܒܕܚܠܬܐ ܘܒܪܬܝܬܐ ܦܠܘܚܘ ܦܘܠܚܢܐ ܕܚܝܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.13",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Philippians 2:13",
      "text": "ܐܠܗܐ ܗܘ ܓܝܪ ܡܚܦܛ ܒܟܘܢ ܐܦ ܠܡܨܒܐ ܐܦ ܠܡܤܥܪ ܗܘ ܡܕܡ ܕܨܒܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.14",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Philippians 2:14",
      "text": "ܟܠܡܕܡ ܗܘܝܬܘܢ ܥܒܕܝܢ ܕܠܐ ܪܛܢܐ ܘܕܠܐ ܦܘܠܓ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.15",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Philippians 2:15",
      "text": "ܕܬܗܘܘܢ ܬܡܝܡܐ ܘܕܠܐ ܡܘܡ ܐܝܟ ܒܢܝܐ ܕܟܝܐ ܕܐܠܗܐ ܕܥܡܪܝܢ ܒܕܪܐ ܥܤܩܐ ܘܡܥܩܡܐ ܘܐܬܚܙܘ ܒܝܢܬܗܘܢ ܐܝܟ ܢܗܝܪܐ ܒܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.16",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Philippians 2:16",
      "text": "ܕܐܝܬܝܟܘܢ ܠܗܘܢ ܒܕܘܟܬ ܚܝܐ ܠܫܘܒܗܪܝ ܕܝܠܝ ܒܝܘܡܗ ܕܡܫܝܚܐ ܕܠܐ ܗܘܐ ܐܝܩܐ ܪܗܛܬ ܘܠܐ ܤܪܝܩܐܝܬ ܥܡܠܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.17",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Philippians 2:17",
      "text": "ܐܠܐ ܐܦܢ ܡܬܢܩܐ ܐܢܐ ܥܠ ܕܒܚܬܐ ܘܬܫܡܫܬܐ ܕܗܝܡܢܘܬܟܘܢ ܚܕܐ ܐܢܐ ܘܪܘܙ ܐܢܐ ܥܡ ܟܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.18",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Philippians 2:18",
      "text": "ܗܟܢܐ ܐܦ ܐܢܬܘܢ ܚܕܘ ܘܪܘܙܘ ܥܡܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.19",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Philippians 2:19",
      "text": "ܡܤܒܪ ܐܢܐ ܕܝܢ ܒܡܪܢ ܝܫܘܥ ܕܐܫܕܪ ܠܘܬܟܘܢ ܠܛܝܡܬܐܘܤ ܒܥܓܠ ܕܐܦ ܠܝ ܢܗܘܐ ܠܝ ܢܝܚܐ ܟܕ ܐܠܦ ܡܛܠܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.20",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Philippians 2:20",
      "text": "ܠܝܬ ܠܝ ܓܝܪ ܐܚܪܝܢ ܗܪܟܐ ܕܐܝܟ ܢܦܫܝ ܗܘ ܕܐܟܝܦܐܝܬ ܝܨܦ ܕܝܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.21",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Philippians 2:21",
      "text": "ܟܠܗܘܢ ܓܝܪ ܕܢܦܫܗܘܢ ܗܘ ܒܥܝܢ ܘܠܐ ܕܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.22",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Philippians 2:22",
      "text": "ܒܘܩܝܗ ܕܝܢ ܕܗܢܐ ܝܕܥܝܬܘܢ ܕܐܝܟ ܒܪܐ ܥܡ ܐܒܘܗܝ ܗܟܢܐ ܦܠܚ ܥܡܝ ܒܤܒܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.23",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Philippians 2:23",
      "text": "ܠܗܢܐ ܡܤܒܪ ܐܢܐ ܕܐܫܕܪ ܠܘܬܟܘܢ ܒܥܓܠ ܡܐ ܕܚܙܝܬ ܡܐ ܕܠܘܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.24",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "Philippians 2:24",
      "text": "ܘܬܟܝܠ ܐܢܐ ܥܠ ܡܪܝ ܕܐܦ ܐܢܐ ܒܥܓܠ ܐܬܐ ܐܢܐ ܠܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.25",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "Philippians 2:25",
      "text": "ܗܫܐ ܕܝܢ ܐܠܨܬܢܝ ܨܒܘܬܐ ܕܐܫܕܪ ܠܘܬܟܘܢ ܠܐܦܦܪܘܕܝܛܤ ܐܚܐ ܕܐܝܬܘܗܝ ܡܥܕܪܢܐ ܘܦܠܚܐ ܕܥܡܝ ܕܝܠܟܘܢ ܕܝܢ ܫܠܝܚܐ ܘܡܫܡܫܢܐ ܕܚܫܚܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.26",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "Philippians 2:26",
      "text": "ܡܛܠ ܕܤܘܐ ܗܘܐ ܠܡܚܙܐ ܠܟܠܟܘܢ ܘܡܥܩ ܗܘܐ ܕܝܕܥ ܕܫܡܥܬܘܢ ܕܐܬܟܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.27",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "Philippians 2:27",
      "text": "ܐܦ ܐܬܟܪܗ ܓܝܪ ܥܕܡܐ ܠܡܘܬܐ ܐܠܐ ܐܠܗܐ ܪܚܡ ܥܠܘܗܝ ܠܐ ܗܘܐ ܕܝܢ ܥܠܘܗܝ ܒܠܚܘܕ ܐܠܐ ܐܦ ܥܠܝ ܕܠܐ ܬܗܘܐ ܠܝ ܥܩܐ ܥܠ ܥܩܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.28",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "Philippians 2:28",
      "text": "ܚܦܝܛܐܝܬ ܗܟܝܠ ܫܕܪܬܗ ܠܘܬܟܘܢ ܕܟܕ ܬܚܙܘܢܝܗܝ ܬܘܒ ܬܚܕܘܢ ܘܠܝ ܩܠܝܠ ܢܗܘܐ ܢܦܐܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.29",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 29,
      "referenceLabel": "Philippians 2:29",
      "text": "ܩܒܠܘܗܝ ܗܟܝܠ ܒܡܪܝܐ ܒܟܠ ܚܕܘܐ ܘܠܐܝܠܝܢ ܕܗܟܢܐ ܐܢܘܢ ܒܐܝܩܪܐ ܐܚܘܕܘ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.2.30",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 30,
      "referenceLabel": "Philippians 2:30",
      "text": "ܡܛܠ ܥܒܕܐ ܓܝܪ ܕܡܫܝܚܐ ܥܕܡܐ ܠܡܘܬܐ ܡܛܝ ܘܒܤܪ ܥܠ ܢܦܫܗ ܕܢܡܠܐ ܡܕܡ ܕܒܨܪܬܘܢ ܗܘܝܬܘܢ ܒܬܫܡܫܬܐ ܕܠܘܬܝ ܀",
      "paragraphStart": false
    }
  ]
}
