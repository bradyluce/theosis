{
  "chapter": {
    "id": "peshitta:philippians.1",
    "translationId": "peshitta",
    "bookSlug": "philippians",
    "chapterNumber": 1,
    "referenceLabel": "Philippians 1",
    "summary": "Source text for Philippians 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:philippians.1.1",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Philippians 1:1",
      "text": "ܦܘܠܘܤ ܘܛܝܡܬܐܘܤ ܥܒܕܐ ܕܝܫܘܥ ܡܫܝܚܐ ܠܟܠܗܘܢ ܩܕܝܫܐ ܕܒܝܫܘܥ ܡܫܝܚܐ ܕܐܝܬ ܒܦܝܠܝܦܘܤ ܥܡ ܩܫܝܫܐ ܘܡܫܡܫܢܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:philippians.1.2",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Philippians 1:2",
      "text": "ܛܝܒܘܬܐ ܥܡܟܘܢ ܘܫܠܡܐ ܡܢ ܐܠܗܐ ܐܒܘܢ ܘܡܢ ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.3",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Philippians 1:3",
      "text": "ܡܘܕܐ ܐܢܐ ܠܐܠܗܝ ܥܠ ܥܘܗܕܢܟܘܢ ܐܡܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.4",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Philippians 1:4",
      "text": "ܕܒܟܠ ܒܥܘܬܝ ܕܥܠ ܐܦܝܟܘܢ ܘܟܕ ܚܕܐ ܐܢܐ ܡܬܟܫܦ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.5",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Philippians 1:5",
      "text": "ܥܠ ܫܘܬܦܘܬܟܘܢ ܕܒܐܘܢܓܠܝܘܢ ܡܢ ܝܘܡܐ ܩܕܡܝܐ ܘܥܕܡܐ ܠܗܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.6",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Philippians 1:6",
      "text": "ܡܛܠ ܕܬܟܝܠ ܐܢܐ ܥܠ ܗܕܐ ܕܗܘ ܡܢ ܕܫܪܝ ܒܟܘܢ ܥܒܕܐ ܛܒܐ ܗܘ ܢܫܠܡ ܥܕܡܐ ܠܝܘܡܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.7",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Philippians 1:7",
      "text": "ܗܟܢܐ ܓܝܪ ܙܕܩ ܠܝ ܠܡܬܪܥܝܘ ܥܠ ܟܠܟܘܢ ܡܛܠ ܕܒܠܒܝ ܤܝܡܝܢ ܐܢܬܘܢ ܘܒܐܤܘܪܝ ܘܒܡܦܩ ܒܪܘܚܝ ܕܥܠ ܫܪܪܗ ܕܐܘܢܓܠܝܘܢ ܕܫܘܬܦܝ ܐܢܬܘܢ ܒܛܝܒܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.8",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Philippians 1:8",
      "text": "ܤܗܕ ܗܘ ܠܝ ܓܝܪ ܐܠܗܐ ܕܐܝܟܢܐ ܡܚܒ ܐܢܐ ܠܟܘܢ ܒܪܚܡܘܗܝ ܕܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.9",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Philippians 1:9",
      "text": "ܘܗܕܐ ܡܨܠܐ ܐܢܐ ܕܬܘܒ ܢܤܓܐ ܘܢܬܝܬܪ ܚܘܒܟܘܢ ܒܝܕܥܬܐ ܘܒܟܠ ܤܘܟܠ ܕܪܘܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.10",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Philippians 1:10",
      "text": "ܕܬܗܘܘܢ ܦܪܫܝܢ ܐܝܠܝܢ ܕܥܗܢܢ ܘܬܗܘܘܢ ܕܟܝܢ ܕܠܐ ܬܘܩܠܐ ܒܝܘܡܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.11",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Philippians 1:11",
      "text": "ܘܡܠܝܢ ܦܐܪܐ ܕܙܕܝܩܘܬܐ ܕܒܝܫܘܥ ܡܫܝܚܐ ܠܫܘܒܚܐ ܘܠܐܝܩܪܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.12",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Philippians 1:12",
      "text": "ܨܒܐ ܐܢܐ ܕܝܢ ܕܬܕܥܘܢ ܐܚܝ ܕܤܘܥܪܢܝ ܕܝܠܝ ܝܬܝܪܐܝܬ ܐܬܐ ܠܩܕܡܘܗܝ ܒܐܘܢܓܠܝܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.13",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Philippians 1:13",
      "text": "ܗܟܢܐ ܕܐܦ ܐܤܘܪܝ ܐܬܓܠܝܘ ܒܡܫܝܚܐ ܒܦܪܛܘܪܝܢ ܟܠܗ ܘܠܫܪܟܐ ܕܟܠܢܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.14",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Philippians 1:14",
      "text": "ܘܤܘܓܐܐ ܕܐܚܐ ܕܒܡܪܢ ܐܬܬܟܠܘ ܥܠ ܐܤܘܪܝ ܘܐܫܝܚܘ ܝܬܝܪܐܝܬ ܕܠܐ ܕܚܠܐ ܠܡܡܠܠܘ ܡܠܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.15",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Philippians 1:15",
      "text": "ܘܐܢܫ ܐܢܫ ܡܢ ܚܤܡܐ ܘܚܪܝܢܐ ܐܢܫ ܐܢܫ ܕܝܢ ܒܨܒܝܢܐ ܛܒܐ ܘܒܚܘܒܐ ܠܡܫܝܚܐ ܡܟܪܙܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.16",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Philippians 1:16",
      "text": "ܡܛܠ ܕܝܕܥܝܢ ܕܠܡܦܩ ܒܪܘܚܐ ܕܐܘܢܓܠܝܘܢ ܤܝܡ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.17",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Philippians 1:17",
      "text": "ܗܢܘܢ ܕܝܢ ܕܒܚܪܝܢܐ ܠܡܫܝܚܐ ܡܟܪܙܝܢ ܠܐ ܗܘܐ ܕܟܝܐܝܬ ܐܠܐ ܕܤܒܪܝܢ ܕܡܘܤܦܝܢ ܐܘܠܨܢܐ ܠܐܤܘܪܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.18",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Philippians 1:18",
      "text": "ܘܒܗܕܐ ܚܕܝܬ ܘܚܕܐ ܐܢܐ ܕܒܟܠ ܦܪܘܤ ܐܢ ܒܥܠܬܐ ܘܐܢ ܒܩܘܫܬܐ ܡܫܝܚܐ ܢܬܟܪܙ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.19",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Philippians 1:19",
      "text": "ܝܕܥ ܐܢܐ ܓܝܪ ܕܗܠܝܢ ܠܚܝܐ ܡܫܬܟܚܢ ܠܝ ܒܒܥܘܬܟܘܢ ܘܒܡܘܗܒܬܐ ܕܪܘܚܐ ܕܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.20",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Philippians 1:20",
      "text": "ܐܝܟܢܐ ܕܡܤܒܪ ܐܢܐ ܘܡܤܟܐ ܐܢܐ ܕܒܡܕܡ ܠܐ ܐܒܗܬ ܐܠܐ ܒܓܠܝܘܬ ܐܦܐ ܐܝܟ ܕܒܟܠܙܒܢ ܐܦ ܗܫܐ ܢܬܪܘܪܒ ܡܫܝܚܐ ܒܦܓܪܝ ܐܢ ܒܚܝܐ ܘܐܢ ܒܡܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.21",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Philippians 1:21",
      "text": "ܚܝܝ ܓܝܪ ܕܝܠܝ ܡܫܝܚܐ ܗܘ ܘܐܢ ܐܡܘܬ ܝܘܬܪܢܐ ܗܘ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.22",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Philippians 1:22",
      "text": "ܐܢ ܕܝܢ ܐܦ ܒܗܠܝܢ ܚܝܐ ܕܒܤܪܐ ܦܐܪܐ ܐܝܬ ܠܝ ܒܥܒܕܝ ܠܐ ܝܕܥ ܐܢܐ ܡܢܐ ܐܓܒܐ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.23",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Philippians 1:23",
      "text": "ܐܠܨܢ ܠܝ ܓܝܪ ܬܪܬܝܗܝܢ ܠܡܦܛܪ ܪܓܝܓ ܐܢܐ ܕܥܡ ܡܫܝܚܐ ܐܗܘܐ ܘܗܕܐ ܛܒ ܦܩܚܐ ܗܘܬ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.24",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Philippians 1:24",
      "text": "ܐܠܐ ܐܦ ܕܐܩܘܐ ܒܦܓܪܝ ܐܠܨܐ ܠܝ ܨܒܘܬܐ ܡܛܠܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.25",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Philippians 1:25",
      "text": "ܘܗܕܐ ܬܟܝܠܐܝܬ ܝܕܥ ܐܢܐ ܕܦܐܫ ܐܢܐ ܘܡܩܘܐ ܐܢܐ ܠܚܕܘܬܐ ܕܝܠܟܘܢ ܘܠܬܪܒܝܬܐ ܕܗܝܡܢܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.26",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "Philippians 1:26",
      "text": "ܕܟܕ ܐܬܐ ܬܘܒ ܠܘܬܟܘܢ ܢܬܝܬܪ ܒܝ ܫܘܒܗܪܟܘܢ ܕܒܝܫܘܥ ܡܫܝܚܐ ܒܠܚܘܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.27",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "Philippians 1:27",
      "text": "ܐܝܟܢܐ ܕܝܐܐ ܠܤܒܪܬܗ ܕܡܫܝܚܐ ܗܘܝܬܘܢ ܡܬܕܒܪܝܢ ܕܐܢ ܐܬܐ ܐܚܙܝܟܘܢ ܘܐܢ ܦܪܝܩ ܐܢܐ ܐܫܡܥ ܥܠܝܟܘܢ ܕܩܝܡܝܢ ܐܢܬܘܢ ܒܚܕܐ ܪܘܚ ܘܒܚܕܐ ܢܦܫ ܘܡܬܢܨܚܝܬܘܢ ܐܟܚܕ ܒܗܝܡܢܘܬܐ ܕܐܘܢܓܠܝܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.28",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "Philippians 1:28",
      "text": "ܘܒܡܕܡ ܠܐ ܡܬܬܙܝܥܝܢ ܐܢܬܘܢ ܡܢ ܗܢܘܢ ܕܩܝܡܝܢ ܠܩܘܒܠܢ ܠܬܚܘܝܬܐ ܕܐܒܕܢܗܘܢ ܘܠܚܝܐ ܕܝܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.29",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "Philippians 1:29",
      "text": "ܘܗܕܐ ܡܢ ܐܠܗܐ ܗܘ ܐܬܝܗܒܬ ܠܟܘܢ ܕܠܐ ܒܠܚܘܕ ܡܗܝܡܢܘ ܬܗܝܡܢܘܢ ܒܗ ܒܡܫܝܚܐ ܐܠܐ ܐܦ ܕܥܠ ܐܦܘܗܝ ܬܚܫܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.1.30",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "Philippians 1:30",
      "text": "ܘܬܤܝܒܪܘܢ ܐܓܘܢܐ ܐܝܟ ܗܘ ܕܚܙܝܬܘܢ ܒܝ ܘܗܫܐ ܫܡܥܝܬܘܢ ܥܠܝ ܀",
      "paragraphStart": false
    }
  ]
}
