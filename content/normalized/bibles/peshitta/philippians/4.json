    "bookSlug": "philippians",
    "chapterNumber": 4,
    "referenceLabel": "Philippians 4",
    "summary": "Source text for Philippians 4 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:philippians.4.1",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Philippians 4:1",
      "text": "ܡܟܝܠ ܐܚܝ ܚܒܝܒܐ ܘܪܚܝܡܐ ܘܚܕܘܬܝ ܘܟܠܝܠܝ ܗܟܢܐ ܩܘܡܘ ܒܡܪܢ ܚܒܝܒܝ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:philippians.4.2",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Philippians 4:2",
      "text": "ܡܢ ܐܘܗܕܝܐ ܒܥܐ ܐܢܐ ܘܡܢ ܤܘܢܛܝܟܐ ܕܚܕ ܪܥܝܢܐ ܢܗܘܐ ܠܗܝܢ ܒܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.3",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Philippians 4:3",
      "text": "ܐܦ ܡܢܟ ܒܥܐ ܐܢܐ ܒܪ ܙܘܓܝ ܫܪܝܪܐ ܕܬܗܘܐ ܡܥܕܪ ܠܗܝܢ ܕܗܢܝܢ ܠܐܝ ܥܡܝ ܒܐܘܢܓܠܝܘܢ ܥܡ ܩܠܡܝܤ ܘܥܡ ܫܪܟܐ ܕܡܥܕܪܢܝ ܗܢܘܢ ܕܫܡܗܝܗܘܢ ܟܬܝܒܝܢ ܒܟܬܒܐ ܕܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.4",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Philippians 4:4",
      "text": "ܚܕܘ ܒܡܪܢ ܒܟܠܙܒܢ ܘܬܘܒ ܐܡܪ ܐܢܐ ܚܕܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.5",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Philippians 4:5",
      "text": "ܘܡܟܝܟܘܬܟܘܢ ܬܬܝܕܥ ܠܘܬ ܟܠܢܫ ܡܪܢ ܩܪܝܒ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.6",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Philippians 4:6",
      "text": "ܕܡܕܡ ܠܐ ܬܐܨܦܘܢ ܐܠܐ ܒܟܠܙܒܢ ܒܨܠܘܬܐ ܘܒܒܥܘܬܐ ܘܒܬܘܕܝܬܐ ܫܐܠܬܟܘܢ ܢܬܝܕܥܢ ܩܕܡ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.7",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Philippians 4:7",
      "text": "ܘܫܠܡܗ ܕܐܠܗܐ ܗܘ ܕܪܒ ܡܢ ܟܠ ܡܕܥ ܢܢܛܪ ܠܒܘܬܟܘܢ ܘܡܕܥܝܟܘܢ ܒܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.8",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Philippians 4:8",
      "text": "ܡܟܝܠ ܐܚܝ ܐܝܠܝܢ ܕܫܪܝܪܢ ܘܐܝܠܝܢ ܕܢܟܦܢ ܘܐܝܠܝܢ ܕܟܐܢܢ ܘܐܝܠܝܢ ܕܕܟܝܢ ܘܐܝܠܝܢ ܕܪܚܝܡܢ ܘܐܝܠܝܢ ܕܫܒܝܚܢ ܘܐܝܠܝܢ ܥܒܕܐ ܕܫܘܒܚܐ ܘܕܩܘܠܤܐ ܗܠܝܢ ܐܬܪܥܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.9",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Philippians 4:9",
      "text": "ܗܠܝܢ ܕܝܠܦܬܘܢ ܘܩܒܠܬܘܢ ܘܫܡܥܬܘܢ ܘܚܙܝܬܘܢ ܒܝ ܗܠܝܢ ܤܥܘܪܘ ܘܐܠܗܐ ܕܫܠܡܐ ܢܗܘܐ ܥܡܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.10",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Philippians 4:10",
      "text": "ܪܘܪܒܐܝܬ ܕܝܢ ܚܕܝܬ ܒܡܪܢ ܕܐܩܦܬܘܢ ܠܡܐܨܦ ܕܝܠܝ ܐܝܟܢܐ ܕܐܦ ܝܨܦܝܢ ܗܘܝܬܘܢ ܐܠܐ ܠܐ ܤܦܝܩܝܢ ܗܘܝܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.11",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Philippians 4:11",
      "text": "ܠܐ ܗܘܐ ܕܝܢ ܡܛܠ ܕܚܤܪ ܠܝ ܐܡܪ ܐܢܐ ܐܢܐ ܓܝܪ ܝܠܦܬ ܕܢܗܘܐ ܤܦܩ ܠܝ ܗܘ ܡܕܡ ܕܐܝܬ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.12",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Philippians 4:12",
      "text": "ܝܕܥ ܐܢܐ ܕܐܬܡܟܟ ܝܕܥ ܐܢܐ ܗܘ ܐܦ ܕܐܬܝܬܪ ܒܟܠ ܘܒܟܠ ܡܕܡ ܡܕܪܫ ܐܢܐ ܐܦ ܒܤܒܥܐ ܐܦ ܒܟܦܢܐ ܒܡܫܪܬܚܘܬܐ ܘܒܚܤܝܪܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.13",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Philippians 4:13",
      "text": "ܕܟܠ ܡܕܡ ܡܨܐ ܐܢܐ ܚܝܠܐ ܒܡܫܝܚܐ ܕܡܚܝܠ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.14",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Philippians 4:14",
      "text": "ܒܪܡ ܫܦܝܪ ܥܒܕܬܘܢ ܕܐܫܬܘܬܦܬܘܢ ܠܐܘܠܨܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.15",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Philippians 4:15",
      "text": "ܝܕܥܝܢ ܐܢܬܘܢ ܕܝܢ ܐܦ ܐܢܬܘܢ ܦܝܠܝܦܤܝܐ ܕܒܫܘܪܝܐ ܕܤܒܪܬܐ ܟܕ ܢܦܩܬ ܡܢ ܡܩܕܘܢܝܐ ܐܦܠܐ ܚܕܐ ܡܢ ܥܕܬܐ ܐܫܬܘܬܦ ܠܝ ܒܚܘܫܒܢ ܡܤܒܐ ܘܡܬܠܐ ܐܠܐ ܐܢܬܘܢ ܒܠܚܘܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.16",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Philippians 4:16",
      "text": "ܕܐܦ ܠܬܤܠܘܢܝܩܐ ܚܕܐ ܙܒܢ ܘܬܪܬܝܢ ܚܫܚܬܝ ܫܕܪܬܘܢ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.17",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Philippians 4:17",
      "text": "ܠܘ ܕܡܘܗܒܬܐ ܒܥܐ ܐܢܐ ܐܠܐ ܒܥܐ ܐܢܐ ܕܦܐܪܐ ܢܤܓܘܢ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.18",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Philippians 4:18",
      "text": "ܟܠܡܕܡ ܩܒܠܬ ܘܝܬܝܪ ܠܝ ܘܡܠܐ ܐܢܐ ܘܢܤܒܬ ܟܠ ܕܫܕܪܬܘܢ ܠܝ ܒܝܕ ܐܦܦܪܘܕܝܛܤ ܪܝܚܐ ܒܤܝܡܐ ܘܕܒܚܐ ܡܩܒܠܐ ܕܫܦܪ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.19",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Philippians 4:19",
      "text": "ܘܐܠܗܝ ܢܡܠܐ ܟܠܗ ܤܢܝܩܘܬܟܘܢ ܐܝܟ ܥܘܬܪܗ ܒܫܘܒܚܐ ܕܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.20",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Philippians 4:20",
      "text": "ܠܐܠܗܐ ܕܝܢ ܐܒܘܢ ܫܘܒܚܐ ܘܐܝܩܪܐ ܠܥܠܡ ܥܠܡܝܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.21",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Philippians 4:21",
      "text": "ܫܐܠܘ ܒܫܠܡܐ ܕܟܠܗܘܢ ܩܕܝܫܐ ܕܒܝܫܘܥ ܡܫܝܚܐ ܫܐܠܝܢ ܒܫܠܡܟܘܢ ܐܚܐ ܕܥܡܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.22",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Philippians 4:22",
      "text": "ܫܐܠܝܢ ܒܫܠܡܟܘܢ ܟܠܗܘܢ ܩܕܝܫܐ ܝܬܝܪܐܝܬ ܗܠܝܢ ܕܡܢ ܒܝܬܗ ܕܩܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.4.23",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Philippians 4:23",
      "text": "ܛܝܒܘܬܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܥܡ ܟܠܟܘܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
