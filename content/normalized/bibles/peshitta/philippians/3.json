    "referenceLabel": "Philippians 3",
    "summary": "Source text for Philippians 3 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:philippians.3.1",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Philippians 3:1",
      "text": "ܡܟܝܠ ܐܚܝ ܚܕܘ ܒܡܪܢ ܗܢܝܢ ܟܕ ܗܢܝܢ ܕܐܟܬܘܒ ܠܟܘܢ ܠܐ ܡܐܢܐ ܠܝ ܡܛܠ ܕܠܟܘܢ ܡܙܗܪܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:philippians.3.2",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Philippians 3:2",
      "text": "ܐܙܕܗܪܘ ܡܢ ܟܠܒܐ ܐܙܕܗܪܘ ܡܢ ܦܥܠܐ ܒܝܫܐ ܐܙܕܗܪܘ ܡܢ ܦܤܩ ܒܤܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.3.3",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Philippians 3:3",
      "text": "ܓܙܘܪܬܐ ܓܝܪ ܚܢܢ ܐܝܬܝܢ ܐܝܠܝܢ ܕܦܠܚܝܢܢ ܠܐܠܗܐ ܒܪܘܚܐ ܘܡܫܬܒܗܪܝܢܢ ܒܝܫܘܥ ܡܫܝܚܐ ܘܠܐ ܬܟܝܠܝܢܢ ܥܠ ܒܤܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.3.4",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Philippians 3:4",
      "text": "ܟܕ ܠܝ ܐܝܬ ܗܘܐ ܠܝ ܬܘܟܠܢܐ ܐܦ ܥܠ ܒܤܪܐ ܐܢ ܓܝܪ ܐܢܫ ܤܒܪ ܕܬܘܟܠܢܗ ܒܒܤܪܐ ܗܘ ܝܬܝܪ ܡܢܗ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.3.5",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Philippians 3:5",
      "text": "ܓܙܝܪܐ ܒܪ ܬܡܢܝܐ ܝܘܡܝܢ ܡܢ ܛܘܗܡܐ ܕܐܝܤܪܝܠ ܡܢ ܫܒܛܐ ܕܒܢܝܡܝܢ ܥܒܪܝܐ ܒܪ ܥܒܪܝܐ ܒܢܡܘܤܐ ܦܪܝܫܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.3.6",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Philippians 3:6",
      "text": "ܒܛܢܢܐ ܪܕܘܦܐ ܕܥܕܬܐ ܘܒܙܕܝܩܘܬܐ ܕܢܡܘܤܐ ܕܠܐ ܪܫܝܢ ܗܘܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.3.7",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Philippians 3:7",
      "text": "ܐܠܐ ܗܠܝܢ ܕܝܘܬܪܢܐ ܗܘܝ ܠܝ ܚܘܤܪܢܐ ܚܫܒܬ ܐܢܝܢ ܡܛܠ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.3.8",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Philippians 3:8",
      "text": "ܐܦ ܚܫܒ ܐܢܐ ܠܗܝܢ ܟܠܗܝܢ ܚܘܤܪܢܐ ܡܛܠ ܪܒܘܬܐ ܕܝܕܥܬܗ ܕܝܫܘܥ ܡܫܝܚܐ ܡܪܝ ܗܘ ܕܡܛܠܬܗ ܟܠܡܕܡ ܚܤܪܬ ܘܐܝܟ ܙܒܠܐ ܚܫܒܬ ܕܠܡܫܝܚܐ ܐܬܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.3.9",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Philippians 3:9",
      "text": "ܘܐܫܬܟܚ ܒܗ ܟܕ ܠܝܬ ܠܝ ܙܕܝܩܘܬܐ ܕܢܦܫܝ ܗܝ ܕܡܢ ܢܡܘܤܐ ܐܠܐ ܗܝ ܕܡܢ ܗܝܡܢܘܬܐ ܕܡܫܝܚܐ ܕܐܝܬܝܗ ܙܕܝܩܘܬܐ ܕܡܢ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.3.10",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Philippians 3:10",
      "text": "ܕܒܗ ܐܫܬܘܕܥ ܠܝܫܘܥ ܘܠܚܝܠܐ ܕܩܝܡܬܗ ܘܐܫܬܘܬܦ ܒܚܫܘܗܝ ܘܐܬܕܡܐ ܒܡܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.3.11",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Philippians 3:11",
      "text": "ܕܠܡܐ ܐܫܟܚ ܐܡܛܐ ܠܩܝܡܬܐ ܕܡܢ ܒܝܬ ܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.3.12",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Philippians 3:12",
      "text": "ܠܐ ܗܘܐ ܡܢ ܟܕܘ ܢܤܒܬ ܐܘ ܡܢ ܟܕܘ ܐܬܓܡܪܬ ܐܠܐ ܪܗܛ ܐܢܐ ܕܠܡܐ ܐܕܪܟ ܠܡܕܡ ܕܡܛܠܬܗ ܐܕܪܟܢܝ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.3.13",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Philippians 3:13",
      "text": "ܐܚܝ ܐܢܐ ܥܠ ܢܦܫܝ ܠܐ ܪܢܐ ܐܢܐ ܕܐܕܪܟܬ ܚܕܐ ܕܝܢ ܝܕܥ ܐܢܐ ܕܕܒܤܬܪܝ ܛܥܐ ܐܢܐ ܘܠܩܕܡܝ ܡܫܬܘܫܛ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.3.14",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Philippians 3:14",
      "text": "ܘܪܗܛ ܐܢܐ ܠܘܩܒܠ ܢܝܫܐ ܕܐܤܒ ܙܟܘܬܐ ܕܩܪܝܢܐ ܕܠܥܠ ܕܐܠܗܐ ܒܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.3.15",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Philippians 3:15",
      "text": "ܐܝܠܝܢ ܕܓܡܝܪܝܢ ܗܟܝܠ ܗܠܝܢ ܢܬܪܥܘܢ ܘܐܢ ܡܕܡ ܐܚܪܢܝܐܝܬ ܡܬܪܥܝܢ ܐܢܬܘܢ ܐܦ ܗܕܐ ܐܠܗܐ ܢܓܠܐ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.3.16",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Philippians 3:16",
      "text": "ܒܪܡ ܠܗܕܐ ܕܡܛܝܢ ܒܚܕ ܫܒܝܠܐ ܢܫܠܡ ܘܒܚܕܐ ܐܘܝܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.3.17",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Philippians 3:17",
      "text": "ܐܬܕܡܘ ܒܝ ܐܚܝ ܘܗܘܝܬܘܢ ܡܬܒܩܝܢ ܒܐܝܠܝܢ ܕܗܟܢܐ ܡܗܠܟܝܢ ܐܝܟ ܕܡܘܬܐ ܕܒܢ ܚܙܝܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.3.18",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Philippians 3:18",
      "text": "ܐܝܬ ܓܝܪ ܤܓܝܐܐ ܕܐܚܪܢܝܐܝܬ ܡܗܠܟܝܢ ܗܢܘܢ ܕܙܒܢܝܢ ܤܓܝܐܢ ܐܡܪܬ ܠܟܘܢ ܥܠܝܗܘܢ ܗܫܐ ܕܝܢ ܟܕ ܒܟܐ ܐܢܐ ܐܡܪ ܐܢܐ ܗܢܘܢ ܕܒܥܠܕܒܒܐ ܐܢܘܢ ܕܙܩܝܦܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.3.19",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Philippians 3:19",
      "text": "ܕܚܪܬܗܘܢ ܐܒܕܢܐ ܗܝ ܗܢܘܢ ܕܐܠܗܗܘܢ ܟܪܤܗܘܢ ܘܬܫܒܘܚܬܗܘܢ ܒܗܬܬܗܘܢ ܗܠܝܢ ܕܬܪܥܝܬܗܘܢ ܒܐܪܥܐ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.3.20",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Philippians 3:20",
      "text": "ܕܝܠܢ ܕܝܢ ܦܘܠܚܢܢ ܒܫܡܝܐ ܗܘ ܘܡܢ ܬܡܢ ܡܤܟܝܢܢ ܠܡܚܝܢܐ ܠܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:philippians.3.21",
      "translationId": "peshitta",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Philippians 3:21",
      "text": "ܕܗܘ ܢܚܠܦ ܦܓܪܐ ܕܡܘܟܟܢ ܕܢܗܘܐ ܒܕܡܘܬܐ ܕܦܓܪܐ ܕܫܘܒܚܗ ܐܝܟ ܚܝܠܗ ܪܒܐ ܗܘ ܕܒܗ ܟܠ ܐܫܬܥܒܕ ܠܗ ܀",
      "paragraphStart": false
    }
  ]
}
