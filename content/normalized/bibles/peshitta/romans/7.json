    "bookSlug": "romans",
    "chapterNumber": 7,
    "referenceLabel": "Romans 7",
    "summary": "Source text for Romans 7 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:romans.7.1",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Romans 7:1",
      "text": "ܐܘ ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܐܚܝ ܠܝܕܥܝ ܢܡܘܤܐ ܓܝܪ ܡܡܠܠ ܐܢܐ ܕܢܡܘܤܐ ܫܠܝܛ ܗܘ ܥܠ ܓܒܪܐ ܟܡܐ ܕܚܝ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:romans.7.2",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Romans 7:2",
      "text": "ܐܝܟ ܐܢܬܬܐ ܕܐܤܝܪܐ ܗܝ ܒܒܥܠܗ ܟܡܐ ܕܚܝ ܒܢܡܘܤܐ ܐܢ ܕܝܢ ܡܝܬ ܒܥܠܗ ܐܬܚܪܪܬ ܡܢ ܢܡܘܤܐ ܕܒܥܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.3",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Romans 7:3",
      "text": "ܐܢ ܕܝܢ ܟܕ ܚܝ ܒܥܠܗ ܬܩܦ ܠܓܒܪ ܐܚܪܝܢ ܗܘܬ ܠܗ ܓܝܪܬܐ ܐܢ ܕܝܢ ܢܡܘܬ ܒܥܠܗ ܐܬܚܪܪܬ ܡܢ ܢܡܘܤܐ ܘܠܐ ܐܝܬܝܗ ܓܝܪܬܐ ܐܢ ܬܗܘܐ ܠܓܒܪܐ ܐܚܪܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.4",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Romans 7:4",
      "text": "ܘܗܫܐ ܐܚܝ ܐܦ ܐܢܬܘܢ ܡܝܬܬܘܢ ܠܢܡܘܤܐ ܒܦܓܪܗ ܕܡܫܝܚܐ ܕܬܗܘܘܢ ܠܐܚܪܝܢ ܐܝܢܐ ܕܩܡ ܡܢ ܒܝܬ ܡܝܬܐ ܕܬܬܠܘܢ ܦܐܪܐ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.5",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Romans 7:5",
      "text": "ܟܕ ܒܒܤܪܐ ܗܘܝܢ ܓܝܪ ܟܐܒܐ ܕܚܛܗܐ ܕܒܢܡܘܤܐ ܡܬܚܦܛܝܢ ܗܘܘ ܒܗܕܡܝܢ ܕܦܐܪܐ ܢܬܠ ܠܡܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.6",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Romans 7:6",
      "text": "ܗܫܐ ܕܝܢ ܐܬܒܛܠܢ ܡܢ ܢܡܘܤܐ ܘܡܝܬܢ ܠܗܘ ܕܐܚܝܕ ܗܘܐ ܠܢ ܕܢܫܡܫ ܡܟܝܠ ܒܚܕܬܘܬܐ ܕܪܘܚܐ ܘܠܐ ܒܥܬܝܩܘܬ ܟܬܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.7",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Romans 7:7",
      "text": "ܡܢܐ ܗܟܝܠ ܐܡܪܝܢܢ ܢܡܘܤܐ ܚܛܝܬܐ ܗܘ ܚܤ ܐܠܐ ܠܚܛܝܬܐ ܠܐ ܝܠܦܬ ܐܠܐ ܒܝܕ ܢܡܘܤܐ ܠܐ ܓܝܪ ܪܓܬܐ ܝܕܥ ܗܘܝܬ ܐܠܘ ܠܐ ܢܡܘܤܐ ܕܐܡܪ ܕܠܐ ܬܪܓ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.8",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Romans 7:8",
      "text": "ܘܒܗܢܐ ܦܘܩܕܢܐ ܐܫܟܚܬ ܠܗ ܚܛܝܬܐ ܥܠܬܐ ܘܓܡܪܬ ܒܝ ܟܠ ܪܓܐ ܒܠܥܕ ܢܡܘܤܐ ܓܝܪ ܚܛܝܬܐ ܡܝܬܐ ܗܘܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.9",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Romans 7:9",
      "text": "ܐܢܐ ܕܝܢ ܚܝ ܗܘܝܬ ܕܠܐ ܢܡܘܤܐ ܡܢ ܩܕܝܡ ܟܕ ܐܬܐ ܕܝܢ ܦܘܩܕܢܐ ܚܛܝܬܐ ܚܝܬ ܘܐܢܐ ܡܝܬܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.10",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Romans 7:10",
      "text": "ܘܐܫܬܟܚ ܠܝ ܦܘܩܕܢܐ ܗܘ ܕܚܝܐ ܠܡܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.11",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Romans 7:11",
      "text": "ܚܛܝܬܐ ܓܝܪ ܒܥܠܬܐ ܕܐܫܟܚܬ ܠܗ ܒܝܕ ܦܘܩܕܢܐ ܐܛܥܝܬܢܝ ܘܒܗ ܩܛܠܬܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.12",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Romans 7:12",
      "text": "ܢܡܘܤܐ ܡܕܝܢ ܩܕܝܫ ܗܘ ܘܦܘܩܕܢܐ ܩܕܝܫ ܗܘ ܘܟܐܝܢ ܘܛܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.13",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Romans 7:13",
      "text": "ܛܒܬܐ ܗܟܝܠ ܠܝ ܠܡܘܬܐ ܗܘ ܗܘܬ ܚܤ ܐܠܐ ܚܛܝܬܐ ܕܬܬܚܙܐ ܕܚܛܝܬܐ ܗܝ ܕܒܛܒܬܐ ܓܡܪܬ ܒܝ ܡܘܬܐ ܕܝܬܝܪܐܝܬ ܬܬܚܝܒ ܚܛܝܬܐ ܒܦܘܩܕܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.14",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Romans 7:14",
      "text": "ܝܕܥܝܢܢ ܓܝܪ ܕܢܡܘܤܐ ܕܪܘܚ ܗܘ ܐܢܐ ܕܝܢ ܕܒܤܪ ܐܢܐ ܘܡܙܒܢ ܐܢܐ ܠܚܛܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.15",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Romans 7:15",
      "text": "ܡܕܡ ܕܤܥܪ ܐܢܐ ܓܝܪ ܠܐ ܝܕܥ ܐܢܐ ܘܠܐ ܗܘܐ ܡܕܡ ܕܨܒܐ ܐܢܐ ܥܒܕ ܐܢܐ ܐܠܐ ܡܕܡ ܕܤܢܐ ܐܢܐ ܗܘ ܗܘ ܥܒܕ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.16",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Romans 7:16",
      "text": "ܘܐܢ ܡܕܡ ܕܠܐ ܨܒܐ ܐܢܐ ܥܒܕ ܐܢܐ ܤܗܕ ܐܢܐ ܥܠ ܢܡܘܤܐ ܕܫܦܝܪ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.17",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Romans 7:17",
      "text": "ܗܫܐ ܕܝܢ ܠܐ ܗܘܐ ܐܢܐ ܤܥܪ ܐܢܐ ܗܕܐ ܐܠܐ ܚܛܝܬܐ ܕܥܡܪܐ ܒܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.18",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Romans 7:18",
      "text": "ܝܕܥ ܐܢܐ ܗܘ ܓܝܪ ܕܠܐ ܥܡܪܐ ܒܝ ܗܢܘ ܕܝܢ ܒܒܤܪܝ ܛܒܬܐ ܕܐܨܒܐ ܓܝܪ ܒܛܒܬܐ ܦܫܝܩ ܠܝ ܕܐܤܥܪܝܗ ܕܝܢ ܠܐ ܡܫܟܚ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.19",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Romans 7:19",
      "text": "ܠܐ ܗܘܐ ܓܝܪ ܠܛܒܬܐ ܕܨܒܐ ܐܢܐ ܕܐܥܒܕ ܥܒܕ ܐܢܐ ܐܠܐ ܒܝܫܬܐ ܕܠܐ ܨܒܐ ܐܢܐ ܕܐܥܒܕ ܠܗ ܥܒܕ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.20",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Romans 7:20",
      "text": "ܘܐܢ ܡܕܡ ܕܠܐ ܨܒܐ ܐܢܐ ܥܒܕ ܐܢܐ ܠܐ ܗܘܐ ܐܢܐ ܥܒܕ ܐܢܐ ܐܠܐ ܚܛܝܬܐ ܕܥܡܪܐ ܒܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.21",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Romans 7:21",
      "text": "ܡܫܟܚ ܐܢܐ ܗܟܝܠ ܠܢܡܘܤܐ ܕܫܠܡ ܠܪܥܝܢܝ ܗܘ ܕܨܒܐ ܕܢܥܒܕ ܛܒܬܐ ܡܛܠ ܕܒܝܫܬܐ ܩܪܝܒܐ ܗܝ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.22",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Romans 7:22",
      "text": "ܚܕܐ ܐܢܐ ܓܝܪ ܒܢܡܘܤܗ ܕܐܠܗܐ ܒܒܪܢܫܐ ܕܠܓܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.23",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Romans 7:23",
      "text": "ܚܙܐ ܐܢܐ ܕܝܢ ܢܡܘܤܐ ܐܚܪܢܐ ܒܗܕܡܝ ܕܡܩܪܒ ܠܘܩܒܠ ܢܡܘܤܐ ܕܪܥܝܢܝ ܘܫܒܐ ܠܝ ܠܢܡܘܤܐ ܕܚܛܝܬܐ ܕܐܝܬ ܒܗܕܡܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.24",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Romans 7:24",
      "text": "ܕܘܝܐ ܐܢܐ ܒܪܢܫܐ ܡܢܘ ܢܦܨܝܢܝ ܡܢ ܦܓܪܐ ܗܢܐ ܕܡܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.7.25",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Romans 7:25",
      "text": "ܡܘܕܐ ܐܢܐ ܠܐܠܗܐ ܒܝܕ ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܗܫܐ ܗܟܝܠ ܐܢܐ ܒܪܥܝܢܝ ܥܒܕܐ ܐܢܐ ܕܢܡܘܤܐ ܕܐܠܗܐ ܒܒܤܪܝ ܕܝܢ ܐܝܬܝ ܥܒܕܐ ܕܢܡܘܤܐ ܕܚܛܝܬܐ ܀",
      "paragraphStart": false
    }
  ]
