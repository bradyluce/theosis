  },
  "verses": [
    {
      "id": "peshitta:romans.12.1",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Romans 12:1",
      "text": "ܒܥܢܐ ܗܟܝܠ ܡܢܟܘܢ ܐܚܝ ܒܪܚܡܘܗܝ ܕܐܠܗܐ ܕܬܩܝܡܘܢ ܦܓܪܝܟܘܢ ܕܒܚܬܐ ܚܝܬܐ ܘܩܕܝܫܬܐ ܘܡܩܒܠܬܐ ܠܐܠܗܐ ܒܬܫܡܫܬܐ ܡܠܝܠܬܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:romans.12.2",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Romans 12:2",
      "text": "ܘܠܐ ܬܬܕܡܘܢ ܠܥܠܡܐ ܗܢܐ ܐܠܐ ܐܫܬܚܠܦܘ ܒܚܘܕܬܐ ܕܪܥܝܢܝܟܘܢ ܘܗܘܝܬܘܢ ܦܪܫܝܢ ܐܝܢܐ ܗܘ ܨܒܝܢܐ ܕܐܠܗܐ ܛܒܐ ܘܡܩܒܠܐ ܘܓܡܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.12.3",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Romans 12:3",
      "text": "ܐܡܪ ܐܢܐ ܕܝܢ ܒܛܝܒܘܬܐ ܕܐܬܝܗܒܬ ܠܝ ܠܟܠܟܘܢ ܕܠܐ ܬܗܘܘܢ ܡܬܪܥܝܢ ܠܒܪ ܡܢ ܡܐ ܕܘܠܐ ܕܬܬܪܥܘܢ ܐܠܐ ܬܗܘܘܢ ܡܬܪܥܝܢ ܒܢܟܦܘܬܐ ܟܠܢܫ ܐܝܟ ܕܦܠܓ ܠܗ ܐܠܗܐ ܗܝܡܢܘܬܐ ܒܡܫܘܚܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.12.4",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Romans 12:4",
      "text": "ܐܝܟܢܐ ܓܝܪ ܕܒܚܕ ܦܓܪܐ ܗܕܡܐ ܤܓܝܐܐ ܐܝܬ ܠܢ ܘܟܠܗܘܢ ܗܕܡܐ ܠܐ ܗܘܐ ܚܕ ܤܘܥܪܢܐ ܐܝܬ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.12.5",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Romans 12:5",
      "text": "ܗܟܢܐ ܐܦ ܚܢܢ ܕܤܓܝܐܐ ܚܢܢ ܚܕ ܚܢܢ ܦܓܪ ܒܡܫܝܚܐ ܚܕ ܚܕ ܡܢܢ ܕܝܢ ܗܕܡܐ ܚܢܢ ܕܚܕܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.12.6",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Romans 12:6",
      "text": "ܐܠܐ ܐܝܬ ܠܢ ܡܘܗܒܬܐ ܡܫܚܠܦܬܐ ܐܝܟ ܛܝܒܘܬܐ ܕܐܬܝܗܒܬ ܠܢ ܐܝܬ ܕܢܒܝܘܬܐ ܐܝܟ ܡܫܘܚܬܐ ܕܗܝܡܢܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.12.7",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Romans 12:7",
      "text": "ܘܐܝܬ ܕܬܫܡܫܬܐ ܐܝܬ ܠܗ ܒܬܫܡܫܬܗ ܘܐܝܬ ܕܡܠܦܢܐ ܗܘ ܒܝܘܠܦܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.12.8",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Romans 12:8",
      "text": "ܘܐܝܬ ܕܡܒܝܐܢܐ ܗܘ ܒܒܘܝܐܗ ܘܕܝܗܒ ܒܦܫܝܛܘܬܐ ܘܕܩܐܡ ܒܪܫܐ ܒܚܦܝܛܘܬܐ ܘܕܡܪܚܡ ܒܦܨܝܚܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.12.9",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Romans 12:9",
      "text": "ܘܠܐ ܢܗܘܐ ܢܟܝܠ ܚܘܒܟܘܢ ܐܠܐ ܗܘܝܬܘܢ ܤܢܝܢ ܠܒܝܫܬܐ ܘܡܬܢܩܦܝܢ ܠܛܒܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.12.10",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Romans 12:10",
      "text": "ܗܘܝܬܘܢ ܪܚܡܝܢ ܠܐܚܝܟܘܢ ܘܡܚܒܝܢ ܚܕ ܠܚܕ ܗܘܝܬܘܢ ܡܩܕܡܝܢ ܡܝܩܪܝܢ ܚܕ ܠܚܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.12.11",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Romans 12:11",
      "text": "ܗܘܝܬܘܢ ܚܦܝܛܝܢ ܘܠܐ ܚܒܢܢܝܢ ܗܘܝܬܘܢ ܪܬܚܝܢ ܒܪܘܚ ܗܘܝܬܘܢ ܦܠܚܝܢ ܠܡܪܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.12.12",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Romans 12:12",
      "text": "ܗܘܝܬܘܢ ܚܕܝܢ ܒܤܒܪܟܘܢ ܗܘܝܬܘܢ ܡܤܝܒܪܝܢ ܐܘܠܨܢܝܟܘܢ ܗܘܝܬܘܢ ܐܡܝܢܝܢ ܒܨܠܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.12.13",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Romans 12:13",
      "text": "ܗܘܝܬܘܢ ܡܫܬܘܬܦܝܢ ܠܤܢܝܩܘܬܐ ܕܩܕܝܫܐ ܗܘܝܬܘܢ ܪܚܡܝܢ ܐܟܤܢܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.12.14",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Romans 12:14",
      "text": "ܒܪܟܘ ܠܪܕܘܦܝܟܘܢ ܒܪܟܘ ܘܠܐ ܬܠܘܛܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.12.15",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Romans 12:15",
      "text": "ܚܕܘ ܥܡ ܕܚܕܝܢ ܘܒܟܘ ܥܡ ܕܒܟܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.12.16",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Romans 12:16",
      "text": "ܘܡܕܡ ܕܡܬܪܥܝܢ ܐܢܬܘܢ ܥܠ ܢܦܫܟܘܢ ܐܦ ܥܠ ܐܚܝܟܘܢ ܘܠܐ ܬܬܪܥܘܢ ܪܥܝܢܐ ܪܡܐ ܐܠܐ ܩܦܘ ܠܐܝܠܝܢ ܕܡܟܝܟܝܢ ܘܠܐ ܗܘܝܬܘܢ ܚܟܝܡܝܢ ܒܪܥܝܢ ܢܦܫܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.12.17",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Romans 12:17",
      "text": "ܘܠܐ ܬܦܪܥܘܢ ܠܐܢܫ ܒܝܫܬܐ ܚܠܦ ܒܝܫܬܐ ܐܠܐ ܢܬܒܛܠ ܠܟܘܢ ܕܬܥܒܕܘܢ ܛܒܬܐ ܩܕܡ ܒܢܝܢܫܐ ܟܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.12.18",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Romans 12:18",
      "text": "ܘܐܢ ܡܫܟܚܐ ܐܝܟ ܕܡܢ ܠܘܬܟܘܢ ܥܡ ܟܠܒܪܢܫ ܫܠܡܐ ܥܒܕܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.12.19",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Romans 12:19",
      "text": "ܘܠܐ ܗܘܝܬܘܢ ܬܒܥܝܢ ܢܦܫܟܘܢ ܚܒܝܒܝ ܐܠܐ ܗܒܘ ܐܬܪܐ ܠܪܘܓܙܐ ܟܬܝܒ ܗܘ ܓܝܪ ܕܐܢ ܠܐ ܬܥܒܕ ܕܝܢܐ ܠܢܦܫܟ ܐܢܐ ܐܥܒܕ ܕܝܢܟ ܐܡܪ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.12.20",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Romans 12:20",
      "text": "ܘܐܢ ܟܦܢ ܒܥܠܕܒܒܟ ܐܘܟܠܝܗܝ ܘܐܢ ܨܗܐ ܐܫܩܝܗܝ ܘܐܢ ܗܠܝܢ ܬܥܒܕ ܠܗ ܓܘܡܪܐ ܕܢܘܪܐ ܬܩܒܪ ܥܠ ܩܪܩܦܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.12.21",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Romans 12:21",
      "text": "ܠܐ ܬܙܟܝܟܘܢ ܒܝܫܬܐ ܐܠܐ ܙܟܐܘܗ ܠܒܝܫܬܐ ܒܛܒܬܐ ܀",
      "paragraphStart": false
    }
  ]
