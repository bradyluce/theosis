  "verses": [
    {
      "id": "peshitta:romans.5.1",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Romans 5:1",
      "text": "ܡܛܠ ܕܐܙܕܕܩܢ ܗܟܝܠ ܒܗܝܡܢܘܬܐ ܢܗܘܐ ܠܢ ܫܠܡܐ ܠܘܬ ܐܠܗܐ ܒܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:romans.5.2",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Romans 5:2",
      "text": "ܕܒܗ ܐܬܩܪܒܢ ܒܗܝܡܢܘܬܐ ܠܛܝܒܘܬܐ ܗܕܐ ܕܒܗ ܩܝܡܝܢܢ ܘܡܫܬܒܗܪܝܢܢ ܒܤܒܪܐ ܕܬܫܒܘܚܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.5.3",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Romans 5:3",
      "text": "ܘܠܐ ܗܟܢܐ ܒܠܚܘܕ ܐܠܐ ܐܦ ܒܐܘܠܨܢܝܢ ܡܫܬܒܗܪܝܢܢ ܕܝܕܥܝܢܢ ܕܐܘܠܨܢܐ ܡܤܝܒܪܢܘܬܐ ܓܡܪ ܒܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.5.4",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Romans 5:4",
      "text": "ܘܡܤܝܒܪܢܘܬܐ ܒܘܩܝܐ ܘܒܘܩܝܐ ܤܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.5.5",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Romans 5:5",
      "text": "ܤܒܪܐ ܕܝܢ ܠܐ ܡܒܗܬ ܡܛܠ ܕܚܘܒܗ ܕܐܠܗܐ ܡܫܦܥ ܥܠ ܠܒܘܬܢ ܒܪܘܚܐ ܕܩܘܕܫܐ ܕܐܬܝܗܒܬ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.5.6",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Romans 5:6",
      "text": "ܐܢ ܕܝܢ ܡܫܝܚܐ ܡܛܠ ܟܪܝܗܘܬܢ ܒܙܒܢܐ ܗܢܐ ܚܠܦ ܪܫܝܥܐ ܡܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.5.7",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Romans 5:7",
      "text": "ܠܡܚܤܢ ܓܝܪ ܐܢܫ ܚܠܦ ܪܫܝܥܐ ܡܐܬ ܚܠܦ ܛܒܐ ܓܝܪ ܛܟ ܡܡܪܚ ܐܢܫ ܠܡܡܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.5.8",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Romans 5:8",
      "text": "ܗܪܟܐ ܡܚܘܐ ܐܠܗܐ ܚܘܒܗ ܕܠܘܬܢ ܕܐܢ ܟܕ ܚܛܝܐ ܐܝܬܝܢ ܗܘܝܢ ܡܫܝܚܐ ܚܠܦܝܢ ܡܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.5.9",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Romans 5:9",
      "text": "ܟܡܐ ܗܟܝܠ ܝܬܝܪܐܝܬ ܢܙܕܕܩ ܗܫܐ ܒܕܡܗ ܘܒܗ ܢܬܦܨܐ ܡܢ ܪܘܓܙܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.5.10",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Romans 5:10",
      "text": "ܐܢ ܓܝܪ ܟܕ ܐܝܬܝܢ ܒܥܠܕܒܒܐ ܐܬܪܥܝ ܥܡܢ ܐܠܗܐ ܒܡܘܬܐ ܕܒܪܗ ܟܡܐ ܗܟܝܠ ܝܬܝܪܐܝܬ ܒܬܪܥܘܬܗ ܢܚܐ ܒܚܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.5.11",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Romans 5:11",
      "text": "ܘܠܐ ܗܟܢܐ ܒܠܚܘܕ ܐܠܐ ܐܦ ܢܫܬܒܗܪ ܒܐܠܗܐ ܒܝܕ ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܕܒܗ ܗܘ ܗܫܐ ܩܒܠܢ ܬܪܥܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.5.12",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Romans 5:12",
      "text": "ܐܝܟܢܐ ܓܝܪ ܕܒܝܕ ܚܕ ܒܪܢܫܐ ܥܠܬ ܚܛܝܬܐ ܠܥܠܡܐ ܘܒܝܕ ܚܛܝܬܐ ܡܘܬܐ ܘܗܟܢܐ ܒܟܠܗܘܢ ܒܢܝ ܐܢܫܐ ܥܒܪ ܡܘܬܐ ܒܗܝ ܕܟܠܗܘܢ ܚܛܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.5.13",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Romans 5:13",
      "text": "ܥܕܡܐ ܓܝܪ ܠܢܡܘܤܐ ܚܛܝܬܐ ܟܕ ܐܝܬܝܗ ܗܘܬ ܒܥܠܡܐ ܠܐ ܚܫܝܒܐ ܗܘܬ ܚܛܝܬܐ ܡܛܠ ܕܠܝܬ ܗܘܐ ܢܡܘܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.5.14",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Romans 5:14",
      "text": "ܐܠܐ ܐܡܠܟ ܡܘܬܐ ܡܢ ܐܕܡ ܘܥܕܡܐ ܠܡܘܫܐ ܐܦ ܥܠ ܐܝܠܝܢ ܕܠܐ ܚܛܘ ܒܕܡܘܬܐ ܕܥܒܪ ܢܡܘܤܗ ܕܐܕܡ ܗܘ ܕܐܝܬܘܗܝ ܕܡܘܬܐ ܕܗܘ ܕܥܬܝܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.5.15",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Romans 5:15",
      "text": "ܐܠܐ ܠܐ ܗܘܐ ܐܝܟ ܫܘܪܥܬܐ ܗܟܢܐ ܡܘܗܒܬܐ ܐܢ ܓܝܪ ܡܛܠ ܫܘܪܥܬܗ ܕܚܕ ܤܓܝܐܐ ܡܝܬܘ ܟܡܐ ܗܟܝܠ ܝܬܝܪܐܝܬ ܛܝܒܘܬܗ ܕܐܠܗܐ ܘܡܘܗܒܬܗ ܡܛܠ ܚܕ ܒܪܢܫܐ ܝܫܘܥ ܡܫܝܚܐ ܒܤܓܝܐܐ ܬܬܝܬܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.5.16",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Romans 5:16",
      "text": "ܘܠܐ ܐܝܟ ܤܟܠܘܬܐ ܕܚܕ ܗܟܢܐ ܡܘܗܒܬܐ ܕܝܢܐ ܓܝܪ ܕܗܘܐ ܡܢ ܚܕ ܠܚܘܝܒܐ ܗܘܐ ܡܘܗܒܬܐ ܕܝܢ ܡܢ ܚܛܗܐ ܤܓܝܐܐ ܗܘܬ ܠܟܐܢܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.5.17",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Romans 5:17",
      "text": "ܐܢ ܓܝܪ ܡܛܠ ܤܟܠܘܬܐ ܕܚܕ ܐܡܠܟ ܡܘܬܐ ܝܬܝܪܐܝܬ ܐܝܠܝܢ ܕܢܤܒܘ ܤܘܓܐܐ ܕܛܝܒܘܬܐ ܘܕܡܘܗܒܬܐ ܘܕܟܐܢܘܬܐ ܒܚܝܐ ܢܡܠܟܘܢ ܒܝܕ ܚܕ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.5.18",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Romans 5:18",
      "text": "ܐܟܙܢܐ ܗܟܝܠ ܕܡܛܠ ܤܟܠܘܬܐ ܕܚܕ ܗܘܐ ܚܘܝܒܐ ܠܟܠܗܘܢ ܒܢܝܢܫܐ ܗܟܢܐ ܡܛܠ ܟܐܢܘܬܐ ܕܚܕ ܬܗܘܐ ܙܟܘܬܐ ܠܚܝܐ ܠܟܠܗܘܢ ܒܢܝܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.5.19",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Romans 5:19",
      "text": "ܐܝܟܢܐ ܓܝܪ ܕܡܛܠ ܠܐ ܡܫܬܡܥܢܘܬܗ ܕܚܕ ܒܪܢܫܐ ܚܛܝܐ ܤܓܝܐܐ ܗܘܘ ܗܟܢܐ ܐܦ ܡܛܠ ܡܫܬܡܥܢܘܬܗ ܕܚܕ ܤܓܝܐܐ ܟܐܢܐ ܗܘܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.5.20",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Romans 5:20",
      "text": "ܡܥܠܢܐ ܕܝܢ ܕܗܘܐ ܠܢܡܘܤܐ ܕܬܤܓܐ ܚܛܝܬܐ ܘܟܪ ܕܤܓܝܬ ܚܛܝܬܐ ܬܡܢ ܐܬܝܬܪܬ ܛܝܒܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.5.21",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Romans 5:21",
      "text": "ܕܐܝܟ ܕܐܡܠܟܬ ܚܛܝܬܐ ܒܡܘܬܐ ܗܟܢܐ ܬܡܠܟ ܛܝܒܘܬܐ ܒܟܐܢܘܬܐ ܠܚܝܐ ܕܠܥܠܡ ܒܝܕ ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    }
  ]
