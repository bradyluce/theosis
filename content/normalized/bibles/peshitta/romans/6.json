  },
  "verses": [
    {
      "id": "peshitta:romans.6.1",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Romans 6:1",
      "text": "ܡܢܐ ܗܟܝܠ ܢܐܡܪ ܢܩܘܐ ܒܗ ܒܚܛܝܬܐ ܕܛܝܒܘܬܐ ܬܬܝܬܪ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:romans.6.2",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Romans 6:2",
      "text": "ܚܤ ܐܝܠܝܢ ܓܝܪ ܕܡܝܬܢ ܠܚܛܝܬܐ ܐܝܟܢܐ ܢܚܐ ܒܗ ܬܘܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.3",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Romans 6:3",
      "text": "ܐܘ ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܕܐܝܠܝܢ ܕܥܡܕܢ ܒܝܫܘܥ ܡܫܝܚܐ ܒܡܘܬܗ ܗܘ ܥܡܕܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.4",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Romans 6:4",
      "text": "ܐܬܩܒܪܢ ܥܡܗ ܒܡܥܡܘܕܝܬܐ ܠܡܘܬܐ ܕܐܝܟܢܐ ܕܩܡ ܝܫܘܥ ܡܫܝܚܐ ܡܢ ܒܝܬ ܡܝܬܐ ܒܬܫܒܘܚܬܐ ܕܐܒܘܗܝ ܗܟܢܐ ܐܦ ܚܢܢ ܒܚܝܐ ܚܕܬܐ ܢܗܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.5",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Romans 6:5",
      "text": "ܐܢ ܓܝܪ ܐܟܚܕ ܐܬܢܨܒܢ ܥܡܗ ܒܕܡܘܬܐ ܕܡܘܬܗ ܗܟܢܐ ܐܦ ܒܩܝܡܬܗ ܢܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.6",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Romans 6:6",
      "text": "ܝܕܥܝܢܢ ܓܝܪ ܕܒܪܢܫܢ ܥܬܝܩܐ ܐܙܕܩܦ ܥܡܗ ܕܢܬܒܛܠ ܦܓܪܐ ܕܚܛܝܬܐ ܕܬܘܒ ܠܐ ܢܫܡܫ ܠܚܛܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.7",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Romans 6:7",
      "text": "ܐܝܢܐ ܕܡܝܬ ܓܝܪ ܐܬܚܪܪ ܠܗ ܡܢ ܚܛܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.8",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Romans 6:8",
      "text": "ܐܢ ܗܟܝܠ ܡܝܬܢ ܥܡ ܡܫܝܚܐ ܢܗܝܡܢ ܕܥܡܗ ܥܡ ܡܫܝܚܐ ܢܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.9",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Romans 6:9",
      "text": "ܝܕܥܝܢܢ ܓܝܪ ܕܡܫܝܚܐ ܩܡ ܡܢ ܒܝܬ ܡܝܬܐ ܘܬܘܒ ܠܐ ܡܐܬ ܘܡܘܬܐ ܠܐ ܡܫܬܠܛ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.10",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Romans 6:10",
      "text": "ܕܡܝܬ ܓܝܪ ܠܚܛܝܬܐ ܗܘ ܡܝܬ ܚܕܐ ܙܒܢ ܘܕܚܝ ܚܝ ܗܘ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.11",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Romans 6:11",
      "text": "ܗܟܢܐ ܐܦ ܐܢܬܘܢ ܚܫܘܒܘ ܢܦܫܟܘܢ ܕܡܝܬܐ ܐܢܬܘܢ ܠܚܛܝܬܐ ܘܚܝܐ ܐܢܬܘܢ ܠܐܠܗܐ ܒܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.12",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Romans 6:12",
      "text": "ܠܐ ܗܟܝܠ ܬܡܠܟ ܚܛܝܬܐ ܒܦܓܪܟܘܢ ܡܝܬܐ ܐܝܟ ܕܬܫܬܡܥܘܢ ܠܪܓܝܓܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.13",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Romans 6:13",
      "text": "ܘܐܦ ܠܐ ܬܛܝܒܘܢ ܗܕܡܝܟܘܢ ܙܝܢܐ ܕܥܘܠܐ ܠܚܛܝܬܐ ܐܠܐ ܛܝܒܘ ܢܦܫܟܘܢ ܠܐܠܗܐ ܐܝܟ ܐܢܫܐ ܕܡܢ ܡܝܬܐ ܚܝܝܬܘܢ ܘܗܕܡܝܟܘܢ ܙܝܢܐ ܢܗܘܘܢ ܠܟܐܢܘܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.14",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Romans 6:14",
      "text": "ܘܚܛܝܬܐ ܠܐ ܡܫܬܠܛܐ ܥܠܝܟܘܢ ܠܐ ܓܝܪ ܐܝܬܝܟܘܢ ܬܚܝܬ ܢܡܘܤܐ ܐܠܐ ܬܚܝܬ ܛܝܒܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.15",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Romans 6:15",
      "text": "ܡܢܐ ܗܟܝܠ ܢܚܛܐ ܕܠܐ ܗܘܝܢ ܬܚܝܬ ܢܡܘܤܐ ܐܠܐ ܬܚܝܬ ܛܝܒܘܬܐ ܚܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.16",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Romans 6:16",
      "text": "ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܕܠܡܢ ܕܡܛܝܒܝܢ ܐܢܬܘܢ ܢܦܫܟܘܢ ܕܬܫܬܡܥܘܢ ܠܗ ܠܥܒܕܘܬܐ ܕܝܠܗ ܐܢܬܘܢ ܥܒܕܐ ܕܗܘ ܕܡܫܬܡܥܝܢ ܐܢܬܘܢ ܠܗ ܐܢ ܠܚܛܝܬܐ ܘܐܢ ܠܡܫܡܥ ܐܕܢܐ ܕܟܐܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.17",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Romans 6:17",
      "text": "ܛܝܒܘ ܕܝܢ ܠܐܠܗܐ ܕܥܒܕܐ ܗܘܝܬܘܢ ܕܚܛܝܬܐ ܘܐܫܬܡܥܬܘܢ ܡܢ ܠܒܐ ܠܕܡܘܬܐ ܕܝܘܠܦܢܐ ܕܐܫܬܠܡܬܘܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.18",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Romans 6:18",
      "text": "ܘܟܕ ܐܬܚܪܪܬܘܢ ܡܢ ܚܛܝܬܐ ܐܫܬܥܒܕܬܘܢ ܠܟܐܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.19",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Romans 6:19",
      "text": "ܐܝܟ ܕܒܝܬ ܒܢܝܢܫܐ ܐܡܪ ܐܢܐ ܡܛܠ ܟܪܝܗܘܬܐ ܕܒܤܪܟܘܢ ܕܐܝܟܢܐ ܕܛܝܒܬܘܢ ܗܕܡܝܟܘܢ ܠܥܒܕܘܬܐ ܕܛܢܦܘܬܐ ܘܕܥܘܠܐ ܗܟܢܐ ܐܦ ܗܫܐ ܛܝܒܘ ܗܕܡܝܟܘܢ ܠܥܒܕܘܬܐ ܕܟܐܢܘܬܐ ܘܕܩܕܝܫܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.20",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Romans 6:20",
      "text": "ܟܕ ܥܒܕܐ ܗܘܝܬܘܢ ܓܝܪ ܕܚܛܝܬܐ ܡܚܪܪܐ ܗܘܝܬܘܢ ܠܟܐܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.21",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "Romans 6:21",
      "text": "ܘܡܢܐ ܐܕܫܐ ܐܝܬ ܗܘܐ ܠܟܘܢ ܗܝܕܝܢ ܐܝܢܐ ܕܝܘܡܢܐ ܒܗܬܝܢ ܐܢܬܘܢ ܒܗ ܚܪܬܗ ܓܝܪ ܐܝܬܝܗ ܡܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.22",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "Romans 6:22",
      "text": "ܘܗܫܐ ܕܐܬܚܪܪܬܘܢ ܡܢ ܚܛܝܬܐ ܘܗܘܝܬܘܢ ܥܒܕܐ ܠܐܠܗܐ ܐܝܬ ܠܟܘܢ ܦܐܪܐ ܩܕܝܫܐ ܕܚܪܬܗܘܢ ܚܝܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.6.23",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "Romans 6:23",
      "text": "ܬܐܓܘܪܬܐ ܕܝܢ ܕܚܛܝܬܐ ܡܘܬܐ ܗܘ ܘܡܘܗܒܬܗ ܕܐܠܗܐ ܚܝܐ ܕܠܥܠܡ ܒܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    }
  ]
}
