    },
    {
      "id": "peshitta:romans.11.22",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Romans 11:22",
      "text": "ܚܙܝ ܗܟܝܠ ܒܤܝܡܘܬܗ ܘܩܫܝܘܬܗ ܕܐܠܗܐ ܥܠ ܐܝܠܝܢ ܕܢܦܠܘ ܩܫܝܘܬܐ ܥܠܝܟ ܕܝܢ ܒܤܝܡܘܬܐ ܐܢ ܬܩܘܐ ܒܗ ܒܒܤܝܡܘܬܐ ܘܐܢ ܠܐ ܐܦ ܐܢܬ ܬܬܦܫܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.11.23",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Romans 11:23",
      "text": "ܘܗܢܘܢ ܐܢ ܠܐ ܢܩܘܘܢ ܒܚܤܝܪܘܬ ܗܝܡܢܘܬܗܘܢ ܐܦ ܗܢܘܢ ܢܬܛܥܡܘܢ ܡܫܟܚ ܓܝܪ ܐܠܗܐ ܕܬܘܒ ܢܛܥܡ ܐܢܘܢ ܀",
