      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Romans 11:1",
      "text": "ܐܠܐ ܐܡܪ ܐܢܐ ܕܠܡܐ ܕܚܩܗ ܐܠܗܐ ܠܥܡܗ ܚܤ ܐܦ ܐܢܐ ܓܝܪ ܡܢ ܐܝܤܪܝܠ ܐܢܐ ܡܢ ܙܪܥܗ ܕܐܒܪܗܡ ܡܢ ܫܪܒܬܐ ܕܒܢܝܡܝܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:romans.11.2",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Romans 11:2",
      "text": "ܠܐ ܕܚܩ ܐܠܗܐ ܠܥܡܗ ܐܝܢܐ ܕܡܢ ܩܕܝܡ ܝܕܝܥ ܗܘܐ ܠܗ ܐܘ ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܒܟܬܒܐ ܕܐܠܝܐ ܡܢܐ ܐܡܪ ܟܕ ܩܒܠ ܗܘܐ ܠܐܠܗܐ ܥܠ ܐܝܤܪܝܠ ܘܐܡܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.11.3",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Romans 11:3",
      "text": "ܡܪܝ ܠܢܒܝܝܟ ܩܛܠܘ ܘܠܡܕܒܚܝܟ ܤܚܦܘ ܘܐܢܐ ܗܘ ܒܠܚܘܕܝ ܐܫܬܚܪܬ ܘܒܥܝܢ ܠܢܦܫܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.11.4",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Romans 11:4",
      "text": "ܘܐܬܐܡܪ ܠܗ ܒܓܠܝܢܐ ܕܗܐ ܫܒܩܬ ܠܢܦܫܝ ܫܒܥܐ ܐܠܦܝܢ ܓܒܪܝܢ ܐܝܠܝܢ ܕܥܠ ܒܘܪܟܝܗܘܢ ܠܐ ܒܪܟܘ ܘܠܐ ܤܓܕܘ ܠܒܥܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.11.5",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Romans 11:5",
      "text": "ܗܟܢܐ ܐܦ ܒܗܢܐ ܙܒܢܐ ܫܪܟܢܐ ܗܘ ܐܫܬܚܪ ܒܓܒܝܬܐ ܕܛܝܒܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.11.6",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Romans 11:6",
      "text": "ܐܢ ܕܝܢ ܒܛܝܒܘܬܐ ܠܐ ܗܘܐ ܡܢ ܥܒܕܐ ܘܐܢ ܠܐ ܛܝܒܘܬܐ ܠܐ ܐܝܬܝܗ ܛܝܒܘܬܐ ܐܢ ܕܝܢ ܒܥܒܕܐ ܠܐ ܗܘܐ ܡܢ ܛܝܒܘܬܐ ܘܐܢ ܠܐ ܥܒܕܐ ܠܐ ܐܝܬܘܗܝ ܥܒܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.11.7",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Romans 11:7",
      "text": "ܡܢܐ ܗܟܝܠ ܗܝ ܕܒܥܐ ܗܘܐ ܐܝܤܪܝܠ ܠܐ ܐܫܟܚ ܓܒܝܬܐ ܕܝܢ ܐܫܟܚܬ ܫܪܟܗܘܢ ܕܝܢ ܐܬܥܘܪܘ ܒܠܒܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.11.8",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Romans 11:8",
      "text": "ܐܝܟܢܐ ܕܟܬܝܒ ܕܝܗܒ ܠܗܘܢ ܐܠܗܐ ܪܘܚܐ ܡܕܥܪܢܝܬܐ ܘܥܝܢܐ ܕܠܐ ܢܒܚܪܘܢ ܒܗܝܢ ܘܐܕܢܐ ܕܠܐ ܢܫܡܥܘܢ ܥܕܡܐ ܠܝܘܡܐ ܕܝܘܡܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.11.9",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Romans 11:9",
      "text": "ܘܕܘܝܕ ܬܘܒ ܐܡܪ ܢܗܘܐ ܦܬܘܪܗܘܢ ܩܕܡܝܗܘܢ ܠܦܚܐ ܘܦܘܪܥܢܗܘܢ ܠܬܘܩܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.11.10",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Romans 11:10",
      "text": "ܢܚܫܟܢ ܥܝܢܝܗܘܢ ܕܠܐ ܢܚܙܘܢ ܘܚܨܗܘܢ ܒܟܠܙܒܢ ܢܗܘܐ ܟܦܝܦ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.11.11",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Romans 11:11",
      "text": "ܐܡܪ ܐܢܐ ܕܝܢ ܕܠܡܐ ܐܬܬܩܠܘ ܐܝܟ ܕܢܦܠܘܢ ܚܤ ܐܠܐ ܒܬܘܩܠܬܗܘܢ ܕܝܠܗܘܢ ܗܘܘ ܚܝܐ ܠܥܡܡܐ ܠܛܢܢܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.11.12",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Romans 11:12",
      "text": "ܘܐܢ ܬܘܩܠܬܗܘܢ ܗܘܬ ܥܘܬܪܐ ܠܥܠܡܐ ܘܚܝܒܘܬܗܘܢ ܥܘܬܪܐ ܠܥܡܡܐ ܟܡܐ ܗܟܝܠ ܫܘܡܠܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.11.13",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Romans 11:13",
      "text": "ܠܟܘܢ ܕܝܢ ܐܡܪ ܐܢܐ ܠܥܡܡܐ ܐܢܐ ܕܐܝܬܝ ܫܠܝܚܐ ܕܥܡܡܐ ܠܬܫܡܫܬܝ ܡܫܒܚ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.11.14",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Romans 11:14",
      "text": "ܕܠܡܐ ܐܛܢ ܠܒܢܝ ܒܤܪܝ ܘܐܚܐ ܐܢܫܝܢ ܡܢܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.11.15",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Romans 11:15",
      "text": "ܐܢ ܓܝܪ ܡܤܬܠܝܢܘܬܗܘܢ ܬܪܥܘܬܐ ܠܥܠܡܐ ܗܘܬ ܟܡܐ ܗܟܝܠ ܦܘܢܝܗܘܢ ܐܠܐ ܚܝܐ ܕܡܢ ܒܝܬ ܡܝܬܐ ܀",
      "paragraphStart": false
