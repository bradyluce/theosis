    {
      "id": "peshitta:romans.11.21",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Romans 11:21",
      "text": "ܐܢ ܐܠܗܐ ܓܝܪ ܥܠ ܤܘܟܐ ܕܡܢ ܟܝܢܗܝܢ ܠܐ ܚܤ ܕܠܡܐ ܐܦܠܐ ܥܠܝܟ ܢܚܘܤ ܀",
