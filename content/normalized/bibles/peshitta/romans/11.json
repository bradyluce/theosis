    {
      "id": "peshitta:romans.11.18",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Romans 11:18",
      "text": "ܠܐ ܬܫܬܒܗܪ ܥܠ ܤܘܟܐ ܐܢ ܕܝܢ ܡܫܬܒܗܪ ܐܢܬ ܠܐ ܗܘܐ ܐܢܬ ܫܩܝܠ ܠܗ ܠܥܩܪܐ ܐܠܐ ܗܘ ܥܩܪܐ ܫܩܝܠ ܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.11.19",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Romans 11:19",
      "text": "ܘܟܒܪ ܬܐܡܪ ܕܤܘܟܐ ܕܐܬܦܫܚ ܕܐܢܐ ܒܕܘܟܝܬܗܝܢ ܐܬܛܥܡ ܀",
