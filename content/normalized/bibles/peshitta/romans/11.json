    {
      "id": "peshitta:romans.11.20",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Romans 11:20",
      "text": "ܫܦܝܪ ܗܠܝܢ ܡܛܠ ܕܠܐ ܗܝܡܢ ܐܬܦܫܚ ܐܢܬ ܕܝܢ ܒܗܝܡܢܘܬܐ ܩܡܬ ܠܐ ܬܬܪܝܡ ܒܪܥܝܢܟ ܐܠܐ ܕܚܠ ܀",
      "paragraphStart": false
