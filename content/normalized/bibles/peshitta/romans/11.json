    {
      "id": "peshitta:romans.11.16",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Romans 11:16",
      "text": "ܘܐܢ ܕܝܢ ܪܫܝܬܐ ܩܕܝܫܐ ܐܦ ܓܒܝܠܬܐ ܘܐܢ ܥܩܪܐ ܩܕܝܫ ܗܘ ܐܦ ܤܘܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.11.17",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Romans 11:17",
      "text": "ܘܐܢ ܡܢ ܤܘܟܐ ܐܬܦܫܚ ܘܐܢܬ ܕܙܝܬܐ ܐܢܬ ܕܒܪܐ ܐܬܛܥܡܬ ܒܕܘܟܝܬܗܝܢ ܘܗܘܝܬ ܫܘܬܦܐ ܠܥܩܪܗ ܘܠܫܘܡܢܗ ܕܙܝܬܐ ܀",
