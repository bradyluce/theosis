{
  "chapter": {
    "id": "peshitta:romans.10",
    "translationId": "peshitta",
    "bookSlug": "romans",
    "chapterNumber": 10,
    "referenceLabel": "Romans 10",
    "summary": "Source text for Romans 10 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:romans.10.1",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Romans 10:1",
      "text": "ܐܚܝ ܨܒܝܢܐ ܕܠܒܝ ܘܒܥܘܬܝ ܕܠܘܬ ܐܠܗܐ ܚܠܦܝܗܘܢ ܕܢܚܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:romans.10.2",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Romans 10:2",
      "text": "ܡܤܗܕ ܐܢܐ ܓܝܪ ܥܠܝܗܘܢ ܕܛܢܢܐ ܕܐܠܗܐ ܐܝܬ ܒܗܘܢ ܐܠܐ ܠܘ ܒܝܕܥܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.10.3",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Romans 10:3",
      "text": "ܟܐܢܘܬܗ ܓܝܪ ܕܐܠܗܐ ܠܐ ܝܕܥܘ ܐܠܐ ܒܥܘ ܕܟܐܢܘܬܐ ܕܢܦܫܗܘܢ ܢܩܝܡܘܢ ܘܡܛܠ ܗܢܐ ܠܟܐܢܘܬܗ ܕܐܠܗܐ ܠܐ ܐܫܬܥܒܕܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.10.4",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Romans 10:4",
      "text": "ܤܟܗ ܓܝܪ ܕܢܡܘܤܐ ܡܫܝܚܐ ܗܘ ܠܟܐܢܘܬܐ ܠܟܠ ܕܡܗܝܡܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.10.5",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Romans 10:5",
      "text": "ܡܘܫܐ ܓܝܪ ܗܟܢܐ ܟܬܒ ܟܐܢܘܬܐ ܕܒܢܡܘܤܐ ܕܡܢ ܕܢܥܒܕ ܗܠܝܢ ܢܚܐ ܒܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.10.6",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Romans 10:6",
      "text": "ܟܐܢܘܬܐ ܕܝܢ ܕܒܗܝܡܢܘܬܐ ܗܟܢܐ ܐܡܪܐ ܕܠܐ ܬܐܡܪ ܒܠܒܟ ܕܡܢܘ ܤܠܩ ܠܫܡܝܐ ܘܐܚܬ ܠܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.10.7",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Romans 10:7",
      "text": "ܘܡܢܘ ܢܚܬ ܠܬܗܘܡܐ ܕܫܝܘܠ ܘܐܤܩ ܠܡܫܝܚܐ ܡܢ ܒܝܬ ܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.10.8",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Romans 10:8",
      "text": "ܐܠܐ ܡܢܐ ܐܡܪ ܩܪܝܒ ܗܘ ܠܟ ܦܬܓܡܐ ܠܦܘܡܟ ܘܠܠܒܟ ܗܕܐ ܗܝ ܡܠܬܐ ܕܗܝܡܢܘܬܐ ܕܡܟܪܙܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.10.9",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Romans 10:9",
      "text": "ܘܐܢ ܬܘܕܐ ܒܦܘܡܟ ܒܡܪܢ ܝܫܘܥ ܘܬܗܝܡܢ ܒܠܒܟ ܕܐܠܗܐ ܐܩܝܡܗ ܡܢ ܒܝܬ ܡܝܬܐ ܬܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.10.10",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Romans 10:10",
      "text": "ܠܒܐ ܓܝܪ ܕܡܗܝܡܢ ܒܗ ܡܙܕܕܩ ܘܦܘܡܐ ܕܡܘܕܐ ܒܗ ܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.10.11",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Romans 10:11",
      "text": "ܐܡܪ ܓܝܪ ܟܬܒܐ ܕܟܠ ܕܡܗܝܡܢ ܒܗ ܠܐ ܢܒܗܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.10.12",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Romans 10:12",
      "text": "ܘܒܗܕܐ ܠܐ ܦܪܫ ܠܐ ܠܝܗܘܕܝܐ ܘܠܐ ܠܐܪܡܝܐ ܚܕ ܗܘ ܓܝܪ ܡܪܝܐ ܕܟܠܗܘܢ ܕܥܬܝܪ ܒܟܠ ܕܩܪܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.10.13",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Romans 10:13",
      "text": "ܟܠ ܓܝܪ ܕܢܩܪܐ ܫܡܗ ܕܡܪܝܐ ܢܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.10.14",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Romans 10:14",
      "text": "ܐܝܟܢܐ ܗܟܝܠ ܢܩܪܘܢ ܠܐܝܢܐ ܕܠܐ ܗܝܡܢܘ ܒܗ ܐܘ ܐܝܟܢܐ ܢܗܝܡܢܘܢ ܠܗܘ ܕܠܐ ܫܡܥܘܗܝ ܐܘ ܐܝܟܢܐ ܢܫܡܥܘܢ ܕܠܐ ܡܟܪܙܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.10.15",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Romans 10:15",
      "text": "ܐܘ ܐܝܟܢܐ ܢܟܪܙܘܢ ܐܢ ܠܐ ܢܫܬܠܚܘܢ ܐܝܟ ܕܟܬܝܒ ܕܡܐ ܝܐܝܢ ܪܓܠܝܗܘܢ ܕܡܤܒܪܝ ܫܠܡܐ ܘܕܡܤܒܪܝ ܛܒܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.10.16",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Romans 10:16",
      "text": "ܐܠܐ ܠܐ ܗܘܐ ܟܠܗܘܢ ܐܫܬܡܥܘ ܠܤܒܪܬܐ ܕܐܘܢܓܠܝܘܢ ܐܫܥܝܐ ܓܝܪ ܐܡܪ ܡܪܝ ܡܢܘ ܗܝܡܢ ܠܒܪܬ ܩܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.10.17",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Romans 10:17",
      "text": "ܡܟܝܠ ܗܝܡܢܘܬܐ ܡܢ ܡܫܡܥ ܐܕܢܐ ܗܝ ܘܡܫܡܥ ܐܕܢܐ ܡܢ ܡܠܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.10.18",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Romans 10:18",
      "text": "ܐܠܐ ܐܡܪ ܐܢܐ ܕܠܡܐ ܠܐ ܫܡܥܘ ܘܗܐ ܒܟܠܗ ܐܪܥܐ ܢܦܩܬ ܒܪܬ ܩܠܗܘܢ ܘܒܤܘܦܝܗ ܕܬܒܝܠ ܡܠܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.10.19",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Romans 10:19",
      "text": "ܐܠܐ ܐܡܪ ܐܢܐ ܕܠܡܐ ܠܐ ܝܕܥ ܐܝܤܪܝܠ ܩܕܡܝܐ ܡܘܫܐ ܗܟܢܐ ܐܡܪ ܐܛܢܟܘܢ ܒܥܡ ܕܠܐ ܥܡ ܘܒܥܡܐ ܕܠܐ ܡܬܛܦܝܤ ܐܪܓܙܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.10.20",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Romans 10:20",
      "text": "ܐܫܥܝܐ ܕܝܢ ܐܡܪܚ ܘܐܡܪ ܕܐܬܚܙܝܬ ܠܐܝܠܝܢ ܕܠܐ ܒܥܐܘܢܝ ܘܐܫܬܟܚܬ ܠܐܝܠܝܢ ܕܥܠܝ ܠܐ ܫܐܠܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.10.21",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Romans 10:21",
      "text": "ܠܐܝܤܪܝܠ ܕܝܢ ܐܡܪ ܕܦܫܛܬ ܐܝܕܝ ܝܘܡܐ ܟܠܗ ܠܘܬ ܥܡܐ ܕܡܬܚܪܐ ܘܠܐ ܡܬܛܦܝܤ ܀",
      "paragraphStart": false
    }
  ]
}
