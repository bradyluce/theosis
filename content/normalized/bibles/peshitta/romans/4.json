{
  "chapter": {
    "id": "peshitta:romans.4",
    "translationId": "peshitta",
    "bookSlug": "romans",
    "chapterNumber": 4,
    "referenceLabel": "Romans 4",
    "summary": "Source text for Romans 4 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:romans.4.1",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Romans 4:1",
      "text": "ܡܢܐ ܗܟܝܠ ܐܡܪܝܢܢ ܥܠ ܐܒܪܗܡ ܪܫܐ ܕܐܒܗܬܐ ܕܐܫܟܚ ܒܒܤܪ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:romans.4.2",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Romans 4:2",
      "text": "ܐܠܘ ܓܝܪ ܐܒܪܗܡ ܡܢ ܥܒܕܐ ܐܙܕܕܩ ܗܘܐ ܐܝܬ ܗܘܐ ܠܗ ܫܘܒܗܪܐ ܐܠܐ ܠܐ ܠܘܬ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.3",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Romans 4:3",
      "text": "ܡܢܐ ܓܝܪ ܐܡܪ ܟܬܒܐ ܕܗܝܡܢ ܐܒܪܗܡ ܠܐܠܗܐ ܘܐܬܚܫܒܬ ܠܗ ܠܙܕܝܩܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.4",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Romans 4:4",
      "text": "ܠܡܢ ܕܦܠܚ ܕܝܢ ܠܐ ܡܬܚܫܒ ܠܗ ܐܓܪܗ ܐܝܟ ܕܒܛܝܒܘ ܐܠܐ ܐܝܟ ܡܢ ܕܡܬܬܚܝܒ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.5",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Romans 4:5",
      "text": "ܠܗܘ ܕܝܢ ܕܠܐ ܦܠܚ ܐܠܐ ܗܝܡܢ ܒܠܚܘܕ ܒܡܢ ܕܡܙܕܩ ܠܚܛܝܐ ܡܬܚܫܒܐ ܠܗ ܗܝܡܢܘܬܗ ܠܟܐܢܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.6",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Romans 4:6",
      "text": "ܐܝܟܢܐ ܕܐܦ ܕܘܝܕ ܐܡܪ ܥܠ ܛܘܒܗ ܕܓܒܪܐ ܐܝܢܐ ܕܐܠܗܐ ܚܫܒ ܠܗ ܙܕܝܩܘܬܐ ܕܠܐ ܥܒܕܐ ܟܕ ܐܡܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.7",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Romans 4:7",
      "text": "ܕܛܘܒܝܗܘܢ ܠܐܝܠܝܢ ܕܐܫܬܒܩ ܠܗܘܢ ܥܘܠܗܘܢ ܘܐܬܟܤܝܘ ܚܛܗܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.8",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Romans 4:8",
      "text": "ܘܛܘܒܘܗܝ ܠܓܒܪܐ ܕܠܐ ܢܚܫܘܒ ܠܗ ܐܠܗܐ ܚܛܝܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.9",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Romans 4:9",
      "text": "ܗܢܐ ܗܟܝܠ ܛܘܒܐ ܥܠ ܓܙܘܪܬܐ ܗܘ ܐܘ ܥܠ ܥܘܪܠܘܬܐ ܐܡܪܝܢܢ ܓܝܪ ܕܐܬܚܫܒܬ ܠܐܒܪܗܡ ܗܝܡܢܘܬܗ ܠܟܐܢܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.10",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Romans 4:10",
      "text": "ܐܝܟܢܐ ܗܟܝܠ ܐܬܚܫܒܬ ܠܗ ܒܓܙܘܪܬܐ ܐܘ ܒܥܘܪܠܘܬܐ ܠܐ ܗܘܐ ܒܓܙܘܪܬܐ ܐܠܐ ܒܥܘܪܠܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.11",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Romans 4:11",
      "text": "ܐܬܐ ܗܘ ܓܝܪ ܫܩܠܗ ܠܓܙܘܪܬܐ ܘܚܬܡܐ ܕܟܐܢܘܬܐ ܕܗܝܡܢܘܬܗ ܕܒܥܘܪܠܘܬܐ ܕܢܗܘܐ ܐܒܐ ܠܟܠܗܘܢ ܐܝܠܝܢ ܕܡܗܝܡܢܝܢ ܡܢ ܥܘܪܠܘܬܐ ܕܬܬܚܫܒ ܐܦ ܠܗܘܢ ܠܟܐܢܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.12",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Romans 4:12",
      "text": "ܘܐܒܐ ܠܓܙܘܪܬܐ ܠܐ ܗܘܐ ܠܐܝܠܝܢ ܕܡܢ ܓܙܘܪܬܐ ܐܢܘܢ ܒܠܚܘܕ ܐܠܐ ܐܦ ܠܐܝܠܝܢ ܕܫܠܡܝܢ ܠܥܩܒܬܐ ܕܗܝܡܢܘܬܐ ܕܥܘܪܠܘܬܐ ܕܐܒܘܢ ܐܒܪܗܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.13",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Romans 4:13",
      "text": "ܠܐ ܗܘܐ ܓܝܪ ܒܢܡܘܤܐ ܗܘܐ ܡܘܠܟܢܐ ܠܐܒܪܗܡ ܘܠܙܪܥܗ ܕܢܗܘܐ ܝܪܬܐ ܠܥܠܡܐ ܐܠܐ ܒܟܐܢܘܬܐ ܕܗܝܡܢܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.14",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Romans 4:14",
      "text": "ܐܠܘ ܓܝܪ ܗܠܝܢ ܕܡܢ ܢܡܘܤܐ ܗܘܘ ܝܪܬܐ ܤܪܝܩܐ ܗܘܬ ܗܝܡܢܘܬܐ ܘܡܒܛܠ ܗܘܐ ܡܘܠܟܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.15",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Romans 4:15",
      "text": "ܢܡܘܤܐ ܓܝܪ ܡܥܒܕܢܐ ܗܘ ܕܪܘܓܙܐ ܟܪ ܕܠܝܬ ܓܝܪ ܢܡܘܤܐ ܐܦܠܐ ܥܒܪ ܢܡܘܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.16",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Romans 4:16",
      "text": "ܡܛܠ ܗܢܐ ܒܗܝܡܢܘܬܐ ܕܒܛܝܒܘܬܐ ܢܙܕܕܩ ܘܢܗܘܐ ܫܪܝܪ ܡܘܠܟܢܐ ܠܟܠܗ ܙܪܥܗ ܠܐ ܠܐܝܢܐ ܕܡܢ ܢܡܘܤܐ ܗܘ ܒܠܚܘܕ ܐܠܐ ܐܦ ܠܐܝܢܐ ܕܡܢ ܗܝܡܢܘܬܐ ܗܘ ܕܐܒܪܗܡ ܕܐܝܬܘܗܝ ܐܒܐ ܕܟܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.17",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Romans 4:17",
      "text": "ܐܝܟܢܐ ܕܟܬܝܒ ܕܤܡܬܟ ܐܒܐ ܠܤܘܓܐܐ ܕܥܡܡܐ ܩܕܡ ܐܠܗܐ ܗܘ ܕܗܝܡܢܬ ܒܗ ܕܡܚܐ ܡܝܬܐ ܘܩܪܐ ܠܐܝܠܝܢ ܕܠܐ ܐܝܬܝܗܘܢ ܐܝܟ ܐܝܬܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.18",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Romans 4:18",
      "text": "ܘܕܠܐ ܤܒܪܐ ܠܤܒܪܐ ܗܝܡܢ ܕܢܗܘܐ ܐܒܐ ܠܤܘܓܐܐ ܕܥܡܡܐ ܐܝܟ ܕܟܬܝܒ ܕܗܟܢܐ ܢܗܘܐ ܙܪܥܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.19",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Romans 4:19",
      "text": "ܘܠܐ ܐܬܟܪܗ ܒܗܝܡܢܘܬܗ ܟܕ ܡܬܒܩܐ ܒܦܓܪܗ ܡܝܬܐ ܕܗܘܐ ܒܪ ܡܐܐ ܫܢܝܢ ܘܒܡܪܒܥܐ ܡܝܬܐ ܕܤܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.20",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Romans 4:20",
      "text": "ܘܒܡܘܠܟܢܐ ܕܐܠܗܐ ܠܐ ܐܬܦܠܓ ܐܝܟ ܚܤܝܪ ܗܝܡܢܘܬܐ ܐܠܐ ܐܬܚܝܠ ܒܗܝܡܢܘܬܐ ܘܝܗܒ ܬܫܒܘܚܬܐ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.21",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Romans 4:21",
      "text": "ܘܐܫܪ ܕܡܕܡ ܕܡܠܟ ܠܗ ܐܠܗܐ ܡܫܟܚ ܠܡܓܡܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.22",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Romans 4:22",
      "text": "ܡܛܠ ܗܢܐ ܐܬܚܫܒܬ ܠܗ ܠܟܐܢܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.23",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Romans 4:23",
      "text": "ܘܠܐ ܗܘܐ ܡܛܠܬܗ ܒܠܚܘܕ ܐܬܟܬܒܬ ܗܕܐ ܕܐܬܚܫܒܬ ܗܝܡܢܘܬܗ ܠܟܐܢܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.24",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Romans 4:24",
      "text": "ܐܠܐ ܐܦ ܡܛܠܬܢ ܕܐܦܠܢ ܥܬܝܕ ܗܘ ܕܢܚܫܘܒ ܐܝܠܝܢ ܕܗܝܡܢܢ ܒܡܢ ܕܐܩܝܡ ܠܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܡܢ ܒܝܬ ܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.4.25",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Romans 4:25",
      "text": "ܕܗܘ ܐܫܬܠܡ ܡܛܠ ܚܛܗܝܢ ܘܩܡ ܡܛܠ ܕܢܙܕܩܢ ܀",
      "paragraphStart": false
    }
  ]
}
