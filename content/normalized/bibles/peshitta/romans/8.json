  },
  "verses": [
    {
      "id": "peshitta:romans.8.1",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Romans 8:1",
      "text": "ܡܟܝܠ ܠܝܬ ܚܝܒܘܬܐ ܠܐܝܠܝܢ ܕܠܐ ܡܗܠܟܝܢ ܒܒܤܪ ܒܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:romans.8.2",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Romans 8:2",
      "text": "ܢܡܘܤܐ ܓܝܪ ܕܪܘܚܐ ܕܚܝܐ ܕܒܝܫܘܥ ܡܫܝܚܐ ܚܪܪܟ ܡܢ ܢܡܘܤܐ ܕܚܛܝܬܐ ܘܕܡܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.3",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Romans 8:3",
      "text": "ܡܛܠ ܕܡܚܝܠ ܗܘܐ ܓܝܪ ܢܡܘܤܐ ܒܝܕ ܟܪܝܗܘܬܗ ܕܒܤܪܐ ܫܕܪ ܐܠܗܐ ܠܒܪܗ ܒܕܡܘܬܐ ܕܒܤܪܐ ܕܚܛܝܬܐ ܡܛܠܬܗ ܕܚܛܝܬܐ ܕܢܚܝܒܝܗ ܠܚܛܝܬܐ ܒܒܤܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.4",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Romans 8:4",
      "text": "ܕܟܐܢܘܬܐ ܕܢܡܘܤܐ ܒܢ ܬܬܡܠܐ ܕܠܐ ܗܘܐ ܒܒܤܪ ܡܗܠܟܝܢܢ ܐܠܐ ܒܪܘܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.5",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Romans 8:5",
      "text": "ܐܝܠܝܢ ܓܝܪ ܕܒܒܤܪ ܐܢܘܢ ܕܒܤܪ ܗܘ ܡܬܪܥܝܢ ܘܐܝܠܝܢ ܕܕܪܘܚ ܐܢܘܢ ܕܪܘܚ ܗܘ ܡܬܪܥܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.6",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Romans 8:6",
      "text": "ܬܪܥܝܬܐ ܓܝܪ ܕܒܤܪܐ ܡܘܬܐ ܗܘ ܘܬܪܥܝܬܐ ܕܪܘܚܐ ܚܝܐ ܘܫܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.7",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Romans 8:7",
      "text": "ܡܛܠ ܕܬܪܥܝܬܐ ܕܒܤܪܐ ܒܥܠܕܒܒܘܬܐ ܗܝ ܠܘܬ ܐܠܗܐ ܠܢܡܘܤܐ ܓܝܪ ܕܐܠܗܐ ܠܐ ܡܫܬܥܒܕܐ ܡܛܠ ܕܠܐ ܡܫܟܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.8",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Romans 8:8",
      "text": "ܘܐܝܠܝܢ ܕܒܒܤܪ ܐܢܘܢ ܠܡܫܦܪ ܠܐܠܗܐ ܠܐ ܡܫܟܚܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.9",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Romans 8:9",
      "text": "ܐܢܬܘܢ ܕܝܢ ܠܐ ܗܘܝܬܘܢ ܒܒܤܪ ܐܠܐ ܒܪܘܚ ܐܢ ܫܪܝܪܐܝܬ ܪܘܚܗ ܕܐܠܗܐ ܥܡܪܐ ܒܟܘܢ ܐܢ ܕܝܢ ܐܢܫ ܠܝܬ ܒܗ ܪܘܚܗ ܕܡܫܝܚܐ ܗܢܐ ܠܐ ܗܘܐ ܕܝܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.10",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Romans 8:10",
      "text": "ܘܐܢ ܕܝܢ ܡܫܝܚܐ ܒܟܘܢ ܦܓܪܐ ܡܝܬ ܗܘ ܡܛܠ ܚܛܝܬܐ ܪܘܚܐ ܕܝܢ ܚܝܐ ܗܝ ܡܛܠ ܟܐܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.11",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Romans 8:11",
      "text": "ܘܐܢ ܪܘܚܗ ܕܗܘ ܡܢ ܕܐܩܝܡ ܠܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܡܢ ܒܝܬ ܡܝܬܐ ܥܡܪܐ ܒܟܘܢ ܗܘ ܡܢ ܕܐܩܝܡܗ ܠܝܫܘܥ ܡܫܝܚܐ ܡܢ ܒܝܬ ܡܝܬܐ ܐܦ ܠܦܓܪܝܟܘܢ ܡܝܬܐ ܢܚܐ ܡܛܠ ܪܘܚܗ ܕܥܡܪܐ ܒܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.12",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Romans 8:12",
      "text": "ܗܫܐ ܐܚܝ ܚܝܒܝܢܢ ܠܘ ܠܒܤܪܐ ܕܒܒܤܪ ܢܗܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.13",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Romans 8:13",
      "text": "ܐܢ ܓܝܪ ܒܒܤܪ ܚܐܝܢ ܐܢܬܘܢ ܥܬܝܕܝܢ ܐܢܬܘܢ ܗܘ ܠܡܡܬ ܘܐܢ ܒܪܘܚ ܗܘܦܟܝ ܦܓܪܐ ܡܡܝܬܝܢ ܐܢܬܘܢ ܚܐܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.14",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Romans 8:14",
      "text": "ܐܝܠܝܢ ܓܝܪ ܕܒܪܘܚܐ ܕܐܠܗܐ ܡܬܕܒܪܝܢ ܗܠܝܢ ܒܢܝܐ ܐܢܘܢ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.15",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Romans 8:15",
      "text": "ܠܐ ܓܝܪ ܢܤܒܬܘܢ ܪܘܚܐ ܕܥܒܕܘܬܐ ܬܘܒ ܠܕܚܠܬܐ ܐܠܐ ܢܤܒܬܘܢ ܪܘܚܐ ܕܤܝܡܬ ܒܢܝܐ ܕܒܗ ܩܪܝܢܢ ܐܒܐ ܐܒܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.16",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Romans 8:16",
      "text": "ܘܗܝ ܪܘܚܐ ܡܤܗܕܐ ܠܪܘܚܢ ܕܐܝܬܝܢ ܒܢܝܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.17",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Romans 8:17",
      "text": "ܘܐܢ ܒܢܝܐ ܐܦ ܝܪܬܐ ܝܪܬܐ ܕܐܠܗܐ ܘܒܢܝ ܝܪܬܘܬܗ ܕܝܫܘܥ ܡܫܝܚܐ ܕܐܢ ܢܚܫ ܥܡܗ ܐܦ ܥܡܗ ܢܫܬܒܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.18",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Romans 8:18",
      "text": "ܡܬܪܥܐ ܐܢܐ ܓܝܪ ܕܠܐ ܫܘܝܢ ܚܫܘܗܝ ܕܙܒܢܐ ܗܢܐ ܠܬܫܒܘܚܬܐ ܐܝܕܐ ܕܥܬܝܕܐ ܕܬܬܓܠܐ ܒܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.19",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Romans 8:19",
      "text": "ܟܠܗ ܓܝܪ ܒܪܝܬܐ ܡܤܒܪܐ ܘܡܤܟܝܐ ܠܓܠܝܢܐ ܕܒܢܘܗܝ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.20",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "Romans 8:20",
      "text": "ܒܪܝܬܐ ܓܝܪ ܐܫܬܥܒܕܬ ܠܤܪܝܩܘܬܐ ܠܐ ܒܨܒܝܢܗ ܐܠܐ ܡܛܠ ܡܢ ܕܫܥܒܕܗ ܥܠ ܤܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.21",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "Romans 8:21",
      "text": "ܕܐܦ ܗܝ ܒܪܝܬܐ ܬܬܚܪܪ ܡܢ ܥܒܕܘܬܐ ܕܚܒܠܐ ܒܚܪܘܪܐ ܕܬܫܒܘܚܬܐ ܕܒܢܝܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.22",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "Romans 8:22",
      "text": "ܝܕܥܝܢܢ ܓܝܪ ܕܟܠܗܝܢ ܒܪܝܬܐ ܡܬܬܢܚܢ ܘܡܚܒܠܢ ܥܕܡܐ ܠܝܘܡܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.23",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "Romans 8:23",
      "text": "ܘܠܐ ܒܠܚܘܕ ܗܢܝܢ ܐܠܐ ܐܦ ܚܢܢ ܕܐܝܬ ܒܢ ܪܫܝܬܐ ܕܪܘܚܐ ܡܬܬܢܚܝܢܢ ܒܢܦܫܢ ܘܡܤܟܝܢܢ ܠܤܝܡܬ ܒܢܝܐ ܘܠܦܘܪܩܢܐ ܕܦܓܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.24",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "Romans 8:24",
      "text": "ܡܛܠ ܕܒܤܒܪܐ ܗܘ ܚܝܝܢ ܤܒܪܐ ܕܝܢ ܕܡܬܚܙܐ ܠܐ ܗܘܐ ܤܒܪܐ ܐܢ ܓܝܪ ܚܙܝܢܢ ܠܗ ܡܢܐ ܡܤܟܝܢܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.25",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 25,
      "referenceLabel": "Romans 8:25",
      "text": "ܐܢ ܕܝܢ ܠܡܕܡ ܕܠܐ ܡܬܚܙܐ ܡܤܒܪܝܢܢ ܒܡܤܝܒܪܢܘܬܐ ܡܩܘܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.26",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 26,
      "referenceLabel": "Romans 8:26",
      "text": "ܗܟܢܐ ܐܦ ܗܝ ܪܘܚܐ ܡܥܕܪܐ ܠܟܪܝܗܘܬܢ ܡܢܐ ܓܝܪ ܢܨܠܐ ܐܝܟ ܡܐ ܕܘܠܐ ܠܐ ܝܕܥܝܢܢ ܐܠܐ ܗܝ ܪܘܚܐ ܡܨܠܝܐ ܚܠܦܝܢ ܒܬܢܚܬܐ ܕܠܐ ܡܬܡܠܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.27",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 27,
      "referenceLabel": "Romans 8:27",
      "text": "ܕܡܐܫ ܕܝܢ ܠܒܘܬܐ ܗܘ ܝܕܥ ܡܢܐ ܗܝ ܬܪܥܝܬܐ ܕܪܘܚܐ ܕܐܝܟ ܨܒܝܢܗ ܗܘ ܕܐܠܗܐ ܡܨܠܝܐ ܚܠܦ ܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.28",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 28,
      "referenceLabel": "Romans 8:28",
      "text": "ܝܕܥܝܢܢ ܕܝܢ ܕܐܝܠܝܢ ܕܡܚܒܝܢ ܠܐܠܗܐ ܒܟܠ ܡܕܡ ܡܥܕܪ ܠܗܘܢ ܠܛܒܬܐ ܠܐܝܠܝܢ ܕܩܕܡ ܤܡ ܕܢܗܘܘܢ ܩܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.29",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 29,
      "referenceLabel": "Romans 8:29",
      "text": "ܘܡܢ ܠܘܩܕܡ ܝܕܥ ܐܢܘܢ ܘܪܫܡ ܐܢܘܢ ܒܕܡܘܬܐ ܕܨܘܪܬܐ ܕܒܪܗ ܕܗܘ ܢܗܘܐ ܒܘܟܪܐ ܕܐܚܐ ܤܓܝܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.30",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 30,
      "referenceLabel": "Romans 8:30",
      "text": "ܠܐܝܠܝܢ ܕܝܢ ܕܩܕܡ ܪܫܡ ܠܗܘܢ ܩܪܐ ܘܠܐܝܠܝܢ ܕܩܪܐ ܠܗܘܢ ܙܕܩ ܘܠܐܝܠܝܢ ܕܙܕܩ ܠܗܘܢ ܫܒܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.31",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 31,
      "referenceLabel": "Romans 8:31",
      "text": "ܡܢܐ ܗܟܝܠ ܢܐܡܪ ܥܠ ܗܠܝܢ ܐܢ ܐܠܗܐ ܚܠܦܝܢ ܡܢܘ ܕܠܩܘܒܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.32",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 32,
      "referenceLabel": "Romans 8:32",
      "text": "ܘܐܢ ܥܠ ܒܪܗ ܠܐ ܚܤ ܐܠܐ ܚܠܦ ܟܠܢ ܐܫܠܡܗ ܐܝܟܢܐ ܠܐ ܟܠ ܡܕܡ ܥܡܗ ܢܬܠ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.33",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 33,
      "referenceLabel": "Romans 8:33",
      "text": "ܡܢܘ ܢܩܒܘܠ ܥܠ ܓܒܝܐ ܕܐܠܗܐ ܐܠܗܐ ܡܙܕܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.34",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 34,
      "referenceLabel": "Romans 8:34",
      "text": "ܡܢܘ ܡܚܝܒ ܡܫܝܚܐ ܡܝܬ ܘܩܡ ܘܐܝܬܘܗܝ ܥܠ ܝܡܝܢܐ ܕܐܠܗܐ ܘܒܥܐ ܚܠܦܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.35",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 35,
      "referenceLabel": "Romans 8:35",
      "text": "ܡܢܘ ܢܦܪܫܢܝ ܡܢ ܚܘܒܗ ܕܡܫܝܚܐ ܐܘܠܨܢܐ ܐܘ ܚܒܘܫܝܐ ܐܘ ܪܕܘܦܝܐ ܐܘ ܟܦܢܐ ܐܘ ܥܪܛܠܝܘܬܐ ܐܘ ܩܢܕܝܢܘܤ ܐܘ ܤܝܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.8.36",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 36,
