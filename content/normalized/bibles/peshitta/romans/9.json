{
  "chapter": {
    "id": "peshitta:romans.9",
    "translationId": "peshitta",
    "bookSlug": "romans",
    "chapterNumber": 9,
    "referenceLabel": "Romans 9",
    "summary": "Source text for Romans 9 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:romans.9.1",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Romans 9:1",
      "text": "ܩܘܫܬܐ ܐܡܪ ܐܢܐ ܒܡܫܝܚܐ ܘܠܐ ܡܕܓܠ ܐܢܐ ܘܪܥܝܢܝ ܡܤܗܕ ܥܠܝ ܒܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:romans.9.2",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Romans 9:2",
      "text": "ܕܟܪܝܘܬܐ ܗܝ ܠܝ ܪܒܬܐ ܘܟܐܒܐ ܕܡܢ ܠܒܝ ܠܐ ܫܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.3",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Romans 9:3",
      "text": "ܡܨܠܐ ܗܘܝܬ ܓܝܪ ܕܐܢܐ ܩܢܘܡܝ ܚܪܡܐ ܐܗܘܐ ܡܢ ܡܫܝܚܐ ܚܠܦ ܐܚܝ ܘܐܚܝܢܝ ܕܒܒܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.4",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Romans 9:4",
      "text": "ܕܐܝܬܝܗܘܢ ܒܢܝ ܐܝܤܪܝܠ ܕܕܝܠܗܘܢ ܗܘܬ ܤܝܡܬ ܒܢܝܐ ܘܬܫܒܘܚܬܐ ܘܩܝܡܐ ܘܢܡܘܤܐ ܘܬܫܡܫܬܐ ܕܒܗ ܘܡܘܠܟܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.5",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Romans 9:5",
      "text": "ܘܐܒܗܬܐ ܘܡܢܗܘܢ ܐܬܚܙܝ ܡܫܝܚܐ ܒܒܤܪ ܕܐܝܬܘܗܝ ܐܠܗܐ ܕܥܠ ܟܠ ܕܠܗ ܬܫܒܚܢ ܘܒܘܪܟܢ ܠܥܠܡ ܥܠܡܝܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.6",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Romans 9:6",
      "text": "ܠܐ ܗܘܐ ܕܝܢ ܡܦܠ ܢܦܠܬ ܡܠܬܗ ܕܐܠܗܐ ܠܐ ܗܘܐ ܓܝܪ ܟܠܗܘܢ ܕܡܢ ܐܝܤܪܝܠ ܐܝܬܝܗܘܢ ܐܝܤܪܝܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.7",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Romans 9:7",
      "text": "ܐܦܠܐ ܡܛܠ ܕܡܢ ܙܪܥܗ ܐܢܘܢ ܕܐܒܪܗܡ ܟܠܗܘܢ ܒܢܝܐ ܡܛܠ ܕܐܬܐܡܪ ܕܒܐܝܤܚܩ ܢܬܩܪܐ ܠܟ ܙܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.8",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Romans 9:8",
      "text": "ܗܢܘ ܕܝܢ ܠܐ ܗܘܐ ܒܢܝܐ ܕܒܤܪܐ ܐܝܬܝܗܘܢ ܒܢܝܐ ܕܐܠܗܐ ܐܠܐ ܒܢܝܐ ܕܡܘܠܟܢܐ ܡܬܚܫܒܝܢ ܠܙܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.9",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Romans 9:9",
      "text": "ܕܡܘܠܟܢܐ ܓܝܪ ܐܝܬܝܗ ܡܠܬܐ ܗܕܐ ܕܒܙܒܢܐ ܗܢܐ ܐܬܐ ܘܢܗܘܐ ܒܪܐ ܠܤܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.10",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Romans 9:10",
      "text": "ܘܠܘ ܗܕܐ ܒܠܚܘܕ ܐܠܐ ܐܦ ܪܦܩܐ ܟܕ ܥܡ ܚܕ ܐܒܘܢ ܐܝܤܚܩ ܐܝܬ ܗܘܐ ܠܗ ܫܘܬܦܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.11",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Romans 9:11",
      "text": "ܥܕܠܐ ܢܬܝܠܕܘܢ ܒܢܝܗ ܘܠܐ ܢܤܥܪܘܢ ܛܒܬܐ ܐܘ ܒܝܫܬܐ ܩܕܡܬ ܐܬܝܕܥܬ ܓܒܝܘܬܗ ܕܐܠܗܐ ܕܗܝ ܬܩܘܐ ܠܐ ܒܥܒܕܐ ܐܠܐ ܒܝܕ ܡܢ ܕܩܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.12",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Romans 9:12",
      "text": "ܐܬܐܡܪ ܓܝܪ ܕܩܫܝܫܐ ܢܗܘܐ ܥܒܕܐ ܠܙܥܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.13",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Romans 9:13",
      "text": "ܐܝܟ ܕܟܬܝܒ ܕܠܝܥܩܘܒ ܪܚܡܬ ܘܠܥܤܘ ܤܢܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.14",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Romans 9:14",
      "text": "ܡܢܐ ܗܟܝܠ ܢܐܡܪ ܕܠܡܐ ܥܘܠܐ ܐܝܬ ܠܘܬ ܐܠܗܐ ܚܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.15",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Romans 9:15",
      "text": "ܗܐ ܐܦ ܠܡܘܫܐ ܐܡܪ ܐܪܚܡ ܥܠ ܐܝܢܐ ܕܡܪܚܡ ܐܢܐ ܘܐܚܘܢ ܠܐܝܢܐ ܕܚܐܢ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.16",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Romans 9:16",
      "text": "ܠܐ ܗܟܝܠ ܒܐܝܕܝ ܡܢ ܕܨܒܐ ܘܠܐ ܒܐܝܕܝ ܡܢ ܕܪܗܛ ܐܠܐ ܒܐܝܕܝ ܐܠܗܐ ܡܪܚܡܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.17",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Romans 9:17",
      "text": "ܐܡܪ ܓܝܪ ܒܟܬܒܐ ܠܦܪܥܘܢ ܕܠܗ ܠܗܕܐ ܐܩܝܡܬܟ ܕܐܚܘܐ ܒܟ ܚܝܠܝ ܘܕܢܬܟܪܙ ܫܡܝ ܒܐܪܥܐ ܟܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.18",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Romans 9:18",
      "text": "ܡܕܝܢ ܥܠ ܡܢ ܕܨܒܐ ܗܘ ܡܪܚܡ ܘܥܠ ܡܢ ܕܨܒܐ ܡܩܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.19",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Romans 9:19",
      "text": "ܘܟܒܪ ܬܐܡܪ ܕܠܡܢܐ ܪܫܐ ܡܢܘ ܓܝܪ ܕܢܩܘܡ ܠܘܩܒܠ ܨܒܝܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.20",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Romans 9:20",
      "text": "ܐܢܬ ܗܟܝܠ ܡܢ ܐܢܬ ܐܘ ܒܪܢܫܐ ܕܦܬܓܡܐ ܠܐܠܗܐ ܝܗܒ ܐܢܬ ܕܠܡܐ ܐܡܪܐ ܓܒܝܠܬܐ ܠܡܢ ܕܓܒܠܗ ܕܠܡܢܐ ܗܟܢܐ ܓܒܠܬܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.21",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Romans 9:21",
      "text": "ܐܘ ܠܐ ܫܠܝܛ ܦܚܪܐ ܥܠ ܛܝܢܗ ܕܡܢܗ ܡܢ ܓܒܝܠܬܐ ܢܥܒܕ ܡܐܢܐ ܚܕ ܠܐܝܩܪܐ ܘܚܕ ܠܨܥܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.22",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "Romans 9:22",
      "text": "ܐܢ ܕܝܢ ܨܒܐ ܐܠܗܐ ܕܢܚܘܐ ܪܘܓܙܗ ܘܢܘܕܥ ܚܝܠܗ ܐܝܬܝ ܒܤܘܓܐܐ ܕܡܓܪܬ ܪܘܚܗ ܪܘܓܙܐ ܥܠ ܡܐܢܐ ܕܪܘܓܙܐ ܕܓܡܝܪܝܢ ܠܐܒܕܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.23",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "Romans 9:23",
      "text": "ܘܐܫܦܥ ܪܚܡܘܗܝ ܥܠ ܡܐܢܐ ܕܪܚܡܐ ܕܡܛܝܒܝܢ ܗܘܘ ܠܐܠܗܐ ܠܬܫܒܘܚܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.24",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "Romans 9:24",
      "text": "ܕܐܝܬܝܢ ܚܢܢ ܩܪܝܐ ܠܐ ܗܘܐ ܒܠܚܘܕ ܡܢ ܝܗܘܕܝܐ ܐܠܐ ܐܦ ܡܢ ܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.25",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "Romans 9:25",
      "text": "ܐܝܟܢܐ ܕܐܦ ܒܗܘܫܥ ܐܡܪ ܕܐܩܪܐ ܠܐܝܠܝܢ ܕܠܐ ܗܘܘ ܥܡܝ ܥܡܐ ܕܝܠܝ ܘܠܠܐ ܐܬܪܚܡܬ ܐܬܪܚܡܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.26",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "Romans 9:26",
      "text": "ܢܗܘܐ ܓܝܪ ܒܕܘܟܬܐ ܟܪ ܕܡܬܩܪܝܢ ܗܘܘ ܠܐ ܥܡܝ ܬܡܢ ܢܬܩܪܘܢ ܒܢܝܐ ܠܐܠܗܐ ܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.27",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "Romans 9:27",
      "text": "ܐܫܥܝܐ ܕܝܢ ܐܟܪܙ ܥܠ ܒܢܝ ܐܝܤܪܝܠ ܕܐܢ ܢܗܘܐ ܡܢܝܢܐ ܕܒܢܝ ܐܝܤܪܝܠ ܐܝܟ ܚܠܐ ܕܒܝܡܐ ܫܪܟܢܐ ܕܡܢܗܘܢ ܢܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.28",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "Romans 9:28",
      "text": "ܡܠܬܐ ܓܪܡ ܘܦܤܩ ܘܢܥܒܕܝܗ ܡܪܝܐ ܥܠ ܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.29",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 29,
      "referenceLabel": "Romans 9:29",
      "text": "ܘܐܝܟ ܡܕܡ ܕܩܕܡ ܐܡܪ ܗܘ ܐܫܥܝܐ ܕܐܠܘ ܠܐ ܡܪܝܐ ܨܒܐܘܬ ܐܘܬܪ ܠܢ ܤܪܝܕܐ ܐܝܟ ܤܕܘܡ ܗܘܝܢ ܗܘܝܢ ܘܠܥܡܘܪܐ ܡܬܕܡܝܢ ܗܘܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.30",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 30,
      "referenceLabel": "Romans 9:30",
      "text": "ܡܢܐ ܗܟܝܠ ܢܐܡܪ ܕܥܡܡܐ ܕܠܐ ܪܗܛܝܢ ܗܘܘ ܒܬܪ ܟܐܢܘܬܐ ܐܕܪܟܘ ܟܐܢܘܬܐ ܟܐܢܘܬܐ ܕܝܢ ܐܝܕܐ ܕܡܢ ܗܝܡܢܘܬܐ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.31",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 31,
      "referenceLabel": "Romans 9:31",
      "text": "ܐܝܤܪܝܠ ܕܝܢ ܕܪܗܛ ܗܘܐ ܒܬܪ ܢܡܘܤܐ ܕܟܐܢܘܬܐ ܠܢܡܘܤܐ ܕܟܐܢܘܬܐ ܠܐ ܐܕܪܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.32",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 32,
      "referenceLabel": "Romans 9:32",
      "text": "ܡܛܠ ܡܢܐ ܡܛܠ ܕܠܐ ܗܘܐ ܡܢ ܗܝܡܢܘܬܐ ܐܠܐ ܡܢ ܥܒܕܘܗܝ ܕܢܡܘܤܐ ܐܬܬܩܠܘ ܓܝܪ ܒܟܐܦܐ ܕܬܘܩܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.9.33",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 33,
      "referenceLabel": "Romans 9:33",
      "text": "ܐܝܟ ܕܟܬܝܒ ܕܗܐ ܤܐܡ ܐܢܐ ܒܨܗܝܘܢ ܟܐܦܐ ܕܬܘܩܠܬܐ ܘܟܐܦܐ ܕܡܟܫܘܠܐ ܘܡܢ ܕܒܗ ܢܗܝܡܢ ܠܐ ܢܒܗܬ ܀",
      "paragraphStart": false
    }
  ]
}
