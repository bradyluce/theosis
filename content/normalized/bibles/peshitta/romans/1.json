{
  "chapter": {
    "id": "peshitta:romans.1",
    "translationId": "peshitta",
    "bookSlug": "romans",
    "chapterNumber": 1,
    "referenceLabel": "Romans 1",
    "summary": "Source text for Romans 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:romans.1.1",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Romans 1:1",
      "text": "ܦܘܠܘܤ ܥܒܕܐ ܕܝܫܘܥ ܡܫܝܚܐ ܩܪܝܐ ܘܫܠܝܚܐ ܕܐܬܦܪܫ ܠܐܘܢܓܠܝܘܢ ܕܐܠܗܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:romans.1.2",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Romans 1:2",
      "text": "ܕܡܢ ܩܕܝܡ ܡܠܟ ܒܝܕ ܢܒܝܘܗܝ ܒܟܬܒܐ ܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.3",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Romans 1:3",
      "text": "ܥܠ ܒܪܗ ܗܘ ܕܐܬܝܠܕ ܒܒܤܪ ܡܢ ܙܪܥܐ ܕܒܝܬ ܕܘܝܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.4",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Romans 1:4",
      "text": "ܘܐܬܝܕܥ ܒܪܐ ܕܐܠܗܐ ܒܚܝܠ ܘܒܪܘܚ ܩܕܘܫ ܕܩܡ ܡܢ ܒܝܬ ܡܝܬܐ ܝܫܘܥ ܡܫܝܚܐ ܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.5",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Romans 1:5",
      "text": "ܕܒܗ ܢܤܒܢ ܛܝܒܘܬܐ ܘܫܠܝܚܘܬܐ ܒܟܠܗܘܢ ܥܡܡܐ ܐܝܟ ܕܢܫܬܡܥܘܢ ܠܗܝܡܢܘܬܐ ܕܫܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.6",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Romans 1:6",
      "text": "ܕܐܦ ܐܢܬܘܢ ܡܢܗܘܢ ܐܢܬܘܢ ܩܪܝܐ ܒܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.7",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Romans 1:7",
      "text": "ܠܟܠܗܘܢ ܕܒܪܗܘܡܝ ܚܒܝܒܘܗܝ ܕܐܠܗܐ ܩܪܝܐ ܘܩܕܝܫܐ ܫܠܡܐ ܘܛܝܒܘܬܐ ܥܡܟܘܢ ܡܢ ܐܠܗܐ ܐܒܘܢ ܘܡܢ ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.8",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Romans 1:8",
      "text": "ܠܘܩܕܡ ܡܘܕܐ ܐܢܐ ܠܐܠܗܝ ܒܝܫܘܥ ܡܫܝܚܐ ܥܠ ܟܠܟܘܢ ܕܗܝܡܢܘܬܟܘܢ ܐܫܬܡܥܬ ܒܟܠܗ ܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.9",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Romans 1:9",
      "text": "ܤܗܕ ܗܘ ܠܝ ܓܝܪ ܐܠܗܐ ܕܠܗ ܡܫܡܫ ܐܢܐ ܒܪܘܚ ܒܐܘܢܓܠܝܘܢ ܕܒܪܗ ܕܕܠܐ ܫܠܘܐ ܒܟܠܙܒܢ ܡܬܕܟܪ ܐܢܐ ܠܟܘܢ ܒܨܠܘܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.10",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Romans 1:10",
      "text": "ܘܡܬܚܢܢ ܐܢܐ ܕܐܢ ܡܢ ܟܕܘ ܬܬܦܬܚ ܠܝ ܐܘܪܚܐ ܒܨܒܝܢܗ ܕܐܠܗܐ ܕܐܬܐ ܠܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.11",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Romans 1:11",
      "text": "ܡܛܠ ܕܛܒ ܤܘܐ ܐܢܐ ܕܐܚܙܟܘܢ ܘܐܬܠ ܠܟܘܢ ܡܘܗܒܬܐ ܕܪܘܚ ܕܒܗ ܬܫܬܪܪܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.12",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Romans 1:12",
      "text": "ܘܐܟܚܕܐ ܢܬܒܝܐ ܒܗܝܡܢܘܬܐ ܕܝܠܟܘܢ ܘܕܝܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.13",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Romans 1:13",
      "text": "ܨܒܐ ܐܢܐ ܕܝܢ ܐܚܝ ܕܬܕܥܘܢ ܕܙܒܢܝܢ ܤܓܝܐܢ ܨܒܝܬ ܕܐܬܐ ܠܘܬܟܘܢ ܘܐܬܟܠܝܬ ܥܕܡܐ ܠܗܫܐ ܕܐܦ ܒܟܘܢ ܢܗܘܐ ܠܝ ܐܕܫܐ ܐܝܟ ܕܒܫܪܟܐ ܕܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.14",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Romans 1:14",
      "text": "ܝܘܢܝܐ ܘܒܪܒܪܝܐ ܚܟܝܡܐ ܘܤܟܠܐ ܕܠܟܠܢܫ ܚܝܒ ܐܢܐ ܕܐܟܪܙ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.15",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Romans 1:15",
      "text": "ܘܗܟܢܐ ܡܬܚܦܛ ܐܢܐ ܕܐܦ ܠܟܘܢ ܕܒܪܗܘܡܝ ܐܤܒܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.16",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Romans 1:16",
      "text": "ܠܐ ܓܝܪ ܒܗܬ ܐܢܐ ܒܗ ܒܐܘܢܓܠܝܘܢ ܡܛܠ ܕܚܝܠܐ ܗܘ ܕܐܠܗܐ ܠܚܝܐ ܕܟܠ ܕܡܗܝܡܢܝܢ ܒܗ ܐܢ ܡܢ ܝܗܘܕܝܐ ܠܘܩܕܡ ܘܐܢ ܡܢ ܐܪܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.17",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Romans 1:17",
      "text": "ܟܐܢܘܬܗ ܓܝܪ ܕܐܠܗܐ ܒܗ ܡܬܓܠܝܐ ܡܢ ܗܝܡܢܘܬܐ ܠܗܝܡܢܘܬܐ ܐܝܟ ܕܟܬܝܒ ܕܟܐܢܐ ܡܢ ܗܝܡܢܘܬܐ ܢܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.18",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Romans 1:18",
      "text": "ܡܬܓܠܐ ܗܘ ܓܝܪ ܪܘܓܙܗ ܕܐܠܗܐ ܡܢ ܫܡܝܐ ܥܠ ܟܠܗ ܥܘܠܗܘܢ ܘܪܘܫܥܗܘܢ ܕܒܢܝܢܫܐ ܗܢܘܢ ܕܩܘܫܬܐ ܒܥܘܠܐ ܐܚܝܕܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.19",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Romans 1:19",
      "text": "ܡܛܠ ܕܝܕܝܥܘܬܗ ܕܐܠܗܐ ܓܠܝܐ ܗܝ ܒܗܘܢ ܐܠܗܐ ܓܝܪ ܓܠܗ ܒܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.20",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Romans 1:20",
      "text": "ܟܤܝܬܗ ܓܝܪ ܕܐܠܗܐ ܡܢ ܬܪܡܝܬܗ ܕܥܠܡܐ ܠܒܪܝܬܗ ܒܤܘܟܠܐ ܡܬܚܙܝܢ ܘܚܝܠܗ ܘܐܠܗܘܬܗ ܕܠܥܠܡ ܕܢܗܘܘܢ ܕܠܐ ܡܦܩ ܒܪܘܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.21",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Romans 1:21",
      "text": "ܡܛܠ ܕܝܕܥܘ ܠܐܠܗܐ ܘܠܐ ܐܝܟ ܕܠܐܠܗܐ ܫܒܚܘܗܝ ܘܐܘܕܝܘ ܠܗ ܐܠܐ ܐܤܬܪܩܘ ܒܡܚܫܒܬܗܘܢ ܘܐܬܚܫܟ ܠܒܗܘܢ ܕܠܐ ܡܤܬܟܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.22",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Romans 1:22",
      "text": "ܘܟܕ ܤܒܪܝܢ ܒܢܦܫܗܘܢ ܕܚܟܝܡܝܢ ܐܢܘܢ ܫܛܘ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.23",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Romans 1:23",
      "text": "ܘܚܠܦܘ ܬܫܒܘܚܬܗ ܕܐܠܗܐ ܕܠܐ ܡܬܚܒܠ ܒܕܡܘܬܐ ܕܨܠܡܐ ܕܒܪܢܫܐ ܕܡܬܚܒܠ ܘܒܕܡܘܬܐ ܕܦܪܚܬܐ ܘܕܐܪܒܥܬ ܪܓܠܝܗ ܘܕܪܚܫܐ ܕܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.24",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Romans 1:24",
      "text": "ܡܛܠ ܗܢܐ ܐܫܠܡ ܐܢܘܢ ܐܠܗܐ ܠܪܓܝܓܬܐ ܛܡܐܬܐ ܕܠܒܗܘܢ ܕܢܨܥܪܘܢ ܦܓܪܝܗܘܢ ܒܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.25",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Romans 1:25",
      "text": "ܘܚܠܦܘ ܫܪܪܗ ܕܐܠܗܐ ܒܟܕܒܘܬܐ ܘܕܚܠܘ ܘܫܡܫܘ ܠܒܪܝܬܐ ܛܒ ܡܢ ܕܠܒܪܘܝܗܝܢ ܕܠܗ ܬܫܒܚܢ ܘܒܘܪܟܢ ܠܥܠܡ ܥܠܡܝܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.26",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "Romans 1:26",
      "text": "ܡܛܠ ܗܢܐ ܐܫܠܡ ܐܢܘܢ ܐܠܗܐ ܠܟܐܒܐ ܕܨܥܪܐ ܢܩܒܬܗܘܢ ܓܝܪ ܚܠܦ ܚܫܚܬܐ ܕܟܝܢܗܝܢ ܘܒܡܕܡ ܕܠܐ ܡܟܢ ܐܬܚܫܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.27",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "Romans 1:27",
      "text": "ܘܬܘܒ ܐܦ ܕܟܪܝܗܘܢ ܗܟܢܐ ܫܒܩܘ ܚܫܚܬܐ ܕܟܝܢܐ ܕܢܩܒܬܐ ܘܐܫܬܪܚܘ ܒܪܓܬܐ ܚܕ ܥܠ ܚܕ ܘܕܟܪܐ ܥܠ ܕܟܪܐ ܒܗܬܬܐ ܥܒܕܘ ܘܦܘܪܥܢܐ ܕܙܕܩ ܗܘܐ ܠܛܥܝܘܬܗܘܢ ܒܩܢܘܡܗܘܢ ܩܒܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.28",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "Romans 1:28",
      "text": "ܘܐܝܟ ܕܠܐ ܕܢܘ ܒܢܦܫܗܘܢ ܕܢܕܥܘܢ ܠܐܠܗܐ ܐܫܠܡ ܐܢܘܢ ܐܠܗܐ ܠܡܕܥܐ ܕܤܪܝܩܘܬܐ ܕܢܗܘܘܢ ܥܒܕܝܢ ܡܕܡ ܕܠܐ ܘܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.29",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "Romans 1:29",
      "text": "ܟܕ ܡܠܝܢ ܟܠ ܥܘܠܘܬܐ ܘܙܢܝܘܬܐ ܘܡܪܝܪܘܬܐ ܘܒܝܫܘܬܐ ܘܥܠܘܒܘܬܐ ܘܚܤܡܐ ܘܩܛܠܐ ܘܚܪܝܢܐ ܘܢܟܠܐ ܘܡܚܫܒܬܐ ܒܝܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.30",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "Romans 1:30",
      "text": "ܘܪܛܢܐ ܘܡܐܟܠܩܪܨܐ ܘܤܢܝܐܝܢ ܠܐܠܗܐ ܡܨܥܪܢܐ ܚܬܝܪܐ ܫܒܗܪܢܐ ܡܫܟܚܝ ܒܝܫܬܐ ܚܤܝܪܝ ܪܥܝܢܐ ܕܠܐܒܗܝܗܘܢ ܠܐ ܡܬܛܦܝܤܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.31",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "Romans 1:31",
      "text": "ܘܕܩܝܡܐ ܠܝܬ ܠܗܘܢ ܘܠܐ ܚܘܒܐ ܘܠܐ ܫܝܢܐ ܘܠܐ ܪܚܡܐ ܐܝܬ ܒܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.1.32",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "Romans 1:32",
      "text": "ܐܝܠܝܢ ܕܟܕ ܝܕܥܝܢ ܕܝܢܗ ܕܐܠܗܐ ܕܠܐܝܠܝܢ ܕܐܝܟ ܗܠܝܢ ܤܥܪܝܢ ܠܡܘܬܐ ܡܚܝܒ ܠܐ ܗܘܐ ܒܠܚܘܕ ܥܒܕܝܢ ܠܗܝܢ ܐܠܐ ܐܦ ܡܫܬܘܬܦܝܢ ܠܐܝܠܝܢ ܕܗܠܝܢ ܥܒܕܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
