  },
  "verses": [
    {
      "id": "peshitta:romans.16.1",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Romans 16:1",
      "text": "ܡܓܥܠ ܐܢܐ ܠܟܘܢ ܕܝܢ ܠܦܘܒܐ ܚܬܢ ܕܐܝܬܝܗ ܡܫܡܫܢܝܬܐ ܕܥܕܬܐ ܕܩܢܟܪܐܘܤ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:romans.16.2",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Romans 16:2",
      "text": "ܕܬܩܒܠܘܢܗ ܒܡܪܢ ܐܝܟ ܕܙܕܩ ܠܩܕܝܫܐ ܘܒܟܠ ܨܒܘ ܕܒܥܝܐ ܡܢܟܘܢ ܬܩܘܡܘܢ ܠܗ ܡܛܠ ܕܐܦ ܗܝ ܩܝܘܡܬܐ ܗܘܬ ܠܤܓܝܐܐ ܐܦ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.3",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Romans 16:3",
      "text": "ܫܐܠܘ ܒܫܠܡܐ ܕܦܪܝܤܩܠܐ ܘܕܐܩܠܤ ܦܠܚܐ ܕܥܡܝ ܒܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.4",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Romans 16:4",
      "text": "ܕܗܢܘܢ ܗܠܝܢ ܚܠܦ ܢܦܫܝ ܨܘܪܝܗܘܢ ܝܗܒܘ ܘܠܐ ܗܘܐ ܐܢܐ ܒܠܚܘܕܝ ܡܘܕܐ ܐܢܐ ܠܗܘܢ ܐܠܐ ܐܦ ܟܠܗܝܢ ܥܕܬܐ ܕܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.5",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Romans 16:5",
      "text": "ܘܗܒܘ ܫܠܡܐ ܠܥܕܬܐ ܕܐܝܬ ܒܒܝܬܗܘܢ ܫܐܠܘ ܒܫܠܡܐ ܕܐܦܢܛܘܤ ܚܒܝܒܝ ܐܝܢܐ ܕܐܝܬܘܗܝ ܪܫܝܬܐ ܕܐܟܐܝܐ ܒܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.6",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Romans 16:6",
      "text": "ܫܐܠܘ ܒܫܠܡܐ ܕܡܪܝܐ ܐܝܕܐ ܕܤܓܝ ܠܐܝܬ ܒܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.7",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Romans 16:7",
      "text": "ܫܐܠܘ ܒܫܠܡܐ ܕܐܢܕܪܘܢܝܩܘܤ ܘܕܝܘܢܝܐ ܐܚܝܢܝ ܕܗܘܘ ܫܒܝܐ ܥܡܝ ܘܝܕܝܥܝܢ ܐܢܘܢ ܒܫܠܝܚܐ ܘܒܡܫܝܚܐ ܩܕܡܝ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.8",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Romans 16:8",
      "text": "ܫܐܠܘ ܒܫܠܡܐ ܕܐܡܦܠܝܘܤ ܚܒܝܒܝ ܒܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.9",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Romans 16:9",
      "text": "ܫܐܠܘ ܒܫܠܡܐ ܕܐܘܪܒܢܘܤ ܦܠܚܐ ܕܥܡܢ ܒܡܫܝܚܐ ܘܕܐܤܛܟܘܤ ܚܒܝܒܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.10",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Romans 16:10",
      "text": "ܫܐܠܘ ܒܫܠܡܐ ܕܐܦܠܐ ܓܒܝܐ ܒܡܪܢ ܫܐܠܘ ܒܫܠܡܐ ܕܒܢܝ ܒܝܬܗ ܕܐܪܤܛܒܘܠܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.11",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Romans 16:11",
      "text": "ܫܐܠܘ ܒܫܠܡܐ ܕܗܪܘܕܝܘܢ ܐܚܝܢܝ ܫܐܠܘ ܒܫܠܡܐ ܕܒܢܝ ܒܝܬܗ ܕܢܪܩܤܘܤ ܐܝܠܝܢ ܕܐܝܬܝܗܘܢ ܒܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.12",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Romans 16:12",
      "text": "ܫܐܠܘ ܒܫܠܡܐ ܕܛܪܘܦܢܐ ܘܕܛܪܘܦܤܐ ܕܠܐܝܝܢ ܒܡܪܢ ܫܐܠܘ ܒܫܠܡܐ ܕܦܪܤܤ ܚܒܝܒܬܝ ܐܝܕܐ ܕܤܓܝ ܠܐܝܬ ܒܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.13",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Romans 16:13",
      "text": "ܫܐܠܘ ܒܫܠܡܐ ܕܪܘܦܤ ܓܒܝܐ ܒܡܪܢ ܘܕܐܡܗ ܕܝܠܗ ܘܕܝܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.14",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Romans 16:14",
      "text": "ܫܐܠܘ ܒܫܠܡܐ ܕܐܤܘܢܩܪܛܘܤ ܘܕܦܠܓܘܢ ܘܕܗܪܡܐ ܘܕܦܛܪܒܐ ܘܕܗܪܡܐ ܘܕܐܚܐ ܕܥܡܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.15",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Romans 16:15",
      "text": "ܫܐܠܘ ܒܫܠܡܐ ܕܦܝܠܠܓܘܤ ܘܕܝܘܠܝܐ ܘܕܢܐܪܘܤ ܘܕܚܬܗ ܘܕܐܠܘܡܦܐ ܘܕܟܠܗܘܢ ܩܕܝܫܐ ܕܥܡܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.16",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Romans 16:16",
      "text": "ܫܐܠܘ ܒܫܠܡܐ ܚܕ ܕܚܕ ܒܢܘܫܩܬܐ ܩܕܝܫܬܐ ܫܐܠܢ ܒܫܠܡܟܘܢ ܟܠܗܝܢ ܥܕܬܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.17",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Romans 16:17",
      "text": "ܒܥܢܐ ܕܝܢ ܡܢܟܘܢ ܐܚܝ ܕܬܙܕܗܪܘܢ ܡܢ ܐܝܠܝܢ ܕܦܠܓܘܬܐ ܘܡܟܫܘܠܐ ܥܒܕܝܢ ܠܒܪ ܡܢ ܝܘܠܦܢܐ ܕܐܢܬܘܢ ܝܠܦܬܘܢ ܕܬܬܪܚܩܘܢ ܠܟܘܢ ܡܢܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.18",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Romans 16:18",
      "text": "ܐܝܠܝܢ ܓܝܪ ܕܗܟܢܐ ܐܢܘܢ ܠܐ ܡܫܡܫܝܢ ܠܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܐܠܐ ܠܟܪܤܗܘܢ ܘܒܡܠܐ ܒܤܝܡܬܐ ܘܒܒܘܪܟܬܐ ܡܛܥܝܢ ܠܒܘܬܐ ܕܦܫܝܛܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.19",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Romans 16:19",
      "text": "ܡܫܬܡܥܢܘܬܟܘܢ ܕܝܢ ܕܝܠܟܘܢ ܠܟܠ ܒܪܢܫ ܐܬܝܕܥܬ ܚܕܐ ܐܢܐ ܗܟܝܠ ܒܟܘܢ ܘܨܒܐ ܐܢܐ ܕܬܗܘܘܢ ܚܟܝܡܝܢ ܠܛܒܬܐ ܘܬܡܝܡܝܢ ܠܒܝܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.20",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Romans 16:20",
      "text": "ܐܠܗܐ ܕܝܢ ܕܫܠܡܐ ܢܫܚܩܝܘܗܝ ܒܥܓܠ ܠܤܛܢܐ ܬܚܝܬ ܪܓܠܝܟܘܢ ܛܝܒܘܬܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܬܗܘܐ ܥܡܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.21",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "Romans 16:21",
      "text": "ܫܐܠܝܢ ܒܫܠܡܟܘܢ ܛܝܡܬܐܘܤ ܦܠܚܐ ܕܥܡܝ ܘܠܘܩܝܘܤ ܘܐܝܤܘܢ ܘܤܘܤܝܦܛܪܘܤ ܐܚܝܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.22",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "Romans 16:22",
      "text": "ܫܐܠ ܐܢܐ ܒܫܠܡܟܘܢ ܐܢܐ ܛܪܛܝܘܤ ܕܟܬܒܬ ܐܓܪܬܐ ܒܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.23",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "Romans 16:23",
      "text": "ܫܐܠ ܒܫܠܡܟܘܢ ܓܐܝܘܤ ܡܩܒܠܢܝ ܘܕܟܠܗ ܥܕܬܐ ܫܐܠ ܒܫܠܡܟܘܢ ܐܪܤܛܘܤ ܪܒܝܬܐ ܕܡܕܝܢܬܐ ܘܩܘܐܪܛܘܤ ܐܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.24",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "Romans 16:24",
      "text": "ܠܐܠܗܐ ܕܝܢ ܗܘ ܕܡܫܟܚ ܕܢܫܪܪܟܘܢ ܒܐܘܢܓܠܝܘܢ ܕܝܠܝ ܗܘ ܕܐܬܟܪܙ ܥܠ ܝܫܘܥ ܡܫܝܚܐ ܒܓܠܝܢܐ ܕܐܪܙܐ ܕܡܢ ܙܒܢܝ ܥܠܡܐ ܡܟܤܝ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.25",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 25,
      "referenceLabel": "Romans 16:25",
      "text": "ܐܬܓܠܝ ܕܝܢ ܒܙܒܢܐ ܗܢܐ ܒܝܕ ܟܬܒܐ ܕܢܒܝܐ ܘܒܦܘܩܕܢܗ ܕܐܠܗܐ ܕܠܥܠܡ ܐܬܝܕܥ ܠܟܠܗܘܢ ܥܡܡܐ ܠܡܫܡܥܐ ܕܗܝܡܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.26",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 26,
      "referenceLabel": "Romans 16:26",
      "text": "ܕܗܘܝܘ ܚܟܝܡܐ ܒܠܚܘܕܘܗܝ ܫܘܒܚܐ ܒܝܕ ܝܫܘܥ ܡܫܝܚܐ ܠܥܠܡܥܠܡܝܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.16.27",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 27,
      "referenceLabel": "Romans 16:27",
      "text": "ܛܝܒܘܬܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܥܡ ܟܠܟܘܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    }
  ]
