{
  "chapter": {
    "id": "peshitta:romans.15",
    "translationId": "peshitta",
    "bookSlug": "romans",
    "chapterNumber": 15,
    "referenceLabel": "Romans 15",
    "summary": "Source text for Romans 15 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:romans.15.1",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Romans 15:1",
      "text": "ܚܝܒܝܢܢ ܗܟܝܠ ܚܢܢ ܚܝܠܬܢܐ ܕܟܘܪܗܢܐ ܕܡܚܝܠܐ ܢܫܩܘܠ ܘܠܐ ܠܢܦܫܢ ܢܫܦܪ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:romans.15.2",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Romans 15:2",
      "text": "ܐܠܐ ܐܢܫ ܡܢܢ ܠܩܪܝܒܗ ܢܫܦܪ ܒܛܒܬܐ ܐܝܟ ܕܠܒܢܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.3",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Romans 15:3",
      "text": "ܡܛܠ ܕܐܦ ܡܫܝܚܐ ܠܐ ܗܘܐ ܠܢܦܫܗ ܫܦܪ ܐܠܐ ܐܝܟ ܕܟܬܝܒ ܕܚܤܕܐ ܕܡܚܤܕܢܝܟ ܢܦܠ ܥܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.4",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Romans 15:4",
      "text": "ܟܠ ܡܕܡ ܓܝܪ ܕܡܢ ܩܕܝܡ ܐܬܟܬܒ ܠܝܘܠܦܢܐ ܗܘ ܕܝܠܢ ܐܬܟܬܒ ܕܒܡܤܝܒܪܢܘܬܐ ܘܒܒܘܝܐܐ ܕܟܬܒܐ ܤܒܪܐ ܢܗܘܐ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.5",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Romans 15:5",
      "text": "ܐܠܗܐ ܕܝܢ ܕܡܤܝܒܪܢܘܬܐ ܘܕܒܘܝܐܐ ܢܬܠ ܠܟܘܢ ܕܫܘܝܘܬܐ ܬܬܚܫܒܘܢ ܚܕ ܥܠ ܚܕ ܒܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.6",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Romans 15:6",
      "text": "ܕܒܚܕ ܪܥܝܢ ܘܒܚܕ ܦܘܡ ܬܫܒܚܘܢ ܠܐܠܗܐ ܐܒܘܗܝ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.7",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Romans 15:7",
      "text": "ܡܛܠ ܗܕܐ ܗܘܘ ܡܩܪܒܝܢ ܘܛܥܢܝܢ ܠܚܕܕܐ ܐܝܟܢܐ ܕܐܦ ܡܫܝܚܐ ܩܪܒܟܘܢ ܠܬܫܒܘܚܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.8",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Romans 15:8",
      "text": "ܐܡܪ ܐܢܐ ܕܝܢ ܕܝܫܘܥ ܡܫܝܚܐ ܫܡܫ ܓܙܘܪܬܐ ܚܠܦ ܫܪܪܗ ܕܐܠܗܐ ܐܝܟܢܐ ܕܢܫܪ ܡܘܠܟܢܐ ܕܐܒܗܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.9",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Romans 15:9",
      "text": "ܘܥܡܡܐ ܢܫܒܚܘܢ ܠܐܠܗܐ ܚܠܦ ܪܚܡܐ ܕܗܘܘ ܥܠܝܗܘܢ ܐܝܟ ܕܟܬܝܒ ܕܐܘܕܐ ܠܟ ܒܥܡܡܐ ܘܠܫܡܟ ܐܙܡܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.10",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Romans 15:10",
      "text": "ܘܬܘܒ ܐܡܪ ܐܬܒܤܡܘ ܥܡܡܐ ܥܡ ܥܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.11",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Romans 15:11",
      "text": "ܘܬܘܒ ܐܡܪ ܫܒܚܘ ܠܡܪܝܐ ܟܠܟܘܢ ܥܡܡܐ ܫܒܚܝܗܝ ܟܠܗܝܢ ܐܡܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.12",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Romans 15:12",
      "text": "ܘܬܘܒ ܐܫܥܝܐ ܐܡܪ ܕܢܗܘܐ ܥܩܪܐ ܠܐܝܫܝ ܘܡܢ ܕܢܩܘܡ ܢܗܘܐ ܪܫܐ ܠܥܡܡܐ ܘܥܠܘܗܝ ܢܤܒܪܘܢ ܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.13",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Romans 15:13",
      "text": "ܐܠܗܐ ܕܝܢ ܕܤܒܪܐ ܢܡܠܝܟܘܢ ܟܠܗ ܚܕܘܬܐ ܘܫܠܡܐ ܒܗܝܡܢܘܬܐ ܕܬܬܝܬܪܘܢ ܒܤܒܪܗ ܒܚܝܠܐ ܕܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.14",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Romans 15:14",
      "text": "ܡܦܤ ܐܢܐ ܕܝܢ ܐܦ ܐܢܐ ܥܠܝܟܘܢ ܐܚܝ ܕܐܦ ܐܢܬܘܢ ܡܠܝܢ ܐܢܬܘܢ ܗܘ ܛܒܬܐ ܘܡܫܡܠܝܬܘܢ ܒܟܠܗ ܝܕܥܬܐ ܘܡܫܟܚܝܢ ܐܢܬܘܢ ܐܦ ܠܐܚܪܢܐ ܠܡܪܬܝܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.15",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Romans 15:15",
      "text": "ܩܠܝܠ ܕܝܢ ܡܪܚܐܝܬ ܟܬܒܬ ܠܟܘܢ ܐܚܝ ܐܝܟܢܐ ܕܐܥܗܕܟܘܢ ܒܛܝܒܘܬܐ ܕܐܬܝܗܒܬ ܠܝ ܡܢ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.16",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Romans 15:16",
      "text": "ܕܐܗܘܐ ܡܫܡܫܢܐ ܠܝܫܘܥ ܡܫܝܚܐ ܒܥܡܡܐ ܘܐܦܠܘܚ ܠܐܘܢܓܠܝܘܢ ܕܐܠܗܐ ܕܢܗܘܐ ܩܘܪܒܢܐ ܕܥܡܡܐ ܡܩܒܠ ܘܡܩܕܫ ܒܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.17",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Romans 15:17",
      "text": "ܐܝܬ ܠܝ ܗܟܝܠ ܫܘܒܗܪܐ ܒܝܫܘܥ ܡܫܝܚܐ ܠܘܬ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.18",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Romans 15:18",
      "text": "ܠܐ ܓܝܪ ܡܡܪܚ ܐܢܐ ܕܐܡܪ ܡܕܡ ܕܠܐ ܤܥܪ ܒܐܝܕܝ ܡܫܝܚܐ ܠܡܫܡܥܐ ܕܥܡܡܐ ܒܡܠܬܐ ܘܒܥܒܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.19",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Romans 15:19",
      "text": "ܒܚܝܠܐ ܕܐܬܘܬܐ ܘܕܬܕܡܪܬܐ ܘܒܚܝܠܐ ܕܪܘܚܗ ܕܐܠܗܐ ܐܝܟܢܐ ܕܡܢ ܐܘܪܫܠܡ ܐܬܟܪܟ ܥܕܡܐ ܠܐܠܘܪܝܩܘܢ ܘܐܡܠܐ ܤܒܪܬܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.20",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Romans 15:20",
      "text": "ܟܕ ܡܬܚܦܛ ܐܢܐ ܐܤܒܪ ܠܐ ܟܪ ܕܐܬܩܪܝ ܫܡܗ ܕܡܫܝܚܐ ܕܠܐ ܐܒܢܐ ܥܠ ܫܬܐܤܬܐ ܢܘܟܪܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.21",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Romans 15:21",
      "text": "ܐܠܐ ܐܝܟܢܐ ܕܟܬܝܒ ܕܐܝܠܝܢ ܕܠܐ ܐܬܐܡܪ ܠܗܘܢ ܥܠܘܗܝ ܢܚܙܘܢܗ ܘܐܝܠܝܢ ܕܠܐ ܫܡܥܘ ܢܬܛܦܝܤܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.22",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Romans 15:22",
      "text": "ܡܛܠ ܗܢܐ ܐܬܬܟܤܬ ܙܒܢܝܢ ܤܓܝܐܢ ܕܐܬܐ ܠܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.23",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Romans 15:23",
      "text": "ܗܫܐ ܕܝܢ ܡܛܠ ܕܕܘܟܐ ܠܝܬ ܠܝ ܒܗܠܝܢ ܐܬܪܘܬܐ ܘܤܘܐ ܗܘܝܬ ܡܢ ܩܕܡ ܫܢܝܐ ܤܓܝܐܬܐ ܕܐܬܐ ܠܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.24",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Romans 15:24",
      "text": "ܡܐ ܕܐܙܠ ܐܢܐ ܠܐܤܦܢܝܐ ܡܤܒܪ ܐܢܐ ܕܐܬܐ ܘܐܚܙܝܟܘܢ ܘܐܢܬܘܢ ܬܠܘܘܢܢܝ ܠܬܡܢ ܡܐ ܕܩܠܝܠ ܡܢ ܤܓܝ ܐܬܒܤܡܬ ܒܚܙܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.25",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Romans 15:25",
      "text": "ܗܫܐ ܕܝܢ ܐܙܠ ܐܢܐ ܠܐܘܪܫܠܡ ܕܐܫܡܫ ܠܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.26",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Romans 15:26",
      "text": "ܨܒܘ ܓܝܪ ܗܠܝܢ ܕܒܡܩܕܘܢܝܐ ܘܒܐܟܐܝܐ ܕܫܘܬܦܘܬܐ ܬܗܘܐ ܠܗܘܢ ܥܡ ܡܤܟܢܐ ܩܕܝܫܐ ܕܐܝܬ ܒܐܘܪܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.27",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Romans 15:27",
      "text": "ܨܒܘ ܡܛܠ ܕܐܦ ܚܝܒܝܢ ܠܗܘܢ ܐܢ ܓܝܪ ܒܕܪܘܚ ܐܫܬܘܬܦܘ ܥܡܗܘܢ ܥܡܡܐ ܚܝܒܝܢ ܐܢܘܢ ܕܐܦ ܒܕܒܤܪ ܢܫܡܫܘܢ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.28",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Romans 15:28",
      "text": "ܗܕܐ ܗܟܝܠ ܡܐ ܕܓܡܪܬ ܘܚܬܡܬ ܠܗܘܢ ܐܕܫܐ ܗܢܐ ܥܒܪ ܐܢܐ ܥܠܝܟܘܢ ܠܐܤܦܢܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.29",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Romans 15:29",
      "text": "ܝܕܥ ܐܢܐ ܕܝܢ ܕܐܡܬܝ ܕܐܬܐ ܐܢܐ ܠܘܬܟܘܢ ܒܡܘܠܝܐ ܗܘ ܕܒܘܪܟܬܐ ܕܐܘܢܓܠܝܘܢ ܕܡܫܝܚܐ ܐܬܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.30",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Romans 15:30",
      "text": "ܒܥܐ ܐܢܐ ܕܝܢ ܡܢܟܘܢ ܐܚܝ ܒܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܘܒܚܘܒܐ ܕܪܘܚܐ ܕܬܥܡܠܘܢ ܥܡܝ ܒܨܠܘܬܐ ܕܚܠܦܝ ܠܘܬ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.31",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Romans 15:31",
      "text": "ܕܐܬܦܨܐ ܡܢ ܐܝܠܝܢ ܕܠܐ ܡܬܛܦܝܤܝܢ ܕܒܝܗܘܕ ܘܬܫܡܫܬܐ ܕܡܘܒܠ ܐܢܐ ܠܩܕܝܫܐ ܕܒܐܘܪܫܠܡ ܬܬܩܒܠ ܫܦܝܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.32",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Romans 15:32",
      "text": "ܘܐܬܐ ܠܘܬܟܘܢ ܒܚܕܘܬܐ ܒܨܒܝܢܗ ܕܐܠܗܐ ܘܐܬܬܢܝܚ ܥܡܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.15.33",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Romans 15:33",
      "text": "ܐܠܗܐ ܕܝܢ ܕܫܠܡܐ ܢܗܘܐ ܥܡ ܟܠܟܘܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    }
  ]
