  },
  "verses": [
    {
      "id": "peshitta:romans.13.1",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Romans 13:1",
      "text": "ܟܠ ܢܦܫ ܠܫܘܠܛܢܐ ܕܪܒܘܬܐ ܬܫܬܥܒܕ ܠܝܬ ܓܝܪ ܫܘܠܛܢܐ ܕܠܐ ܗܘܐ ܡܢ ܐܠܗܐ ܗܘ ܘܐܝܠܝܢ ܫܘܠܛܢܐ ܕܐܝܬܝܗܘܢ ܡܢ ܐܠܗܐ ܗܘ ܦܩܝܕܝܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:romans.13.2",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Romans 13:2",
      "text": "ܡܢ ܕܩܐܡ ܗܟܝܠ ܠܘܩܒܠ ܫܘܠܛܢܐ ܠܘܩܒܠ ܦܘܩܕܢܐ ܕܐܠܗܐ ܩܐܡ ܘܗܠܝܢ ܕܩܝܡܝܢ ܠܘܩܒܠܗܘܢ ܕܝܢܐ ܢܤܒܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.13.3",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Romans 13:3",
      "text": "ܕܝܢܐ ܓܝܪ ܠܐ ܗܘܘ ܕܚܠܬܐ ܠܥܒܕܐ ܛܒܐ ܐܠܐ ܠܒܝܫܐ ܨܒܐ ܐܢܬ ܗܟܝܠ ܕܠܐ ܬܕܚܠ ܡܢ ܫܘܠܛܢܐ ܥܒܕ ܛܒܬܐ ܘܬܫܒܘܚܬܐ ܬܗܘܐ ܠܟ ܡܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.13.4",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Romans 13:4",
      "text": "ܡܫܡܫܢܐ ܗܘ ܓܝܪ ܕܐܠܗܐ ܐܠܐ ܠܟ ܠܛܒܬܐ ܘܐܢ ܒܝܫܬܐ ܥܒܕ ܐܢܬ ܕܚܠ ܠܐ ܗܘܐ ܓܝܪ ܤܪܝܩܐܝܬ ܐܤܝܪ ܠܤܦܤܪܐ ܡܫܡܫܢܐ ܗܘ ܓܝܪ ܕܐܠܗܐ ܘܬܒܘܥܐ ܕܪܘܓܙܐ ܠܐܝܠܝܢ ܕܥܒܕܝܢ ܒܝܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.13.5",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Romans 13:5",
      "text": "ܘܡܛܠ ܗܢܐ ܐܠܨܐ ܠܢ ܕܢܫܬܥܒܕ ܠܐ ܡܛܠ ܪܘܓܙܐ ܒܠܚܘܕ ܐܠܐ ܐܦ ܡܛܠ ܬܐܪܬܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.13.6",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Romans 13:6",
      "text": "ܡܛܠ ܗܢܐ ܐܦ ܟܤܦ ܪܫܐ ܝܗܒܝܢ ܐܢܬܘܢ ܡܫܡܫܢܐ ܐܢܘܢ ܓܝܪ ܕܐܠܗܐ ܕܥܠܝܗܝܢ ܕܗܠܝܢ ܩܝܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.13.7",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Romans 13:7",
      "text": "ܦܪܘܥܘ ܗܟܝܠ ܠܟܠܢܫ ܐܝܟ ܕܡܬܚܝܒ ܠܗ ܠܡܢ ܕܟܤܦ ܪܫܐ ܟܤܦ ܪܫܐ ܘܠܡܢ ܕܡܟܤܐ ܡܟܤܐ ܘܠܡܢ ܕܕܚܠܬܐ ܕܚܠܬܐ ܘܠܡܢ ܕܐܝܩܪܐ ܐܝܩܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.13.8",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Romans 13:8",
      "text": "ܘܠܐܢܫ ܡܕܡ ܠܐ ܬܚܘܒܘܢ ܐܠܐ ܚܕ ܠܚܕ ܠܡܚܒܘ ܡܢ ܕܡܚܒ ܓܝܪ ܚܒܪܗ ܢܡܘܤܐ ܡܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.13.9",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Romans 13:9",
      "text": "ܘܐܦ ܗܝ ܓܝܪ ܕܐܡܪ ܕܠܐ ܬܓܘܪ ܘܠܐ ܬܩܛܘܠ ܘܠܐ ܬܓܢܘܒ ܘܠܐ ܬܪܓ ܘܐܢ ܐܝܬ ܦܘܩܕܢܐ ܐܚܪܢܐ ܒܗܕܐ ܡܠܬܐ ܡܫܬܠܡ ܕܬܪܚܡ ܠܩܪܝܒܟ ܐܝܟ ܢܦܫܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.13.10",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Romans 13:10",
      "text": "ܚܘܒܐ ܠܩܪܝܒܗ ܒܝܫܬܐ ܠܐ ܤܥܪ ܡܛܠ ܕܚܘܒܐ ܡܘܠܝܗ ܗܘ ܕܢܡܘܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.13.11",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Romans 13:11",
      "text": "ܘܐܦ ܗܕܐ ܕܥܘ ܕܙܒܢܐ ܗܘ ܘܫܥܬܐ ܗܝ ܡܟܝܠ ܕܢܬܥܝܪ ܡܢ ܫܢܬܢ ܗܫܐ ܗܘ ܓܝܪ ܐܬܩܪܒܘ ܠܢ ܚܝܝܢ ܝܬܝܪ ܡܢ ܕܟܕ ܗܝܡܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.13.12",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Romans 13:12",
      "text": "ܠܠܝܐ ܡܟܝܠ ܥܒܪ ܘܐܝܡܡܐ ܩܪܒ ܢܢܝܚ ܡܢܢ ܗܟܝܠ ܥܒܕܐ ܕܚܫܘܟܐ ܘܢܠܒܫ ܙܝܢܗ ܕܢܘܗܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.13.13",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Romans 13:13",
      "text": "ܘܐܝܟ ܕܒܐܝܡܡܐ ܒܐܤܟܡܐ ܢܗܠܟ ܠܐ ܒܙܡܪܐ ܘܠܐ ܒܪܘܝܘܬܐ ܘܠܐ ܒܡܕܡܟܐ ܛܢܦܐ ܘܠܐ ܒܚܤܡܐ ܘܒܚܪܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.13.14",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Romans 13:14",
      "text": "ܐܠܐ ܠܘܒܫܘܗܝ ܠܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܘܠܐ ܬܐܨܦܘܢ ܕܒܤܪܟܘܢ ܠܪܓܝܓܬܐ ܀",
      "paragraphStart": false
    }
  ]
}
