{
  "chapter": {
    "id": "peshitta:romans.2",
    "translationId": "peshitta",
    "bookSlug": "romans",
    "chapterNumber": 2,
    "referenceLabel": "Romans 2",
    "summary": "Source text for Romans 2 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:romans.2.1",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Romans 2:1",
      "text": "ܡܛܠ ܗܢܐ ܠܝܬ ܠܟ ܡܦܩ ܒܪܘܚܐ ܐܘ ܒܪܢܫܐ ܕܐܢ ܚܒܪܗ ܒܗܘ ܓܝܪ ܕܕܐܢ ܐܢܬ ܚܒܪܟ ܢܦܫܟ ܗܘ ܡܚܝܒ ܐܢܬ ܐܦ ܐܢܬ ܓܝܪ ܕܕܐܢ ܐܢܬ ܒܗܝܢ ܗܘ ܡܬܗܦܟ ܐܢܬ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:romans.2.2",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Romans 2:2",
      "text": "ܘܝܕܥܝܢܢ ܕܐܝܬܘܗܝ ܕܝܢܗ ܕܐܠܗܐ ܒܩܘܫܬܐ ܥܠ ܐܝܠܝܢ ܕܒܗܠܝܢ ܡܬܗܦܟܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.3",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Romans 2:3",
      "text": "ܡܢܐ ܕܝܢ ܡܬܚܫܒ ܐܢܬ ܐܘ ܒܪܢܫܐ ܕܕܐܢ ܐܢܬ ܠܐܝܠܝܢ ܕܒܗܠܝܢ ܡܬܗܦܟܝܢ ܟܕ ܐܦ ܐܢܬ ܒܗܝܢ ܡܬܗܦܟ ܐܢܬ ܕܐܢܬ ܬܥܪܘܩ ܡܢ ܕܝܢܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.4",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Romans 2:4",
      "text": "ܐܘ ܥܠ ܥܘܬܪܐ ܕܒܤܝܡܘܬܗ ܘܥܠ ܡܓܪܬ ܪܘܚܗ ܘܥܠ ܐܬܪܐ ܕܝܗܒ ܠܟ ܡܡܪܚ ܐܢܬ ܘܠܐ ܝܕܥ ܐܢܬ ܕܒܤܝܡܘܬܗ ܕܐܠܗܐ ܠܬܝܒܘܬܐ ܗܘ ܡܝܬܝܐ ܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.5",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Romans 2:5",
      "text": "ܐܠܐ ܡܛܠ ܩܫܝܘܬ ܠܒܟ ܕܠܐ ܬܐܒ ܤܐܡ ܐܢܬ ܠܟ ܤܝܡܬܐ ܕܪܘܓܙܐ ܠܝܘܡܐ ܕܪܘܓܙܐ ܘܠܓܠܝܢܐ ܕܕܝܢܐ ܟܐܢܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.6",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Romans 2:6",
      "text": "ܗܘ ܕܦܪܥ ܠܟܠܢܫ ܐܝܟ ܥܒܕܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.7",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Romans 2:7",
      "text": "ܠܐܝܠܝܢ ܕܒܡܤܝܒܪܢܘܬܐ ܕܥܒܕܐ ܛܒܐ ܬܫܒܘܚܬܐ ܘܐܝܩܪܐ ܘܠܐ ܡܬܚܒܠܢܘܬܐ ܒܥܝܢ ܝܗܒ ܠܗܘܢ ܚܝܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.8",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Romans 2:8",
      "text": "ܐܝܠܝܢ ܕܝܢ ܕܥܨܝܢ ܘܠܐ ܡܬܛܦܝܤܝܢ ܠܫܪܪܐ ܐܠܐ ܠܥܘܠܐ ܡܬܛܦܝܤܝܢ ܢܦܪܘܥ ܐܢܘܢ ܪܘܓܙܐ ܘܚܡܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.9",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Romans 2:9",
      "text": "ܘܐܘܠܨܢܐ ܘܛܘܪܦܐ ܠܟܠ ܒܪܢܫ ܕܦܠܚ ܒܝܫܬܐ ܠܝܗܘܕܝܐ ܠܘܩܕܡ ܘܠܐܪܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.10",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Romans 2:10",
      "text": "ܬܫܒܘܚܬܐ ܕܝܢ ܘܐܝܩܪܐ ܘܫܠܡܐ ܠܟܠ ܕܦܠܚ ܛܒܬܐ ܠܝܗܘܕܝܐ ܠܘܩܕܡ ܘܠܐܪܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.11",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Romans 2:11",
      "text": "ܠܐ ܓܝܪ ܐܝܬ ܡܤܒ ܒܐܦܐ ܠܘܬ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.12",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Romans 2:12",
      "text": "ܐܝܠܝܢ ܓܝܪ ܕܕܠܐ ܢܡܘܤܐ ܚܛܘ ܐܦ ܕܠܐ ܢܡܘܤܐ ܢܐܒܕܘܢ ܘܐܝܠܝܢ ܕܒܢܡܘܤܐ ܚܛܘ ܡܢ ܢܡܘܤܐ ܢܬܕܝܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.13",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Romans 2:13",
      "text": "ܠܐ ܗܘܐ ܓܝܪ ܫܡܘܥܘܗܝ ܕܢܡܘܤܐ ܟܐܢܝܢ ܩܕܡ ܐܠܗܐ ܐܠܐ ܥܒܘܕܘܗܝ ܕܢܡܘܤܐ ܡܙܕܕܩܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.14",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Romans 2:14",
      "text": "ܐܢ ܓܝܪ ܥܡܡܐ ܕܢܡܘܤܐ ܠܝܬ ܠܗܘܢ ܡܢ ܟܝܢܗܘܢ ܢܥܒܕܘܢ ܕܢܡܘܤܐ ܗܢܘܢ ܕܟܕ ܢܡܘܤܐ ܠܝܬ ܗܘܐ ܠܗܘܢ ܠܢܦܫܗܘܢ ܗܘܘ ܢܡܘܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.15",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Romans 2:15",
      "text": "ܘܗܢܘܢ ܡܚܘܝܢ ܥܒܕܗ ܕܢܡܘܤܐ ܟܕ ܟܬܝܒ ܥܠ ܠܒܗܘܢ ܘܡܤܗܕܐ ܥܠܝܗܘܢ ܬܐܪܬܗܘܢ ܟܕ ܡܚܫܒܬܗܘܢ ܡܟܘܢܢ ܐܘ ܢܦܩܢ ܪܘܚܐ ܠܚܕܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.16",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Romans 2:16",
      "text": "ܒܝܘܡܐ ܕܕܐܢ ܐܠܗܐ ܟܤܝܬܐ ܕܒܢܝܢܫܐ ܐܝܟ ܐܘܢܓܠܝܘܢ ܕܝܠܝ ܒܝܕ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.17",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Romans 2:17",
      "text": "ܐܢ ܐܢܬ ܕܝܢ ܕܝܗܘܕܝܐ ܡܬܩܪܐ ܐܢܬ ܘܡܬܬܢܝܚ ܐܢܬ ܥܠ ܢܡܘܤܐ ܘܡܫܬܒܗܪ ܐܢܬ ܒܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.18",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Romans 2:18",
      "text": "ܕܝܕܥ ܐܢܬ ܨܒܝܢܗ ܘܦܪܫ ܐܢܬ ܘܠܝܬܐ ܕܝܠܝܦ ܐܢܬ ܡܢ ܢܡܘܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.19",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Romans 2:19",
      "text": "ܘܐܬܬܟܠܬ ܥܠ ܢܦܫܟ ܕܡܕܒܪܢܐ ܐܢܬ ܕܥܘܝܪܐ ܘܢܘܗܪܐ ܕܐܝܠܝܢ ܕܐܝܬܝܗܘܢ ܒܚܫܘܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.20",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Romans 2:20",
      "text": "ܘܪܕܘܝܐ ܕܚܤܝܪܝ ܪܥܝܢܐ ܘܡܠܦܢܐ ܕܛܠܝܐ ܘܐܝܬ ܠܟ ܕܘܡܝܐ ܕܝܕܥܬܐ ܘܕܫܪܪܐ ܒܢܡܘܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.21",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Romans 2:21",
      "text": "ܐܢܬ ܗܟܝܠ ܕܡܠܦ ܐܢܬ ܠܐܚܪܢܐ ܠܢܦܫܟ ܠܐ ܡܠܦ ܐܢܬ ܘܕܡܟܪܙ ܐܢܬ ܕܠܐ ܢܓܢܒܘܢ ܐܢܬ ܓܢܒ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.22",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Romans 2:22",
      "text": "ܘܕܐܡܪ ܐܢܬ ܕܠܐ ܢܓܘܪܘܢ ܐܢܬ ܓܐܪ ܐܢܬ ܘܐܢܬ ܕܫܐܛ ܐܢܬ ܦܬܟܪܐ ܡܚܠܨ ܐܢܬ ܒܝܬ ܡܩܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.23",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Romans 2:23",
      "text": "ܘܐܢܬ ܕܡܫܬܒܗܪ ܐܢܬ ܒܢܡܘܤܐ ܒܗܘ ܕܥܒܪ ܐܢܬ ܥܠ ܢܡܘܤܐ ܠܐܠܗܐ ܗܘ ܡܨܥܪ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.24",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "Romans 2:24",
      "text": "ܫܡܗ ܓܝܪ ܕܐܠܗܐ ܡܛܠܬܟܘܢ ܗܘ ܡܬܓܕܦ ܒܝܬ ܥܡܡܐ ܐܝܟ ܕܟܬܝܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.25",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "Romans 2:25",
      "text": "ܓܙܘܪܬܐ ܓܝܪ ܡܗܢܝܐ ܐܢ ܢܡܘܤܐ ܬܓܡܘܪ ܐܢ ܬܥܒܪ ܠܟ ܕܝܢ ܡܢ ܢܡܘܤܐ ܓܙܘܪܬܟ ܗܘܬ ܠܗ ܥܘܪܠܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.26",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "Romans 2:26",
      "text": "ܐܢ ܗܘ ܕܝܢ ܕܥܘܪܠܘܬܐ ܬܛܪ ܦܘܩܕܢܗ ܕܢܡܘܤܐ ܠܐ ܗܐ ܥܘܪܠܘܬܐ ܡܬܚܫܒܐ ܠܗ ܓܙܘܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.27",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "Romans 2:27",
      "text": "ܘܬܕܘܢ ܥܘܪܠܘܬܐ ܕܡܢ ܟܝܢܗ ܓܡܪܐ ܢܡܘܤܐ ܠܟ ܕܒܟܬܒܐ ܘܒܓܙܘܪܬܐ ܥܒܪ ܐܢܬ ܥܠ ܢܡܘܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.28",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "Romans 2:28",
      "text": "ܠܐ ܗܘܐ ܓܝܪ ܡܢ ܕܒܓܠܝܐ ܗܘ ܗܘ ܝܗܘܕܝܐ ܐܦܠܐ ܐܝܕܐ ܕܡܬܚܙܝܐ ܒܒܤܪܐ ܓܙܘܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.2.29",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 29,
      "referenceLabel": "Romans 2:29",
      "text": "ܐܠܐ ܗܘ ܗܘ ܝܗܘܕܝܐ ܐܝܢܐ ܕܒܟܤܝܐ ܗܘ ܘܓܙܘܪܬܐ ܐܝܕܐ ܕܕܠܒܐ ܗܝ ܒܪܘܚ ܘܠܐ ܒܟܬܒܐ ܐܝܕܐ ܕܬܫܒܘܚܬܗ ܠܐ ܗܘܬ ܡܢ ܒܢܝ ܐܢܫܐ ܐܠܐ ܡܢ ܐܠܗܐ ܀",
      "paragraphStart": false
    }
  ]
}
