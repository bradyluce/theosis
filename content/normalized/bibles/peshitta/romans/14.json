    "chapterNumber": 14,
    "referenceLabel": "Romans 14",
    "summary": "Source text for Romans 14 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:romans.14.1",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Romans 14:1",
      "text": "ܠܐܝܢܐ ܕܝܢ ܕܟܪܝܗ ܒܗܝܡܢܘܬܐ ܗܒܘ ܠܗ ܐܝܕܐ ܘܠܐ ܬܗܘܘܢ ܡܬܦܠܓܝܢ ܒܡܚܫܒܬܟܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:romans.14.2",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Romans 14:2",
      "text": "ܐܝܬ ܓܝܪ ܕܡܗܝܡܢ ܕܟܠܡܕܡ ܢܐܟܘܠ ܘܕܟܪܝܗ ܝܪܩܐ ܗܘ ܐܟܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.3",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Romans 14:3",
      "text": "ܗܘ ܕܝܢ ܕܐܟܠ ܠܗܘ ܡܢ ܕܠܐ ܐܟܠ ܠܐ ܢܫܘܛ ܘܗܘ ܡܢ ܕܠܐ ܐܟܠ ܠܗܘ ܡܢ ܕܐܟܠ ܠܐ ܢܕܘܢ ܐܠܗܐ ܓܝܪ ܩܪܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.4",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Romans 14:4",
      "text": "ܐܢܬ ܡܢ ܐܢܬ ܕܕܐܢ ܐܢܬ ܠܥܒܕܐ ܕܠܐ ܕܝܠܟ ܕܐܢ ܩܐܡ ܠܡܪܗ ܩܐܡ ܘܐܢ ܢܦܠ ܠܡܪܗ ܢܦܠ ܡܩܡ ܗܘ ܕܝܢ ܩܐܡ ܡܛܐ ܓܝܪ ܒܐܝܕܝ ܡܪܗ ܕܢܩܝܡܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.5",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Romans 14:5",
      "text": "ܐܝܬ ܕܕܐܢ ܝܘܡܐ ܡܢ ܝܘܡܐ ܘܐܝܬ ܕܕܐܢ ܟܠܗܘܢ ܝܘܡܬܐ ܟܠܢܫ ܕܝܢ ܒܡܕܥܐ ܕܢܦܫܗ ܢܫܬܪܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.6",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Romans 14:6",
      "text": "ܡܢ ܕܡܬܪܥܐ ܕܝܘܡܐ ܠܡܪܗ ܡܬܪܥܐ ܘܟܠ ܕܠܐ ܡܬܪܥܐ ܕܝܘܡܐ ܠܡܪܗ ܠܐ ܡܬܪܥܐ ܘܕܐܟܠ ܠܡܪܗ ܐܟܠ ܘܠܐܠܗܐ ܡܘܕܐ ܘܕܠܐ ܐܟܠ ܠܡܪܗ ܠܐ ܐܟܠ ܘܡܘܕܐ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.7",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Romans 14:7",
      "text": "ܠܝܬ ܓܝܪ ܐܢܫ ܡܢܢ ܕܠܢܦܫܗ ܚܝ ܘܠܝܬ ܐܢܫ ܕܠܢܦܫܗ ܡܐܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.8",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Romans 14:8",
      "text": "ܡܛܠ ܕܐܢ ܚܐܝܢܢ ܠܡܪܢ ܚܐܝܢܢ ܘܐܢ ܡܝܬܝܢܢ ܠܡܪܢ ܗܘ ܡܝܬܝܢܢ ܘܐܢ ܚܝܝܢܢ ܗܟܝܠ ܘܐܢ ܡܝܬܝܢܢ ܕܡܪܢ ܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.9",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Romans 14:9",
      "text": "ܡܛܠ ܗܢܐ ܐܦ ܡܫܝܚܐ ܡܝܬ ܘܚܝܐ ܘܩܡ ܕܗܘ ܢܗܘܐ ܡܪܝܐ ܠܡܝܬܐ ܘܠܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.10",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Romans 14:10",
      "text": "ܐܢܬ ܕܝܢ ܡܢܐ ܕܐܢ ܐܢܬ ܠܐܚܘܟ ܐܘ ܐܦ ܐܢܬ ܠܡܢܐ ܫܐܛ ܐܢܬ ܠܐܚܘܟ ܟܠܢ ܓܝܪ ܥܬܝܕܝܢܢ ܠܡܩܡ ܩܕܡ ܒܝܡ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.11",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Romans 14:11",
      "text": "ܐܝܟ ܕܟܬܝܒ ܕܚܝ ܐܢܐ ܐܡܪ ܡܪܝܐ ܕܠܝ ܬܟܘܦ ܟܠ ܒܪܘܟ ܘܠܝ ܢܘܕܐ ܟܠ ܠܫܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.12",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Romans 14:12",
      "text": "ܡܕܝܢ ܟܠ ܐܢܫ ܡܢܢ ܦܬܓܡܐ ܚܠܦ ܢܦܫܗ ܝܗܒ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.13",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Romans 14:13",
      "text": "ܠܐ ܡܟܝܠ ܢܕܘܢ ܚܕ ܠܚܕ ܐܠܐ ܗܕܐ ܕܘܢܘ ܝܬܝܪܐܝܬ ܕܬܘܩܠܬܐ ܠܐܚܘܟ ܠܐ ܬܤܝܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.14",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Romans 14:14",
      "text": "ܝܕܥ ܐܢܐ ܓܝܪ ܘܡܦܤ ܐܢܐ ܒܡܪܝܐ ܝܫܘܥ ܕܡܕܡ ܕܡܤܝܒ ܡܢ ܠܘܬܗ ܠܝܬ ܐܠܐ ܠܐܝܢܐ ܕܪܢܐ ܥܠ ܡܕܡ ܕܛܡܐ ܠܗܘ ܗܘ ܒܠܚܘܕ ܛܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.15",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Romans 14:15",
      "text": "ܐܢ ܕܝܢ ܡܛܠ ܡܐܟܘܠܬܐ ܡܥܝܩ ܐܢܬ ܠܐܚܘܟ ܠܐ ܗܘܐ ܒܚܘܒܐ ܡܗܠܟ ܐܢܬ ܠܐ ܬܘܒܕ ܒܡܐܟܘܠܬܟ ܠܗܘ ܕܡܛܠܬܗ ܡܝܬ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.16",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Romans 14:16",
      "text": "ܘܠܐ ܬܬܓܕܦ ܛܒܬܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.17",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Romans 14:17",
      "text": "ܡܠܟܘܬܗ ܓܝܪ ܕܐܠܗܐ ܠܐ ܗܘܬ ܡܐܟܠܐ ܘܡܫܬܝܐ ܐܠܐ ܟܐܢܘܬܐ ܘܫܠܡܐ ܘܚܕܘܬܐ ܒܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.18",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Romans 14:18",
      "text": "ܡܢ ܕܒܗܠܝܢ ܓܝܪ ܡܫܡܫ ܠܡܫܝܚܐ ܫܦܪ ܠܐܠܗܐ ܘܩܕܡ ܒܢܝܢܫܐ ܒܩܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.19",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Romans 14:19",
      "text": "ܗܫܐ ܒܬܪ ܫܠܡܐ ܢܪܗܛ ܘܒܬܪ ܒܢܝܢܐ ܚܕ ܕܚܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.20",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Romans 14:20",
      "text": "ܘܠܐ ܡܛܠ ܡܐܟܘܠܬܐ ܢܫܪܐ ܥܒܕܐ ܕܐܠܗܐ ܟܠܡܕܡ ܓܝܪ ܕܟܐ ܗܘ ܐܠܐ ܒܝܫ ܗܘ ܠܒܪܢܫܐ ܕܒܬܘܩܠܬܐ ܐܟܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.21",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Romans 14:21",
      "text": "ܫܦܝܪ ܗܘ ܕܠܐ ܢܐܟܘܠ ܒܤܪܐ ܘܠܐ ܢܫܬܐ ܚܡܪܐ ܘܠܐ ܡܕܡ ܕܡܬܬܩܠ ܒܗ ܐܚܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.22",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Romans 14:22",
      "text": "ܐܢܬ ܕܐܝܬ ܒܟ ܗܝܡܢܘܬܐ ܒܢܦܫܟ ܐܚܘܕܝܗ ܩܕܡ ܐܠܗܐ ܛܘܒܘܗܝ ܠܡܢ ܕܠܐ ܕܢ ܢܦܫܗ ܒܡܕܡ ܕܦܪܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.14.23",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Romans 14:23",
      "text": "ܐܝܢܐ ܓܝܪ ܕܡܬܦܠܓ ܘܐܟܠ ܐܬܚܝܒ ܠܗ ܡܛܠ ܕܠܘ ܒܗܝܡܢܘܬܐ ܟܠ ܡܕܡ ܓܝܪ ܕܠܐ ܗܘܐ ܡܢ ܗܝܡܢܘܬܐ ܚܛܝܬܐ ܗܘ ܀",
      "paragraphStart": false
    }
  ]
}
