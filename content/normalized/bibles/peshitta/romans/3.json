{
  "chapter": {
    "id": "peshitta:romans.3",
    "translationId": "peshitta",
    "bookSlug": "romans",
    "chapterNumber": 3,
    "referenceLabel": "Romans 3",
    "summary": "Source text for Romans 3 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:romans.3.1",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Romans 3:1",
      "text": "ܡܢܐ ܗܝ ܗܟܝܠ ܝܬܝܪܘܬܗ ܕܝܗܘܕܝܐ ܐܘ ܡܢܐ ܝܘܬܪܢܗ ܕܓܙܘܪܬܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:romans.3.2",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Romans 3:2",
      "text": "ܤܓܝ ܒܟܠ ܡܕܡ ܠܘܩܕܡ ܕܐܬܗܝܡܢ ܡܠܘܗܝ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.3",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Romans 3:3",
      "text": "ܐܢ ܡܢܗܘܢ ܓܝܪ ܠܐ ܗܝܡܢܘ ܕܠܡܐ ܒܕܠܐ ܗܝܡܢܘ ܗܝܡܢܘܬܗ ܕܐܠܗܐ ܒܛܠܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.4",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Romans 3:4",
      "text": "ܚܤ ܐܝܬܘܗܝ ܓܝܪ ܐܠܗܐ ܫܪܝܪܐ ܘܟܠ ܒܪܢܫ ܕܓܠ ܐܝܟܢܐ ܕܟܬܝܒ ܕܬܗܘܐ ܟܐܝܢ ܒܡܠܝܟ ܘܬܙܟܐ ܟܕ ܕܝܢܝܢ ܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.5",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Romans 3:5",
      "text": "ܐܢ ܕܝܢ ܥܘܠܢ ܟܐܢܘܬܗ ܕܐܠܗܐ ܡܩܝܡ ܡܢܐ ܢܐܡܪ ܠܡܐ ܥܘܠ ܗܘ ܐܠܗܐ ܕܡܝܬܐ ܪܘܓܙܗ ܐܝܟ ܒܪܢܫܐ ܗܘ ܡܡܠܠ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.6",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Romans 3:6",
      "text": "ܚܤ ܘܐܢ ܠܐ ܐܝܟܢܐ ܢܕܘܢ ܐܠܗܐ ܠܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.7",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Romans 3:7",
      "text": "ܐܢ ܓܝܪ ܫܪܪܗ ܕܐܠܗܐ ܐܬܝܬܪ ܒܕܓܠܘܬܝ ܠܬܫܒܘܚܬܗ ܕܝܠܗ ܠܡܢܐ ܗܟܝܠ ܐܢܐ ܐܝܟ ܚܛܝܐ ܡܬܬܕܝܢ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.8",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Romans 3:8",
      "text": "ܐܘ ܕܠܡܐ ܐܝܟ ܕܡܓܕܦܝܢ ܥܠܝܢ ܘܐܡܪܝܢ ܕܐܡܪܝܢܢ ܕܢܥܒܕ ܒܝܫܬܐ ܕܢܐܬܝܢ ܛܒܬܐ ܗܢܘܢ ܕܕܝܢܗܘܢ ܢܛܝܪ ܗܘ ܠܟܐܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.9",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Romans 3:9",
      "text": "ܡܢܐ ܗܟܝܠ ܐܚܝܕܝܢܢ ܝܬܝܪܐ ܕܩܕܡܢ ܦܤܩܢ ܥܠ ܝܗܘܕܝܐ ܘܥܠ ܐܪܡܝܐ ܕܬܚܝܬ ܚܛܝܬܐ ܐܢܘܢ ܟܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.10",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Romans 3:10",
      "text": "ܐܝܟ ܕܟܬܝܒ ܕܠܝܬ ܟܐܢܐ ܐܦܠܐ ܚܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.11",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Romans 3:11",
      "text": "ܘܠܐ ܕܡܤܬܟܠ ܘܠܐ ܕܒܥܐ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.12",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Romans 3:12",
      "text": "ܟܠܗܘܢ ܤܛܘ ܐܟܚܕܐ ܘܐܤܬܠܝܘ ܘܠܝܬ ܕܥܒܕ ܛܒܬܐ ܐܦܠܐ ܚܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.13",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Romans 3:13",
      "text": "ܩܒܪܐ ܦܬܝܚܐ ܓܓܪܬܗܘܢ ܘܠܫܢܝܗܘܢ ܢܟܘܠܬܢܝܢ ܘܚܡܬܐ ܕܐܤܦܤ ܬܚܝܬ ܤܦܘܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.14",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Romans 3:14",
      "text": "ܦܘܡܗܘܢ ܡܠܐ ܠܘܛܬܐ ܘܡܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.15",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Romans 3:15",
      "text": "ܘܪܓܠܝܗܘܢ ܩܠܝܠܢ ܠܡܐܫܕ ܕܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.16",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Romans 3:16",
      "text": "ܫܚܩܐ ܘܕܘܘܢܐ ܒܐܘܪܚܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.17",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Romans 3:17",
      "text": "ܘܐܘܪܚܐ ܕܫܠܡܐ ܠܐ ܝܕܥܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.18",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Romans 3:18",
      "text": "ܘܕܚܠܬܗ ܕܐܠܗܐ ܠܝܬ ܩܕܡ ܥܝܢܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.19",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Romans 3:19",
      "text": "ܝܕܥܝܢܢ ܕܝܢ ܕܡܕܡ ܕܐܡܪ ܢܡܘܤܐ ܠܐܝܠܝܢ ܕܒܢܡܘܤܐ ܐܢܘܢ ܐܡܪ ܕܟܠ ܦܘܡ ܢܤܬܟܪ ܘܥܠܡܐ ܟܠܗ ܢܬܚܝܒ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.20",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Romans 3:20",
      "text": "ܡܛܠ ܕܡܢ ܥܒܕܘܗܝ ܕܢܡܘܤܐ ܠܐ ܡܙܕܕܩ ܟܠ ܒܤܪ ܩܕܡܘܗܝ ܡܢ ܢܡܘܤܐ ܓܝܪ ܐܬܝܕܥܬ ܚܛܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.21",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Romans 3:21",
      "text": "ܗܫܐ ܕܝܢ ܕܠܐ ܢܡܘܤܐ ܟܐܢܘܬܗ ܕܐܠܗܐ ܐܬܓܠܝܬ ܘܡܤܗܕ ܥܠܝܗ ܗܘ ܢܡܘܤܐ ܘܢܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.22",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Romans 3:22",
      "text": "ܟܐܢܘܬܗ ܕܝܢ ܕܐܠܗܐ ܒܝܕ ܗܝܡܢܘܬܐ ܗܝ ܕܝܫܘܥ ܡܫܝܚܐ ܠܟܠܢܫ ܐܦ ܥܠ ܟܠܢܫ ܕܡܗܝܡܢ ܒܗ ܠܝܬ ܓܝܪ ܦܘܪܫܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.23",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Romans 3:23",
      "text": "ܡܛܠ ܕܟܠܗܘܢ ܚܛܘ ܘܚܤܝܪܝܢ ܡܢ ܬܫܒܘܚܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.24",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Romans 3:24",
      "text": "ܘܡܙܕܕܩܝܢ ܒܛܝܒܘܬܐ ܡܓܢ ܘܒܦܘܪܩܢܐ ܕܐܝܬܘܗܝ ܒܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.25",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Romans 3:25",
      "text": "ܗܢܐ ܕܩܕܡ ܤܡܗ ܐܠܗܐ ܚܘܤܝܐ ܒܗܝܡܢܘܬܐ ܕܕܡܗ ܡܛܠ ܚܛܗܝܢ ܕܡܢ ܩܕܝܡ ܚܛܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.26",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Romans 3:26",
      "text": "ܒܐܬܪܐ ܕܝܗܒ ܠܢ ܐܠܗܐ ܒܡܓܪܬ ܪܘܚܗ ܠܬܚܘܝܬܐ ܕܟܐܢܘܬܗ ܕܒܙܒܢܐ ܗܢܐ ܕܗܘ ܢܗܘܐ ܟܐܢܐ ܘܢܙܕܩ ܒܟܐܢܘܬܐ ܠܡܢ ܕܒܗܝܡܢܘܬܐ ܗܘ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.27",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Romans 3:27",
      "text": "ܐܝܟܘ ܗܟܝܠ ܫܘܒܗܪܐ ܐܬܒܛܠ ܠܗ ܒܐܝܢܐ ܢܡܘܤܐ ܕܥܒܕܐ ܠܐ ܐܠܐ ܒܢܡܘܤܐ ܕܗܝܡܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.28",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Romans 3:28",
      "text": "ܡܬܪܥܝܢܢ ܗܟܝܠ ܕܒܗܝܡܢܘܬܐ ܗܘ ܡܙܕܕܩ ܒܪܢܫܐ ܘܠܐ ܒܥܒܕܐ ܕܢܡܘܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.29",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Romans 3:29",
      "text": "ܠܡܐ ܓܝܪ ܐܠܗܐ ܕܝܗܘܕܝܐ ܗܘ ܒܠܚܘܕ ܘܕܥܡܡܐ ܠܐ ܐܝܢ ܐܦ ܕܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.30",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Romans 3:30",
      "text": "ܡܛܠ ܕܚܕ ܗܘ ܐܠܗܐ ܕܡܙܕܩ ܓܙܘܪܬܐ ܒܗܝܡܢܘܬܐ ܐܦ ܥܘܪܠܘܬܐ ܒܗ ܒܗܝܡܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:romans.3.31",
      "translationId": "peshitta",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Romans 3:31",
      "text": "ܠܡܐ ܗܟܝܠ ܢܡܘܤܐ ܗܘ ܡܒܛܠܝܢܢ ܒܗܝܡܢܘܬܐ ܚܤ ܐܠܐ ܢܡܘܤܐ ܗܘ ܡܩܝܡܝܢܢ ܀",
      "paragraphStart": false
    }
  ]
}
