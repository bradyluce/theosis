  "verses": [
    {
      "id": "peshitta:first-timothy.4.1",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "1 Timothy 4:1",
      "text": "ܪܘܚܐ ܕܝܢ ܦܫܝܩܐܝܬ ܐܡܪܐ ܕܒܙܒܢܐ ܐܚܪܝܐ ܢܦܪܩܘܢ ܐܢܫ ܐܢܫ ܡܢ ܗܝܡܢܘܬܐ ܘܢܐܙܠܘܢ ܒܬܪ ܪܘܚܐ ܛܥܝܬܐ ܘܒܬܪ ܝܘܠܦܢܐ ܕܫܐܕܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-timothy.4.2",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "1 Timothy 4:2",
      "text": "ܗܠܝܢ ܕܒܐܤܟܡܐ ܕܓܠܐ ܡܛܥܝܢ ܘܡܡܠܠܝܢ ܟܕܒܘܬܐ ܘܟܘܝܢ ܒܬܐܪܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.4.3",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "1 Timothy 4:3",
      "text": "ܘܟܠܝܢ ܠܡܙܕܘܓܘ ܘܡܦܪܩܝܢ ܡܢ ܡܐܟܠܬܐ ܐܝܠܝܢ ܕܐܠܗܐ ܒܪܐ ܐܢܝܢ ܠܚܘܫܚܐ ܘܠܬܘܕܝܬܐ ܠܐܝܠܝܢ ܕܡܗܝܡܢܝܢ ܘܝܕܥܝܢ ܫܪܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.4.4",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "1 Timothy 4:4",
      "text": "ܡܛܠ ܕܟܠ ܕܒܪܐ ܠܐܠܗܐ ܫܦܝܪ ܗܘ ܘܠܝܬ ܡܕܡ ܕܡܤܠܝ ܐܢ ܒܬܘܕܝܬܐ ܢܬܢܤܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.4.5",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "1 Timothy 4:5",
      "text": "ܡܬܩܕܫ ܓܝܪ ܒܡܠܬܐ ܕܐܠܗܐ ܘܒܨܠܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.4.6",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "1 Timothy 4:6",
      "text": "ܗܠܝܢ ܐܢ ܬܗܘܐ ܡܠܦ ܠܐܚܝܟ ܡܫܡܫܢܐ ܛܒܐ ܬܗܘܐ ܕܝܫܘܥ ܡܫܝܚܐ ܟܕ ܡܬܪܒܐ ܐܢܬ ܒܡܠܐ ܕܗܝܡܢܘܬܐ ܘܒܝܘܠܦܢܐ ܛܒܐ ܕܝܠܝܦ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.4.7",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "1 Timothy 4:7",
      "text": "ܡܢ ܫܘܥܝܬܐ ܕܝܢ ܦܟܝܗܬܐ ܕܤܒܬܐ ܐܫܬܐܠ ܘܕܪܫ ܢܦܫܟ ܒܟܐܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.4.8",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "1 Timothy 4:8",
      "text": "ܕܘܪܫܐ ܓܝܪ ܕܦܓܪܐ ܙܒܢܐ ܗܘ ܙܥܘܪܐ ܡܘܬܪ ܟܐܢܘܬܐ ܕܝܢ ܒܟܠ ܡܕܡ ܡܘܬܪܐ ܘܐܝܬ ܠܗ ܫܘܘܕܝܐ ܕܚܝܐ ܕܙܒܢܐ ܗܢܐ ܘܕܥܬܝܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.4.9",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "1 Timothy 4:9",
      "text": "ܡܗܝܡܢܐ ܗܝ ܡܠܬܐ ܘܫܘܝܐ ܗܝ ܠܡܩܒܠܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.4.10",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "1 Timothy 4:10",
      "text": "ܡܛܠ ܗܕܐ ܗܘ ܓܝܪ ܠܐܝܢܢ ܘܡܬܚܤܕܝܢܢ ܕܡܤܒܪܝܢܢ ܒܐܠܗܐ ܚܝܐ ܕܐܝܬܘܗܝ ܡܚܝܢܐ ܕܒܢܝܢܫܐ ܟܠܗܘܢ ܝܬܝܪܐܝܬ ܕܡܗܝܡܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.4.11",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "1 Timothy 4:11",
      "text": "ܗܠܝܢ ܐܠܦ ܘܦܩܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.4.12",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "1 Timothy 4:12",
      "text": "ܘܠܐ ܐܢܫ ܢܒܤܐ ܥܠ ܛܠܝܘܬܟ ܐܠܐ ܗܘܝ ܕܡܘܬܐ ܠܡܗܝܡܢܐ ܒܡܠܬܐ ܘܒܗܘܦܟܐ ܘܒܚܘܒܐ ܘܒܗܝܡܢܘܬܐ ܘܒܕܟܝܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.4.13",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "1 Timothy 4:13",
      "text": "ܥܕ ܐܬܐ ܐܢܐ ܐܬܚܦܛ ܒܩܪܝܢܐ ܘܒܒܥܘܬܐ ܘܒܝܘܠܦܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.4.14",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "1 Timothy 4:14",
      "text": "ܘܠܐ ܬܒܤܐ ܒܡܘܗܒܬܐ ܕܐܝܬ ܒܟ ܗܝ ܕܐܬܝܗܒܬ ܠܟ ܒܢܒܝܘܬܐ ܘܒܤܝܡ ܐܝܕܐ ܕܩܫܝܫܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.4.15",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "1 Timothy 4:15",
      "text": "ܒܗܠܝܢ ܐܬܗܓܐ ܘܒܗܝܢ ܗܘܝ ܕܬܬܝܕܥ ܠܟܠܢܫ ܕܠܩܕܡܝܟ ܐܬܐ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.4.16",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "1 Timothy 4:16",
      "text": "ܘܐܙܕܗܪ ܒܢܦܫܟ ܘܒܝܘܠܦܢܟ ܘܚܡܤܢ ܒܗܘܢ ܟܕ ܗܠܝܢ ܓܝܪ ܬܥܒܕ ܢܦܫܟ ܬܚܐ ܘܠܐܝܠܝܢ ܕܫܡܥܝܢ ܠܟ ܀",
      "paragraphStart": false
    }
  ]
}
