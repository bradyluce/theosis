{
  "chapter": {
    "id": "peshitta:first-timothy.1",
    "translationId": "peshitta",
    "bookSlug": "first-timothy",
    "chapterNumber": 1,
    "referenceLabel": "1 Timothy 1",
    "summary": "Source text for 1 Timothy 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:first-timothy.1.1",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "1 Timothy 1:1",
      "text": "ܦܘܠܘܤ ܫܠܝܚܐ ܕܝܫܘܥ ܡܫܝܚܐ ܒܦܘܩܕܢܐ ܕܐܠܗܐ ܡܚܝܢܢ ܘܕܡܫܝܚܐ ܝܫܘܥ ܤܒܪܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-timothy.1.2",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "1 Timothy 1:2",
      "text": "ܠܛܝܡܬܐܘܤ ܒܪܐ ܫܪܝܪܐ ܒܗܝܡܢܘܬܐ ܛܝܒܘܬܐ ܘܪܚܡܐ ܘܫܠܡܐ ܡܢ ܐܠܗܐ ܐܒܘܢ ܘܡܫܝܚܐ ܝܫܘܥ ܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.1.3",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "1 Timothy 1:3",
      "text": "ܒܥܝܬ ܗܘܝܬ ܡܢܟ ܟܕ ܐܙܠ ܐܢܐ ܠܡܩܕܘܢܝܐ ܕܬܩܘܐ ܒܐܦܤܘܤ ܘܬܦܩܕ ܠܐܢܫ ܐܢܫ ܕܠܐ ܢܠܦܘܢ ܝܘܠܦܢܐ ܡܫܚܠܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.1.4",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "1 Timothy 1:4",
      "text": "ܘܠܐ ܢܬܪܡܘܢ ܠܫܘܥܝܬܐ ܘܠܬܫܥܝܬܐ ܕܫܪܒܬܐ ܕܤܟܐ ܠܝܬ ܠܗܘܢ ܗܠܝܢ ܕܚܪܝܢܐ ܗܘ ܥܒܕܢ ܝܬܝܪܐܝܬ ܘܠܐ ܒܢܝܢܐ ܒܗܝܡܢܘܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.1.5",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "1 Timothy 1:5",
      "text": "ܤܟܗ ܕܝܢ ܕܦܘܩܕܢܐ ܐܝܬܘܗܝ ܚܘܒܐ ܕܡܢ ܠܒܐ ܕܟܝܐ ܘܡܢ ܬܐܪܬܐ ܛܒܬܐ ܘܡܢ ܗܝܡܢܘܬܐ ܫܪܝܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.1.6",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "1 Timothy 1:6",
      "text": "ܘܡܢܗܝܢ ܡܢ ܗܠܝܢ ܛܥܘ ܐܢܫܐ ܘܤܛܘ ܠܡܠܐ ܤܪܝܩܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.1.7",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "1 Timothy 1:7",
      "text": "ܒܕܒܥܘ ܠܡܗܘܐ ܡܠܦܢܐ ܕܢܡܘܤܐ ܟܕ ܠܐ ܡܤܬܟܠܝܢ ܡܕܡ ܕܡܡܠܠܝܢ ܘܠܐ ܡܕܡ ܕܥܠܘܗܝ ܡܬܚܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.1.8",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "1 Timothy 1:8",
      "text": "ܝܕܥܝܢܢ ܕܝܢ ܕܢܡܘܤܐ ܫܦܝܪ ܗܘ ܐܢ ܐܢܫ ܐܟܘܬܗ ܕܢܡܘܤܐ ܢܬܕܒܪ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.1.9",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "1 Timothy 1:9",
      "text": "ܟܕ ܝܕܥ ܕܠܟܐܢܐ ܢܡܘܤܐ ܠܐ ܤܝܡ ܐܠܐ ܠܥܘܠܐ ܘܠܡܪܘܕܐ ܘܠܪܫܝܥܐ ܘܠܚܛܝܐ ܘܠܥܢܬܐ ܘܠܐܝܠܝܢ ܕܠܐ ܕܟܝܢ ܘܠܐܝܠܝܢ ܕܡܚܝܢ ܠܐܒܗܝܗܘܢ ܘܠܐܝܠܝܢ ܕܡܚܝܢ ܠܐܡܗܬܗܘܢ ܘܠܩܛܘܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.1.10",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "1 Timothy 1:10",
      "text": "ܘܠܙܢܝܐ ܘܠܫܟܒܝ ܥܡ ܕܟܪܐ ܘܠܓܢܒܝ ܒܢܝ ܚܐܪܐ ܘܠܕܓܠܐ ܘܠܥܒܪܝ ܥܠ ܡܘܡܬܐ ܘܠܟܠܡܕܡ ܕܐܝܬܘܗܝ ܤܩܘܒܠܐ ܠܝܘܠܦܢܐ ܚܠܝܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.1.11",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "1 Timothy 1:11",
      "text": "ܕܐܘܢܓܠܝܘܢ ܕܬܫܒܘܚܬܗ ܕܐܠܗܐ ܡܒܪܟܐ ܗܘ ܕܐܢܐ ܐܬܗܝܡܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.1.12",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "1 Timothy 1:12",
      "text": "ܘܡܘܕܐ ܐܢܐ ܠܗ ܕܚܝܠܢܝ ܠܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܕܚܫܒܢܝ ܡܗܝܡܢܐ ܘܤܡܢܝ ܠܬܫܡܫܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.1.13",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "1 Timothy 1:13",
      "text": "ܠܝ ܕܡܢ ܩܕܝܡ ܡܓܕܦܢ ܗܘܝܬ ܘܪܕܘܦ ܘܡܨܥܪܢ ܐܠܐ ܐܬܚܢܢܬ ܡܛܠ ܕܟܕ ܠܐ ܝܕܥ ܗܘܝܬ ܥܒܕܬ ܕܠܐ ܗܝܡܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.1.14",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "1 Timothy 1:14",
      "text": "ܤܓܝܬ ܒܝ ܕܝܢ ܛܝܒܘܬܗ ܕܡܪܢ ܘܗܝܡܢܘܬܐ ܘܚܘܒܐ ܕܒܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.1.15",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "1 Timothy 1:15",
      "text": "ܡܗܝܡܢܐ ܗܝ ܡܠܬܐ ܘܫܘܝܐ ܗܝ ܠܡܩܒܠܘܬܗ ܕܝܫܘܥ ܡܫܝܚܐ ܐܬܐ ܠܥܠܡܐ ܠܡܚܝܘ ܠܚܛܝܐ ܕܩܕܡܝܗܘܢ ܐܢܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.1.16",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "1 Timothy 1:16",
      "text": "ܐܠܐ ܡܛܠ ܗܢܐ ܪܚܡ ܥܠܝ ܕܒܝ ܩܕܡܐ ܢܚܘܐ ܝܫܘܥ ܡܫܝܚܐ ܟܠܗ ܡܓܪܬ ܪܘܚܗ ܠܬܚܘܝܬܐ ܕܐܝܠܝܢ ܕܥܬܝܕܝܢ ܕܢܗܝܡܢܘܢ ܒܗ ܠܚܝܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.1.17",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "1 Timothy 1:17",
      "text": "ܠܡܠܟܐ ܕܝܢ ܕܥܠܡܐ ܠܗܘ ܕܠܐ ܡܬܚܒܠ ܘܠܐ ܡܬܚܙܐ ܕܗܘܝܘ ܚܕ ܐܠܗܐ ܐܝܩܪܐ ܘܬܫܒܘܚܬܐ ܠܥܠܡ ܥܠܡܝܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.1.18",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "1 Timothy 1:18",
      "text": "ܗܢܐ ܦܘܩܕܢܐ ܡܓܥܠ ܐܢܐ ܠܟ ܒܪܝ ܛܝܡܬܐܘܤ ܐܝܟ ܢܒܝܘܬܐ ܩܕܡܝܬܐ ܕܗܘܝ ܥܠܝܟ ܕܬܦܠܘܚ ܒܗܝܢ ܦܠܚܘܬܐ ܗܕܐ ܫܦܝܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.1.19",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "1 Timothy 1:19",
      "text": "ܒܗܝܡܢܘܬܐ ܘܒܬܐܪܬܐ ܛܒܬܐ ܐܝܠܝܢ ܓܝܪ ܕܠܗܕܐ ܕܚܩܘ ܡܢܗܘܢ ܡܢ ܗܝܡܢܘܬܐ ܐܤܬܪܩܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.1.20",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "1 Timothy 1:20",
      "text": "ܐܝܟ ܗܘܡܢܐܘܤ ܘܐܠܟܤܢܕܪܘܤ ܗܠܝܢ ܕܐܫܠܡܬ ܠܤܛܢܐ ܕܢܬܪܕܘܢ ܕܠܐ ܢܗܘܘܢ ܡܓܕܦܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
