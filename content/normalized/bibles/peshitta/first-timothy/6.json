    "chapterNumber": 6,
    "referenceLabel": "1 Timothy 6",
    "summary": "Source text for 1 Timothy 6 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:first-timothy.6.1",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "1 Timothy 6:1",
      "text": "ܐܝܠܝܢ ܕܐܝܬܝܗܘܢ ܬܚܝܬ ܢܝܪܐ ܕܥܒܕܘܬܐ ܠܡܪܝܗܘܢ ܒܟܠ ܐܝܩܪ ܢܐܚܕܘܢ ܕܠܐ ܢܗܘܐ ܫܡܗ ܕܐܠܗܐ ܘܝܘܠܦܢܗ ܡܬܓܕܦ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-timothy.6.2",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "1 Timothy 6:2",
      "text": "ܐܝܠܝܢ ܕܝܢ ܕܐܝܬ ܠܗܘܢ ܡܪܝܐ ܡܗܝܡܢܐ ܠܐ ܢܒܤܘܢ ܒܗܘܢ ܥܠ ܕܐܚܝܗܘܢ ܐܢܘܢ ܐܠܐ ܝܬܝܪܐܝܬ ܢܫܡܫܘܢ ܐܢܘܢ ܥܠ ܕܡܗܝܡܢܐ ܐܢܘܢ ܘܚܒܝܒܐ ܗܠܝܢ ܕܡܬܬܢܝܚܝܢ ܒܬܫܡܫܬܗܘܢ ܗܠܝܢ ܐܠܦ ܘܒܥܝ ܡܢܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.6.3",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "1 Timothy 6:3",
      "text": "ܐܢ ܕܝܢ ܐܝܬ ܐܢܫ ܕܡܠܦ ܝܘܠܦܢܐ ܐܚܪܢܐ ܘܠܐ ܡܬܩܪܒ ܠܡܠܐ ܚܠܝܡܬܐ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܘܠܝܘܠܦܢܐ ܕܕܚܠܬ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.6.4",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "1 Timothy 6:4",
      "text": "ܗܢܐ ܡܬܪܝܡ ܟܕ ܡܕܡ ܠܐ ܝܕܥ ܐܠܐ ܟܪܝܗ ܒܕܪܫܐ ܘܒܒܥܬܐ ܕܡܠܐ ܕܡܢܗܝܢ ܗܘܐ ܚܤܡܐ ܘܚܪܝܢܐ ܘܓܘܕܦܐ ܘܡܤܡ ܒܪܥܝܢܐ ܒܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.6.5",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "1 Timothy 6:5",
      "text": "ܘܫܚܩܐ ܕܒܢܝܢܫܐ ܐܝܠܝܢ ܕܡܚܒܠ ܪܥܝܢܗܘܢ ܘܓܠܝܙܝܢ ܡܢ ܩܘܫܬܐ ܘܤܒܪܝܢ ܕܬܓܘܪܬܐ ܗܝ ܕܚܠܬ ܐܠܗܐ ܐܢܬ ܕܝܢ ܐܬܪܚܩ ܡܢ ܗܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.6.6",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "1 Timothy 6:6",
      "text": "ܬܐܓܘܪܬܢ ܓܝܪ ܕܝܠܢ ܪܒܐ ܗܝ ܕܐܝܬܝܗ ܕܚܠܬ ܐܠܗܐ ܒܚܫܚܬܐ ܕܡܤܬܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.6.7",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "1 Timothy 6:7",
      "text": "ܡܕܡ ܓܝܪ ܠܐ ܐܥܠܢ ܠܥܠܡܐ ܘܝܕܝܥܐ ܕܐܦܠܐ ܕܢܦܩ ܡܢܗ ܡܫܟܚܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.6.8",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "1 Timothy 6:8",
      "text": "ܡܛܠ ܗܢܐ ܤܦܩܐ ܠܢ ܡܐܟܘܠܬܐ ܘܬܟܤܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.6.9",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "1 Timothy 6:9",
      "text": "ܐܝܠܝܢ ܕܝܢ ܕܨܒܝܢ ܠܡܥܬܪ ܢܦܠܝܢ ܒܢܤܝܘܢܐ ܘܒܦܚܐ ܘܒܪܓܝܓܬܐ ܤܓܝܐܬܐ ܕܤܟܠܢ ܘܡܤܓܦܢ ܘܡܛܒܥܢ ܠܒܢܝܢܫܐ ܒܚܒܠܐ ܘܒܐܒܕܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.6.10",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "1 Timothy 6:10",
      "text": "ܥܩܪܐ ܕܝܢ ܕܟܘܠܗܝܢ ܒܝܫܬܐ ܐܝܬܝܗ ܪܚܡܬ ܟܤܦܐ ܘܐܝܬ ܐܢܫܐ ܕܐܬܪܓܪܓܘ ܠܗ ܘܡܢ ܗܝܡܢܘܬܐ ܛܥܘ ܘܢܦܫܗܘܢ ܐܥܠܘ ܠܕܐܘܢܐ ܤܓܝܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.6.11",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "1 Timothy 6:11",
      "text": "ܐܢܬ ܕܝܢ ܐܘ ܒܪܢܫܐ ܕܐܠܗܐ ܡܢ ܗܠܝܢ ܥܪܘܩ ܘܗܪܛ ܒܬܪ ܙܕܝܩܘܬܐ ܘܒܬܪ ܟܐܢܘܬܐ ܘܒܬܪ ܗܝܡܢܘܬܐ ܘܒܬܪ ܚܘܒܐ ܘܒܬܪ ܡܤܝܒܪܢܘܬܐ ܘܒܬܪ ܡܟܝܟܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.6.12",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "1 Timothy 6:12",
      "text": "ܘܐܬܟܬܫ ܒܐܓܘܢܐ ܛܒܐ ܕܗܝܡܢܘܬܐ ܘܐܕܪܟ ܚܝܐ ܕܠܥܠܡ ܕܠܗܘܢ ܐܬܩܪܝܬ ܘܐܘܕܝܬ ܬܘܕܝܬܐ ܛܒܬܐ ܩܕܡ ܤܗܕܐ ܤܓܝܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.6.13",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "1 Timothy 6:13",
      "text": "ܡܤܗܕ ܐܢܐ ܠܟ ܩܕܡ ܐܠܗܐ ܗܘ ܕܡܚܐ ܟܠ ܘܝܫܘܥ ܡܫܝܚܐ ܗܘ ܕܐܤܗܕ ܩܕܡ ܦܢܛܝܘܤ ܦܝܠܛܘܤ ܤܗܕܘܬܐ ܫܦܝܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.6.14",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "1 Timothy 6:14",
      "text": "ܕܬܛܪܝܘܗܝ ܦܘܩܕܢܐ ܕܠܐ ܛܘܠܫܐ ܘܕܠܐ ܡܘܡܐ ܥܕܡܐ ܠܓܠܝܢܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.6.15",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "1 Timothy 6:15",
      "text": "ܗܘ ܕܥܬܝܕ ܒܙܒܢܗ ܢܚܘܝܘܗܝ ܐܠܗܐ ܡܒܪܟܐ ܘܚܝܠܬܢܐ ܒܠܚܘܕܘܗܝ ܡܠܟܐ ܕܡܠܟܐ ܘܡܪܐ ܕܡܪܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.6.16",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "1 Timothy 6:16",
      "text": "ܗܘ ܕܗܘ ܒܠܚܘܕܘܗܝ ܠܐ ܡܬܚܒܠ ܘܥܡܪ ܒܢܘܗܪܐ ܕܐܢܫ ܠܐ ܡܫܟܚ ܕܢܬܩܪܒ ܠܗ ܘܐܢܫ ܡܢ ܒܢܝܢܫܐ ܠܐ ܚܙܝܗܝ ܘܐܦܠܐ ܡܨܐ ܠܡܚܙܝܗ ܗܘ ܕܠܗ ܐܝܩܪܐ ܘܫܘܠܛܢܐ ܠܥܠܡ ܥܠܡܝܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.6.17",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "1 Timothy 6:17",
      "text": "ܠܥܬܝܪܐ ܕܥܠܡܐ ܗܢܐ ܦܩܕ ܕܠܐ ܢܬܪܝܡܘܢ ܒܪܥܝܢܝܗܘܢ ܘܠܐ ܢܬܬܟܠܘܢ ܥܠ ܥܘܬܪܐ ܕܠܝܬ ܥܠܘܗܝ ܬܘܟܠܢܐ ܐܠܐ ܥܠ ܐܠܗܐ ܚܝܐ ܗܘ ܕܝܗܒ ܠܢ ܟܠ ܥܬܝܪܐܝܬ ܠܢܝܚܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.6.18",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "1 Timothy 6:18",
      "text": "ܘܢܥܒܕܘܢ ܥܒܕܐ ܛܒܐ ܘܢܥܬܪܘܢ ܒܤܘܥܪܢܐ ܫܦܝܪܐ ܘܢܗܘܘܢ ܕܠܝܠܝܢ ܠܡܬܠ ܘܠܡܫܬܘܬܦܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.6.19",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "1 Timothy 6:19",
      "text": "ܘܢܤܝܡܘܢ ܠܢܦܫܗܘܢ ܫܬܐܤܬܐ ܛܒܬܐ ܠܡܕܡ ܕܥܬܝܕ ܕܢܕܪܟܘܢ ܚܝܐ ܫܪܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.6.20",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "1 Timothy 6:20",
      "text": "ܐܘ ܛܝܡܬܐܐ ܐܙܕܗܪ ܒܡܕܡ ܕܐܬܓܥܠ ܠܟ ܘܥܪܘܩ ܡܢ ܒܢܬ ܩܠܐ ܤܪܝܩܬܐ ܘܡܢ ܗܦܟܬܐ ܕܝܕܥܬܐ ܕܓܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.6.21",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "1 Timothy 6:21",
      "text": "ܐܝܠܝܢ ܓܝܪ ܕܡܫܬܘܕܝܢ ܠܗ ܛܥܘ ܠܗܘܢ ܡܢ ܗܝܡܢܘܬܐ ܛܝܒܘܬܐ ܥܡܟ ܐܡܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
