{
  "chapter": {
    "id": "peshitta:first-timothy.5",
    "translationId": "peshitta",
    "bookSlug": "first-timothy",
    "chapterNumber": 5,
    "referenceLabel": "1 Timothy 5",
    "summary": "Source text for 1 Timothy 5 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:first-timothy.5.1",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "1 Timothy 5:1",
      "text": "ܒܩܫܝܫܐ ܠܐ ܬܓܥܘܪ ܐܠܐ ܐܦܝܤܝܗܝ ܐܝܟ ܕܠܐܒܐ ܘܠܐܝܠܝܢ ܕܛܠܝܢ ܐܝܟ ܕܠܐܚܝܟ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-timothy.5.2",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "1 Timothy 5:2",
      "text": "ܘܠܩܫܝܫܬܐ ܐܝܟ ܐܡܗܬܐ ܘܠܐܝܠܝܢ ܕܛܠܝܢ ܐܝܟ ܕܠܐܚܘܬܟ ܒܟܠܗ ܕܟܝܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.3",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "1 Timothy 5:3",
      "text": "ܠܐܪܡܠܬܐ ܝܩܪ ܠܐܝܠܝܢ ܕܐܪܡܠܬܐ ܐܢܝܢ ܒܫܪܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.4",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "1 Timothy 5:4",
      "text": "ܘܐܢ ܐܝܬ ܐܪܡܠܬܐ ܕܐܝܬ ܠܗ ܒܢܝܐ ܐܘ ܒܢܝ ܒܢܝܐ ܢܐܠܦܘܢ ܠܘܩܕܡ ܕܒܒܢܝ ܒܝܬܗܘܢ ܢܙܕܕܩܘܢ ܘܢܦܪܥܘܢ ܚܘܒܠܐ ܠܐܒܗܝܗܘܢ ܗܕܐ ܓܝܪ ܡܩܒܠܐ ܩܕܡ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.5",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "1 Timothy 5:5",
      "text": "ܐܝܕܐ ܕܝܢ ܕܫܪܝܪܐܝܬ ܐܪܡܠܬܐ ܗܝ ܘܡܫܘܚܕܬܐ ܗܕܐ ܤܒܪܗ ܥܠ ܐܠܗܐ ܗܘ ܘܐܡܝܢܐ ܒܨܠܘܬܐ ܘܒܒܥܘܬܐ ܒܠܠܝܐ ܘܒܐܝܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.6",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "1 Timothy 5:6",
      "text": "ܐܝܕܐ ܕܝܢ ܕܦܠܚܐ ܐܤܛܪܢܝܐ ܡܝܬܐ ܗܝ ܟܕ ܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.7",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "1 Timothy 5:7",
      "text": "ܗܠܝܢ ܗܘܝܬ ܡܦܩܕ ܠܗܝܢ ܕܕܠܐ ܪܫܝܢ ܢܗܘܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.8",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "1 Timothy 5:8",
      "text": "ܐܢ ܐܢܫ ܓܝܪ ܕܐܝܠܝܢ ܕܕܝܠܗ ܐܢܘܢ ܘܝܬܝܪܐܝܬ ܕܐܝܠܝܢ ܕܐܝܬܝܗܘܢ ܒܢܝ ܒܝܬܐ ܕܗܝܡܢܘܬܐ ܠܐ ܝܨܦ ܗܢܐ ܟܦܪ ܠܗ ܒܗܝܡܢܘܬܐ ܘܒܝܫ ܗܘ ܡܢ ܐܝܠܝܢ ܕܠܐ ܡܗܝܡܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.9",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "1 Timothy 5:9",
      "text": "ܗܘܝܬ ܗܟܝܠ ܓܒܐ ܐܪܡܠܬܐ ܐܝܕܐ ܕܠܐ ܒܨܝܪܐ ܡܢ ܫܬܝܢ ܫܢܝܢ ܐܝܕܐ ܕܠܚܕ ܗܘ ܓܒܪܐ ܗܘܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.10",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "1 Timothy 5:10",
      "text": "ܘܐܝܬ ܠܗ ܤܗܕܘܬܐ ܕܥܒܕܐ ܫܦܝܪܐ ܐܢ ܪܒܝܬ ܒܢܝܐ ܐܢ ܩܒܠܬ ܐܟܤܢܝܐ ܐܢ ܐܫܝܓܬ ܪܓܠܝܗܘܢ ܕܩܕܝܫܐ ܐܢ ܐܪܘܚܬ ܠܐܠܝܨܐ ܐܢ ܗܠܟܬ ܒܟܠ ܥܒܕ ܛܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.11",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "1 Timothy 5:11",
      "text": "ܡܢ ܐܪܡܠܬܐ ܕܝܢ ܐܝܠܝܢ ܕܛܠܝܢ ܐܫܬܐܠ ܡܨܛܪܝܢ ܠܗܝܢ ܓܝܪ ܥܠ ܡܫܝܚܐ ܘܒܥܝܢ ܠܡܗܘܐ ܠܓܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.12",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "1 Timothy 5:12",
      "text": "ܘܕܝܢܗܝܢ ܩܝܡ ܗܘ ܕܛܠܡ ܗܝܡܢܘܬܗܝܢ ܩܕܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.13",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "1 Timothy 5:13",
      "text": "ܝܠܦܢ ܕܝܢ ܐܦ ܚܒܢܢܘܬܐ ܟܕ ܡܬܟܪܟܢ ܒܝܬ ܒܬܐ ܘܠܐ ܒܠܚܘܕ ܚܒܢܢܘܬܐ ܐܠܐ ܐܦ ܕܢܤܓܝܢ ܡܡܠܠܐ ܘܢܦܪܩܢ ܤܪܝܩܬܐ ܘܢܡܠܠܢ ܡܕܡ ܕܠܐ ܘܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.14",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "1 Timothy 5:14",
      "text": "ܨܒܐ ܐܢܐ ܗܟܝܠ ܕܐܝܠܝܢ ܕܛܠܝܢ ܢܙܕܘܓܢ ܘܢܐܠܕܢ ܒܢܝܐ ܘܢܕܒܪܢ ܒܬܝܗܝܢ ܘܠܐ ܢܬܠܢ ܠܒܥܠܕܒܒܐ ܐܦܠܐ ܚܕܐ ܥܠܬܐ ܕܨܘܚܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.15",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "1 Timothy 5:15",
      "text": "ܥܠ ܕܗܫܐ ܓܝܪ ܫܪܝܘ ܐܢܫ ܐܢܫ ܠܡܤܛܐ ܒܬܪ ܤܛܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.16",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "1 Timothy 5:16",
      "text": "ܐܢ ܐܢܫ ܡܗܝܡܢܐ ܐܘ ܡܗܝܡܢܬܐ ܐܝܬ ܠܗܘܢ ܐܪܡܠܬܐ ܢܬܪܤܘܢ ܐܢܝܢ ܘܠܐ ܢܐܩܪܢ ܥܠ ܥܕܬܐ ܕܠܐܝܠܝܢ ܕܐܪܡܠܬܐ ܐܢܝܢ ܕܫܪܪܐ ܬܤܦܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.17",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "1 Timothy 5:17",
      "text": "ܩܫܝܫܐ ܐܝܠܝܢ ܕܫܦܝܪ ܡܬܕܒܪܝܢ ܠܐܝܩܪܐ ܥܦܝܦܐ ܢܫܘܘܢ ܝܬܝܪܐܝܬ ܐܝܠܝܢ ܕܠܐܝܢ ܒܡܠܬܐ ܘܒܝܘܠܦܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.18",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "1 Timothy 5:18",
      "text": "ܐܡܪ ܓܝܪ ܟܬܒܐ ܕܠܐ ܬܒܠܘܡ ܬܘܪܐ ܒܕܪܟܬܐ ܘܫܘܐ ܗܘ ܦܥܠܐ ܐܓܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.19",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "1 Timothy 5:19",
      "text": "ܥܠ ܩܫܝܫܐ ܩܛܓܪܢܘܬܐ ܠܐ ܬܩܒܠ ܐܠܐ ܥܠ ܦܘܡ ܬܪܝܢ ܘܬܠܬܐ ܤܗܕܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.20",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "1 Timothy 5:20",
      "text": "ܠܐܝܠܝܢ ܕܚܛܝܢ ܩܕܡ ܟܠܢܫ ܟܘܢ ܕܐܦ ܫܪܟܐ ܕܐܢܫܐ ܢܕܚܠܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.21",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "1 Timothy 5:21",
      "text": "ܡܤܗܕ ܐܢܐ ܠܟ ܩܕܡ ܐܠܗܐ ܘܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܘܡܠܐܟܘܗܝ ܓܒܝܐ ܕܗܠܝܢ ܬܛܪ ܘܠܐ ܢܬܩܕܡ ܪܥܝܢܟ ܠܡܕܡ ܘܠܐ ܬܤܥܘܪ ܡܕܡ ܒܡܤܒ ܒܐܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.22",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "1 Timothy 5:22",
      "text": "ܐܝܕܐ ܒܥܓܠ ܥܠ ܐܢܫ ܠܐ ܬܤܝܡ ܘܠܐ ܬܫܬܘܬܦ ܒܚܛܗܐ ܢܘܟܪܝܐ ܢܦܫܟ ܛܪ ܒܕܟܝܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.23",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "1 Timothy 5:23",
      "text": "ܘܡܟܝܠ ܡܝܐ ܠܐ ܬܫܬܐ ܐܠܐ ܚܡܪܐ ܩܠܝܠ ܗܘܝܬ ܫܬܐ ܡܛܠ ܐܤܛܘܡܟܟ ܘܡܛܠ ܟܘܪܗܢܝܟ ܐܡܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.24",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "1 Timothy 5:24",
      "text": "ܐܝܬ ܒܢܝܢܫܐ ܕܚܛܗܝܗܘܢ ܝܕܝܥܝܢ ܐܢܘܢ ܘܡܩܕܡܝܢ ܠܗܘܢ ܠܒܝܬ ܕܝܢܐ ܘܐܝܬ ܕܒܬܪܗܘܢ ܐܙܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.5.25",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "1 Timothy 5:25",
      "text": "ܗܟܢܐ ܐܦ ܥܒܕܐ ܛܒܐ ܝܕܝܥܝܢ ܐܢܘܢ ܘܐܝܠܝܢ ܕܐܚܪܢܝܐܝܬ ܐܢܘܢ ܠܡܛܫܐ ܠܐ ܡܫܟܚܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
