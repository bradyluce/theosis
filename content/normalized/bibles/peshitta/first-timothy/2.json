    "referenceLabel": "1 Timothy 2",
    "summary": "Source text for 1 Timothy 2 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:first-timothy.2.1",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "1 Timothy 2:1",
      "text": "ܒܥܐ ܐܢܐ ܗܟܝܠ ܡܢܟ ܕܡܢ ܩܕܡ ܟܠܡܕܡ ܒܥܘܬܐ ܬܗܘܐ ܡܩܪܒ ܠܐܠܗܐ ܘܨܠܘܬܐ ܘܬܚܢܢܬܐ ܘܬܘܕܝܬܐ ܚܠܦ ܟܠܗܘܢ ܒܢܝܢܫܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-timothy.2.2",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "1 Timothy 2:2",
      "text": "ܚܠܦ ܡܠܟܐ ܘܪܘܪܒܢܐ ܕܥܘܡܪܐ ܫܠܝܐ ܘܢܝܚܐ ܢܥܡܪ ܒܟܠܗ ܕܚܠܬ ܐܠܗܐ ܘܕܟܝܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.2.3",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "1 Timothy 2:3",
      "text": "ܗܕܐ ܓܝܪ ܫܦܝܪܐ ܘܡܩܒܠܐ ܩܕܡ ܐܠܗܐ ܡܚܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.2.4",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "1 Timothy 2:4",
      "text": "ܗܘ ܕܨܒܐ ܕܟܠܗܘܢ ܒܢܝܢܫܐ ܢܚܘܢ ܘܢܬܦܢܘܢ ܠܝܕܥܬܐ ܕܫܪܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.2.5",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "1 Timothy 2:5",
      "text": "ܚܕ ܗܘ ܓܝܪ ܐܠܗܐ ܘܚܕ ܗܘ ܡܨܥܝܐ ܕܐܠܗܐ ܘܕܒܢܝܢܫܐ ܒܪܢܫܐ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.2.6",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "1 Timothy 2:6",
      "text": "ܗܘ ܕܝܗܒ ܢܦܫܗ ܦܘܪܩܢܐ ܚܠܦ ܟܠ ܐܢܫ ܤܗܕܘܬܐ ܕܐܬܬ ܒܙܒܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.2.7",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "1 Timothy 2:7",
      "text": "ܗܝ ܕܐܢܐ ܐܬܤܝܡܬ ܟܪܘܙܗ ܘܫܠܝܚܗ ܩܘܫܬܐ ܐܡܪ ܐܢܐ ܘܠܐ ܡܕܓܠ ܐܢܐ ܕܗܘܝܬ ܡܠܦܢܐ ܕܥܡܡܐ ܒܗܝܡܢܘܬܐ ܕܫܪܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.2.8",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "1 Timothy 2:8",
      "text": "ܨܒܐ ܐܢܐ ܗܟܝܠ ܕܗܘܘ ܡܨܠܝܢ ܓܒܪܐ ܒܟܠ ܕܘܟܐ ܟܕ ܡܪܝܡܝܢ ܐܝܕܝܗܘܢ ܕܟܝܐܝܬ ܕܠܐ ܪܘܓܙܐ ܘܕܠܐ ܡܚܫܒܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.2.9",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "1 Timothy 2:9",
      "text": "ܗܟܢܐ ܐܦ ܢܫܐ ܒܐܤܟܡܐ ܢܟܦܐ ܕܠܒܘܫܐ ܒܬܚܡܨܬܐ ܘܒܢܟܦܘܬܐ ܢܗܘܐ ܬܨܒܝܬܗܝܢ ܠܐ ܒܓܕܘܠܐ ܘܒܕܗܒܐ ܐܘ ܒܡܪܓܢܝܬܐ ܐܘ ܒܢܚܬܐ ܫܦܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.2.10",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "1 Timothy 2:10",
      "text": "ܐܠܐ ܒܥܒܕܐ ܛܒܐ ܐܝܟܢܐ ܕܝܐܐ ܠܢܫܐ ܕܡܫܬܘܕܝܢ ܕܚܠܬ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.2.11",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "1 Timothy 2:11",
      "text": "ܐܢܬܬܐ ܒܫܠܝܐ ܗܘܬ ܝܠܦܐ ܒܟܠ ܫܘܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.2.12",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "1 Timothy 2:12",
      "text": "ܠܐܢܬܬܐ ܓܝܪ ܠܡܠܦܘ ܠܐ ܡܦܤ ܐܢܐ ܘܠܐ ܠܡܡܪܚܘ ܥܠ ܓܒܪܐ ܐܠܐ ܬܗܘܐ ܒܫܠܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.2.13",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "1 Timothy 2:13",
      "text": "ܐܕܡ ܓܝܪ ܐܬܓܒܠ ܠܘܩܕܡ ܘܗܝܕܝܢ ܚܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.2.14",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "1 Timothy 2:14",
      "text": "ܘܐܕܡ ܠܐ ܛܥܐ ܐܢܬܬܐ ܕܝܢ ܛܥܬ ܘܥܒܪܬ ܥܠ ܦܘܩܕܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.2.15",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "1 Timothy 2:15",
      "text": "ܚܝܐ ܕܝܢ ܒܝܕ ܝܠܕܝܗ ܐܢ ܢܩܘܘܢ ܒܗܝܡܢܘܬܐ ܘܒܚܘܒܐ ܘܒܩܕܝܫܘܬܐ ܘܒܢܟܦܘܬܐ ܀",
      "paragraphStart": false
    }
  ]
