    "summary": "Source text for 1 Timothy 3 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:first-timothy.3.1",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "1 Timothy 3:1",
      "text": "ܡܗܝܡܢܐ ܗܝ ܡܠܬܐ ܕܐܢ ܐܢܫ ܪܐܓ ܩܫܝܫܘܬܐ ܥܒܕܐ ܛܒܐ ܪܐܓ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-timothy.3.2",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "1 Timothy 3:2",
      "text": "ܘܠܐ ܕܝܢ ܕܢܗܘܐ ܩܫܝܫܐ ܐܝܢܐ ܕܡܘܡܐ ܠܐ ܡܫܬܟܚ ܒܗ ܘܗܘܐ ܒܥܠܐ ܕܚܕܐ ܐܢܬܬܐ ܐܝܢܐ ܕܥܝܪ ܪܥܝܢܗ ܘܢܟܦ ܘܡܛܟܤ ܘܪܚܡ ܐܟܤܢܝܐ ܘܡܠܦܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.3.3",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "1 Timothy 3:3",
      "text": "ܘܠܐ ܥܒܪ ܥܠ ܚܡܪܐ ܘܠܐ ܪܗܛܐ ܐܝܕܗ ܠܡܡܚܐ ܐܠܐ ܢܗܘܐ ܡܟܝܟ ܘܠܐ ܢܨܝ ܘܠܐ ܪܚܡ ܟܤܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.3.4",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "1 Timothy 3:4",
      "text": "ܘܡܕܒܪ ܒܝܬܗ ܫܦܝܪ ܘܐܚܝܕ ܒܢܘܗܝ ܒܫܘܥܒܕܐ ܒܟܠܗ ܕܟܝܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.3.5",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "1 Timothy 3:5",
      "text": "ܐܢ ܓܝܪ ܒܝܬܐ ܕܢܦܫܗ ܠܐ ܝܕܥ ܕܢܕܒܪ ܫܦܝܪ ܐܝܟܢܐ ܡܫܟܚ ܥܕܬܗ ܕܐܠܗܐ ܕܢܕܒܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.3.6",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "1 Timothy 3:6",
      "text": "ܘܠܐ ܢܗܘܐ ܛܠܐ ܬܘܠܡܕܗ ܕܠܐ ܢܬܪܝܡ ܘܢܦܠ ܒܕܝܢܗ ܕܤܛܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.3.7",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "1 Timothy 3:7",
      "text": "ܘܠܐ ܕܝܢ ܕܐܦ ܤܗܕܘܬܐ ܫܦܝܪܬܐ ܐܝܬ ܠܗ ܡܢ ܒܪܝܐ ܕܠܐ ܢܦܠ ܒܚܤܕܐ ܘܒܦܚܐ ܕܤܛܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.3.8",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "1 Timothy 3:8",
      "text": "ܘܐܦ ܡܫܡܫܢܐ ܗܟܢܐ ܢܗܘܘܢ ܕܟܝܢ ܘܠܐ ܢܡܠܠܘܢ ܬܪܬܝܢ ܘܠܐ ܢܗܘܘܢ ܨܠܝܢ ܠܚܡܪܐ ܤܓܝܐܐ ܘܠܐ ܢܪܚܡܘܢ ܝܘܬܪܢܐ ܛܢܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.3.9",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "1 Timothy 3:9",
      "text": "ܐܠܐ ܢܐܚܕܘܢ ܐܪܙܐ ܕܗܝܡܢܘܬܐ ܒܬܐܪܬܐ ܕܟܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.3.10",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "1 Timothy 3:10",
      "text": "ܘܗܢܘܢ ܗܠܝܢ ܢܬܒܩܘܢ ܠܘܩܕܡ ܘܗܝܕܝܢ ܢܫܡܫܘܢ ܟܕ ܐܝܬܝܗܘܢ ܕܠܐ ܪܫܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.3.11",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "1 Timothy 3:11",
      "text": "ܗܟܢܐ ܐܦ ܢܫܐ ܢܗܘܝܢ ܢܟܦܢ ܘܢܗܘܐ ܥܝܪ ܪܥܝܢܗܝܢ ܘܢܗܘܝܢ ܡܗܝܡܢܢ ܒܟܠ ܡܕܡ ܘܠܐ ܢܗܘܝܢ ܐܟܠܢ ܩܪܨܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.3.12",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "1 Timothy 3:12",
      "text": "ܡܫܡܫܢܐ ܢܗܘܘܢ ܐܝܢܐ ܕܚܕܐ ܐܢܬܬܐ ܗܘܬ ܠܗ ܘܕܒܪ ܒܢܘܗܝ ܘܒܝܬܗ ܫܦܝܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.3.13",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "1 Timothy 3:13",
      "text": "ܐܝܠܝܢ ܓܝܪ ܕܫܡܫܘ ܫܦܝܪ ܕܪܓܐ ܛܒܐ ܩܢܝܢ ܠܢܦܫܗܘܢ ܘܡܓܠܐ ܐܦܐ ܤܓܝܐܐ ܒܗܝܡܢܘܬܐ ܕܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.3.14",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "1 Timothy 3:14",
      "text": "ܗܠܝܢ ܟܬܒ ܐܢܐ ܠܟ ܟܕ ܡܤܒܪ ܐܢܐ ܕܒܥܓܠ ܐܬܐ ܐܢܐ ܠܘܬܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.3.15",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "1 Timothy 3:15",
      "text": "ܘܐܢ ܗܘ ܕܝܢ ܕܡܘܚܪ ܐܢܐ ܕܬܕܥ ܐܝܟܢܐ ܘܠܐ ܠܡܬܗܦܟܘ ܒܒܝܬܗ ܕܐܠܗܐ ܕܐܝܬܝܗ ܥܕܬܐ ܕܐܠܗܐ ܚܝܐ ܥܡܘܕܐ ܘܫܬܐܤܬܐ ܕܫܪܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-timothy.3.16",
      "translationId": "peshitta",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "1 Timothy 3:16",
      "text": "ܘܫܪܝܪܐܝܬ ܪܒ ܗܘ ܐܪܙܐ ܗܢܐ ܕܟܐܢܘܬܐ ܕܐܬܓܠܝ ܒܒܤܪ ܘܐܙܕܕܩ ܒܪܘܚ ܘܐܬܚܙܝ ܠܡܠܐܟܐ ܘܐܬܟܪܙ ܒܝܬ ܥܡܡܐ ܘܐܬܗܝܡܢ ܒܥܠܡܐ ܘܐܤܬܠܩ ܒܫܘܒܚܐ ܀",
      "paragraphStart": false
    }
  ]
}
