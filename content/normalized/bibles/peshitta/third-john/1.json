{
  "chapter": {
    "id": "peshitta:third-john.1",
    "translationId": "peshitta",
    "bookSlug": "third-john",
    "chapterNumber": 1,
    "referenceLabel": "3 John 1",
    "summary": "Source text for 3 John 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:third-john.1.1",
      "translationId": "peshitta",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "3 John 1:1",
      "text": "ܩܫܝܫܐ ܠܓܐܝܘܤ ܚܒܝܒ ܠܗܘ ܕܐܢܐ ܡܚܒ ܐܢܐ ܒܫܪܪܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:third-john.1.2",
      "translationId": "peshitta",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "3 John 1:2",
      "text": "ܚܒܝܒܢ ܒܟܠܡܕܡ ܡܨܠܐ ܐܢܐ ܥܠܝܟ ܕܬܨܠܚ ܘܬܗܘܐ ܚܠܝܡ ܐܝܟ ܡܐ ܕܡܨܠܚܐ ܢܦܫܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:third-john.1.3",
      "translationId": "peshitta",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "3 John 1:3",
      "text": "ܚܕܝܬ ܓܝܪ ܤܓܝ ܕܐܬܝܢ ܐܚܐ ܘܤܗܕܝܢ ܥܠ ܫܪܪܟ ܐܝܟ ܡܐ ܕܐܢܬ ܒܫܪܪܐ ܡܗܠܟ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:third-john.1.4",
      "translationId": "peshitta",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "3 John 1:4",
      "text": "ܕܪܒܐ ܡܢ ܗܕܐ ܚܕܘܬܐ ܠܝܬ ܠܝ ܕܐܫܡܥ ܕܒܢܝܐ ܕܝܠܝ ܒܫܪܪܐ ܡܗܠܟܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:third-john.1.5",
      "translationId": "peshitta",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "3 John 1:5",
      "text": "ܚܒܝܒܢ ܒܗܝܡܢܘܬܐ ܥܒܕ ܐܢܬ ܗܘ ܡܐ ܕܤܥܪ ܐܢܬ ܠܘܬ ܐܚܐ ܘܝܬܝܪܐܝܬ ܕܐܝܬܝܗܘܢ ܐܟܤܢܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:third-john.1.6",
      "translationId": "peshitta",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "3 John 1:6",
      "text": "ܐܝܠܝܢ ܕܐܤܗܕܘ ܥܠ ܚܘܒܟ ܩܕܡ ܟܠܗ ܥܕܬܐ ܠܗܢܘܢ ܫܦܝܪ ܥܒܕ ܐܢܬ ܕܡܙܘܕ ܐܢܬ ܠܗܘܢ ܐܝܟ ܡܐ ܕܦܐܐ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:third-john.1.7",
      "translationId": "peshitta",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "3 John 1:7",
      "text": "ܚܠܦ ܓܝܪ ܫܡܗ ܢܦܩܘ ܟܕ ܡܕܡ ܠܐ ܢܤܒܘ ܡܢ ܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:third-john.1.8",
      "translationId": "peshitta",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "3 John 1:8",
      "text": "ܚܢܢ ܗܟܝܠ ܚܝܒܝܢܢ ܠܡܩܒܠܘ ܠܕܐܝܟ ܗܠܝܢ ܕܡܥܕܪܢܐ ܢܗܘܐ ܠܫܪܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:third-john.1.9",
      "translationId": "peshitta",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "3 John 1:9",
      "text": "ܒܥܐ ܗܘܝܬ ܐܟܬܘܒ ܠܥܕܬܐ ܐܠܐ ܗܘ ܕܪܚܡ ܕܢܗܘܐ ܩܕܡܝܐ ܕܝܠܗܘܢ ܕܝܘܛܪܦܝܤ ܠܐ ܡܩܒܠ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:third-john.1.10",
      "translationId": "peshitta",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "3 John 1:10",
      "text": "ܡܛܠ ܗܢܐ ܐܢ ܗܘ ܕܐܬܐ ܐܥܗܕ ܥܒܕܘܗܝ ܗܢܘܢ ܕܥܒܕ ܕܒܡܠܐ ܒܝܫܬܐ ܤܬܪ ܠܢ ܘܟܕ ܠܐ ܤܦܩ ܠܗ ܗܠܝܢ ܠܐ ܗܘ ܡܩܒܠ ܠܐܚܐ ܘܠܐܝܠܝܢ ܕܡܩܒܠܝܢ ܟܠܐ ܘܡܦܩ ܡܢ ܥܕܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:third-john.1.11",
      "translationId": "peshitta",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "3 John 1:11",
      "text": "ܚܒܝܒܢ ܠܐ ܬܬܕܡܐ ܒܒܝܫܬܐ ܐܠܐ ܒܛܒܬܐ ܗܘ ܕܥܒܕ ܛܒܬܐ ܡܢ ܐܠܗܐ ܐܝܬܘܗܝ ܗܘ ܕܥܒܕ ܒܝܫܬܐ ܠܐ ܚܙܝܗܝ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:third-john.1.12",
      "translationId": "peshitta",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "3 John 1:12",
      "text": "ܥܠ ܕܡܝܛܪܝܘܤ ܐܝܬ ܗܘ ܤܗܕܘܬܐ ܡܢ ܟܠܢܫ ܘܡܢܗ ܕܥܕܬܐ ܘܡܢܗ ܕܫܪܪܐ ܐܦ ܚܢܢ ܕܝܢ ܤܗܕܝܢܢ ܘܝܕܥ ܐܢܬ ܕܤܗܕܘܬܐ ܕܝܠܢ ܫܪܝܪܐ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:third-john.1.13",
      "translationId": "peshitta",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "3 John 1:13",
      "text": "ܤܓܝܐܬܐ ܐܝܬ ܗܘܐ ܠܝ ܠܡܟܬܒ ܠܟ ܐܠܐ ܠܐ ܒܥܐ ܐܢܐ ܕܒܝܕ ܕܝܘܬܐ ܘܩܢܝܐ ܐܟܬܘܒ ܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:third-john.1.14",
      "translationId": "peshitta",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "3 John 1:14",
      "text": "ܡܤܒܪ ܐܢܐ ܕܝܢ ܕܒܥܓܠ ܐܚܙܝܟ ܘܦܘܡܐ ܠܘܬ ܦܘܡܐ ܢܡܠܠܥ ܫܠܡܐ ܢܗܘܐ ܥܡܟ ܫܐܠܝܢ ܫܠܡܟ ܪܚܡܐ ܫܐܠ ܫܠܡܐ ܕܪܚܡܐ ܕܟܠܢܫ ܒܫܡܗ ܀",
      "paragraphStart": false
    }
  ]
}
