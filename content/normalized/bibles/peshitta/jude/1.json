{
  "chapter": {
    "id": "peshitta:jude.1",
    "translationId": "peshitta",
    "bookSlug": "jude",
    "chapterNumber": 1,
    "referenceLabel": "Jude 1",
    "summary": "Source text for Jude 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:jude.1.1",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Jude 1:1",
      "text": "ܝܗܘܕܐ ܥܒܕܐ ܕܝܫܘܥ ܡܫܝܚܐ ܐܚܐ ܕܝܢ ܕܝܥܩܘܒ ܠܥܡܡܐ ܩܪܝܐ ܕܒܐܠܗܐ ܐܒܐ ܪܚܝܡܝܢ ܘܒܝܫܘܥ ܡܫܝܚܐ ܢܛܝܪܝܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:jude.1.2",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Jude 1:2",
      "text": "ܪܚܡܐ ܘܫܠܡܐ ܘܚܘܒܐ ܢܤܓܐ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.3",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Jude 1:3",
      "text": "ܚܒܝܒܝ ܟܕ ܟܠܗ ܝܨܝܦܘܬܐ ܥܒܕ ܐܢܐ ܠܡܟܬܒ ܠܟܘܢ ܥܠ ܚܝܐ ܕܝܠܢ ܕܓܘܐ ܐܢܢܩܐ ܐܝܬ ܠܝ ܠܡܟܬܒ ܠܟܘܢ ܟܕ ܡܦܝܤ ܐܢܐ ܕܐܓܘܢܐ ܬܥܒܕܘܢ ܚܠܦ ܗܝܡܢܘܬܐ ܐܝܕܐ ܕܚܕܐ ܙܒܢ ܐܫܬܠܡܬ ܠܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.4",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Jude 1:4",
      "text": "ܩܢܘ ܓܝܪ ܐܢܫܝܢ ܡܥܠܢܘܬܐ ܐܝܠܝܢ ܕܡܢ ܫܘܪܝܐ ܩܕܡܘ ܐܬܟܬܒܘ ܒܚܘܝܒܐ ܗܢܐ ܐܢܫܐ ܪܫܝܥܐ ܕܠܛܝܒܘܬܗ ܕܐܠܗܢ ܡܗܦܟܝܢ ܠܛܢܦܘܬܐ ܘܒܗܘ ܕܐܝܬܘܗܝ ܒܠܚܘܕܘܗܝ ܡܪܐ ܐܠܗܐ ܘܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܟܦܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.5",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Jude 1:5",
      "text": "ܠܡܥܗܕܘܬܟܘܢ ܕܝܢ ܨܒܐ ܐܢܐ ܟܕ ܝܕܥܝܢ ܐܢܬܘܢ ܟܠܗܝܢ ܕܐܠܗܐ ܟܕ ܚܕܐ ܙܒܢ ܠܥܡܐ ܡܢ ܡܨܪܝܢ ܦܪܩ ܗܝ ܕܬܪܬܝܢ ܠܐܝܠܝܢ ܕܠܐ ܗܝܡܢܘ ܐܘܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.6",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Jude 1:6",
      "text": "ܘܠܡܠܐܟܐ ܐܝܠܝܢ ܕܠܐ ܢܛܪܘ ܪܝܫܢܘܬܗܘܢ ܐܠܐ ܫܒܩܘ ܥܘܡܪܐ ܕܝܠܗܘܢ ܠܕܝܢܐ ܕܝܘܡܐ ܪܒܐ ܒܐܤܘܪܐ ܠܐ ܝܕܝܥܐ ܬܚܝܬ ܥܡܛܢܐ ܢܛܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.7",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Jude 1:7",
      "text": "ܐܝܟܢܐ ܕܤܕܘܡ ܘܥܡܘܪܐ ܘܡܕܝܢܬܐ ܕܚܕܪܝܗܝܢ ܕܒܗ ܒܕܡܘܬܐ ܕܗܠܝܢ ܙܢܝ ܘܐܙܠ ܒܬܪ ܒܤܪܐ ܐܚܪܢܐ ܤܝܡܢ ܬܚܝܬ ܬܚܘܝܬܐ ܕܢܘܪܐ ܕܠܥܠܡ ܟܕ ܡܚܝܒܢ ܠܕܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.8",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Jude 1:8",
      "text": "ܒܗ ܒܕܡܘܬܐ ܐܦ ܗܠܝܢ ܕܒܚܠܡܐ ܡܫܬܪܓܪܓܝܢ ܠܒܤܪܐ ܡܢ ܡܛܢܦܝܢ ܠܡܪܘܬܐ ܕܝܢ ܛܠܡܝܢ ܘܠܬܫܒܘܚܬܐ ܡܓܕܦܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.9",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Jude 1:9",
      "text": "ܡܝܟܐܝܠ ܕܝܢ ܪܝܫ ܡܠܐܟܐ ܗܘ ܕܥܡ ܐܟܠܩܪܨܐ ܟܕ ܕܐܢ ܡܡܠܠ ܗܘܐ ܡܛܠ ܦܓܪܗ ܕܡܘܫܐ ܠܐ ܐܡܪܚ ܕܢܝܬܐ ܥܠܘܗܝ ܕܝܢܐ ܕܓܘܕܦܐ ܐܠܐ ܐܡܪ ܕܢܓܥܘܪ ܒܟ ܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.10",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Jude 1:10",
      "text": "ܗܠܝܢ ܕܝܢ ܒܐܝܠܝܢ ܕܠܐ ܝܕܥܝܢ ܡܓܕܦܝܢ ܒܐܝܠܝܢ ܕܝܢ ܕܟܝܢܐܝܬ ܐܝܟ ܚܝܘܬܐ ܚܪܫܬܐ ܡܦܤܝܢ ܒܗܝܢ ܡܬܚܒܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.11",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Jude 1:11",
      "text": "ܘܝ ܠܗܘܢ ܕܒܐܘܪܚܗ ܕܩܐܝܢ ܐܙܠܘ ܘܒܬܪ ܛܥܝܘܬܗ ܕܒܠܥܡ ܒܐܓܪܐ ܐܫܬܪܚܘ ܘܒܥܨܝܝܘܬܗ ܕܩܘܪܚ ܐܒܕܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.12",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Jude 1:12",
      "text": "ܗܠܝܢ ܐܝܬܝܗܘܢ ܐܝܠܝܢ ܕܒܢܝܚܬܗܘܢ ܟܕ ܡܟܬܡܝܢ ܡܬܦܪܦܥܝܢ ܟܕ ܕܠܐ ܕܚܠܬܐ ܢܦܫܗܘܢ ܪܥܝܢ ܥܢܢܐ ܕܠܐ ܡܛܪܐ ܕܡܢ ܪܘܚܐ ܦܗܝܢ ܐܝܠܢܐ ܕܐܘܦܝ ܐܒܗܘܢ ܕܐܝܬܝܗܘܢ ܕܠܐ ܦܐܪܐ ܕܡܝܬܘ ܬܢܝܢܘܬ ܘܤܠܩܘ ܡܢ ܥܩܪܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.13",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Jude 1:13",
      "text": "ܓܠܠܐ ܥܙܝܙܐ ܕܝܡܐ ܕܒܝܕ ܪܘܥܬܗܘܢ ܡܚܘܝܢ ܒܗܬܬܗܘܢ ܟܘܟܒܐ ܡܛܥܝܢܐ ܠܗܠܝܢ ܕܥܡܛܢܐ ܕܚܫܘܟܐ ܠܥܠܡ ܠܗܘܢ ܢܛܝܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.14",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Jude 1:14",
      "text": "ܐܬܢܒܝ ܕܝܢ ܐܦ ܠܗܠܝܢ ܗܘ ܕܐܝܬܘܗܝ ܕܫܒܥܐ ܡܢ ܐܕܡ ܚܢܘܟ ܟܕ ܐܡܪ ܕܗܐ ܡܪܝܐ ܐܬܐ ܒܪܒܘܬܐ ܕܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.15",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Jude 1:15",
      "text": "ܕܢܥܒܕ ܕܝܢܐ ܥܠ ܟܠ ܘܠܡܟܤܘ ܠܟܠ ܢܦܫܬܐ ܡܛܠ ܟܠܗܘܢ ܥܒܕܐ ܐܝܠܝܢ ܕܐܪܫܥܘ ܘܡܛܠ ܟܠܗܝܢ ܡܠܐ ܩܫܝܬܐ ܐܝܠܝܢ ܕܡܠܠܘ ܚܛܝܐ ܪܫܝܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.16",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Jude 1:16",
      "text": "ܗܠܝܢ ܐܢܘܢ ܕܡܪܛܢܝܢ ܘܥܕܠܝܢ ܒܟܠ ܨܒܘܢ ܟܕ ܐܝܟ ܪܓܝܓܬܐ ܕܝܠܗܘܢ ܡܗܠܟܝܢ ܘܦܘܡܗܘܢ ܡܡܠܠ ܓܢܝܚܬܐ ܘܡܫܒܚܝܢ ܠܦܪܨܘܦܐ ܡܛܠ ܝܘܬܪܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.17",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Jude 1:17",
      "text": "ܐܢܬܘܢ ܕܝܢ ܚܒܝܒܝ ܐܬܕܟܪܘ ܠܡܠܐ ܐܝܠܝܢ ܕܩܕܡ ܐܬܐܡܪ ܡܢ ܫܠܝܚܘܗܝ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.18",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Jude 1:18",
      "text": "ܕܐܡܪܝܢ ܗܘܘ ܠܟܘܢ ܕܒܚܪܬܐ ܕܙܒܢܐ ܢܗܘܘܢ ܐܝܠܝܢ ܕܡܒܙܚܝܢ ܕܐܝܟ ܪܓܝܓܬܐ ܕܝܠܗܘܢ ܐܙܠܝܢ ܒܬܪ ܪܘܫܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.19",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Jude 1:19",
      "text": "ܗܠܝܢ ܐܝܬܝܗܘܢ ܐܝܠܝܢ ܕܡܦܪܫܝܢ ܢܦܫܢܝܐ ܕܪܘܚܐ ܠܝܬ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.20",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Jude 1:20",
      "text": "ܐܢܬܘܢ ܕܝܢ ܚܒܝܒܝ ܒܗܝܡܢܘܬܐ ܕܝܠܟܘܢ ܩܕܝܫܬܐ ܐܬܒܢܘ ܡܢ ܕܪܝܫ ܒܪܘܚܐ ܩܕܝܫܐ ܟܕ ܡܨܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.21",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Jude 1:21",
      "text": "ܢܦܫܢ ܕܝܢ ܒܚܘܒܐ ܕܐܠܗܐ ܢܛܪ ܟܕ ܡܤܟܝܢܢ ܠܚܢܢܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܠܚܝܐ ܕܝܠܢ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.22",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Jude 1:22",
      "text": "ܘܠܡܢܗܘܢ ܡܢ ܡܢ ܢܘܪܐ ܚܛܘܦܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.23",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Jude 1:23",
      "text": "ܟܕ ܕܝܢ ܡܬܬܘܝܢ ܐܬܪܚܡܘ ܥܠܝܗܘܢ ܒܕܚܠܬܐ ܟܕ ܤܢܝܢ ܐܢܬܘܢ ܐܦ ܠܟܘܬܝܢܐ ܕܡܢ ܒܤܪܐ ܕܡܟܬܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.24",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Jude 1:24",
      "text": "ܠܗܘ ܕܝܢ ܕܡܫܟܚ ܕܢܢܛܪ ܠܢ ܕܠܐ ܫܘܪܥܬܐ ܘܕܠܐ ܟܘܬܡܐ ܘܢܩܝܡ ܕܠܐ ܡܘܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:jude.1.25",
      "translationId": "peshitta",
      "bookSlug": "jude",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Jude 1:25",
      "text": "ܒܠܚܘܕܘܗܝ ܐܠܗܐ ܦܪܘܩܢ ܒܝܕ ܝܫܘܥ ܡܫܝܚܐ ܡܪܢ ܩܕܡ ܬܫܒܘܚܬܗ ܒܚܕܘܬܐ ܠܗ ܫܘܒܚܐ ܘܐܘܚܕܢܐ ܘܐܝܩܪܐ ܘܪܒܘܬܐ ܐܦ ܗܫܐ ܘܒܟܠܗܘܢ ܥܠܡܐ ܐܡܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
