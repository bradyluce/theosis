{
  "chapter": {
    "id": "dra:song-of-solomon.1",
    "translationId": "dra",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 1,
    "referenceLabel": "Song of Solomon 1",
    "summary": "Source text for Song of Solomon 1 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:song-of-solomon.1.1",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 1:1",
      "text": "Let him kiss me with the kiss of his mouth: for thy breasts are better than wine,",
      "paragraphStart": true
    },
    {
      "id": "dra:song-of-solomon.1.2",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 1:2",
      "text": "Smelling sweet of the best ointments. Thy name is as oil poured out: therefore young maidens have loved thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.1.3",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 1:3",
      "text": "Draw me: we will run after thee to the odour of thy ointments. The king hath brought me into his storerooms: we will be glad and rejoice in thee, remembering thy breasts more than wine: the rightous love thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.1.4",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 1:4",
      "text": "I am black but beautiful, O ye daughters of Jerusalem, as the tents of Cedar, as the curtains of Solomon.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.1.5",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 1:5",
      "text": "Do not consider me that I am brown, because the sun hath altered my colour: the sons of my mother have fought against me, they have made me the keeper in the vineyards: my vineyard I have not kept.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.1.6",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 1:6",
      "text": "Shew me, O thou whom my soul loveth, where thou feedest, where thou liest in the midday, lest I begin to wander after the flocks of thy companions.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.1.7",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 1:7",
      "text": "If thou know not thyself, O fairest among women, go forth, and follow after the steps of the flocks, and feed thy kids beside the tents of the shepherds.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.1.8",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 1:8",
      "text": "To my company of horsemen, in Pharao's chariots, have I likened thee, O my love.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.1.9",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 1:9",
      "text": "Thy cheeks are beautiful as the turtledove's, thy neck as jewels.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.1.10",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 1:10",
      "text": "We will make thee chains of gold, inlaid with silver.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.1.11",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 1:11",
      "text": "While the king was at his repose, my spikenard sent forth the odour thereof.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.1.12",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 1:12",
      "text": "A bundle of myrrh is my beloved to me, he shall abide between my breasts.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.1.13",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 1:13",
      "text": "A cluster of cypress my love is to me, in the vineyards of Engaddi.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.1.14",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Song of Solomon 1:14",
      "text": "Behold thou are fair, O my love, behold thou are fair, thy eyes are as those of doves.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.1.15",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Song of Solomon 1:15",
      "text": "Behold thou art fair, my beloved, and comely. Our bed is flourishing.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.1.16",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Song of Solomon 1:16",
      "text": "The beams of our houses are of cedar, our rafters of cypress trees.",
      "paragraphStart": false
    }
  ]
}
