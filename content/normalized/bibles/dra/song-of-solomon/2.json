{
  "chapter": {
    "id": "dra:song-of-solomon.2",
    "translationId": "dra",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 2,
    "referenceLabel": "Song of Solomon 2",
    "summary": "Source text for Song of Solomon 2 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:song-of-solomon.2.1",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 2:1",
      "text": "I am the flower of the field, and the lily of the valleys.",
      "paragraphStart": true
    },
    {
      "id": "dra:song-of-solomon.2.2",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 2:2",
      "text": "As the lily among thorns, so is my love among the daughters.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.2.3",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 2:3",
      "text": "As the apple tree among the trees of the woods, so is my beloved among the sons. I sat down under his shadow, whom I desired: and his fruit was sweet to my palate.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.2.4",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 2:4",
      "text": "He brought me into the cellar of wine, he set in order charity in me.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.2.5",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 2:5",
      "text": "Stay me up with flowers, compass me about with apples: because I languish with love.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.2.6",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 2:6",
      "text": "His left hand is under my head, and his right hand shall embrace me.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.2.7",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 2:7",
      "text": "I adjure you, O ye daughters of Jerusalem, by the roes, and the harts of the field, that you stir not up, nor make the beloved to awake, till she please.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.2.8",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 2:8",
      "text": "The voice of my beloved, behold he cometh leaping upon the mountains, skipping over the hills.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.2.9",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 2:9",
      "text": "My beloved is like a roe, or a young hart. Behold he standeth behind our wall, looking through the windows, looking through the lattices.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.2.10",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 2:10",
      "text": "Behold my beloved speaketh to me: Arise, make haste, my love, my dove, my beautiful one, and come.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.2.11",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 2:11",
      "text": "For winter is now past, the rain is over and gone.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.2.12",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 2:12",
      "text": "The flowers have appeared in our land, the time of pruning is come: the voice of the turtle is heard in our land:",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.2.13",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 2:13",
      "text": "The fig tree hath put forth her green figs: the vines in flower yield their sweet smell. Arise, my love, my beautiful one, and come:",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.2.14",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Song of Solomon 2:14",
      "text": "My dove in the clefts of the rock, in the hollow places of the wall, shew me thy face, let thy voice sound in my ears: for thy voice is sweet, and thy face comely.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.2.15",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Song of Solomon 2:15",
      "text": "Catch us the little foxes that destroy the vines: for our vineyard hath flourished.",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.2.16",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Song of Solomon 2:16",
      "text": "My beloved to me, and I to him who feedeth among the lilies,",
      "paragraphStart": false
    },
    {
      "id": "dra:song-of-solomon.2.17",
      "translationId": "dra",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Song of Solomon 2:17",
      "text": "Till the day break, and the shadows retire. Return: be like, my beloved, to a roe, or to a young hart upon the mountains of Bether.",
      "paragraphStart": false
    }
  ]
}
