{
  "chapter": {
    "id": "dra:psalms.148",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 148,
    "referenceLabel": "Psalms 148",
    "summary": "Source text for Psalms 148 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.148.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 1,
      "referenceLabel": "Psalms 148:1",
      "text": "Praise ye the Lord from the heavens: praise ye him in the high places.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.148.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 2,
      "referenceLabel": "Psalms 148:2",
      "text": "Praise ye him, all his angels, praise ye him, all his hosts.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.148.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 3,
      "referenceLabel": "Psalms 148:3",
      "text": "Praise ye him, O sun and moon: praise him, all ye stars and light.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.148.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 4,
      "referenceLabel": "Psalms 148:4",
      "text": "Praise him, ye heavens of heavens: and let all the waters that are above the heavens",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.148.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 5,
      "referenceLabel": "Psalms 148:5",
      "text": "Praise the name of the Lord. For he spoke, and they were made: he commanded, and they were created.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.148.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 6,
      "referenceLabel": "Psalms 148:6",
      "text": "He hath established them for ever, and for ages of ages: he hath made a decree, and it shall not pass away.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.148.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 7,
      "referenceLabel": "Psalms 148:7",
      "text": "Praise the Lord from the earth, ye dragons, and all ye deeps:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.148.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 8,
      "referenceLabel": "Psalms 148:8",
      "text": "Fire, hail, snow, ice, stormy winds, which fulfil his word:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.148.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 9,
      "referenceLabel": "Psalms 148:9",
      "text": "Mountains and all hills, fruitful trees and all cedars:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.148.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 10,
      "referenceLabel": "Psalms 148:10",
      "text": "Beasts and all cattle: serpents and feathered fowls:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.148.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 11,
      "referenceLabel": "Psalms 148:11",
      "text": "Kings of the earth and all people: princes and all judges of the earth:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.148.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 12,
      "referenceLabel": "Psalms 148:12",
      "text": "Young men and maidens: let the old with the younger, praise the name of the Lord:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.148.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 13,
      "referenceLabel": "Psalms 148:13",
      "text": "For his name alone is exalted.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.148.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 14,
      "referenceLabel": "Psalms 148:14",
      "text": "The praise of him is above heaven and earth: and he hath exalted the horn of his people. A hymn to all his saints to the children of Israel, a people approaching to him. Alleluia.",
      "paragraphStart": false
    }
  ]
}
