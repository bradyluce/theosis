{
  "chapter": {
    "id": "dra:psalms.68",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 68,
    "referenceLabel": "Psalms 68",
    "summary": "Source text for Psalms 68 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.68.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 1,
      "referenceLabel": "Psalms 68:1",
      "text": "Unto the end, for them that shall be changed; for David.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.68.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 2,
      "referenceLabel": "Psalms 68:2",
      "text": "Save me, O God: for the waters are come in even unto my soul.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 3,
      "referenceLabel": "Psalms 68:3",
      "text": "I stick fast in the mire of the deep and there is no sure standing. I am come into the depth of the sea, and a tempest hath overwhelmed me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 4,
      "referenceLabel": "Psalms 68:4",
      "text": "I have laboured with crying; my jaws are become hoarse, my eyes have failed, whilst I hope in my God.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 5,
      "referenceLabel": "Psalms 68:5",
      "text": "They are multiplied above the hairs of my head, who hate me without cause. My enemies are grown strong who have wrongfully persecuted me: then did I pay that which I took not away.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 6,
      "referenceLabel": "Psalms 68:6",
      "text": "O God, thou knowest my foolishness; and my offences are not hidden from thee:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 7,
      "referenceLabel": "Psalms 68:7",
      "text": "Let not them be ashamed for me, who look for thee, O Lord, the Lord of hosts. Let them not be confounded on my account, who seek thee, O God of Israel.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 8,
      "referenceLabel": "Psalms 68:8",
      "text": "Because for thy sake I have borne reproach; shame hath covered my face.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 9,
      "referenceLabel": "Psalms 68:9",
      "text": "I am become a stranger to my brethren, and an alien to the sons of my mother.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 10,
      "referenceLabel": "Psalms 68:10",
      "text": "For the zeal of thy house hath eaten me up: and the reproaches of them that reproached thee are fallen upon me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 11,
      "referenceLabel": "Psalms 68:11",
      "text": "And I covered my soul in fasting: and it was made a reproach to me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 12,
      "referenceLabel": "Psalms 68:12",
      "text": "And I made haircloth my garment: and I became a byword to them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 13,
      "referenceLabel": "Psalms 68:13",
      "text": "They that sat in the gate spoke against me: and they that drank wine made me their song.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 14,
      "referenceLabel": "Psalms 68:14",
      "text": "But as for me, my prayer is to thee, O Lord; for the time of thy good pleasure, O God. In the multitude of thy mercy hear me, in the truth of thy salvation.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 15,
      "referenceLabel": "Psalms 68:15",
      "text": "Draw me out of the mire, that I may not stick fast: deliver me from them that hate me, and out of the deep waters.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 16,
      "referenceLabel": "Psalms 68:16",
      "text": "Let not the tempest of water drown me, nor the deep water swallow me up: and let not the pit shut her mouth upon me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 17,
      "referenceLabel": "Psalms 68:17",
      "text": "Hear me, O Lord, for thy mercy is kind; look upon me according to the multitude of thy tender mercies.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 18,
      "referenceLabel": "Psalms 68:18",
      "text": "And turn not away thy face from thy servant: for I am in trouble, hear me speedily.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 19,
      "referenceLabel": "Psalms 68:19",
      "text": "Attend to my soul, and deliver it: save me because of my enemies.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 20,
      "referenceLabel": "Psalms 68:20",
      "text": "Thou knowest my reproach, and my confusion, and my shame.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 21,
      "referenceLabel": "Psalms 68:21",
      "text": "In thy sight are all they that afflict me; my heart hath expected reproach and misery. And I looked for one that would grieve together with me, but there was none: and for one that would comfort me, and I found none.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 22,
      "referenceLabel": "Psalms 68:22",
      "text": "And they gave me gall for my food, and in my thirst they gave me vinegar to drink.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 23,
      "referenceLabel": "Psalms 68:23",
      "text": "Let their table become as a snare before them, and a recompense, and a stumblingblock.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.24",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 24,
      "referenceLabel": "Psalms 68:24",
      "text": "Let their eyes be darkened that they see not; and their back bend thou down always.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.25",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 25,
      "referenceLabel": "Psalms 68:25",
      "text": "Pour out thy indignation upon them: and let thy wrathful anger take hold of them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.26",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 26,
      "referenceLabel": "Psalms 68:26",
      "text": "Let their habitation be made desolate: and let there be none to dwell in their tabernacles.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.27",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 27,
      "referenceLabel": "Psalms 68:27",
      "text": "Because they have persecuted him whom thou hast smitten; and they have added to the grief of my wounds.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.28",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 28,
      "referenceLabel": "Psalms 68:28",
      "text": "Add thou iniquity upon their iniquity: and let them not come into thy justice.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.29",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 29,
      "referenceLabel": "Psalms 68:29",
      "text": "Let them be blotted out of the book of the living; and with the just let them not be written.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.30",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 30,
      "referenceLabel": "Psalms 68:30",
      "text": "But I am poor and sorrowful: thy salvation, O God, hath set me up.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.31",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 31,
      "referenceLabel": "Psalms 68:31",
      "text": "I will praise the name of God with a canticle: and I will magnify him with praise.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.32",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 32,
      "referenceLabel": "Psalms 68:32",
      "text": "And it shall please God better than a young calf, that bringeth forth horns and hoofs.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.33",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 33,
      "referenceLabel": "Psalms 68:33",
      "text": "Let the poor see and rejoice: seek ye God, and your soul shall live.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.34",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 34,
      "referenceLabel": "Psalms 68:34",
      "text": "For the Lord hath heard the poor: and hath not despised his prisoners.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.35",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 35,
      "referenceLabel": "Psalms 68:35",
      "text": "Let the heavens and the earth praise him; the sea, and every thing that creepeth therein.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.36",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 36,
      "referenceLabel": "Psalms 68:36",
      "text": "For God will save Sion, and the cities of Juda shall be built up. And they shall dwell there, and acquire it by inheritance.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.68.37",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 37,
      "referenceLabel": "Psalms 68:37",
      "text": "And the seed of his servants shall possess it; and they that love his name shall dwell therein.",
      "paragraphStart": false
    }
  ]
}
