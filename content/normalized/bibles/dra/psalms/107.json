{
  "chapter": {
    "id": "dra:psalms.107",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 107,
    "referenceLabel": "Psalms 107",
    "summary": "Source text for Psalms 107 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.107.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 1,
      "referenceLabel": "Psalms 107:1",
      "text": "A canticle of a psalm for David himself.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.107.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 2,
      "referenceLabel": "Psalms 107:2",
      "text": "My heart is ready, O God, my heart is ready: I will sing, and will give praise, with my glory.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.107.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 3,
      "referenceLabel": "Psalms 107:3",
      "text": "Arise, my glory; arise, psaltery and harp: I will arise in the morning early.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.107.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 4,
      "referenceLabel": "Psalms 107:4",
      "text": "I will praise thee, O Lord, among the people: and I will sing unto thee among the nations.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.107.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 5,
      "referenceLabel": "Psalms 107:5",
      "text": "For thy mercy is great above the heavens: and thy truth even unto the clouds.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.107.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 6,
      "referenceLabel": "Psalms 107:6",
      "text": "Be thou exalted, O God, above the heavens, and thy glory over all the earth:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.107.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 7,
      "referenceLabel": "Psalms 107:7",
      "text": "That thy beloved may be delivered. Save with thy right hand and hear me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.107.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 8,
      "referenceLabel": "Psalms 107:8",
      "text": "God hath spoken in his holiness. I will rejoice, and I will divide Sichem and I will mete out the vale of tabernacles.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.107.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 9,
      "referenceLabel": "Psalms 107:9",
      "text": "Galaad is mine: and Manasses is mine and Ephraim the protection of my head. Juda is my king:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.107.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 10,
      "referenceLabel": "Psalms 107:10",
      "text": "Moab the pot of my hope. Over Edom I will stretch out my shoe: the aliens are become my friends.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.107.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 11,
      "referenceLabel": "Psalms 107:11",
      "text": "Who will bring me into the strong city? who will lead me into Edom?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.107.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 12,
      "referenceLabel": "Psalms 107:12",
      "text": "Wilt not thou, O God, who hast cast us off? and wilt not thou, O God, go forth with our armies?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.107.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 13,
      "referenceLabel": "Psalms 107:13",
      "text": "O grant us help from trouble: for vain is the help of man.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.107.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 14,
      "referenceLabel": "Psalms 107:14",
      "text": "Through God we shall do mightily: and he will bring our enemies to nothing.",
      "paragraphStart": false
    }
  ]
}
