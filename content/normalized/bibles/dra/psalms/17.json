{
  "chapter": {
    "id": "dra:psalms.17",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 17,
    "referenceLabel": "Psalms 17",
    "summary": "Source text for Psalms 17 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.17.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Psalms 17:1",
      "text": "Unto the end, for David, the servant of the Lord, who spoke to the Lord the words of this canticle, in the day that the Lord delivered him from the hand of all his enemies, and from the hand of Saul: and he said:",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.17.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Psalms 17:2",
      "text": "I will love thee, O Lord, my strength:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Psalms 17:3",
      "text": "The Lord is my firmament, my refuge, and my deliverer. My God is my helper, and in him will I put my trust. My protector, and the horn of my salvation, and my support.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Psalms 17:4",
      "text": "Praising, I will call upon the Lord: and I shall be saved from my enemies.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Psalms 17:5",
      "text": "The sorrows of death surrounded me: and the torrents of iniquity troubled me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Psalms 17:6",
      "text": "The sorrows of hell encompassed me: and the snares of death prevented me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Psalms 17:7",
      "text": "In my affliction I called upon the Lord, and I cried to my God: And he heard my voice from his holy temple: and my cry before him came into his ears.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Psalms 17:8",
      "text": "The earth shook and trembled: the foundations of the mountains were troubled and were moved, because he was angry with them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Psalms 17:9",
      "text": "There went up a smoke in his wrath: and a fire flamed from his face: coals were kindled by it.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Psalms 17:10",
      "text": "He bowed the heavens, and came down, and darkness was under his feet.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Psalms 17:11",
      "text": "And he ascended upon the cherubim, and he flew; he flew upon the wings of the winds.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Psalms 17:12",
      "text": "And he made darkness his cover, his pavilion round about him: dark waters in the clouds of the air.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Psalms 17:13",
      "text": "At the brightness that was before him the clouds passed, hail and coals of fire.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Psalms 17:14",
      "text": "And the Lord thundered from heaven, and the Highest gave his voice: hail and coals of fire.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Psalms 17:15",
      "text": "And he sent forth his arrows, and he scattered them: he multiplied lightnings, and troubled them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Psalms 17:16",
      "text": "Then the fountains of waters appeared, and the foundations of the world were discovered: At thy rebuke, O Lord, at the blast of the spirit of thy wrath.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 17,
      "referenceLabel": "Psalms 17:17",
      "text": "He sent from on high, and took me: and received me out of many waters.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 18,
      "referenceLabel": "Psalms 17:18",
      "text": "He delivered me from my strongest enemies, and from them that hated me: for they were too strong for me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 19,
      "referenceLabel": "Psalms 17:19",
      "text": "They prevented me in the day of my affliction: and the Lord became my protector.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 20,
      "referenceLabel": "Psalms 17:20",
      "text": "And he brought me forth into a large place: he saved me, because he was well pleased with me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 21,
      "referenceLabel": "Psalms 17:21",
      "text": "And the Lord will reward me according to my justice; and will repay me according to the cleanness of my hands:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 22,
      "referenceLabel": "Psalms 17:22",
      "text": "Because I have kept the ways of the Lord; and have not done wickedly against my God.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 23,
      "referenceLabel": "Psalms 17:23",
      "text": "For all his judgments are in my sight: and his justices I have not put away from me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.24",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 24,
      "referenceLabel": "Psalms 17:24",
      "text": "And I shall be spotless with him: and shall keep myself from my iniquity.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.25",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 25,
      "referenceLabel": "Psalms 17:25",
      "text": "And the Lord will reward me according to my justice: and according to the cleanness of my hands before his eyes.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.26",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 26,
      "referenceLabel": "Psalms 17:26",
      "text": "With the holy thou wilt be holy; and with the innocent man thou wilt be innocent:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.27",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 27,
      "referenceLabel": "Psalms 17:27",
      "text": "And with the elect thou wilt be elect: and with the perverse thou wilt be perverted.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.28",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 28,
      "referenceLabel": "Psalms 17:28",
      "text": "For thou wilt save the humble people; but wilt bring down the eyes of the proud.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.29",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 29,
      "referenceLabel": "Psalms 17:29",
      "text": "For thou lightest my lamp, O Lord: O my God, enlighten my darkness.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.30",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 30,
      "referenceLabel": "Psalms 17:30",
      "text": "For by thee I shall be delivered from temptation; and through my God I shall go over a wall.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.31",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 31,
      "referenceLabel": "Psalms 17:31",
      "text": "As for my God, his way is undefiled: the words of the Lord are fire-tried: he is the protector of all that trust in him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.32",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 32,
      "referenceLabel": "Psalms 17:32",
      "text": "For who is God but the Lord? or who is God but our God?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.33",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 33,
      "referenceLabel": "Psalms 17:33",
      "text": "God, who hath girt me with strength; and made my way blameless.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.34",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 34,
      "referenceLabel": "Psalms 17:34",
      "text": "Who hath made my feet like the feet of harts: and who setteth me upon high places.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.35",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 35,
      "referenceLabel": "Psalms 17:35",
      "text": "Who teacheth my hands to war: and thou hast made my arms like a brazen bow.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.36",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 36,
      "referenceLabel": "Psalms 17:36",
      "text": "And thou hast given me the protection of thy salvation: and thy right hand hath held me up: And thy discipline hath corrected me unto the end: and thy discipline, the same shall teach me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.37",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 37,
      "referenceLabel": "Psalms 17:37",
      "text": "Thou hast enlarged my steps under me; and my feet are not weakened.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.38",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 38,
      "referenceLabel": "Psalms 17:38",
      "text": "I will pursue after my enemies, and overtake them: and I will not turn again till they are consumed.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.39",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 39,
      "referenceLabel": "Psalms 17:39",
      "text": "I will break them, and they shall not be able to stand: they shall fall under my feet.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.40",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 40,
      "referenceLabel": "Psalms 17:40",
      "text": "And thou hast girded me with strength unto battle; and hast subdued under me them that rose up against me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.41",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 41,
      "referenceLabel": "Psalms 17:41",
      "text": "And thou hast made my enemies turn their back upon me, and hast destroyed them that hated me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.42",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 42,
      "referenceLabel": "Psalms 17:42",
      "text": "They cried, but there was none to save them, to the Lord: but he heard them not.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.43",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 43,
      "referenceLabel": "Psalms 17:43",
      "text": "And I shall beat them as small as the dust before the wind; I shall bring them to nought, like the dirt in the streets.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.44",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 44,
      "referenceLabel": "Psalms 17:44",
      "text": "Thou wilt deliver me from the contradictions of the people; thou wilt make me head of the Gentiles.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.45",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 45,
      "referenceLabel": "Psalms 17:45",
      "text": "A people which I knew not, hath served me: at the hearing of the ear they have obeyed me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.46",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 46,
      "referenceLabel": "Psalms 17:46",
      "text": "The children that are strangers have lied to me, strange children have faded away, and have halted from their paths.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.47",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 47,
      "referenceLabel": "Psalms 17:47",
      "text": "The Lord liveth, and blessed be my God, and let the God of my salvation be exalted.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.48",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 48,
      "referenceLabel": "Psalms 17:48",
      "text": "O God, who avengest me, and subduest the people under me, my deliverer from my enraged enemies.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.49",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 49,
      "referenceLabel": "Psalms 17:49",
      "text": "And thou wilt lift me up above them that rise up against me: from the unjust man thou wilt deliver me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.50",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 50,
      "referenceLabel": "Psalms 17:50",
      "text": "Therefore will I give glory to thee, O Lord, among the nations, and I will sing a psalm to thy name.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.17.51",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 51,
      "referenceLabel": "Psalms 17:51",
      "text": "Giving great deliverance to his king, and shewing mercy to David, his anointed: and to his seed for ever.",
      "paragraphStart": false
    }
  ]
}
