{
  "chapter": {
    "id": "dra:psalms.103",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 103,
    "referenceLabel": "Psalms 103",
    "summary": "Source text for Psalms 103 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.103.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 1,
      "referenceLabel": "Psalms 103:1",
      "text": "For David himself. Bless the Lord, O my soul: O Lord my God, thou art exceedingly great. Thou hast put on praise and beauty:",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.103.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 2,
      "referenceLabel": "Psalms 103:2",
      "text": "And art clothed with light as with a garment. Who stretchest out the heaven like a pavilion:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 3,
      "referenceLabel": "Psalms 103:3",
      "text": "Who coverest the higher rooms thereof with water. Who makest the clouds thy chariot: who walkest upon the wings of the winds.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 4,
      "referenceLabel": "Psalms 103:4",
      "text": "Who makest thy angels spirits: and thy ministers a burning fire.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 5,
      "referenceLabel": "Psalms 103:5",
      "text": "Who hast founded the earth upon its own bases: it shall not be moved for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 6,
      "referenceLabel": "Psalms 103:6",
      "text": "The deep like a garment is its clothing: above the mountains shall the waters stand.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 7,
      "referenceLabel": "Psalms 103:7",
      "text": "At thy rebuke they shall flee: at the voice of thy thunder they shall fear.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 8,
      "referenceLabel": "Psalms 103:8",
      "text": "The mountains ascend, and the plains descend into the place which thou hast founded for them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 9,
      "referenceLabel": "Psalms 103:9",
      "text": "Thou hast set a bound which they shall not pass over; neither shall they return to cover the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 10,
      "referenceLabel": "Psalms 103:10",
      "text": "Thou sendest forth springs in the vales: between the midst of the hills the waters shall pass.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 11,
      "referenceLabel": "Psalms 103:11",
      "text": "All the beasts of the field shall drink: the wild asses shall expect in their thirst.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 12,
      "referenceLabel": "Psalms 103:12",
      "text": "Over them the birds of the air shall dwell: from the midst of the rocks they shall give forth their voices.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 13,
      "referenceLabel": "Psalms 103:13",
      "text": "Thou waterest the hills from thy upper rooms: the earth shall be filled with the fruit of thy works:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 14,
      "referenceLabel": "Psalms 103:14",
      "text": "Bringing forth grass for cattle, and herb for the service of men. That thou mayst bring bread out of the earth:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 15,
      "referenceLabel": "Psalms 103:15",
      "text": "And that wine may cheer the heart of man. That he may make the face cheerful with oil: and that bread may strengthen man's heart.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 16,
      "referenceLabel": "Psalms 103:16",
      "text": "The trees of the field shall be filled, and the cedars of Libanus which he hath planted:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 17,
      "referenceLabel": "Psalms 103:17",
      "text": "There the sparrows shall make their nests. The highest of them is the house of the heron.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 18,
      "referenceLabel": "Psalms 103:18",
      "text": "The high hills are a refuge for the harts, the rock for the irchins.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 19,
      "referenceLabel": "Psalms 103:19",
      "text": "He hath made the moon for seasons: the sun knoweth his going down.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 20,
      "referenceLabel": "Psalms 103:20",
      "text": "Thou hast appointed darkness, and it is night: in it shall all the beasts of the woods go about:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 21,
      "referenceLabel": "Psalms 103:21",
      "text": "The young lions roaring after their prey, and seeking their meat from God.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 22,
      "referenceLabel": "Psalms 103:22",
      "text": "The sun ariseth, and they are gathered together: and they shall lie down in their dens.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 23,
      "referenceLabel": "Psalms 103:23",
      "text": "Man shall go forth to his work, and to his labour until the evening.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.24",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 24,
      "referenceLabel": "Psalms 103:24",
      "text": "How great are thy works, O Lord? thou hast made all things in wisdom: the earth is filled with thy riches.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.25",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 25,
      "referenceLabel": "Psalms 103:25",
      "text": "So is this great sea, which stretcheth wide its arms: there are creeping things without number: Creatures little and great.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.26",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 26,
      "referenceLabel": "Psalms 103:26",
      "text": "There the ships shall go. This sea dragon which thou hast formed to play therein.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.27",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 27,
      "referenceLabel": "Psalms 103:27",
      "text": "All expect of thee that thou give them food in season.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.28",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 28,
      "referenceLabel": "Psalms 103:28",
      "text": "What thou givest to them they shall gather up: when thou openest thy hand, they shall all be filled with good.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.29",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 29,
      "referenceLabel": "Psalms 103:29",
      "text": "But if thou turnest away thy face, they shall be troubled: thou shalt take away their breath, and they shall fail, and shall return to their dust.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.30",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 30,
      "referenceLabel": "Psalms 103:30",
      "text": "Thou shalt send forth thy spirit, and they shall be created: and thou shalt renew the face of the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.31",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 31,
      "referenceLabel": "Psalms 103:31",
      "text": "May the glory of the Lord endure for ever: the Lord shall rejoice in his works.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.32",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 32,
      "referenceLabel": "Psalms 103:32",
      "text": "He looketh upon the earth, and maketh it tremble: he troubleth the mountains, and they smoke.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.33",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 33,
      "referenceLabel": "Psalms 103:33",
      "text": "I will sing to the Lord as long as I live: I will sing praise to my God while I have my being.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.34",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 34,
      "referenceLabel": "Psalms 103:34",
      "text": "Let my speech be acceptable to him: but I will take delight in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.103.35",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 35,
      "referenceLabel": "Psalms 103:35",
      "text": "Let sinners be consumed out of the earth, and the unjust, so that they be no more: O my soul, bless thou the Lord.",
      "paragraphStart": false
    }
  ]
}
