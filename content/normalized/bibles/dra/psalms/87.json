{
  "chapter": {
    "id": "dra:psalms.87",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 87,
    "referenceLabel": "Psalms 87",
    "summary": "Source text for Psalms 87 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.87.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 1,
      "referenceLabel": "Psalms 87:1",
      "text": "A canticle of a psalm for the sons of Core: unto the end, for Maheleth, to answer understanding of Eman the Ezrahite.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.87.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 2,
      "referenceLabel": "Psalms 87:2",
      "text": "O Lord, the God of my salvation: I have cried in the day, and in the night before thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.87.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 3,
      "referenceLabel": "Psalms 87:3",
      "text": "Let my prayer come in before thee: incline thy ear to my petition.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.87.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 4,
      "referenceLabel": "Psalms 87:4",
      "text": "For my soul is filled with evils: and my life hath drawn nigh to hell.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.87.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 5,
      "referenceLabel": "Psalms 87:5",
      "text": "I am counted among them that go down to the pit: I am become as a man without help,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.87.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 6,
      "referenceLabel": "Psalms 87:6",
      "text": "Free among the dead. Like the slain sleeping in the sepulchres, whom thou rememberest no more: and they are cut off from thy hand.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.87.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 7,
      "referenceLabel": "Psalms 87:7",
      "text": "They have laid me in the lower pit: in the dark places, and in the shadow of death.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.87.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 8,
      "referenceLabel": "Psalms 87:8",
      "text": "Thy wrath is strong over me: and all thy waves thou hast brought in upon me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.87.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 9,
      "referenceLabel": "Psalms 87:9",
      "text": "Thou hast put away my acquaintance far from me: they have set me an abomination to themselves. I was delivered up, and came not forth:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.87.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 10,
      "referenceLabel": "Psalms 87:10",
      "text": "My eyes languished through poverty. All the day I cried to thee, O Lord: I stretched out my hands to thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.87.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 11,
      "referenceLabel": "Psalms 87:11",
      "text": "Wilt thou shew wonders to the dead? or shall physicians raise to life, and give praise to thee?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.87.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 12,
      "referenceLabel": "Psalms 87:12",
      "text": "Shall any one in the sepulchre declare thy mercy: and thy truth in destruction?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.87.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 13,
      "referenceLabel": "Psalms 87:13",
      "text": "Shall thy wonders be known in the dark; and thy justice in the land of forgetfulness?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.87.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 14,
      "referenceLabel": "Psalms 87:14",
      "text": "But I, O Lord, have cried to thee: and in the morning my prayer shall prevent thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.87.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 15,
      "referenceLabel": "Psalms 87:15",
      "text": "Lord, why castest thou off my prayer: why turnest thou away thy face from me?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.87.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 16,
      "referenceLabel": "Psalms 87:16",
      "text": "I am poor, and in labours from my youth: and being exalted have been humbled and troubled.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.87.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 17,
      "referenceLabel": "Psalms 87:17",
      "text": "Thy wrath hath come upon me: and thy terrors have troubled me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.87.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 18,
      "referenceLabel": "Psalms 87:18",
      "text": "They have come round about me like water all the day: they have compassed me about together.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.87.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 19,
      "referenceLabel": "Psalms 87:19",
      "text": "Friend and neighbour thou hast put far from me: and my acquaintance, because of misery.",
      "paragraphStart": false
    }
  ]
}
