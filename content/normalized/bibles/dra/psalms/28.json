{
  "chapter": {
    "id": "dra:psalms.28",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 28,
    "referenceLabel": "Psalms 28",
    "summary": "Source text for Psalms 28 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.28.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Psalms 28:1",
      "text": "A psalm for David, at the finishing of the tabernacle. Bring to the Lord, O ye children of God: bring to the Lord the offspring of rams.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.28.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Psalms 28:2",
      "text": "Bring to the Lord glory and honour: bring to the Lord glory to his name: adore ye the Lord in his holy court.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.28.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Psalms 28:3",
      "text": "The voice of the Lord is upon the waters; the God of majesty hath thundered, The Lord is upon many waters.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.28.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Psalms 28:4",
      "text": "The voice of the Lord is in power; the voice of the Lord in magnificence.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.28.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Psalms 28:5",
      "text": "The voice of the Lord breaketh the cedars: yea, the Lord shall break the cedars of Libanus.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.28.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Psalms 28:6",
      "text": "And shall reduce them to pieces, as a calf of Libanus, and as the beloved son of unicorns.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.28.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Psalms 28:7",
      "text": "The voice of the Lord divideth the flame of fire:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.28.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Psalms 28:8",
      "text": "The voice of the Lord shaketh the desert: and the Lord shall shake the desert of Cades.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.28.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Psalms 28:9",
      "text": "The voice of the Lord prepareth the stags: and he will discover the thick woods: and in his temple all shall speak his glory.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.28.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Psalms 28:10",
      "text": "The Lord maketh the flood to dwell: and the Lord shall sit king for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.28.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Psalms 28:11",
      "text": "The Lord will give strength to his people: the Lord will bless his people with peace.",
      "paragraphStart": false
    }
  ]
}
