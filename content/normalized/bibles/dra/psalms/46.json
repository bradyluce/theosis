{
  "chapter": {
    "id": "dra:psalms.46",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 46,
    "referenceLabel": "Psalms 46",
    "summary": "Source text for Psalms 46 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.46.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 1,
      "referenceLabel": "Psalms 46:1",
      "text": "Unto the end, for the sons of Core.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.46.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 2,
      "referenceLabel": "Psalms 46:2",
      "text": "O clap your hands, all ye nations: shout unto God with the voice of joy,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.46.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 3,
      "referenceLabel": "Psalms 46:3",
      "text": "For the Lord is high, terrible: a great king over all the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.46.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 4,
      "referenceLabel": "Psalms 46:4",
      "text": "He hath subdued the people under us; and the nations under our feet.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.46.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 5,
      "referenceLabel": "Psalms 46:5",
      "text": "He hath chosen for us his inheritance, the beauty of Jacob which he hath loved.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.46.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 6,
      "referenceLabel": "Psalms 46:6",
      "text": "God is ascended with jubilee, and the Lord with the sound of trumpet.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.46.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 7,
      "referenceLabel": "Psalms 46:7",
      "text": "Sing praises to our God, sing ye: sing praises to our king, sing ye.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.46.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 8,
      "referenceLabel": "Psalms 46:8",
      "text": "For God is the king of all the earth: sing ye wisely.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.46.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 9,
      "referenceLabel": "Psalms 46:9",
      "text": "God shall reign over the nations: God sitteth on his holy throne.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.46.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 10,
      "referenceLabel": "Psalms 46:10",
      "text": "The princes of the people are gathered together, with the God of Abraham: for the strong gods of the earth are exceedingly exalted.",
      "paragraphStart": false
    }
  ]
}
