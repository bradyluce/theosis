{
  "chapter": {
    "id": "dra:psalms.11",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 11,
    "referenceLabel": "Psalms 11",
    "summary": "Source text for Psalms 11 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.11.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Psalms 11:1",
      "text": "Unto the end: for the octave, a psalm for David.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.11.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Psalms 11:2",
      "text": "Save me, O Lord, for there is now no saint: truths are decayed from among the children of men.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.11.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Psalms 11:3",
      "text": "They have spoken vain things, every one to his neighbour: with deceitful lips, and with a double heart have they spoken.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.11.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Psalms 11:4",
      "text": "May the Lord destroy all deceitful lips, and the tongue that speaketh proud things.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.11.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Psalms 11:5",
      "text": "Who have said: We will magnify our tongue: our lips are our own: who is Lord over us?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.11.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Psalms 11:6",
      "text": "By reason of the misery of the needy, and the groans of the poor, now will I arise, saith the Lord. I will set him in safety: I will deal confidently in his regard.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.11.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Psalms 11:7",
      "text": "The words of the Lord are pure words: as silver tried by the fire, purged from the earth, refined seven times.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.11.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Psalms 11:8",
      "text": "Thou, O Lord, wilt preserve us: and keep us from this generation for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.11.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Psalms 11:9",
      "text": "The wicked walk round about: according to thy highness, thou hast multiplied the children of men.",
      "paragraphStart": false
    }
  ]
}
