{
  "chapter": {
    "id": "dra:psalms.90",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 90,
    "referenceLabel": "Psalms 90",
    "summary": "Source text for Psalms 90 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.90.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 1,
      "referenceLabel": "Psalms 90:1",
      "text": "The praise of a canticle for David. He that dwelleth in the aid of the most High, shall abide under the protection of the God of Jacob.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.90.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 2,
      "referenceLabel": "Psalms 90:2",
      "text": "He shall say to the Lord: Thou art my protector, and my refuge: my God, in him will I trust.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.90.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 3,
      "referenceLabel": "Psalms 90:3",
      "text": "For he hath delivered me from the snare of the hunters: and from the sharp word.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.90.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 4,
      "referenceLabel": "Psalms 90:4",
      "text": "He will overshadow thee with his shoulders: and under his wings thou shalt trust.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.90.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 5,
      "referenceLabel": "Psalms 90:5",
      "text": "His truth shall compass thee with a shield: thou shalt not be afraid of the terror of the night.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.90.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 6,
      "referenceLabel": "Psalms 90:6",
      "text": "Of the arrow that flieth in the day, of the business that walketh about in the dark: of invasion, or of the noonday devil.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.90.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 7,
      "referenceLabel": "Psalms 90:7",
      "text": "A thousand shall fall at thy side, and ten thousand at thy right hand: but it shall not come nigh thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.90.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 8,
      "referenceLabel": "Psalms 90:8",
      "text": "But thou shalt consider with thy eyes: and shalt see the reward of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.90.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 9,
      "referenceLabel": "Psalms 90:9",
      "text": "Because thou, O Lord, art my hope: thou hast made the most High thy refuge.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.90.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 10,
      "referenceLabel": "Psalms 90:10",
      "text": "There shall no evil come to thee: nor shall the scourge come near thy dwelling.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.90.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 11,
      "referenceLabel": "Psalms 90:11",
      "text": "For he hath given his angels charge over thee; to keep thee in all thy ways.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.90.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 12,
      "referenceLabel": "Psalms 90:12",
      "text": "In their hands they shall bear thee up: lest thou dash thy foot against a stone.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.90.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 13,
      "referenceLabel": "Psalms 90:13",
      "text": "Thou shalt walk upon the asp and the basilisk: and thou shalt trample under foot the lion and the dragon.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.90.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 14,
      "referenceLabel": "Psalms 90:14",
      "text": "Because he hoped in me I will deliver him: I will protect him because he hath known my name.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.90.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 15,
      "referenceLabel": "Psalms 90:15",
      "text": "He shall cry to me, and I will hear him: I am with him in tribulation, I will deliver him, and I will glorify him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.90.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 16,
      "referenceLabel": "Psalms 90:16",
      "text": "I will fill him with length of days; and I will shew him my salvation.",
      "paragraphStart": false
    }
  ]
}
