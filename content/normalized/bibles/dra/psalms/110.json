{
  "chapter": {
    "id": "dra:psalms.110",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 110,
    "referenceLabel": "Psalms 110",
    "summary": "Source text for Psalms 110 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.110.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 1,
      "referenceLabel": "Psalms 110:1",
      "text": "I will praise thee, O Lord, with my whole heart; in the council of the just, and in the congregation.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.110.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 2,
      "referenceLabel": "Psalms 110:2",
      "text": "Great are the works of the Lord: sought out according to all his wills.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.110.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 3,
      "referenceLabel": "Psalms 110:3",
      "text": "His work is praise and magnificence: and his justice continueth for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.110.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 4,
      "referenceLabel": "Psalms 110:4",
      "text": "He hath made a remembrance of his wonderful works, being a merciful and gracious Lord:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.110.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 5,
      "referenceLabel": "Psalms 110:5",
      "text": "He hath given food to them that fear him. He will be mindful for ever of his covenant:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.110.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 6,
      "referenceLabel": "Psalms 110:6",
      "text": "He will shew forth to his people the power of his works.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.110.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 7,
      "referenceLabel": "Psalms 110:7",
      "text": "That he may give them the inheritance of the Gentiles: the works of his hands are truth and judgment.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.110.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 8,
      "referenceLabel": "Psalms 110:8",
      "text": "All his commandments are faithful: confirmed for ever and ever, made in truth and equity.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.110.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 9,
      "referenceLabel": "Psalms 110:9",
      "text": "He hath sent redemption to his people: he hath commanded his covenant for ever. Holy and terrible is his name:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.110.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 10,
      "referenceLabel": "Psalms 110:10",
      "text": "The fear of the Lord is the beginning of wisdom. A good understanding to all that do it: his praise continueth for ever and ever.",
      "paragraphStart": false
    }
  ]
}
