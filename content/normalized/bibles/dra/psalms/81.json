{
  "chapter": {
    "id": "dra:psalms.81",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 81,
    "referenceLabel": "Psalms 81",
    "summary": "Source text for Psalms 81 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.81.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 1,
      "referenceLabel": "Psalms 81:1",
      "text": "A psalm for Asaph. God hath stood in the congregation of gods: and being in the midst of them he judgeth gods.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.81.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 2,
      "referenceLabel": "Psalms 81:2",
      "text": "How long will you judge unjustly: and accept the persons of the wicked?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.81.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 3,
      "referenceLabel": "Psalms 81:3",
      "text": "Judge for the needy and fatherless: do justice to the humble and the poor.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.81.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 4,
      "referenceLabel": "Psalms 81:4",
      "text": "Rescue the poor; and deliver the needy out of the hand of the sinner.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.81.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 5,
      "referenceLabel": "Psalms 81:5",
      "text": "They have not known nor understood: they walk on in darkness: all the foundations of the earth shall be moved.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.81.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 6,
      "referenceLabel": "Psalms 81:6",
      "text": "I have said: You are gods and all of you the sons of the most High.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.81.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 7,
      "referenceLabel": "Psalms 81:7",
      "text": "But you like men shall die: and shall fall like one of the princes.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.81.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 8,
      "referenceLabel": "Psalms 81:8",
      "text": "Arise, O God, judge thou the earth: for thou shalt inherit among all the nations.",
      "paragraphStart": false
    }
  ]
}
