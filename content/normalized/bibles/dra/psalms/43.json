{
  "chapter": {
    "id": "dra:psalms.43",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 43,
    "referenceLabel": "Psalms 43",
    "summary": "Source text for Psalms 43 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.43.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 1,
      "referenceLabel": "Psalms 43:1",
      "text": "Unto the end, for the sons of Core, to give understanding.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.43.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 2,
      "referenceLabel": "Psalms 43:2",
      "text": "We have heard, O God, with our ears: our fathers have declared to us, The work thou hast wrought in their days, and in the days of old.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 3,
      "referenceLabel": "Psalms 43:3",
      "text": "Thy hand destroyed the Gentiles, and thou plantedst them: thou didst afflict the people and cast them out.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 4,
      "referenceLabel": "Psalms 43:4",
      "text": "For they got not the possession of the land by their own sword: neither did their own arm save them. But thy right hand and thy arm, and the light of thy countenance: because thou wast pleased with them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 5,
      "referenceLabel": "Psalms 43:5",
      "text": "Thou art thyself my king and my God, who commandest the saving of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 6,
      "referenceLabel": "Psalms 43:6",
      "text": "Through thee we will push down our enemies with the horn: and through thy name we will despise them that rise up against us.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 7,
      "referenceLabel": "Psalms 43:7",
      "text": "For I will not trust in my bow: neither shall my sword save me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 8,
      "referenceLabel": "Psalms 43:8",
      "text": "But thou hast saved us from them that afflict us: and hast put them to shame that hate us.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 9,
      "referenceLabel": "Psalms 43:9",
      "text": "In God shall we glory all the day long: and in thy name we will give praise for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 10,
      "referenceLabel": "Psalms 43:10",
      "text": "But now thou hast cast us off, and put us to shame: and thou, O God, wilt not go out with our armies.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 11,
      "referenceLabel": "Psalms 43:11",
      "text": "Thou hast made us turn our back to our enemies: and they that hated us plundered for themselves.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 12,
      "referenceLabel": "Psalms 43:12",
      "text": "Thou hast given us up like sheep to be eaten: thou hast scattered us among the nations.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 13,
      "referenceLabel": "Psalms 43:13",
      "text": "Thou hast sold thy people for no price: and there was no reckoning in the exchange of them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 14,
      "referenceLabel": "Psalms 43:14",
      "text": "Thou hast made us a reproach to our neighbours, a scoff and derision to them that are round about us.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 15,
      "referenceLabel": "Psalms 43:15",
      "text": "Thou hast made us a byword among the Gentiles: a shaking of the head among the people.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 16,
      "referenceLabel": "Psalms 43:16",
      "text": "All the day long my shame is before me: and the confusion of my face hath covered me,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 17,
      "referenceLabel": "Psalms 43:17",
      "text": "At the voice of him that reproacheth and detracteth me: at the face of the enemy and persecutor.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 18,
      "referenceLabel": "Psalms 43:18",
      "text": "All these things have come upon us, yet we have not forgotten thee: and we have not done wickedly in thy covenant.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 19,
      "referenceLabel": "Psalms 43:19",
      "text": "And our heart hath not turned back: neither hast thou turned aside our steps from thy way.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 20,
      "referenceLabel": "Psalms 43:20",
      "text": "For thou hast humbled us in the place of affliction: and the shadow of death hath covered us.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 21,
      "referenceLabel": "Psalms 43:21",
      "text": "If we have forgotten the name of our God, and if we have spread forth our hands to a strange god:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 22,
      "referenceLabel": "Psalms 43:22",
      "text": "Shall not God search out these things: for he knoweth the secrets of the heart. Because for thy sake we are killed all the day long: we are counted as sheep for the slaughter.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 23,
      "referenceLabel": "Psalms 43:23",
      "text": "Arise, why sleepest thou, O Lord? arise, and cast us not off to the end.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.24",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 24,
      "referenceLabel": "Psalms 43:24",
      "text": "Why turnest thou thy face away? and forgettest our want and our trouble?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.25",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 25,
      "referenceLabel": "Psalms 43:25",
      "text": "For our soul is humbled down to the dust: our belly cleaveth to the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.43.26",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 26,
      "referenceLabel": "Psalms 43:26",
      "text": "Arise, O Lord, help us and redeem us for thy name's sake.",
      "paragraphStart": false
    }
  ]
}
