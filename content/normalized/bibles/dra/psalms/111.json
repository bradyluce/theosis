{
  "chapter": {
    "id": "dra:psalms.111",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 111,
    "referenceLabel": "Psalms 111",
    "summary": "Source text for Psalms 111 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.111.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 1,
      "referenceLabel": "Psalms 111:1",
      "text": "Blessed is the man that feareth the Lord: he shall delight exceedingly in his commandments.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.111.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 2,
      "referenceLabel": "Psalms 111:2",
      "text": "His seed shall be mighty upon earth: the generation of the righteous shall be blessed.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.111.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 3,
      "referenceLabel": "Psalms 111:3",
      "text": "Glory and wealth shall be in his house: and his justice remaineth for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.111.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 4,
      "referenceLabel": "Psalms 111:4",
      "text": "To the righteous a light is risen up in darkness: he is merciful, and compassionate and just.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.111.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 5,
      "referenceLabel": "Psalms 111:5",
      "text": "Acceptable is the man that sheweth mercy and lendeth: he shall order his words with judgment:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.111.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 6,
      "referenceLabel": "Psalms 111:6",
      "text": "Because he shall not be moved for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.111.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 7,
      "referenceLabel": "Psalms 111:7",
      "text": "The just shall be in everlasting remembrance: he shall not fear the evil hearing. His heart is ready to hope in the Lord:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.111.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 8,
      "referenceLabel": "Psalms 111:8",
      "text": "His heart is strengthened, he shall not be moved until he look over his enemies.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.111.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 9,
      "referenceLabel": "Psalms 111:9",
      "text": "He hath distributed, he hath given to the poor: his justice remaineth for ever and ever: his horn shall be exalted in glory.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.111.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 10,
      "referenceLabel": "Psalms 111:10",
      "text": "The wicked shall see, and shall be angry, he shall gnash with his teeth and pine away: the desire of the wicked shall perish.",
      "paragraphStart": false
    }
  ]
}
