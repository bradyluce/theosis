{
  "chapter": {
    "id": "dra:psalms.96",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 96,
    "referenceLabel": "Psalms 96",
    "summary": "Source text for Psalms 96 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.96.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 1,
      "referenceLabel": "Psalms 96:1",
      "text": "For the same David, when his land was restored again to him. The Lord hath reigned, let the earth rejoice: let many islands be glad.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.96.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 2,
      "referenceLabel": "Psalms 96:2",
      "text": "Clouds and darkness are round about him: justice and judgment are the establishment of his throne.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.96.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 3,
      "referenceLabel": "Psalms 96:3",
      "text": "A fire shall go before him, and shall burn his enemies round about.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.96.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 4,
      "referenceLabel": "Psalms 96:4",
      "text": "His lightnings have shone forth to the world: the earth saw and trembled.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.96.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 5,
      "referenceLabel": "Psalms 96:5",
      "text": "The mountains melted like wax, at the presence of the Lord: at the presence of the Lord of all the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.96.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 6,
      "referenceLabel": "Psalms 96:6",
      "text": "The heavens declared his justice: and all people saw his glory.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.96.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 7,
      "referenceLabel": "Psalms 96:7",
      "text": "Let them be all confounded that adore graven things, and that glory in their idols. Adore him, all you his angels:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.96.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 8,
      "referenceLabel": "Psalms 96:8",
      "text": "Sion heard, and was glad. And the daughters of Juda rejoiced, because of thy judgments, O Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.96.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 9,
      "referenceLabel": "Psalms 96:9",
      "text": "For thou art the most high Lord over all the earth: thou art exalted exceedingly above all gods.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.96.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 10,
      "referenceLabel": "Psalms 96:10",
      "text": "You that love the Lord, hate evil: the Lord preserveth the souls of his saints, he will deliver them out of the hand of the sinner.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.96.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 11,
      "referenceLabel": "Psalms 96:11",
      "text": "Light is risen to the just, and joy to the right of heart.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.96.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 12,
      "referenceLabel": "Psalms 96:12",
      "text": "Rejoice, ye just, in the Lord: and give praise to the remembrance of his holiness.",
      "paragraphStart": false
    }
  ]
}
