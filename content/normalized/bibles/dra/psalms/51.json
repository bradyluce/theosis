{
  "chapter": {
    "id": "dra:psalms.51",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 51,
    "referenceLabel": "Psalms 51",
    "summary": "Source text for Psalms 51 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.51.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 1,
      "referenceLabel": "Psalms 51:1",
      "text": "Unto the end, understanding for David,",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.51.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 2,
      "referenceLabel": "Psalms 51:2",
      "text": "When Doeg the Edomite came and told Saul: David went to the house of Achimelech.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.51.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 3,
      "referenceLabel": "Psalms 51:3",
      "text": "Why dost thou glory in malice, thou that art mighty in iniquity?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.51.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 4,
      "referenceLabel": "Psalms 51:4",
      "text": "All the day long thy tongue hath devised injustice: as a sharp razor, thou hast wrought deceit.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.51.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 5,
      "referenceLabel": "Psalms 51:5",
      "text": "Thou hast loved malice more than goodness: and iniquity rather than to speak righteousness.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.51.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 6,
      "referenceLabel": "Psalms 51:6",
      "text": "Thou hast loved all the words of ruin, O deceitful tongue.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.51.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 7,
      "referenceLabel": "Psalms 51:7",
      "text": "Therefore will God destroy thee for ever: he will pluck thee out, and remove thee from thy dwelling place: and thy root out of the land of the living.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.51.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 8,
      "referenceLabel": "Psalms 51:8",
      "text": "The just shall see and fear, and shall laugh at him, and say:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.51.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 9,
      "referenceLabel": "Psalms 51:9",
      "text": "Behold the man that made not God his helper: But trusted in the abundance of his riches: and prevailed in his vanity.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.51.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 10,
      "referenceLabel": "Psalms 51:10",
      "text": "But I, as a fruitful olive tree in the house of God, have hoped in the mercy of God for ever, yea for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.51.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 11,
      "referenceLabel": "Psalms 51:11",
      "text": "I will praise thee for ever, because thou hast done it: and I will wait on thy name, for it is good in the sight of thy saints.",
      "paragraphStart": false
    }
  ]
}
