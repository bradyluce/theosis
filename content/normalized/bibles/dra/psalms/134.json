{
  "chapter": {
    "id": "dra:psalms.134",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 134,
    "referenceLabel": "Psalms 134",
    "summary": "Source text for Psalms 134 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.134.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 1,
      "referenceLabel": "Psalms 134:1",
      "text": "Alleluia. Praise ye the name of the Lord: O you his servants, praise the Lord:",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.134.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 2,
      "referenceLabel": "Psalms 134:2",
      "text": "You that stand in the house of the Lord, in the courts of the house of our God.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.134.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 3,
      "referenceLabel": "Psalms 134:3",
      "text": "Praise ye the Lord, for the Lord is good: sing ye to his name, for it is sweet.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.134.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 4,
      "referenceLabel": "Psalms 134:4",
      "text": "For the Lord hath chosen Jacob unto himself: Israel for his own possession.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.134.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 5,
      "referenceLabel": "Psalms 134:5",
      "text": "For I have known that the Lord is great, and our God is above all gods.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.134.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 6,
      "referenceLabel": "Psalms 134:6",
      "text": "Whatsoever the Lord pleased he hath done, in heaven, in earth, in the sea, and in all the deeps.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.134.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 7,
      "referenceLabel": "Psalms 134:7",
      "text": "He bringeth up clouds from the end of the earth: he hath made lightnings for the rain. He bringeth forth winds out of his stores:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.134.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 8,
      "referenceLabel": "Psalms 134:8",
      "text": "He slew the firstborn of Egypt from man even unto beast.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.134.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 9,
      "referenceLabel": "Psalms 134:9",
      "text": "He sent forth signs and wonders in the midst of thee, O Egypt: upon Pharao, and upon all his servants.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.134.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 10,
      "referenceLabel": "Psalms 134:10",
      "text": "He smote many nations, and slew mighty kings:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.134.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 11,
      "referenceLabel": "Psalms 134:11",
      "text": "Sehon king of the Amorrhites, and Og king of Basan, and all the kingdoms of Chanaan.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.134.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 12,
      "referenceLabel": "Psalms 134:12",
      "text": "And gave their land for an inheritance, for an inheritance to his people Israel.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.134.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 13,
      "referenceLabel": "Psalms 134:13",
      "text": "Thy name, O Lord, is for ever: thy memorial, O Lord, unto all generations.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.134.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 14,
      "referenceLabel": "Psalms 134:14",
      "text": "For the Lord will judge his people, and will be entreated in favour of his servants.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.134.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 15,
      "referenceLabel": "Psalms 134:15",
      "text": "The idols of the Gentiles are silver and gold, the works of men's hands.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.134.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 16,
      "referenceLabel": "Psalms 134:16",
      "text": "They have a mouth, but they speak not: they have eyes, but they see not.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.134.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 17,
      "referenceLabel": "Psalms 134:17",
      "text": "They have ears, but they hear not: neither is there any breath in their mouths.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.134.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 18,
      "referenceLabel": "Psalms 134:18",
      "text": "Let them that make them be like to them: and every one that trusteth in them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.134.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 19,
      "referenceLabel": "Psalms 134:19",
      "text": "Bless the Lord, O house of Israel: bless the Lord, O house of Aaron.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.134.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 20,
      "referenceLabel": "Psalms 134:20",
      "text": "Bless the Lord, O house of Levi: you that fear the Lord, bless the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.134.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 21,
      "referenceLabel": "Psalms 134:21",
      "text": "Blessed be the Lord out of Sion, who dwelleth in Jerusalem.",
      "paragraphStart": false
    }
  ]
}
