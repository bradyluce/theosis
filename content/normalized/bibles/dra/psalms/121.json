{
  "chapter": {
    "id": "dra:psalms.121",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 121,
    "referenceLabel": "Psalms 121",
    "summary": "Source text for Psalms 121 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.121.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 1,
      "referenceLabel": "Psalms 121:1",
      "text": "A gradual canticle. I rejoiced at the things that were said to me: We shall go into the house of the Lord.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.121.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 2,
      "referenceLabel": "Psalms 121:2",
      "text": "Our feet were standing in thy courts, O Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.121.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 3,
      "referenceLabel": "Psalms 121:3",
      "text": "Jerusalem, which is built as a city, which is compact together.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.121.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 4,
      "referenceLabel": "Psalms 121:4",
      "text": "For thither did the tribes go up, the tribes of the Lord: the testimony of Israel, to praise the name of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.121.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 5,
      "referenceLabel": "Psalms 121:5",
      "text": "Because their seats have sat in judgment, seats upon the house of David.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.121.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 6,
      "referenceLabel": "Psalms 121:6",
      "text": "Pray ye for the things that are for the peace of Jerusalem: and abundance for them that love thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.121.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 7,
      "referenceLabel": "Psalms 121:7",
      "text": "Let peace be in thy strength: and abundance in thy towers.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.121.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 8,
      "referenceLabel": "Psalms 121:8",
      "text": "For the sake of my brethren, and of my neighbours, I spoke peace of thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.121.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 9,
      "referenceLabel": "Psalms 121:9",
      "text": "Because of the house of the Lord our God, I have sought good things for thee.",
      "paragraphStart": false
    }
  ]
}
