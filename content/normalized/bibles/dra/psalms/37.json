{
  "chapter": {
    "id": "dra:psalms.37",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 37,
    "referenceLabel": "Psalms 37",
    "summary": "Source text for Psalms 37 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.37.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 1,
      "referenceLabel": "Psalms 37:1",
      "text": "A psalm for David, for a remembrance of the sabbath.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.37.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 2,
      "referenceLabel": "Psalms 37:2",
      "text": "Rebuke me not, O Lord, in thy indignation; nor chastise me in thy wrath.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 3,
      "referenceLabel": "Psalms 37:3",
      "text": "For thy arrows are fastened in me: and thy hand hath been strong upon me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 4,
      "referenceLabel": "Psalms 37:4",
      "text": "There is no health in my flesh, because of thy wrath: there is no peace for my bones, because of my sins.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 5,
      "referenceLabel": "Psalms 37:5",
      "text": "For my iniquities are gone over my head: and as a heavy burden are become heavy upon me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 6,
      "referenceLabel": "Psalms 37:6",
      "text": "My sores are putrefied and corrupted, because of my foolishness.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 7,
      "referenceLabel": "Psalms 37:7",
      "text": "I am become miserable, and am bowed down even to the end: I walked sorrowful all the day long.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 8,
      "referenceLabel": "Psalms 37:8",
      "text": "For my loins are filled with illusions; and there is no health in my flesh.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 9,
      "referenceLabel": "Psalms 37:9",
      "text": "I am afflicted and humbled exceedingly: I roared with the groaning of my heart.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 10,
      "referenceLabel": "Psalms 37:10",
      "text": "Lord, all my desire is before thee, and my groaning is not hidden from thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 11,
      "referenceLabel": "Psalms 37:11",
      "text": "My heart is troubled, my strength hath left me, and the light of my eyes itself is not with me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 12,
      "referenceLabel": "Psalms 37:12",
      "text": "My friends and my neighbours have drawn near, and stood against me. And they that were near me stood afar off:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 13,
      "referenceLabel": "Psalms 37:13",
      "text": "And they that sought my soul used violence. And they that sought evils to me spoke vain things, and studied deceits all the day long.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 14,
      "referenceLabel": "Psalms 37:14",
      "text": "But I, as a deaf man, heard not: and as a dumb man not opening his mouth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 15,
      "referenceLabel": "Psalms 37:15",
      "text": "And I became as a man that heareth not: and that hath no reproofs in his mouth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 16,
      "referenceLabel": "Psalms 37:16",
      "text": "For in thee, O Lord, have I hoped: thou wilt hear me, O Lord my God.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 17,
      "referenceLabel": "Psalms 37:17",
      "text": "For I said: Lest at any time my enemies rejoice over me: and whilst my feet are moved, they speak great things against me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 18,
      "referenceLabel": "Psalms 37:18",
      "text": "For I am ready for scourges: and my sorrow is continually before me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 19,
      "referenceLabel": "Psalms 37:19",
      "text": "For I will declare my iniquity: and I will think for my sin.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 20,
      "referenceLabel": "Psalms 37:20",
      "text": "But my enemies live, and are stronger than I: and they that hate me wrongfully are multiplied.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 21,
      "referenceLabel": "Psalms 37:21",
      "text": "They that render evil for good, have detracted me, because I followed goodness.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 22,
      "referenceLabel": "Psalms 37:22",
      "text": "For sake me not, O Lord my God: do not thou depart from me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.37.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 23,
      "referenceLabel": "Psalms 37:23",
      "text": "Attend unto my help, O Lord, the God of my salvation.",
      "paragraphStart": false
    }
  ]
}
