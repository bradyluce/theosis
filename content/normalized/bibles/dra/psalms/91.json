{
  "chapter": {
    "id": "dra:psalms.91",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 91,
    "referenceLabel": "Psalms 91",
    "summary": "Source text for Psalms 91 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.91.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 1,
      "referenceLabel": "Psalms 91:1",
      "text": "A psalm of a canticle on the sabbath day.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.91.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 2,
      "referenceLabel": "Psalms 91:2",
      "text": "It is good to give praise to the Lord: and to sing to thy name, O most High.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.91.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 3,
      "referenceLabel": "Psalms 91:3",
      "text": "To shew forth thy mercy in the morning, and thy truth in the night:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.91.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 4,
      "referenceLabel": "Psalms 91:4",
      "text": "Upon an instrument of ten strings, upon the psaltery: with a canticle upon the harp.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.91.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 5,
      "referenceLabel": "Psalms 91:5",
      "text": "For thou hast given me, O Lord, a delight in thy doings: and in the works of thy hands I shall rejoice.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.91.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 6,
      "referenceLabel": "Psalms 91:6",
      "text": "O Lord, how great are thy works! thy thoughts are exceeding deep.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.91.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 7,
      "referenceLabel": "Psalms 91:7",
      "text": "The senseless man shall not know: nor will the fool understand these things.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.91.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 8,
      "referenceLabel": "Psalms 91:8",
      "text": "When the wicked shall spring up as grass: and all the workers of iniquity shall appear: That they may perish for ever and ever:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.91.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 9,
      "referenceLabel": "Psalms 91:9",
      "text": "But thou, O Lord, art most high for evermore.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.91.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 10,
      "referenceLabel": "Psalms 91:10",
      "text": "For behold thy enemies, O Lord, for behold thy enemies shall perish: and all the workers of iniquity shall be scattered.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.91.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 11,
      "referenceLabel": "Psalms 91:11",
      "text": "But my horn shall be exalted like that of the unicorn: and my old age in plentiful mercy.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.91.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 12,
      "referenceLabel": "Psalms 91:12",
      "text": "My eye also hath looked down upon my enemies: and my ear shall hear of the downfall of the malignant that rise up against me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.91.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 13,
      "referenceLabel": "Psalms 91:13",
      "text": "The just shall flourish like the palm tree: he shall grow up like the cedar of Libanus.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.91.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 14,
      "referenceLabel": "Psalms 91:14",
      "text": "They that are planted in the house of the Lord shall flourish in the courts of the house of our God.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.91.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 15,
      "referenceLabel": "Psalms 91:15",
      "text": "They shall still increase in a fruitful old age: and shall be well treated,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.91.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 16,
      "referenceLabel": "Psalms 91:16",
      "text": "That they may shew, That the Lord our God is righteous, and there is no iniquity in him.",
      "paragraphStart": false
    }
  ]
}
