{
  "chapter": {
    "id": "dra:psalms.102",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 102,
    "referenceLabel": "Psalms 102",
    "summary": "Source text for Psalms 102 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.102.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 1,
      "referenceLabel": "Psalms 102:1",
      "text": "For David himself. Bless the Lord, O my soul: and let all that is within me bless his holy name.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.102.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 2,
      "referenceLabel": "Psalms 102:2",
      "text": "Bless the Lord, O my soul, and never forget all he hath done for thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 3,
      "referenceLabel": "Psalms 102:3",
      "text": "Who forgiveth all thy iniquities: who healeth all thy diseases.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 4,
      "referenceLabel": "Psalms 102:4",
      "text": "Who redeemeth thy life from destruction: who crowneth thee with mercy and compassion.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 5,
      "referenceLabel": "Psalms 102:5",
      "text": "Who satisfieth thy desire with good things: thy youth shall be renewed like the eagle's.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 6,
      "referenceLabel": "Psalms 102:6",
      "text": "The Lord doth mercies, and judgment for all that suffer wrong.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 7,
      "referenceLabel": "Psalms 102:7",
      "text": "He hath made his ways known to Moses: his wills to the children of Israel.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 8,
      "referenceLabel": "Psalms 102:8",
      "text": "The Lord is compassionate and merciful: longsuffering and plenteous in mercy.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 9,
      "referenceLabel": "Psalms 102:9",
      "text": "He will not always be angry: nor will he threaten for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 10,
      "referenceLabel": "Psalms 102:10",
      "text": "He hath not dealt with us according to our sins: nor rewarded us according to our iniquities.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 11,
      "referenceLabel": "Psalms 102:11",
      "text": "For according to the height of the heaven above the earth: he hath strengthened his mercy towards them that fear him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 12,
      "referenceLabel": "Psalms 102:12",
      "text": "As far as the east is from the west, so far hath he removed our iniquities from us.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 13,
      "referenceLabel": "Psalms 102:13",
      "text": "As a father hath compassion on his children, so hath the Lord compassion on them that fear him:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 14,
      "referenceLabel": "Psalms 102:14",
      "text": "For he knoweth our frame. He remembereth that we are dust:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 15,
      "referenceLabel": "Psalms 102:15",
      "text": "Man's days are as grass, as the flower of the field so shall he flourish.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 16,
      "referenceLabel": "Psalms 102:16",
      "text": "For the spirit shall pass in him, and he shall not be: and he shall know his place no more.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 17,
      "referenceLabel": "Psalms 102:17",
      "text": "But the mercy of the Lord is from eternity and unto eternity upon them that fear him: And his justice unto children's children,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 18,
      "referenceLabel": "Psalms 102:18",
      "text": "To such as keep his covenant, And are mindful of his commandments to do them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 19,
      "referenceLabel": "Psalms 102:19",
      "text": "The Lord hath prepared his throne in heaven: and his kingdom shall rule over all.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 20,
      "referenceLabel": "Psalms 102:20",
      "text": "Bless the Lord, all ye his angels: you that are mighty in strength, and execute his word, hearkening to the voice of his orders.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 21,
      "referenceLabel": "Psalms 102:21",
      "text": "Bless the Lord, all ye his hosts: you ministers of his that do his will.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.102.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 22,
      "referenceLabel": "Psalms 102:22",
      "text": "Bless the Lord, all his works: in every place of his dominion, O my soul, bless thou the Lord.",
      "paragraphStart": false
    }
  ]
}
