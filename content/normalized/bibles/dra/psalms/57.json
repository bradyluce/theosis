{
  "chapter": {
    "id": "dra:psalms.57",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 57,
    "referenceLabel": "Psalms 57",
    "summary": "Source text for Psalms 57 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.57.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 1,
      "referenceLabel": "Psalms 57:1",
      "text": "Unto the end, destroy not, for David, for an inscription of a title.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.57.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 2,
      "referenceLabel": "Psalms 57:2",
      "text": "If in very deed ye speak justice: judge right things, ye sons of men.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.57.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 3,
      "referenceLabel": "Psalms 57:3",
      "text": "For in your heart you work iniquity: your hands forge injustice in the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.57.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 4,
      "referenceLabel": "Psalms 57:4",
      "text": "The wicked are alienated from the womb; they have gone astray from the womb: they have spoken false things.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.57.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 5,
      "referenceLabel": "Psalms 57:5",
      "text": "Their madness is according to the likeness of a serpent: like the deaf asp that stoppeth her ears:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.57.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 6,
      "referenceLabel": "Psalms 57:6",
      "text": "Which will not hear the voice of the charmers; nor of the wizard that charmeth wisely.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.57.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 7,
      "referenceLabel": "Psalms 57:7",
      "text": "God shall break in pieces their teeth in their mouth: the Lord shall break the grinders of the lions.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.57.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 8,
      "referenceLabel": "Psalms 57:8",
      "text": "They shall come to nothing, like water running down; he hath bent his bow till they be weakened.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.57.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 9,
      "referenceLabel": "Psalms 57:9",
      "text": "Like wax that melteth they shall be taken away: fire hath fallen on them, and they shall not see the sun.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.57.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 10,
      "referenceLabel": "Psalms 57:10",
      "text": "Before your thorns could know the brier; he swalloweth them up, as alive, in his wrath.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.57.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 11,
      "referenceLabel": "Psalms 57:11",
      "text": "The just shall rejoice when he shall see the revenge: he shall wash his hands in the blood of the sinner.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.57.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 12,
      "referenceLabel": "Psalms 57:12",
      "text": "And man shall say: If indeed there be fruit to the just: there is indeed a God that judgeth them on the earth.",
      "paragraphStart": false
    }
  ]
}
