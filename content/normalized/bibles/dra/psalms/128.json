{
  "chapter": {
    "id": "dra:psalms.128",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 128,
    "referenceLabel": "Psalms 128",
    "summary": "Source text for Psalms 128 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.128.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 1,
      "referenceLabel": "Psalms 128:1",
      "text": "A gradual canticle. Often have they fought against me from my youth, let Israel now say.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.128.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 2,
      "referenceLabel": "Psalms 128:2",
      "text": "Often have they fought against me from my youth: but they could not prevail over me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.128.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 3,
      "referenceLabel": "Psalms 128:3",
      "text": "The wicked have wrought upon my back: they have lengthened their iniquity.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.128.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 4,
      "referenceLabel": "Psalms 128:4",
      "text": "The Lord who is just will cut the necks of sinners:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.128.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 5,
      "referenceLabel": "Psalms 128:5",
      "text": "Let them all be confounded and turned back that hate Sion.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.128.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 6,
      "referenceLabel": "Psalms 128:6",
      "text": "Let them be as grass upon the tops of houses: which withereth before it be plucked up:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.128.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 7,
      "referenceLabel": "Psalms 128:7",
      "text": "Who with the mower filleth not his hand: nor he that gathereth sheaves his bosom.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.128.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 8,
      "referenceLabel": "Psalms 128:8",
      "text": "And they that passed by have not said: The blessing of the Lord be upon you: we have blessed you in the name of the Lord.",
      "paragraphStart": false
    }
  ]
}
