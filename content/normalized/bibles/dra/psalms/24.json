{
  "chapter": {
    "id": "dra:psalms.24",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 24,
    "referenceLabel": "Psalms 24",
    "summary": "Source text for Psalms 24 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.24.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Psalms 24:1",
      "text": "Unto the end, a psalm for David. To thee, O Lord, have I lifted up my soul.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.24.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Psalms 24:2",
      "text": "In thee, O my God, I put my trust; let me not be ashamed.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Psalms 24:3",
      "text": "Neither let my enemies laugh at me: for none of them that wait on thee shall be confounded.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Psalms 24:4",
      "text": "Let all them be confounded that act unjust things without cause. Shew, O Lord, thy ways to me, and teach me thy paths.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Psalms 24:5",
      "text": "Direct me in thy truth, and teach me; for thou art God my Saviour; and on thee have I waited all the day long.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Psalms 24:6",
      "text": "Remember, O Lord, thy bowels of compassion; and thy mercies that are from the beginning of the world.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Psalms 24:7",
      "text": "The sins of my youth and my ignorances do not remember. According to thy mercy remember thou me: for thy goodness' sake, O Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Psalms 24:8",
      "text": "The Lord is sweet and righteous: therefore he will give a law to sinners in the way.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Psalms 24:9",
      "text": "He will guide the mild in judgment: he will teach the meek his ways.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Psalms 24:10",
      "text": "All the ways of the Lord are mercy and truth, to them that seek after his covenant and his testimonies.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 11,
      "referenceLabel": "Psalms 24:11",
      "text": "For thy name's sake, O Lord, thou wilt pardon my sin: for it is great.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 12,
      "referenceLabel": "Psalms 24:12",
      "text": "Who is the man that feareth the Lord? He hath appointed him a law in the way he hath chosen.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 13,
      "referenceLabel": "Psalms 24:13",
      "text": "His soul shall dwell in good things: and his seed shall inherit the land.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 14,
      "referenceLabel": "Psalms 24:14",
      "text": "The Lord is a firmament to them that fear him: and his covenant shall be made manifest to them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 15,
      "referenceLabel": "Psalms 24:15",
      "text": "My eyes are ever towards the Lord: for he shall pluck my feet out of the snare.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 16,
      "referenceLabel": "Psalms 24:16",
      "text": "Look thou upon me, and have mercy on me; for I am alone and poor.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 17,
      "referenceLabel": "Psalms 24:17",
      "text": "The troubles of my heart are multiplied: deliver me from my necessities.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 18,
      "referenceLabel": "Psalms 24:18",
      "text": "See my abjection and my labour; and forgive me all my sins.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 19,
      "referenceLabel": "Psalms 24:19",
      "text": "Consider my enemies for they are multiplied, and have hated me with an unjust hatred.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 20,
      "referenceLabel": "Psalms 24:20",
      "text": "Keep thou my soul, and deliver me: I shall not be ashamed, for I have hoped in thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 21,
      "referenceLabel": "Psalms 24:21",
      "text": "The innocent and the upright have adhered to me: because I have waited on thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.24.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 22,
      "referenceLabel": "Psalms 24:22",
      "text": "Deliver Israel, O God, from all his tribulations.",
      "paragraphStart": false
    }
  ]
}
