{
  "chapter": {
    "id": "dra:psalms.131",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 131,
    "referenceLabel": "Psalms 131",
    "summary": "Source text for Psalms 131 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.131.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 1,
      "referenceLabel": "Psalms 131:1",
      "text": "A gradual canticle. O Lord, remember David, and all his meekness.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.131.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 2,
      "referenceLabel": "Psalms 131:2",
      "text": "How he swore to the Lord, he vowed a vow to the God of Jacob:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.131.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 3,
      "referenceLabel": "Psalms 131:3",
      "text": "If I shall enter into the tabernacle of my house: if I shall go up into the bed wherein I lie:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.131.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 4,
      "referenceLabel": "Psalms 131:4",
      "text": "If I shall give sleep to my eyes, or slumber to my eyelids,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.131.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 5,
      "referenceLabel": "Psalms 131:5",
      "text": "Or rest to my temples: until I find out a place for the Lord, a tabernacle for the God of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.131.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 6,
      "referenceLabel": "Psalms 131:6",
      "text": "Behold we have heard of it in Ephrata: we have found it in the fields of the wood.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.131.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 7,
      "referenceLabel": "Psalms 131:7",
      "text": "We will go into his tabernacle: we will adore in the place where his feet stood.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.131.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 8,
      "referenceLabel": "Psalms 131:8",
      "text": "Arise, O Lord, into thy resting place: thou and the ark, which thou hast sanctified.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.131.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 9,
      "referenceLabel": "Psalms 131:9",
      "text": "Let thy priests be clothed with justice: and let thy saints rejoice.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.131.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 10,
      "referenceLabel": "Psalms 131:10",
      "text": "For thy servant David's sake, turn not away the face of thy anointed.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.131.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 11,
      "referenceLabel": "Psalms 131:11",
      "text": "The Lord hath sworn truth to David, and he will not make it void: of the fruit of thy womb I will set upon thy throne.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.131.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 12,
      "referenceLabel": "Psalms 131:12",
      "text": "If thy children will keep my covenant, and these my testimonies which I shall teach them: Their children also for evermore shall sit upon thy throne.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.131.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 13,
      "referenceLabel": "Psalms 131:13",
      "text": "For the Lord hath chosen Sion: he hath chosen it for his dwelling.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.131.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 14,
      "referenceLabel": "Psalms 131:14",
      "text": "This is my rest for ever and ever: here will I dwell, for I have chosen it.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.131.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 15,
      "referenceLabel": "Psalms 131:15",
      "text": "Blessing I will bless her widow: I will satisfy her poor with bread.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.131.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 16,
      "referenceLabel": "Psalms 131:16",
      "text": "I will clothe her priests with salvation, and her saints shall rejoice with exceeding great joy.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.131.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 17,
      "referenceLabel": "Psalms 131:17",
      "text": "There will I bring forth a horn to David: I have prepared a lamp for my anointed.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.131.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 18,
      "referenceLabel": "Psalms 131:18",
      "text": "His enemies I will clothe with confusion: but upon him shall my sanctification flourish.",
      "paragraphStart": false
    }
  ]
}
