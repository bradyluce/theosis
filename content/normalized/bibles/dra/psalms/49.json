{
  "chapter": {
    "id": "dra:psalms.49",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 49,
    "referenceLabel": "Psalms 49",
    "summary": "Source text for Psalms 49 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.49.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 1,
      "referenceLabel": "Psalms 49:1",
      "text": "A psalm for Asaph. The God of gods, the Lord hath spoken: and he hath called the earth. From the rising of the sun, to the going down thereof:",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.49.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 2,
      "referenceLabel": "Psalms 49:2",
      "text": "Out of Sion the loveliness of his beauty.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 3,
      "referenceLabel": "Psalms 49:3",
      "text": "God shall come manifestly: our God shall come, and shall not keep silence. A fire shall burn before him: and a mighty tempest shall be round about him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 4,
      "referenceLabel": "Psalms 49:4",
      "text": "He shall call heaven from above, and the earth, to judge his people.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 5,
      "referenceLabel": "Psalms 49:5",
      "text": "Gather ye together his saints to him: who set his covenant before sacrifices.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 6,
      "referenceLabel": "Psalms 49:6",
      "text": "And the heavens shall declare his justice: for God is judge.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 7,
      "referenceLabel": "Psalms 49:7",
      "text": "Hear, O my people, and I will speak: O Israel, and I will testify to thee: I am God, thy God.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 8,
      "referenceLabel": "Psalms 49:8",
      "text": "I will not reprove thee for thy sacrifices: and thy burnt offerings are always in my sight.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 9,
      "referenceLabel": "Psalms 49:9",
      "text": "I will not take calves out of thy house: nor he goats out of thy flocks.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 10,
      "referenceLabel": "Psalms 49:10",
      "text": "For all the beasts of the woods are mine: the cattle on the hills, and the oxen.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 11,
      "referenceLabel": "Psalms 49:11",
      "text": "I know all the fowls of the air: and with me is the beauty of the field.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 12,
      "referenceLabel": "Psalms 49:12",
      "text": "If I should be hungry, I would not tell thee: for the world is mine, and the fulness thereof.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 13,
      "referenceLabel": "Psalms 49:13",
      "text": "Shall I eat the flesh of bullocks? or shall I drink the blood of goats?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 14,
      "referenceLabel": "Psalms 49:14",
      "text": "Offer to God the sacrifice of praise: and pay thy vows to the most High.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 15,
      "referenceLabel": "Psalms 49:15",
      "text": "And call upon me in the day of trouble: I will deliver thee, and thou shalt glorify me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 16,
      "referenceLabel": "Psalms 49:16",
      "text": "But to the sinner God hath said: Why dost thou declare my justices, and take my covenant in thy mouth?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 17,
      "referenceLabel": "Psalms 49:17",
      "text": "Seeing thou hast hated discipline: and hast cast my words behind thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 18,
      "referenceLabel": "Psalms 49:18",
      "text": "If thou didst see a thief thou didst run with him: and with adulterers thou hast been a partaker.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 19,
      "referenceLabel": "Psalms 49:19",
      "text": "Thy mouth hath abounded with evil, and thy tongue framed deceits.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 20,
      "referenceLabel": "Psalms 49:20",
      "text": "Sitting thou didst speak against thy brother, and didst lay a scandal against thy mother's son:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 21,
      "referenceLabel": "Psalms 49:21",
      "text": "These things hast thou done, and I was silent. Thou thoughtest unjustly that I should be like to thee: but I will reprove thee, and set before thy face.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 22,
      "referenceLabel": "Psalms 49:22",
      "text": "Understand these things, you that forget God; lest he snatch you away, and there be none to deliver you.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.49.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 23,
      "referenceLabel": "Psalms 49:23",
      "text": "The sacrifice of praise shall glorify me: and there is the way by which I will shew him the salvation of God.",
      "paragraphStart": false
    }
  ]
}
