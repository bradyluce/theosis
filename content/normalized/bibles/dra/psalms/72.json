{
  "chapter": {
    "id": "dra:psalms.72",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 72,
    "referenceLabel": "Psalms 72",
    "summary": "Source text for Psalms 72 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.72.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 1,
      "referenceLabel": "Psalms 72:1",
      "text": "A psalm for Asaph. How good is God to Israel, to them that are of a right heart!",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.72.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 2,
      "referenceLabel": "Psalms 72:2",
      "text": "But my feet were almost moved; my steps had well nigh slipped.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 3,
      "referenceLabel": "Psalms 72:3",
      "text": "Because I had a zeal on occasion of the wicked, seeing the prosperity of sinners.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 4,
      "referenceLabel": "Psalms 72:4",
      "text": "For there is no regard to their death, nor is there strength in their stripes.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 5,
      "referenceLabel": "Psalms 72:5",
      "text": "They are not in the labour of men: neither shall they be scourged like other men.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 6,
      "referenceLabel": "Psalms 72:6",
      "text": "Therefore pride hath held them fast: they are covered with their iniquity and their wickedness.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 7,
      "referenceLabel": "Psalms 72:7",
      "text": "Their iniquity hath come forth, as it were from fatness: they have passed into the affection of the heart.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 8,
      "referenceLabel": "Psalms 72:8",
      "text": "They have thought and spoken wickedness: they have spoken iniquity on high.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 9,
      "referenceLabel": "Psalms 72:9",
      "text": "They have set their mouth against heaven: and their tongue hath passed through the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 10,
      "referenceLabel": "Psalms 72:10",
      "text": "Therefore will my people return here and full days shall be found in them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 11,
      "referenceLabel": "Psalms 72:11",
      "text": "And they said: How doth God know? and is there knowledge in the most High?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 12,
      "referenceLabel": "Psalms 72:12",
      "text": "Behold these are sinners; and yet, abounding in the world they have obtained riches.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 13,
      "referenceLabel": "Psalms 72:13",
      "text": "And I said: Then have I in vain justified my heart, and washed my hands among the innocent.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 14,
      "referenceLabel": "Psalms 72:14",
      "text": "And I have been scourged all the day; and my chastisement hath been in the mornings.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 15,
      "referenceLabel": "Psalms 72:15",
      "text": "If I said: I will speak thus; behold I should condemn the generation of thy children.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 16,
      "referenceLabel": "Psalms 72:16",
      "text": "I studied that I might know this thing, it is a labour in my sight:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 17,
      "referenceLabel": "Psalms 72:17",
      "text": "Until I go into the sanctuary of God, and understand concerning their last ends.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 18,
      "referenceLabel": "Psalms 72:18",
      "text": "But indeed for deceits thou hast put it to them: when they were lifted up thou hast cast them down.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 19,
      "referenceLabel": "Psalms 72:19",
      "text": "How are they brought to desolation? they have suddenly ceased to be: they have perished by reason of their iniquity.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 20,
      "referenceLabel": "Psalms 72:20",
      "text": "As the dream of them that awake, O Lord; so in thy city thou shalt bring their image to nothing.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 21,
      "referenceLabel": "Psalms 72:21",
      "text": "For my heart hath been inflamed, and my reins have been changed:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 22,
      "referenceLabel": "Psalms 72:22",
      "text": "And I am brought to nothing, and I knew not.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 23,
      "referenceLabel": "Psalms 72:23",
      "text": "I am become as a beast before thee: and I am always with thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.24",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 24,
      "referenceLabel": "Psalms 72:24",
      "text": "Thou hast held me by my right hand; and by thy will thou hast conducted me, and with thy glory thou hast received me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.25",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 25,
      "referenceLabel": "Psalms 72:25",
      "text": "For what have I in heaven? and besides thee what do I desire upon earth?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.26",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 26,
      "referenceLabel": "Psalms 72:26",
      "text": "For thee my flesh and my heart hath fainted away: thou art the God of my heart, and the God that is my portion for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.27",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 27,
      "referenceLabel": "Psalms 72:27",
      "text": "For behold they that go far from thee shall perish: thou hast destroyed all them that are disloyal to thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.72.28",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 28,
      "referenceLabel": "Psalms 72:28",
      "text": "But it is good for me to adhere to my God, to put my hope in the Lord God: That I may declare all thy praises, in the gates of the daughter of Sion.",
      "paragraphStart": false
    }
  ]
}
