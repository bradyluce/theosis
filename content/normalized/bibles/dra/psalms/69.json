{
  "chapter": {
    "id": "dra:psalms.69",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 69,
    "referenceLabel": "Psalms 69",
    "summary": "Source text for Psalms 69 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.69.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 1,
      "referenceLabel": "Psalms 69:1",
      "text": "Unto the end, a psalm for David, to bring to remembrance that the Lord saved him.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.69.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 2,
      "referenceLabel": "Psalms 69:2",
      "text": "O God, come to my assistance; O Lord, make haste to help me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.69.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 3,
      "referenceLabel": "Psalms 69:3",
      "text": "Let them be confounded and ashamed that seek my soul:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.69.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 4,
      "referenceLabel": "Psalms 69:4",
      "text": "Let them be turned backward, and blush for shame that desire evils to me: Let them be presently turned away blushing for shame that say to me: 'Tis well, 'tis well.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.69.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 5,
      "referenceLabel": "Psalms 69:5",
      "text": "Let all that seek thee rejoice and be glad in thee; and let such as love thy salvation say always: The Lord be magnified.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.69.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 6,
      "referenceLabel": "Psalms 69:6",
      "text": "But I am needy and poor; O God, help me. Thou art my helper and my deliverer: O Lord, make no delay.",
      "paragraphStart": false
    }
  ]
}
