  "verses": [
    {
      "id": "dra:psalms.119.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 1,
      "referenceLabel": "Psalms 119:1",
      "text": "In my trouble I cried to the Lord: and he heard me.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.119.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 2,
      "referenceLabel": "Psalms 119:2",
      "text": "O Lord, deliver my soul from wicked lips, and a deceitful tongue.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.119.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 3,
      "referenceLabel": "Psalms 119:3",
      "text": "What shall be given to thee, or what shall be added to thee, to a deceitful tongue?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.119.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 4,
      "referenceLabel": "Psalms 119:4",
      "text": "The sharp arrows of the mighty, with coals that lay waste.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.119.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 5,
      "referenceLabel": "Psalms 119:5",
      "text": "Woe is me, that my sojourning is prolonged! I have dwelt with the inhabitants of Cedar:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.119.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 6,
      "referenceLabel": "Psalms 119:6",
      "text": "My soul hath been long a sojourner.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.119.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 7,
      "referenceLabel": "Psalms 119:7",
      "text": "With them that hated peace I was peaceable: when I spoke to them they fought against me without cause.",
      "paragraphStart": false
    }
  ]
}
