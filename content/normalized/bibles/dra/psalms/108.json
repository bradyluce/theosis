{
  "chapter": {
    "id": "dra:psalms.108",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 108,
    "referenceLabel": "Psalms 108",
    "summary": "Source text for Psalms 108 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.108.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 1,
      "referenceLabel": "Psalms 108:1",
      "text": "Unto the end, a psalm for David.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.108.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 2,
      "referenceLabel": "Psalms 108:2",
      "text": "O God, be not thou silent in my praise: for the mouth of the wicked and the mouth of the deceitful man is opened against me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 3,
      "referenceLabel": "Psalms 108:3",
      "text": "They have spoken against me with deceitful tongues; and they have compassed me about with words of hatred; and have fought against me without cause.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 4,
      "referenceLabel": "Psalms 108:4",
      "text": "Instead of making me a return of love, they detracted me: but I gave myself to prayer.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 5,
      "referenceLabel": "Psalms 108:5",
      "text": "And they repaid me evil for good: and hatred for my love.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 6,
      "referenceLabel": "Psalms 108:6",
      "text": "Set thou the sinner over him: and may the devil stand at his right hand.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 7,
      "referenceLabel": "Psalms 108:7",
      "text": "When he is judged, may he go out condemned; and may his prayer be turned to sin.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 8,
      "referenceLabel": "Psalms 108:8",
      "text": "May his days be few: and his bishopric let another take.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 9,
      "referenceLabel": "Psalms 108:9",
      "text": "May his children be fatherless, and his wife a widow.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 10,
      "referenceLabel": "Psalms 108:10",
      "text": "Let his children be carried about vagabonds, and beg; and let them be cast out of their dwellings.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 11,
      "referenceLabel": "Psalms 108:11",
      "text": "May the usurer search all his substance: and let strangers plunder his labours.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 12,
      "referenceLabel": "Psalms 108:12",
      "text": "May there be none to help him: nor none to pity his fatherless offspring.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 13,
      "referenceLabel": "Psalms 108:13",
      "text": "May his posterity be cut off; in one generation may his name be blotted out.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 14,
      "referenceLabel": "Psalms 108:14",
      "text": "May the iniquity of his fathers be remembered in the sight of the Lord: and let not the sin of his mother be blotted out.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 15,
      "referenceLabel": "Psalms 108:15",
      "text": "May they be before the Lord continually, and let the memory of them perish from the earth:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 16,
      "referenceLabel": "Psalms 108:16",
      "text": "because he remembered not to shew mercy,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 17,
      "referenceLabel": "Psalms 108:17",
      "text": "But persecuted the poor man and the beggar; and the broken in heart, to put him to death.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 18,
      "referenceLabel": "Psalms 108:18",
      "text": "And he loved cursing, and it shall come unto him: and he would not have blessing, and it shall be far from him. And he put on cursing, like a garment: and it went in like water into his entrails, and like oil in his bones.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 19,
      "referenceLabel": "Psalms 108:19",
      "text": "May it be unto him like a garment which covereth him; and like a girdle with which he is girded continually.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 20,
      "referenceLabel": "Psalms 108:20",
      "text": "This is the work of them who detract me before the Lord; and who speak evils against my soul.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 21,
      "referenceLabel": "Psalms 108:21",
      "text": "But thou, O Lord, do with me for thy name's sake: because thy mercy is sweet. Do thou deliver me,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 22,
      "referenceLabel": "Psalms 108:22",
      "text": "For I am poor and needy, and my heart is troubled within me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 23,
      "referenceLabel": "Psalms 108:23",
      "text": "I am taken away like the shadow when it declineth: and I am shaken off as locusts.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.24",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 24,
      "referenceLabel": "Psalms 108:24",
      "text": "My knees are weakened through fasting: and my flesh is changed for oil.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.25",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 25,
      "referenceLabel": "Psalms 108:25",
      "text": "And I am become a reproach to them: they saw me and they shaked their heads.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.26",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 26,
      "referenceLabel": "Psalms 108:26",
      "text": "Help me, O Lord my God; save me; according to thy mercy.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.27",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 27,
      "referenceLabel": "Psalms 108:27",
      "text": "And let them know that this is thy hand: and that thou, O Lord, hast done it.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.28",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 28,
      "referenceLabel": "Psalms 108:28",
      "text": "They will curse and thou wilt bless: let them that rise up against me be confounded: but thy servant shall rejoice.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.29",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 29,
      "referenceLabel": "Psalms 108:29",
      "text": "Let them that detract me be clothed with shame: and let them be covered with their confusion as with a double cloak.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.30",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 30,
      "referenceLabel": "Psalms 108:30",
      "text": "I will give great thanks to the Lord with my mouth: and in the midst of many I will praise him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.108.31",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 31,
      "referenceLabel": "Psalms 108:31",
      "text": "Because he hath stood at the right hand of the poor, to save my soul from persecutors.",
      "paragraphStart": false
    }
  ]
}
