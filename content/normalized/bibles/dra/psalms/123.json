{
  "chapter": {
    "id": "dra:psalms.123",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 123,
    "referenceLabel": "Psalms 123",
    "summary": "Source text for Psalms 123 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.123.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 1,
      "referenceLabel": "Psalms 123:1",
      "text": "A gradual canticle. If it had not been that the Lord was with us, let Israel now say:",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.123.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 2,
      "referenceLabel": "Psalms 123:2",
      "text": "If it had not been that the Lord was with us, When men rose up against us,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.123.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 3,
      "referenceLabel": "Psalms 123:3",
      "text": "Perhaps they had swallowed us up alive. When their fury was enkindled against us,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.123.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 4,
      "referenceLabel": "Psalms 123:4",
      "text": "Perhaps the waters had swallowed us up.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.123.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 5,
      "referenceLabel": "Psalms 123:5",
      "text": "Our soul hath passed through a torrent: perhaps our soul had passed through a water insupportable.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.123.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 6,
      "referenceLabel": "Psalms 123:6",
      "text": "Blessed be the Lord, who hath not given us to be a prey to their teeth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.123.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 7,
      "referenceLabel": "Psalms 123:7",
      "text": "Our soul hath been delivered as a sparrow out of the snare of the fowlers. The snare is broken, and we are delivered.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.123.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 8,
      "referenceLabel": "Psalms 123:8",
      "text": "Our help is in the name of the Lord, who made heaven and earth.",
      "paragraphStart": false
    }
  ]
}
