{
  "chapter": {
    "id": "dra:psalms.125",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 125,
    "referenceLabel": "Psalms 125",
    "summary": "Source text for Psalms 125 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.125.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 1,
      "referenceLabel": "Psalms 125:1",
      "text": "A gradual canticle. When the Lord brought back the captivity of Sion, we became like men comforted.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.125.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 2,
      "referenceLabel": "Psalms 125:2",
      "text": "Then was our mouth filled with gladness; and our tongue with joy. Then shall they say among the Gentiles: The Lord hath done great things for them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.125.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 3,
      "referenceLabel": "Psalms 125:3",
      "text": "The Lord hath done great things for us: we are become joyful.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.125.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 4,
      "referenceLabel": "Psalms 125:4",
      "text": "Turn again our captivity, O Lord, as a stream in the south.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.125.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 5,
      "referenceLabel": "Psalms 125:5",
      "text": "They that sow in tears shall reap in joy.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.125.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 6,
      "referenceLabel": "Psalms 125:6",
      "text": "Going they went and wept, casting their seeds.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.125.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 7,
      "referenceLabel": "Psalms 125:7",
      "text": "But coming they shall come with joyfulness, carrying their sheaves.",
      "paragraphStart": false
    }
  ]
}
