{
  "chapter": {
    "id": "dra:psalms.33",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 33,
    "referenceLabel": "Psalms 33",
    "summary": "Source text for Psalms 33 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.33.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 1,
      "referenceLabel": "Psalms 33:1",
      "text": "For David, when he changed his countenance before Achimelech, who dismissed him, and he went his way.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.33.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 2,
      "referenceLabel": "Psalms 33:2",
      "text": "I will bless the Lord at all times, his praise shall be always in my mouth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 3,
      "referenceLabel": "Psalms 33:3",
      "text": "In the Lord shall my soul be praised: let the meek hear and rejoice.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 4,
      "referenceLabel": "Psalms 33:4",
      "text": "O magnify the Lord with me; and let us extol his name together.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 5,
      "referenceLabel": "Psalms 33:5",
      "text": "I sought the Lord, and he heard me; and he delivered me from all my troubles.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 6,
      "referenceLabel": "Psalms 33:6",
      "text": "Come ye to him and be enlightened: and your faces shall not be confounded.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 7,
      "referenceLabel": "Psalms 33:7",
      "text": "This poor man cried, and the Lord heard him: and saved him out of all his troubles.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 8,
      "referenceLabel": "Psalms 33:8",
      "text": "The angel of the Lord shall encamp round about them that fear him: and shall deliver them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 9,
      "referenceLabel": "Psalms 33:9",
      "text": "O taste, and see that the Lord is sweet: blessed is the man that hopeth in him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 10,
      "referenceLabel": "Psalms 33:10",
      "text": "Fear the Lord, all ye his saints: for there is no want to them that fear him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 11,
      "referenceLabel": "Psalms 33:11",
      "text": "The rich have wanted, and have suffered hunger: but they that seek the Lord shall not be deprived of any good.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 12,
      "referenceLabel": "Psalms 33:12",
      "text": "Come, children, hearken to me: I will teach you the fear of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 13,
      "referenceLabel": "Psalms 33:13",
      "text": "Who is the man that desireth life: who liveth to see good days?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 14,
      "referenceLabel": "Psalms 33:14",
      "text": "Keep thy tongue from evil, and thy lips from speaking guile.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 15,
      "referenceLabel": "Psalms 33:15",
      "text": "Turn away from evil and do good: seek after peace and pursue it.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 16,
      "referenceLabel": "Psalms 33:16",
      "text": "The eyes of the Lord are upon the just: and his ears unto their prayers.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 17,
      "referenceLabel": "Psalms 33:17",
      "text": "But the countenance of the Lord is against them that do evil things: to cut off the remembrance of them from the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 18,
      "referenceLabel": "Psalms 33:18",
      "text": "The just cried, and the Lord heard them: and delivered them out of all their troubles.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 19,
      "referenceLabel": "Psalms 33:19",
      "text": "The Lord is nigh unto them that are of a contrite heart: and he will save the humble of spirit.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 20,
      "referenceLabel": "Psalms 33:20",
      "text": "Many are the afflictions of the just; but out of them all will the Lord deliver them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 21,
      "referenceLabel": "Psalms 33:21",
      "text": "The Lord keepeth all their bones, not one of them shall be broken.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 22,
      "referenceLabel": "Psalms 33:22",
      "text": "The death of the wicked is very evil: and they that hate the just shall be guilty.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.33.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 23,
      "referenceLabel": "Psalms 33:23",
      "text": "The Lord will redeem the souls of his servants: and none of them that trust in him shall offend.",
      "paragraphStart": false
    }
  ]
}
