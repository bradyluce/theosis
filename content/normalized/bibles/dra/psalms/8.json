{
  "chapter": {
    "id": "dra:psalms.8",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 8,
    "referenceLabel": "Psalms 8",
    "summary": "Source text for Psalms 8 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.8.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Psalms 8:1",
      "text": "Unto the end, for the presses: a psalm for David.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.8.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Psalms 8:2",
      "text": "O Lord, our Lord, how admirable is thy name in the whole earth! For thy magnificence is elevated above the heavens.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.8.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Psalms 8:3",
      "text": "Out of the mouth of infants and of sucklings thou hast perfected praise, because of thy enemies, that thou mayst destroy the enemy and the avenger.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.8.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Psalms 8:4",
      "text": "For I will behold thy heavens, the works of thy fingers: the moon and the stars which thou hast founded.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.8.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Psalms 8:5",
      "text": "What is man, that thou art mindful of him? or the son of man, that thou visitest him?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.8.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Psalms 8:6",
      "text": "Thou hast made him a little less than the angels, thou hast crowned him with glory and honour:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.8.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Psalms 8:7",
      "text": "And hast set him over the works of thy hands.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.8.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Psalms 8:8",
      "text": "Thou hast subjected all things under his feet, all sheep and oxen: moreover, the beasts also of the fields.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.8.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Psalms 8:9",
      "text": "The birds of the air, and the fishes of the sea, that pass through the paths of the sea.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.8.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Psalms 8:10",
      "text": "O Lord, our Lord, how admirable is thy name in the whole earth!",
      "paragraphStart": false
    }
  ]
}
