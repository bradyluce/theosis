{
  "chapter": {
    "id": "dra:psalms.23",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 23,
    "referenceLabel": "Psalms 23",
    "summary": "Source text for Psalms 23 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.23.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Psalms 23:1",
      "text": "On the first day of the week, a psalm for David. The earth is the Lord's and the fulness thereof: the world, and all they that dwell therein.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.23.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Psalms 23:2",
      "text": "For he hath founded it upon the seas; and hath prepared it upon the rivers.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.23.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Psalms 23:3",
      "text": "Who shall ascend into the mountain of the Lord: or who shall stand in his holy place?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.23.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Psalms 23:4",
      "text": "The innocent in hands, and clean of heart, who hath not taken his soul in vain, nor sworn deceitfully to his neighbour.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.23.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Psalms 23:5",
      "text": "He shall receive a blessing from the Lord, and mercy from God his Saviour.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.23.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Psalms 23:6",
      "text": "This is the generation of them that seek him, of them that seek the face of the God of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.23.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Psalms 23:7",
      "text": "Lift up your gates, O ye princes, and be ye lifted up, O eternal gates: and the King of Glory shall enter in.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.23.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Psalms 23:8",
      "text": "Who is this King of Glory? the Lord who is strong and mighty: the Lord mighty in battle.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.23.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Psalms 23:9",
      "text": "Lift up your gates, O ye princes, and be ye lifted up, O eternal gates: and the King of Glory shall enter in.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.23.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Psalms 23:10",
      "text": "Who is this King of Glory? the Lord of hosts, he is the King of Glory.",
      "paragraphStart": false
    }
  ]
}
