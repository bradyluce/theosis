{
  "chapter": {
    "id": "dra:psalms.135",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 135,
    "referenceLabel": "Psalms 135",
    "summary": "Source text for Psalms 135 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.135.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 1,
      "referenceLabel": "Psalms 135:1",
      "text": "Alleluia. Praise the Lord, for he is good: for his mercy endureth for ever.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.135.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 2,
      "referenceLabel": "Psalms 135:2",
      "text": "Praise ye the God of gods: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 3,
      "referenceLabel": "Psalms 135:3",
      "text": "Praise ye the Lord of lords: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 4,
      "referenceLabel": "Psalms 135:4",
      "text": "Who alone doth great wonders: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 5,
      "referenceLabel": "Psalms 135:5",
      "text": "Who made the heavens in understanding: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 6,
      "referenceLabel": "Psalms 135:6",
      "text": "Who established the earth above the waters: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 7,
      "referenceLabel": "Psalms 135:7",
      "text": "Who made the great lights: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 8,
      "referenceLabel": "Psalms 135:8",
      "text": "The sun to rule the day: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 9,
      "referenceLabel": "Psalms 135:9",
      "text": "The moon and the stars to rule the night: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 10,
      "referenceLabel": "Psalms 135:10",
      "text": "Who smote Egypt with their firstborn: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 11,
      "referenceLabel": "Psalms 135:11",
      "text": "Who brought out Israel from among them: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 12,
      "referenceLabel": "Psalms 135:12",
      "text": "With a mighty hand and with a stretched out arm: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 13,
      "referenceLabel": "Psalms 135:13",
      "text": "Who divided the Red Sea into parts: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 14,
      "referenceLabel": "Psalms 135:14",
      "text": "And brought out Israel through the midst thereof: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 15,
      "referenceLabel": "Psalms 135:15",
      "text": "And overthrew Pharao and his host in the Red Sea: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 16,
      "referenceLabel": "Psalms 135:16",
      "text": "Who led his people through the desert: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 17,
      "referenceLabel": "Psalms 135:17",
      "text": "Who smote great kings: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 18,
      "referenceLabel": "Psalms 135:18",
      "text": "And slew strong kings: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 19,
      "referenceLabel": "Psalms 135:19",
      "text": "Sehon king of the Amorrhites: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 20,
      "referenceLabel": "Psalms 135:20",
      "text": "And Og king of Basan: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 21,
      "referenceLabel": "Psalms 135:21",
      "text": "And he gave their land for an inheritance: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 22,
      "referenceLabel": "Psalms 135:22",
      "text": "For an inheritance to his servant Israel: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 23,
      "referenceLabel": "Psalms 135:23",
      "text": "For he was mindful of us in our affliction: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.24",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 24,
      "referenceLabel": "Psalms 135:24",
      "text": "And he redeemed us from our enemies: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.25",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 25,
      "referenceLabel": "Psalms 135:25",
      "text": "Who giveth food to all flesh: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.26",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 26,
      "referenceLabel": "Psalms 135:26",
      "text": "Give glory to the God of heaven: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.135.27",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 27,
      "referenceLabel": "Psalms 135:27",
      "text": "Give glory to the Lord of lords: for his mercy endureth for ever.",
      "paragraphStart": false
    }
  ]
}
