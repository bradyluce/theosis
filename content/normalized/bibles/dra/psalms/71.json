{
  "chapter": {
    "id": "dra:psalms.71",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 71,
    "referenceLabel": "Psalms 71",
    "summary": "Source text for Psalms 71 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.71.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 1,
      "referenceLabel": "Psalms 71:1",
      "text": "A psalm on Solomon.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.71.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 2,
      "referenceLabel": "Psalms 71:2",
      "text": "Give to the king thy judgment, O God, and to the king's son thy justice: To judge thy people with justice, and thy poor with judgment.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.71.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 3,
      "referenceLabel": "Psalms 71:3",
      "text": "Let the mountains receive peace for the people: and the hills justice.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.71.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 4,
      "referenceLabel": "Psalms 71:4",
      "text": "He shall judge the poor of the people, and he shall save the children of the poor: and he shall humble the oppressor.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.71.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 5,
      "referenceLabel": "Psalms 71:5",
      "text": "And he shall continue with the sun and before the moon, throughout all generations.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.71.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 6,
      "referenceLabel": "Psalms 71:6",
      "text": "He shall come down like rain upon the fleece; and as showers falling gently upon the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.71.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 7,
      "referenceLabel": "Psalms 71:7",
      "text": "In his days shall justice spring up, and abundance of peace, till the moon be taken away.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.71.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 8,
      "referenceLabel": "Psalms 71:8",
      "text": "And he shall rule from sea to sea, and from the river unto the ends of the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.71.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 9,
      "referenceLabel": "Psalms 71:9",
      "text": "Before him the Ethiopians shall fall down: and his enemies shall lick the ground.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.71.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 10,
      "referenceLabel": "Psalms 71:10",
      "text": "The kings of Tharsis and the islands shall offer presents: the kings of the Arabians and of Saba shall bring gifts:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.71.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 11,
      "referenceLabel": "Psalms 71:11",
      "text": "And all kings of the earth shall adore him: all nations shall serve him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.71.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 12,
      "referenceLabel": "Psalms 71:12",
      "text": "For he shall deliver the poor from the mighty: and the needy that had no helper.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.71.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 13,
      "referenceLabel": "Psalms 71:13",
      "text": "He shall spare the poor and needy: and he shall save the souls of the poor.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.71.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 14,
      "referenceLabel": "Psalms 71:14",
      "text": "He shall redeem their souls from usuries and iniquity: and their names shall be honourable in his sight.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.71.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 15,
      "referenceLabel": "Psalms 71:15",
      "text": "And he shall live, and to him shall be given of the gold of Arabia, for him they shall always adore: they shall bless him all the day.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.71.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 16,
      "referenceLabel": "Psalms 71:16",
      "text": "And there shall be a firmament on the earth on the tops of mountains, above Libanus shall the fruit thereof be exalted: and they of the city shall flourish like the grass of the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.71.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 17,
      "referenceLabel": "Psalms 71:17",
      "text": "Let his name be blessed for evermore: his name continueth before the sun. And in him shall all the tribes of the earth be blessed: all nations shall magnify him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.71.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 18,
      "referenceLabel": "Psalms 71:18",
      "text": "Blessed be the Lord, the God of Israel, who alone doth wonderful things.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.71.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 19,
      "referenceLabel": "Psalms 71:19",
      "text": "And blessed be the name of his majesty for ever: and the whole earth shall be filled with his majesty. So be it. So be it.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.71.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 20,
      "referenceLabel": "Psalms 71:20",
      "text": "The praises of David, the son of Jesse, are ended.",
      "paragraphStart": false
    }
  ]
}
