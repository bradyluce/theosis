{
  "chapter": {
    "id": "dra:psalms.53",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 53,
    "referenceLabel": "Psalms 53",
    "summary": "Source text for Psalms 53 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.53.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 1,
      "referenceLabel": "Psalms 53:1",
      "text": "Unto the end, in verses, understanding for David.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.53.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 2,
      "referenceLabel": "Psalms 53:2",
      "text": "When the men of Ziph had come and said to Saul: Is not David hidden with us?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.53.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 3,
      "referenceLabel": "Psalms 53:3",
      "text": "Save me, O God, by thy name, and judge me in thy strength.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.53.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 4,
      "referenceLabel": "Psalms 53:4",
      "text": "O God, hear my prayer: give ear to the words of my mouth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.53.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 5,
      "referenceLabel": "Psalms 53:5",
      "text": "For strangers have risen up against me; and the mighty have sought after my soul: and they have not set God before their eyes.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.53.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 6,
      "referenceLabel": "Psalms 53:6",
      "text": "For behold God is my helper: and the Lord is the protector of my soul.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.53.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 7,
      "referenceLabel": "Psalms 53:7",
      "text": "Turn back the evils upon my enemies; and cut them off in thy truth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.53.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 8,
      "referenceLabel": "Psalms 53:8",
      "text": "I will freely sacrifice to thee, and will give praise, O God, to thy name: because it is good:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.53.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 9,
      "referenceLabel": "Psalms 53:9",
      "text": "For thou hast delivered me out of all trouble: and my eye hath looked down upon my enemies.",
      "paragraphStart": false
    }
  ]
}
