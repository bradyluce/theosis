{
  "chapter": {
    "id": "dra:psalms.45",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 45,
    "referenceLabel": "Psalms 45",
    "summary": "Source text for Psalms 45 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.45.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 1,
      "referenceLabel": "Psalms 45:1",
      "text": "Unto the end, for the sons of Core, for the hidden.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.45.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 2,
      "referenceLabel": "Psalms 45:2",
      "text": "Our God is our refuge and strength: a helper in troubles, which have found us exceedingly.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.45.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 3,
      "referenceLabel": "Psalms 45:3",
      "text": "Therefore we will not fear, when the earth shall be troubled; and the mountains shall be removed into the heart of the sea.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.45.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 4,
      "referenceLabel": "Psalms 45:4",
      "text": "Their waters roared and were troubled: the mountains were troubled with his strength.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.45.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 5,
      "referenceLabel": "Psalms 45:5",
      "text": "The stream of the river maketh the city of God joyful: the most High hath sanctified his own tabernacle.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.45.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 6,
      "referenceLabel": "Psalms 45:6",
      "text": "God is in the midst thereof, it shall not be moved: God will help it in the morning early.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.45.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 7,
      "referenceLabel": "Psalms 45:7",
      "text": "Nations were troubled, and kingdoms were bowed down: he uttered his voice, the earth trembled.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.45.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 8,
      "referenceLabel": "Psalms 45:8",
      "text": "The Lord of armies is with us: the God of Jacob is our protector.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.45.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 9,
      "referenceLabel": "Psalms 45:9",
      "text": "Come and behold ye the works of the Lord: what wonders he hath done upon earth,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.45.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 10,
      "referenceLabel": "Psalms 45:10",
      "text": "Making wars to cease even to the end of the earth. He shall destroy the bow, and break the weapons: and the shield he shall burn in the fire.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.45.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 11,
      "referenceLabel": "Psalms 45:11",
      "text": "Be still and see that I am God; I will be exalted among the nations, and I will be exalted in the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.45.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 12,
      "referenceLabel": "Psalms 45:12",
      "text": "The Lord of armies is with us: the God of Jacob is our protector.",
      "paragraphStart": false
    }
  ]
}
