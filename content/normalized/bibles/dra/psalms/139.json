{
  "chapter": {
    "id": "dra:psalms.139",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 139,
    "referenceLabel": "Psalms 139",
    "summary": "Source text for Psalms 139 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.139.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 1,
      "referenceLabel": "Psalms 139:1",
      "text": "Unto the end, a psalm of David.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.139.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 2,
      "referenceLabel": "Psalms 139:2",
      "text": "Deliver me, O Lord, from the evil man: rescue me from the unjust man.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.139.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 3,
      "referenceLabel": "Psalms 139:3",
      "text": "Who have devised iniquities in their hearts: all the day long they designed battles.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.139.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 4,
      "referenceLabel": "Psalms 139:4",
      "text": "They have sharpened their tongues like a serpent: the venom of asps is under their lips.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.139.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 5,
      "referenceLabel": "Psalms 139:5",
      "text": "Keep me, O Lord, from the hand of the wicked: and from unjust men deliver me. Who have proposed to supplant my steps:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.139.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 6,
      "referenceLabel": "Psalms 139:6",
      "text": "The proud have hidden a net for me. And they have stretched out cords for a snare: they have laid for me a stumblingblock by the wayside.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.139.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 7,
      "referenceLabel": "Psalms 139:7",
      "text": "I said to the Lord: Thou art my God: hear, O Lord, the voice of my supplication.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.139.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 8,
      "referenceLabel": "Psalms 139:8",
      "text": "O Lord, Lord, the strength of my salvation: thou hast overshadowed my head in the day of battle.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.139.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 9,
      "referenceLabel": "Psalms 139:9",
      "text": "Give me not up, O Lord, from my desire to the wicked: they have plotted against me; do not thou forsake me, lest they should triumph.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.139.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 10,
      "referenceLabel": "Psalms 139:10",
      "text": "The head of them compassing me about: the labour of their lips shall overwhelm them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.139.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 11,
      "referenceLabel": "Psalms 139:11",
      "text": "Burning coals shall fall upon them; thou wilt cast them down into the fire: in miseries they shall not be able to stand.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.139.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 12,
      "referenceLabel": "Psalms 139:12",
      "text": "A man full of tongue shall not be established in the earth: evil shall catch the unjust man unto destruction.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.139.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 13,
      "referenceLabel": "Psalms 139:13",
      "text": "I know that the Lord will do justice to the needy, and will revenge the poor.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.139.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 14,
      "referenceLabel": "Psalms 139:14",
      "text": "But as for the just, they shall give glory to thy name: and the upright shall dwell with thy countenance.",
      "paragraphStart": false
    }
  ]
}
