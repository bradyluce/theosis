{
  "chapter": {
    "id": "dra:psalms.94",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 94,
    "referenceLabel": "Psalms 94",
    "summary": "Source text for Psalms 94 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.94.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 1,
      "referenceLabel": "Psalms 94:1",
      "text": "Come let us praise the Lord with joy: let us joyfully sing to God our saviour.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.94.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 2,
      "referenceLabel": "Psalms 94:2",
      "text": "Let us come before his presence with thanksgiving; and make a joyful noise to him with psalms.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.94.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 3,
      "referenceLabel": "Psalms 94:3",
      "text": "For the Lord is a great God, and a great King above all gods.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.94.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 4,
      "referenceLabel": "Psalms 94:4",
      "text": "For in his hand are all the ends of the earth: and the heights of the mountains are his.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.94.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 5,
      "referenceLabel": "Psalms 94:5",
      "text": "For the sea is his, and he made it: and his hands formed the dry land.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.94.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 6,
      "referenceLabel": "Psalms 94:6",
      "text": "Come let us adore and fall down: and weep before the Lord that made us.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.94.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 7,
      "referenceLabel": "Psalms 94:7",
      "text": "For he is the Lord our God: and we are the people of his pasture and the sheep of his hand.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.94.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 8,
      "referenceLabel": "Psalms 94:8",
      "text": "To day if you shall hear his voice, harden not your hearts:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.94.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 9,
      "referenceLabel": "Psalms 94:9",
      "text": "As in the provocation, according to the day of temptation in the wilderness: where your fathers tempted me, they proved me, and saw my works.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.94.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 10,
      "referenceLabel": "Psalms 94:10",
      "text": "Forty years long was I offended with that generation, and I said: These always err in heart.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.94.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 11,
      "referenceLabel": "Psalms 94:11",
      "text": "And these men have not known my ways: so I swore in my wrath that they shall not enter into my rest.",
      "paragraphStart": false
    }
  ]
}
