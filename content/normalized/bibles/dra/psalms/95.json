{
  "chapter": {
    "id": "dra:psalms.95",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 95,
    "referenceLabel": "Psalms 95",
    "summary": "Source text for Psalms 95 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.95.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 1,
      "referenceLabel": "Psalms 95:1",
      "text": "A canticle for David himself, when the house was built after the captivity. Sing ye to the Lord a new canticle: sing to the Lord, all the earth.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.95.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 2,
      "referenceLabel": "Psalms 95:2",
      "text": "Sing ye to the Lord and bless his name: shew forth his salvation from day to day.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.95.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 3,
      "referenceLabel": "Psalms 95:3",
      "text": "Declare his glory among the Gentiles: his wonders among all people.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.95.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 4,
      "referenceLabel": "Psalms 95:4",
      "text": "For the Lord is great, and exceedingly to be praised: he is to be feared above all gods.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.95.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 5,
      "referenceLabel": "Psalms 95:5",
      "text": "For all the gods of the Gentiles are devils: but the Lord made the heavens.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.95.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 6,
      "referenceLabel": "Psalms 95:6",
      "text": "Praise and beauty are before him: holiness and majesty in his sanctuary.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.95.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 7,
      "referenceLabel": "Psalms 95:7",
      "text": "Bring ye to the Lord, O ye kindreds of the Gentiles, bring ye to the Lord glory and honour:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.95.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 8,
      "referenceLabel": "Psalms 95:8",
      "text": "Bring to the Lord glory unto his name. Bring up sacrifices, and come into his courts:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.95.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 9,
      "referenceLabel": "Psalms 95:9",
      "text": "Adore ye the Lord in his holy court. Let all the earth be moved at his presence.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.95.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 10,
      "referenceLabel": "Psalms 95:10",
      "text": "Say ye among the Gentiles, the Lord hath reigned. For he hath corrected the world, which shall not be moved: he will judge the people with justice.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.95.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 11,
      "referenceLabel": "Psalms 95:11",
      "text": "Let the heavens rejoice, and let the earth be glad, let the sea be moved, and the fulness thereof:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.95.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 12,
      "referenceLabel": "Psalms 95:12",
      "text": "The fields and all things that are in them shall be joyful. Then shall all the trees of the woods rejoice",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.95.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 13,
      "referenceLabel": "Psalms 95:13",
      "text": "before the face of the Lord, because he cometh: because he cometh to judge the earth. He shall judge the world with justice, and the people with his truth.",
      "paragraphStart": false
    }
  ]
}
