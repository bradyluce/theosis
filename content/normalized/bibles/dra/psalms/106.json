{
  "chapter": {
    "id": "dra:psalms.106",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 106,
    "referenceLabel": "Psalms 106",
    "summary": "Source text for Psalms 106 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.106.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 1,
      "referenceLabel": "Psalms 106:1",
      "text": "Give glory to the Lord, for he is good: for his mercy endureth for ever.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.106.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 2,
      "referenceLabel": "Psalms 106:2",
      "text": "Let them say so that have been redeemed by the Lord, whom he hath redeemed from the hand of the enemy: and gathered out of the countries.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 3,
      "referenceLabel": "Psalms 106:3",
      "text": "From the rising and from the setting of the sun, from the north and from the sea.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 4,
      "referenceLabel": "Psalms 106:4",
      "text": "They wandered in a wilderness, in a place without water: they found not the way of a city for their habitation.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 5,
      "referenceLabel": "Psalms 106:5",
      "text": "They were hungry and thirsty: their soul fainted in them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 6,
      "referenceLabel": "Psalms 106:6",
      "text": "And they cried to the Lord in their tribulation: and he delivered them out of their distresses.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 7,
      "referenceLabel": "Psalms 106:7",
      "text": "And he led them into the right way, that they might go to a city of habitation.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 8,
      "referenceLabel": "Psalms 106:8",
      "text": "Let the mercies of the Lord give glory to him: and his wonderful works to the children of men.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 9,
      "referenceLabel": "Psalms 106:9",
      "text": "For he hath satisfied the empty soul, and hath filled the hungry soul with good things.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 10,
      "referenceLabel": "Psalms 106:10",
      "text": "Such as sat in darkness and in the shadow of death: bound in want and in iron.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 11,
      "referenceLabel": "Psalms 106:11",
      "text": "Because they had exasperated the words of God: and provoked the counsel of the most High:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 12,
      "referenceLabel": "Psalms 106:12",
      "text": "And their heart was humbled with labours: they were weakened, and there was none to help them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 13,
      "referenceLabel": "Psalms 106:13",
      "text": "Then they cried to the Lord in their affliction: and he delivered them out of their distresses.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 14,
      "referenceLabel": "Psalms 106:14",
      "text": "And he brought them out of darkness, and the shadow of death; and broke their bonds in sunder.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 15,
      "referenceLabel": "Psalms 106:15",
      "text": "Let the mercies of the Lord give glory to him, and his wonderful works to the children of men.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 16,
      "referenceLabel": "Psalms 106:16",
      "text": "Because he hath broken gates of brass, and burst iron bars.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 17,
      "referenceLabel": "Psalms 106:17",
      "text": "He took them out of the way of their iniquity: for they were brought low for their injustices.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 18,
      "referenceLabel": "Psalms 106:18",
      "text": "Their soul abhorred all manner of meat: and they drew nigh even to the gates of death.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 19,
      "referenceLabel": "Psalms 106:19",
      "text": "And they cried to the Lord in their affliction: and he delivered them out of their distresses.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 20,
      "referenceLabel": "Psalms 106:20",
      "text": "He sent his word, and healed them: and delivered them from their destructions.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 21,
      "referenceLabel": "Psalms 106:21",
      "text": "Let the mercies of the Lord give glory to him: and his wonderful works to the children of men.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 22,
      "referenceLabel": "Psalms 106:22",
      "text": "And let them sacrifice the sacrifice of praise: and declare his works with joy.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 23,
      "referenceLabel": "Psalms 106:23",
      "text": "They that go down to the sea in ships, doing business in the great waters:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.24",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 24,
      "referenceLabel": "Psalms 106:24",
      "text": "These have seen the works of the Lord, and his wonders in the deep.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.25",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 25,
      "referenceLabel": "Psalms 106:25",
      "text": "He said the word, and there arose a storm of wind: and the waves thereof were lifted up.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.26",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 26,
      "referenceLabel": "Psalms 106:26",
      "text": "They mount up to the heavens, and they go down to the depths: their soul pined away with evils.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.27",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 27,
      "referenceLabel": "Psalms 106:27",
      "text": "They were troubled, and reeled like a drunken man; and all their wisdom was swallowed up.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.28",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 28,
      "referenceLabel": "Psalms 106:28",
      "text": "And they cried to the Lord in their affliction: and he brought them out of their distresses.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.29",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 29,
      "referenceLabel": "Psalms 106:29",
      "text": "And he turned the storm into a breeze: and its waves were still.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.30",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 30,
      "referenceLabel": "Psalms 106:30",
      "text": "And they rejoiced because they were still: and he brought them to the haven which they wished for.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.31",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 31,
      "referenceLabel": "Psalms 106:31",
      "text": "Let the mercies of the Lord give glory to him, and his wonderful works to the children of men.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.32",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 32,
      "referenceLabel": "Psalms 106:32",
      "text": "And let them exalt him in the church of the people: and praise him in the chair of the ancients.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.33",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 33,
      "referenceLabel": "Psalms 106:33",
      "text": "He hath turned rivers into a wilderness: and the sources of waters into dry ground:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.34",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 34,
      "referenceLabel": "Psalms 106:34",
      "text": "A fruitful land into barrenness, for the wickedness of them that dwell therein.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.35",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 35,
      "referenceLabel": "Psalms 106:35",
      "text": "He hath turned a wilderness into pools of waters, and a dry land into water springs.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.36",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 36,
      "referenceLabel": "Psalms 106:36",
      "text": "And hath placed there the hungry; and they made a city for their habitation.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.37",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 37,
      "referenceLabel": "Psalms 106:37",
      "text": "And they sowed fields, and planted vineyards: and they yielded fruit of birth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.38",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 38,
      "referenceLabel": "Psalms 106:38",
      "text": "And he blessed them, and they were multiplied exceedingly: and their cattle he suffered not to decrease.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.39",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 39,
      "referenceLabel": "Psalms 106:39",
      "text": "Then they were brought to be few: and they were afflicted through the trouble of evils and sorrow.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.40",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 40,
      "referenceLabel": "Psalms 106:40",
      "text": "Contempt was poured forth upon their princes: and he caused them to wander where there was no passing, and out of the way.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.41",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 41,
      "referenceLabel": "Psalms 106:41",
      "text": "And he helped the poor out of poverty: and made him families like a flock of sheep.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.42",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 42,
      "referenceLabel": "Psalms 106:42",
      "text": "The just shall see, and shall rejoice, and all iniquity shall stop her mouth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.106.43",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 43,
      "referenceLabel": "Psalms 106:43",
      "text": "Who is wise, and will keep these things; and will understand the mercies of the Lord?",
      "paragraphStart": false
    }
  ]
}
