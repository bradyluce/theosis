{
  "chapter": {
    "id": "dra:psalms.4",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 4,
    "referenceLabel": "Psalms 4",
    "summary": "Source text for Psalms 4 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.4.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Psalms 4:1",
      "text": "Unto the end, in verses. A psalm for David.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.4.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Psalms 4:2",
      "text": "When I called upon him, the God of my justice heard me: when I was in distress, thou hast enlarged me. Have mercy on me: and hear my prayer.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.4.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Psalms 4:3",
      "text": "O ye sons of men, how long will you be dull of heart? why do you love vanity, and seek after lying?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.4.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Psalms 4:4",
      "text": "Know ye also that the Lord hath made his holy one wonderful: the Lord will hear me when I shall cry unto him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.4.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Psalms 4:5",
      "text": "Be ye angry, and sin not: the things you say in your hearts, be sorry for them upon your beds.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.4.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Psalms 4:6",
      "text": "Offer up the sacrifice of justice, and trust in the Lord: many say, Who sheweth us good things?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.4.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Psalms 4:7",
      "text": "The light of thy countenance, O Lord, is signed upon us: thou hast given gladness in my heart.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.4.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Psalms 4:8",
      "text": "By the fruit of their corn, their wine, and oil, they are multiplied:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.4.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Psalms 4:9",
      "text": "In peace in the self same I will sleep, and I will rest:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.4.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Psalms 4:10",
      "text": "For thou, O Lord, singularly hast settled me in hope.",
      "paragraphStart": false
    }
  ]
}
