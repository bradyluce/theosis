{
  "chapter": {
    "id": "dra:psalms.10",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 10,
    "referenceLabel": "Psalms 10",
    "summary": "Source text for Psalms 10 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.10.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Psalms 10:1",
      "text": "Unto the end. A psalm to David.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.10.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Psalms 10:2",
      "text": "In the Lord I put my trust: how then do you say to my soul: Get thee away from hence to the mountain, like a sparrow.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.10.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Psalms 10:3",
      "text": "For, lo, the wicked have bent their bow: they have prepared their arrows in the quiver, to shoot in the dark the upright of heart.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.10.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Psalms 10:4",
      "text": "For they have destroyed the things which thou hast made: but what has the just man done?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.10.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Psalms 10:5",
      "text": "The Lord is in his holy temple, the Lord's throne is in heaven. His eyes look on the poor man: his eyelids examine the sons of men.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.10.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Psalms 10:6",
      "text": "The Lord trieth the just and the wicked: but he that loveth iniquity, hateth his own soul.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.10.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Psalms 10:7",
      "text": "He shall rain snares upon sinners: fire and brimstone, and storms of winds, shall be the portion of their cup.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.10.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Psalms 10:8",
      "text": "For the Lord is just, and hath loved justice: his countenance hath beheld righteousness.",
      "paragraphStart": false
    }
  ]
}
