{
  "chapter": {
    "id": "dra:psalms.54",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 54,
    "referenceLabel": "Psalms 54",
    "summary": "Source text for Psalms 54 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.54.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 1,
      "referenceLabel": "Psalms 54:1",
      "text": "Unto the end, in verses, understanding for David.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.54.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 2,
      "referenceLabel": "Psalms 54:2",
      "text": "Hear, O God, my prayer, and despise not my supplication:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 3,
      "referenceLabel": "Psalms 54:3",
      "text": "Be attentive to me and hear me. I am grieved in my exercise; and am troubled,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 4,
      "referenceLabel": "Psalms 54:4",
      "text": "At the voice of the enemy, and at the tribulation of the sinner. For they have cast iniquities upon me: and in wrath they were troublesome to me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 5,
      "referenceLabel": "Psalms 54:5",
      "text": "My heart is troubled within me: and the fear of death is fallen upon me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 6,
      "referenceLabel": "Psalms 54:6",
      "text": "Fear and trembling are come upon me: and darkness hath covered me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 7,
      "referenceLabel": "Psalms 54:7",
      "text": "And I said: Who will give me wings like a dove, and I will fly and be at rest?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 8,
      "referenceLabel": "Psalms 54:8",
      "text": "Lo, I have gone far off flying away; and I abode in the wilderness.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 9,
      "referenceLabel": "Psalms 54:9",
      "text": "I waited for him that hath saved me from pusillanimity of spirit, and a storm.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 10,
      "referenceLabel": "Psalms 54:10",
      "text": "Cast down, O Lord, and divide their tongues; for I have seen iniquity and contradiction in the city.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 11,
      "referenceLabel": "Psalms 54:11",
      "text": "Day and night shall iniquity surround it upon its walls: and in the midst thereof are labour,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 12,
      "referenceLabel": "Psalms 54:12",
      "text": "And injustice. And usury and deceit have not departed from its streets.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 13,
      "referenceLabel": "Psalms 54:13",
      "text": "For if my enemy had reviled me, I would verily have borne with it. And if he that hated me had spoken great things against me, I would perhaps have hidden my self from him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 14,
      "referenceLabel": "Psalms 54:14",
      "text": "But thou a man of one mind, my guide, and my familiar,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 15,
      "referenceLabel": "Psalms 54:15",
      "text": "Who didst take sweetmeats together with me: in the house of God we walked with consent.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 16,
      "referenceLabel": "Psalms 54:16",
      "text": "Let death come upon them, and let them go down alive into hell. For there is wickedness in their dwellings: in the midst of them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 17,
      "referenceLabel": "Psalms 54:17",
      "text": "But I have cried to God: and the Lord will save me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 18,
      "referenceLabel": "Psalms 54:18",
      "text": "Evening and morning, and at noon I will speak and declare: and he shall hear my voice.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 19,
      "referenceLabel": "Psalms 54:19",
      "text": "He shall redeem my soul in peace from them that draw near to me: for among many they were with me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 20,
      "referenceLabel": "Psalms 54:20",
      "text": "God shall hear, and the Eternal shall humble them. For there is no change with them, and they have not feared God:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 21,
      "referenceLabel": "Psalms 54:21",
      "text": "He hath stretched forth his hand to repay. They have defiled his covenant,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 22,
      "referenceLabel": "Psalms 54:22",
      "text": "They are divided by the wrath of his countenance, and his heart hath drawn near. His words are smoother than oil, and the same are darts.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 23,
      "referenceLabel": "Psalms 54:23",
      "text": "Cast thy care upon the Lord, and he shall sustain thee: he shall not suffer the just to waver for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.54.24",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 24,
      "referenceLabel": "Psalms 54:24",
      "text": "But thou, O God, shalt bring them down into the pit of destruction. Bloody and deceitful men shall not live out half their days; but I will trust in thee, O Lord.",
      "paragraphStart": false
    }
  ]
}
