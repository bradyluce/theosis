{
  "chapter": {
    "id": "dra:psalms.136",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 136,
    "referenceLabel": "Psalms 136",
    "summary": "Source text for Psalms 136 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.136.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 1,
      "referenceLabel": "Psalms 136:1",
      "text": "Upon the rivers of Babylon, there we sat and wept: when we remembered Sion:",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.136.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 2,
      "referenceLabel": "Psalms 136:2",
      "text": "On the willows in the midst thereof we hung up our instruments.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.136.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 3,
      "referenceLabel": "Psalms 136:3",
      "text": "For there they that led us into captivity required of us the words of songs. And they that carried us away, said: Sing ye to us a hymn of the songs of Sion.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.136.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 4,
      "referenceLabel": "Psalms 136:4",
      "text": "How shall we sing the song of the Lord in a strange land?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.136.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 5,
      "referenceLabel": "Psalms 136:5",
      "text": "If I forget thee, O Jerusalem, let my right hand be forgotten.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.136.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 6,
      "referenceLabel": "Psalms 136:6",
      "text": "Let my tongue cleave to my jaws, if I do not remember thee: If I make not Jerusalem the beginning of my joy.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.136.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 7,
      "referenceLabel": "Psalms 136:7",
      "text": "Remember, O Lord, the children of Edom, in the day of Jerusalem: Who say: Rase it, rase it, even to the foundation thereof.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.136.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 8,
      "referenceLabel": "Psalms 136:8",
      "text": "O daughter of Babylon, miserable: blessed shall he be who shall repay thee thy payment which thou hast paid us.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.136.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 9,
      "referenceLabel": "Psalms 136:9",
      "text": "Blessed be he that shall take and dash thy little ones against the rock.",
      "paragraphStart": false
    }
  ]
}
