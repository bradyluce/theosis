{
  "chapter": {
    "id": "dra:psalms.36",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 36,
    "referenceLabel": "Psalms 36",
    "summary": "Source text for Psalms 36 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.36.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 1,
      "referenceLabel": "Psalms 36:1",
      "text": "Be not emulous of evildoers; nor envy them that work iniquity.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.36.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 2,
      "referenceLabel": "Psalms 36:2",
      "text": "For they shall shortly wither away as grass, and as the green herbs shall quickly fall.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 3,
      "referenceLabel": "Psalms 36:3",
      "text": "Trust in the Lord, and do good, and dwell in the land, and thou shalt be fed with its riches.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 4,
      "referenceLabel": "Psalms 36:4",
      "text": "Delight in the Lord, and he will give thee the requests of thy heart.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 5,
      "referenceLabel": "Psalms 36:5",
      "text": "Commit thy way to the Lord, and trust in him, and he will do it.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 6,
      "referenceLabel": "Psalms 36:6",
      "text": "And he will bring forth thy justice as the light, and thy judgment as the noonday.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 7,
      "referenceLabel": "Psalms 36:7",
      "text": "Be subject to the Lord and pray to him. Envy not the man who prospereth in his way; the man who doth unjust things.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 8,
      "referenceLabel": "Psalms 36:8",
      "text": "Cease from anger, and leave rage; have no emulation to do evil.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 9,
      "referenceLabel": "Psalms 36:9",
      "text": "For evildoers shall be cut off: but they that wait upon the Lord, they shall inherit the land.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 10,
      "referenceLabel": "Psalms 36:10",
      "text": "For yet a little while, and the wicked shall not be: and thou shalt seek his place, and shalt not find it.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 11,
      "referenceLabel": "Psalms 36:11",
      "text": "But the meek shall inherit the land, and shall delight in abundance of peace.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 12,
      "referenceLabel": "Psalms 36:12",
      "text": "The sinner shall watch the just man: and shall gnash upon him with his teeth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 13,
      "referenceLabel": "Psalms 36:13",
      "text": "But the Lord shall laugh at him: for he foreseeth that his day shall come.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 14,
      "referenceLabel": "Psalms 36:14",
      "text": "The wicked have drawn out the sword: they have bent their bow. To cast down the poor and needy, to kill the upright of heart.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 15,
      "referenceLabel": "Psalms 36:15",
      "text": "Let their sword enter into their own hearts, and let their bow be broken.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 16,
      "referenceLabel": "Psalms 36:16",
      "text": "Better is a little to the just, than the great riches of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 17,
      "referenceLabel": "Psalms 36:17",
      "text": "For the arms of the wicked shall be broken in pieces; but the Lord strengtheneth the just.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 18,
      "referenceLabel": "Psalms 36:18",
      "text": "The Lord knoweth the days of the undefiled; and their inheritance shall be for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 19,
      "referenceLabel": "Psalms 36:19",
      "text": "They shall not be confounded in the evil time; and in the days of famine they shall be filled:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 20,
      "referenceLabel": "Psalms 36:20",
      "text": "Because the wicked shall perish. And the enemies of the Lord, presently after they shall be honoured and exalted, shall come to nothing and vanish like smoke.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 21,
      "referenceLabel": "Psalms 36:21",
      "text": "The sinner shall borrow, and not pay again; but the just sheweth mercy and shall give.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 22,
      "referenceLabel": "Psalms 36:22",
      "text": "For such as bless him shall inherit the land: but such as curse him shall perish.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 23,
      "referenceLabel": "Psalms 36:23",
      "text": "With the Lord shall the steps of a man be directed, and he shall like well his way.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.24",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 24,
      "referenceLabel": "Psalms 36:24",
      "text": "When he shall fall he shall not be bruised, for the Lord putteth his hand under him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.25",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 25,
      "referenceLabel": "Psalms 36:25",
      "text": "I have been young and now am old; and I have not seen the just forsaken, nor his seed seeking bread.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.26",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 26,
      "referenceLabel": "Psalms 36:26",
      "text": "He sheweth mercy, and lendeth all the day long; and his seed shall be in blessing.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.27",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 27,
      "referenceLabel": "Psalms 36:27",
      "text": "Decline from evil and do good, and dwell for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.28",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 28,
      "referenceLabel": "Psalms 36:28",
      "text": "For the Lord loveth judgment, and will not forsake his saints: they shall be preserved for ever. The unjust shall be punished, and the seed of the wicked shall perish.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.29",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 29,
      "referenceLabel": "Psalms 36:29",
      "text": "But the just shall inherit the land, and shall dwell therein for evermore.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.30",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 30,
      "referenceLabel": "Psalms 36:30",
      "text": "The mouth of the just shall meditate wisdom: and his tongue shall speak judgment.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.31",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 31,
      "referenceLabel": "Psalms 36:31",
      "text": "The law of his God is in his heart, and his steps shall not be supplanted.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.32",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 32,
      "referenceLabel": "Psalms 36:32",
      "text": "The wicked watcheth the just man, and seeketh to put him to death,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.33",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 33,
      "referenceLabel": "Psalms 36:33",
      "text": "But the Lord will not leave him in his hands; nor condemn him when he shall be judged.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.34",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 34,
      "referenceLabel": "Psalms 36:34",
      "text": "Expect the Lord and keep his way: and he will exalt thee to inherit the land: when the sinners shall perish thou shalt see.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.35",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 35,
      "referenceLabel": "Psalms 36:35",
      "text": "I have seen the wicked highly exalted, and lifted up like the cedars of Libanus.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.36",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 36,
      "referenceLabel": "Psalms 36:36",
      "text": "And I passed by, and lo, he was not: and I sought him and his place was not found.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.37",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 37,
      "referenceLabel": "Psalms 36:37",
      "text": "Keep innocence, and behold justice: for there are remnants for the peaceable man.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.38",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 38,
      "referenceLabel": "Psalms 36:38",
      "text": "But the unjust shall be destroyed together: the remnants of the wicked shall perish.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.39",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 39,
      "referenceLabel": "Psalms 36:39",
      "text": "But the salvation of the just is from the Lord, and he is their protector in the time of trouble.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.36.40",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 40,
      "referenceLabel": "Psalms 36:40",
      "text": "And the Lord will help them and deliver them: and he will rescue them from the wicked, and save them because they have hoped in him.",
      "paragraphStart": false
    }
  ]
}
