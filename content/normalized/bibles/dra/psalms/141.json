{
  "chapter": {
    "id": "dra:psalms.141",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 141,
    "referenceLabel": "Psalms 141",
    "summary": "Source text for Psalms 141 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.141.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 1,
      "referenceLabel": "Psalms 141:1",
      "text": "Of understanding for David, A prayer when he was in the cave.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.141.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 2,
      "referenceLabel": "Psalms 141:2",
      "text": "I cried to the Lord with my voice: with my voice I made supplication to the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.141.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 3,
      "referenceLabel": "Psalms 141:3",
      "text": "In his sight I pour out my prayer, and before him I declare my trouble:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.141.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 4,
      "referenceLabel": "Psalms 141:4",
      "text": "When my spirit failed me, then thou knewest my paths. In this way wherein I walked, they have hidden a snare for me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.141.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 5,
      "referenceLabel": "Psalms 141:5",
      "text": "I looked on my right hand, and beheld, and there was no one that would know me. Flight hath failed me: and there is no one that hath regard to my soul.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.141.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 6,
      "referenceLabel": "Psalms 141:6",
      "text": "I cried to thee, O Lord: I said: Thou art my hope, my portion in the land of the living.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.141.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 7,
      "referenceLabel": "Psalms 141:7",
      "text": "Attend to my supplication: for I am brought very low. Deliver me from my persecutors; for they are stronger than I.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.141.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 8,
      "referenceLabel": "Psalms 141:8",
      "text": "Bring my soul out of prison, that I may praise thy name: the just wait for me, until thou reward me.",
      "paragraphStart": false
    }
  ]
}
