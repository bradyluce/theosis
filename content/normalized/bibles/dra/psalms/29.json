{
  "chapter": {
    "id": "dra:psalms.29",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 29,
    "referenceLabel": "Psalms 29",
    "summary": "Source text for Psalms 29 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.29.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Psalms 29:1",
      "text": "A psalm of a canticle, at the dedication of David's house.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.29.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Psalms 29:2",
      "text": "I will extol thee, O Lord, for thou hast upheld me: and hast not made my enemies to rejoice over me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.29.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Psalms 29:3",
      "text": "O Lord my God, I have cried to thee, and thou hast healed me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.29.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Psalms 29:4",
      "text": "Thou hast brought forth, O Lord, my soul from hell: thou hast saved me from them that go down into the pit.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.29.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Psalms 29:5",
      "text": "Sing to the Lord, O ye his saints: and give praise to the memory of his holiness.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.29.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Psalms 29:6",
      "text": "For wrath is in his indignation; and life in his good will. In the evening weeping shall have place, and in the morning gladness.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.29.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Psalms 29:7",
      "text": "And in my abundance I said: I shall never be moved.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.29.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Psalms 29:8",
      "text": "O Lord, in thy favour, thou gavest strength to my beauty. Thou turnedst away thy face from me, and I became troubled.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.29.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Psalms 29:9",
      "text": "To thee, O Lord, will I cry: and I will make supplication to my God.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.29.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Psalms 29:10",
      "text": "What profit is there in my blood, whilst I go down to corruption? Shall dust confess to thee, or declare thy truth?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.29.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Psalms 29:11",
      "text": "The Lord hath heard, and hath had mercy on me: the Lord became my helper.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.29.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 12,
      "referenceLabel": "Psalms 29:12",
      "text": "Thou hast turned for me my mourning into joy: thou hast cut my sackcloth, and hast compassed me with gladness:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.29.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 13,
      "referenceLabel": "Psalms 29:13",
      "text": "To the end that my glory may sing to thee, and I may not regret: O Lord my God, I will give praise to thee for ever.",
      "paragraphStart": false
    }
  ]
}
