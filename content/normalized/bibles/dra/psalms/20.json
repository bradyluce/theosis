{
  "chapter": {
    "id": "dra:psalms.20",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 20,
    "referenceLabel": "Psalms 20",
    "summary": "Source text for Psalms 20 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.20.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Psalms 20:1",
      "text": "Unto the end. A psalm for David.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.20.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Psalms 20:2",
      "text": "In thy strength, O Lord, the king shall joy; and in thy salvation he shall rejoice exceedingly.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.20.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Psalms 20:3",
      "text": "Thou hast given him his heart's desire: and hast not withholden from him the will of his lips.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.20.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Psalms 20:4",
      "text": "For thou hast prevented him with blessings of sweetness: thou hast set on his head a crown of precious stones.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.20.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Psalms 20:5",
      "text": "He asked life of thee: and thou hast given him length of days for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.20.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Psalms 20:6",
      "text": "His glory is great in thy salvation: glory and great beauty shalt thou lay upon him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.20.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Psalms 20:7",
      "text": "For thou shalt give him to be a blessing for ever and ever: thou shalt make him joyful in gladness with thy countenance.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.20.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Psalms 20:8",
      "text": "For the king hopeth in the Lord: and through the mercy of the most High he shall not be moved.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.20.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Psalms 20:9",
      "text": "Let thy hand be found by all thy enemies: let thy right hand find out all them that hate thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.20.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Psalms 20:10",
      "text": "Thou shalt make them as an oven of fire, in the time of thy anger: the Lord shall trouble them in his wrath, and fire shall devour them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.20.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Psalms 20:11",
      "text": "Their fruit shalt thou destroy from the earth: and their seed from among the children of men.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.20.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Psalms 20:12",
      "text": "For they have intended evils against thee: they have devised counsels which they have not been able to establish.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.20.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "Psalms 20:13",
      "text": "For thou shalt make them turn their back: in thy remnants thou shalt prepare their face.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.20.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 14,
      "referenceLabel": "Psalms 20:14",
      "text": "Be thou exalted, O Lord, in thy own strength: we will sing and praise thy power.",
      "paragraphStart": false
    }
  ]
}
