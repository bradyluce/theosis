{
  "chapter": {
    "id": "dra:psalms.62",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 62,
    "referenceLabel": "Psalms 62",
    "summary": "Source text for Psalms 62 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.62.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 1,
      "referenceLabel": "Psalms 62:1",
      "text": "A psalm of David while he was in the desert of Edom.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.62.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 2,
      "referenceLabel": "Psalms 62:2",
      "text": "O God, my God, to thee do I watch at break of day. For thee my soul hath thirsted; for thee my flesh, O how many ways!",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.62.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 3,
      "referenceLabel": "Psalms 62:3",
      "text": "In a desert land, and where there is no way, and no water: so in the sanctuary have I come before thee, to see thy power and thy glory.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.62.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 4,
      "referenceLabel": "Psalms 62:4",
      "text": "For thy mercy is better than lives: thee my lips will praise.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.62.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 5,
      "referenceLabel": "Psalms 62:5",
      "text": "Thus will I bless thee all my life long: and in thy name I will lift up my hands.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.62.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 6,
      "referenceLabel": "Psalms 62:6",
      "text": "Let my soul be filled as with marrow and fatness: and my mouth shall praise thee with joyful lips.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.62.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 7,
      "referenceLabel": "Psalms 62:7",
      "text": "If I have remembered thee upon my bed, I will meditate on thee in the morning:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.62.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 8,
      "referenceLabel": "Psalms 62:8",
      "text": "Because thou hast been my helper. And I will rejoice under the cover of thy wings:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.62.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 9,
      "referenceLabel": "Psalms 62:9",
      "text": "My soul hath stuck close to thee: thy right hand hath received me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.62.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 10,
      "referenceLabel": "Psalms 62:10",
      "text": "But they have sought my soul in vain, they shall go into the lower parts of the earth:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.62.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 11,
      "referenceLabel": "Psalms 62:11",
      "text": "They shall be delivered into the hands of the sword, they shall be the portions of foxes.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.62.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 12,
      "referenceLabel": "Psalms 62:12",
      "text": "But the king shall rejoice in God, all they shall be praised that swear by him: because the mouth is stopped of them that speak wicked things.",
      "paragraphStart": false
    }
  ]
}
