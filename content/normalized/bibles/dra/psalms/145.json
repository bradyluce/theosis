{
  "chapter": {
    "id": "dra:psalms.145",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 145,
    "referenceLabel": "Psalms 145",
    "summary": "Source text for Psalms 145 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.145.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 1,
      "referenceLabel": "Psalms 145:1",
      "text": "Alleluia, of Aggeus and Zacharias.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.145.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 2,
      "referenceLabel": "Psalms 145:2",
      "text": "Praise the Lord, O my soul, in my life I will praise the Lord: I will sing to my God as long as I shall be. Put not your trust in princes:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.145.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 3,
      "referenceLabel": "Psalms 145:3",
      "text": "In the children of men, in whom there is no salvation.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.145.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 4,
      "referenceLabel": "Psalms 145:4",
      "text": "His spirit shall go forth, and he shall return into his earth: in that day all their thoughts shall perish.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.145.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 5,
      "referenceLabel": "Psalms 145:5",
      "text": "Blessed is he who hath the God of Jacob for his helper, whose hope is in the Lord his God:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.145.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 6,
      "referenceLabel": "Psalms 145:6",
      "text": "Who made heaven and earth, the sea, and all things that are in them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.145.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 7,
      "referenceLabel": "Psalms 145:7",
      "text": "Who keepeth truth for ever: who executeth judgment for them that suffer wrong: who giveth food to the hungry. The Lord looseth them that are fettered:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.145.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 8,
      "referenceLabel": "Psalms 145:8",
      "text": "The Lord enlighteneth the blind. The Lord lifteth up them that are cast down: the Lord loveth the just.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.145.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 9,
      "referenceLabel": "Psalms 145:9",
      "text": "The Lord keepeth the strangers, he will support the fatherless and the widow: and the ways of sinners he will destroy.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.145.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 10,
      "referenceLabel": "Psalms 145:10",
      "text": "The Lord shall reign for ever: thy God, O Sion, unto generation and generation.",
      "paragraphStart": false
    }
  ]
}
