{
  "chapter": {
    "id": "dra:psalms.19",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 19,
    "referenceLabel": "Psalms 19",
    "summary": "Source text for Psalms 19 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.19.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Psalms 19:1",
      "text": "Unto the end. A psalm for David.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.19.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Psalms 19:2",
      "text": "May the Lord hear thee in the day of tribulation: may the name of the God of Jacob protect thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.19.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Psalms 19:3",
      "text": "May he send thee help from the sanctuary: and defend thee out of Sion.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.19.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Psalms 19:4",
      "text": "May he be mindful of all thy sacrifices: and may thy whole burntoffering be made fat.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.19.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Psalms 19:5",
      "text": "May he give thee according to thy own heart; and confirm all thy counsels.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.19.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Psalms 19:6",
      "text": "We will rejoice in thy salvation; and in the name of our God we shall be exalted.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.19.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Psalms 19:7",
      "text": "The Lord fulfil all thy petitions: now have I known that the Lord hath saved his anointed. He will hear him from his holy heaven: the salvation of his right hand is in powers.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.19.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Psalms 19:8",
      "text": "Some trust in chariots, and some in horses: but we will call upon the name of the Lord, our God.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.19.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Psalms 19:9",
      "text": "They are bound, and have fallen: but we are risen, and are set upright.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.19.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Psalms 19:10",
      "text": "O Lord, save the king: and hear us in the day that we shall call upon thee.",
      "paragraphStart": false
    }
  ]
}
