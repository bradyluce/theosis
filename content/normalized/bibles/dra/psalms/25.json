{
  "chapter": {
    "id": "dra:psalms.25",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 25,
    "referenceLabel": "Psalms 25",
    "summary": "Source text for Psalms 25 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.25.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Psalms 25:1",
      "text": "Unto the end, a psalm for David. Judge me, O Lord, for I have walked in my innocence: and I have put my trust in the Lord, and shall not be weakened.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.25.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Psalms 25:2",
      "text": "Prove me, O Lord, and try me; burn my reins and my heart.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.25.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Psalms 25:3",
      "text": "For thy mercy is before my eyes; and I am well pleased with thy truth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.25.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Psalms 25:4",
      "text": "I have not sat with the council of vanity: neither will I go in with the doers of unjust things.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.25.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Psalms 25:5",
      "text": "I have hated the assembly of the malignant; and with the wicked I will not sit.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.25.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Psalms 25:6",
      "text": "I will wash my hands among the innocent; and will compass thy altar, O Lord:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.25.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Psalms 25:7",
      "text": "That I may hear the voice of thy praise: and tell of all thy wondrous works.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.25.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Psalms 25:8",
      "text": "I have loved, O Lord, the beauty of thy house; and the place where thy glory dwelleth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.25.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Psalms 25:9",
      "text": "Take not away my soul, O God, with the wicked: nor my life with bloody men:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.25.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Psalms 25:10",
      "text": "In whose hands are iniquities: their right hand is filled with gifts.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.25.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Psalms 25:11",
      "text": "But as for me, I have walked in my innocence: redeem me, and have mercy on me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.25.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Psalms 25:12",
      "text": "My foot hath stood in the direct way: in the churches I will bless thee, O Lord.",
      "paragraphStart": false
    }
  ]
}
