{
  "chapter": {
    "id": "dra:psalms.79",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 79,
    "referenceLabel": "Psalms 79",
    "summary": "Source text for Psalms 79 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.79.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 1,
      "referenceLabel": "Psalms 79:1",
      "text": "Unto the end, for them that shall be changed, a testimony for Asaph, a psalm.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.79.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 2,
      "referenceLabel": "Psalms 79:2",
      "text": "Give ear, O thou that rulest Israel: thou that leadest Joseph like a sheep. Thou that sittest upon the cherubims, shine forth",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.79.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 3,
      "referenceLabel": "Psalms 79:3",
      "text": "Before Ephraim, Benjamin, and Manasses. Stir up thy might, and come to save us.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.79.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 4,
      "referenceLabel": "Psalms 79:4",
      "text": "Convert us, O God: and shew us thy face, and we shall be saved.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.79.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 5,
      "referenceLabel": "Psalms 79:5",
      "text": "O Lord God of hosts, how long wilt thou be angry against the prayer of thy servant?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.79.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 6,
      "referenceLabel": "Psalms 79:6",
      "text": "How long wilt thou feed us with the bread of tears: and give us for our drink tears in measure?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.79.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 7,
      "referenceLabel": "Psalms 79:7",
      "text": "Thou hast made us to be a contradiction to our neighbours: and our enemies have scoffed at us.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.79.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 8,
      "referenceLabel": "Psalms 79:8",
      "text": "O God of hosts, convert us: and shew thy face, and we shall be saved.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.79.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 9,
      "referenceLabel": "Psalms 79:9",
      "text": "Thou hast brought a vineyard out of Egypt: thou hast cast out the Gentiles and planted it.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.79.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 10,
      "referenceLabel": "Psalms 79:10",
      "text": "Thou wast the guide of its journey in its sight: thou plantedst the roots thereof, and it filled the land.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.79.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 11,
      "referenceLabel": "Psalms 79:11",
      "text": "The shadow of it covered the hills: and the branches thereof the cedars of God.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.79.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 12,
      "referenceLabel": "Psalms 79:12",
      "text": "It stretched forth its branches unto the sea, and its boughs unto the river.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.79.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 13,
      "referenceLabel": "Psalms 79:13",
      "text": "Why hast thou broken down the hedge thereof, so that all they who pass by the way do pluck it?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.79.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 14,
      "referenceLabel": "Psalms 79:14",
      "text": "The boar out of the wood hath laid it waste: and a singular wild beast hath devoured it.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.79.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 15,
      "referenceLabel": "Psalms 79:15",
      "text": "Turn again, O God of hosts, look down from heaven, and see, and visit this vineyard:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.79.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 16,
      "referenceLabel": "Psalms 79:16",
      "text": "And perfect the same which thy right hand hath planted: and upon the son of man whom thou hast confirmed for thyself.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.79.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 17,
      "referenceLabel": "Psalms 79:17",
      "text": "Things set on fire and dug down shall perish at the rebuke of thy countenance.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.79.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 18,
      "referenceLabel": "Psalms 79:18",
      "text": "Let thy hand be upon the man of thy right hand: and upon the son of man whom thou hast confirmed for thyself.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.79.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 19,
      "referenceLabel": "Psalms 79:19",
      "text": "And we depart not from thee, thou shalt quicken us: and we will call upon thy name.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.79.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 20,
      "referenceLabel": "Psalms 79:20",
      "text": "O Lord God of hosts, convert us and shew thy face, and we shall be saved.",
      "paragraphStart": false
    }
  ]
}
