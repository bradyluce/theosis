{
  "chapter": {
    "id": "dra:psalms.138",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 138,
    "referenceLabel": "Psalms 138",
    "summary": "Source text for Psalms 138 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.138.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 1,
      "referenceLabel": "Psalms 138:1",
      "text": "Unto the end, a psalm of David. Lord, thou hast proved me, and known me:",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.138.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 2,
      "referenceLabel": "Psalms 138:2",
      "text": "Thou hast known my sitting down, and my rising up.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 3,
      "referenceLabel": "Psalms 138:3",
      "text": "Thou hast understood my thoughts afar off: my path and my line thou hast searched out.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 4,
      "referenceLabel": "Psalms 138:4",
      "text": "And thou hast foreseen all my ways: for there is no speech in my tongue.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 5,
      "referenceLabel": "Psalms 138:5",
      "text": "Behold, O Lord, thou hast known all things, the last and those of old: thou hast formed me, and hast laid thy hand upon me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 6,
      "referenceLabel": "Psalms 138:6",
      "text": "Thy knowledge is become wonderful to me: it is high, and I cannot reach to it.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 7,
      "referenceLabel": "Psalms 138:7",
      "text": "Whither shall I go from thy spirit? or whither shall I flee from thy face?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 8,
      "referenceLabel": "Psalms 138:8",
      "text": "If I ascend into heaven, thou art there: if I descend into hell, thou art present.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 9,
      "referenceLabel": "Psalms 138:9",
      "text": "If I take my wings early in the morning, and dwell in the uttermost parts of the sea:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 10,
      "referenceLabel": "Psalms 138:10",
      "text": "Even there also shall thy hand lead me: and thy right hand shall hold me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 11,
      "referenceLabel": "Psalms 138:11",
      "text": "And I said: Perhaps darkness shall cover me: and night shall be my light in my pleasures.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 12,
      "referenceLabel": "Psalms 138:12",
      "text": "But darkness shall not be dark to thee, and night shall be light all the day: the darkness thereof, and the light thereof are alike to thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 13,
      "referenceLabel": "Psalms 138:13",
      "text": "For thou hast possessed my reins: thou hast protected me from my mother's womb.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 14,
      "referenceLabel": "Psalms 138:14",
      "text": "I will praise thee, for thou art fearfully magnified: wonderful are thy works, and my soul knoweth right well.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 15,
      "referenceLabel": "Psalms 138:15",
      "text": "My bone is not hidden from thee, which thou hast made in secret: and my substance in the lower parts of the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 16,
      "referenceLabel": "Psalms 138:16",
      "text": "Thy eyes did see my imperfect being, and in thy book all shall be written: days shall be formed, and no one in them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 17,
      "referenceLabel": "Psalms 138:17",
      "text": "But to me thy friends, O God, are made exceedingly honourable: their principality is exceedingly strengthened.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 18,
      "referenceLabel": "Psalms 138:18",
      "text": "I will number them, and they shall be multiplied above the sand, I rose up and am still with thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 19,
      "referenceLabel": "Psalms 138:19",
      "text": "If thou wilt kill the wicked, O God: ye men of blood, depart from me:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 20,
      "referenceLabel": "Psalms 138:20",
      "text": "Because you say in thought: They shall receive thy cities in vain.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 21,
      "referenceLabel": "Psalms 138:21",
      "text": "Have I not hated them, O Lord, that hated thee: and pined away because of thy enemies?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 22,
      "referenceLabel": "Psalms 138:22",
      "text": "I have hated them with a perfect hatred: and they are become enemies to me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 23,
      "referenceLabel": "Psalms 138:23",
      "text": "Prove me, O God, and know my heart: examine me, and know my paths.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.138.24",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 24,
      "referenceLabel": "Psalms 138:24",
      "text": "And see if there be in me the way of iniquity: and lead me in the eternal way.",
      "paragraphStart": false
    }
  ]
}
