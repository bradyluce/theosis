{
  "chapter": {
    "id": "dra:psalms.115",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 115,
    "referenceLabel": "Psalms 115",
    "summary": "Source text for Psalms 115 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.115.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 1,
      "referenceLabel": "Psalms 115:1",
      "text": "I have believed, therefore have I spoken; but I have been humbled exceedingly.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.115.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 2,
      "referenceLabel": "Psalms 115:2",
      "text": "I said in my excess: Every man is a liar.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.115.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 3,
      "referenceLabel": "Psalms 115:3",
      "text": "What shall I render to the Lord, for all the things that he hath rendered to me?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.115.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 4,
      "referenceLabel": "Psalms 115:4",
      "text": "I will take the chalice of salvation; and I will call upon the name of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.115.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 5,
      "referenceLabel": "Psalms 115:5",
      "text": "I will pay my vows to the Lord before all his people:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.115.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 6,
      "referenceLabel": "Psalms 115:6",
      "text": "Precious in the sight of the Lord is the death of his saints.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.115.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 7,
      "referenceLabel": "Psalms 115:7",
      "text": "O Lord, for I am thy servant: I am thy servant, and the son of thy handmaid. Thou hast broken my bonds:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.115.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 8,
      "referenceLabel": "Psalms 115:8",
      "text": "I will sacrifice to thee the sacrifice of praise, and I will call upon the name of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.115.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 9,
      "referenceLabel": "Psalms 115:9",
      "text": "I will pay my vows to the Lord in the sight of all his people:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.115.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 10,
      "referenceLabel": "Psalms 115:10",
      "text": "In the courts of the house of the Lord, in the midst of thee, O Jerusalem.",
      "paragraphStart": false
    }
  ]
}
