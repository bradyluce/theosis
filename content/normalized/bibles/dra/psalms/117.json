{
  "chapter": {
    "id": "dra:psalms.117",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 117,
    "referenceLabel": "Psalms 117",
    "summary": "Source text for Psalms 117 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.117.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 1,
      "referenceLabel": "Psalms 117:1",
      "text": "Give praise to the Lord, for he is good: for his mercy endureth for ever.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.117.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 2,
      "referenceLabel": "Psalms 117:2",
      "text": "Let Israel now say, that he is good: that his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 3,
      "referenceLabel": "Psalms 117:3",
      "text": "Let the house of Aaron now say, that his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 4,
      "referenceLabel": "Psalms 117:4",
      "text": "Let them that fear the Lord now say, that his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 5,
      "referenceLabel": "Psalms 117:5",
      "text": "In my trouble I called upon the Lord: and the Lord heard me, and enlarged me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 6,
      "referenceLabel": "Psalms 117:6",
      "text": "The Lord is my helper: I will not fear what man can do unto me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 7,
      "referenceLabel": "Psalms 117:7",
      "text": "The Lord is my helper: and I will look over my enemies.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 8,
      "referenceLabel": "Psalms 117:8",
      "text": "It is good to confide in the Lord, rather than to have confidence in man.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 9,
      "referenceLabel": "Psalms 117:9",
      "text": "It is good to trust in the Lord, rather than to trust in princes.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 10,
      "referenceLabel": "Psalms 117:10",
      "text": "All nations compassed me about; and, in the name of the Lord I have been revenged on them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 11,
      "referenceLabel": "Psalms 117:11",
      "text": "Surrounding me they compassed me about: and in the name of the Lord I have been revenged on them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 12,
      "referenceLabel": "Psalms 117:12",
      "text": "They surrounded me like bees, and they burned like fire among thorns: and in the name of the Lord I was revenged on them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 13,
      "referenceLabel": "Psalms 117:13",
      "text": "Being pushed I was overturned that I might fall: but the Lord supported me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 14,
      "referenceLabel": "Psalms 117:14",
      "text": "The Lord is my strength and my praise: and he is become my salvation.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 15,
      "referenceLabel": "Psalms 117:15",
      "text": "The voice of rejoicing and of salvation is in the tabernacles of the just.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 16,
      "referenceLabel": "Psalms 117:16",
      "text": "The right hand of the Lord hath wrought strength: the right hand of the Lord hath exalted me: the right hand of the Lord hath wrought strength.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 17,
      "referenceLabel": "Psalms 117:17",
      "text": "I shall not die, but live: and shall declare the works of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 18,
      "referenceLabel": "Psalms 117:18",
      "text": "The Lord chastising hath chastised me: but he hath not delivered me over to death.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 19,
      "referenceLabel": "Psalms 117:19",
      "text": "Open ye to me the gates of justice: I will go in to them, and give praise to the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 20,
      "referenceLabel": "Psalms 117:20",
      "text": "This is the gate of the Lord, the just shall enter into it.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 21,
      "referenceLabel": "Psalms 117:21",
      "text": "I will give glory to thee because thou hast heard me: and art become my salvation.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 22,
      "referenceLabel": "Psalms 117:22",
      "text": "The stone which the builders rejected; the same is become the head of the corner.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 23,
      "referenceLabel": "Psalms 117:23",
      "text": "This is the Lord's doing, and it is wonderful in our eyes.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.24",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 24,
      "referenceLabel": "Psalms 117:24",
      "text": "This is the day which the Lord hath made: let us be glad and rejoice therein.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.25",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 25,
      "referenceLabel": "Psalms 117:25",
      "text": "O Lord, save me: O Lord, give good success.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.26",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 26,
      "referenceLabel": "Psalms 117:26",
      "text": "Blessed be he that cometh in the name of the Lord. We have blessed you out of the house of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.27",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 27,
      "referenceLabel": "Psalms 117:27",
      "text": "The Lord is God, and he hath shone upon us. Appoint a solemn day, with shady boughs, even to the horn of the altar.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.28",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 28,
      "referenceLabel": "Psalms 117:28",
      "text": "Thou art my God, and I will praise thee: thou art my God, and I will exalt thee. I will praise thee, because thou hast heard me, and art become my salvation.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.117.29",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 29,
      "referenceLabel": "Psalms 117:29",
      "text": "O praise ye the Lord, for he is good: for his mercy endureth for ever.",
      "paragraphStart": false
    }
  ]
}
