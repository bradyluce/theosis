{
  "chapter": {
    "id": "dra:psalms.40",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 40,
    "referenceLabel": "Psalms 40",
    "summary": "Source text for Psalms 40 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.40.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 1,
      "referenceLabel": "Psalms 40:1",
      "text": "Unto the end, a psalm for David himself.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.40.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 2,
      "referenceLabel": "Psalms 40:2",
      "text": "Blessed is he that understandeth concerning the needy and the poor: the Lord will deliver him in the evil day.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.40.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 3,
      "referenceLabel": "Psalms 40:3",
      "text": "The Lord preserve him and give him life, and make him blessed upon the earth: and deliver him not up to the will of his enemies.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.40.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 4,
      "referenceLabel": "Psalms 40:4",
      "text": "The Lord help him on his bed of sorrow: thou hast turned all his couch in his sickness.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.40.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 5,
      "referenceLabel": "Psalms 40:5",
      "text": "I said: O Lord, be thou merciful to me: heal my soul, for I have sinned against thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.40.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 6,
      "referenceLabel": "Psalms 40:6",
      "text": "My enemies have spoken evils against me: when shall he die and his name perish?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.40.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 7,
      "referenceLabel": "Psalms 40:7",
      "text": "And if he came in to see me, he spoke vain things: his heart gathered together iniquity to itself. He went out and spoke to the same purpose.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.40.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 8,
      "referenceLabel": "Psalms 40:8",
      "text": "All my enemies whispered together against me: they devised evils to me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.40.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 9,
      "referenceLabel": "Psalms 40:9",
      "text": "They determined against me an unjust word: shall he that sleepeth rise again no more?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.40.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 10,
      "referenceLabel": "Psalms 40:10",
      "text": "For even the man of my peace, in whom I trusted, who ate my bread, hath greatly supplanted me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.40.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 11,
      "referenceLabel": "Psalms 40:11",
      "text": "But thou, O Lord, have mercy on me, and raise me up again: and I will requite them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.40.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 12,
      "referenceLabel": "Psalms 40:12",
      "text": "By this I know, that thou hast had a good will for me: because my enemy shall not rejoice over me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.40.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 13,
      "referenceLabel": "Psalms 40:13",
      "text": "But thou hast upheld me by reason of my innocence: and hast established me in thy sight for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.40.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 14,
      "referenceLabel": "Psalms 40:14",
      "text": "Blessed be the Lord the God of Israel from eternity to eternity. So be it. So be it.",
      "paragraphStart": false
    }
  ]
}
