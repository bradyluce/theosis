{
  "chapter": {
    "id": "dra:psalms.65",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 65,
    "referenceLabel": "Psalms 65",
    "summary": "Source text for Psalms 65 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.65.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 1,
      "referenceLabel": "Psalms 65:1",
      "text": "Unto the end, a canticle of a psalm of the resurrection. Shout with joy to God, all the earth,",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.65.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 2,
      "referenceLabel": "Psalms 65:2",
      "text": "Sing ye a psalm to his name; give glory to his praise.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.65.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 3,
      "referenceLabel": "Psalms 65:3",
      "text": "Say unto God, How terrible are thy works, O Lord! in the multitude of thy strength thy enemies shall lie to thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.65.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 4,
      "referenceLabel": "Psalms 65:4",
      "text": "Let all the earth adore thee, and sing to thee: let it sing a psalm to thy name.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.65.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 5,
      "referenceLabel": "Psalms 65:5",
      "text": "Come and see the works of God; who is terrible in his counsels over the sons of men.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.65.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 6,
      "referenceLabel": "Psalms 65:6",
      "text": "Who turneth the sea into dry land, in the river they shall pass on foot: there shall we rejoice in him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.65.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 7,
      "referenceLabel": "Psalms 65:7",
      "text": "Who by his power ruleth for ever: his eyes behold the nations; let not them that provoke him be exalted in themselves.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.65.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 8,
      "referenceLabel": "Psalms 65:8",
      "text": "O bless our God, ye Gentiles: and make the voice of his praise to be heard.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.65.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 9,
      "referenceLabel": "Psalms 65:9",
      "text": "Who hath set my soul to live: and hath not suffered my feet to be moved:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.65.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 10,
      "referenceLabel": "Psalms 65:10",
      "text": "For thou, O God, hast proved us: thou hast tried us by fire, as silver is tried.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.65.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 11,
      "referenceLabel": "Psalms 65:11",
      "text": "Thou hast brought us into a net, thou hast laid afflictions on our back:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.65.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 12,
      "referenceLabel": "Psalms 65:12",
      "text": "Thou hast set men over our heads. We have passed through fire and water, and thou hast brought us out into a refreshment.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.65.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 13,
      "referenceLabel": "Psalms 65:13",
      "text": "I will go into thy house with burnt offerings: I will pay thee my vows,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.65.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 14,
      "referenceLabel": "Psalms 65:14",
      "text": "Which my lips have uttered, And my mouth hath spoken, when I was in trouble.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.65.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 15,
      "referenceLabel": "Psalms 65:15",
      "text": "I will offer up to thee holocausts full of marrow, with burnt offerings of rams: I will offer to thee bullocks with goats.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.65.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 16,
      "referenceLabel": "Psalms 65:16",
      "text": "Come and hear, all ye that fear God, and I will tell you what great things he hath done for my soul.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.65.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 17,
      "referenceLabel": "Psalms 65:17",
      "text": "I cried to him with my mouth: and I extolled him with my tongue.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.65.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 18,
      "referenceLabel": "Psalms 65:18",
      "text": "If I have looked at iniquity in my heart, the Lord will not hear me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.65.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 19,
      "referenceLabel": "Psalms 65:19",
      "text": "Therefore hath God heard me, and hath attended to the voice of my supplication.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.65.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 20,
      "referenceLabel": "Psalms 65:20",
      "text": "Blessed be God, who hath not turned away my prayer, nor his mercy from me.",
      "paragraphStart": false
    }
  ]
}
