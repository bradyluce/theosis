{
  "chapter": {
    "id": "dra:psalms.144",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 144,
    "referenceLabel": "Psalms 144",
    "summary": "Source text for Psalms 144 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.144.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 1,
      "referenceLabel": "Psalms 144:1",
      "text": "Praise, for David himself. I will extol thee, O God my king: and I will bless thy name for ever; yea, for ever and ever.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.144.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 2,
      "referenceLabel": "Psalms 144:2",
      "text": "Every day will I bless thee: and I will praise thy name for ever; yea, for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.144.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 3,
      "referenceLabel": "Psalms 144:3",
      "text": "Great is the Lord, and greatly to be praised: and of his greatness there is no end.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.144.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 4,
      "referenceLabel": "Psalms 144:4",
      "text": "Generation and generation shall praise thy works: and they shall declare thy power.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.144.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 5,
      "referenceLabel": "Psalms 144:5",
      "text": "They shall speak of the magnificence of the glory of thy holiness: and shall tell thy wondrous works.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.144.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 6,
      "referenceLabel": "Psalms 144:6",
      "text": "And they shall speak of the might of thy terrible acts: and shall declare thy greatness.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.144.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 7,
      "referenceLabel": "Psalms 144:7",
      "text": "They shall publish the memory of the abundance of thy sweetness: and shall rejoice in thy justice.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.144.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 8,
      "referenceLabel": "Psalms 144:8",
      "text": "The Lord is gracious and merciful: patient and plenteous in mercy.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.144.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 9,
      "referenceLabel": "Psalms 144:9",
      "text": "The Lord is sweet to all: and his tender mercies are over all his works.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.144.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 10,
      "referenceLabel": "Psalms 144:10",
      "text": "Let all thy works, O Lord, praise thee: and let thy saints bless thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.144.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 11,
      "referenceLabel": "Psalms 144:11",
      "text": "They shall speak of the glory of thy kingdom: and shall tell of thy power:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.144.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 12,
      "referenceLabel": "Psalms 144:12",
      "text": "To make thy might known to the sons of men: and the glory of the magnificence of thy kingdom.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.144.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 13,
      "referenceLabel": "Psalms 144:13",
      "text": "Thy kingdom is a kingdom of all ages: and thy dominion endureth throughout all generations. The Lord is faithful in all his words: and holy in all his works.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.144.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 14,
      "referenceLabel": "Psalms 144:14",
      "text": "The Lord lifteth up all that fall: and setteth up all that are cast down.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.144.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 15,
      "referenceLabel": "Psalms 144:15",
      "text": "The eyes of all hope in thee, O Lord: and thou givest them meat in due season.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.144.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 16,
      "referenceLabel": "Psalms 144:16",
      "text": "Thou openest thy hand, and fillest with blessing every living creature.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.144.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 17,
      "referenceLabel": "Psalms 144:17",
      "text": "The Lord is just in all his ways: and holy in all his works.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.144.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 18,
      "referenceLabel": "Psalms 144:18",
      "text": "The Lord is nigh unto all them that call upon him: to all that call upon him in truth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.144.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 19,
      "referenceLabel": "Psalms 144:19",
      "text": "He will do the will of them that fear him: and he will hear their prayer, and save them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.144.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 20,
      "referenceLabel": "Psalms 144:20",
      "text": "The Lord keepeth all them that love him; but all the wicked he will destroy.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.144.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 21,
      "referenceLabel": "Psalms 144:21",
      "text": "My mouth shall speak the praise of the Lord: and let all flesh bless his holy name forever; yea, for ever and ever.",
      "paragraphStart": false
    }
  ]
}
