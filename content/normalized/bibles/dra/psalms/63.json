{
  "chapter": {
    "id": "dra:psalms.63",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 63,
    "referenceLabel": "Psalms 63",
    "summary": "Source text for Psalms 63 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.63.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 1,
      "referenceLabel": "Psalms 63:1",
      "text": "Unto the end, a psalm for David.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.63.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 2,
      "referenceLabel": "Psalms 63:2",
      "text": "Hear O God, my prayer, when I make supplication to thee: deliver my soul from the fear of the enemy.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.63.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 3,
      "referenceLabel": "Psalms 63:3",
      "text": "Thou hast protected me from the assembly of the malignant; from the multitude of the workers of iniquity.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.63.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 4,
      "referenceLabel": "Psalms 63:4",
      "text": "For they have whetted their tongues like a sword; they have bent their bow a bitter thing,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.63.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 5,
      "referenceLabel": "Psalms 63:5",
      "text": "To shoot in secret the undefiled.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.63.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 6,
      "referenceLabel": "Psalms 63:6",
      "text": "They will shoot at him on a sudden, and will not fear: they are resolute in wickedness. They have talked of hiding snares; they have said: Who shall see them?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.63.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 7,
      "referenceLabel": "Psalms 63:7",
      "text": "They have searched after iniquities: they have failed in their search. Man shall come to a deep heart:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.63.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 8,
      "referenceLabel": "Psalms 63:8",
      "text": "And God shall be exalted. The arrows of children are their wounds:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.63.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 9,
      "referenceLabel": "Psalms 63:9",
      "text": "And their tongues against them are made weak. All that saw them were troubled;",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.63.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 10,
      "referenceLabel": "Psalms 63:10",
      "text": "And every man was afraid. And they declared the works of God, and understood his doings.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.63.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 11,
      "referenceLabel": "Psalms 63:11",
      "text": "The just shall rejoice in the Lord, and shall hope in him: and all the upright in heart shall be praised.",
      "paragraphStart": false
    }
  ]
}
