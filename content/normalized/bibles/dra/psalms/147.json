{
  "chapter": {
    "id": "dra:psalms.147",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 147,
    "referenceLabel": "Psalms 147",
    "summary": "Source text for Psalms 147 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.147.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 1,
      "referenceLabel": "Psalms 147:1",
      "text": "Praise the Lord, O Jerusalem: praise thy God, O Sion.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.147.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 2,
      "referenceLabel": "Psalms 147:2",
      "text": "Because he hath strengthened the bolts of thy gates, he hath blessed thy children within thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.147.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 3,
      "referenceLabel": "Psalms 147:3",
      "text": "Who hath placed peace in thy borders: and filleth thee with the fat of corn.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.147.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 4,
      "referenceLabel": "Psalms 147:4",
      "text": "Who sendeth forth his speech to the earth: his word runneth swiftly.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.147.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 5,
      "referenceLabel": "Psalms 147:5",
      "text": "Who giveth snow like wool: scattereth mists like ashes.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.147.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 6,
      "referenceLabel": "Psalms 147:6",
      "text": "He sendeth his crystal like morsels: who shall stand before the face of his cold?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.147.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 7,
      "referenceLabel": "Psalms 147:7",
      "text": "He shall send out his word, and shall melt them: his wind shall blow, and the waters shall run.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.147.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 8,
      "referenceLabel": "Psalms 147:8",
      "text": "Who declareth his word to Jacob: his justices and his judgments to Israel.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.147.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 9,
      "referenceLabel": "Psalms 147:9",
      "text": "He hath not done in like manner to every nation: and his judgments he hath not made manifest to them. Alleluia.",
      "paragraphStart": false
    }
  ]
}
