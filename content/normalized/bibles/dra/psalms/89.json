{
  "chapter": {
    "id": "dra:psalms.89",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 89,
    "referenceLabel": "Psalms 89",
    "summary": "Source text for Psalms 89 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.89.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 1,
      "referenceLabel": "Psalms 89:1",
      "text": "A prayer of Moses the man of God. Lord, thou hast been our refuge from generation to generation.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.89.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 2,
      "referenceLabel": "Psalms 89:2",
      "text": "Before the mountains were made, or the earth and the world was formed; from eternity and to eternity thou art God.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.89.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 3,
      "referenceLabel": "Psalms 89:3",
      "text": "Turn not man away to be brought low: and thou hast said: Be converted, O ye sons of men.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.89.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 4,
      "referenceLabel": "Psalms 89:4",
      "text": "For a thousand years in thy sight are as yesterday, which is past. And as a watch in the night,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.89.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 5,
      "referenceLabel": "Psalms 89:5",
      "text": "Things that are counted nothing, shall their years be.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.89.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 6,
      "referenceLabel": "Psalms 89:6",
      "text": "In the morning man shall grow up like grass; in the morning he shall flourish and pass away: in the evening he shall fall, grow dry, and wither.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.89.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 7,
      "referenceLabel": "Psalms 89:7",
      "text": "For in thy wrath we have fainted away: and are troubled in thy indignation.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.89.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 8,
      "referenceLabel": "Psalms 89:8",
      "text": "Thou hast set our iniquities before thy eyes: our life in the light of thy countenance.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.89.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 9,
      "referenceLabel": "Psalms 89:9",
      "text": "For all our days are spent; and in thy wrath we have fainted away. Our years shall be considered as a spider:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.89.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 10,
      "referenceLabel": "Psalms 89:10",
      "text": "The days of our years in them are threescore and ten years. But if in the strong they be fourscore years: and what is more of them is labour and sorrow. For mildness is come upon us: and we shall be corrected.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.89.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 11,
      "referenceLabel": "Psalms 89:11",
      "text": "Who knoweth the power of thy anger, and for thy fear",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.89.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 12,
      "referenceLabel": "Psalms 89:12",
      "text": "Can number thy wrath? So make thy right hand known: and men learned in heart, in wisdom.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.89.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 13,
      "referenceLabel": "Psalms 89:13",
      "text": "Return, O Lord, how long? and be entreated in favour of thy servants.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.89.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 14,
      "referenceLabel": "Psalms 89:14",
      "text": "We are filled in the morning with thy mercy: and we have rejoiced, and are delighted all our days.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.89.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 15,
      "referenceLabel": "Psalms 89:15",
      "text": "We have rejoiced for the days in which thou hast humbled us: for the years in which we have seen evils.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.89.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 16,
      "referenceLabel": "Psalms 89:16",
      "text": "Look upon thy servants and upon their works: and direct their children.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.89.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 17,
      "referenceLabel": "Psalms 89:17",
      "text": "And let the brightness of the Lord our God be upon us: and direct thou the works of our hands over us; yea, the work of our hands do thou direct.",
      "paragraphStart": false
    }
  ]
}
