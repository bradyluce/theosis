{
  "chapter": {
    "id": "dra:psalms.74",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 74,
    "referenceLabel": "Psalms 74",
    "summary": "Source text for Psalms 74 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.74.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 1,
      "referenceLabel": "Psalms 74:1",
      "text": "Unto the end, corrupt not, a psalm of a canticle for Asaph.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.74.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 2,
      "referenceLabel": "Psalms 74:2",
      "text": "We will praise thee, O God: we will praise, and we will call upon thy name. We will relate thy wondrous works:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.74.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 3,
      "referenceLabel": "Psalms 74:3",
      "text": "When I shall take a time, I will judge justices.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.74.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 4,
      "referenceLabel": "Psalms 74:4",
      "text": "The earth is melted, and all that dwell therein: I have established the pillars thereof.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.74.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 5,
      "referenceLabel": "Psalms 74:5",
      "text": "I said to the wicked: Do not act wickedly: and to the sinners: Lift not up the horn.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.74.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 6,
      "referenceLabel": "Psalms 74:6",
      "text": "Lift not up your horn on high: speak not iniquity against God.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.74.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 7,
      "referenceLabel": "Psalms 74:7",
      "text": "For neither from the east, nor from the west, nor from the desert hills:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.74.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 8,
      "referenceLabel": "Psalms 74:8",
      "text": "For God is the judge. One he putteth down, and another he lifteth up:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.74.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 9,
      "referenceLabel": "Psalms 74:9",
      "text": "For in the hand of the Lord there is a cup of strong wine full of mixture. And he hath poured it out from this to that: but the dregs thereof are not emptied: all the sinners of the earth shall drink.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.74.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 10,
      "referenceLabel": "Psalms 74:10",
      "text": "But I will declare for ever: I will sing to the God of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.74.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 11,
      "referenceLabel": "Psalms 74:11",
      "text": "And I will break all the horns of sinners: but the horns of the just shall be exalted.",
      "paragraphStart": false
    }
  ]
}
