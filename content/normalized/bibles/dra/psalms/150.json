  "verses": [
    {
      "id": "dra:psalms.150.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 1,
      "referenceLabel": "Psalms 150:1",
      "text": "Praise ye the Lord in his holy places: praise ye him in the firmament of his power.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.150.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 2,
      "referenceLabel": "Psalms 150:2",
      "text": "Praise ye him for his mighty acts: praise ye him according to the multitude of his greatness.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.150.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 3,
      "referenceLabel": "Psalms 150:3",
      "text": "Praise him with the sound of trumpet: praise him with psaltery and harp.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.150.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 4,
      "referenceLabel": "Psalms 150:4",
      "text": "Praise him with timbrel and choir: praise him with strings and organs.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.150.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 5,
      "referenceLabel": "Psalms 150:5",
      "text": "Praise him on high sounding cymbals: praise him on cymbals of joy: let every spirit praise the Lord. Alleluia.",
      "paragraphStart": false
    }
  ]
}
