{
  "chapter": {
    "id": "dra:psalms.32",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 32,
    "referenceLabel": "Psalms 32",
    "summary": "Source text for Psalms 32 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.32.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 1,
      "referenceLabel": "Psalms 32:1",
      "text": "A psalm for David. Rejoice in the Lord, O ye just: praise becometh the upright.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.32.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 2,
      "referenceLabel": "Psalms 32:2",
      "text": "Give praise to the Lord on the harp; sing to him with the psaltery, the instrument of ten strings.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 3,
      "referenceLabel": "Psalms 32:3",
      "text": "Sing to him a new canticle, sing well unto him with a loud noise.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 4,
      "referenceLabel": "Psalms 32:4",
      "text": "For the word of the Lord is right, and all his works are done with faithfulness.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 5,
      "referenceLabel": "Psalms 32:5",
      "text": "He loveth mercy and judgment; the earth is full of the mercy of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 6,
      "referenceLabel": "Psalms 32:6",
      "text": "By the word of the Lord the heavens were established; and all the power of them by the spirit of his mouth:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 7,
      "referenceLabel": "Psalms 32:7",
      "text": "Gathering together the waters of the sea, as in a vessel; laying up the depths in storehouses.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 8,
      "referenceLabel": "Psalms 32:8",
      "text": "Let all the earth fear the Lord, and let all the inhabitants of the world be in awe of him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 9,
      "referenceLabel": "Psalms 32:9",
      "text": "For he spoke and they were made: he commanded and they were created.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 10,
      "referenceLabel": "Psalms 32:10",
      "text": "The Lord bringeth to nought the counsels of nations; and he rejecteth the devices of people, and casteth away the counsels of princes.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 11,
      "referenceLabel": "Psalms 32:11",
      "text": "But the counsel of the Lord standeth for ever: the thoughts of his heart to all generations.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 12,
      "referenceLabel": "Psalms 32:12",
      "text": "Blessed is the nation whose God is the Lord: the people whom he hath chosen for his inheritance.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 13,
      "referenceLabel": "Psalms 32:13",
      "text": "The Lord hath looked from heaven: he hath beheld all the sons of men.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 14,
      "referenceLabel": "Psalms 32:14",
      "text": "From his habitation which he hath prepared, he hath looked upon all that dwell on the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 15,
      "referenceLabel": "Psalms 32:15",
      "text": "He who hath made the hearts of every one of them: who understandeth all their works.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 16,
      "referenceLabel": "Psalms 32:16",
      "text": "The king is not saved by a great army: nor shall the giant be saved by his own great strength.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 17,
      "referenceLabel": "Psalms 32:17",
      "text": "Vain is the horse for safety: neither shall he be saved by the abundance of his strength.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 18,
      "referenceLabel": "Psalms 32:18",
      "text": "Behold the eyes of the Lord are on them that fear him: and on them that hope in his mercy.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 19,
      "referenceLabel": "Psalms 32:19",
      "text": "To deliver their souls from death; and feed them in famine.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 20,
      "referenceLabel": "Psalms 32:20",
      "text": "Our soul waiteth for the Lord: for he is our helper and protector.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 21,
      "referenceLabel": "Psalms 32:21",
      "text": "For in him our heart shall rejoice: and in his holy name we have trusted.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.32.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 22,
      "referenceLabel": "Psalms 32:22",
      "text": "Let thy mercy, O Lord, be upon us, as we have hoped in thee.",
      "paragraphStart": false
    }
  ]
}
