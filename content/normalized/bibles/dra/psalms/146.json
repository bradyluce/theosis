{
  "chapter": {
    "id": "dra:psalms.146",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 146,
    "referenceLabel": "Psalms 146",
    "summary": "Source text for Psalms 146 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.146.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 1,
      "referenceLabel": "Psalms 146:1",
      "text": "Alleluia. Praise ye the Lord, because psalm is good: to our God be joyful and comely praise.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.146.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 2,
      "referenceLabel": "Psalms 146:2",
      "text": "The Lord buildeth up Jerusalem: he will gather together the dispersed of Israel.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.146.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 3,
      "referenceLabel": "Psalms 146:3",
      "text": "Who healeth the broken of heart, and bindeth up their bruises.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.146.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 4,
      "referenceLabel": "Psalms 146:4",
      "text": "Who telleth the number of the stars: and calleth them all by their names.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.146.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 5,
      "referenceLabel": "Psalms 146:5",
      "text": "Great is our Lord, and great is his power: and of his wisdom there is no number.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.146.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 6,
      "referenceLabel": "Psalms 146:6",
      "text": "The Lord lifteth up the meek, and bringeth the wicked down even to the ground.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.146.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 7,
      "referenceLabel": "Psalms 146:7",
      "text": "Sing ye to the Lord with praise: sing to our God upon the harp.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.146.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 8,
      "referenceLabel": "Psalms 146:8",
      "text": "Who covereth the heaven with clouds, and prepareth rain for the earth. Who maketh grass to grow on the mountains, and herbs for the service of men.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.146.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 9,
      "referenceLabel": "Psalms 146:9",
      "text": "Who giveth to beasts their food: and to the young ravens that call upon him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.146.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 10,
      "referenceLabel": "Psalms 146:10",
      "text": "He shall not delight in the strength of the horse: nor take pleasure in the legs of a man.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.146.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 11,
      "referenceLabel": "Psalms 146:11",
      "text": "The Lord taketh pleasure in them that fear him: and in them that hope in his mercy.",
      "paragraphStart": false
    }
  ]
}
