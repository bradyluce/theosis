{
  "chapter": {
    "id": "dra:psalms.113",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 113,
    "referenceLabel": "Psalms 113",
    "summary": "Source text for Psalms 113 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.113.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 1,
      "referenceLabel": "Psalms 113:1",
      "text": "When Israel went out of Egypt, the house of Jacob from a barbarous people:",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.113.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 2,
      "referenceLabel": "Psalms 113:2",
      "text": "Judea was made his sanctuary, Israel his dominion.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 3,
      "referenceLabel": "Psalms 113:3",
      "text": "The sea saw and fled: Jordan was turned back.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 4,
      "referenceLabel": "Psalms 113:4",
      "text": "The mountains skipped like rams, and the hills like the lambs of the flock.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 5,
      "referenceLabel": "Psalms 113:5",
      "text": "What ailed thee, O thou sea, that thou didst flee: and thou, O Jordan, that thou wast turned back?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 6,
      "referenceLabel": "Psalms 113:6",
      "text": "Ye mountains, that ye skipped like rams, and ye hills, like lambs of the flock?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 7,
      "referenceLabel": "Psalms 113:7",
      "text": "At the presence of the Lord the earth was moved, at the presence of the God of Jacob:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 8,
      "referenceLabel": "Psalms 113:8",
      "text": "Who turned the rock into pools of water, and the stony hill into fountains of waters.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 9,
      "referenceLabel": "Psalms 113:9",
      "text": "Not to us, O Lord, not to us; but to thy name give glory.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 10,
      "referenceLabel": "Psalms 113:10",
      "text": "For thy mercy, and for thy truth's sake: lest the Gentiles should say: Where is their God?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 11,
      "referenceLabel": "Psalms 113:11",
      "text": "But our God is in heaven: he hath done all things whatsoever he would.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 12,
      "referenceLabel": "Psalms 113:12",
      "text": "The idols of the Gentiles are silver and gold, the works of the hands of men.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 13,
      "referenceLabel": "Psalms 113:13",
      "text": "They have mouths and speak not: they have eyes and see not.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 14,
      "referenceLabel": "Psalms 113:14",
      "text": "They have ears and hear not: they have noses and smell not.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 15,
      "referenceLabel": "Psalms 113:15",
      "text": "They have hands and feel not: they have feet and walk not: neither shall they cry out through their throat.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 16,
      "referenceLabel": "Psalms 113:16",
      "text": "Let them that make them become like unto them: and all such as trust in them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 17,
      "referenceLabel": "Psalms 113:17",
      "text": "The house of Israel hath hoped in the Lord: he is their helper and their protector.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 18,
      "referenceLabel": "Psalms 113:18",
      "text": "The house of Aaron hath hoped in the Lord: he is their helper and their protector.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 19,
      "referenceLabel": "Psalms 113:19",
      "text": "They that fear the Lord have hoped in the Lord: he is their helper and their protector.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 20,
      "referenceLabel": "Psalms 113:20",
      "text": "The Lord hath been mindful of us, and hath blessed us. He hath blessed the house of Israel: he hath blessed the house of Aaron.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 21,
      "referenceLabel": "Psalms 113:21",
      "text": "He hath blessed all that fear the Lord, both little and great.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 22,
      "referenceLabel": "Psalms 113:22",
      "text": "May the Lord add blessings upon you: upon you, and upon your children.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 23,
      "referenceLabel": "Psalms 113:23",
      "text": "Blessed be you of the Lord, who made heaven and earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.24",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 24,
      "referenceLabel": "Psalms 113:24",
      "text": "The heaven of heaven is the Lord's: but the earth he has given to the children of men.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.25",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 25,
      "referenceLabel": "Psalms 113:25",
      "text": "The dead shall not praise thee, O Lord: nor any of them that go down to hell.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.113.26",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 26,
      "referenceLabel": "Psalms 113:26",
      "text": "But we that live bless the Lord: from this time now and for ever.",
      "paragraphStart": false
    }
  ]
}
