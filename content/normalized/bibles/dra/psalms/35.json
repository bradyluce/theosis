{
  "chapter": {
    "id": "dra:psalms.35",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 35,
    "referenceLabel": "Psalms 35",
    "summary": "Source text for Psalms 35 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.35.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 1,
      "referenceLabel": "Psalms 35:1",
      "text": "Unto the end, for the servant of God, David himself.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.35.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 2,
      "referenceLabel": "Psalms 35:2",
      "text": "The unjust hath said within himself, that he would sin: there is no fear of God before his eyes.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.35.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 3,
      "referenceLabel": "Psalms 35:3",
      "text": "For in his sight he hath done deceitfully, that his iniquity may be found unto hatred.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.35.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 4,
      "referenceLabel": "Psalms 35:4",
      "text": "The words of his mouth are iniquity and guile: he would not understand that he might do well.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.35.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 5,
      "referenceLabel": "Psalms 35:5",
      "text": "He hath devised iniquity on his bed, he hath set himself on every way that is not good: but evil he hath not hated.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.35.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 6,
      "referenceLabel": "Psalms 35:6",
      "text": "O Lord, thy mercy is in heaven, and thy truth reacheth even to the clouds.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.35.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 7,
      "referenceLabel": "Psalms 35:7",
      "text": "Thy justice is as the mountains of God, thy judgments are a great deep. Men and beasts thou wilt preserve, O Lord:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.35.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 8,
      "referenceLabel": "Psalms 35:8",
      "text": "O how hast thou multiplied thy mercy, O God! But the children of men shall put their trust under the cover of thy wings.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.35.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 9,
      "referenceLabel": "Psalms 35:9",
      "text": "They shall be inebriated with the plenty of thy house; and thou shalt make them drink of the torrent of thy pleasure.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.35.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 10,
      "referenceLabel": "Psalms 35:10",
      "text": "For with thee is the fountain of life; and in thy light we shall see light.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.35.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 11,
      "referenceLabel": "Psalms 35:11",
      "text": "Extend thy mercy to them that know thee, and thy justice to them that are right in heart.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.35.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 12,
      "referenceLabel": "Psalms 35:12",
      "text": "Let not the foot of pride come to me, and let not the hand of the sinner move me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.35.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 13,
      "referenceLabel": "Psalms 35:13",
      "text": "There the workers of iniquity are fallen, they are cast out, and could not stand.",
      "paragraphStart": false
    }
  ]
}
