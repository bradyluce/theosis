{
  "chapter": {
    "id": "dra:psalms.50",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 50,
    "referenceLabel": "Psalms 50",
    "summary": "Source text for Psalms 50 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.50.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 1,
      "referenceLabel": "Psalms 50:1",
      "text": "Unto the end, a psalm of David,",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.50.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 2,
      "referenceLabel": "Psalms 50:2",
      "text": "When Nathan the prophet came to him, after he had sinned with Bethsabee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.50.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 3,
      "referenceLabel": "Psalms 50:3",
      "text": "Have mercy on me, O God, according to thy great mercy. And according to the multitude of thy tender mercies blot out my iniquity.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.50.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 4,
      "referenceLabel": "Psalms 50:4",
      "text": "Wash me yet more from my iniquity, and cleanse me from my sin.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.50.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 5,
      "referenceLabel": "Psalms 50:5",
      "text": "For I know my iniquity, and my sin is always before me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.50.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 6,
      "referenceLabel": "Psalms 50:6",
      "text": "To thee only have I sinned, and have done evil before thee: that thou mayst be justified in thy words, and mayst overcome when thou art judged.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.50.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 7,
      "referenceLabel": "Psalms 50:7",
      "text": "For behold I was conceived in iniquities; and in sins did my mother conceive me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.50.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 8,
      "referenceLabel": "Psalms 50:8",
      "text": "For behold thou hast loved truth: the uncertain and hidden things of thy wisdom thou hast made manifest to me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.50.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 9,
      "referenceLabel": "Psalms 50:9",
      "text": "Thou shalt sprinkle me with hyssop, and I shall be cleansed: thou shalt wash me, and I shall be made whiter than snow.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.50.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 10,
      "referenceLabel": "Psalms 50:10",
      "text": "To my hearing thou shalt give joy and gladness: and the bones that have been humbled shall rejoice.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.50.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 11,
      "referenceLabel": "Psalms 50:11",
      "text": "Turn away thy face from my sins, and blot out all my iniquities.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.50.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 12,
      "referenceLabel": "Psalms 50:12",
      "text": "Create a clean heart in me, O God: and renew a right spirit within my bowels.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.50.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 13,
      "referenceLabel": "Psalms 50:13",
      "text": "Cast me not away from thy face; and take not thy holy spirit from me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.50.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 14,
      "referenceLabel": "Psalms 50:14",
      "text": "Restore unto me the joy of thy salvation, and strengthen me with a perfect spirit.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.50.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 15,
      "referenceLabel": "Psalms 50:15",
      "text": "I will teach the unjust thy ways: and the wicked shall be converted to thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.50.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 16,
      "referenceLabel": "Psalms 50:16",
      "text": "Deliver me from blood, O God, thou God of my salvation: and my tongue shall extol thy justice.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.50.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 17,
      "referenceLabel": "Psalms 50:17",
      "text": "O Lord, thou wilt open my lips: and my mouth shall declare thy praise.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.50.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 18,
      "referenceLabel": "Psalms 50:18",
      "text": "For if thou hadst desired sacrifice, I would indeed have given it: with burnt offerings thou wilt not be delighted.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.50.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 19,
      "referenceLabel": "Psalms 50:19",
      "text": "A sacrifice to God is an afflicted spirit: a contrite and humbled heart, O God, thou wilt not despise.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.50.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 20,
      "referenceLabel": "Psalms 50:20",
      "text": "Deal favourably, O Lord, in thy good will with Sion; that the walls of Jerusalem may be built up.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.50.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 21,
      "referenceLabel": "Psalms 50:21",
      "text": "Then shalt thou accept the sacrifice of justice, oblations and whole burnt offerings: then shall they lay calves upon thy altar.",
      "paragraphStart": false
    }
  ]
}
