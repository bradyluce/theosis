{
  "chapter": {
    "id": "dra:psalms.86",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 86,
    "referenceLabel": "Psalms 86",
    "summary": "Source text for Psalms 86 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.86.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 1,
      "referenceLabel": "Psalms 86:1",
      "text": "For the sons of Core, a psalm of a canticle. The foundations thereof are the holy mountains:",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.86.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 2,
      "referenceLabel": "Psalms 86:2",
      "text": "The Lord loveth the gates of Sion above all the tabernacles of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.86.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 3,
      "referenceLabel": "Psalms 86:3",
      "text": "Glorious things are said of thee, O city of God.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.86.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 4,
      "referenceLabel": "Psalms 86:4",
      "text": "I will be mindful of Rahab and of Babylon knowing me. Behold the foreigners, and Tyre, and the people of the Ethiopians, these were there.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.86.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 5,
      "referenceLabel": "Psalms 86:5",
      "text": "Shall not Sion say: This man and that man is born in her? and the Highest himself hath founded her.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.86.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 6,
      "referenceLabel": "Psalms 86:6",
      "text": "The Lord shall tell in his writings of peoples and of princes, of them that have been in her.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.86.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 7,
      "referenceLabel": "Psalms 86:7",
      "text": "The dwelling in thee is as it were of all rejoicing.",
      "paragraphStart": false
    }
  ]
}
