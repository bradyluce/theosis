{
  "chapter": {
    "id": "dra:psalms.101",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 101,
    "referenceLabel": "Psalms 101",
    "summary": "Source text for Psalms 101 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.101.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 1,
      "referenceLabel": "Psalms 101:1",
      "text": "The prayer of the poor man, when he was anxious, and poured out his supplication before the Lord.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.101.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 2,
      "referenceLabel": "Psalms 101:2",
      "text": "Hear, O Lord, my prayer: and let my cry come to thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 3,
      "referenceLabel": "Psalms 101:3",
      "text": "Turn not away thy face from me: in the day when I am in trouble, incline thy ear to me. In what day soever I shall call upon thee, hear me speedily.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 4,
      "referenceLabel": "Psalms 101:4",
      "text": "For my days are vanished like smoke, and my bones are grown dry like fuel for the fire.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 5,
      "referenceLabel": "Psalms 101:5",
      "text": "I am smitten as grass, and my heart is withered: because I forgot to eat my bread.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 6,
      "referenceLabel": "Psalms 101:6",
      "text": "Through the voice of my groaning, my bone hath cleaved to my flesh.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 7,
      "referenceLabel": "Psalms 101:7",
      "text": "I am become like to a pelican of the wilderness: I am like a night raven in the house.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 8,
      "referenceLabel": "Psalms 101:8",
      "text": "I have watched, and am become as a sparrow all alone on the housetop.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 9,
      "referenceLabel": "Psalms 101:9",
      "text": "All the day long my enemies reproached me: and they that praised me did swear against me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 10,
      "referenceLabel": "Psalms 101:10",
      "text": "For I did eat ashes like bread, and mingled my drink with weeping.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 11,
      "referenceLabel": "Psalms 101:11",
      "text": "Because of thy anger and indignation: for having lifted me up thou hast thrown me down.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 12,
      "referenceLabel": "Psalms 101:12",
      "text": "My days have declined like a shadow, and I am withered like grass.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 13,
      "referenceLabel": "Psalms 101:13",
      "text": "But thou, O Lord, endurest for ever: and thy memorial to all generations.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 14,
      "referenceLabel": "Psalms 101:14",
      "text": "Thou shalt arise and have mercy on Sion: for it is time to have mercy on it, for the time is come.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 15,
      "referenceLabel": "Psalms 101:15",
      "text": "For the stones thereof have pleased thy servants: and they shall have pity on the earth thereof.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 16,
      "referenceLabel": "Psalms 101:16",
      "text": "All the Gentiles shall fear thy name, O Lord, and all the kings of the earth thy glory.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 17,
      "referenceLabel": "Psalms 101:17",
      "text": "For the Lord hath built up Sion: and he shall be seen in his glory.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 18,
      "referenceLabel": "Psalms 101:18",
      "text": "He hath had regard to the prayer of the humble: and he hath not despised their petition.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 19,
      "referenceLabel": "Psalms 101:19",
      "text": "Let these things be written unto another generation: and the people that shall be created shall praise the Lord:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 20,
      "referenceLabel": "Psalms 101:20",
      "text": "Because he hath looked forth from his high sanctuary: from heaven the Lord hath looked upon the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 21,
      "referenceLabel": "Psalms 101:21",
      "text": "That he might hear the groans of them that are in fetters: that he might release the children of the slain:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 22,
      "referenceLabel": "Psalms 101:22",
      "text": "That they may declare the name of the Lord in Sion: and his praise in Jerusalem;",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 23,
      "referenceLabel": "Psalms 101:23",
      "text": "When the people assemble together, and kings, to serve the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.24",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 24,
      "referenceLabel": "Psalms 101:24",
      "text": "He answered him in the way of his strength: Declare unto me the fewness of my days.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.25",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 25,
      "referenceLabel": "Psalms 101:25",
      "text": "Call me not away in the midst of my days: thy years are unto generation and generation.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.26",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 26,
      "referenceLabel": "Psalms 101:26",
      "text": "In the beginning, O Lord, thou foundedst the earth: and the heavens are the works of thy hands.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.27",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 27,
      "referenceLabel": "Psalms 101:27",
      "text": "They shall perish but thou remainest: and all of them shall grow old like a garment: And as a vesture thou shalt change them, and they shall be changed.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.28",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 28,
      "referenceLabel": "Psalms 101:28",
      "text": "But thou art always the selfsame, and thy years shall not fail.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.101.29",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 29,
      "referenceLabel": "Psalms 101:29",
      "text": "The children of thy servants shall continue and their seed shall be directed for ever.",
      "paragraphStart": false
    }
  ]
}
