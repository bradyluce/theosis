{
  "chapter": {
    "id": "dra:psalms.85",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 85,
    "referenceLabel": "Psalms 85",
    "summary": "Source text for Psalms 85 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.85.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 1,
      "referenceLabel": "Psalms 85:1",
      "text": "A prayer for David himself. Incline thy ear, O Lord, and hear me: for I am needy and poor.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.85.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 2,
      "referenceLabel": "Psalms 85:2",
      "text": "Preserve my soul, for I am holy: save thy servant, O my God, that trusteth in thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.85.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 3,
      "referenceLabel": "Psalms 85:3",
      "text": "Have mercy on me, O Lord, for I have cried to thee all the day.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.85.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 4,
      "referenceLabel": "Psalms 85:4",
      "text": "Give joy to the soul of thy servant, for to thee, O Lord, I have lifted up my soul.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.85.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 5,
      "referenceLabel": "Psalms 85:5",
      "text": "For thou, O Lord, art sweet and mild: and plenteous in mercy to all that call upon thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.85.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 6,
      "referenceLabel": "Psalms 85:6",
      "text": "Give ear, O Lord, to my prayer: and attend to the voice of my petition.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.85.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 7,
      "referenceLabel": "Psalms 85:7",
      "text": "I have called upon thee in the day of my trouble: because thou hast heard me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.85.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 8,
      "referenceLabel": "Psalms 85:8",
      "text": "There is none among the gods like unto thee, O Lord: and there is none according to thy works.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.85.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 9,
      "referenceLabel": "Psalms 85:9",
      "text": "All the nations thou hast made shall come and adore before thee, O Lord: and they shall glorify thy name.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.85.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 10,
      "referenceLabel": "Psalms 85:10",
      "text": "For thou art great and dost wonderful things: thou art God alone.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.85.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 11,
      "referenceLabel": "Psalms 85:11",
      "text": "Conduct me, O Lord, in thy way, and I will walk in thy truth: let my heart rejoice that it may fear thy name.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.85.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 12,
      "referenceLabel": "Psalms 85:12",
      "text": "I will praise thee, O Lord my God, with my whole heart, and I will glorify thy name for ever:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.85.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 13,
      "referenceLabel": "Psalms 85:13",
      "text": "For thy mercy is great towards me: and thou hast delivered my soul out of the lower hell.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.85.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 14,
      "referenceLabel": "Psalms 85:14",
      "text": "O God, the wicked are risen up against me, and the assembly of the mighty have sought my soul: and they have not set thee before their eyes.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.85.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 15,
      "referenceLabel": "Psalms 85:15",
      "text": "And thou, O Lord, art a God of compassion, and merciful, patient, and of much mercy, and true.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.85.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 16,
      "referenceLabel": "Psalms 85:16",
      "text": "O look upon me, and have mercy on me: give thy command to thy servant, and save the son of thy handmaid.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.85.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 17,
      "referenceLabel": "Psalms 85:17",
      "text": "Shew me a token for good: that they who hate me may see, and be confounded, because thou, O Lord, hast helped me and hast comforted me.",
      "paragraphStart": false
    }
  ]
}
