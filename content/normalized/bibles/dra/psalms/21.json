{
  "chapter": {
    "id": "dra:psalms.21",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 21,
    "referenceLabel": "Psalms 21",
    "summary": "Source text for Psalms 21 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.21.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Psalms 21:1",
      "text": "Unto the end, for the morning protection, a psalm for David.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.21.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Psalms 21:2",
      "text": "O God my God, look upon me: why hast thou forsaken me? Far from my salvation are the words of my sins.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Psalms 21:3",
      "text": "O my God, I shall cry by day, and thou wilt not hear: and by night, and it shall not be reputed as folly in me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Psalms 21:4",
      "text": "But thou dwellest in the holy place, the praise of Israel.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Psalms 21:5",
      "text": "In thee have our fathers hoped: they have hoped, and thou hast delivered them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Psalms 21:6",
      "text": "They cried to thee, and they were saved: they trusted in thee, and were not confounded.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Psalms 21:7",
      "text": "But I am a worm, and no man: the reproach of men, and the outcast of the people.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Psalms 21:8",
      "text": "All they that saw me have laughed me to scorn: they have spoken with the lips, and wagged the head.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Psalms 21:9",
      "text": "He hoped in the Lord, let him deliver him: let him save him, seeing he delighteth in him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Psalms 21:10",
      "text": "For thou art he that hast drawn me out of the womb: my hope from the breasts of my mother.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Psalms 21:11",
      "text": "I was cast upon thee from the womb. From my mother's womb thou art my God,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Psalms 21:12",
      "text": "Depart not from me. For tribulation is very near: for there is none to help me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Psalms 21:13",
      "text": "Many calves have surrounded me: fat bulls have besieged me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Psalms 21:14",
      "text": "They have opened their mouths against me, as a lion ravening and roaring.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Psalms 21:15",
      "text": "I am poured out like water; and all my bones are scattered. My heart is become like wax melting in the midst of my bowels.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Psalms 21:16",
      "text": "My strength is dried up like a potsherd, and my tongue hath cleaved to my jaws: and thou hast brought me down into the dust of death.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Psalms 21:17",
      "text": "For many dogs have encompassed me: the council of the malignant hath besieged me. They have dug my hands and feet.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Psalms 21:18",
      "text": "They have numbered all my bones. And they have looked and stared upon me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Psalms 21:19",
      "text": "They parted my garments amongst them; and upon my vesture they cast lots.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Psalms 21:20",
      "text": "But thou, O Lord, remove not thy help to a distance from me; look towards my defence.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Psalms 21:21",
      "text": "Deliver, O God, my soul from the sword: my only one from the hand of the dog.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Psalms 21:22",
      "text": "Save me from the lion's mouth; and my lowness from the horns of the unicorns.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Psalms 21:23",
      "text": "I will declare thy name to my brethren: in the midst of the church will I praise thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.24",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Psalms 21:24",
      "text": "Ye that fear the Lord, praise him: all ye the seed of Jacob, glorify him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.25",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Psalms 21:25",
      "text": "Let all the seed of Israel fear him: because he hath not slighted nor despised the supplication of the poor man. Neither hath he turned away his face from me: and when I cried to him he heard me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.26",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Psalms 21:26",
      "text": "With thee is my praise in a great church: I will pay my vows in the sight of them that fear him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.27",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Psalms 21:27",
      "text": "The poor shall eat and shall be filled: and they shall praise the Lord that seek him: their hearts shall live for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.28",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Psalms 21:28",
      "text": "All the ends of the earth shall remember, and shall be converted to the Lord: And all the kindreds of the Gentiles shall adore in his sight.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.29",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Psalms 21:29",
      "text": "For the kingdom is the Lord's; and he shall have dominion over the nations.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.30",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Psalms 21:30",
      "text": "All the fat ones of the earth have eaten and have adored: all they that go down to the earth shall fall before him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.31",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Psalms 21:31",
      "text": "And to him my soul shall live: and my seed shall serve him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.21.32",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 32,
      "referenceLabel": "Psalms 21:32",
      "text": "There shall be declared to the Lord a generation to come: and the heavens shall shew forth his justice to a people that shall be born, which the Lord hath made.",
      "paragraphStart": false
    }
  ]
}
