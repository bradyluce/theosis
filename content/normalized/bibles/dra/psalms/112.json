{
  "chapter": {
    "id": "dra:psalms.112",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 112,
    "referenceLabel": "Psalms 112",
    "summary": "Source text for Psalms 112 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.112.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 1,
      "referenceLabel": "Psalms 112:1",
      "text": "Praise the Lord, ye children: praise ye the name of the Lord.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.112.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 2,
      "referenceLabel": "Psalms 112:2",
      "text": "Blessed be the name of the Lord, from henceforth now and for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.112.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 3,
      "referenceLabel": "Psalms 112:3",
      "text": "From the rising of the sun unto the going down of the same, the name of the Lord is worthy of praise.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.112.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 4,
      "referenceLabel": "Psalms 112:4",
      "text": "The Lord is high above all nations; and his glory above the heavens.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.112.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 5,
      "referenceLabel": "Psalms 112:5",
      "text": "Who is as the Lord our God, who dwelleth on high:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.112.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 6,
      "referenceLabel": "Psalms 112:6",
      "text": "and looketh down on the low things in heaven and in earth?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.112.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 7,
      "referenceLabel": "Psalms 112:7",
      "text": "Raising up the needy from the earth, and lifting up the poor out of the dunghill:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.112.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 8,
      "referenceLabel": "Psalms 112:8",
      "text": "That he may place him with princes, with the princes of his people.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.112.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 9,
      "referenceLabel": "Psalms 112:9",
      "text": "Who maketh a barren woman to dwell in a house, the joyful mother of children.",
      "paragraphStart": false
    }
  ]
}
