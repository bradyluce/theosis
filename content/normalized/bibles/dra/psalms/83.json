{
  "chapter": {
    "id": "dra:psalms.83",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 83,
    "referenceLabel": "Psalms 83",
    "summary": "Source text for Psalms 83 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.83.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 1,
      "referenceLabel": "Psalms 83:1",
      "text": "Unto the end, for the winepresses, a psalm for the sons of Core.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.83.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 2,
      "referenceLabel": "Psalms 83:2",
      "text": "How lovely are thy tabernacles, O Lord of hosts!",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.83.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 3,
      "referenceLabel": "Psalms 83:3",
      "text": "my soul longeth and fainteth for the courts of the Lord. My heart and my flesh have rejoiced in the living God.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.83.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 4,
      "referenceLabel": "Psalms 83:4",
      "text": "For the sparrow hath found herself a house, and the turtle a nest for herself where she may lay her young ones: Thy altars, O Lord of hosts, my king and my God.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.83.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 5,
      "referenceLabel": "Psalms 83:5",
      "text": "Blessed are they that dwell in thy house, O Lord: they shall praise thee for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.83.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 6,
      "referenceLabel": "Psalms 83:6",
      "text": "Blessed is the man whose help is from thee: in his heart he hath disposed to ascend by steps,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.83.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 7,
      "referenceLabel": "Psalms 83:7",
      "text": "In the vale of tears, in the place which he hath set.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.83.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 8,
      "referenceLabel": "Psalms 83:8",
      "text": "For the lawgiver shall give a blessing, they shall go from virtue to virtue: the God of gods shall be seen in Sion.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.83.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 9,
      "referenceLabel": "Psalms 83:9",
      "text": "O Lord God of hosts, hear my prayer: give ear, O God of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.83.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 10,
      "referenceLabel": "Psalms 83:10",
      "text": "Behold, O God our protector: and look on the face of thy Christ.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.83.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 11,
      "referenceLabel": "Psalms 83:11",
      "text": "For better is one day in thy courts above thousands. I have chosen to be an abject in the house of my God, rather than to dwell in the tabernacles of sinners.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.83.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 12,
      "referenceLabel": "Psalms 83:12",
      "text": "For God loveth mercy and truth: the Lord will give grace and glory.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.83.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 13,
      "referenceLabel": "Psalms 83:13",
      "text": "He will not deprive of good things them that walk in innocence: O Lord of hosts, blessed is the man that trusteth in thee.",
      "paragraphStart": false
    }
  ]
}
