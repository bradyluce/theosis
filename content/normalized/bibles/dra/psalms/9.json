{
  "chapter": {
    "id": "dra:psalms.9",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 9,
    "referenceLabel": "Psalms 9",
    "summary": "Source text for Psalms 9 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.9.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Psalms 9:1",
      "text": "Unto the end, for the hidden things of the Son. A psalm for David.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.9.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Psalms 9:2",
      "text": "I will give praise to thee, O Lord, with my whole heart: I will relate all thy wonders.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Psalms 9:3",
      "text": "I will be glad, and rejoice in thee: I will sing to thy name, O thou most high.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Psalms 9:4",
      "text": "When my enemy shall be turned back: they shall be weakened, and perish before thy face.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Psalms 9:5",
      "text": "For thou hast maintained my judgment and my cause: thou hast sat on the throne, who judgest justice.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Psalms 9:6",
      "text": "Thou hast rebuked the Gentiles, and the wicked one hath perished; thou hast blotted out their name for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Psalms 9:7",
      "text": "The swords of the enemy have failed unto the end: and their cities thou hast destroyed. Their memory hath perished with a noise:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Psalms 9:8",
      "text": "But the Lord remaineth for ever. He hath prepared his throne in judgment:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Psalms 9:9",
      "text": "And he shall judge the world in equity, he shall judge the people in justice.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Psalms 9:10",
      "text": "And the Lord is become a refuge for the poor: a helper in due time in tribulation.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Psalms 9:11",
      "text": "And let them trust in thee who know thy name: for thou hast not forsaken them that seek thee, O Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Psalms 9:12",
      "text": "Sing ye to the Lord, who dwelleth in Sion: declare his ways among the Gentiles:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Psalms 9:13",
      "text": "For requiring their blood, he hath remembered them: he hath not forgotten the cry of the poor.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Psalms 9:14",
      "text": "Have mercy on me, O Lord: see my humiliation which I suffer from my enemies.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Psalms 9:15",
      "text": "Thou that liftest me up from the gates of death, that I may declare all thy praises in the gates of the daughter of Sion.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Psalms 9:16",
      "text": "I will rejoice in thy salvation: the Gentiles have stuck fast in the destruction which they prepared. Their foot hath been taken in the very snare which they hid.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Psalms 9:17",
      "text": "The Lord shall be known when he executeth judgments: the sinner hath been caught in the works of his own hands.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Psalms 9:18",
      "text": "The wicked shall be turned into hell, all the nations that forget God.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Psalms 9:19",
      "text": "For the poor man shall not be forgotten to the end: the patience of the poor shall not perish for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Psalms 9:20",
      "text": "Arise, O Lord, let not man be strengthened: let the Gentiles be judged in thy sight.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Psalms 9:21",
      "text": "Appoint, O Lord, a lawgiver over them: that the Gentiles may know themselves to be but men.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "Psalms 9:22",
      "text": "Why, O Lord, hast thou retired afar off? why dost thou slight us in our wants, in the time of trouble?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "Psalms 9:23",
      "text": "Whilst the wicked man is proud, the poor is set on fire: they are caught in the counsels which they devise.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.24",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "Psalms 9:24",
      "text": "For the sinner is praised in the desires of his soul: and the unjust man is blessed.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.25",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "Psalms 9:25",
      "text": "The sinner hath provoked the Lord according to the multitude of his wrath he will not seek him:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.26",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "Psalms 9:26",
      "text": "God is not before his eyes: his ways are filthy at all times. Thy judgments are removed from his sight: he shall rule over all his enemies.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.27",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "Psalms 9:27",
      "text": "For he hath said in his heart: I shall not be moved from generation to generation, and shall be without evil.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.28",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "Psalms 9:28",
      "text": "His mouth is full of cursing, and of bitterness, and of deceit: under his tongue are labor and sorrow.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.29",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 29,
      "referenceLabel": "Psalms 9:29",
      "text": "He sits in ambush with the rich in private places, that he may kill the innocent.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.30",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 30,
      "referenceLabel": "Psalms 9:30",
      "text": "His eyes are upon the poor man: He lieth in wait in secret like a lion in his den. He lieth in ambush that he may catch the poor man: to catch the poor, whilst he draweth him to him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.31",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 31,
      "referenceLabel": "Psalms 9:31",
      "text": "In his net he will bring him down, he will crouch and fall, when he shall have power over the poor.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.32",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 32,
      "referenceLabel": "Psalms 9:32",
      "text": "For he hath said in his heart: God hath forgotten, he hath turned away his face not to see to the end.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.33",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 33,
      "referenceLabel": "Psalms 9:33",
      "text": "Arise, O Lord God, let thy hand be exalted: forget not the poor.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.34",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 34,
      "referenceLabel": "Psalms 9:34",
      "text": "Wherefore hath the wicked provoked God? for he hath said in his heart: He will not require it.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.35",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 35,
      "referenceLabel": "Psalms 9:35",
      "text": "Thou seest it, for thou considerest labour and sorrow: that thou mayst deliver them into thy hands. To thee is the poor man left: thou wilt be a helper to the orphan.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.36",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 36,
      "referenceLabel": "Psalms 9:36",
      "text": "Break thou the arm of the sinner and of the malignant: his sin shall be sought, and shall not be found.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.37",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 37,
      "referenceLabel": "Psalms 9:37",
      "text": "The Lord shall reign to eternity, yea, for ever and ever: ye Gentiles shall perish from his land.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.38",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 38,
      "referenceLabel": "Psalms 9:38",
      "text": "The Lord hath heard the desire of the poor: thy ear hath heard the preparation of their heart.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.9.39",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 39,
      "referenceLabel": "Psalms 9:39",
      "text": "To judge for the fatherless and for the humble, that man may no more presume to magnify himself upon earth.",
      "paragraphStart": false
    }
  ]
}
