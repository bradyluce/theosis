{
  "chapter": {
    "id": "dra:psalms.120",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 120,
    "referenceLabel": "Psalms 120",
    "summary": "Source text for Psalms 120 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.120.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 1,
      "referenceLabel": "Psalms 120:1",
      "text": "I have lifted up my eyes to the mountains, from whence help shall come to me.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.120.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 2,
      "referenceLabel": "Psalms 120:2",
      "text": "My help is from the Lord, who made heaven and earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.120.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 3,
      "referenceLabel": "Psalms 120:3",
      "text": "May he not suffer thy foot to be moved: neither let him slumber that keepeth thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.120.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 4,
      "referenceLabel": "Psalms 120:4",
      "text": "Behold he shall neither slumber nor sleep, that keepeth Israel.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.120.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 5,
      "referenceLabel": "Psalms 120:5",
      "text": "The Lord is thy keeper, the Lord is thy protection upon thy right hand.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.120.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 6,
      "referenceLabel": "Psalms 120:6",
      "text": "The sun shall not burn thee by day: nor the moon by night.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.120.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 7,
      "referenceLabel": "Psalms 120:7",
      "text": "The Lord keepeth thee from all evil: may the Lord keep thy soul.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.120.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 8,
      "referenceLabel": "Psalms 120:8",
      "text": "May the Lord keep thy coming in and thy going out; from henceforth now and for ever.",
      "paragraphStart": false
    }
  ]
}
