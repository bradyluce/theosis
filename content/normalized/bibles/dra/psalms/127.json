    "bookSlug": "psalms",
    "chapterNumber": 127,
    "referenceLabel": "Psalms 127",
    "summary": "Source text for Psalms 127 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.127.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 127,
      "verseNumber": 1,
      "referenceLabel": "Psalms 127:1",
      "text": "A gradual canticle. Blessed are all they that fear the Lord: that walk in his ways.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.127.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 127,
      "verseNumber": 2,
      "referenceLabel": "Psalms 127:2",
      "text": "For thou shalt eat the labours of thy hands: blessed art thou, and it shall be well with thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.127.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 127,
      "verseNumber": 3,
      "referenceLabel": "Psalms 127:3",
      "text": "Thy wife as a fruitful vine, on the sides of thy house. Thy children as olive plants, round about thy table.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.127.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 127,
      "verseNumber": 4,
      "referenceLabel": "Psalms 127:4",
      "text": "Behold, thus shall the man be blessed that feareth the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.127.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 127,
      "verseNumber": 5,
      "referenceLabel": "Psalms 127:5",
      "text": "May the Lord bless thee out of Sion: and mayst thou see the good things of Jerusalem all the days of thy life.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.127.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 127,
      "verseNumber": 6,
      "referenceLabel": "Psalms 127:6",
      "text": "And mayst thou see thy children's children, peace upon Israel.",
      "paragraphStart": false
    }
  ]
}
