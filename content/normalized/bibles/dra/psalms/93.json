{
  "chapter": {
    "id": "dra:psalms.93",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 93,
    "referenceLabel": "Psalms 93",
    "summary": "Source text for Psalms 93 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.93.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 1,
      "referenceLabel": "Psalms 93:1",
      "text": "The Lord is the God to whom revenge belongeth: the God of revenge hath acted freely.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.93.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 2,
      "referenceLabel": "Psalms 93:2",
      "text": "Lift up thyself, thou that judgest the earth: render a reward to the proud.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 3,
      "referenceLabel": "Psalms 93:3",
      "text": "How long shall sinners, O Lord: how long shall sinners glory?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 4,
      "referenceLabel": "Psalms 93:4",
      "text": "Shall they utter, and speak iniquity: shall all speak who work injustice?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 5,
      "referenceLabel": "Psalms 93:5",
      "text": "Thy people, O Lord, they have brought low: and they have afflicted thy inheritance.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 6,
      "referenceLabel": "Psalms 93:6",
      "text": "They have slain the widow and the stranger: and they have murdered the fatherless.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 7,
      "referenceLabel": "Psalms 93:7",
      "text": "And they have said: The Lord shall not see: neither shall the God of Jacob understand.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 8,
      "referenceLabel": "Psalms 93:8",
      "text": "Understand, ye senseless among the people: and, you fools, be wise at last.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 9,
      "referenceLabel": "Psalms 93:9",
      "text": "He that planted the ear, shall he not hear? or he that formed the eye, doth he not consider?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 10,
      "referenceLabel": "Psalms 93:10",
      "text": "He that chastiseth nations, shall he not rebuke: he that teacheth man knowledge?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 11,
      "referenceLabel": "Psalms 93:11",
      "text": "The Lord knoweth the thoughts of men, that they are vain.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 12,
      "referenceLabel": "Psalms 93:12",
      "text": "Blessed is the man whom thou shalt instruct, O Lord: and shalt teach him out of thy law.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 13,
      "referenceLabel": "Psalms 93:13",
      "text": "That thou mayst give him rest from the evil days: till a pit be dug for the wicked.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 14,
      "referenceLabel": "Psalms 93:14",
      "text": "For the Lord will not cast off his people: neither will he forsake his own inheritance.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 15,
      "referenceLabel": "Psalms 93:15",
      "text": "Until justice be turned into judgment: and they that are near it are all the upright in heart.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 16,
      "referenceLabel": "Psalms 93:16",
      "text": "Who shall rise up for me against the evildoers? or who shall stand with me against the workers of iniquity?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 17,
      "referenceLabel": "Psalms 93:17",
      "text": "Unless the Lord had been my helper, my soul had almost dwelt in hell.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 18,
      "referenceLabel": "Psalms 93:18",
      "text": "If I said: My foot is moved: thy mercy, O Lord, assisted me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 19,
      "referenceLabel": "Psalms 93:19",
      "text": "According to the multitude of my sorrows in my heart, thy comforts have given joy to my soul.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 20,
      "referenceLabel": "Psalms 93:20",
      "text": "Doth the seat of iniquity stick to thee, who framest labour in commandment?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 21,
      "referenceLabel": "Psalms 93:21",
      "text": "They will hunt after the soul of the just, and will condemn innocent blood.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 22,
      "referenceLabel": "Psalms 93:22",
      "text": "But the Lord is my refuge: and my God the help of my hope.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.93.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 23,
      "referenceLabel": "Psalms 93:23",
      "text": "And he will render them their iniquity: and in their malice he will destroy them: the Lord our God will destroy them.",
      "paragraphStart": false
    }
  ]
}
