{
  "chapter": {
    "id": "dra:psalms.66",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 66,
    "referenceLabel": "Psalms 66",
    "summary": "Source text for Psalms 66 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.66.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 1,
      "referenceLabel": "Psalms 66:1",
      "text": "Unto the end, in hymns, a psalm of a canticle for David.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.66.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 2,
      "referenceLabel": "Psalms 66:2",
      "text": "May God have mercy on us, and bless us: may he cause the light of his countenance to shine upon us, and may he have mercy on us.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.66.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 3,
      "referenceLabel": "Psalms 66:3",
      "text": "That we may know thy way upon earth: thy salvation in all nations.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.66.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 4,
      "referenceLabel": "Psalms 66:4",
      "text": "Let people confess to thee, O God: let all people give praise to thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.66.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 5,
      "referenceLabel": "Psalms 66:5",
      "text": "Let the nations be glad and rejoice: for thou judgest the people with justice, and directest the nations upon earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.66.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 6,
      "referenceLabel": "Psalms 66:6",
      "text": "Let the people, O God, confess to thee: let all the people give praise to thee:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.66.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 7,
      "referenceLabel": "Psalms 66:7",
      "text": "The earth hath yielded her fruit. May God, our God bless us,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.66.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 8,
      "referenceLabel": "Psalms 66:8",
      "text": "May God bless us: and all the ends of the earth fear him.",
      "paragraphStart": false
    }
  ]
}
