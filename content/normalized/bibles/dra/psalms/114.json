{
  "chapter": {
    "id": "dra:psalms.114",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 114,
    "referenceLabel": "Psalms 114",
    "summary": "Source text for Psalms 114 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.114.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 1,
      "referenceLabel": "Psalms 114:1",
      "text": "I have loved, because the Lord will hear the voice of my prayer.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.114.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 2,
      "referenceLabel": "Psalms 114:2",
      "text": "Because he hath inclined his ear unto me: and in my days I will call upon him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.114.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 3,
      "referenceLabel": "Psalms 114:3",
      "text": "The sorrows of death have compassed me: and the perils of hell have found me. I met with trouble and sorrow:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.114.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 4,
      "referenceLabel": "Psalms 114:4",
      "text": "And I called upon the name of the Lord. O Lord, deliver my soul.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.114.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 5,
      "referenceLabel": "Psalms 114:5",
      "text": "The Lord is merciful and just, and our God sheweth mercy.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.114.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 6,
      "referenceLabel": "Psalms 114:6",
      "text": "The Lord is the keeper of little ones: I was humbled, and he delivered me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.114.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 7,
      "referenceLabel": "Psalms 114:7",
      "text": "Turn, O my soul, into thy rest: for the Lord hath been bountiful to thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.114.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 8,
      "referenceLabel": "Psalms 114:8",
      "text": "For he hath delivered my soul from death: my eyes from tears, my feet from falling.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.114.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 9,
      "referenceLabel": "Psalms 114:9",
      "text": "I will please the Lord in the land of the living.",
      "paragraphStart": false
    }
  ]
}
