{
  "chapter": {
    "id": "dra:psalms.129",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 129,
    "referenceLabel": "Psalms 129",
    "summary": "Source text for Psalms 129 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.129.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 1,
      "referenceLabel": "Psalms 129:1",
      "text": "A gradual canticle. Out of the depths I have cried to thee, O Lord:",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.129.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 2,
      "referenceLabel": "Psalms 129:2",
      "text": "Lord, hear my voice. Let thy ears be attentive to the voice of my supplication.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.129.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 3,
      "referenceLabel": "Psalms 129:3",
      "text": "If thou, O Lord, wilt mark iniquities: Lord, who shall stand it.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.129.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 4,
      "referenceLabel": "Psalms 129:4",
      "text": "For with thee there is merciful forgiveness: and by reason of thy law, I have waited for thee, O Lord. My soul hath relied on his word:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.129.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 5,
      "referenceLabel": "Psalms 129:5",
      "text": "my soul hath hoped in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.129.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 6,
      "referenceLabel": "Psalms 129:6",
      "text": "From the morning watch even until night, let Israel hope in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.129.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 7,
      "referenceLabel": "Psalms 129:7",
      "text": "Because with the Lord there is mercy: and with him plentiful redemption.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.129.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 8,
      "referenceLabel": "Psalms 129:8",
      "text": "And he shall redeem Israel from all his iniquities.",
      "paragraphStart": false
    }
  ]
}
