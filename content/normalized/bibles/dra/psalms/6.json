{
  "chapter": {
    "id": "dra:psalms.6",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 6,
    "referenceLabel": "Psalms 6",
    "summary": "Source text for Psalms 6 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.6.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Psalms 6:1",
      "text": "Unto the end, in verses, a psalm for David, for the octave.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.6.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Psalms 6:2",
      "text": "O Lord, rebuke me not in thy indignation, nor chastise me in thy wrath.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.6.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Psalms 6:3",
      "text": "Have mercy on me, O Lord, for I am weak: heal me, O Lord, for my bones are troubled.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.6.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Psalms 6:4",
      "text": "And my soul is troubled exceedingly: but thou, O Lord, how long?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.6.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Psalms 6:5",
      "text": "Turn to me, O Lord, and deliver my soul: O save me for thy mercy's sake.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.6.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Psalms 6:6",
      "text": "For there is no one in death, that is mindful of thee: and who shall confess to thee in hell?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.6.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Psalms 6:7",
      "text": "I have laboured in my groanings, every night I will wash my bed: I will water my couch with my tears.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.6.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Psalms 6:8",
      "text": "My eye is troubled through indignation: I have grown old amongst all my enemies.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.6.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Psalms 6:9",
      "text": "Depart from me, all ye workers of iniquity: for the Lord hath heard the voice of my weeping.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.6.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Psalms 6:10",
      "text": "The Lord hath heard my supplication: the Lord hath received my prayer.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.6.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Psalms 6:11",
      "text": "Let all my enemies be ashamed, and be very much troubled: let them be turned back, and be ashamed very speedily.",
      "paragraphStart": false
    }
  ]
}
