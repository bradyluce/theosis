{
  "chapter": {
    "id": "dra:psalms.75",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 75,
    "referenceLabel": "Psalms 75",
    "summary": "Source text for Psalms 75 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.75.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 1,
      "referenceLabel": "Psalms 75:1",
      "text": "Unto the end, in praises, a psalm for Asaph: a canticle to the Assyrians.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.75.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 2,
      "referenceLabel": "Psalms 75:2",
      "text": "In Judea God is known: his name is great in Israel.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.75.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 3,
      "referenceLabel": "Psalms 75:3",
      "text": "And his place is in peace: and his abode in Sion:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.75.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 4,
      "referenceLabel": "Psalms 75:4",
      "text": "There hath he broken the powers of bows, the shield, the sword, and the battle.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.75.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 5,
      "referenceLabel": "Psalms 75:5",
      "text": "Thou enlightenest wonderfully from the everlasting hills.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.75.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 6,
      "referenceLabel": "Psalms 75:6",
      "text": "All the foolish of heart were troubled. They have slept their sleep; and all the men of riches have found nothing in their hands.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.75.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 7,
      "referenceLabel": "Psalms 75:7",
      "text": "At thy rebuke, O God of Jacob, they have all slumbered that mounted on horseback.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.75.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 8,
      "referenceLabel": "Psalms 75:8",
      "text": "Thou art terrible, and who shall resist thee? from that time thy wrath.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.75.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 9,
      "referenceLabel": "Psalms 75:9",
      "text": "Thou hast caused judgment to be heard from heaven: the earth trembled and was still,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.75.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 10,
      "referenceLabel": "Psalms 75:10",
      "text": "When God arose in judgment, to save all the meek of the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.75.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 11,
      "referenceLabel": "Psalms 75:11",
      "text": "For the thought of man shall give praise to thee: and the remainders of the thought shall keep holiday to thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.75.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 12,
      "referenceLabel": "Psalms 75:12",
      "text": "Vow ye, and pay to the Lord your God: all you that are round about him bring presents. To him that is terrible,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.75.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 13,
      "referenceLabel": "Psalms 75:13",
      "text": "Even to him who taketh away the spirit of princes: to the terrible with the kings of the earth.",
      "paragraphStart": false
    }
  ]
}
