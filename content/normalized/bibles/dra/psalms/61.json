{
  "chapter": {
    "id": "dra:psalms.61",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 61,
    "referenceLabel": "Psalms 61",
    "summary": "Source text for Psalms 61 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.61.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 1,
      "referenceLabel": "Psalms 61:1",
      "text": "Unto the end, for Idithun, a psalm of David.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.61.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 2,
      "referenceLabel": "Psalms 61:2",
      "text": "Shall not my soul be subject to God? for from him is my salvation.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.61.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 3,
      "referenceLabel": "Psalms 61:3",
      "text": "For he is my God and my saviour: he is my protector, I shall be moved no more.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.61.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 4,
      "referenceLabel": "Psalms 61:4",
      "text": "How long do you rush in upon a man? you all kill, as if you were thrusting down a leaning wall, and a tottering fence.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.61.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 5,
      "referenceLabel": "Psalms 61:5",
      "text": "But they have thought to cast away my price; I ran in thirst: they blessed with their mouth, but cursed with their heart.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.61.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 6,
      "referenceLabel": "Psalms 61:6",
      "text": "But be thou, O my soul, subject to God: for from him is my patience.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.61.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 7,
      "referenceLabel": "Psalms 61:7",
      "text": "For he is my God and my saviour: he is my helper, I shall not be moved.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.61.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 8,
      "referenceLabel": "Psalms 61:8",
      "text": "In God is my salvation and my glory: he is the God of my help, and my hope is in God.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.61.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 9,
      "referenceLabel": "Psalms 61:9",
      "text": "Trust in him, all ye congregation of people: pour out your hearts before him. God is our helper for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.61.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 10,
      "referenceLabel": "Psalms 61:10",
      "text": "But vain are the sons of men, the sons of men are liars in the balances: that by vanity they may together deceive.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.61.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 11,
      "referenceLabel": "Psalms 61:11",
      "text": "Trust not in iniquity, and covet not robberies: if riches abound, set not your heart upon them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.61.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 12,
      "referenceLabel": "Psalms 61:12",
      "text": "God hath spoken once, these two things have I heard, that power belongeth to God,",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.61.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 13,
      "referenceLabel": "Psalms 61:13",
      "text": "And mercy to thee, O Lord; for thou wilt render to every man according to his works.",
      "paragraphStart": false
    }
  ]
}
