{
  "chapter": {
    "id": "dra:psalms.149",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 149,
    "referenceLabel": "Psalms 149",
    "summary": "Source text for Psalms 149 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.149.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 1,
      "referenceLabel": "Psalms 149:1",
      "text": "Sing ye to the Lord a new canticle: let his praise be in the church of the saints.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.149.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 2,
      "referenceLabel": "Psalms 149:2",
      "text": "Let Israel rejoice in him that made him: and let the children of Sion be joyful in their king.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.149.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 3,
      "referenceLabel": "Psalms 149:3",
      "text": "Let them praise his name in choir: let them sing to him with the timbrel and the psaltery.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.149.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 4,
      "referenceLabel": "Psalms 149:4",
      "text": "For the Lord is well pleased with his people: and he will exalt the meek unto salvation.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.149.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 5,
      "referenceLabel": "Psalms 149:5",
      "text": "The saints shall rejoice in glory: they shall be joyful in their beds.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.149.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 6,
      "referenceLabel": "Psalms 149:6",
      "text": "The high praises of God shall be in their mouth: and two-edged swords in their hands:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.149.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 7,
      "referenceLabel": "Psalms 149:7",
      "text": "To execute vengeance upon the nations, chastisements among the people:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.149.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 8,
      "referenceLabel": "Psalms 149:8",
      "text": "To bind their kings with fetters, and their nobles with manacles of iron.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.149.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 9,
      "referenceLabel": "Psalms 149:9",
      "text": "To execute upon them the judgment that is written: this glory is to all his saints. Alleluia.",
      "paragraphStart": false
    }
  ]
}
