{
  "chapter": {
    "id": "dra:psalms.88",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 88,
    "referenceLabel": "Psalms 88",
    "summary": "Source text for Psalms 88 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.88.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 1,
      "referenceLabel": "Psalms 88:1",
      "text": "Of understanding, for Ethan the Ezrahite.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.88.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 2,
      "referenceLabel": "Psalms 88:2",
      "text": "The mercies of the Lord I will sing for ever. I will shew forth thy truth with my mouth to generation and generation.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 3,
      "referenceLabel": "Psalms 88:3",
      "text": "For thou hast said: Mercy shall be built up for ever in the heavens: thy truth shall be prepared in them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 4,
      "referenceLabel": "Psalms 88:4",
      "text": "I have made a covenant with my elect: I have sworn to David my servant:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 5,
      "referenceLabel": "Psalms 88:5",
      "text": "Thy seed will I settle for ever. And I will build up thy throne unto generation and generation.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 6,
      "referenceLabel": "Psalms 88:6",
      "text": "The heavens shall confess thy wonders, O Lord: and thy truth in the church of the saints.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 7,
      "referenceLabel": "Psalms 88:7",
      "text": "For who in the clouds can be compared to the Lord: or who among the sons of God shall be like to God?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 8,
      "referenceLabel": "Psalms 88:8",
      "text": "God, who is glorified in the assembly of the saints: great and terrible above all them that are about him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 9,
      "referenceLabel": "Psalms 88:9",
      "text": "O Lord God of hosts, who is like to thee? thou art mighty, O Lord, and thy truth is round about thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 10,
      "referenceLabel": "Psalms 88:10",
      "text": "Thou rulest the power of the sea: and appeasest the motion of the waves thereof.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 11,
      "referenceLabel": "Psalms 88:11",
      "text": "Thou hast humbled the proud one, as one that is slain: with the arm of thy strength thou hast scattered thy enemies.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 12,
      "referenceLabel": "Psalms 88:12",
      "text": "Thine are the heavens, and thine is the earth: the world and the fulness thereof thou hast founded:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 13,
      "referenceLabel": "Psalms 88:13",
      "text": "The north and the sea thou hast created. Thabor and Hermon shall rejoice in thy name:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 14,
      "referenceLabel": "Psalms 88:14",
      "text": "Thy arm is with might. Let thy hand be strengthened, and thy right hand exalted:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.15",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 15,
      "referenceLabel": "Psalms 88:15",
      "text": "Justice and judgment are the preparation of thy throne. Mercy and truth shall go before thy face:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.16",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 16,
      "referenceLabel": "Psalms 88:16",
      "text": "Blessed is the people that knoweth jubilation. They shall walk, O Lord, in the light of thy countenance:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.17",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 17,
      "referenceLabel": "Psalms 88:17",
      "text": "And in thy name they shall rejoice all the day, and in thy justice they shall be exalted.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.18",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 18,
      "referenceLabel": "Psalms 88:18",
      "text": "For thou art the glory of their strength: and in thy good pleasure shall our horn be exalted.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.19",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 19,
      "referenceLabel": "Psalms 88:19",
      "text": "For our protection is of the Lord, and of our king the holy one of Israel.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.20",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 20,
      "referenceLabel": "Psalms 88:20",
      "text": "Then thou spokest in a vision to thy saints, and saidst: I have laid help upon one that is mighty, and have exalted one chosen out of my people.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.21",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 21,
      "referenceLabel": "Psalms 88:21",
      "text": "I have found David my servant: with my holy oil I have anointed him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.22",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 22,
      "referenceLabel": "Psalms 88:22",
      "text": "For my hand shall help him: and my arm shall strengthen him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.23",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 23,
      "referenceLabel": "Psalms 88:23",
      "text": "The enemy shall have no advantage over him: nor the son of iniquity have power to hurt him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.24",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 24,
      "referenceLabel": "Psalms 88:24",
      "text": "And I will cut down his enemies before his face; and them that hate him I will put to flight.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.25",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 25,
      "referenceLabel": "Psalms 88:25",
      "text": "And my truth and my mercy shall be with him: and in my name shall his horn be exalted.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.26",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 26,
      "referenceLabel": "Psalms 88:26",
      "text": "And I will set his hand in the sea; and his right hand in the rivers.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.27",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 27,
      "referenceLabel": "Psalms 88:27",
      "text": "He shall cry out to me: Thou art my father: my God, and the support of my salvation.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.28",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 28,
      "referenceLabel": "Psalms 88:28",
      "text": "And I will make him my firstborn, high above the kings of the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.29",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 29,
      "referenceLabel": "Psalms 88:29",
      "text": "I will keep my mercy for him for ever: and my covenant faithful to him.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.30",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 30,
      "referenceLabel": "Psalms 88:30",
      "text": "And I will make his seed to endure for evermore: and his throne as the days of heaven.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.31",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 31,
      "referenceLabel": "Psalms 88:31",
      "text": "And if his children forsake my law, and walk not in my judgments:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.32",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 32,
      "referenceLabel": "Psalms 88:32",
      "text": "If they profane my justices: and keep not my commandments:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.33",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 33,
      "referenceLabel": "Psalms 88:33",
      "text": "I will visit their iniquities with a rod and their sins with stripes.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.34",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 34,
      "referenceLabel": "Psalms 88:34",
      "text": "But my mercy I will not take away from him: nor will I suffer my truth to fail.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.35",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 35,
      "referenceLabel": "Psalms 88:35",
      "text": "Neither will I profane my covenant: and the words that proceed from my mouth I will not make void.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.36",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 36,
      "referenceLabel": "Psalms 88:36",
      "text": "Once have I sworn by my holiness: I will not lie unto David:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.37",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 37,
      "referenceLabel": "Psalms 88:37",
      "text": "His seed shall endure for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.38",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 38,
      "referenceLabel": "Psalms 88:38",
      "text": "And his throne as the sun before me: and as the moon perfect for ever, and a faithful witness in heaven.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.39",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 39,
      "referenceLabel": "Psalms 88:39",
      "text": "But thou hast rejected and despised: thou hast been angry with my anointed.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.40",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 40,
      "referenceLabel": "Psalms 88:40",
      "text": "Thou hast overthrown the covenant of thy servant: thou hast profaned his sanctuary on the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.41",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 41,
      "referenceLabel": "Psalms 88:41",
      "text": "Thou hast broken down all his hedges: thou hast made his strength fear.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.42",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 42,
      "referenceLabel": "Psalms 88:42",
      "text": "All that pass by the way have robbed him: he is become a reproach to his neighbours.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.43",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 43,
      "referenceLabel": "Psalms 88:43",
      "text": "Thou hast set up the right hand of them that oppress him: thou hast made all his enemies to rejoice.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.44",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 44,
      "referenceLabel": "Psalms 88:44",
      "text": "Thou hast turned away the help of his sword; and hast not assisted him in battle.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.45",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 45,
      "referenceLabel": "Psalms 88:45",
      "text": "Thou hast made his purification to cease: and thou hast cast his throne down to the ground.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.46",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 46,
      "referenceLabel": "Psalms 88:46",
      "text": "Thou hast shortened the days of his time: thou hast covered him with confusion.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.47",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 47,
      "referenceLabel": "Psalms 88:47",
      "text": "How long, O Lord, turnest thou away unto the end? shall thy anger burn like fire?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.48",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 48,
      "referenceLabel": "Psalms 88:48",
      "text": "Remember what my substance is: for hast thou made all the children of men in vain?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.49",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 49,
      "referenceLabel": "Psalms 88:49",
      "text": "Who is the man that shall live, and not see death: that shall deliver his soul from the hand of hell?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.50",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 50,
      "referenceLabel": "Psalms 88:50",
      "text": "Lord, where are thy ancient mercies, according to what thou didst swear to David in thy truth?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.51",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 51,
      "referenceLabel": "Psalms 88:51",
      "text": "Be mindful, O Lord, of the reproach of thy servants (which I have held in my bosom) of many nations:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.52",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 52,
      "referenceLabel": "Psalms 88:52",
      "text": "Wherewith thy enemies have reproached, O Lord; wherewith they have reproached the change of thy anointed.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.88.53",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 53,
      "referenceLabel": "Psalms 88:53",
      "text": "Blessed be the Lord for evermore. So be it. So be it.",
      "paragraphStart": false
    }
  ]
}
