{
  "chapter": {
    "id": "dra:psalms.98",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 98,
    "referenceLabel": "Psalms 98",
    "summary": "Source text for Psalms 98 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.98.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 1,
      "referenceLabel": "Psalms 98:1",
      "text": "A psalm for David himself. The Lord hath reigned, let the people be angry: he that sitteth on the cherubims: let the earth be moved.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.98.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 2,
      "referenceLabel": "Psalms 98:2",
      "text": "The Lord is great in Sion, and high above all people.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.98.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 3,
      "referenceLabel": "Psalms 98:3",
      "text": "Let them give praise to thy great name: for it is terrible and holy:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.98.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 4,
      "referenceLabel": "Psalms 98:4",
      "text": "And the king's honour loveth judgment. Thou hast prepared directions: thou hast done judgment and justice in Jacob.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.98.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 5,
      "referenceLabel": "Psalms 98:5",
      "text": "Exalt ye the Lord our God, and adore his footstool, for it is holy.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.98.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 6,
      "referenceLabel": "Psalms 98:6",
      "text": "Moses and Aaron among his priests: and Samuel among them that call upon his name. They called upon the Lord, and he heard them:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.98.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 7,
      "referenceLabel": "Psalms 98:7",
      "text": "He spoke to them in the pillar of the cloud. They kept his testimonies, and the commandment which he gave them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.98.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 8,
      "referenceLabel": "Psalms 98:8",
      "text": "Thou didst hear them, O Lord our God: thou wast a merciful God to them, and taking vengeance on all their inventions.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.98.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 9,
      "referenceLabel": "Psalms 98:9",
      "text": "Exalt ye the Lord our God, and adore at his holy mountain: for the Lord our God is holy.",
      "paragraphStart": false
    }
  ]
}
