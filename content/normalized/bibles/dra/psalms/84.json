{
  "chapter": {
    "id": "dra:psalms.84",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 84,
    "referenceLabel": "Psalms 84",
    "summary": "Source text for Psalms 84 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.84.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 1,
      "referenceLabel": "Psalms 84:1",
      "text": "Unto the end, for the sons of Core, a psalm.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.84.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 2,
      "referenceLabel": "Psalms 84:2",
      "text": "Lord, thou hast blessed thy land: thou hast turned away the captivity of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.84.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 3,
      "referenceLabel": "Psalms 84:3",
      "text": "Thou hast forgiven the iniquity of thy people: thou hast covered all their sins.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.84.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 4,
      "referenceLabel": "Psalms 84:4",
      "text": "Thou hast mitigated all thy anger: thou hast turned away from the wrath of thy indignation.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.84.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 5,
      "referenceLabel": "Psalms 84:5",
      "text": "Convert us, O God our saviour: and turn off thy anger from us.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.84.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 6,
      "referenceLabel": "Psalms 84:6",
      "text": "Wilt thou be angry with us for ever: or wilt thou extend thy wrath from generation to generation?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.84.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 7,
      "referenceLabel": "Psalms 84:7",
      "text": "Thou wilt turn, O God, and bring us to life: and thy people shall rejoice in thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.84.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 8,
      "referenceLabel": "Psalms 84:8",
      "text": "Shew us, O Lord, thy mercy; and grant us thy salvation.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.84.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 9,
      "referenceLabel": "Psalms 84:9",
      "text": "I will hear what the Lord God will speak in me: for he will speak peace unto his people: And unto his saints: and unto them that are converted to the heart.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.84.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 10,
      "referenceLabel": "Psalms 84:10",
      "text": "Surely his salvation is near to them that fear him: that glory may dwell in our land.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.84.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 11,
      "referenceLabel": "Psalms 84:11",
      "text": "Mercy and truth have met each other: justice and peace have kissed.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.84.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 12,
      "referenceLabel": "Psalms 84:12",
      "text": "Truth is sprung out of the earth: and justice hath looked down from heaven.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.84.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 13,
      "referenceLabel": "Psalms 84:13",
      "text": "For the Lord will give goodness: and our earth shall yield her fruit.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.84.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 14,
      "referenceLabel": "Psalms 84:14",
      "text": "Justice shall walk before him: and he shall set his steps in the way.",
      "paragraphStart": false
    }
  ]
}
