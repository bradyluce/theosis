{
  "chapter": {
    "id": "dra:psalms.2",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 2,
    "referenceLabel": "Psalms 2",
    "summary": "Source text for Psalms 2 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.2.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Psalms 2:1",
      "text": "Why have the Gentiles raged, and the people devised vain things?",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.2.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Psalms 2:2",
      "text": "The kings of the earth stood up, and the princes met together, against the Lord, and against his Christ.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.2.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Psalms 2:3",
      "text": "Let us break their bonds asunder: and let us cast away their yoke from us.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.2.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Psalms 2:4",
      "text": "He that dwelleth in heaven shall laugh at them: and the Lord shall deride them.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.2.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Psalms 2:5",
      "text": "Then shall he speak to them in his anger, and trouble them in his rage.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.2.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Psalms 2:6",
      "text": "But I am appointed king by him over Sion, his holy mountain, preaching his commandment.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.2.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Psalms 2:7",
      "text": "The Lord hath said to me: Thou art my son, this day have I begotten thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.2.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Psalms 2:8",
      "text": "Ask of me, and I will give thee the Gentiles for thy inheritance, and the utmost parts of the earth for thy possession.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.2.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Psalms 2:9",
      "text": "Thou shalt rule them with a rod of iron, and shalt break them in pieces like a potter's vessel.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.2.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Psalms 2:10",
      "text": "And now, O ye kings, understand: receive instruction, you that judge the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.2.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Psalms 2:11",
      "text": "Serve ye the Lord with fear: and rejoice unto him with trembling.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.2.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Psalms 2:12",
      "text": "Embrace discipline, lest at any time the Lord be angry, and you perish from the just way.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.2.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Psalms 2:13",
      "text": "When his wrath shall be kindled in a short time, blessed are all they that trust in him.",
      "paragraphStart": false
    }
  ]
}
