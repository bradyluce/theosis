{
  "chapter": {
    "id": "dra:psalms.60",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 60,
    "referenceLabel": "Psalms 60",
    "summary": "Source text for Psalms 60 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.60.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 1,
      "referenceLabel": "Psalms 60:1",
      "text": "Unto the end, in hymns, for David.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.60.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 2,
      "referenceLabel": "Psalms 60:2",
      "text": "Hear, O God, my supplication: be attentive to my prayer.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.60.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 3,
      "referenceLabel": "Psalms 60:3",
      "text": "To thee have I cried from the ends of the earth: when my heart was in anguish, thou hast exalted me on a rock. Thou hast conducted me;",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.60.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 4,
      "referenceLabel": "Psalms 60:4",
      "text": "For thou hast been my hope; a tower of strength against the face of the enemy.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.60.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 5,
      "referenceLabel": "Psalms 60:5",
      "text": "In thy tabernacle I shall dwell for ever: I shall be protected under the covert of thy wings.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.60.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 6,
      "referenceLabel": "Psalms 60:6",
      "text": "For thou, my God, hast heard my prayer: thou hast given an inheritance to them that fear thy name.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.60.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 7,
      "referenceLabel": "Psalms 60:7",
      "text": "Thou wilt add days to the days of the king: his years even to generation and generation.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.60.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 8,
      "referenceLabel": "Psalms 60:8",
      "text": "He abideth for ever in the sight of God: his mercy and truth who shall search?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.60.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 9,
      "referenceLabel": "Psalms 60:9",
      "text": "So will I sing a psalm to thy name for ever and ever: that I may pay my vows from day to day.",
      "paragraphStart": false
    }
  ]
}
