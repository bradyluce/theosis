{
  "chapter": {
    "id": "dra:psalms.59",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 59,
    "referenceLabel": "Psalms 59",
    "summary": "Source text for Psalms 59 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.59.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 1,
      "referenceLabel": "Psalms 59:1",
      "text": "Unto the end, for them that shall be changed, for the inscription of a title, to David himself, for doctrine,",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.59.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 2,
      "referenceLabel": "Psalms 59:2",
      "text": "When he set fire to Mesopotamia of Syria and Sobal: and Joab returned and slew of Edom, in the vale of the saltpits, twelve thousand men.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.59.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 3,
      "referenceLabel": "Psalms 59:3",
      "text": "O God, thou hast cast us off, and hast destroyed us; thou hast been angry, and hast had mercy on us.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.59.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 4,
      "referenceLabel": "Psalms 59:4",
      "text": "Thou hast moved the earth, and hast troubled it: heal thou the breaches thereof, for it has been moved.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.59.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 5,
      "referenceLabel": "Psalms 59:5",
      "text": "Thou hast shewn thy people hard things; thou hast made us drink the wine of sorrow.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.59.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 6,
      "referenceLabel": "Psalms 59:6",
      "text": "Thou hast given a warning to them that fear thee: that they may flee from before the bow: That thy beloved may be delivered.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.59.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 7,
      "referenceLabel": "Psalms 59:7",
      "text": "Save me with thy right hand, and hear me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.59.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 8,
      "referenceLabel": "Psalms 59:8",
      "text": "God hath spoken in his holy place: I will rejoice, and I will divide Sichem; and will mete out the vale of tabernacles.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.59.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 9,
      "referenceLabel": "Psalms 59:9",
      "text": "Galaad is mine, and Manasses is mine: and Ephraim is the strength of my head. Juda is my king:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.59.10",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 10,
      "referenceLabel": "Psalms 59:10",
      "text": "Moab is the pot of my hope. Into Edom will I stretch out my shoe: to me the foreigners are made subject.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.59.11",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 11,
      "referenceLabel": "Psalms 59:11",
      "text": "Who will bring me into the strong city? who will lead me into Edom?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.59.12",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 12,
      "referenceLabel": "Psalms 59:12",
      "text": "Wilt not thou, O God, who hast cast us off? and wilt not thou, O God, go out with our armies?",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.59.13",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 13,
      "referenceLabel": "Psalms 59:13",
      "text": "Give us help from trouble: for vain is the salvation of man.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.59.14",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 14,
      "referenceLabel": "Psalms 59:14",
      "text": "Through God we shall do mightily: and he shall bring to nothing them that afflict us.",
      "paragraphStart": false
    }
  ]
}
