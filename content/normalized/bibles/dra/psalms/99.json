  "verses": [
    {
      "id": "dra:psalms.99.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 1,
      "referenceLabel": "Psalms 99:1",
      "text": "A psalm of praise.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.99.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 2,
      "referenceLabel": "Psalms 99:2",
      "text": "Sing joyfully to God, all the earth: serve ye the Lord with gladness. Come in before his presence with exceeding great joy.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.99.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 3,
      "referenceLabel": "Psalms 99:3",
      "text": "Know ye that the Lord he is God: he made us, and not we ourselves. We are his people and the sheep of his pasture.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.99.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 4,
      "referenceLabel": "Psalms 99:4",
      "text": "Go ye into his gates with praise, into his courts with hymns: and give glory to him. Praise ye his name:",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.99.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 5,
      "referenceLabel": "Psalms 99:5",
      "text": "For the Lord is sweet, his mercy endureth for ever, and his truth to generation and generation.",
      "paragraphStart": false
    }
  ]
}
