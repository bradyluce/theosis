{
  "chapter": {
    "id": "dra:psalms.3",
    "translationId": "dra",
    "bookSlug": "psalms",
    "chapterNumber": 3,
    "referenceLabel": "Psalms 3",
    "summary": "Source text for Psalms 3 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:psalms.3.1",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Psalms 3:1",
      "text": "The psalm of David when he fled from the face of his son Absalom.",
      "paragraphStart": true
    },
    {
      "id": "dra:psalms.3.2",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Psalms 3:2",
      "text": "Why, O Lord, are they multiplied that afflict me? many are they who rise up against me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.3.3",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Psalms 3:3",
      "text": "Many say to my soul: There is no salvation for him in his God.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.3.4",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Psalms 3:4",
      "text": "But thou, O Lord, art my protector, my glory, and the lifter up of my head.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.3.5",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Psalms 3:5",
      "text": "I have cried to the Lord with my voice: and he hath heard me from his holy hill.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.3.6",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Psalms 3:6",
      "text": "I have slept and have taken my rest: and I have risen up, because the Lord hath protected me.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.3.7",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Psalms 3:7",
      "text": "I will not fear thousands of the people surrounding me: arise, O Lord; save me, O my God.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.3.8",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Psalms 3:8",
      "text": "For thou hast struck all them who are my adversaries without cause: thou hast broken the teeth of sinners.",
      "paragraphStart": false
    },
    {
      "id": "dra:psalms.3.9",
      "translationId": "dra",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Psalms 3:9",
      "text": "Salvation is of the Lord: and thy blessing is upon thy people.",
      "paragraphStart": false
    }
  ]
}
