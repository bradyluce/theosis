      "paragraphStart": false
    },
    {
      "id": "dra:nehemiah.7.67",
      "translationId": "dra",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 67,
      "referenceLabel": "Nehemiah 7:67",
      "text": "Beside their menservants and womenservants, who were seven thousand three hundred thirty-seven: and among them singing men, and singing women, two hundred forty-five.",
      "paragraphStart": false
    },
    {
      "id": "dra:nehemiah.7.68",
      "translationId": "dra",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 68,
      "referenceLabel": "Nehemiah 7:68",
      "text": "Their horses, seven hundred thirty-six: their mules two hundred forty-five.",
      "paragraphStart": false
    },
    {
      "id": "dra:nehemiah.7.69",
