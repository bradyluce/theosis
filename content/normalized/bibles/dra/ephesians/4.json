{
  "chapter": {
    "id": "dra:ephesians.4",
    "translationId": "dra",
    "bookSlug": "ephesians",
    "chapterNumber": 4,
    "referenceLabel": "Ephesians 4",
    "summary": "Source text for Ephesians 4 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:ephesians.4.1",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 4:1",
      "text": "I therefore, a prisoner in the Lord, beseech you that you walk worthy of the vocation in which you are called:",
      "paragraphStart": true
    },
    {
      "id": "dra:ephesians.4.2",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 4:2",
      "text": "With all humility and mildness, with patience, supporting one another in charity.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.3",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 4:3",
      "text": "Careful to keep the unity of the Spirit in the bond of peace.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.4",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 4:4",
      "text": "One body and one Spirit: as you are called in one hope of your calling.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.5",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 4:5",
      "text": "One Lord, one faith, one baptism.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.6",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 4:6",
      "text": "One God and Father of all, who is above all, and through all, and in us all.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.7",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 4:7",
      "text": "But to every one of us is given grace, according to the measure of the giving of Christ.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.8",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 4:8",
      "text": "Wherefore he saith: Ascending on high, he led captivity captive: he gave gifts to men.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.9",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 4:9",
      "text": "Now that he ascended, what is it, but because he also descended first into the lower parts of the earth?",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.10",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 4:10",
      "text": "He that descended is the same also that ascended above all the heavens: that he might fill all things.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.11",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 4:11",
      "text": "And he gave some apostles, and some prophets, and other some evangelists, and other some pastors and doctors:",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.12",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 4:12",
      "text": "For the perfecting of the saints, for the word of the ministry, for the edifying of the body of Christ:",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.13",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 4:13",
      "text": "Until we all meet into the unity of faith and of the knowledge of the Son of God, unto a perfect man, unto the measure of the age of the fulness of Christ:",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.14",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 4:14",
      "text": "That henceforth we be no more children tossed to and fro and carried about with every wind of doctrine, by the wickedness of men, by cunning craftiness by which they lie in wait to deceive.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.15",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 4:15",
      "text": "But doing the truth in charity, we may in all things grow up in him who is the head, even Christ:",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.16",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 4:16",
      "text": "From whom the whole body, being compacted and fitly joined together, by what every joint supplieth, according to the operation in the measure of every part, maketh increase of the body, unto the edifying of itself in charity.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.17",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 4:17",
      "text": "This then I say and testify in the Lord: That henceforward you walk not as also the Gentiles walk in the vanity of their mind:",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.18",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 4:18",
      "text": "Having their understanding darkened: being alienated from the life of God through the ignorance that is in them, because of the blindness of their hearts.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.19",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 4:19",
      "text": "Who despairing have given themselves up to lasciviousness, unto the working of all uncleanness, unto covetousness.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.20",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 4:20",
      "text": "But you have not so learned Christ:",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.21",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 4:21",
      "text": "If so be that you have heard him and have been taught in him, as the truth is in Jesus:",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.22",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Ephesians 4:22",
      "text": "To put off, according to former conversation, the old man, who is corrupted according to the desire of error.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.23",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Ephesians 4:23",
      "text": "And be renewed in spirit of your mind:",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.24",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Ephesians 4:24",
      "text": "And put on the new man, who according to God is created in justice and holiness of truth.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.25",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Ephesians 4:25",
      "text": "Wherefore, putting away lying, speak ye the truth, every man with his neighbour. For we are members one of another.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.26",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Ephesians 4:26",
      "text": "Be angry: and sin not. Let not the sun go down upon your anger.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.27",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Ephesians 4:27",
      "text": "Give not place to the devil.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.28",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "Ephesians 4:28",
      "text": "He that stole, let him now steal no more: but rather let him labour, working with his hands the thing which is good, that he may have something to give to him that suffereth need.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.29",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "Ephesians 4:29",
      "text": "Let no evil speech proceed from your mouth: but that which is good, to the edification of faith: that it may administer grace to the hearers.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.30",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "Ephesians 4:30",
      "text": "And grieve not the holy Spirit of God: whereby you are sealed unto the day of redemption.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.31",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "Ephesians 4:31",
      "text": "Let all bitterness and anger and indignation and clamour and blasphemy be put away from you, with all malice.",
      "paragraphStart": false
    },
    {
      "id": "dra:ephesians.4.32",
      "translationId": "dra",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 32,
      "referenceLabel": "Ephesians 4:32",
      "text": "And be ye kind one to another: merciful, forgiving one another, even as God hath forgiven you in Christ.",
      "paragraphStart": false
    }
  ]
}
