{
  "chapter": {
    "id": "dra:first-thessalonians.5",
    "translationId": "dra",
    "bookSlug": "first-thessalonians",
    "chapterNumber": 5,
    "referenceLabel": "1 Thessalonians 5",
    "summary": "Source text for 1 Thessalonians 5 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:first-thessalonians.5.1",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "1 Thessalonians 5:1",
      "text": "But of the times and moments, brethren, you need not, that we should write to you:",
      "paragraphStart": true
    },
    {
      "id": "dra:first-thessalonians.5.2",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "1 Thessalonians 5:2",
      "text": "For yourselves know perfectly that the day of the Lord shall so come as a thief in the night.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.3",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "1 Thessalonians 5:3",
      "text": "For when they shall say: Peace and security; then shall sudden destruction come upon them, as the pains upon her that is with child, and they shall not escape.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.4",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "1 Thessalonians 5:4",
      "text": "But you, brethren, are not in darkness, that the day should overtake you as a thief.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.5",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "1 Thessalonians 5:5",
      "text": "For all you are the children of light and children of the day: we are not of the night nor of darkness.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.6",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "1 Thessalonians 5:6",
      "text": "Therefore, let us not sleep, as others do: but let us watch, and be sober.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.7",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "1 Thessalonians 5:7",
      "text": "For they that sleep, sleep in the night; and they that are drunk, are drunk in the night.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.8",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "1 Thessalonians 5:8",
      "text": "But let us, who are of the day, be sober, having on the breast plate of faith and charity and, for a helmet, the hope of salvation.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.9",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "1 Thessalonians 5:9",
      "text": "For God hath not appointed us unto wrath: but unto the purchasing of salvation by our Lord Jesus Christ,",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.10",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "1 Thessalonians 5:10",
      "text": "Who died for us: that, whether we watch or sleep, we may live together with him.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.11",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "1 Thessalonians 5:11",
      "text": "For which cause comfort one another and edify one another, as you also do.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.12",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "1 Thessalonians 5:12",
      "text": "And we beseech you, brethren, to know them who labour among you and are over you in the Lord and admonish you;",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.13",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "1 Thessalonians 5:13",
      "text": "That you esteem them more abundantly in charity, for their work's sake. Have peace with them.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.14",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "1 Thessalonians 5:14",
      "text": "And we beseech you, brethren, rebuke the unquiet: comfort the feeble minded: support the weak: be patient towards all men.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.15",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "1 Thessalonians 5:15",
      "text": "See that none render evil for evil to any man: but ever follow that which is good towards each other and towards all men.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.16",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "1 Thessalonians 5:16",
      "text": "Always rejoice.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.17",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "1 Thessalonians 5:17",
      "text": "Pray without ceasing.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.18",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "1 Thessalonians 5:18",
      "text": "In all things give thanks for this is the will of God in Christ Jesus concerning you all.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.19",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "1 Thessalonians 5:19",
      "text": "Extinguish not the spirit.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.20",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "1 Thessalonians 5:20",
      "text": "Despise not prophecies.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.21",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "1 Thessalonians 5:21",
      "text": "But prove all things: hold fast that which is good.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.22",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "1 Thessalonians 5:22",
      "text": "From all appearance of evil refrain yourselves.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.23",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "1 Thessalonians 5:23",
      "text": "And may the God of peace himself sanctify you in all things: that your whole spirit and soul and body may be preserved blameless in the coming of our Lord Jesus Christ.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.24",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "1 Thessalonians 5:24",
      "text": "He is faithful who hath called you, who also will do it.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.25",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "1 Thessalonians 5:25",
      "text": "Brethren, pray for us.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.26",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "1 Thessalonians 5:26",
      "text": "Salute all the brethren with a holy kiss.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.27",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "1 Thessalonians 5:27",
      "text": "I charge you by the Lord that this epistle be read to all the holy brethren.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-thessalonians.5.28",
      "translationId": "dra",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "1 Thessalonians 5:28",
      "text": "The grace of our Lord Jesus Christ be with you. Amen.",
      "paragraphStart": false
    }
  ]
}
