{
  "chapter": {
    "id": "dra:second-thessalonians.3",
    "translationId": "dra",
    "bookSlug": "second-thessalonians",
    "chapterNumber": 3,
    "referenceLabel": "2 Thessalonians 3",
    "summary": "Source text for 2 Thessalonians 3 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:second-thessalonians.3.1",
      "translationId": "dra",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "2 Thessalonians 3:1",
      "text": "For the rest, brethren, pray for us that the word of God may run and may be glorified, even as among you:",
      "paragraphStart": true
    },
    {
      "id": "dra:second-thessalonians.3.2",
      "translationId": "dra",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "2 Thessalonians 3:2",
      "text": "And that we may be delivered from importunate and evil men: for all men have not faith.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-thessalonians.3.3",
      "translationId": "dra",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "2 Thessalonians 3:3",
      "text": "But God is faithful, who will strengthen and keep you from evil.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-thessalonians.3.4",
      "translationId": "dra",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "2 Thessalonians 3:4",
      "text": "And we have confidence concerning you in the Lord that the things which we command, you both do and will do.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-thessalonians.3.5",
      "translationId": "dra",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "2 Thessalonians 3:5",
      "text": "And the Lord direct your hearts, in the charity of God and the patience of Christ.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-thessalonians.3.6",
      "translationId": "dra",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "2 Thessalonians 3:6",
      "text": "And we charge you, brethren, in the name of our Lord Jesus Christ, that you withdraw yourselves from every brother walking disorderly and not according to the tradition which they have received of us.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-thessalonians.3.7",
      "translationId": "dra",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "2 Thessalonians 3:7",
      "text": "For yourselves know how you ought to imitate us. For we were not disorderly among you.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-thessalonians.3.8",
      "translationId": "dra",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "2 Thessalonians 3:8",
      "text": "Neither did we eat any man's bread for nothing: but in labour and in toil we worked night and day, lest we should be chargeable to any of you.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-thessalonians.3.9",
      "translationId": "dra",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "2 Thessalonians 3:9",
      "text": "Not as if we had not power: but that we might give ourselves a pattern unto you, to imitate us.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-thessalonians.3.10",
      "translationId": "dra",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "2 Thessalonians 3:10",
      "text": "For also, when we were with you, this we declared to you: that, if any man will not work, neither let him eat.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-thessalonians.3.11",
      "translationId": "dra",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "2 Thessalonians 3:11",
      "text": "For we have heard there are some among you who walk disorderly: working not at all, but curiously meddling.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-thessalonians.3.12",
      "translationId": "dra",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "2 Thessalonians 3:12",
      "text": "Now we charge them that are such and beseech them by the Lord Jesus Christ that, working with silence, they would eat their own bread.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-thessalonians.3.13",
      "translationId": "dra",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "2 Thessalonians 3:13",
      "text": "But you, brethren, be not weary in well doing.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-thessalonians.3.14",
      "translationId": "dra",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "2 Thessalonians 3:14",
      "text": "And if any man obey not our word by this epistle, note that man and do not keep company with him, that he may be ashamed.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-thessalonians.3.15",
      "translationId": "dra",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "2 Thessalonians 3:15",
      "text": "Yet do not esteem him as an enemy but admonish him as a brother.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-thessalonians.3.16",
      "translationId": "dra",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "2 Thessalonians 3:16",
      "text": "Now the Lord of peace himself give you everlasting peace in every place. The Lord be with you all.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-thessalonians.3.17",
      "translationId": "dra",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "2 Thessalonians 3:17",
      "text": "The salutation of Paul with my own hand: which is the sign in every epistle. So I write.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-thessalonians.3.18",
      "translationId": "dra",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "2 Thessalonians 3:18",
      "text": "The grace of our Lord Jesus Christ be with you all. Amen.",
      "paragraphStart": false
    }
  ]
}
