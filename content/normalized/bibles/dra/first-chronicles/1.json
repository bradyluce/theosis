{
  "chapter": {
    "id": "dra:first-chronicles.1",
    "translationId": "dra",
    "bookSlug": "first-chronicles",
    "chapterNumber": 1,
    "referenceLabel": "1 Chronicles 1",
    "summary": "Source text for 1 Chronicles 1 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:first-chronicles.1.1",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 1:1",
      "text": "Adam, Seth, Enos,",
      "paragraphStart": true
    },
    {
      "id": "dra:first-chronicles.1.2",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 1:2",
      "text": "Cainan, Malaleel, Jared,",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.3",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 1:3",
      "text": "Henoc, Mathusale, Lamech,",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.4",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 1:4",
      "text": "Noe, Sem, Cham, and Japheth.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.5",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 1:5",
      "text": "The sons of Japheth: Gomer, and Magog, and Madai, and Javan, Thubal, Mosoch, Thiras.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.6",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 1:6",
      "text": "And the sons of Gomer: Ascenez, and Riphath, and Thogorma.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.7",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 1:7",
      "text": "And the sons of Javan: Elisa and Tharsis, Cethim and Dodanim.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.8",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 1:8",
      "text": "The sons of Cham: Chus, and Mesrai, and Phut, and Chanaan.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.9",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 1:9",
      "text": "And the sons of Chus: Saba, and Hevila, Sabatha, and Regma, and Sabathaca. And the sons of Regma: Saba, and Dadan.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.10",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 1:10",
      "text": "Now Chus begot Nemrod: he began to be mighty upon earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.11",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 1:11",
      "text": "But Mesraim begot Ludim, and Anamim, and Laabim, and Nephtuim,",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.12",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 1:12",
      "text": "Phetrusim also, and Casluim: from whom came the Philistines, and Caphtorim.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.13",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 1:13",
      "text": "And Chanaan begot Sidon his firstborn, and the Hethite,",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.14",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 1:14",
      "text": "And the Jebusite, and the Amorrhite, and the Gergesite,",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.15",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 1:15",
      "text": "And the Hevite, and the Aracite, and the Sinite,",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.16",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 1:16",
      "text": "And the Aradian, and the Samarite, and the Hamathite.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.17",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 1:17",
      "text": "The sons of Sem: Elam and Asur, and Arphaxad, and Lud, and Aram, and Hus, and Hul, and Gether, and Mosoch.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.18",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 1:18",
      "text": "And Arphaxad begot Sale, and Sale begot Heber.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.19",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 1:19",
      "text": "And to Heber were born two sons, the name of the one was Phaleg, because in his days the earth was divided; and the name of his brother was Jectan.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.20",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 1:20",
      "text": "And Jectan begot Elmodad, and Saleph, and Asarmoth, and Jare,",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.21",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 1:21",
      "text": "And Adoram, and Usal, and Decla,",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.22",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 1:22",
      "text": "And Hebal, and Abimael, and Saba,",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.23",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 1:23",
      "text": "And Ophir, and Hevila, and Jobab. All these are the sons of Jectan.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.24",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 1:24",
      "text": "Sem, Arphaxad, Sale,",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.25",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 1:25",
      "text": "Heber, Phaleg, Ragau,",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.26",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 1:26",
      "text": "Serug, Nachor, Thare,",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.27",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 1:27",
      "text": "Abram, this is Abraham.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.28",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 1:28",
      "text": "And the sons of Abraham, Isaac and Ismahel.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.29",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 1:29",
      "text": "And these are the generations of them. The firstborn of Ismahel, Nabajoth, then Cedar, and Adbeel, and Mabsam,",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.30",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 1:30",
      "text": "And Masma, and Duma, Massa, Hadad, and Thema,",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.31",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 1:31",
      "text": "Jetur, Naphis, Cedma: these are the sons of Ismahel.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.32",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 1:32",
      "text": "And the sons of Cetura, Abraham's concubine, whom she bore: Zamran, Jecsan, Madan, Madian, Jesboc, and Sue. And the sons of Jecsan, Saba, and Dadan. And the sons of Dadan: Assurim, and Latussim, and Laomin.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.33",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 1:33",
      "text": "And the sons of Madian: Epha, and Epher, and Henoch, and Abida, and Eldaa. All these are the sons of Cetura.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.34",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 1:34",
      "text": "And Abraham begot Isaac: and his sons were Esau and Israel.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.35",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 1:35",
      "text": "The sons of Esau: Eliphaz, Rahuel, Jehus, Ihelom, and Core.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.36",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 1:36",
      "text": "The sons of Eliphaz: Theman, Omar, Sephi, Gathan, Cenez, and by Thamna, Amalec.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.37",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 1:37",
      "text": "The sons of Rahuel: Nahath, Zara, Samma, Meza.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.38",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 1:38",
      "text": "The sons of Seir: Lotan, Sobal, Sebeon, Ana, Dison, Eser, Disan.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.39",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 1:39",
      "text": "The sons of Lotan: Hori, Homam. And the sister of Lotan was Thamna.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.40",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 1:40",
      "text": "The sons of Sobal: Alian, and Manahath, and Ebal, Sephi, and Onam. The sons of Sebeon: Aia, and Ana. The son of Ana: Dison.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.41",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 41,
      "referenceLabel": "1 Chronicles 1:41",
      "text": "The sons of Dison: Hamram, and Eseban, and Jethran, and Charan.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.42",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 42,
      "referenceLabel": "1 Chronicles 1:42",
      "text": "The sons of Eser: Balaan, and Zavan, and Jacan. The sons of Disan: Hus and Aran.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.43",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 43,
      "referenceLabel": "1 Chronicles 1:43",
      "text": "Now these are the kings that reigned in the land of Edom, before there was a king over the children of Israel: Bale the son of Beor: and the name of his city was Denaba.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.44",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 44,
      "referenceLabel": "1 Chronicles 1:44",
      "text": "And Bale died, and Jobab the son of Zare of Bosra, reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.45",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 45,
      "referenceLabel": "1 Chronicles 1:45",
      "text": "And when Jobab also was dead, Husam of the land of the Themanites reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.46",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 46,
      "referenceLabel": "1 Chronicles 1:46",
      "text": "And Husam also died, and Adad the son of Badad reigned in his stead, and he defeated the Madianites in the land of Moab: the name of his city was Avith.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.47",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 47,
      "referenceLabel": "1 Chronicles 1:47",
      "text": "And when Adad also was dead, Semla of Masreca reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.48",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 48,
      "referenceLabel": "1 Chronicles 1:48",
      "text": "Semla also died, and Saul of Rohoboth, which is near the river, reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.49",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 49,
      "referenceLabel": "1 Chronicles 1:49",
      "text": "And when Saul was dead, Balanan the son of Achobor reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.50",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 50,
      "referenceLabel": "1 Chronicles 1:50",
      "text": "He also died, and Adad reigned in his stead: and the name of his city was Phau, and his wife was called Meetabel the daughter of Matred, the daughter of Mezaab.",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.51",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 51,
      "referenceLabel": "1 Chronicles 1:51",
      "text": "And after the death of Adad, there began to be dukes in Edom instead of kings: duke Thamna, duke Alva, duke Jetheth,",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.52",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 52,
      "referenceLabel": "1 Chronicles 1:52",
      "text": "Duke Oolibama, duke Ela, duke Phinon,",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.53",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 53,
      "referenceLabel": "1 Chronicles 1:53",
      "text": "Duke Cenez, duke Theman, duke Mabsar,",
      "paragraphStart": false
    },
    {
      "id": "dra:first-chronicles.1.54",
      "translationId": "dra",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 54,
      "referenceLabel": "1 Chronicles 1:54",
      "text": "Duke Magdiel, duke Hiram. These are the dukes of Edom.",
      "paragraphStart": false
    }
  ]
}
