{
  "chapter": {
    "id": "dra:ezra.2",
    "translationId": "dra",
    "bookSlug": "ezra",
    "chapterNumber": 2,
    "referenceLabel": "Ezra 2",
    "summary": "Source text for Ezra 2 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:ezra.2.1",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Ezra 2:1",
      "text": "Now these are the children of the province, that went out of the captivity, which Nabuchodonosor king of Babylon had carried away to Babylon, and who returned to Jerusalem and Juda, every man to his city.",
      "paragraphStart": true
    },
    {
      "id": "dra:ezra.2.2",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Ezra 2:2",
      "text": "Who came with Zorobabel, Josue, Nehemia, Saraia, Rahelaia, Mardochai, Belsan, Mesphar, Beguai, Rehum, Baana. The number of the men of the people of Israel:",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.3",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Ezra 2:3",
      "text": "The children of Pharos two thousand one hundred seventy-two.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.4",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Ezra 2:4",
      "text": "The children of Sephatia, three hundred seventy-two.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.5",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Ezra 2:5",
      "text": "The children of Area, seven hundred seventy-five.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.6",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Ezra 2:6",
      "text": "The children of Phahath Moab, of the children of Josue: Joab, Two thousand eight hundred twelve.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.7",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Ezra 2:7",
      "text": "The children of Elam, a thousand two hundred fifty-four.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.8",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Ezra 2:8",
      "text": "The children of Zethua, nine hundred forty-five.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.9",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Ezra 2:9",
      "text": "The children of Zachai, seven hundred sixty.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.10",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Ezra 2:10",
      "text": "The children of Bani, six hundred forty-two.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.11",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Ezra 2:11",
      "text": "The children of Bebai, six hundred twenty-three.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.12",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Ezra 2:12",
      "text": "The children of Azgad, a thousand two hundred twenty-two.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.13",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Ezra 2:13",
      "text": "The children of Adonicam, six hundred sixty-six.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.14",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Ezra 2:14",
      "text": "The children of Beguai, two thousand fifty-six.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.15",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Ezra 2:15",
      "text": "The children of Adin, four hundred fifty-four.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.16",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Ezra 2:16",
      "text": "The children of Ather, who were of Ezechias, ninety-eight.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.17",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Ezra 2:17",
      "text": "The children of Besai, three hundred and twenty-three.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.18",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Ezra 2:18",
      "text": "The children of Jora, a hundred and twelve.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.19",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Ezra 2:19",
      "text": "The children of Hasum, two hundred twenty-three.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.20",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Ezra 2:20",
      "text": "The children of Gebbar, ninety-five.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.21",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Ezra 2:21",
      "text": "The children of Bethlehem, a hundred twenty-three.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.22",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Ezra 2:22",
      "text": "The men of Netupha, fifty-six.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.23",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Ezra 2:23",
      "text": "The men of Anathoth, a hundred twenty-eight.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.24",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "Ezra 2:24",
      "text": "The children of Azmaveth, forty-two.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.25",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "Ezra 2:25",
      "text": "The children of Cariathiarim, Cephira, and Beroth, seven hundred forty-three.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.26",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "Ezra 2:26",
      "text": "The children of Rama and Gabaa, six hundred twenty-one.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.27",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "Ezra 2:27",
      "text": "The men of Machmas, a hundred twenty-two.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.28",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "Ezra 2:28",
      "text": "The men of Bethel and Hai, two hundred twenty-three.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.29",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 29,
      "referenceLabel": "Ezra 2:29",
      "text": "The children of Nebo, fifty-two.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.30",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 30,
      "referenceLabel": "Ezra 2:30",
      "text": "The children of Megbis, a hundred fifty-six.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.31",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 31,
      "referenceLabel": "Ezra 2:31",
      "text": "The children of the other Elam, a thousand two hundred fifty-five.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.32",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 32,
      "referenceLabel": "Ezra 2:32",
      "text": "The children of Harim, three hundred and twenty.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.33",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 33,
      "referenceLabel": "Ezra 2:33",
      "text": "The children of Lod, Hadid and Ono, seven hundred twenty-five.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.34",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 34,
      "referenceLabel": "Ezra 2:34",
      "text": "The children of Jericho, three hundred forty-five.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.35",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 35,
      "referenceLabel": "Ezra 2:35",
      "text": "The children of Senaa, three thousand six hundred thirty.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.36",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 36,
      "referenceLabel": "Ezra 2:36",
      "text": "The priests: the children of Jadaia of the house of Josue, nine hundred seventy-three.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.37",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 37,
      "referenceLabel": "Ezra 2:37",
      "text": "The children of Emmer, a thousand fifty-two.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.38",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 38,
      "referenceLabel": "Ezra 2:38",
      "text": "The children of Pheshur, a thousand two hundred forty-seven.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.39",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 39,
      "referenceLabel": "Ezra 2:39",
      "text": "The children of Harim, a thousand and seventeen.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.40",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 40,
      "referenceLabel": "Ezra 2:40",
      "text": "The Levites: the children of Josue and of Cedmihel, the children of Odovia, seventy-four.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.41",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 41,
      "referenceLabel": "Ezra 2:41",
      "text": "The singing men: the children of Asaph, a hundred twenty-eight.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.42",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 42,
      "referenceLabel": "Ezra 2:42",
      "text": "The children of the porters: the children of Sellum, the children of Ater, the children of Telmon, the children of Accub, the children of Hatita, the children of Sobai: in all a hundred thirty-nine.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.43",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 43,
      "referenceLabel": "Ezra 2:43",
      "text": "The Nathinites: the children of Siha, the children of Hasupha, the children of Tabbaoth,",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.44",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 44,
      "referenceLabel": "Ezra 2:44",
      "text": "The children of Ceros, the children of Sia, the children of Phadon,",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.45",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 45,
      "referenceLabel": "Ezra 2:45",
      "text": "The children of Lebana, the children of Hegaba, the children of Accub,",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.46",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 46,
      "referenceLabel": "Ezra 2:46",
      "text": "The children of Hagab, the children of Semlai, the children of Hanan,",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.47",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 47,
      "referenceLabel": "Ezra 2:47",
      "text": "The children of Gaddel, the children of Gaher, the children of Raaia,",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.48",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 48,
      "referenceLabel": "Ezra 2:48",
      "text": "The children of Rasin, the children of Necoda, the children of Gazam,",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.49",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 49,
      "referenceLabel": "Ezra 2:49",
      "text": "The children of Asa, the children of Phasea, the children of Besee,",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.50",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 50,
      "referenceLabel": "Ezra 2:50",
      "text": "The children of Asena, the children of Munim, the children of Nephusim,",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.51",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 51,
      "referenceLabel": "Ezra 2:51",
      "text": "The children of Bacbuc, the children of Hacupha, the children of Harhur,",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.52",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 52,
      "referenceLabel": "Ezra 2:52",
      "text": "The children of Besluth, the children of Mahida, the children of Harsa,",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.53",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 53,
      "referenceLabel": "Ezra 2:53",
      "text": "The children of Bercos, the children of Sisara, the children of Thema,",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.54",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 54,
      "referenceLabel": "Ezra 2:54",
      "text": "The children of Nasia, the children of Hatipha,",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.55",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 55,
      "referenceLabel": "Ezra 2:55",
      "text": "The children of the servants of Solomon, the children of Sotai, the children of Sopheret, the children of Pharuda,",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.56",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 56,
      "referenceLabel": "Ezra 2:56",
      "text": "The children of Jala, the children of Dercon, the children of Geddel,",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.57",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 57,
      "referenceLabel": "Ezra 2:57",
      "text": "The children of Saphatia, the children of Hatil, the children of Phochereth, which were of Asebaim, the children of Ami,",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.58",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 58,
      "referenceLabel": "Ezra 2:58",
      "text": "All the Nathinites, and the children of the servants of Solomon, three hundred ninety-two.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.59",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 59,
      "referenceLabel": "Ezra 2:59",
      "text": "And these are they that came up from Thelmela, Thelharsa, Cherub, and Adon, and Emer. And they could not shew the house of their fathers and their seed, whether they were of Israel.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.60",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 60,
      "referenceLabel": "Ezra 2:60",
      "text": "The children of Dalaia, the children of Tobia, the children of Necoda, six hundred fifty-two.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.61",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 61,
      "referenceLabel": "Ezra 2:61",
      "text": "And of the children of the priests: the children of Hobia, the children of Accos, the children of Berzellai, who took a wife of the daughters of Berzellai, the Galaadite, and was called by their name:",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.62",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 62,
      "referenceLabel": "Ezra 2:62",
      "text": "These sought the writing of their genealogy, and found it not, and they were cast out of the priesthood.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.63",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 63,
      "referenceLabel": "Ezra 2:63",
      "text": "And Athersatha said to them, that they should not eat of the holy of holies, till there arose a priest learned and perfect.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.64",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 64,
      "referenceLabel": "Ezra 2:64",
      "text": "All the multitudes as one man, were forty-two thousand three hundred and sixty:",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.65",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 65,
      "referenceLabel": "Ezra 2:65",
      "text": "Besides their menservants, and womenservants, of whom there were seven thousand three hundred and thirty-seven: and among them singing men, and singing women two hundred.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.66",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 66,
      "referenceLabel": "Ezra 2:66",
      "text": "Their horses seven hundred thirty-six, their mules two hundred forty-five,",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.67",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 67,
      "referenceLabel": "Ezra 2:67",
      "text": "Their camels four hundred thirty-five, their asses six thousand seven hundred and twenty.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.68",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 68,
      "referenceLabel": "Ezra 2:68",
      "text": "And some of the chief of the fathers, when they came to the temple of the Lord, which is in Jerusalem, offered freely to the house of the Lord to build it in its place.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.69",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 69,
      "referenceLabel": "Ezra 2:69",
      "text": "According to their ability, they gave towards the expenses of the work, sixty-one thousand solids of gold, five thousand pounds of silver, and a hundred garments for the priests.",
      "paragraphStart": false
    },
    {
      "id": "dra:ezra.2.70",
      "translationId": "dra",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 70,
      "referenceLabel": "Ezra 2:70",
      "text": "So the priests and the Levites, and some of the people, and the singing men, and the porters, and the Nathinites dwelt in their cities, and all Israel in their cities.",
      "paragraphStart": false
    }
  ]
}
