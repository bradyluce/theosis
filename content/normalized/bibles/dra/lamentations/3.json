{
  "chapter": {
    "id": "dra:lamentations.3",
    "translationId": "dra",
    "bookSlug": "lamentations",
    "chapterNumber": 3,
    "referenceLabel": "Lamentations 3",
    "summary": "Source text for Lamentations 3 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:lamentations.3.1",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Lamentations 3:1",
      "text": "Aleph. I am the man that see my poverty by the rod of his indignation.",
      "paragraphStart": true
    },
    {
      "id": "dra:lamentations.3.2",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Lamentations 3:2",
      "text": "Aleph. He hath led me, and brought me into darkness, and not into light.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.3",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Lamentations 3:3",
      "text": "Aleph. Only against me he hath turned, and turned again his hand all the day.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.4",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Lamentations 3:4",
      "text": "Beth. My skin and my flesh he hath made old, he hath broken my bones.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.5",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Lamentations 3:5",
      "text": "Beth. He hath built round about me, and he hath compassed me with gall, and labour.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.6",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Lamentations 3:6",
      "text": "Beth. He hath set me in dark places as those that are dead for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.7",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Lamentations 3:7",
      "text": "Ghimel. He hath built against me round about, that I may not get out: he hath made my fetters heavy.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.8",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Lamentations 3:8",
      "text": "Ghimel. Yea, and when I cry, and entreat, he hath shut out my prayer.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.9",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Lamentations 3:9",
      "text": "Ghimel. He hath shut up my ways with square stones, he hath turned my paths upside down.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.10",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Lamentations 3:10",
      "text": "Daleth. He is become to me as a bear lying in wait: as a lion in secret places.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.11",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Lamentations 3:11",
      "text": "Daleth. He hath turned aside my paths, and hath broken me in pieces, he hath made me desolate.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.12",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Lamentations 3:12",
      "text": "Daleth. He hath bent his bow, and set me as a mark for his arrows.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.13",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Lamentations 3:13",
      "text": "He. He hath shot into my reins the daughters of his quiver.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.14",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Lamentations 3:14",
      "text": "He. I am made a derision to all my people, their song all the day long.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.15",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Lamentations 3:15",
      "text": "He. He hath filled me with bitterness, he hath inebriated me with wormwood.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.16",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Lamentations 3:16",
      "text": "Vau. And he hath broken my teeth one by one, he hath fed me with ashes.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.17",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Lamentations 3:17",
      "text": "Vau. And my soul is removed far off from peace, I have forgotten good things.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.18",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Lamentations 3:18",
      "text": "Vau. And I said: My end and my hope is perished from the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.19",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Lamentations 3:19",
      "text": "Zain. Remember my poverty, and transgression, the wormwood and the gall.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.20",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Lamentations 3:20",
      "text": "Zain. I will be mindful and remember, and my soul shall languish within me.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.21",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Lamentations 3:21",
      "text": "Zain. These things I shall think over in my heart, therefore will I hope.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.22",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Lamentations 3:22",
      "text": "Heth. The mercies of the Lord that we are not consumed: because his commiserations have not failed.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.23",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Lamentations 3:23",
      "text": "Heth. They are new every morning, great is thy faithfulness.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.24",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Lamentations 3:24",
      "text": "Heth. The Lord is my portion, said my soul: therefore will I wait for him.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.25",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Lamentations 3:25",
      "text": "Teth. The Lord is good to them that hope in him, to the soul that seeketh him.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.26",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Lamentations 3:26",
      "text": "Teth. It is good to wait with silence for the salvation of God.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.27",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Lamentations 3:27",
      "text": "Teth. It is good for a man, when he hath borne the yoke from his youth.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.28",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Lamentations 3:28",
      "text": "Jod. He shall sit solitary, and hold his peace: because he hath taken it up upon himself.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.29",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Lamentations 3:29",
      "text": "Jod. He shall put his mouth in the dust, if so be there may be hope.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.30",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Lamentations 3:30",
      "text": "Jod. He shall give his cheek to him that striketh him, he shall be filled with reproaches.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.31",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Lamentations 3:31",
      "text": "Caph. For the Lord will not cast off for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.32",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "Lamentations 3:32",
      "text": "Caph. For if he hath cast off, he will also have mercy, according to the multitude of his mercies.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.33",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "Lamentations 3:33",
      "text": "Caph. For he hath not willingly afflicted, nor cast off the children of men.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.34",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "Lamentations 3:34",
      "text": "Lamed. To crush under his feet all the prisoners of the land,",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.35",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "Lamentations 3:35",
      "text": "Lamed. To turn aside the judgment of a man before the face of the most High,",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.36",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 36,
      "referenceLabel": "Lamentations 3:36",
      "text": "Lamed. To destroy a man wrongfully in his judgment, the Lord hath not approved.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.37",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 37,
      "referenceLabel": "Lamentations 3:37",
      "text": "Mem. Who is he that hath commanded a thing to be done, when the Lord commandeth it not?",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.38",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 38,
      "referenceLabel": "Lamentations 3:38",
      "text": "Mem. Shall not both evil and good proceed out of the mouth of the Highest?",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.39",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 39,
      "referenceLabel": "Lamentations 3:39",
      "text": "Mem. Why hath a living man murmured, man suffering for his sins?",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.40",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 40,
      "referenceLabel": "Lamentations 3:40",
      "text": "Nun. Let us search our ways, and seek, and return to the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.41",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 41,
      "referenceLabel": "Lamentations 3:41",
      "text": "Nun. Let us lift up our hearts with our hands to the Lord in the heavens.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.42",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 42,
      "referenceLabel": "Lamentations 3:42",
      "text": "Nun. We have done wickedly, and provoked thee to wrath: therefore thou art inexorable.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.43",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 43,
      "referenceLabel": "Lamentations 3:43",
      "text": "Samech. Thou hast covered in thy wrath, and hast struck us: thou hast killed and hast not spared.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.44",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 44,
      "referenceLabel": "Lamentations 3:44",
      "text": "Samech. Thou hast set a cloud before thee, that our prayer may not pass through.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.45",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 45,
      "referenceLabel": "Lamentations 3:45",
      "text": "Samech. Thou hast made me as an outcast, and refuse in the midst of the people.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.46",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 46,
      "referenceLabel": "Lamentations 3:46",
      "text": "Phe. All our enemies have opened their mouths against us.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.47",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 47,
      "referenceLabel": "Lamentations 3:47",
      "text": "Phe. Prophecy is become to us a fear, and a snare, and destruction.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.48",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 48,
      "referenceLabel": "Lamentations 3:48",
      "text": "Phe. My eye hath run down with streams of water, for the destruction of the daughter of my people.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.49",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 49,
      "referenceLabel": "Lamentations 3:49",
      "text": "Ain. My eye is afflicted, and hath not been quiet, because there was no rest:",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.50",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 50,
      "referenceLabel": "Lamentations 3:50",
      "text": "Ain. Till the Lord regarded and looked down from the heavens.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.51",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 51,
      "referenceLabel": "Lamentations 3:51",
      "text": "Ain. My eye hath wasted my soul because of all the daughters of my city.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.52",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 52,
      "referenceLabel": "Lamentations 3:52",
      "text": "Sade. My enemies have chased me and caught me like a bird, without cause.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.53",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 53,
      "referenceLabel": "Lamentations 3:53",
      "text": "Sade. My life is fallen into the pit, and they have laid a stone over me.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.54",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 54,
      "referenceLabel": "Lamentations 3:54",
      "text": "Sade. Waters have flowed over my head: I said: I am cut off.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.55",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 55,
      "referenceLabel": "Lamentations 3:55",
      "text": "Coph. I have called upon thy name, O Lord, from the lowest pit.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.56",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 56,
      "referenceLabel": "Lamentations 3:56",
      "text": "Coph. Thou hast heard my voice: turn not away thy ear from my sighs, and cries.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.57",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 57,
      "referenceLabel": "Lamentations 3:57",
      "text": "Coph. Thou drewest near in the day, when I called upon thee, thou saidst: Fear not.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.58",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 58,
      "referenceLabel": "Lamentations 3:58",
      "text": "Res. Thou hast judged, O Lord, the cause of my soul, thou the Redeemer of my life.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.59",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 59,
      "referenceLabel": "Lamentations 3:59",
      "text": "Res. Thou hast seen, O Lord, their iniquity against me: judge thou my judgment.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.60",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 60,
      "referenceLabel": "Lamentations 3:60",
      "text": "Res. Thou hast seen all their fury, and all their thoughts against me.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.61",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 61,
      "referenceLabel": "Lamentations 3:61",
      "text": "Sin. Thou hast heard their reproach, O Lord, all their imaginations against me.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.62",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 62,
      "referenceLabel": "Lamentations 3:62",
      "text": "Sin. The lips of them that rise up against me: and their devices against me all the day.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.63",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 63,
      "referenceLabel": "Lamentations 3:63",
      "text": "Sin. Behold their sitting down, and their rising up, I am their song.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.64",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 64,
      "referenceLabel": "Lamentations 3:64",
      "text": "Thau. Thou shalt render them a recompense, O Lord, according to the works of their hands.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.65",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 65,
      "referenceLabel": "Lamentations 3:65",
      "text": "Thau. Thou shalt give them a buckler of heart, thy labour.",
      "paragraphStart": false
    },
    {
      "id": "dra:lamentations.3.66",
      "translationId": "dra",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 66,
      "referenceLabel": "Lamentations 3:66",
      "text": "Thau. Thou shalt persecute them in anger, and shalt destroy them from under the heavens, O Lord.",
      "paragraphStart": false
    }
  ]
}
