{
  "chapter": {
    "id": "dra:sirach.8",
    "translationId": "dra",
    "bookSlug": "sirach",
    "chapterNumber": 8,
    "referenceLabel": "Sirach 8",
    "summary": "Source text for Sirach 8 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:sirach.8.1",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Sirach 8:1",
      "text": "Strive not with a powerful man, lest thou fall into his hands.",
      "paragraphStart": true
    },
    {
      "id": "dra:sirach.8.2",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Sirach 8:2",
      "text": "Contend not with a rich man, lest he bring an action against thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.3",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Sirach 8:3",
      "text": "For gold and silver hath destroyed many, and hath reached even to the heart of kings, and perverted them.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.4",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Sirach 8:4",
      "text": "Strive not with a man that is full of tongue, and heap not wood upon his fire.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.5",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Sirach 8:5",
      "text": "Communicate not with an ignorant man, lest he speak ill of thy family.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.6",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Sirach 8:6",
      "text": "Despise not a man that turneth away from sin, nor reproach him therewith: remember that we are all worthy of reproof.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.7",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Sirach 8:7",
      "text": "Despise not a man in his old age; for we also shall become old.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.8",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Sirach 8:8",
      "text": "Rejoice not at the death of thy enemy; knowing that we all die, and are not willing that others should rejoice at our death.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.9",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Sirach 8:9",
      "text": "Despise not the discourse of them that are ancient and wise, but acquaint thyself with their proverbs.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.10",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Sirach 8:10",
      "text": "For of them thou shalt learn wisdom, and instruction of understanding, and to serve great men without blame.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.11",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Sirach 8:11",
      "text": "Let not the discourse of the ancients escape thee, for they have learned of their fathers:",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.12",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Sirach 8:12",
      "text": "For of them thou shalt learn understanding, and to give an answer in time of need.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.13",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Sirach 8:13",
      "text": "Kindle not the coals of sinners by rebuking them, lest thou be burnt with the flame of the fire of their sins.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.14",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Sirach 8:14",
      "text": "Stand not against the face of an injurious person, lest he sit as a spy to entrap thee in thy words.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.15",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Sirach 8:15",
      "text": "Lend not to a man that is mightier than thyself: and if thou lendest, count it as lost.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.16",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Sirach 8:16",
      "text": "Be not surety above thy power: and if thou be surety, think as if thou wert to pay it.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.17",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Sirach 8:17",
      "text": "Judge not against a judge: for he judgeth according to that which is just.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.18",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Sirach 8:18",
      "text": "Go not on the way with a bold man, lest he burden thee with his evils: for he goeth according to his own will, and thou shalt perish together with his folly.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.19",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Sirach 8:19",
      "text": "Quarrel not with a passionate man, and go not into the desert with a bold man: for blood is as nothing in his sight, and where there is no help he will overthrow thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.20",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "Sirach 8:20",
      "text": "Advise not with fools, for they cannot love but such things as please them.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.21",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "Sirach 8:21",
      "text": "Before a stranger do no matter of counsel: for thou knowest not what he will bring forth.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.8.22",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "Sirach 8:22",
      "text": "Open not thy heart to every man: lest he repay thee with an evil turn, and speak reproachfully to thee.",
      "paragraphStart": false
    }
  ]
}
