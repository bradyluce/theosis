{
  "chapter": {
    "id": "dra:sirach.9",
    "translationId": "dra",
    "bookSlug": "sirach",
    "chapterNumber": 9,
    "referenceLabel": "Sirach 9",
    "summary": "Source text for Sirach 9 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:sirach.9.1",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Sirach 9:1",
      "text": "Be not jealous over the wife of thy bosom, lest she shew in thy regard the malice of a wicked lesson.",
      "paragraphStart": true
    },
    {
      "id": "dra:sirach.9.2",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Sirach 9:2",
      "text": "Give not the power of thy soul to a woman, lest she enter upon thy strength, and thou be confounded.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.3",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Sirach 9:3",
      "text": "Look not upon a woman that hath a mind for many: lest thou fall into her snares.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.4",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Sirach 9:4",
      "text": "Use not much the company of her that is a dancer, and hearken not to her, lest thou perish by the force of her charms.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.5",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Sirach 9:5",
      "text": "Gaze not upon a maiden, lest her beauty be a stumblingblock to thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.6",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Sirach 9:6",
      "text": "Give not thy soul to harlots in any point: lest thou destroy thyself and thy inheritance.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.7",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Sirach 9:7",
      "text": "Look not round about thee in the ways of the city, nor wander up and down in the streets thereof.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.8",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Sirach 9:8",
      "text": "Turn away thy face from a woman dressed up, and gaze not about upon another's beauty.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.9",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Sirach 9:9",
      "text": "For many have perished by the beauty of a woman, and hereby lust is enkindled as a fire.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.10",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Sirach 9:10",
      "text": "Every woman that is a harlot, shall be trodden upon as dung in the way.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.11",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Sirach 9:11",
      "text": "Many by admiring the beauty of another man's wife, have become reprobate, for her conversation burneth as fire.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.12",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Sirach 9:12",
      "text": "Sit not at all with another man's wife, nor repose upon the bed with her:",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.13",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Sirach 9:13",
      "text": "And strive not with her over wine, lest thy heart decline towards her and by thy blood thou fall into destruction.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.14",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Sirach 9:14",
      "text": "Forsake not an old friend, for the new will not be like to him.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.15",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Sirach 9:15",
      "text": "A new friend is as new wine: it shall grow old, and thou shalt drink it with pleasure.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.16",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Sirach 9:16",
      "text": "Envy not the glory and riches of a sinner: for thou knowest not what his ruin shall be.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.17",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Sirach 9:17",
      "text": "Be not pleased with the wrong done by the unjust, knowing that even to hell the wicked shall not please.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.18",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Sirach 9:18",
      "text": "Keep thee far from the man that hath power to kill, so thou shalt not suspect the fear of death.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.19",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Sirach 9:19",
      "text": "And if thou come to him, commit no fault, lest he take away thy life.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.20",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Sirach 9:20",
      "text": "Know it to be a communication with death: for thou art going in the midst of snares, and walking upon the arms of them that are grieved.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.21",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Sirach 9:21",
      "text": "According to thy power beware of thy neighbour, and treat with the wise and prudent.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.22",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "Sirach 9:22",
      "text": "Let just men be thy guests, and let thy glory be in the fear of God.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.23",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "Sirach 9:23",
      "text": "And let the thought of God be in thy mind, and all thy discourse on the commandments of the Highest.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.24",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "Sirach 9:24",
      "text": "Works shall be praised for the hand of the artificers, and the prince of the people for the wisdom of his speech, but the word of the ancients for the sense.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.9.25",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "Sirach 9:25",
      "text": "A man full of tongue is terrible in his city, and he that is rash in his word shall be hateful.",
      "paragraphStart": false
    }
  ]
}
