{
  "chapter": {
    "id": "dra:sirach.5",
    "translationId": "dra",
    "bookSlug": "sirach",
    "chapterNumber": 5,
    "referenceLabel": "Sirach 5",
    "summary": "Source text for Sirach 5 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:sirach.5.1",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Sirach 5:1",
      "text": "Set not thy heart upon unjust possessions, and say not: I have enough to live on: for it shall be of no service in the time of vengeance and darkness.",
      "paragraphStart": true
    },
    {
      "id": "dra:sirach.5.2",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Sirach 5:2",
      "text": "Follow not in thy strength the desires of thy heart:",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.5.3",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Sirach 5:3",
      "text": "And say not: How mighty am I? and who shall bring me under for my deeds? for God will surely take revenge.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.5.4",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Sirach 5:4",
      "text": "Say not: I have sinned, and what harm hath befallen me? for the most High is a patient rewarder.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.5.5",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Sirach 5:5",
      "text": "Be not without fear about sin forgiven, and add not sin upon sin:",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.5.6",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Sirach 5:6",
      "text": "And say not: The mercy of the Lord is great, he will have mercy on the multitude of my sins.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.5.7",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Sirach 5:7",
      "text": "For mercy and wrath quickly come from him, and his wrath looketh upon sinners.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.5.8",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Sirach 5:8",
      "text": "Delay not to be converted to the Lord, and defer it not from day to day.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.5.9",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Sirach 5:9",
      "text": "For his wrath shall come on a sudden, and in the time of vengeance he will destroy thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.5.10",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Sirach 5:10",
      "text": "Be not anxious for goods unjustly gotten: for they shall not profit thee in the day of calamity and revenge.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.5.11",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Sirach 5:11",
      "text": "Winnow not with every wind, and go not into every way: for so is every sinner proved by a double tongue.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.5.12",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Sirach 5:12",
      "text": "Be steadfast in the way of the Lord, and in the truth of thy judgment, and in knowledge, and let the word of peace and justice keep with thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.5.13",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Sirach 5:13",
      "text": "Be meek to hear the word, that thou mayst understand: and return a true answer with wisdom.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.5.14",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Sirach 5:14",
      "text": "If thou have understanding, answer thy neighbour: but if not, let thy hand be upon thy mouth, lest thou be surprised in an unskilful word, and be confounded.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.5.15",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Sirach 5:15",
      "text": "Honour and glory is in the word of the wise, but the tongue of the fool is his ruin.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.5.16",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Sirach 5:16",
      "text": "Be not called a whisperer, and be not taken in thy tongue, and confounded.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.5.17",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Sirach 5:17",
      "text": "For confusion and repentance is upon a thief, and an evil mark of disgrace upon the double tongued, but to the whisperer hatred, and enmity, and reproach.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.5.18",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Sirach 5:18",
      "text": "Justify alike the small and the great.",
      "paragraphStart": false
    }
  ]
}
