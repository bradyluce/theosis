{
  "chapter": {
    "id": "dra:sirach.15",
    "translationId": "dra",
    "bookSlug": "sirach",
    "chapterNumber": 15,
    "referenceLabel": "Sirach 15",
    "summary": "Source text for Sirach 15 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:sirach.15.1",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Sirach 15:1",
      "text": "He that feareth God, will do good: and he that possesseth justice, shall lay hold on her,",
      "paragraphStart": true
    },
    {
      "id": "dra:sirach.15.2",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Sirach 15:2",
      "text": "And she will meet him as an honourable mother, and will receive him as a wife married of a virgin.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.3",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Sirach 15:3",
      "text": "With the bread of life and understanding, she shall feed him, and give him the water of wholesome wisdom to drink: and she shall be made strong in him, and he shall not be moved.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.4",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Sirach 15:4",
      "text": "And she shall hold him fast, and he shall not be confounded: and she shall exalt him among his neighbours.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.5",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Sirach 15:5",
      "text": "And in the midst of the church she shall open his mouth, and shall fill him with the spirit of wisdom and understanding, and shall clothe him with a robe of glory.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.6",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Sirach 15:6",
      "text": "She shall heap upon him a treasure of joy and gladness, and shall cause him to inherit an everlasting name.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.7",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Sirach 15:7",
      "text": "But foolish men shall not obtain her, and wise men shall meet her, foolish men shall not see her: for she is far from pride and deceit.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.8",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Sirach 15:8",
      "text": "Lying men shall be mindful of her: but men that speak truth shall be found with her, and shall advance, even till they come to the sight of God.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.9",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Sirach 15:9",
      "text": "Praise is not seemly in the mouth of a sinner:",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.10",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Sirach 15:10",
      "text": "For wisdom came forth from God: for praise shall be with the wisdom of God, and shall abound in a faithful mouth, and the sovereign Lord will give praise unto it.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.11",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Sirach 15:11",
      "text": "Say not: It is through God, that she is not with me: for do not thou the things that he hateth.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.12",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Sirach 15:12",
      "text": "Say not: He hath caused me to err: for he hath no need of wicked men.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.13",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Sirach 15:13",
      "text": "The Lord hateth all abomination of error, and they that fear him shall not love it.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.14",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Sirach 15:14",
      "text": "God made man from the beginning, and left him in the hand of his own counsel.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.15",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Sirach 15:15",
      "text": "He added his commandments and precepts.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.16",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Sirach 15:16",
      "text": "If thou wilt keep the commandments and perform acceptable fidelity for ever, they shall preserve thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.17",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Sirach 15:17",
      "text": "He hath set water and fire before thee: stretch forth thy hand to which thou wilt.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.18",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Sirach 15:18",
      "text": "Before man is life and death, good and evil, that which he shall choose shall be given him:",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.19",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Sirach 15:19",
      "text": "For the wisdom of God is great, and he is strong in power, seeing all men without ceasing.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.20",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Sirach 15:20",
      "text": "The eyes of the Lord are towards them that fear him, and he knoweth al the work of man.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.21",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Sirach 15:21",
      "text": "He hath commanded no man to do wickedly, and he hath given no man license to sin;",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.15.22",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Sirach 15:22",
      "text": "For he desireth not a multitude of faithless and unprofitable children.",
      "paragraphStart": false
    }
  ]
}
