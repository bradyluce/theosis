{
  "chapter": {
    "id": "dra:sirach.7",
    "translationId": "dra",
    "bookSlug": "sirach",
    "chapterNumber": 7,
    "referenceLabel": "Sirach 7",
    "summary": "Source text for Sirach 7 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:sirach.7.1",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Sirach 7:1",
      "text": "Do no evils, and no evils shall lay hold of thee.",
      "paragraphStart": true
    },
    {
      "id": "dra:sirach.7.2",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Sirach 7:2",
      "text": "Depart from the unjust, and evils shall depart from thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.3",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Sirach 7:3",
      "text": "My son, sow not evils in the furrows of injustice, and thou shalt not reap them sevenfold.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.4",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Sirach 7:4",
      "text": "Seek not of the Lord a preeminence, nor of the king the seat of honour.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.5",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Sirach 7:5",
      "text": "Justify not thyself before God, for he knoweth the heart: and desire not to appear wise before the king.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.6",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Sirach 7:6",
      "text": "Seek not to be made a judge, unless thou have strength enough to extirpate iniquities: lest thou fear the person of the powerful, and lay a stumblingblock for thy integrity.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.7",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Sirach 7:7",
      "text": "Offend not against the multitude of a city, neither cast thyself in upon the people,",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.8",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Sirach 7:8",
      "text": "Nor bind sin to sin: for even in one thou shalt not be unpunished.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.9",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Sirach 7:9",
      "text": "Be not fainthearted in thy mind:",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.10",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Sirach 7:10",
      "text": "Neglect not to pray, and to give alms.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.11",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Sirach 7:11",
      "text": "Say not: God will have respect to the multitude of my gifts, and when I offer to the most high God, he will accept my offerings.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.12",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Sirach 7:12",
      "text": "Laugh no man to scorn in the bitterness of his soul: for there is one that humbleth and exalteth, God who seeth all.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.13",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Sirach 7:13",
      "text": "Devise not a lie against thy brother: neither do the like against thy friend.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.14",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Sirach 7:14",
      "text": "Be not willing to make any manner of lie: for the custom thereof is not good.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.15",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Sirach 7:15",
      "text": "Be not full of words in a multitude of ancients, and repeat not the word in thy prayer.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.16",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Sirach 7:16",
      "text": "Hate not laborious works, nor husbandry ordained by the most High.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.17",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Sirach 7:17",
      "text": "Number not thyself among the multitude of the disorderly.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.18",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Sirach 7:18",
      "text": "Remember wrath, for it will not tarry long.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.19",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Sirach 7:19",
      "text": "Humble thy spirit very much: for the vengeance on the flesh of the ungodly is fire and worms.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.20",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Sirach 7:20",
      "text": "Do not transgress against thy friend deferring money, nor despise thy dear brother for the sake of gold.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.21",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Sirach 7:21",
      "text": "Depart not from a wise and good wife, whom thou hast gotten in the fear of the Lord: for the grace of her modesty is above gold.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.22",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Sirach 7:22",
      "text": "Hurt not the servant that worketh faithfully, nor the hired man that giveth thee his life.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.23",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Sirach 7:23",
      "text": "Let a wise servant be dear to thee as thy own soul, defraud him not of liberty, nor leave him needy.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.24",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Sirach 7:24",
      "text": "Hast thou cattle? have an eye to them: and if they be for thy profit, keep them with thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.25",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Sirach 7:25",
      "text": "Hast thou children? instruct them, and bow down their neck from their childhood.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.26",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "Sirach 7:26",
      "text": "Hast thou daughters? have a care of their body, and shew not thy countenance gay towards them.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.27",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "Sirach 7:27",
      "text": "Marry thy daughter well, and thou shalt do a great work, and give her to a wise man.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.28",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "Sirach 7:28",
      "text": "If thou hast a wife according to thy soul, cast her not off: and to her that is hateful, trust not thyself. With thy whole heart,",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.29",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "Sirach 7:29",
      "text": "Honour thy father, and forget not the groanings of thy mother:",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.30",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 30,
      "referenceLabel": "Sirach 7:30",
      "text": "Remember that thou hadst not been born but through them: and make a return to them as they have done for thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.31",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 31,
      "referenceLabel": "Sirach 7:31",
      "text": "With all thy soul fear the Lord, and reverence his priests.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.32",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 32,
      "referenceLabel": "Sirach 7:32",
      "text": "With all thy strength love him that made thee: and forsake not his ministers.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.33",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 33,
      "referenceLabel": "Sirach 7:33",
      "text": "Honour God with all thy soul and give honour to the priests, and purify thyself with thy arms.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.34",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 34,
      "referenceLabel": "Sirach 7:34",
      "text": "Give them their portion, as it is commanded thee, of the firstfruits and of purifications: and for thy negligences purify thyself with a few.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.35",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 35,
      "referenceLabel": "Sirach 7:35",
      "text": "Offer to the Lord the gift of thy shoulders, and the sacrifice of sanctification, and the firstfruits of the holy things:",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.36",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 36,
      "referenceLabel": "Sirach 7:36",
      "text": "And stretch out thy hand to the poor, that thy expiation and thy blessing may be perfected.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.37",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 37,
      "referenceLabel": "Sirach 7:37",
      "text": "A gift hath grace in the sight of all the living, and restrain not grace from the dead.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.38",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 38,
      "referenceLabel": "Sirach 7:38",
      "text": "Be not wanting in comforting them that weep, and walk with them that mourn.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.39",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 39,
      "referenceLabel": "Sirach 7:39",
      "text": "Be not slow to visit the sick: for by these things thou shalt be confirmed in love.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.7.40",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 40,
      "referenceLabel": "Sirach 7:40",
      "text": "In all thy works remember thy last end, and thou shalt never sin.",
      "paragraphStart": false
    }
  ]
}
