{
  "chapter": {
    "id": "dra:sirach.4",
    "translationId": "dra",
    "bookSlug": "sirach",
    "chapterNumber": 4,
    "referenceLabel": "Sirach 4",
    "summary": "Source text for Sirach 4 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:sirach.4.1",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Sirach 4:1",
      "text": "Son, defraud not the poor of alms, and turn not away thy eyes from the poor.",
      "paragraphStart": true
    },
    {
      "id": "dra:sirach.4.2",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Sirach 4:2",
      "text": "Despise not the hungry soul: and provoke not the poor in his want.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.3",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Sirach 4:3",
      "text": "Afflict not the heart of the needy, and defer not to gibe to him that is in distress.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.4",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Sirach 4:4",
      "text": "Reject not the petition of the afflicted: and turn not away thy face from the needy.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.5",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Sirach 4:5",
      "text": "Turn not away thy eyes from the poor for fear of anger: and leave not to them that ask of thee to curse thee behind thy back.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.6",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Sirach 4:6",
      "text": "For the prayer of him that curseth thee in the bitterness of his soul, shall be heard, for he that made him will hear him.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.7",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Sirach 4:7",
      "text": "Make thyself affable to the congregation of the poor, and humble thy soul to the ancient, and bow thy head to a great man.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.8",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Sirach 4:8",
      "text": "Bow down thy ear cheerfully to the poor, and pay what thou owest, and answer him peaceable words with mildness.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.9",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Sirach 4:9",
      "text": "Deliver him that suffereth wrong out of the hand of the proud: and be not fainthearted in thy soul.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.10",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Sirach 4:10",
      "text": "In judging be merciful to the fatherless as a father, and as a husband to their mother.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.11",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Sirach 4:11",
      "text": "And thou shalt be as the obedient son of the most High, and he will have mercy on thee more than a mother.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.12",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Sirach 4:12",
      "text": "Wisdom inspireth life into her children, and protecteth them that seek after her, and will go before them in the way of justice.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.13",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Sirach 4:13",
      "text": "And he that loveth her, loveth life: and they that watch for her, shall embrace her sweetness.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.14",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Sirach 4:14",
      "text": "They that hold her fast, shall inherit life: and whithersoever she entereth, God will give a blessing.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.15",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Sirach 4:15",
      "text": "They that serve her, shall be servants to the holy one: and God loveth them that love her.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.16",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Sirach 4:16",
      "text": "He that hearkeneth to her, shall judge nations: and he that looketh upon her, shall remain secure.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.17",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Sirach 4:17",
      "text": "If he trust to her, he shall inherit her, and his generation shall be in assurance.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.18",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Sirach 4:18",
      "text": "For she walketh with him in temptation, and at the first she chooseth him.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.19",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Sirach 4:19",
      "text": "She will bring upon him fear and dread and trial: and she will scourge him with the affliction of her discipline, till she try him by her laws, and trust his soul.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.20",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Sirach 4:20",
      "text": "Then she will strengthen him, and make a straight way to him, and give him joy,",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.21",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Sirach 4:21",
      "text": "And will disclose her secrets to him, and will heap upon him treasures of knowledge and understanding of justice.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.22",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Sirach 4:22",
      "text": "But if he go astray, she will forsake him, and deliver him into the hands of his enemy.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.23",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Sirach 4:23",
      "text": "Son, observe the time, and fly from evil.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.24",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Sirach 4:24",
      "text": "For thy soul be not ashamed to say the truth.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.25",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Sirach 4:25",
      "text": "For there is a shame that bringeth sin, and there is a shame that bringeth glory and grace.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.26",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Sirach 4:26",
      "text": "Accept no person against thy own person, nor against thy soul a lie.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.27",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Sirach 4:27",
      "text": "Reverence not thy neighbour in his fall:",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.28",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "Sirach 4:28",
      "text": "And refrain not to speak in the time of salvation. Hide not thy wisdom in her beauty.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.29",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "Sirach 4:29",
      "text": "For by the tongue wisdom is discerned: and understanding, and knowledge, and learning by the word of the wise, and steadfastness in the works of justice.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.30",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "Sirach 4:30",
      "text": "In nowise speak against the truth, but be ashamed of the lie of thy ignorance.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.31",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "Sirach 4:31",
      "text": "Be not ashamed to confess thy sins, but submit not thyself to every man for sin.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.32",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 32,
      "referenceLabel": "Sirach 4:32",
      "text": "Resist not against the face of the mighty, and do not strive against the stream of the river.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.33",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 33,
      "referenceLabel": "Sirach 4:33",
      "text": "Strive for justice for thy soul, and even unto death fight for justice, and God will overthrow thy enemies for thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.34",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 34,
      "referenceLabel": "Sirach 4:34",
      "text": "Be not hasty in thy tongue: and slack and remiss in thy works.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.35",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 35,
      "referenceLabel": "Sirach 4:35",
      "text": "Be not as a lion in thy house, terrifying them of thy household, and oppressing them that are under thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:sirach.4.36",
      "translationId": "dra",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 36,
      "referenceLabel": "Sirach 4:36",
      "text": "Let not thy hand be stretched out to receive, and shut when thou shouldst give.",
      "paragraphStart": false
    }
  ]
}
