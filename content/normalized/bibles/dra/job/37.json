{
  "chapter": {
    "id": "dra:job.37",
    "translationId": "dra",
    "bookSlug": "job",
    "chapterNumber": 37,
    "referenceLabel": "Job 37",
    "summary": "Source text for Job 37 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:job.37.1",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 1,
      "referenceLabel": "Job 37:1",
      "text": "At this my heart trembleth, and is moved out of its place.",
      "paragraphStart": true
    },
    {
      "id": "dra:job.37.2",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 2,
      "referenceLabel": "Job 37:2",
      "text": "Hear ye attentively the terror of his voice, and the sound that cometh out of his mouth.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.3",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 3,
      "referenceLabel": "Job 37:3",
      "text": "He beholdeth under all the heavens, and his light is upon the ends of the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.4",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 4,
      "referenceLabel": "Job 37:4",
      "text": "After it a noise shall roar, he shall thunder with the voice of his majesty, and shall not be found out, when his voice shall be heard.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.5",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 5,
      "referenceLabel": "Job 37:5",
      "text": "God shall thunder wonderfully with his voice, he that doth great and unsearchable things.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.6",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 6,
      "referenceLabel": "Job 37:6",
      "text": "He commandeth the snow to go down upon the earth, and the winter rain, and the shower of his strength.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.7",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 7,
      "referenceLabel": "Job 37:7",
      "text": "He sealeth up the hand of all men, that every one may know his works.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.8",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 8,
      "referenceLabel": "Job 37:8",
      "text": "Then the beast shall go into his covert, and shall abide in his den.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.9",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 9,
      "referenceLabel": "Job 37:9",
      "text": "Out of the inner parts shall a tempest come, and cold out of the north.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.10",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 10,
      "referenceLabel": "Job 37:10",
      "text": "When God bloweth there cometh frost, and again the waters are poured out abundantly.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.11",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 11,
      "referenceLabel": "Job 37:11",
      "text": "Corn desireth clouds, and the clouds spread their light:",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.12",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 12,
      "referenceLabel": "Job 37:12",
      "text": "Which go round about, whithersoever the will of him that governeth them shall lead them, to whatsoever he shall command them upon the face of the whole earth:",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.13",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 13,
      "referenceLabel": "Job 37:13",
      "text": "Whether in one tribe, or in his own land, or in what place soever of his mercy he shall command them to be found.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.14",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 14,
      "referenceLabel": "Job 37:14",
      "text": "Hearken to these things, Job: Stand, and consider the wondrous works of God.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.15",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 15,
      "referenceLabel": "Job 37:15",
      "text": "Dost thou know when God commanded the rains, to shew his light of his clouds?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.16",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 16,
      "referenceLabel": "Job 37:16",
      "text": "Knowest thou the great paths of the clouds, and the perfect knowledges?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.17",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 17,
      "referenceLabel": "Job 37:17",
      "text": "Are not thy garments hot, when the south wind blows upon the earth?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.18",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 18,
      "referenceLabel": "Job 37:18",
      "text": "Thou perhaps hast made the heavens with him, which are most strong, as if they were of molten brass.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.19",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 19,
      "referenceLabel": "Job 37:19",
      "text": "Shew us what we may say to him: or we are wrapped up in darkness.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.20",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 20,
      "referenceLabel": "Job 37:20",
      "text": "Who shall tell him the things I speak? even if a man shall speak, he shall be swallowed up.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.21",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 21,
      "referenceLabel": "Job 37:21",
      "text": "But now they see not the light: the air on a sudden shall be thickened into clouds, and the wind shall pass and drive them away.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.22",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 22,
      "referenceLabel": "Job 37:22",
      "text": "Cold cometh out of the north, and to God praise with fear.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.23",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 23,
      "referenceLabel": "Job 37:23",
      "text": "We cannot find him worthily: he is great in strength, and in judgment, and in justice, and he is ineffable.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.37.24",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 24,
      "referenceLabel": "Job 37:24",
      "text": "Therefore men shall fear him, and all that seem to themselves to be wise, shall not dare to behold him.",
      "paragraphStart": false
    }
  ]
}
