{
  "chapter": {
    "id": "dra:job.17",
    "translationId": "dra",
    "bookSlug": "job",
    "chapterNumber": 17,
    "referenceLabel": "Job 17",
    "summary": "Source text for Job 17 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:job.17.1",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Job 17:1",
      "text": "My spirit shall be wasted, my days shall be shortened and only the grave remaineth for me.",
      "paragraphStart": true
    },
    {
      "id": "dra:job.17.2",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Job 17:2",
      "text": "I have not sinned, and my eye abideth in bitterness.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.17.3",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Job 17:3",
      "text": "Deliver me, O Lord, and set me beside thee, and let any man's hand fight against me.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.17.4",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Job 17:4",
      "text": "Thou hast set their heart far from understanding, therefore they shall not be exalted.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.17.5",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Job 17:5",
      "text": "He promiseth a prey to his companions, and the eyes of his children shall fail.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.17.6",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Job 17:6",
      "text": "He hath made me as it were a byword of the people, and I am an example before them.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.17.7",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Job 17:7",
      "text": "My eye is dim through indignation, and my limbs are brought as it were to nothing.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.17.8",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Job 17:8",
      "text": "The just shall be astonished at this, and the innocent shall be raised up against the hypocrite.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.17.9",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Job 17:9",
      "text": "And the just man shall hold on his way, and he that hath clean hands shall be stronger and stronger.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.17.10",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Job 17:10",
      "text": "Wherefore be you all converted, and come, and I shall not find among you any wise man.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.17.11",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Job 17:11",
      "text": "My days have passed away, my thoughts are dissipated, tormenting my heart.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.17.12",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Job 17:12",
      "text": "They have turned night into day, and after darkness I hope for light again.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.17.13",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Job 17:13",
      "text": "If I wait hell is my house, and I have made my bed in darkness.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.17.14",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Job 17:14",
      "text": "I have said to rottenness: Thou art my father; to worms, my mother and my sister.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.17.15",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Job 17:15",
      "text": "Where is now then my expectation, and who considereth my patience?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.17.16",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Job 17:16",
      "text": "All that I have shall go down into the deepest pit: thinkest thou that there at least I shall have rest?",
      "paragraphStart": false
    }
  ]
}
