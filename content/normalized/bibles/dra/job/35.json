{
  "chapter": {
    "id": "dra:job.35",
    "translationId": "dra",
    "bookSlug": "job",
    "chapterNumber": 35,
    "referenceLabel": "Job 35",
    "summary": "Source text for Job 35 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:job.35.1",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 1,
      "referenceLabel": "Job 35:1",
      "text": "Moreover Eliu spoke these words:",
      "paragraphStart": true
    },
    {
      "id": "dra:job.35.2",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 2,
      "referenceLabel": "Job 35:2",
      "text": "Doth thy thought seem right to thee, that thou shouldst say: I am more just than God?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.35.3",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 3,
      "referenceLabel": "Job 35:3",
      "text": "For thou saidst: That which is right doth not please thee: or what will it profit thee if I sin?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.35.4",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 4,
      "referenceLabel": "Job 35:4",
      "text": "Therefore I will answer thy words, and thy friends with thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.35.5",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 5,
      "referenceLabel": "Job 35:5",
      "text": "Look up to heaven and see, and behold the sky, that it is higher than thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.35.6",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 6,
      "referenceLabel": "Job 35:6",
      "text": "If thou sin, what shalt thou hurt him? and if thy iniquities be multiplied, what shalt thou do against him?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.35.7",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 7,
      "referenceLabel": "Job 35:7",
      "text": "And if thou do justly, what shalt thou give him, or what shall he receive of thy hand?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.35.8",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 8,
      "referenceLabel": "Job 35:8",
      "text": "Thy wickedness may hurt a man that is like thee: and thy justice may help the son of man.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.35.9",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 9,
      "referenceLabel": "Job 35:9",
      "text": "By reason of the multitude of oppressors they shall cry out: and shall wail for the violence of the arm of tyrants.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.35.10",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 10,
      "referenceLabel": "Job 35:10",
      "text": "And he hath not said: Where is God, who made me, who hath given songs in the night?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.35.11",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 11,
      "referenceLabel": "Job 35:11",
      "text": "Who teacheth us more than the beasts of the earth, and instructeth us more than the fowls of the air.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.35.12",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 12,
      "referenceLabel": "Job 35:12",
      "text": "There shall they cry, and he will not hear, because of the pride of evil men.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.35.13",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 13,
      "referenceLabel": "Job 35:13",
      "text": "God therefore will not hear in vain, and the Almighty will look into the causes of every one.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.35.14",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 14,
      "referenceLabel": "Job 35:14",
      "text": "Yea, when thou shalt say: He considereth not: be judged before him, and expect him.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.35.15",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 15,
      "referenceLabel": "Job 35:15",
      "text": "For he doth not now bring on his fury, neither doth he revenge wickedness exceedingly.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.35.16",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 16,
      "referenceLabel": "Job 35:16",
      "text": "Therefore Job openeth his mouth in vain, and multiplieth words without knowledge.",
      "paragraphStart": false
    }
  ]
}
