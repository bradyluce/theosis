{
  "chapter": {
    "id": "dra:job.36",
    "translationId": "dra",
    "bookSlug": "job",
    "chapterNumber": 36,
    "referenceLabel": "Job 36",
    "summary": "Source text for Job 36 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:job.36.1",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 1,
      "referenceLabel": "Job 36:1",
      "text": "Eliu also proceeded, and said:",
      "paragraphStart": true
    },
    {
      "id": "dra:job.36.2",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 2,
      "referenceLabel": "Job 36:2",
      "text": "Suffer me a little, and I will shew thee: for I have yet somewhat to speak in God's behalf.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.3",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 3,
      "referenceLabel": "Job 36:3",
      "text": "I will repeat my knowledge from the beginning, and I will prove my Maker just.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.4",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 4,
      "referenceLabel": "Job 36:4",
      "text": "For indeed my words are without a lie, and perfect knowledge shall be proved to thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.5",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 5,
      "referenceLabel": "Job 36:5",
      "text": "God doth not cast away the mighty, whereas he himself also is mighty.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.6",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 6,
      "referenceLabel": "Job 36:6",
      "text": "But he saveth not the wicked, and he giveth judgment to the poor.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.7",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 7,
      "referenceLabel": "Job 36:7",
      "text": "He will not take away his eyes from the just, and he placeth kings on the throne for ever, and they are exalted.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.8",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 8,
      "referenceLabel": "Job 36:8",
      "text": "And if they shall be in chains, and be bound with the cords of poverty:",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.9",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 9,
      "referenceLabel": "Job 36:9",
      "text": "He shall shew them their works, and their wicked deeds, because they have been violent.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.10",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 10,
      "referenceLabel": "Job 36:10",
      "text": "He also shall open their ear, to correct them: and shall speak, that they may return from iniquity.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.11",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 11,
      "referenceLabel": "Job 36:11",
      "text": "If they shall hear and observe, they shall accomplish their days in good, and their years in glory.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.12",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 12,
      "referenceLabel": "Job 36:12",
      "text": "But if they hear not, they shall pass by the sword, and shall be consumed in folly.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.13",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 13,
      "referenceLabel": "Job 36:13",
      "text": "Dissemblers and crafty men prove the wrath of God, neither shall they cry when they are bound.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.14",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 14,
      "referenceLabel": "Job 36:14",
      "text": "Their soul shall die in a storm, and their life among the effeminate.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.15",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 15,
      "referenceLabel": "Job 36:15",
      "text": "He shall deliver the poor out of his distress, and shall open his ear in affliction.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.16",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 16,
      "referenceLabel": "Job 36:16",
      "text": "Therefore he shall set thee at large out of the narrow mouth, and which hath no foundation under it: and the rest of thy table shall be full of fatness.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.17",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 17,
      "referenceLabel": "Job 36:17",
      "text": "Thy cause hath been judged as that of the wicked, cause and judgment thou shalt recover.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.18",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 18,
      "referenceLabel": "Job 36:18",
      "text": "Therefore let not anger overcome thee to oppress any man: neither let multitude of gifts turn thee aside.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.19",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 19,
      "referenceLabel": "Job 36:19",
      "text": "Lay down thy greatness without tribulation, and all the mighty of strength.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.20",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 20,
      "referenceLabel": "Job 36:20",
      "text": "Prolong not the night that people may come up for them.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.21",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 21,
      "referenceLabel": "Job 36:21",
      "text": "Beware thou turn not aside to iniquity: for this thou hast begun to follow after misery.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.22",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 22,
      "referenceLabel": "Job 36:22",
      "text": "Behold, God is high in his strength, and none is like him among the lawgivers.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.23",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 23,
      "referenceLabel": "Job 36:23",
      "text": "Who can search out his ways? or who can say to him: Thou hast wrought iniquity?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.24",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 24,
      "referenceLabel": "Job 36:24",
      "text": "Remember that thou knowest not his work, concerning which men have sung.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.25",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 25,
      "referenceLabel": "Job 36:25",
      "text": "All men see him, every one beholdeth afar off.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.26",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 26,
      "referenceLabel": "Job 36:26",
      "text": "Behold, God is great, exceeding our knowledge: the number of his years is inestimable.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.27",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 27,
      "referenceLabel": "Job 36:27",
      "text": "He lifteth up the drops of rain, and poureth out showers like floods:",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.28",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 28,
      "referenceLabel": "Job 36:28",
      "text": "Which flow from the clouds that cover all above.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.29",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 29,
      "referenceLabel": "Job 36:29",
      "text": "If he will spread out clouds as his tent,",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.30",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 30,
      "referenceLabel": "Job 36:30",
      "text": "And lighten with his light from above, he shall cover also the ends of the sea.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.31",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 31,
      "referenceLabel": "Job 36:31",
      "text": "For by these he judgeth people, and giveth food to many mortals.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.32",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 32,
      "referenceLabel": "Job 36:32",
      "text": "In his hands he hideth the light, and commandeth it to come again.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.36.33",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 33,
      "referenceLabel": "Job 36:33",
      "text": "He sheweth his friend concerning it, that it is his possession, and that he may come up to it.",
      "paragraphStart": false
    }
  ]
}
