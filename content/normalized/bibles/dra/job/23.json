{
  "chapter": {
    "id": "dra:job.23",
    "translationId": "dra",
    "bookSlug": "job",
    "chapterNumber": 23,
    "referenceLabel": "Job 23",
    "summary": "Source text for Job 23 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:job.23.1",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Job 23:1",
      "text": "Then Job answered, and said:",
      "paragraphStart": true
    },
    {
      "id": "dra:job.23.2",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Job 23:2",
      "text": "Now also my words are in bitterness, and the hand of my scourge is more grievous than my mourning.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.23.3",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Job 23:3",
      "text": "Who will grant me that I might know and find him, and come even to his throne?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.23.4",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Job 23:4",
      "text": "I would set judgment before him, and would fill my mouth with complaints.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.23.5",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Job 23:5",
      "text": "That I might know the words that he would answer me, and understand what he would say to me.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.23.6",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Job 23:6",
      "text": "I would not that he should contend with me with much strength, nor overwhelm me with the weight of his greatness.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.23.7",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Job 23:7",
      "text": "Let him propose equity against me, and let my judgment come to victory.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.23.8",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Job 23:8",
      "text": "But if I go to the east, he appeareth not; if to the west, I shall not understand him.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.23.9",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Job 23:9",
      "text": "If to the left hand, what shall I do? I shall not take hold on him: if I turn myself to the right hand, I shall not see him.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.23.10",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Job 23:10",
      "text": "But he knoweth my way, and has tried me as gold that passeth through the fire:",
      "paragraphStart": false
    },
    {
      "id": "dra:job.23.11",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "Job 23:11",
      "text": "My foot hath followed his steps, I have kept his way, and have not declined from it.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.23.12",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "Job 23:12",
      "text": "I have not departed from the commandments of his lips, and the words of his mouth I have hid in my bosom.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.23.13",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "Job 23:13",
      "text": "For he is alone, and no man can turn away his thought: and whatsoever his soul hath desired, that hath he done.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.23.14",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "Job 23:14",
      "text": "And when he shall have fulfilled his will in me, many other like things are also at hand with him.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.23.15",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "Job 23:15",
      "text": "And therefore I am troubled at his presence, and when I consider him, I am made pensive with fear.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.23.16",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "Job 23:16",
      "text": "God hath softened my heart, and the Almighty hath troubled me.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.23.17",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "Job 23:17",
      "text": "For I have not perished because of the darkness that hangs over me, neither hath the mist covered my face.",
      "paragraphStart": false
    }
  ]
}
