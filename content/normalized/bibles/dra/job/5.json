{
  "chapter": {
    "id": "dra:job.5",
    "translationId": "dra",
    "bookSlug": "job",
    "chapterNumber": 5,
    "referenceLabel": "Job 5",
    "summary": "Source text for Job 5 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:job.5.1",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Job 5:1",
      "text": "Call now, if there be any that will answer thee, and turn to some of the saints.",
      "paragraphStart": true
    },
    {
      "id": "dra:job.5.2",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Job 5:2",
      "text": "Anger indeed killeth the foolish, and envy slayeth the little one.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.3",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Job 5:3",
      "text": "I have seen a fool with a strong root, and I cursed his beauty immediately.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.4",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Job 5:4",
      "text": "His children shall be far from safety, and shall be destroyed in the gate, and there shall be none to deliver them.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.5",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Job 5:5",
      "text": "Whose harvest the hungry shall eat, and the armed man shall take him by violence, and the thirsty shall drink up his riches.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.6",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Job 5:6",
      "text": "Nothing upon earth is done without a cause, and sorrow doth not spring out of the ground.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.7",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Job 5:7",
      "text": "Man is born to labour, and the bird to fly.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.8",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Job 5:8",
      "text": "Wherefore I will pray to the Lord, and address my speech to God:",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.9",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Job 5:9",
      "text": "Who doth great things, and unsearchable and wonderful things without number:",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.10",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Job 5:10",
      "text": "Who giveth rain upon the face of the earth, and watereth all things with waters:",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.11",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Job 5:11",
      "text": "Who setteth up the humble on high, and comforteth with health those that mourn.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.12",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Job 5:12",
      "text": "Who bringeth to nought the designs of the malignant, so that their hands cannot accomplish what they had begun:",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.13",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Job 5:13",
      "text": "Who catcheth the wise in their craftiness, and disappointeth the counsel of the wicked:",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.14",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Job 5:14",
      "text": "They shall meet with darkness in the day, and grope at noonday as in the night.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.15",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Job 5:15",
      "text": "But he shall save the needy from the sword of their mouth, and the poor from the hand of the violent.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.16",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Job 5:16",
      "text": "And to the needy there shall be hope, but iniquity shall draw in her mouth.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.17",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Job 5:17",
      "text": "Blessed is the man whom God correcteth: refuse not, therefore, the chastising of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.18",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Job 5:18",
      "text": "For he woundeth, and cureth: he striketh, and his hands shall heal.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.19",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Job 5:19",
      "text": "In six troubles he shall deliver thee, and in the seventh, evil shall not touch thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.20",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Job 5:20",
      "text": "In famine he shall deliver thee from death; and in battle, from the hand of the sword.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.21",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Job 5:21",
      "text": "Thou shalt be hidden from the scourge of the tongue: and thou shalt not fear calamity when it cometh.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.22",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Job 5:22",
      "text": "In destruction and famine thou shalt laugh: and thou shalt not be afraid of the beasts of the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.23",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Job 5:23",
      "text": "But thou shalt have a covenant with the stones of the lands, and the beasts of the earth shall be at peace with thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.24",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Job 5:24",
      "text": "And thou shalt know that thy tabernacle is in peace, and visiting thy beauty, thou shalt not sin.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.25",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Job 5:25",
      "text": "Thou shalt know also that thy seed shall be multiplied, and thy offspring like the grass of the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.26",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Job 5:26",
      "text": "Thou shalt enter into the grave in abundance, as a heap of wheat is brought in its season.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.5.27",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Job 5:27",
      "text": "Behold, this is even so, as we have searched out: which thou having heard, consider it thoroughly in thy mind.",
      "paragraphStart": false
    }
  ]
}
