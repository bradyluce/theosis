{
  "chapter": {
    "id": "dra:job.19",
    "translationId": "dra",
    "bookSlug": "job",
    "chapterNumber": 19,
    "referenceLabel": "Job 19",
    "summary": "Source text for Job 19 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:job.19.1",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Job 19:1",
      "text": "Then Job answered, and said:",
      "paragraphStart": true
    },
    {
      "id": "dra:job.19.2",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Job 19:2",
      "text": "How long do you afflict my soul, and break me in pieces with words?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.3",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Job 19:3",
      "text": "Behold, these ten times you confound me, and are not ashamed to oppress me.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.4",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Job 19:4",
      "text": "For if I have been ignorant, my ignorance shall be with me.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.5",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Job 19:5",
      "text": "But you set yourselves up against me, and reprove me with my reproaches.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.6",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Job 19:6",
      "text": "At least now understand, that God hath not afflicted me with an equal judgment, and compassed me with his scourges.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.7",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Job 19:7",
      "text": "Behold I shall cry suffering violence, and no one will hear: I shall cry aloud, and there is none to judge.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.8",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Job 19:8",
      "text": "He hath hedged in my path round about, and I cannot pass, and in my way he hath set darkness.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.9",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Job 19:9",
      "text": "He hath stripped me of my glory, and hath taken the crown from my head.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.10",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Job 19:10",
      "text": "He hath destroyed me on every side, and I am lost, and he hath taken away my hope, as from a tree that is plucked up.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.11",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Job 19:11",
      "text": "His wrath is kindled against me, and he hath counted me as his enemy.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.12",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Job 19:12",
      "text": "His troops have come together, and have made themselves a way by me, and have besieged my tabernacle round about.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.13",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Job 19:13",
      "text": "He hath put my brethren far from me, and my acquaintance like strangers have departed from me.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.14",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Job 19:14",
      "text": "My kinsmen have forsaken me, and they that knew me, have forgotten me.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.15",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Job 19:15",
      "text": "They that dwell in my house, and my maidservants have counted me as a stranger, and I have been like an alien in their eyes.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.16",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "Job 19:16",
      "text": "I called my servant, and he gave me no answer, I entreated him with my own mouth.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.17",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "Job 19:17",
      "text": "My wife hath abhorred my breath, and I entreated the children of my womb.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.18",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "Job 19:18",
      "text": "Even fools despised me, and when I was gone from them, they spoke against me.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.19",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "Job 19:19",
      "text": "They that were sometime my counsellors, have abhorred me: and he whom I loved most is turned against me.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.20",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "Job 19:20",
      "text": "The flesh being consumed, my bone hath cleaved to my skin, and nothing but lips are left about my teeth.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.21",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "Job 19:21",
      "text": "Have pity on me, have pity on me, at least you my friends, because the hand of the Lord hath touched me.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.22",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 22,
      "referenceLabel": "Job 19:22",
      "text": "Why do you persecute me as God, and glut yourselves with my flesh?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.23",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 23,
      "referenceLabel": "Job 19:23",
      "text": "Who will grant me that my words may be written? who will grant me that they may be marked down in a book?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.24",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 24,
      "referenceLabel": "Job 19:24",
      "text": "With an iron pen and in a plate of lead, or else be graven with an instrument in flint stone?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.25",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 25,
      "referenceLabel": "Job 19:25",
      "text": "For I know that my Redeemer liveth, and in the last day I shall rise out of the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.26",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 26,
      "referenceLabel": "Job 19:26",
      "text": "And I shall be clothed again with my skin, and in my flesh I shall see my God.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.27",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 27,
      "referenceLabel": "Job 19:27",
      "text": "Whom I myself shall see, and my eyes shall behold, and not another: this my hope is laid up in my bosom.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.28",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 28,
      "referenceLabel": "Job 19:28",
      "text": "Why then do you say now: Let us persecute him, and let us find occasion of word against him?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.19.29",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 29,
      "referenceLabel": "Job 19:29",
      "text": "Flee then from the face of the sword, for the sword is the revenger of iniquities: and know ye that there is a judgment.",
      "paragraphStart": false
    }
  ]
}
