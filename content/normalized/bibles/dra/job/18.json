{
  "chapter": {
    "id": "dra:job.18",
    "translationId": "dra",
    "bookSlug": "job",
    "chapterNumber": 18,
    "referenceLabel": "Job 18",
    "summary": "Source text for Job 18 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:job.18.1",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Job 18:1",
      "text": "Then Baldad the Suhite answered, and said:",
      "paragraphStart": true
    },
    {
      "id": "dra:job.18.2",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Job 18:2",
      "text": "How long will you throw out words? understand first, and so let us speak.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.18.3",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Job 18:3",
      "text": "Why are we reputed as beasts, and counted vile before you?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.18.4",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Job 18:4",
      "text": "Thou that destroyest thy soul in thy fury, shall the earth be forsaken for thee, and shall rocks be removed out of their place?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.18.5",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Job 18:5",
      "text": "Shall not the light of the wicked be extinguished, and the flame of his fire not shine?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.18.6",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Job 18:6",
      "text": "The light shall be dark in his tabernacle, and the lamp that is over him, shall be put out.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.18.7",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Job 18:7",
      "text": "The step of his strength shall be straitened, and his own counsel shall cast him down headlong.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.18.8",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Job 18:8",
      "text": "For he hath thrust his feet into a net, and walketh in its meshes.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.18.9",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Job 18:9",
      "text": "The sole of his foot shall be held in a snare, and thirst shall burn against him.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.18.10",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Job 18:10",
      "text": "A gin is hidden for him in the earth, and his trap upon the path.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.18.11",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Job 18:11",
      "text": "Fears shall terrify him on every side, and shall entangle his feet.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.18.12",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Job 18:12",
      "text": "Let his strength be wasted with famine, and let hunger invade his ribs.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.18.13",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "Job 18:13",
      "text": "Let it devour the beauty of his skin, let the firstborn death consume his arms.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.18.14",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "Job 18:14",
      "text": "Let his confidence be rooted out of his tabernacle, and let destruction tread upon him like a king.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.18.15",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "Job 18:15",
      "text": "Let the companions of him that is not, dwell in his tabernacle, let brimstone be sprinkled in his tent.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.18.16",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 16,
      "referenceLabel": "Job 18:16",
      "text": "Let his roots be dried up beneath, and his harvest destroyed above.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.18.17",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 17,
      "referenceLabel": "Job 18:17",
      "text": "Let the memory of him perish from the earth, and let not his name be renowned in the streets.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.18.18",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 18,
      "referenceLabel": "Job 18:18",
      "text": "He shall drive him out of light into darkness, and shall remove him out of the world.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.18.19",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 19,
      "referenceLabel": "Job 18:19",
      "text": "His seed shall not subsist, nor his offspring among his people, nor any remnants in his country.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.18.20",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 20,
      "referenceLabel": "Job 18:20",
      "text": "They that come after him shall be astonished at his day, and horror shall fall upon them that went before.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.18.21",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 21,
      "referenceLabel": "Job 18:21",
      "text": "These then are the tabernacles of the wicked, and this the place of him that knoweth not God.",
      "paragraphStart": false
    }
  ]
}
