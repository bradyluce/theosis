      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Job 25:1",
      "text": "Then Baldad the Suhite answered, and said:",
      "paragraphStart": true
    },
    {
      "id": "dra:job.25.2",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Job 25:2",
      "text": "Power and terror are with him, who maketh peace in his high places.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.25.3",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Job 25:3",
      "text": "Is there any numbering of his soldiers? and upon whom shall not his light arise?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.25.4",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Job 25:4",
      "text": "Can man be justified compared with God, or he that is born of a woman appear clean?",
      "paragraphStart": false
    },
    {
      "id": "dra:job.25.5",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Job 25:5",
      "text": "Behold even the moon doth not shine, and the stars are not pure in his sight.",
      "paragraphStart": false
    },
    {
      "id": "dra:job.25.6",
      "translationId": "dra",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Job 25:6",
      "text": "How much more is man than rottenness and the son of man than a worm?",
      "paragraphStart": false
    }
  ]
}
