{
  "chapter": {
    "id": "dra:genesis.5",
    "translationId": "dra",
    "bookSlug": "genesis",
    "chapterNumber": 5,
    "referenceLabel": "Genesis 5",
    "summary": "Source text for Genesis 5 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:genesis.5.1",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Genesis 5:1",
      "text": "This is the book of the generation of Adam. In the day that God created man, he made him to the likeness of God.",
      "paragraphStart": true
    },
    {
      "id": "dra:genesis.5.2",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Genesis 5:2",
      "text": "He created them male and female; and blessed them: and called their name Adam, in the day when they were created.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.3",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Genesis 5:3",
      "text": "And Adam lived a hundred and thirty years, and begot a son to his own image and likeness, and called his name Seth.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.4",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Genesis 5:4",
      "text": "And the days of Adam, after he begot Seth, were eight hundred years: and he begot sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.5",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Genesis 5:5",
      "text": "And all the time that Adam lived, came to nine hundred and thirty years, and he died.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.6",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Genesis 5:6",
      "text": "Seth also lived a hundred and five years, and begot Enos.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.7",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Genesis 5:7",
      "text": "And Seth lived after he begot Enos, eight hundred and seven years, and begot sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.8",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Genesis 5:8",
      "text": "And all the days of Seth were nine hundred and twelve years, and he died.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.9",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Genesis 5:9",
      "text": "And Enos lived ninety years, and begot Cainan.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.10",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Genesis 5:10",
      "text": "After whose birth he lived eight hundred and fifteen years, and begot sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.11",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Genesis 5:11",
      "text": "And all the days of Enos were nine hundred and five years, and he died.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.12",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Genesis 5:12",
      "text": "And Cainan lived seventy years, and begot Malaleel.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.13",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Genesis 5:13",
      "text": "And Cainan lived after he begot Malaleel, eight hundred and forty years, and begot sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.14",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Genesis 5:14",
      "text": "And all the days of Cainan were nine hundred and ten years, and he died.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.15",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Genesis 5:15",
      "text": "And Malaleel lived sixty-five years and begot Jared.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.16",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Genesis 5:16",
      "text": "And Malaleel lived after he begot Jared, eight hundred and thirty years, and begot sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.17",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Genesis 5:17",
      "text": "And all the days of Malaleel were eight hundred and ninety-five years, and he died.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.18",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Genesis 5:18",
      "text": "And Jared lived a hundred and sixty-two years, and begot Henoch.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.19",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Genesis 5:19",
      "text": "And Jared lived after he begot Henoch, eight hundred years, and begot sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.20",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Genesis 5:20",
      "text": "And all the days of Jared were nine hundred and sixty-two years, and he died.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.21",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Genesis 5:21",
      "text": "And Henoch lived sixty-five years, and begot Mathusala.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.22",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Genesis 5:22",
      "text": "And Henoch walked with God: and lived after he begot Mathusala, three hundred years, and begot sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.23",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Genesis 5:23",
      "text": "And all the days of Henoch were three hundred and sixty-five years.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.24",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Genesis 5:24",
      "text": "And he walked with God, and was seen no more: because God took him.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.25",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Genesis 5:25",
      "text": "And Mathusala lived a hundred and eighty-seven years, and begot Lamech.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.26",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Genesis 5:26",
      "text": "And Mathlusala lived after he begot Lamech, seven hundred and eighty-two years, and begot sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.27",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Genesis 5:27",
      "text": "And all the days of Mathusala were nine hundred and sixty-nine years, and he died.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.28",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "Genesis 5:28",
      "text": "And Lamech lived a hundred and eighty-two years, and begot a son.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.29",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "Genesis 5:29",
      "text": "And he called his name Noe, saying: This same shall comfort us from the works and labours of our hands on the earth, which the Lord hath cursed.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.30",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "Genesis 5:30",
      "text": "And Lamech lived after he begot Noe, five hundred and ninety-five years, and begot sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "dra:genesis.5.31",
      "translationId": "dra",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "Genesis 5:31",
      "text": "And all the days of Lamech came to seven hundred and seventy-seven years, and he died. And Noe, when he was five hundred years old, begot Sem, Cham, and Japheth.",
      "paragraphStart": false
    }
  ]
}
