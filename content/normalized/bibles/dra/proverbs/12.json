{
  "chapter": {
    "id": "dra:proverbs.12",
    "translationId": "dra",
    "bookSlug": "proverbs",
    "chapterNumber": 12,
    "referenceLabel": "Proverbs 12",
    "summary": "Source text for Proverbs 12 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:proverbs.12.1",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 12:1",
      "text": "He that loveth correction, loveth knowledge: but he that hateth reproof, is foolish.",
      "paragraphStart": true
    },
    {
      "id": "dra:proverbs.12.2",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 12:2",
      "text": "He that is good, shall draw grace from the Lord: but he that trusteth in his own devices, doth wickedly.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.3",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 12:3",
      "text": "Man shall not be strengthened by wickedness: and the root of the just shall not be moved.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.4",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 12:4",
      "text": "A diligent woman is a crown to her husband: and she that doth things worthy of confusion, is as rottenness in his bones.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.5",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 12:5",
      "text": "The thoughts of the just are judgments: and the counsels of the wicked are deceitful.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.6",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 12:6",
      "text": "The words of the wicked lie in wait for blood: the mouth of the just shall deliver them.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.7",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 12:7",
      "text": "Turn the wicked, and they shall not be: but the house of the just shall stand firm.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.8",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 12:8",
      "text": "A man shall be known by his learning: but he that is vain and foolish, shall be exposed to contempt.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.9",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 12:9",
      "text": "Better is the poor man that provideth for himself, than he that is glorious and wanteth bread.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.10",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 12:10",
      "text": "The just regardeth the lives of his beasts: but the bowels of the wicked are cruel.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.11",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 12:11",
      "text": "He that tilleth his land shall be satisfied with bread: but he that pursueth idleness is very foolish.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.12",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 12:12",
      "text": "He that is delighted in passing his time over wine, leaveth a reproach in his strong holds. The desire of the wicked is the fortification of evil men: but the root of the just shall prosper.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.13",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 12:13",
      "text": "For the sins of the lips ruin draweth nigh to the evil man: but the just shall escape out of distress.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.14",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 12:14",
      "text": "By the fruit of his own mouth shall a man be filled with good things, and according to the works of his hands it shall be repaid him.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.15",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 12:15",
      "text": "The way of a fool is right in his own eyes: but he that is wise hearkeneth unto counsels.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.16",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 12:16",
      "text": "A fool immediately sheweth his anger: but he that dissembleth injuries is wise.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.17",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 12:17",
      "text": "He that speaketh that which he knoweth, sheweth forth justice: but he that lieth, is a deceitful witness.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.18",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 12:18",
      "text": "There is that promiseth, and is pricked as it were with a sword of conscience: but the tongue of the wise is health.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.19",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 12:19",
      "text": "The lip of truth shall be steadfast for ever: but he that is a hasty witness, frameth a lying tongue.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.20",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 12:20",
      "text": "Deceit is in the heart of them that think evil things: but joy followeth them that take counsels of peace.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.21",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 12:21",
      "text": "Whatsoever shall befall the just man, shall not make him sad: but the wicked shall be filled with mischief.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.22",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 12:22",
      "text": "Lying lips are an abomination to the Lord: but they that deal faithfully, please him.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.23",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 12:23",
      "text": "A cautious man concealeth knowledge: and the heart of fools publisheth folly.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.24",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 12:24",
      "text": "The hand of the valiant shall bear rule: but that which is slothful shall be under tribute.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.25",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 12:25",
      "text": "Grief in the heart of a man shall bring him low, but with a good word he shall be made glad.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.26",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 12:26",
      "text": "He that neglecteth a loss for the sake of a friend, is just: but the way of the wicked shall deceive them.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.27",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 12:27",
      "text": "The deceitful man shall not find gain: but the substance of a just man shall be precious gold.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.12.28",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 12:28",
      "text": "In the path of justice is life: but the bye-way leadeth to death.",
      "paragraphStart": false
    }
  ]
}
