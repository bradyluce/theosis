{
  "chapter": {
    "id": "dra:proverbs.2",
    "translationId": "dra",
    "bookSlug": "proverbs",
    "chapterNumber": 2,
    "referenceLabel": "Proverbs 2",
    "summary": "Source text for Proverbs 2 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:proverbs.2.1",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 2:1",
      "text": "My son, if thou wilt receive my words, and wilt hide my commandments with thee,",
      "paragraphStart": true
    },
    {
      "id": "dra:proverbs.2.2",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 2:2",
      "text": "That thy ear may hearken to wisdom: incline thy heart to know prudence.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.3",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 2:3",
      "text": "For if thou shalt call for wisdom, and incline thy heart to prudence:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.4",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 2:4",
      "text": "If thou shalt seek her as money, and shalt dig for her as for a treasure:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.5",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 2:5",
      "text": "Then shalt thou understand the fear of the Lord, and shalt find the knowledge of God:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.6",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 2:6",
      "text": "Because the Lord giveth wisdom: and out of his mouth cometh prudence and knowledge.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.7",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 2:7",
      "text": "He wilt keep the salvation of the righteous, and protect them that walk in simplicity,",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.8",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 2:8",
      "text": "Keeping the paths of justice, and guarding the ways of saints.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.9",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 2:9",
      "text": "Then shalt thou understand justice, and judgment, and equity, and every good path.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.10",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 2:10",
      "text": "If wisdom shall enter into thy heart, and knowledge please thy soul:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.11",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 2:11",
      "text": "Counsel shall keep thee, and prudence shall preserve thee,",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.12",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 2:12",
      "text": "That thou mayst be delivered from the evil way, and from the man that speaketh perverse things:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.13",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 2:13",
      "text": "Who leave the right way, and walk by dark ways:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.14",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 2:14",
      "text": "Who are glad when they have done evil, and rejoice in the most wicked things:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.15",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 2:15",
      "text": "Whose ways are perverse, and their steps infamous.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.16",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 2:16",
      "text": "That thou mayst be delivered from the strange woman, and from the stranger, who softeneth her words;",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.17",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 2:17",
      "text": "And forsaketh the guide of her youth,",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.18",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 2:18",
      "text": "And hath forgotten the covenant of her God: for her house inclineth unto death, and her paths to hell.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.19",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 2:19",
      "text": "None that go in unto her, shall return again, neither shall they take hold of the paths of life.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.20",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 2:20",
      "text": "That thou mayst walk in a good way: and mayst keep the paths of the just.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.21",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 2:21",
      "text": "For they that are upright, shall dwell in the earth; and the simple shall continue in it.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.2.22",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 2:22",
      "text": "But the wicked shall be destroyed from the earth: and they that do unjustly, shall be taken away from it.",
      "paragraphStart": false
    }
  ]
}
