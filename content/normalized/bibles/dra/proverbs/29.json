{
  "chapter": {
    "id": "dra:proverbs.29",
    "translationId": "dra",
    "bookSlug": "proverbs",
    "chapterNumber": 29,
    "referenceLabel": "Proverbs 29",
    "summary": "Source text for Proverbs 29 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:proverbs.29.1",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 29:1",
      "text": "The man that with a stiff neck despiseth him that reproveth him, shall suddenly be destroyed: and health shall not follow him.",
      "paragraphStart": true
    },
    {
      "id": "dra:proverbs.29.2",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 29:2",
      "text": "When just men increase, the people shall rejoice: when the wicked shall bear rule, the people shall mourn.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.3",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 29:3",
      "text": "A man that loveth wisdom, rejoiceth his father: but he that maintaineth harlots, shall squander away his substance.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.4",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 29:4",
      "text": "A just king setteth up the land: a covetous man shall destroy it.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.5",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 29:5",
      "text": "A man that speaketh to his friend with flattering and dissembling words, spreadeth a net for his feet.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.6",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 29:6",
      "text": "A snare shall entangle the wicked man when he sinneth: and the just shall praise and rejoice.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.7",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 29:7",
      "text": "The just taketh notice of the cause of the poor: the wicked is void of knowledge.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.8",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 29:8",
      "text": "Corrupt men bring a city to ruin: but wise men turn away wrath.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.9",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 29:9",
      "text": "If a wise man contend with a fool, whether he be angry, or laugh, he shall find no rest.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.10",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 29:10",
      "text": "Bloodthirsty men hate the upright: but just men seek his soul.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.11",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 29:11",
      "text": "A fool uttereth all his mind: a wise man deferreth, and keepeth it till afterwards.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.12",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 29:12",
      "text": "A prince that gladly heareth lying words, hath all his servants wicked.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.13",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 29:13",
      "text": "The poor man and the creditor have met one another: the Lord is the enlightener of them both.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.14",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 29:14",
      "text": "The king that judgeth the poor in truth, his throne shall be established for ever.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.15",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 29:15",
      "text": "The rod and reproof give wisdom: but the child that is left to his own will, bringeth his mother to shame.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.16",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 29:16",
      "text": "When the wicked are multiplied, crimes shall be multiplied: but the just shall see their downfall.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.17",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 29:17",
      "text": "Instruct thy son and he shall refresh thee, and shall give delight to thy soul.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.18",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 29:18",
      "text": "When prophecy shall fail, the people shall be scattered abroad: but he that keepeth the law, is blessed.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.19",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 29:19",
      "text": "A slave will not be corrected by words: because he understandeth what thou sayest, and will not answer.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.20",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 29:20",
      "text": "Hast thou seen a man hasty to speak? folly is rather to be looked for, than his amendment.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.21",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 29:21",
      "text": "He that nourisheth his servant delicately from his childhood, afterwards shall find him stubborn.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.22",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 29:22",
      "text": "A passionate man provoketh quarrels: and he that is easily stirred up to wrath, shall be more prone to sin.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.23",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 29:23",
      "text": "Humiliation followeth the proud: and glory shall uphold the humble of spirit.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.24",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 29:24",
      "text": "He that is partaker with a thief, hateth his own soul: he heareth one putting him to his oath, and discovereth not.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.25",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 29:25",
      "text": "He that feareth man shall quickly fall: he that trusteth in the Lord, shall be set on high.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.26",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 29:26",
      "text": "Many seek the face of the prince: but the judgment of every one cometh forth from the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.29.27",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 29:27",
      "text": "The just abhor a wicked man: and the wicked loathe them that are in the right way. The son that keepeth the word, shall be free from destruction.",
      "paragraphStart": false
    }
  ]
}
