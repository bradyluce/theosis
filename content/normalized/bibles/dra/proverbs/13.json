{
  "chapter": {
    "id": "dra:proverbs.13",
    "translationId": "dra",
    "bookSlug": "proverbs",
    "chapterNumber": 13,
    "referenceLabel": "Proverbs 13",
    "summary": "Source text for Proverbs 13 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:proverbs.13.1",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 13:1",
      "text": "A wise son heareth the doctrine of his father: but he that is a scorner, heareth not when he is reproved.",
      "paragraphStart": true
    },
    {
      "id": "dra:proverbs.13.2",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 13:2",
      "text": "Of the fruit of his own month shall a man be filled with good things: but the soul of transgressors is wicked.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.3",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 13:3",
      "text": "He that keepeth his mouth keepeth his soul: but he that hath no guard on his speech shall meet with evils.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.4",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 13:4",
      "text": "The sluggard willeth, and willeth not: but the soul of them that work, shall be made fat.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.5",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 13:5",
      "text": "The just shall hate a lying word: but the wicked confoundeth, and shall be confounded.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.6",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 13:6",
      "text": "Justice keepeth the way of the innocent: but wickedness overthroweth the sinner.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.7",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 13:7",
      "text": "One is as it were rich, when he hath nothing and another is as it were poor, when he hath great riches.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.8",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 13:8",
      "text": "The ransom of a man's life are his riches: but he that is poor, beareth not reprehension.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.9",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 13:9",
      "text": "The light of the just giveth joy: but the lamp of the wicked shall be put out.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.10",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 13:10",
      "text": "Among the proud there are always contentions: but they that do all things with counsel, are ruled by wisdom.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.11",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 13:11",
      "text": "Substance got in haste shall be diminished: but that which by little and little is gathered with the hand, shall increase.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.12",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 13:12",
      "text": "Hope that is deferred afflicteth the soul: desire when it cometh, is a tree of life.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.13",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 13:13",
      "text": "Whosoever speaketh ill of any thing, bindeth himself for the time to come: but he that feareth the commandment, shall dwell in peace. Deceitful souls go astray in sins: the just are merciful, and shew mercy.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.14",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 13:14",
      "text": "The law of the wise is a fountain of life, that he may decline from the ruin of death.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.15",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 13:15",
      "text": "Good instruction shall give grace: in the way of scorners is a deep pit.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.16",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 13:16",
      "text": "The prudent man doth all things with counsel: but he that is a fool, layeth open his folly.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.17",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 13:17",
      "text": "The messenger of the wicked shall fall into mischief: but a faithful ambassador is health.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.18",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 13:18",
      "text": "Poverty and shame to him that refuseth instruction: but he that yieldeth to reproof shall be glorified.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.19",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 13:19",
      "text": "The desire that is accomplished, delighteth the soul: fools hate them that flee from evil things.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.20",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 13:20",
      "text": "He that walketh with the wise, shall be wise: a friend of fools shall become like to them.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.21",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 13:21",
      "text": "Evil pursueth sinners: and to the just good shall be repaid.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.22",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 13:22",
      "text": "The good man leaveth heirs, sons, and grandsons: and the substance of the sinner is kept for the just.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.23",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 13:23",
      "text": "Much food is in the tillage of fathers: but for others it is gathered without judgment.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.24",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 13:24",
      "text": "He that spareth the rod, hateth his son: but he that loveth him, correcteth him betimes.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.13.25",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 13:25",
      "text": "The just eateth and filleth his soul: but the belly of the wicked is never to be filled.",
      "paragraphStart": false
    }
  ]
}
