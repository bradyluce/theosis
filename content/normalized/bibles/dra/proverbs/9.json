{
  "chapter": {
    "id": "dra:proverbs.9",
    "translationId": "dra",
    "bookSlug": "proverbs",
    "chapterNumber": 9,
    "referenceLabel": "Proverbs 9",
    "summary": "Source text for Proverbs 9 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:proverbs.9.1",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 9:1",
      "text": "Wisdom hath built herself a house, she hath hewn her out seven pillars.",
      "paragraphStart": true
    },
    {
      "id": "dra:proverbs.9.2",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 9:2",
      "text": "She hath slain her victims, mingled her wine, and set forth her table.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.9.3",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 9:3",
      "text": "She hath sent her maids to invite to the tower, and to the walls of the city:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.9.4",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 9:4",
      "text": "Whosoever is a little one, let him come to me. And to the unwise she said:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.9.5",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 9:5",
      "text": "Come, eat my bread, and drink the wine which I have mingled for you.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.9.6",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 9:6",
      "text": "Forsake childishness, and live, and walk by the ways of prudence.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.9.7",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 9:7",
      "text": "He that teacheth a scorner, doth an injury to himself; and he that rebuketh a wicked man, getteth himself a blot.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.9.8",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 9:8",
      "text": "Rebuke not a scorner, lest he hate thee. Rebuke a wise man, and he will love thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.9.9",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 9:9",
      "text": "Give an occasion to a wise man, and wisdom shall be added to him. Teach a just man, and he shall make haste to receive it.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.9.10",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 9:10",
      "text": "The fear of the Lord is the beginning of wisdom: and the knowledge of the holy is prudence.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.9.11",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 9:11",
      "text": "For by me shall thy days be multiplied, and years of life shall be added to thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.9.12",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 9:12",
      "text": "If thou be wise, thou shalt be so to thyself: and if a scorner, thou alone shalt bear the evil.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.9.13",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 9:13",
      "text": "A foolish woman and clamorous, and full of allurements, and knowing nothing at all,",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.9.14",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 9:14",
      "text": "Sat at the door of her house, upon a seat, in a high place of the city,",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.9.15",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 9:15",
      "text": "To call them that pass by the way, and go on their journey:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.9.16",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 9:16",
      "text": "He that is a little one, let him turn to me. And to the fool she said:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.9.17",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 9:17",
      "text": "Stolen waters are sweeter, and hidden bread is more pleasant.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.9.18",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 9:18",
      "text": "And he did not know that giants are there, and that her guests are in the depths of hell.",
      "paragraphStart": false
    }
  ]
}
