{
  "chapter": {
    "id": "dra:proverbs.8",
    "translationId": "dra",
    "bookSlug": "proverbs",
    "chapterNumber": 8,
    "referenceLabel": "Proverbs 8",
    "summary": "Source text for Proverbs 8 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:proverbs.8.1",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 8:1",
      "text": "Doth not wisdom cry aloud, and prudence put forth her voice?",
      "paragraphStart": true
    },
    {
      "id": "dra:proverbs.8.2",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 8:2",
      "text": "Standing in the top of the highest places by the way, in the midst of the paths,",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.3",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 8:3",
      "text": "Beside the gates of the city, in the very doors she speaketh, saying:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.4",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 8:4",
      "text": "O ye men, to you I call, and my voice is to the sons of men.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.5",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 8:5",
      "text": "O little ones understand subtlety, and ye unwise, take notice.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.6",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 8:6",
      "text": "Hear, for I will speak of great things: and my lips shall be opened to preach right things.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.7",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 8:7",
      "text": "My mouth shall meditate truth, and my lips shall hate wickedness.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.8",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 8:8",
      "text": "All my words are just, there is nothing wicked, nor perverse in them.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.9",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 8:9",
      "text": "They are right to them that understand, and just to them that find knowledge.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.10",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 8:10",
      "text": "Receive my instruction, and not money: choose knowledge rather than gold.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.11",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 8:11",
      "text": "For wisdom is better than all the most precious things: and whatsoever may be desired cannot be compared to it.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.12",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 8:12",
      "text": "I, wisdom, dwell in counsel, and am present in learned thoughts.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.13",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 8:13",
      "text": "The fear of the Lord hateth evil; I hate arrogance, and pride, and every wicked way, and a mouth with a double tongue.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.14",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 8:14",
      "text": "Counsel and equity is mine, prudence is mine, strength is mine.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.15",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 8:15",
      "text": "By me kings reign, and lawgivers decree just things.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.16",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 8:16",
      "text": "By me princes rule, and the mighty decree justice.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.17",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 8:17",
      "text": "I love them that love me: and they that in the morning early watch for me, shall find me.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.18",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 8:18",
      "text": "With me are riches and glory, glorious riches and justice.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.19",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 8:19",
      "text": "For my fruit is better than gold and the precious stone, and my blossoms than choice silver.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.20",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 8:20",
      "text": "I walk in the way of justice, in the midst of the paths of judgment,",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.21",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 8:21",
      "text": "That I may enrich them that love me, and may fill their treasures.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.22",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 8:22",
      "text": "The Lord possessed me in the beginning of his ways, before he made any thing from the beginning.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.23",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 8:23",
      "text": "I was set up from eternity, and of old, before the earth was made.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.24",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 8:24",
      "text": "The depths were not as yet, and I was already conceived, neither had the fountains of waters as yet sprung out.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.25",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 8:25",
      "text": "The mountains, with their huge bulk, had not as yet been established: before the hills, I was brought forth:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.26",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 8:26",
      "text": "He had not yet made the earth, nor the rivers, nor the poles of the world.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.27",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 8:27",
      "text": "When he prepared the heavens, I was present: when with a certain law, and compass, he enclosed the depths:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.28",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 8:28",
      "text": "When he established the sky above, and poised the fountains of waters:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.29",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 8:29",
      "text": "When he compassed the sea with its bounds, and set a law to the waters that they should not pass their limits: when he balanced the foundations of the earth;",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.30",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 8:30",
      "text": "I was with him forming all things: and was delighted every day, playing before him at all times;",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.31",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 8:31",
      "text": "Playing in the world: and my delights were to be with the children of men.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.32",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 8:32",
      "text": "Now, therefore, ye children, hear me: blessed are they that keep my ways.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.33",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 8:33",
      "text": "Hear instruction, and be wise, and refuse it not.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.34",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 8:34",
      "text": "Blessed is the man that heareth me, and that watcheth daily at my gates, and waiteth at the posts of my doors.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.35",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 8:35",
      "text": "He that shall find me, shall find life, and shall have salvation from the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.8.36",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 36,
      "referenceLabel": "Proverbs 8:36",
      "text": "But he that shall sin against me shall hurt his own soul. All that hate me love death.",
      "paragraphStart": false
    }
  ]
}
