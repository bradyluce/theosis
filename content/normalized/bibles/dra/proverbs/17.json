{
  "chapter": {
    "id": "dra:proverbs.17",
    "translationId": "dra",
    "bookSlug": "proverbs",
    "chapterNumber": 17,
    "referenceLabel": "Proverbs 17",
    "summary": "Source text for Proverbs 17 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:proverbs.17.1",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 17:1",
      "text": "Better is a dry morsel with joy, than a house full of victims with strife.",
      "paragraphStart": true
    },
    {
      "id": "dra:proverbs.17.2",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 17:2",
      "text": "A wise servant shall rule over foolish sons, and shall divide the inheritance among the brethren.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.3",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 17:3",
      "text": "As silver is tried by fire, and gold in the furnace: so the Lord trieth the hearts.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.4",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 17:4",
      "text": "The evil man obeyeth an unjust tongue: and the deceitful hearkeneth to lying lips.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.5",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 17:5",
      "text": "He that despiseth the poor, reproacheth his maker: and he that rejoiceth at another man's ruin, shall not be unpunished.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.6",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 17:6",
      "text": "Children's children are the crown of old men: and the glory of children are their fathers.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.7",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 17:7",
      "text": "Eloquent words do not become a fool, nor lying lips a prince.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.8",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 17:8",
      "text": "The expectation of him that expecteth is a most acceptable jewel: whithersoever he turneth himself, he understandeth wisely.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.9",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 17:9",
      "text": "He that concealeth a transgression, seeketh friendships: he that repeateth it again, separateth friends.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.10",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 17:10",
      "text": "A reproof availeth more with a wise man, than a hundred stripes with a fool.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.11",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 17:11",
      "text": "An evil man always seeketh quarrels: but a cruel angel shall be sent against him.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.12",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 17:12",
      "text": "It is better to meet a bear robbed of her whelps, than a fool trusting in his own folly.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.13",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 17:13",
      "text": "He that rendereth evil for good, evil shall not depart from his house.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.14",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 17:14",
      "text": "The beginning of quarrels is as when one letteth out water: and before he suffereth reproach, he forsaketh judgment.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.15",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 17:15",
      "text": "He that justifieth the wicked, and he that condemneth the just, both are abominable before God.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.16",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 17:16",
      "text": "What doth it avail a fool to have riches, seeing he cannot buy wisdom? He that maketh his house high, seeketh a downfall: and he that refuseth to learn, shall fall into evils.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.17",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 17:17",
      "text": "He that is a friend loveth at all times: and a brother is proved in distress.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.18",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 17:18",
      "text": "A foolish man will clap hands, when he is surety for his friend.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.19",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 17:19",
      "text": "He that studieth discords, loveth quarrels: and he that exalteth his door, seeketh ruin.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.20",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 17:20",
      "text": "He that is of a perverse heart, shall not find good: and he that perverteth his tongue, shall fall into evil.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.21",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 17:21",
      "text": "A fool is born to his own disgrace: and even his father shall not rejoice in a fool.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.22",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 17:22",
      "text": "A joyful mind maketh age flourishing: a sorrowful spirit drieth up the bones.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.23",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 17:23",
      "text": "The wicked man taketh gifts out of the bosom, that he may pervert the paths of judgment.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.24",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 17:24",
      "text": "Wisdom shineth in the face of the wise: the eyes of fools are in the ends of the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.25",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 17:25",
      "text": "A foolish son is the anger of the father: and the sorrow of the mother that bore him.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.26",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 17:26",
      "text": "It is no good thing to do hurt to the just: nor to strike the prince, who judgeth right.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.27",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 17:27",
      "text": "He that setteth bounds to his words, is knowing and wise: and the man of understanding is of a precious spirit.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.17.28",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 17:28",
      "text": "Even a fool, if he will hold his peace, shall be counted wise: and if he close his lips, a man of understanding.",
      "paragraphStart": false
    }
  ]
}
