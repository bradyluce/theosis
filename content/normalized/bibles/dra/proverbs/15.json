{
  "chapter": {
    "id": "dra:proverbs.15",
    "translationId": "dra",
    "bookSlug": "proverbs",
    "chapterNumber": 15,
    "referenceLabel": "Proverbs 15",
    "summary": "Source text for Proverbs 15 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:proverbs.15.1",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 15:1",
      "text": "A mild answer breaketh wrath: but a harsh word stirreth up fury.",
      "paragraphStart": true
    },
    {
      "id": "dra:proverbs.15.2",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 15:2",
      "text": "The tongue of the wise adorneth knowledge: but the mouth of fools bubbleth out folly.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.3",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 15:3",
      "text": "The eyes of the Lord in every place behold the good and the evil.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.4",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 15:4",
      "text": "A peaceable tongue is a tree of life: but that which is immoderate, shall crush the spirit.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.5",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 15:5",
      "text": "A fool laugheth at the instruction of his father: but he that regardeth reproofs shall become prudent. In abundant justice there is the greatest strength: but the devices of the wicked shall be rooted out.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.6",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 15:6",
      "text": "The house of the just is very much strength: and in the fruits of the wicked is trouble.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.7",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 15:7",
      "text": "The lips of the wise shall disperse knowledge: the heart of fools shall be unlike.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.8",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 15:8",
      "text": "The victims of the wicked are abominable to the Lord: the vows of the just are acceptable.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.9",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 15:9",
      "text": "The way of the wicked is an abomination to the Lord: he that followeth justice is beloved by him.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.10",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 15:10",
      "text": "Instruction is grievous to him that forsaketh the way of life: he that hateth reproof shall die.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.11",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 15:11",
      "text": "Hell and destruction are before the Lord: how much more the hearts of the children of men?",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.12",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 15:12",
      "text": "A corrupt man loveth not one that reproveth him: nor will he go to the wise.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.13",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 15:13",
      "text": "A glad heart maketh a cheerful countenance: but by grief of mind the spirit is cast down.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.14",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 15:14",
      "text": "The heart of the wise seeketh instruction: and the mouth of fools feedeth on foolishness.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.15",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 15:15",
      "text": "All the days of the poor are evil: a secure mind is like a continual feast.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.16",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 15:16",
      "text": "Better is a little with the fear of the Lord, than great treasures without content.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.17",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 15:17",
      "text": "It is better to be invited to herbs with love, than to a fatted calf with hatred.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.18",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 15:18",
      "text": "A passionate man stirreth up strifes: he that is patient appeaseth those that are stirred up.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.19",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 15:19",
      "text": "The way of the slothful is as a hedge of thorns: the way of the just is without offence.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.20",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 15:20",
      "text": "A wise son maketh a father joyful: but the foolish man despiseth his mother.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.21",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 15:21",
      "text": "Folly is joy to the fool: and the wise man maketh straight his steps.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.22",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 15:22",
      "text": "Designs are brought to nothing where there is no counsel: but where there are many counsellors, they are established.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.23",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 15:23",
      "text": "A man rejoiceth in the sentence of his mouth: and a word in due time is best.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.24",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 15:24",
      "text": "The path of life is above for the wise, that he may decline from the lowest hell.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.25",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 15:25",
      "text": "The Lord will destroy the house of the proud: and will strengthen the borders of the widow.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.26",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 15:26",
      "text": "Evil thoughts are an abomination to the Lord: and pure words most beautiful shall be confirmed by him.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.27",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 15:27",
      "text": "He that is greedy of gain troubleth his own house: but he that hateth bribes shall live. By mercy and faith sins are purged away: and by the fear of the Lord every one declineth from evil.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.28",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 15:28",
      "text": "The mind of the just studieth obedience: the mouth of the wicked overfloweth with evils.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.29",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 15:29",
      "text": "The Lord is far from the wicked: and he will hear the prayers of the just.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.30",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 15:30",
      "text": "The light of the eyes rejoiceth the soul: a good name maketh the bones fat.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.31",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 15:31",
      "text": "The ear that heareth the reproofs of life, shall abide in the midst of the wise.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.32",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 15:32",
      "text": "He that rejecteth instruction, despiseth his own soul: but he that yieldeth to reproof, possesseth understanding.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.15.33",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 15:33",
      "text": "The fear of the Lord is the lesson of wisdom: and humility goeth before glory.",
      "paragraphStart": false
    }
  ]
}
