{
  "chapter": {
    "id": "dra:proverbs.14",
    "translationId": "dra",
    "bookSlug": "proverbs",
    "chapterNumber": 14,
    "referenceLabel": "Proverbs 14",
    "summary": "Source text for Proverbs 14 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:proverbs.14.1",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 14:1",
      "text": "A wise woman buildeth her house: but the foolish will pull down with her hands that also which is built.",
      "paragraphStart": true
    },
    {
      "id": "dra:proverbs.14.2",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 14:2",
      "text": "He that walketh in the right way, and feareth God, is despised by him that goeth by an infamous way.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.3",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 14:3",
      "text": "In the mouth of a fool is the rod of pride: but the lips of the wise preserve them.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.4",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 14:4",
      "text": "Where there are no oxen, the crib is empty: but where there is much corn, there the strength of the ox is manifest.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.5",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 14:5",
      "text": "A faithful witness will not lie: but a deceitful witness uttereth a lie.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.6",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 14:6",
      "text": "A scorner seeketh wisdom, and findeth it not: the learning of the wise is easy.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.7",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 14:7",
      "text": "Go against a foolish man, and he knoweth not the lips of prudence.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.8",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 14:8",
      "text": "The wisdom of a discreet man is to understand his way: and the imprudence of fools erreth.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.9",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 14:9",
      "text": "A fool will laugh at sin, but among the just grace shall abide.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.10",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 14:10",
      "text": "The heart that knoweth the bitterness of his own soul, in his joy the stranger shall not intermeddle.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.11",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 14:11",
      "text": "The house of the wicked shall be destroyed: but the tabernacles of the just shall flourish.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.12",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 14:12",
      "text": "There is a way which seemeth just to a man: but the ends thereof lead to death.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.13",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 14:13",
      "text": "Laughter shall be mingled with sorrow, and mourning taketh hold of the ends of joy.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.14",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 14:14",
      "text": "A fool shall be filled with his own ways, and the good man shall be above him.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.15",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 14:15",
      "text": "The innocent believeth every word: the discreet man considereth his steps. No good shall come to the deceitful son: but the wise servant shall prosper in his dealings, and his way shall be made straight.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.16",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 14:16",
      "text": "A wise man feareth, and declineth from evil: the fool leapeth over, and is confident.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.17",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 14:17",
      "text": "The impatient man shall work folly: and the crafty man is hateful.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.18",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 14:18",
      "text": "The childish shall possess folly, and the prudent shall look for knowledge.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.19",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 14:19",
      "text": "The evil shall fall down before the good: and the wicked before the gates of the just.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.20",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 14:20",
      "text": "The poor man shall be hateful even to his own neighbour: but the friends of the rich are many.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.21",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 14:21",
      "text": "He that despiseth his neighbour, sinneth: but he that sheweth mercy to the poor, shall be blessed. He that believeth in the Lord, loveth mercy.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.22",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 14:22",
      "text": "They err that work evil: but mercy and truth prepare good things.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.23",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 14:23",
      "text": "In much work there shall be abundance: but where there are many words, there is oftentimes want.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.24",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 14:24",
      "text": "The crown of the wise, is their riches: the folly of fools, imprudence.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.25",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 14:25",
      "text": "A faithful witness delivereth souls: and the double dealer uttereth lies.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.26",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 14:26",
      "text": "In the fear of the Lord is confidence of strength, and there shall be hope for his children.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.27",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 14:27",
      "text": "The fear of the Lord is a fountain of life, to decline from the ruin of death.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.28",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 14:28",
      "text": "In the multitude of people is the dignity of the king: and in the small number of the people the dishonour of the prince.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.29",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 14:29",
      "text": "He that is patient, is governed with much wisdom: but he that is impatient, exalteth his folly.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.30",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 14:30",
      "text": "Soundness of heart is the life of the flesh: but envy is the rottenness of the bones.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.31",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 14:31",
      "text": "He that oppresseth the poor, upbraideth his maker: but he that hath pity on the poor, honoureth him.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.32",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 14:32",
      "text": "The wicked man shall be driven out in his wickedness: but the just hath hope in his death.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.33",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 14:33",
      "text": "In the heart of the prudent resteth wisdom, and it shall instruct all the ignorant.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.34",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 14:34",
      "text": "Justice exalteth a nation: but sin maketh nations miserable.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.14.35",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 14:35",
      "text": "A wise servant is acceptable to the king: he that is good for nothing shall feel his anger.",
      "paragraphStart": false
    }
  ]
}
