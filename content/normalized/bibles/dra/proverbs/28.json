{
  "chapter": {
    "id": "dra:proverbs.28",
    "translationId": "dra",
    "bookSlug": "proverbs",
    "chapterNumber": 28,
    "referenceLabel": "Proverbs 28",
    "summary": "Source text for Proverbs 28 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:proverbs.28.1",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 28:1",
      "text": "The wicked man fleeth, when no man pursueth: but the just, bold as a lion, shall be without dread.",
      "paragraphStart": true
    },
    {
      "id": "dra:proverbs.28.2",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 28:2",
      "text": "For the sins of the land many are the princes thereof: and for the wisdom of a man, and the knowledge of those things that are said, the life of the prince shall be prolonged.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.3",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 28:3",
      "text": "A poor man that oppresseth the poor, is like a violent shower, which bringeth a famine.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.4",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 28:4",
      "text": "They that forsake the law, praise the wicked man: they that keep it, are incensed against him.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.5",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 28:5",
      "text": "Evil men think not on judgment: but they that seek after the Lord, take notice of all things.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.6",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 28:6",
      "text": "Better is the poor man walking in his simplicity, than the rich in crooked ways.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.7",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 28:7",
      "text": "He that keepeth the law, is a wise son: but he that feedeth gluttons, shameth his father.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.8",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 28:8",
      "text": "He that heapeth together riches by usury and loan, gathereth them for him that will be bountiful to the poor.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.9",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 28:9",
      "text": "He that turneth away his ears from hearing the law, his prayer shall be an abomination.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.10",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 28:10",
      "text": "He that deceiveth the just in a wicked way, shall fall in his own destruction: and the upright shall possess his goods.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.11",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 28:11",
      "text": "The rich man seemeth to himself wise: but the poor man that is prudent shall search him out.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.12",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 28:12",
      "text": "In the joy of the just there is great glory: when the wicked reign, men are ruined.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.13",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 28:13",
      "text": "He that hideth his sins, shall not prosper: but he that shall confess, and forsake them, shall obtain mercy.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.14",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 28:14",
      "text": "Blessed is the man that is always fearful: but he that is hardened in mind shall fall into evil.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.15",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 28:15",
      "text": "As a roaring lion, and a hungry bear, so is a wicked prince over the poor people.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.16",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 28:16",
      "text": "A prince void of prudence shall oppress many by calumny: but he that hateth covetousness, shall prolong his days.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.17",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 28:17",
      "text": "A man that doth violence to the blood of a person, if he flee even to the pit, no man will stay him.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.18",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 28:18",
      "text": "He that walketh uprightly, shall be saved: he that is perverse in his ways, shall fall at once.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.19",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 28:19",
      "text": "He that tilleth his ground, shall be filled with bread: but he that followeth idleness, shall be filled with poverty.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.20",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 28:20",
      "text": "A faithful man shall be much praised: but he that maketh haste to be rich, shall not be innocent.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.21",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 28:21",
      "text": "He that hath respect to a person in judgment, doth not well: such a man even for a morsel of bread forsaketh the truth.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.22",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 28:22",
      "text": "A man that maketh haste to be rich, and envieth others, is ignorant that poverty shall come upon him.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.23",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 28:23",
      "text": "He that rebuketh a man, shall afterward find favour with him, more than he that by a flattering tongue deceiveth him.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.24",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 28:24",
      "text": "He that stealeth any thing from his father, or from his mother: and saith, This is no sin, is the partner of a murderer.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.25",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 28:25",
      "text": "He that boasteth and puffeth up himself, stirreth up quarrels: but he that trusteth in the Lord, shall be healed.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.26",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 28:26",
      "text": "He that trusteth in his own heart, is a fool: but he that walketh wisely, he shall be saved.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.27",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 28:27",
      "text": "He that giveth to the poor shall not want: he that despiseth his entreaty, shall suffer indigence.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.28.28",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 28:28",
      "text": "When the wicked rise up, men shall hide themselves: when they perish, the just shall be multiplied.",
      "paragraphStart": false
    }
  ]
}
