{
  "chapter": {
    "id": "dra:proverbs.10",
    "translationId": "dra",
    "bookSlug": "proverbs",
    "chapterNumber": 10,
    "referenceLabel": "Proverbs 10",
    "summary": "Source text for Proverbs 10 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:proverbs.10.1",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 10:1",
      "text": "A wise son maketh the father glad: but a foolish son is the sorrow of his mother.",
      "paragraphStart": true
    },
    {
      "id": "dra:proverbs.10.2",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 10:2",
      "text": "Treasures of wickedness shall profit nothing: but justice shall deliver from death.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.3",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 10:3",
      "text": "The Lord will not afflict the soul of the just with famine, and he will disappoint the deceitful practices of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.4",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 10:4",
      "text": "The slothful hand hath wrought poverty: but the hand of the industrious getteth riches. He that trusteth to lies feedeth the winds: and the same runneth after birds, that fly away.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.5",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 10:5",
      "text": "He that gathereth in the harvest, is a wise son: but he that snorteth in the summer, is the son of confusion.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.6",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 10:6",
      "text": "The blessing of the Lord is upon the head of the just: but iniquity covereth the mouth of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.7",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 10:7",
      "text": "The memory of the just is with praises: and the name of the wicked shall rot.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.8",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 10:8",
      "text": "The wise of heart receiveth precepts: a fool is beaten with lips.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.9",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 10:9",
      "text": "He that walketh sincerely, walketh confidently: but he that perverteth his ways, shall be manifest.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.10",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 10:10",
      "text": "He that winketh with the eye, shall cause sorrow: and the foolish in lips shall be beaten.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.11",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 10:11",
      "text": "The mouth of the just is a vein of life: and the mouth of the wicked covereth iniquity.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.12",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 10:12",
      "text": "Hatred stirreth up strifes: and charity covereth all sins.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.13",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 10:13",
      "text": "In the lips of the wise is wisdom found: and a rod on the back of him that wanteth sense.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.14",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 10:14",
      "text": "Wise men lay up knowledge: but the mouth of the fool is next to confusion.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.15",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 10:15",
      "text": "The substance of a rich man is the city of his strength: the fear of the poor is their poverty.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.16",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 10:16",
      "text": "The work of the just is unto life: but the fruit of the wicked unto sin.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.17",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 10:17",
      "text": "The way of life, to him that observeth correction: but he that forsaketh reproofs, goeth astray.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.18",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 10:18",
      "text": "Lying lips hide hatred: he that uttereth reproach, is foolish.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.19",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 10:19",
      "text": "In the multitude of words there shall not want sin: but he that refraineth his lips, is most wise.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.20",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 10:20",
      "text": "The tongue of the just is as choice silver: but the heart of the wicked is nothing worth.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.21",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 10:21",
      "text": "The lips of the just teach many: but they that are ignorant, shall die in the want of understanding.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.22",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 10:22",
      "text": "The blessing of the Lord maketh men rich: neither shall affliction be joined to them.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.23",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 10:23",
      "text": "A fool worketh mischief as it were for sport: but wisdom is prudence to a man.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.24",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 10:24",
      "text": "That which the wicked feareth, shall come upon him: to the just their desire shall be given.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.25",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 10:25",
      "text": "As a tempest that passeth, so the wicked shall be no more: but the just is as an everlasting foundation.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.26",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 10:26",
      "text": "As vinegar to the teeth, and smoke to the eyes, so is the sluggard to them that sent him.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.27",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 10:27",
      "text": "The fear of the Lord shall prolong days: and the years of the wicked shall be shortened.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.28",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 10:28",
      "text": "The expectation of the just is joy: but the hope of the wicked shall perish.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.29",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 10:29",
      "text": "The strength of the upright is the way of the Lord: and fear to them that work evil.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.30",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 10:30",
      "text": "The just shall never be moved: but the wicked shall not dwell on the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.31",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 10:31",
      "text": "The mouth of the just shall bring forth wisdom: the tongue of the perverse shall perish.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.10.32",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 10:32",
      "text": "The lips of the just consider what is acceptable: and the mouth of the wicked uttereth perverse things.",
      "paragraphStart": false
    }
  ]
}
