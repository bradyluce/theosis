{
  "chapter": {
    "id": "dra:proverbs.3",
    "translationId": "dra",
    "bookSlug": "proverbs",
    "chapterNumber": 3,
    "referenceLabel": "Proverbs 3",
    "summary": "Source text for Proverbs 3 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:proverbs.3.1",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 3:1",
      "text": "My son, forget not my law, and let thy heart keep my commandments.",
      "paragraphStart": true
    },
    {
      "id": "dra:proverbs.3.2",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 3:2",
      "text": "For they shall add to thee length of days, and years of life, and peace.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.3",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 3:3",
      "text": "Let not mercy aud truth leave thee, put them about thy neck, and write them in the tables of thy heart.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.4",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 3:4",
      "text": "And thou shalt find grace, and good understanding before God and men.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.5",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 3:5",
      "text": "Have confidence in the Lord with all thy heart, and lean not upon thy own prudence.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.6",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 3:6",
      "text": "In all thy ways think on him, and he will direct thy steps.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.7",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 3:7",
      "text": "Be not wise in thy own conceit: fear God, and depart from evil:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.8",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 3:8",
      "text": "For it shall be health to thy navel, and moistening to thy bones.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.9",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 3:9",
      "text": "Honour the Lord with thy substance, and give him of the first of all thy fruits;",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.10",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 3:10",
      "text": "And thy barns shall be filled with abundance, and thy presses shall run over with wine.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.11",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 3:11",
      "text": "My son, reject not the correction of the Lord: and do not faint when thou art chastised by him:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.12",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 3:12",
      "text": "For whom the Lord loveth, he chastiseth: and as a father in the son he pleaseth himself.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.13",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 3:13",
      "text": "Blessed is the man that findeth wisdom, and is rich in prudence:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.14",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 3:14",
      "text": "The purchasing thereof is better than the merchandise of silver, and her fruit than the chief and purest gold:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.15",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 3:15",
      "text": "She is more precious than all riches: and all the things that are desired, are not to be compared to her.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.16",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 3:16",
      "text": "Length of days is in her right hand, and in her left hand riches and glory.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.17",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 3:17",
      "text": "Her ways are beautiful ways, and all her paths are peaceable.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.18",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 3:18",
      "text": "She is a tree of life to them that lay hold on her: and he that shall retain her is blessed.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.19",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 3:19",
      "text": "The Lord by wisdom hath founded the earth, hath established the heavens by prudence.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.20",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 3:20",
      "text": "By his wisdom the depths have broken out, and the clouds grow thick with dew.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.21",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 3:21",
      "text": "My son, let not these things depart from thy eyes: keep the law and counsel:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.22",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 3:22",
      "text": "And there shall be life to thy soul, and grace to thy mouth.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.23",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 3:23",
      "text": "Then shalt thou walk confidently in thy way, and thy foot shall not stumble:",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.24",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 3:24",
      "text": "If thou sleep, thou shalt not fear: thou shalt rest, and thy sleep shall be sweet.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.25",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 3:25",
      "text": "Be not afraid of sudden fear, nor of the power of the wicked falling upon thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.26",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 3:26",
      "text": "For the Lord will be at thy side, and will keep thy foot that thou be not taken.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.27",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 3:27",
      "text": "Do not withhold him from doing good, who is able: if thou art able, do good thyself also.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.28",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 3:28",
      "text": "Say not to thy friend: Go, and come again: and to morrow I will give to thee: when thou canst give at present.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.29",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 3:29",
      "text": "Practise not evil against thy friend, when he hath confidence in thee.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.30",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 3:30",
      "text": "Strive not against a man without cause, when he hath done thee no evil.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.31",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 3:31",
      "text": "Envy not the unjust man, and do not follow his ways.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.32",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 3:32",
      "text": "For every mocker is an abomination to the Lord, and his communication is with the simple.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.33",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 3:33",
      "text": "Want is from the Lord in the house of the wicked: but the habitations of the just shall be blessed.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.34",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 3:34",
      "text": "He shall scorn the scorners, and to the meek he will give grace.",
      "paragraphStart": false
    },
    {
      "id": "dra:proverbs.3.35",
      "translationId": "dra",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 3:35",
      "text": "The wise shall possess glory: the promotion of fools is disgrace.",
      "paragraphStart": false
    }
  ]
}
