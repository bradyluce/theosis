{
  "chapter": {
    "id": "dra:second-timothy.3",
    "translationId": "dra",
    "bookSlug": "second-timothy",
    "chapterNumber": 3,
    "referenceLabel": "2 Timothy 3",
    "summary": "Source text for 2 Timothy 3 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:second-timothy.3.1",
      "translationId": "dra",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "2 Timothy 3:1",
      "text": "Know also this, that in the last days shall come dangerous times.",
      "paragraphStart": true
    },
    {
      "id": "dra:second-timothy.3.2",
      "translationId": "dra",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "2 Timothy 3:2",
      "text": "Men shall be lovers of themselves, covetous, haughty, proud, blasphemers, disobedient to parents, ungrateful, wicked,",
      "paragraphStart": false
    },
    {
      "id": "dra:second-timothy.3.3",
      "translationId": "dra",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "2 Timothy 3:3",
      "text": "Without affection, without peace, slanderers, incontinent, unmerciful, without kindness,",
      "paragraphStart": false
    },
    {
      "id": "dra:second-timothy.3.4",
      "translationId": "dra",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "2 Timothy 3:4",
      "text": "Traitors, stubborn, puffed up, and lovers of pleasure more than of God:",
      "paragraphStart": false
    },
    {
      "id": "dra:second-timothy.3.5",
      "translationId": "dra",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "2 Timothy 3:5",
      "text": "Having an appearance indeed of godliness but denying the power thereof. Now these avoid.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-timothy.3.6",
      "translationId": "dra",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "2 Timothy 3:6",
      "text": "For of these sort are they who creep into houses and lead captive silly women laden with sins, who are led away with divers desires:",
      "paragraphStart": false
    },
    {
      "id": "dra:second-timothy.3.7",
      "translationId": "dra",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "2 Timothy 3:7",
      "text": "Ever learning, and never attaining to the knowledge of the truth.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-timothy.3.8",
      "translationId": "dra",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "2 Timothy 3:8",
      "text": "Now as Jannes and Mambres resisted Moses, so these also resist the truth, men corrupted in mind, reprobate concerning the faith.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-timothy.3.9",
      "translationId": "dra",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "2 Timothy 3:9",
      "text": "But they shall proceed no farther: for their folly shall be manifest to all men, as theirs also was.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-timothy.3.10",
      "translationId": "dra",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "2 Timothy 3:10",
      "text": "But thou hast fully known my doctrine, manner of life, purpose, faith, longsuffering, love, patience,",
      "paragraphStart": false
    },
    {
      "id": "dra:second-timothy.3.11",
      "translationId": "dra",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "2 Timothy 3:11",
      "text": "Persecutions, afflictions: such as came upon me at Antioch, at Iconium and at Lystra: what persecutions I endured, and out of them all the Lord delivered me.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-timothy.3.12",
      "translationId": "dra",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "2 Timothy 3:12",
      "text": "And all that will live godly in Christ Jesus shall suffer persecution.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-timothy.3.13",
      "translationId": "dra",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "2 Timothy 3:13",
      "text": "But evil men and seducers shall grow worse and worse: erring, and driving into error,",
      "paragraphStart": false
    },
    {
      "id": "dra:second-timothy.3.14",
      "translationId": "dra",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "2 Timothy 3:14",
      "text": "But continue thou in those things which thou hast learned and which have been committed to thee. Knowing of whom thou hast learned them:",
      "paragraphStart": false
    },
    {
      "id": "dra:second-timothy.3.15",
      "translationId": "dra",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "2 Timothy 3:15",
      "text": "And because from thy infancy thou hast known the holy scriptures which can instruct thee to salvation by the faith which is in Christ Jesus.",
      "paragraphStart": false
    },
    {
      "id": "dra:second-timothy.3.16",
      "translationId": "dra",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "2 Timothy 3:16",
      "text": "All scripture, inspired of God, is profitable to teach, to reprove, to correct, to instruct in justice:",
      "paragraphStart": false
    },
    {
      "id": "dra:second-timothy.3.17",
      "translationId": "dra",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "2 Timothy 3:17",
      "text": "That the man of God may be perfect, furnished to every good work.",
      "paragraphStart": false
    }
  ]
}
