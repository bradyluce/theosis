{
  "chapter": {
    "id": "dra:colossians.3",
    "translationId": "dra",
    "bookSlug": "colossians",
    "chapterNumber": 3,
    "referenceLabel": "Colossians 3",
    "summary": "Source text for Colossians 3 in Douay-Rheims Bible (Challoner)."
  },
  "verses": [
    {
      "id": "dra:colossians.3.1",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Colossians 3:1",
      "text": "Therefore if you be risen with Christ, seek the things that are above, where Christ is sitting at the right hand of God.",
      "paragraphStart": true
    },
    {
      "id": "dra:colossians.3.2",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Colossians 3:2",
      "text": "Mind the things that are above, not the things that are upon the earth.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.3",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Colossians 3:3",
      "text": "For you are dead: and your life is hid with Christ in God.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.4",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Colossians 3:4",
      "text": "When Christ shall appear, who is your life, then you also shall appear with him in glory.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.5",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Colossians 3:5",
      "text": "Mortify therefore your members which are upon the earth: fornication, uncleanness, lust, evil concupiscence and covetousness, which is the service of idols.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.6",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Colossians 3:6",
      "text": "For which things the wrath of God cometh upon the children of unbelief.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.7",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Colossians 3:7",
      "text": "In which you also walked some time, when you lived in them.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.8",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Colossians 3:8",
      "text": "But now put you also all away: anger, indignation, malice, blasphemy, filthy speech out of your mouth.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.9",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Colossians 3:9",
      "text": "Lie not one to another: stripping yourselves of the old man with his deeds,",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.10",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Colossians 3:10",
      "text": "And putting on the new, him who is renewed unto knowledge, according to the image of him that created him.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.11",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Colossians 3:11",
      "text": "Where there is neither Gentile nor Jew, circumcision nor uncircumcision, Barbarian nor Scythian, bond nor free. But Christ is all and in all.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.12",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Colossians 3:12",
      "text": "Put ye on therefore, as the elect of God, holy and beloved, the bowels of mercy, benignity, humility, modesty, patience:",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.13",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Colossians 3:13",
      "text": "Bearing with one another and forgiving one another, if any have a complaint against another. Even as the Lord hath forgiven you, so do you also.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.14",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Colossians 3:14",
      "text": "But above all these things have charity, which is the bond of perfection.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.15",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Colossians 3:15",
      "text": "And let the peace of Christ rejoice in your hearts, wherein also you are called in one body: and be ye thankful.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.16",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Colossians 3:16",
      "text": "Let the word of Christ dwell in you abundantly: in all wisdom, teaching and admonishing one another in psalms, hymns and spiritual canticles, singing in grace in your hearts to God.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.17",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Colossians 3:17",
      "text": "All whatsoever you do in word or in work, do all in the name of the Lord Jesus Christ, giving thanks to God and the Father by him.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.18",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Colossians 3:18",
      "text": "Wives, be subject to your husbands, as it behoveth in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.19",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Colossians 3:19",
      "text": "Husbands, love your wives and be not bitter towards them.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.20",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Colossians 3:20",
      "text": "Children, obey your parents in all things: for this is well pleasing to the Lord.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.21",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Colossians 3:21",
      "text": "Fathers, provoke not your children to indignation, lest they be discouraged.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.22",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Colossians 3:22",
      "text": "Servants, obey in all things your masters according to the flesh: not serving to the eye, as pleasing men: but in simplicity of heart, fearing God.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.23",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Colossians 3:23",
      "text": "Whatsoever you do, do it from the heart, as to the Lord, and not to men:",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.24",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Colossians 3:24",
      "text": "Knowing that you shall receive of the Lord the reward of inheritance. Serve ye the Lord Christ.",
      "paragraphStart": false
    },
    {
      "id": "dra:colossians.3.25",
      "translationId": "dra",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Colossians 3:25",
      "text": "For he that doth wrong shall receive for that which he hath done wrongfully. And there is no respect of persons with God.",
      "paragraphStart": false
    }
  ]
}
