{
  "chapter": {
    "id": "gnt:ephesians.4",
    "translationId": "gnt",
    "bookSlug": "ephesians",
    "chapterNumber": 4,
    "referenceLabel": "Ephesians 4",
    "summary": "Source text for Ephesians 4 in Greek New Testament."
  },
  "verses": [
    {
      "id": "gnt:ephesians.4.1",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 4:1",
      "text": "Σας παρακαλω λοιπον εγω ο δεσμιος εν Κυριω να περιπατησητε αξιως της προσκλησεως, καθ' ην προσεκληθητε,",
      "paragraphStart": true
    },
    {
      "id": "gnt:ephesians.4.2",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 4:2",
      "text": "μετα πασης ταπεινοφροσυνης και πραοτητος, μετα μακροθυμιας, υποφεροντες αλληλους εν αγαπη,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.3",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 4:3",
      "text": "σπουδαζοντες να διατηρητε την ενοτητα του Πνευματος δια του συνδεσμου της ειρηνης.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.4",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 4:4",
      "text": "Εν σωμα και εν Πνευμα, καθως και προσεκληθητε με μιαν ελπιδα της προσκλησεως σας",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.5",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 4:5",
      "text": "εις Κυριος, μια πιστις, εν βαπτισμα",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.6",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 4:6",
      "text": "εις Θεος και Πατηρ παντων, ο ων επι παντων και δια παντων και εν πασιν υμιν.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.7",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 4:7",
      "text": "Εις ενα δε εκαστον ημων εδοθη η χαρις κατα το μετρον της δωρεας του Χριστου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.8",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 4:8",
      "text": "Δια τουτο λεγει Αναβας εις υψος, ηχμαλωτευσεν αιχμαλωσιαν και εδωκε χαρισματα εις τους ανθρωπους.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.9",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 4:9",
      "text": "Το δε ανεβη τι ειναι ειμη οτι και κατεβη πρωτον εις τα κατωτερα μερη της γης;",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.10",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 4:10",
      "text": "Ο καταβας αυτος ειναι και ο αναβας υπερανω παντων των ουρανων, δια να πληρωση τα παντα.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.11",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 4:11",
      "text": "Και αυτος εδωκεν αλλους μεν αποστολους, αλλους δε προφητας, αλλους δε ευαγγελιστας, αλλους δε ποιμενας και διδασκαλους,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.12",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 4:12",
      "text": "προς την τελειοποιησιν των αγιων, δια το εργον της διακονιας, δια την οικοδομην του σωματος του Χριστου,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.13",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 4:13",
      "text": "εωσου καταντησωμεν παντες εις την ενοτητα της πιστεως και της επιγνωσεως του Υιου του Θεου, εις ανδρα τελειον, εις μετρον ηλικιας του πληρωματος του Χριστου,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.14",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 4:14",
      "text": "δια να μη ημεθα πλεον νηπιοι, κυματιζομενοι και περιφερομενοι με παντα ανεμον της διδασκαλιας, δια της δολιοτητος των ανθρωπων, δια της πανουργιας εις το μεθοδευεσθαι την πλανην,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.15",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 4:15",
      "text": "αλλα αληθευοντες εις την αγαπην να αυξησωμεν εις αυτον κατα παντα, οστις ειναι η κεφαλη, ο Χριστος,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.16",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 4:16",
      "text": "εξ ου παν το σωμα συναρμολογουμενον και συνδεδεμενον δια πασης συναφειας των συνεργουντων μελων, κατα την αναλογον ενεργειαν ενος εκαστου μερους καμνει την αυξησιν του σωματος προς οικοδομην εαυτου εν αγαπη.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.17",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 4:17",
      "text": "Τουτο λοιπον λεγω και μαρτυρομαι δια του Κυριου, να μη περιπατητε πλεον καθως και τα λοιπα εθνη περιπατουσιν εν τη ματαιοτητι του νοος αυτων,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.18",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 4:18",
      "text": "εσκοτισμενοι την διανοιαν, απηλλοτριωμενοι οντες απο της ζωης του Θεου δια την αγνοιαν την ουσαν εν αυτοις, δια την πωρωσιν της καρδιας αυτων,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.19",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 4:19",
      "text": "οιτινες αναισθητουντες, παρεδωκαν εαυτοις εις την ασελγειαν, δια να εργαζωνται πασαν ακαθαρσιαν ακορεστως.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.20",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 4:20",
      "text": "Σεις ομως δεν εμαθετε ουτω τον Χριστον,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.21",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 4:21",
      "text": "επειδη αυτον ηκουσατε και εις αυτον εδιδαχθητε, καθως ειναι η αληθεια εν τω Ιησου",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.22",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Ephesians 4:22",
      "text": "να απεκδυθητε τον παλαιον ανθρωπον τον κατα την προτεραν διαγωγην, τον φθειρομενον κατα τας απατηλας επιθυμιας,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.23",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Ephesians 4:23",
      "text": "και να ανανεονησθε εις το πνευμα του νοος σας",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.24",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Ephesians 4:24",
      "text": "και να ενδυθητε τον νεον ανθρωπον, τον κτισθεντα κατα Θεον εν δικαιοσυνη και οσιοτητι της αληθειας.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.25",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Ephesians 4:25",
      "text": "Οθεν απορριψαντες το ψευδος, λαλειτε αληθειαν εκαστος μετα του πλησιον αυτου διοτι ειμεθα μελη αλληλων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.26",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Ephesians 4:26",
      "text": "Οργιζεσθε και μη αμαρτανετε ο ηλιος ας μη δυη επι τον παροργισμον σας,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.27",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Ephesians 4:27",
      "text": "μητε διδετε τοπον εις τον διαβολον.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.28",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "Ephesians 4:28",
      "text": "Ο κλεπτων ας μη κλεπτη πλεον, μαλλον δε ας κοπιαζη εργαζομενος το καλον με τας χειρας αυτου, δια να εχη να μεταδιδη εις τον χρειαν εχοντα.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.29",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "Ephesians 4:29",
      "text": "Μηδεις λογος σαπρος ας μη εξερχηται εκ του στοματος σας, αλλ' οστις ειναι καλος προς οικοδομην της χρειας, δια να δωση χαριν εις τους ακουοντας.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.30",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "Ephesians 4:30",
      "text": "Και μη λυπειτε το Πνευμα το Αγιον του Θεου, με το οποιον εσφραγισθητε δια την ημεραν της απολυτρωσεως.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.31",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "Ephesians 4:31",
      "text": "Πασα πικρια και θυμος και οργη και κραυγη και βλασφημια ας αφαιρεθη απο σας μετα πασης κακιας",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.4.32",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 32,
      "referenceLabel": "Ephesians 4:32",
      "text": "γινεσθε δε εις αλληλους χρηστοι, ευσπλαγχνοι, συγχωρουντες αλληλους, καθως ο Θεος συνεχωρησεν εσας δια του Χριστου.",
      "paragraphStart": false
    }
  ]
}
