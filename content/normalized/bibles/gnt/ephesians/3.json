{
  "chapter": {
    "id": "gnt:ephesians.3",
    "translationId": "gnt",
    "bookSlug": "ephesians",
    "chapterNumber": 3,
    "referenceLabel": "Ephesians 3",
    "summary": "Source text for Ephesians 3 in Greek New Testament."
  },
  "verses": [
    {
      "id": "gnt:ephesians.3.1",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 3:1",
      "text": "Δια τουτο εγω ο Παυλος, ο δεσμιος του Ιησου Χριστου υπερ υμων των εθνικων,",
      "paragraphStart": true
    },
    {
      "id": "gnt:ephesians.3.2",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 3:2",
      "text": "επειδη ηκουσατε την οικονομιαν της χαριτος του Θεου της δοθεισης εις εμε υπερ υμων,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.3.3",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 3:3",
      "text": "οτι δι' αποκαλυψεως εφανερωσεν εις εμε το μυστηριον, καθως προεγραψα συντομως,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.3.4",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 3:4",
      "text": "εξ ων δυνασθε αναγινωσκοντες να νοησητε την εν τω μυστηριω του Χριστου γνωσιν μου,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.3.5",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 3:5",
      "text": "το οποιον εν αλλαις γενεαις δεν εγνωστοποιηθη εις τους υιους των ανθρωπων, καθως τωρα απεκαλυφθη δια Πνευματος εις τους αγιους αυτου αποστολους και προφητας,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.3.6",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 3:6",
      "text": "να ηναι τα εθνη συγκληρονομα και συσσωμα και συμμετοχα της επαγγελιας αυτου εν τω Χριστω δια του ευαγγελιου,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.3.7",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 3:7",
      "text": "του οποιου εγεινα υπηρετης κατα την δωρεαν της χαριτος του Θεου, την δοθεισαν εις εμε κατα την ενεργειαν της δυναμεως αυτου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.3.8",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 3:8",
      "text": "Εις εμε τον πλεον ελαχιστον παντων των αγιων εδοθη η χαρις αυτη, να ευαγγελισω μεταξυ των εθνων τον ανεξιχνιαστον πλουτον του Χριστου",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.3.9",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 3:9",
      "text": "και να φωτισω παντας, ποια ειναι η κοινωνια του μυστηριου του αποκεκρυμμενου απο των αιωνων εν τω Θεω οστις εκτισε τα παντα δια του Ιησου Χριστου,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.3.10",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 3:10",
      "text": "δια να γνωρισθη τωρα δια της εκκλησιας εν τοις επουρανιοις εις τας αρχας και τας εξουσιας η πολυποικιλος σοφια του Θεου,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.3.11",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 3:11",
      "text": "κατα την αιωνιον προθεσιν, την οποιαν εκαμεν εν Χριστω Ιησου τω Κυριω ημων,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.3.12",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 3:12",
      "text": "δια του οποιου εχομεν την παρρησιαν και την εισοδον με πεποιθησιν δια της εις αυτον πιστεως.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.3.13",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 3:13",
      "text": "Δια τουτο σας παρακαλω να μη αθυμητε δια τας υπερ υμων θλιψεις μου, το οποιον ειναι δοξα υμων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.3.14",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 3:14",
      "text": "Δια τουτο καμπτω τα γονατα μου προς τον Πατερα του Κυριου ημων Ιησου Χριστου,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.3.15",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 3:15",
      "text": "εκ του οποιου πασα πατρια εν ουρανοις και επι γης ονομαζεται,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.3.16",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 3:16",
      "text": "δια να δωση εις εσας κατα τον πλουτον της δοξης αυτου, να κραταιωθητε εν δυναμει δια του Πνευματος αυτου εις τον εσωτερικον ανθρωπον,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.3.17",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 3:17",
      "text": "δια να κατοικηση ο Χριστος δια της πιστεως εν ταις καρδιαις υμων,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.3.18",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 3:18",
      "text": "ωστε να δυνηθητε, ερριζωμενοι και τεθεμελιωμενοι εν αγαπη, να καταλαβητε μετα παντων των αγιων τι το πλατος και μηκος και βαθος και υψος,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.3.19",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 3:19",
      "text": "και να γνωρισητε την αγαπην του Χριστου την υπερβαινουσαν πασαν γνωσιν, δια να πληρωθητε με ολον το πληρωμα του Θεου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.3.20",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 3:20",
      "text": "Εις δε τον δυναμενον υπερεκπερισσου να καμη υπερ παντα οσα ζητουμεν η νοουμεν, κατα την δυναμιν την ενεργουμενην εν ημιν,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.3.21",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 3:21",
      "text": "εις αυτον εστω η δοξα εν τη εκκλησια δια Ιησου Χριστου εις πασας τας γενεας του αιωνος των αιωνων αμην.",
      "paragraphStart": false
    }
  ]
}
