{
  "chapter": {
    "id": "gnt:ephesians.5",
    "translationId": "gnt",
    "bookSlug": "ephesians",
    "chapterNumber": 5,
    "referenceLabel": "Ephesians 5",
    "summary": "Source text for Ephesians 5 in Greek New Testament."
  },
  "verses": [
    {
      "id": "gnt:ephesians.5.1",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 5:1",
      "text": "Γινεσθε λοιπον μιμηται του Θεου ως τεκνα αγαπητα,",
      "paragraphStart": true
    },
    {
      "id": "gnt:ephesians.5.2",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 5:2",
      "text": "και περιπατειτε εν αγαπη, καθως και ο Χριστος ηγαπησεν ημας και παρεδωκεν εαυτον υπερ ημων προσφοραν και θυσιαν εις τον Θεον εις οσμην ευωδιας.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.3",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 5:3",
      "text": "Πορνεια δε και πασα ακαθαρσια η πλεονεξια μηδε ας ονομαζηται μεταξυ σας, καθως πρεπει εις αγιους,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.4",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 5:4",
      "text": "μηδε αισχροτης και μωρολογια η βωμολοχια, τα οποια ειναι απρεπη, αλλα μαλλον ευχαριστια.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.5",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 5:5",
      "text": "Διοτι τουτο εξευρετε, οτι πας πορνος η ακαθαρτος η πλεονεκτης, οστις ειναι ειδωλολατρης, δεν εχει κληρονομιαν εν τη βασιλεια του Χριστου και Θεου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.6",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 5:6",
      "text": "Μηδεις ας μη σας απατα με ματαιους λογους επειδη δια ταυτα ερχεται η οργη του Θεου επι τους υιους της απειθειας.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.7",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 5:7",
      "text": "Μη γινεσθε λοιπον συμμετοχοι αυτων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.8",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 5:8",
      "text": "Διοτι ησθε ποτε σκοτος, τωρα ομως φως εν Κυριω περιπατειτε ως τεκνα φωτος",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.9",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 5:9",
      "text": "διοτι ο καρπος του Πνευματος ειναι εν παση αγαθωσυνη και δικαιοσυνη και αληθεια",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.10",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 5:10",
      "text": "εξεταζοντες τι ειναι ευαρεστον εις τον Κυριον.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.11",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 5:11",
      "text": "Και μη συγκοινωνειτε εις τα εργα τα ακαρπα του σκοτους, μαλλον δε και ελεγχετε",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.12",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 5:12",
      "text": "διοτι τα κρυφιως γινομενα υπ' αυτων αισχρον εστι και λεγειν",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.13",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 5:13",
      "text": "τα δε παντα ελεγχομενα υπο του φωτος γινονται φανερα επειδη παν το φανερουμενον φως ειναι.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.14",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 5:14",
      "text": "Δια τουτο λεγει Σηκωθητι ο κοιμωμενος και αναστηθι εκ των νεκρων, και θελει σε φωτισει ο Χριστος.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.15",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 5:15",
      "text": "Προσεχετε λοιπον πως να περιπατητε ακριβως, μη ως ασοφοι, αλλ' ως σοφοι,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.16",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 5:16",
      "text": "εξαγοραζομενοι τον καιρον, διοτι αι ημεραι ειναι πονηραι.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.17",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 5:17",
      "text": "Δια τουτο μη γινεσθε αφρονες, αλλα νοειτε τι ειναι το θελημα του Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.18",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 5:18",
      "text": "Και μη μεθυσκεσθε με οινον, εις τον οποιον ειναι ασωτια, αλλα πληρουσθε δια του Πνευματος,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.19",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 5:19",
      "text": "λαλουντες μεταξυ σας με ψαλμους και υμνους και ωδας πνευματικας, αδοντες και ψαλλοντες εν τη καρδια υμων εις τον Κυριον,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.20",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 5:20",
      "text": "ευχαριστουντες παντοτε υπερ παντων εις τον Θεον και Πατερα εν ονοματι του Κυριου ημων Ιησου Χριστου,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.21",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 5:21",
      "text": "υποτασσομενοι εις αλληλους εν φοβω Θεου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.22",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Ephesians 5:22",
      "text": "Αι γυναικες, υποτασσεσθε εις τους ανδρας σας ως εις τον Κυριον,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.23",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Ephesians 5:23",
      "text": "διοτι ο ανηρ ειναι κεφαλη της γυναικος, καθως και ο Χριστος κεφαλη της εκκλησιας, και αυτος ειναι σωτηρ του σωματος.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.24",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Ephesians 5:24",
      "text": "Αλλα καθως η εκκλησια υποτασσεται εις τον Χριστον, ουτω και αι γυναικες ας υποτασσωνται εις τους ανδρας αυτων κατα παντα.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.25",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Ephesians 5:25",
      "text": "Οι ανδρες, αγαπατε τας γυναικας σας, καθως και ο Χριστος ηγαπησε την εκκλησιαν και παρεδωκεν εαυτον υπερ αυτης,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.26",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Ephesians 5:26",
      "text": "δια να αγιαση αυτην, καθαρισας με το λουτρον του υδατος δια του λογου,",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.27",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Ephesians 5:27",
      "text": "δια να παραστηση αυτην εις εαυτον ενδοξον εκκλησιαν, μη εχουσαν κηλιδα η ρυτιδα η τι των τοιουτων, αλλα δια να ηναι αγια και αμωμος.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.28",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "Ephesians 5:28",
      "text": "Ουτω χρεωστουσιν οι ανδρες να αγαπωσι τας εαυτων γυναικας ως τα εαυτων σωματα. Οστις αγαπα την εαυτου γυναικα εαυτον αγαπα",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.29",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "Ephesians 5:29",
      "text": "διοτι ουδεις εμισησε ποτε την εαυτου σαρκα, αλλ' εκτρεφει και περιθαλπει αυτην, καθως και ο Κυριος την εκκλησιαν",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.30",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "Ephesians 5:30",
      "text": "επειδη μελη ειμεθα του σωματος αυτου, εκ της σαρκος αυτου και εκ των οστεων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.31",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "Ephesians 5:31",
      "text": "Δια τουτο θελει αφησει ο ανθρωπος τον πατερα αυτου και την μητερα και θελει προσκολληθη εις την γυναικα αυτου, και θελουσιν εισθαι οι δυο εις σαρκα μιαν.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.32",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 32,
      "referenceLabel": "Ephesians 5:32",
      "text": "Το μυστηριον τουτο ειναι μεγα, εγω δε λεγω τουτο περι Χριστου και περι της εκκλησιας.",
      "paragraphStart": false
    },
    {
      "id": "gnt:ephesians.5.33",
      "translationId": "gnt",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 33,
      "referenceLabel": "Ephesians 5:33",
      "text": "Πλην και σεις οι καθ' ενα εκαστος την εαυτου γυναικα ουτως ας αγαπα ως εαυτον, η δε γυνη ας σεβηται τον ανδρα.",
      "paragraphStart": false
    }
  ]
}
