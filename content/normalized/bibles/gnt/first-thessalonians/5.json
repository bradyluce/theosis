{
  "chapter": {
    "id": "gnt:first-thessalonians.5",
    "translationId": "gnt",
    "bookSlug": "first-thessalonians",
    "chapterNumber": 5,
    "referenceLabel": "1 Thessalonians 5",
    "summary": "Source text for 1 Thessalonians 5 in Greek New Testament."
  },
  "verses": [
    {
      "id": "gnt:first-thessalonians.5.1",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "1 Thessalonians 5:1",
      "text": "Περι δε των χρονων και των καιρων, αδελφοι, δεν εχετε χρειαν να σας γραφη τις",
      "paragraphStart": true
    },
    {
      "id": "gnt:first-thessalonians.5.2",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "1 Thessalonians 5:2",
      "text": "διοτι σεις εξευρετε ακριβως οτι η ημερα του Κυριου ως κλεπτης εν νυκτι ουτως ερχεται.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.3",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "1 Thessalonians 5:3",
      "text": "Επειδη οταν λεγωσιν, Ειρηνη και ασφαλεια, τοτε επερχεται επ' αυτους αιφνιδιος ολεθρος, καθως αι ωδινες εις την εγκυμονουσαν, και δεν θελουσιν εκφυγει.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.4",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "1 Thessalonians 5:4",
      "text": "Αλλα σεις, αδελφοι, δεν εισθε εν σκοτει, ωστε η ημερα να σας καταφθαση ως κλεπτης",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.5",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "1 Thessalonians 5:5",
      "text": "παντες σεις εισθε υιοι φωτος και υιοι ημερας. Δεν ειμεθα νυκτος ουδε σκοτους.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.6",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "1 Thessalonians 5:6",
      "text": "Αρα λοιπον ας μη κοιμωμεθα ως και οι λοιποι, αλλ' ας αγρυπνωμεν και ας εγκρατευωμεθα.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.7",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "1 Thessalonians 5:7",
      "text": "Διοτι οι κοιμωμενοι την νυκτα κοιμωνται, και οι μεθυοντες την νυκτα μεθυουσιν.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.8",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "1 Thessalonians 5:8",
      "text": "αλλ' ημεις, οντες της ημερας, ας εγκρατευωμεθα, ενδυθεντες τον θωρακα της πιστεως και αγαπης και περικεφαλαιαν την ελπιδα της σωτηριας",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.9",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "1 Thessalonians 5:9",
      "text": "διοτι ο Θεος δεν προσδιωρισεν ημας εις οργην, αλλ' εις απολαυσιν σωτηριας δια του Κυριου ημων Ιησου Χριστου,",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.10",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "1 Thessalonians 5:10",
      "text": "οστις απεθανεν υπερ ημων, ινα ειτε αγρυπνουμεν ειτε κοιμωμεθα ζησωμεν μετ' αυτου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.11",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "1 Thessalonians 5:11",
      "text": "Δια τουτο παρηγορειτε αλληλους και οικοδομειτε ο εις τον αλλον, καθως και καμνετε.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.12",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "1 Thessalonians 5:12",
      "text": "Σας παρακαλουμεν δε, αδελφοι, να γνωριζητε τους οσοι κοπιαζουσι μεταξυ σας και ειναι προεστωτες σας εν Κυριω και σας νουθετουσι,",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.13",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "1 Thessalonians 5:13",
      "text": "και να τιματε αυτους εν αγαπη υπερεκπερισσου δια το εργον αυτων. Ειρηνευετε μεταξυ σας.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.14",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "1 Thessalonians 5:14",
      "text": "Σας παρακαλουμεν δε, αδελφοι, νουθετειτε τους ατακτους, παρηγορειτε τους ολιγοψυχους, περιθαλπετε τους ασθενεις, μακροθυμειτε προς παντας.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.15",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "1 Thessalonians 5:15",
      "text": "Προσεχετε μη αποδιδη τις εις τινα κακον αντι κακου, αλλα ζητειτε παντοτε το αγαθον και εις αλληλους και εις παντας.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.16",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "1 Thessalonians 5:16",
      "text": "Παντοτε χαιρετε,",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.17",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "1 Thessalonians 5:17",
      "text": "αδιαλειπτως προσευχεσθε,",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.18",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "1 Thessalonians 5:18",
      "text": "κατα παντα ευχαριστειτε διοτι τουτο ειναι το θελημα του Θεου προς εσας εν Χριστω Ιησου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.19",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "1 Thessalonians 5:19",
      "text": "Το Πνευμα μη σβυνετε,",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.20",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "1 Thessalonians 5:20",
      "text": "προφητειας μη εξουθενειτε.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.21",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "1 Thessalonians 5:21",
      "text": "Παντα δοκιμαζετε, το καλον κατεχετε",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.22",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "1 Thessalonians 5:22",
      "text": "απο παντος ειδους κακου απεχεσθε.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.23",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "1 Thessalonians 5:23",
      "text": "Αυτος δε ο Θεος της ειρηνης ειθε να σας αγιαση ολοκληρως, και να διατηρηθη ολοκληρον το πνευμα σας και η ψυχη και το σωμα αμεμπτως εν τη παρουσια του Κυριου ημων Ιησου Χριστου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.24",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "1 Thessalonians 5:24",
      "text": "Πιστος ειναι εκεινος οστις σας καλει, οστις και θελει εκτελεσει.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.25",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "1 Thessalonians 5:25",
      "text": "Αδελφοι, προσευχεσθε περι ημων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.26",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "1 Thessalonians 5:26",
      "text": "Ασπασθητε τους αδελφους παντας εν φιληματι αγιω.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.27",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "1 Thessalonians 5:27",
      "text": "Σας ορκιζω εις τον Κυριον να αναγνωσθη η επιστολη εις παντας τους αγιους αδελφους.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-thessalonians.5.28",
      "translationId": "gnt",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "1 Thessalonians 5:28",
      "text": "Η χαρις του Κυριου ημων Ιησου Χριστου ειη μεθ' υμων αμην.",
      "paragraphStart": false
    }
  ]
}
