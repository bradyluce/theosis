{
  "chapter": {
    "id": "gnt:first-corinthians.12",
    "translationId": "gnt",
    "bookSlug": "first-corinthians",
    "chapterNumber": 12,
    "referenceLabel": "1 Corinthians 12",
    "summary": "Source text for 1 Corinthians 12 in Greek New Testament."
  },
  "verses": [
    {
      "id": "gnt:first-corinthians.12.1",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 12:1",
      "text": "Περι δε των πνευματικων, αδελφοι, δεν θελω να αγνοητε.",
      "paragraphStart": true
    },
    {
      "id": "gnt:first-corinthians.12.2",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 12:2",
      "text": "Εξευρετε οτι ησθε εθνικοι, συρομενοι οπως εσυρεσθε προς τα ειδωλα τα αφωνα.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.3",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 12:3",
      "text": "Δια τουτο σας γνωστοποιω οτι ουδεις λαλων δια Πνευματος Θεου λεγει αναθεμα τον Ιησουν, και ουδεις δυναται να ειπη Κυριον Ιησουν, ειμη δια Πνευματος Αγιου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.4",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 12:4",
      "text": "Ειναι δε διαιρεσεις χαρισματων, το Πνευμα ομως το αυτο",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.5",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 12:5",
      "text": "ειναι και διαιρεσεις διακονιων, ο Κυριος ομως ο αυτος",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.6",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 12:6",
      "text": "ειναι και διαιρεσεις ενεργηματων, ο Θεος ομως ειναι ο αυτος, ο ενεργων τα παντα εν πασι.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.7",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 12:7",
      "text": "Διδεται δε εις εκαστον η φανερωσις του Πνευματος προς το συμφερον.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.8",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 12:8",
      "text": "Διοτι εις αλλον μεν διδεται δια του Πνευματος λογος σοφιας, εις αλλον δε λογος γνωσεως κατα το αυτο Πνευμα,",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.9",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 12:9",
      "text": "εις αλλον δε πιστις δια του αυτου Πνευματος, εις αλλον δε χαρισματα ιαματων δια του αυτου Πνευματος,",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.10",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 12:10",
      "text": "εις αλλον δε ενεργειαι θαυματων, εις αλλον δε προφητεια, εις αλλον δε διακρισεις πνευματων, εις αλλον δε ειδη γλωσσων, εις αλλον δε ερμηνεια γλωσσων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.11",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 12:11",
      "text": "Παντα δε ταυτα ενεργει το εν και το αυτο Πνευμα, διανεμον ιδια εις εκαστον καθως θελει.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.12",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 12:12",
      "text": "Διοτι καθως το σωμα ειναι εν και εχει μελη πολλα, παντα δε τα μελη του σωματος του ενος, πολλα οντα, ειναι εν σωμα, ουτω και ο Χριστος",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.13",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 12:13",
      "text": "διοτι ημεις παντες δια του ενος Πνευματος εβαπτισθημεν εις εν σωμα, ειτε Ιουδαιοι ειτε Ελληνες, ειτε δουλοι ειτε ελευθεροι, και παντες εις εν Πνευμα εποτισθημεν.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.14",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 12:14",
      "text": "Διοτι το σωμα δεν ειναι εν μελος, αλλα πολλα.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.15",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 12:15",
      "text": "Εαν ειπη ο πους, Επειδη δεν ειμαι χειρ, δεν ειμαι εκ του σωματος, δια τουτο ταχα δεν ειναι εκ του σωματος;",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.16",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 12:16",
      "text": "Και εαν ειπη το ωτιον, Επειδη δεν ειμαι οφθαλμος, δεν ειμαι εκ του σωματος, δια τουτο δεν ειναι ταχα εκ του σωματος;",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.17",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 12:17",
      "text": "Εαν ολον το σωμα ηναι οφθαλμος, που η ακοη; Εαν ολον ακοη, που η οσφρησις;",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.18",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 12:18",
      "text": "Αλλα τωρα ο Θεος εθεσε τα μελη εν εκαστον αυτων εις το σωμα καθως ηθελησεν.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.19",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 12:19",
      "text": "Εαν ομως παντα ησαν εν μελος, που το σωμα;",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.20",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 12:20",
      "text": "Αλλα τωρα ειναι μεν πολλα μελη, εν ομως σωμα.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.21",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 12:21",
      "text": "Και δεν δυναται ο οφθαλμος να ειπη προς την χειρα Δεν εχω χρειαν σου η παλιν η κεφαλη προς τους ποδας Δεν εχω χρειαν υμων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.22",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 12:22",
      "text": "Αλλα πολυ περισσοτερον τα μελη του σωματος, τα οποια φαινονται οτι ειναι ασθενεστερα, ταυτα ειναι αναγκαια,",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.23",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 12:23",
      "text": "και εκεινα τα οποια νομιζομεν οτι ειναι τα ατιμοτερα του σωματος, εις ταυτα αποδιδομεν τιμην περισσοτεραν, και τα ασχημα ημων εχουσι περισσοτεραν ευσχημοσυνην",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.24",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 12:24",
      "text": "τα δε ευσχημονα ημων δεν εχουσι χρειαν. Αλλ' ο Θεος συνεκερασε το σωμα, δωσας περισσοτεραν τιμην εις το ευτελεστερον,",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.25",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "1 Corinthians 12:25",
      "text": "δια να μη ηναι σχισμα εν τω σωματι, αλλα να φροντιζωσι τα μελη το αυτο υπερ αλληλων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.26",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 12:26",
      "text": "Και ειτε πασχει εν μελος, παντα τα μελη συμπασχουσιν ειτε τιμαται εν μελος, παντα τα μελη συγχαιρουσι.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.27",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "1 Corinthians 12:27",
      "text": "Και σεις εισθε σωμα Χριστου και μελη κατα μερος.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.28",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "1 Corinthians 12:28",
      "text": "Και αλλους μεν εθεσεν ο Θεος εν τη εκκλησια πρωτον αποστολους, δευτερον προφητας, τριτον διδασκαλους, επειτα θαυματα, επειτα χαρισματα ιαματων, βοηθειας, κυβερνησεις, ειδη γλωσσων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.29",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 29,
      "referenceLabel": "1 Corinthians 12:29",
      "text": "Μη παντες ειναι αποστολοι; μη παντες προφηται; μη παντες διδασκαλοι; μη παντες ενεργουσι θαυματα;",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.30",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 30,
      "referenceLabel": "1 Corinthians 12:30",
      "text": "μη παντες εχουσι χαρισματα ιαματων; μη παντες λαλουσι γλωσσας; μη παντες διερμηνευουσι;",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.12.31",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 31,
      "referenceLabel": "1 Corinthians 12:31",
      "text": "Ζητειτε δε μετα ζηλου τα καλητερα χαρισματα. Και ετι πολυ υπερεχουσαν οδον σας δεικνυω.",
      "paragraphStart": false
    }
  ]
}
