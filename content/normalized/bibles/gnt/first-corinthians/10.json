{
  "chapter": {
    "id": "gnt:first-corinthians.10",
    "translationId": "gnt",
    "bookSlug": "first-corinthians",
    "chapterNumber": 10,
    "referenceLabel": "1 Corinthians 10",
    "summary": "Source text for 1 Corinthians 10 in Greek New Testament."
  },
  "verses": [
    {
      "id": "gnt:first-corinthians.10.1",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 10:1",
      "text": "Δεν θελω δε να αγνοητε, αδελφοι, οτι οι πατερες ημων ησαν παντες υπο την νεφελην, και παντες δια της θαλασσης διηλθον,",
      "paragraphStart": true
    },
    {
      "id": "gnt:first-corinthians.10.2",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 10:2",
      "text": "και παντες εις τον Μωυσην εβαπτισθησαν εν τη νεφελη και εν τη θαλασση,",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.3",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 10:3",
      "text": "και παντες την αυτην πνευματικην βρωσιν εφαγον,",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.4",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 10:4",
      "text": "και παντες το αυτο πνευματικον ποτον επιον διοτι επινον απο πνευματικης πετρας ακολουθουσης, η δε πετρα ητο ο Χριστος",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.5",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 10:5",
      "text": "αλλα δεν ευηρεστηθη ο Θεος εις τους πλειοτερους εξ αυτων διοτι κατεστρωθησαν εν τη ερημω.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.6",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 10:6",
      "text": "Ταυτα δε εγειναν παραδειγματα ημων, δια να μη ημεθα ημεις επιθυμηται κακων, καθως και εκεινοι επεθυμησαν.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.7",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 10:7",
      "text": "Μηδε γινεσθε ειδωλολατραι, καθως τινες εξ αυτων, ως ειναι γεγραμμενον Εκαθησεν ο λαος δια να φαγη και να πιη, και εσηκωθησαν να παιζωσι.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.8",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 10:8",
      "text": "Μηδε ας πορνευωμεν, καθως τινες αυτων επορνευσαν και επεσον εν μια ημερα εικοσιτρεις χιλιαδες.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.9",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 10:9",
      "text": "Μηδε ας πειραζωμεν τον Χριστον, καθως και τινες αυτων επειρασαν και απωλεσθησαν υπο των οφεων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.10",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 10:10",
      "text": "Μηδε γογγυζετε, καθως και τινες αυτων εγογγυσαν, και απωλεσθησαν υπο του εξολοθρευτου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.11",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 10:11",
      "text": "Ταυτα δε παντα εγινοντο εις εκεινους παραδειγματα, και εγραφησαν προς νουθεσιαν ημων, εις τους οποιους τα τελη των αιωνων εφθασαν.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.12",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 10:12",
      "text": "Ωστε ο νομιζων οτι ισταται ας βλεπη μη πεση.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.13",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 10:13",
      "text": "Πειρασμος δεν σας κατελαβεν ειμη ανθρωπινος πιστος ομως ειναι ο Θεος, οστις δεν θελει σας αφησει να πειρασθητε υπερ την δυναμιν σας, αλλα μετα του πειρασμου θελει καμει και την εκβασιν, ωστε να δυνασθε να υποφερητε.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.14",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 10:14",
      "text": "Δια τουτο, αγαπητοι μου, φευγετε απο της ειδωλολατρειας.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.15",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 10:15",
      "text": "Λεγω ως προς φρονιμους κρινατε σεις τουτο το οποιον λεγω",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.16",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 10:16",
      "text": "Το ποτηριον της ευλογιας, το οποιον ευλογουμεν, δεν ειναι κοινωνια του αιματος του Χριστου; Ο αρτος, τον οποιον κοπτομεν, δεν ειναι κοινωνια του σωματος του Χριστου;",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.17",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 10:17",
      "text": "διοτι εις αρτος, εν σωμα ειμεθα οι πολλοι επειδη παντες εκ του ενος αρτου μετεχομεν.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.18",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 10:18",
      "text": "Βλεπετε τον Ισραηλ κατα σαρκα οι τρωγοντες τας θυσιας δεν ειναι κοινωνοι του θυσιαστηριου;",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.19",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 10:19",
      "text": "Τι λοιπον λεγω; οτι το ειδωλον ειναι τι; η οτι το ειδωλοθυτον ειναι τι; ουχι",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.20",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 10:20",
      "text": "αλλ' οτι εκεινα, τα οποια θυσιαζουσι τα εθνη, εις τα δαιμονια θυσιαζουσι και ουχι εις τον Θεον και δεν θελω σεις να γινησθε κοινωνοι των δαιμονιων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.21",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 10:21",
      "text": "Δεν δυνασθε να πινητε το ποτηριον του Κυριου και το ποτηριον των δαιμονιων δεν δυνασθε να ησθε μετοχοι της τραπεζης του Κυριου και της τραπεζης των δαιμονιων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.22",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 10:22",
      "text": "Η τον Κυριον θελομεν να διεγειρωμεν εις ζηλοτυπιαν; μηπως ειμεθα ισχυροτεροι αυτου;",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.23",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 10:23",
      "text": "Παντα ειναι εις την εξουσιαν μου αλλα παντα δεν συμφερουσι παντα ειναι εις την εξουσιαν μου, αλλα παντα δεν οικοδομουσι.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.24",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 10:24",
      "text": "Μηδεις ας ζητη το εαυτου συμφερον, αλλ' εκαστος τα του αλλου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.25",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "1 Corinthians 10:25",
      "text": "Παν το πωλουμενον εν τω μακελλιω τρωγετε, μηδεν εξεταζοντες δια την συνειδησιν",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.26",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 10:26",
      "text": "διοτι του Κυριου ειναι η γη και το πληρωμα αυτης.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.27",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "1 Corinthians 10:27",
      "text": "Και εαν τις των απιστων σας προσκαλη και θελετε να υπαγητε, τρωγετε ο, τι βαλλεται εμπροσθεν σας, μηδεν εξεταζοντες δια την συνειδησιν.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.28",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "1 Corinthians 10:28",
      "text": "Εαν δε τις σας ειπη, Τουτο ειναι ειδωλοθυτον, μη τρωγετε δι' εκεινον τον φανερωσαντα και δια την συνειδησιν διοτι του Κυριου ειναι η γη και το πληρωμα αυτης.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.29",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "1 Corinthians 10:29",
      "text": "Συνειδησιν δε λεγω ουχι την ιδικην σου, αλλα την του αλλου. Επειδη δια τι η ελευθερια μου κρινεται υπο αλλης συνειδησεως;",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.30",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "1 Corinthians 10:30",
      "text": "Και εαν εγω μετ' ευχαριστιας μετεχω, δια τι βλασφημουμαι δι' εκεινο, δια το οποιον εγω ευχαριστω;",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.31",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "1 Corinthians 10:31",
      "text": "Ειτε λοιπον τρωγετε ειτε πινετε ειτε πραττετε τι, παντα πραττετε εις δοξαν Θεου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.32",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "1 Corinthians 10:32",
      "text": "Μη γινεσθε προσκομμα μητε εις Ιουδαιους μητε εις Ελληνας μητε εις την εκκλησιαν του Θεου,",
      "paragraphStart": false
    },
    {
      "id": "gnt:first-corinthians.10.33",
      "translationId": "gnt",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "1 Corinthians 10:33",
      "text": "καθως και εγω κατα παντα αρεσκω εις παντας, μη ζητων το ιδικον μου συμφερον, αλλα το των πολλων, δια να σωθωσι.",
      "paragraphStart": false
    }
  ]
}
