{
  "chapter": {
    "id": "gnt:second-thessalonians.3",
    "translationId": "gnt",
    "bookSlug": "second-thessalonians",
    "chapterNumber": 3,
    "referenceLabel": "2 Thessalonians 3",
    "summary": "Source text for 2 Thessalonians 3 in Greek New Testament."
  },
  "verses": [
    {
      "id": "gnt:second-thessalonians.3.1",
      "translationId": "gnt",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "2 Thessalonians 3:1",
      "text": "Το λοιπον προσευχεσθε, αδελφοι, περι ημων, δια να τρεχη ο λογος του Κυριου και να δοξαζηται, καθως και εις εσας,",
      "paragraphStart": true
    },
    {
      "id": "gnt:second-thessalonians.3.2",
      "translationId": "gnt",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "2 Thessalonians 3:2",
      "text": "και δια να ελευθερωθωμεν απο των παραλογων και πονηρων ανθρωπων διοτι η πιστις δεν υπαρχει εις παντας.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-thessalonians.3.3",
      "translationId": "gnt",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "2 Thessalonians 3:3",
      "text": "Πιστος ομως ειναι ο Κυριος, οστις θελει σας στηριξει και φυλαξει απο του πονηρου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-thessalonians.3.4",
      "translationId": "gnt",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "2 Thessalonians 3:4",
      "text": "Εχομεν δε πεποιθησιν δια του Κυριου εφ' υμας οτι εκεινα, τα οποια σας παραγγελλομεν, και πραττετε και θελετε πραττει.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-thessalonians.3.5",
      "translationId": "gnt",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "2 Thessalonians 3:5",
      "text": "Ο δε Κυριος ειθε να κατευθυνη τας καρδιας σας εις την αγαπην του Θεου και εις την προσδοκιαν του Χριστου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-thessalonians.3.6",
      "translationId": "gnt",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "2 Thessalonians 3:6",
      "text": "Σας παραγγελλομεν δε, αδελφοι, εν ονοματι του Κυριου ημων Ιησου Χριστου, να απομακρυνησθε απο παντος αδελφου ατακτως περιπατουντος και ουχι κατα την παραδοσιν, την οποιαν παρελαβε παρ' ημων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-thessalonians.3.7",
      "translationId": "gnt",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "2 Thessalonians 3:7",
      "text": "Επειδη σεις εξευρετε πως πρεπει να μιμησθε ημας, διοτι δεν εφερθημεν ατακτως μεταξυ σας,",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-thessalonians.3.8",
      "translationId": "gnt",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "2 Thessalonians 3:8",
      "text": "ουδε εφαγομεν δωρεαν αρτον παρα τινος, αλλα μετα κοπου και μοχθου, νυκτα και ημεραν εργαζομενοι, δια να μη επιβαρυνωμεν μηδενα υμων",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-thessalonians.3.9",
      "translationId": "gnt",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "2 Thessalonians 3:9",
      "text": "ουχι διοτι δεν εχομεν εξουσιαν, αλλα δια να σας δωσωμεν εαυτους τυπον εις το να μιμησθε ημας.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-thessalonians.3.10",
      "translationId": "gnt",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "2 Thessalonians 3:10",
      "text": "Διοτι και οτε ημεθα παρ' υμιν, τουτο σας παρηγγελλομεν, οτι εαν τις δεν θελη να εργαζηται, μηδε ας τρωγη.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-thessalonians.3.11",
      "translationId": "gnt",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "2 Thessalonians 3:11",
      "text": "Επειδη ακουομεν τινας οτι περιπατουσι μεταξυ σας ατακτως, μη εργαζομενοι μηδεν, αλλα περιεργαζομενοι",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-thessalonians.3.12",
      "translationId": "gnt",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "2 Thessalonians 3:12",
      "text": "παραγγελλομεν δε εις τους τοιουτους και προτρεπομεν δια του Κυριου ημων Ιησου Χριστου, να τρωγωσι τον αρτον αυτων εργαζομενοι μετα ησυχιας.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-thessalonians.3.13",
      "translationId": "gnt",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "2 Thessalonians 3:13",
      "text": "Σεις δε, αδελφοι, μη αποκαμητε πραττοντες το καλον.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-thessalonians.3.14",
      "translationId": "gnt",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "2 Thessalonians 3:14",
      "text": "Και εαν τις δεν υπακουη εις τον λογον ημων τον δια της επιστολης, τουτον σημειονετε και μη συναναστρεφεσθε μετ' αυτου, δια να εντραπη",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-thessalonians.3.15",
      "translationId": "gnt",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "2 Thessalonians 3:15",
      "text": "πλην μη θεωρειτε αυτον ως εχθρον, αλλα νουθετειτε ως αδελφον.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-thessalonians.3.16",
      "translationId": "gnt",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "2 Thessalonians 3:16",
      "text": "Αυτος δε ο Κυριος της ειρηνης ειθε να σας δωση την ειρηνην διαπαντος εν παντι τροπω. Ο Κυριος ειη μετα παντων υμων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-thessalonians.3.17",
      "translationId": "gnt",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "2 Thessalonians 3:17",
      "text": "Ο ασπασμος εγραφη με την χειρα εμου του Παυλου, το οποιον ειναι σημειον εν παση επιστολη ουτω γραφω.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-thessalonians.3.18",
      "translationId": "gnt",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "2 Thessalonians 3:18",
      "text": "Η χαρις του Κυριου ημων Ιησου Χριστου ειη μετα παντων υμων αμην.",
      "paragraphStart": false
    }
  ]
}
