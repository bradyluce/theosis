{
  "chapter": {
    "id": "gnt:second-timothy.2",
    "translationId": "gnt",
    "bookSlug": "second-timothy",
    "chapterNumber": 2,
    "referenceLabel": "2 Timothy 2",
    "summary": "Source text for 2 Timothy 2 in Greek New Testament."
  },
  "verses": [
    {
      "id": "gnt:second-timothy.2.1",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "2 Timothy 2:1",
      "text": "Συ λοιπον, τεκνον μου, ενδυναμου δια της χαριτος της εν Χριστω Ιησου,",
      "paragraphStart": true
    },
    {
      "id": "gnt:second-timothy.2.2",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "2 Timothy 2:2",
      "text": "και οσα ηκουσας παρ' εμου δια πολλων μαρτυρων, ταυτα παραδος εις πιστους ανθρωπους, οιτινες θελουσιν εισθαι ικανοι και αλλους να διδαξωσι.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.3",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "2 Timothy 2:3",
      "text": "Συ λοιπον κακοπαθησον ως καλος στρατιωτης Ιησου Χριστου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.4",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "2 Timothy 2:4",
      "text": "Ουδεις στρατευομενος εμπλεκεται εις τας βιωτικας υποθεσεις, δια να αρεση εις τον στρατολογησαντα.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.5",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "2 Timothy 2:5",
      "text": "Εαν δε και αγωνιζηται τις, δεν στεφανουται, εαν νομιμως δεν αγωνισθη.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.6",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "2 Timothy 2:6",
      "text": "Ο κοπιαζων γεωργος πρεπει πρωτος να μεταλαμβανη απο των καρπων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.7",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "2 Timothy 2:7",
      "text": "Εννοει εκεινα τα οποια λεγω ειθε δε να σοι δωση ο Κυριος συνεσιν εις παντα.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.8",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "2 Timothy 2:8",
      "text": "Ενθυμου τον εκ σπερματος Δαβιδ Ιησουν Χριστον, τον ανασταντα εκ νεκρων, κατα το ευαγγελιον μου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.9",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "2 Timothy 2:9",
      "text": "Δια το οποιον κακοπαθω μεχρι δεσμων ως κακουργος αλλ' ο λογος του Θεου δεν δεσμευεται.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.10",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "2 Timothy 2:10",
      "text": "Δια τουτο παντα υπομενω δια τους εκλεκτους, δια να απολαυσωσι και αυτοι την σωτηριαν την εν Χριστω Ιησου μετα δοξης αιωνιου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.11",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "2 Timothy 2:11",
      "text": "Πιστος ο λογος διοτι εαν συναπεθανομεν, θελομεν και συζησει",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.12",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "2 Timothy 2:12",
      "text": "εαν υπομενωμεν, θελομεν και συμβασιλευσει εαν αρνωμεθα αυτον, και εκεινος θελει αρνηθη ημας",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.13",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "2 Timothy 2:13",
      "text": "εαν απιστωμεν, εκεινος μενει πιστος να αρνηθη εαυτον δεν δυναται.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.14",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "2 Timothy 2:14",
      "text": "Ταυτα υπενθυμιζε, διαμαρτυρομενος ενωπιον του Κυριου να μη λογομαχωσι, το οποιον δεν ειναι εις ουδεν χρησιμον, αλλα φερει καταστροφην των ακουοντων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.15",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "2 Timothy 2:15",
      "text": "Σπουδασον να παραστησης σεαυτον δοκιμον εις τον Θεον, εργατην ανεπαισχυντον, ορθοτομουντα τον λογον της αληθειας.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.16",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "2 Timothy 2:16",
      "text": "Τας δε βεβηλους ματαιοφωνιας φευγε διοτι θελουσι προχωρησει εις πλειοτεραν ασεβειαν,",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.17",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "2 Timothy 2:17",
      "text": "και ο λογος αυτων θελει κατατρωγει ως γαγγραινα εκ των οποιων ειναι ο Υμεναιος και ο Φιλητος,",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.18",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "2 Timothy 2:18",
      "text": "οιτινες απεπλανηθησαν απο της αληθειας, λεγοντες οτι εγεινεν ηδη η αναστασις, και ανατρεπουσι την πιστιν τινων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.19",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "2 Timothy 2:19",
      "text": "Το στερεον ομως θεμελιον του Θεου μενει, εχον την σφραγιδα ταυτην Γνωριζει ο Κυριος τους οντας αυτου, και Ας απομακρυνθη απο της αδικιας πας οστις ονομαζει το ονομα του Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.20",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "2 Timothy 2:20",
      "text": "Εν μεγαλη δε οικια δεν ειναι μονον σκευη χρυσα και αργυρα, αλλα και ξυλινα και οστρακινα, και αλλα μεν προς χρησιν τιμιαν, αλλα δε προς ατιμον.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.21",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "2 Timothy 2:21",
      "text": "Εαν λοιπον καθαριση τις εαυτον απο τουτων, θελει εισθαι σκευος τιμιας χρησεως, ηγιασμενον και ευχρηστον εις τον δεσποτην, ητοιμασμενον εις παν εργον αγαθον.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.22",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "2 Timothy 2:22",
      "text": "Τας δε νεανικας επιθυμιας φευγε και ζητει την δικαιοσυνην, την πιστιν, την αγαπην, την ειρηνην μετα των επικαλουμενων τον Κυριον εκ καθαρας καρδιας.",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.23",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "2 Timothy 2:23",
      "text": "Τας δε μωρας και απαιδευτους φιλονεικιας παραιτου, εξευρων οτι γεννωσι μαχας",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.24",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "2 Timothy 2:24",
      "text": "ο δε δουλος του Κυριου δεν πρεπει να μαχηται, αλλα να ηναι πραος προς παντας, διδακτικος, ανεξικακος,",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.25",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "2 Timothy 2:25",
      "text": "διδασκων μετα πραοτητος τους αντιφρονουντας, μηποτε δωση εις αυτους ο Θεος μετανοιαν, ωστε να γνωρισωσι την αληθειαν,",
      "paragraphStart": false
    },
    {
      "id": "gnt:second-timothy.2.26",
      "translationId": "gnt",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "2 Timothy 2:26",
      "text": "και να ανανηψωσιν απο της παγιδος του διαβολου, υπο του οποιου ειναι πεπαγιδευμενοι εις το θελημα εκεινου.",
      "paragraphStart": false
    }
  ]
}
