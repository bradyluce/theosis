{
  "chapter": {
    "id": "gnt:matthew.14",
    "translationId": "gnt",
    "bookSlug": "matthew",
    "chapterNumber": 14,
    "referenceLabel": "Matthew 14",
    "summary": "Source text for Matthew 14 in Greek New Testament."
  },
  "verses": [
    {
      "id": "gnt:matthew.14.1",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Matthew 14:1",
      "text": "Κατ' εκεινον τον καιρον ηκουσεν Ηρωδης ο τετραρχης την φημην του Ιησου",
      "paragraphStart": true
    },
    {
      "id": "gnt:matthew.14.2",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Matthew 14:2",
      "text": "και ειπε προς τους δουλους αυτου Ουτος ειναι Ιωαννης ο Βαπτιστης αυτος ηγερθη απο των νεκρων, και δια τουτο ενεργουσιν αι δυναμεις εν αυτω.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.3",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Matthew 14:3",
      "text": "Διοτι ο Ηρωδης συλλαβων τον Ιωαννην εδεσεν αυτον και εβαλεν εν φυλακη δια Ηρωδιαδα την γυναικα Φιλιππου του αδελφου αυτου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.4",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Matthew 14:4",
      "text": "Διοτι ελεγε προς αυτον ο Ιωαννης Δεν σοι ειναι συγκεχωρημενον να εχης αυτην.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.5",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Matthew 14:5",
      "text": "Και θελων να θανατωση αυτον εφοβηθη τον οχλον, διοτι ειχον αυτον ως προφητην.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.6",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Matthew 14:6",
      "text": "Οτε δε ετελουντο τα γενεθλια του Ηρωδου, εχορευσεν η θυγατηρ της Ηρωδιαδος εν τω μεσω και ηρεσεν εις τον Ηρωδην",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.7",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Matthew 14:7",
      "text": "οθεν μεθ' ορκου ωμολογησεν εις αυτην να δωση ο, τι αν ζητηση.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.8",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Matthew 14:8",
      "text": "Η δε, παρακινηθεισα υπο της μητρος αυτης, Δος μοι, λεγει, εδω επι πινακι την κεφαλην Ιωαννου του Βαπτιστου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.9",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Matthew 14:9",
      "text": "Και ελυπηθη ο βασιλευς, δια τους ορκους ομως και τους συγκαθημενους προσεταξε να δοθη,",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.10",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Matthew 14:10",
      "text": "και πεμψας απεκεφαλισε τον Ιωαννην εν τη φυλακη.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.11",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Matthew 14:11",
      "text": "Και εφερθη η κεφαλη αυτου επι πινακι και εδοθη εις το κορασιον, και εφερεν αυτην προς την μητερα αυτης.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.12",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Matthew 14:12",
      "text": "Και προσελθοντες οι μαθηται αυτου εσηκωσαν το σωμα και εθαψαν αυτο, και ελθοντες απηγγειλαν τουτο εις τον Ιησουν.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.13",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Matthew 14:13",
      "text": "Και ακουσας ο Ιησους ανεχωρησεν εκειθεν εν πλοιω εις ερημον τοπον κατ' ιδιαν και ακουσαντες οι οχλοι ηκολουθησαν αυτον πεζοι απο των πολεων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.14",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Matthew 14:14",
      "text": "Και οτε ο Ιησους, ειδε πολυν οχλον και εσπλαγχνισθη δι' αυτους και εθεραπευσε τους αρρωστους αυτων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.15",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Matthew 14:15",
      "text": "Οτε δε εγεινεν εσπερα, προσηλθον προς αυτον οι μαθηται αυτου, λεγοντες Ερημος ειναι ο τοπος και η ωρα ηδη παρηλθεν απολυσον τους οχλους, δια να υπαγωσιν εις τας κωμας και αγορασωσιν εις εαυτους τροφας.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.16",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Matthew 14:16",
      "text": "Ο δε Ιησους ειπε προς αυτους Δεν εχουσι χρειαν να υπαγωσι δοτε εις αυτους σεις να φαγωσιν.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.17",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Matthew 14:17",
      "text": "Οι δε λεγουσι προς αυτον Δεν εχομεν εδω ειμη πεντε αρτους και δυο οψαρια.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.18",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Matthew 14:18",
      "text": "Ο δε ειπε Φερετε μοι αυτα εδω.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.19",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Matthew 14:19",
      "text": "Και προσταξας τους οχλους να καθησωσιν επι τα χορτα, και λαβων τους πεντε αρτους και τα δυο οψαρια, αναβλεψας εις τον ουρανον ευλογησε, και κοψας εδωκεν εις τους μαθητας τους αρτους, οι δε μαθηται εις τους οχλους.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.20",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Matthew 14:20",
      "text": "Και εφαγον παντες και εχορτασθησαν, και εσηκωσαν το περισσευμα των κλασματων, δωδεκα κοφινους πληρεις.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.21",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Matthew 14:21",
      "text": "οι δε τρωγοντες ησαν εως πεντακισχιλιοι ανδρες, εκτος γυναικων και παιδιων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.22",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Matthew 14:22",
      "text": "Και ευθυς ηναγκασεν ο Ιησους τους μαθητας αυτου να εμβωσιν εις το πλοιον και να υπαγωσι προ αυτου εις το περαν, εωσου απολυση τους οχλους.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.23",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Matthew 14:23",
      "text": "Και αφου απελυσε τους οχλους, ανεβη εις το ορος κατ' ιδιαν δια να προσευχηθη. Και οτε εγεινεν εσπερα, ητο μονος εκει.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.24",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Matthew 14:24",
      "text": "Το δε πλοιον ητο ηδη εν τω μεσω της θαλασσης, βασανιζομενον υπο των κυματων διοτι ητο εναντιος ο ανεμος.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.25",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Matthew 14:25",
      "text": "Εν δε τη τεταρτη φυλακη της νυκτος υπηγε προς αυτους ο Ιησους, περιπατων επι την θαλασσαν.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.26",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Matthew 14:26",
      "text": "Και ιδοντες αυτον οι μαθηται επι την θαλασσαν περιπατουντα, εταραχθησαν, λεγοντες οτι φαντασμα ειναι, και απο του φοβου εκραξαν.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.27",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Matthew 14:27",
      "text": "Ευθυς δε ελαλησε προς αυτους ο Ιησους λεγων Θαρσειτε, εγω ειμαι μη φοβεισθε.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.28",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "Matthew 14:28",
      "text": "Αποκριθεις δε προς αυτον ο Πετρος ειπε Κυριε, εαν ησαι συ, προσταξον με να ελθω προς σε επι τα υδατα.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.29",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "Matthew 14:29",
      "text": "Ο δε ειπεν, Ελθε. Και καταβας απο του πλοιου ο Πετρος περιεπατησεν επι τα υδατα, δια να ελθη προς τον Ιησουν.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.30",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "Matthew 14:30",
      "text": "Βλεπων ομως τον ανεμον δυνατον εφοβηθη, και αρχισας να καταποντιζηται, εκραξε λεγων Κυριε, σωσον με.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.31",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "Matthew 14:31",
      "text": "Και ευθυς ο Ιησους εκτεινας την χειρα επιασεν αυτον και λεγει προς αυτον Ολιγοπιστε, εις τι εδιστασας;",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.32",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "Matthew 14:32",
      "text": "Και αφου εισηλθον εις το πλοιον, επαυσεν ο ανεμος",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.33",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "Matthew 14:33",
      "text": "οι δε εν τω πλοιω ελθοντες προσεκυνησαν αυτον, λεγοντες Αληθως Θεου Υιος εισαι.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.34",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "Matthew 14:34",
      "text": "Και διαπερασαντες ηλθον εις την γην Γεννησαρετ.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.35",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "Matthew 14:35",
      "text": "Και γνωρισαντες αυτον οι ανθρωποι του τοπου εκεινου, απεστειλαν εις ολην την περιχωρον εκεινην και εφεραν προς αυτον παντας τους πασχοντας,",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.14.36",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 36,
      "referenceLabel": "Matthew 14:36",
      "text": "και παρεκαλουν αυτον να εγγισωσι μονον το ακρον του ιματιου αυτου και οσοι ηγγισαν ιατρευθησαν.",
      "paragraphStart": false
    }
  ]
}
