{
  "chapter": {
    "id": "gnt:matthew.22",
    "translationId": "gnt",
    "bookSlug": "matthew",
    "chapterNumber": 22,
    "referenceLabel": "Matthew 22",
    "summary": "Source text for Matthew 22 in Greek New Testament."
  },
  "verses": [
    {
      "id": "gnt:matthew.22.1",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Matthew 22:1",
      "text": "Και αποκριθεις ο Ιησους παλιν ειπε προς αυτους δια παραβολων, λεγων",
      "paragraphStart": true
    },
    {
      "id": "gnt:matthew.22.2",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Matthew 22:2",
      "text": "Ωμοιωθη η βασιλεια των ουρανων με ανθρωπον βασιλεα, οστις εκαμε γαμους εις τον υιον αυτου",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.3",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Matthew 22:3",
      "text": "και απεστειλε τους δουλους αυτου να καλεσωσι τους προσκεκλημενους εις τους γαμους, και δεν ηθελον να ελθωσι.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.4",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Matthew 22:4",
      "text": "Παλιν απεστειλεν αλλους δουλους, λεγων Ειπατε προς τους προσκεκλημενους Ιδου, το γευμα μου ητοιμασα, οι ταυροι μου και τα θρεπτα ειναι εσφαγμενα και παντα ειναι ετοιμα ελθετε εις τους γαμους.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.5",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Matthew 22:5",
      "text": "Εκεινοι ομως αμελησαντες απηλθον, ο μεν εις τον αγρον αυτου, ο δε εις το εμποριον αυτου",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.6",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Matthew 22:6",
      "text": "οι δε λοιποι πιασαντες τους δουλους αυτου υβρισαν και εφονευσαν.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.7",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Matthew 22:7",
      "text": "Ακουσας δε ο βασιλευς ωργισθη, και πεμψας τα στρατευματα αυτου απωλεσε τους φονεις εκεινους και την πολιν αυτων κατεκαυσε.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.8",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Matthew 22:8",
      "text": "Τοτε λεγει προς τους δουλους αυτου Ο μεν γαμος ειναι ετοιμος, οι δε προσκεκλημενοι δεν ησαν αξιοι",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.9",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Matthew 22:9",
      "text": "υπαγετε λοιπον εις τας διεξοδους των οδων, και οσους αν ευρητε καλεσατε εις τους γαμους.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.10",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Matthew 22:10",
      "text": "Και εξελθοντες οι δουλοι εκεινοι εις τας οδους, συνηγαγον παντας οσους ευρον, κακους τε και καλους και εγεμισθη ο γαμος απο ανακεκλιμενων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.11",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Matthew 22:11",
      "text": "Εισελθων δε ο βασιλευς δια να θεωρηση τους ανακεκλιμενους, ειδεν εκει ανθρωπον μη ενδεδυμενον ενδυμα γαμου,",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.12",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Matthew 22:12",
      "text": "και λεγει προς αυτον Φιλε, πως εισηλθες ενταυθα μη εχων ενδυμα γαμου; Ο δε απεστομωθη.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.13",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Matthew 22:13",
      "text": "Τοτε ειπεν ο βασιλευς προς τους υπηρετας Δεσαντες αυτου ποδας και χειρας, σηκωσατε αυτον και ριψατε εις το σκοτος το εξωτερον εκει θελει εισθαι ο κλαυθμος και ο τριγμος των οδοντων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.14",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Matthew 22:14",
      "text": "Διοτι πολλοι ειναι οι κεκλημενοι, ολιγοι δε οι εκλεκτοι.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.15",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Matthew 22:15",
      "text": "Τοτε υπηγον οι Φαρισαιοι και συνεβουλευθησαν πως να παγιδευσωσιν αυτον εν λογω.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.16",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Matthew 22:16",
      "text": "Και αποστελλουσι προς αυτον τους μαθητας αυτων μετα των Ηρωδιανων, λεγοντες Διδασκαλε, εξευρομεν οτι αληθης εισαι και την οδον του Θεου εν αληθεια διδασκεις και δεν σε μελει περι ουδενος διοτι δεν βλεπεις εις προσωπον ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.17",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Matthew 22:17",
      "text": "ειπε λοιπον προς ημας, Τι σοι φαινεται; ειναι συγκεχωρημενον να δωσωμεν δασμον εις τον Καισαρα η ουχι;",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.18",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Matthew 22:18",
      "text": "Γνωρισας δε ο Ιησους την πονηριαν αυτων, ειπε Τι με πειραζετε, υποκριται;",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.19",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Matthew 22:19",
      "text": "δειξατε μοι το νομισμα του δασμου οι δε εφεραν προς αυτον δηναριον.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.20",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Matthew 22:20",
      "text": "Και λεγει προς αυτους Τινος ειναι η εικων αυτη και η επιγραφη;",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.21",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Matthew 22:21",
      "text": "Λεγουσι προς αυτον Του Καισαρος. Τοτε λεγει προς αυτους Αποδοτε λοιπον τα του Καισαρος εις τον Καισαρα και τα του Θεου εις τον Θεον.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.22",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Matthew 22:22",
      "text": "Και ακουσαντες εθαυμασαν, και αφησαντες αυτον ανεχωρησαν.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.23",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Matthew 22:23",
      "text": "Εν εκεινη τη ημερα προσηλθον προς αυτον Σαδδουκαιοι, οι λεγοντες οτι δεν ειναι αναστασις, και ηρωτησαν αυτον, λεγοντες",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.24",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Matthew 22:24",
      "text": "Διδασκαλε, ο Μωυσης ειπεν, Εαν τις αποθανη μη εχων τεκνα, θελει νυμφευθη ο αδελφος αυτου την γυναικα αυτου και θελει αναστησει σπερμα εις τον αδελφον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.25",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Matthew 22:25",
      "text": "Ησαν δε παρ' ημιν επτα αδελφοι και ο πρωτος αφου ενυμφευθη ετελευτησε, και μη εχων τεκνον, αφηκε την γυναικα αυτου εις τον αδελφον αυτου",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.26",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Matthew 22:26",
      "text": "ομοιως και ο δευτερος, και ο τριτος, εως των επτα.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.27",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Matthew 22:27",
      "text": "Υστερον δε παντων απεθανε και η γυνη.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.28",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Matthew 22:28",
      "text": "Εν τη αναστασει λοιπον τινος των επτα θελει εισθαι γυνη; διοτι παντες ελαβον αυτην.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.29",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Matthew 22:29",
      "text": "Αποκριθεις δε ο Ιησους, ειπε προς αυτους Πλανασθε μη γνωριζοντες τας γραφας μηδε την δυναμιν του Θεου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.30",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "Matthew 22:30",
      "text": "Διοτι εν τη αναστασει ουτε νυμφευονται ουτε νυμφευουσιν, αλλ' ειναι ως αγγελοι του Θεου εν ουρανω.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.31",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 31,
      "referenceLabel": "Matthew 22:31",
      "text": "Περι δε της αναστασεως των νεκρων δεν ανεγνωσατε το ρηθεν προς εσας υπο του Θεου, λεγοντος",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.32",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 32,
      "referenceLabel": "Matthew 22:32",
      "text": "Εγω ειμαι ο Θεος του Αβρααμ και ο Θεος του Ισαακ και ο Θεος του Ιακωβ; δεν ειναι ο Θεος νεκρων, αλλα ζωντων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.33",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 33,
      "referenceLabel": "Matthew 22:33",
      "text": "Και ακουσαντες οι οχλοι, εξεπληττοντο δια την διδαχην αυτου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.34",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 34,
      "referenceLabel": "Matthew 22:34",
      "text": "Οι δε Φαρισαιοι, ακουσαντες οτι απεστομωσε τους Σαδδουκαιους, συνηχθησαν ομου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.35",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 35,
      "referenceLabel": "Matthew 22:35",
      "text": "Και εις εξ αυτων, νομικος, ηρωτησε πειραζων αυτον και λεγων",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.36",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 36,
      "referenceLabel": "Matthew 22:36",
      "text": "Διδασκαλε, ποια εντολη ειναι μεγαλη εν τω νομω;",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.37",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 37,
      "referenceLabel": "Matthew 22:37",
      "text": "Και ο Ιησους ειπε προς αυτον Θελεις αγαπα Κυριον τον Θεον σου εξ ολης της καρδιας σου και εξ ολης της ψυχης σου και εξ ολης της διανοιας σου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.38",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 38,
      "referenceLabel": "Matthew 22:38",
      "text": "Αυτη ειναι πρωτη και μεγαλη εντολη.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.39",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 39,
      "referenceLabel": "Matthew 22:39",
      "text": "Δευτερα δε ομοια αυτης Θελεις αγαπα τον πλησιον σου ως σεαυτον.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.40",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 40,
      "referenceLabel": "Matthew 22:40",
      "text": "Εν ταυταις ταις δυο εντολαις ολος ο νομος και οι προφηται κρεμανται.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.41",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 41,
      "referenceLabel": "Matthew 22:41",
      "text": "Και ενω ησαν συνηγμενοι οι Φαρισαιοι, ηρωτησεν αυτους ο Ιησους,",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.42",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 42,
      "referenceLabel": "Matthew 22:42",
      "text": "λεγων Τι σας φαινεται περι του Χριστου; τινος υιος ειναι; Λεγουσι προς αυτον Του Δαβιδ.",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.43",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 43,
      "referenceLabel": "Matthew 22:43",
      "text": "Λεγει προς αυτους Πως λοιπον ο Δαβιδ δια Πνευματος ονομαζει αυτον Κυριον, λεγων,",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.44",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 44,
      "referenceLabel": "Matthew 22:44",
      "text": "Ειπεν ο Κυριος προς τον Κυριον μου, Καθου εκ δεξιων μου εωσου θεσω τους εχθρους σου υποποδιον των ποδων σου;",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.45",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 45,
      "referenceLabel": "Matthew 22:45",
      "text": "Εαν λοιπον ο Δαβιδ ονομαζη αυτον Κυριον, πως ειναι υιος αυτου;",
      "paragraphStart": false
    },
    {
      "id": "gnt:matthew.22.46",
      "translationId": "gnt",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 46,
      "referenceLabel": "Matthew 22:46",
      "text": "Και ουδεις ηδυνατο να αποκριθη προς αυτον λογον ουδ' ετολμησε τις απ' εκεινης της ημερας να ερωτηση πλεον αυτον.",
      "paragraphStart": false
    }
  ]
}
