{
  "chapter": {
    "id": "gnt:titus.2",
    "translationId": "gnt",
    "bookSlug": "titus",
    "chapterNumber": 2,
    "referenceLabel": "Titus 2",
    "summary": "Source text for Titus 2 in Greek New Testament."
  },
  "verses": [
    {
      "id": "gnt:titus.2.1",
      "translationId": "gnt",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Titus 2:1",
      "text": "Συ ομως λαλει οσα πρεπουσιν εις την υγιαινουσαν διδασκαλιαν.",
      "paragraphStart": true
    },
    {
      "id": "gnt:titus.2.2",
      "translationId": "gnt",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Titus 2:2",
      "text": "Οι γεροντες να ηναι αγρυπνοι, σεμνοι, σωφρονες, υγιαινοντες εν τη πιστει, τη αγαπη, τη υπομονη.",
      "paragraphStart": false
    },
    {
      "id": "gnt:titus.2.3",
      "translationId": "gnt",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Titus 2:3",
      "text": "Αι γραιαι ωσαυτως να εχωσι τροπον ιεροπρεπη, μη καταλαλοι, μη δεδουλωμεναι εις πολλην οινοποσιαν, να ηναι διδασκαλοι των καλων,",
      "paragraphStart": false
    },
    {
      "id": "gnt:titus.2.4",
      "translationId": "gnt",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Titus 2:4",
      "text": "δια να νουθετωσι τας νεας να ηναι φιλανδροι, φιλοτεκνοι,",
      "paragraphStart": false
    },
    {
      "id": "gnt:titus.2.5",
      "translationId": "gnt",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Titus 2:5",
      "text": "σωφρονες, καθαραι, οικοφυλακες, αγαθαι, ευπειθεις εις τους ιδιους αυτων ανδρας, δια να μη βλασφημηται ο λογος του Θεου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:titus.2.6",
      "translationId": "gnt",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Titus 2:6",
      "text": "Τους νεωτερους ωσαυτως νουθετει να σωφρονωσι,",
      "paragraphStart": false
    },
    {
      "id": "gnt:titus.2.7",
      "translationId": "gnt",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Titus 2:7",
      "text": "δεικνυων κατα παντα σεαυτον τυπον των καλων εργων, φυλαττων εν τη διδασκαλια αδιαφθοριαν, σεμνοτητα,",
      "paragraphStart": false
    },
    {
      "id": "gnt:titus.2.8",
      "translationId": "gnt",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Titus 2:8",
      "text": "λογον υγιη και ακατακριτον, δια να εντραπη ο εναντιος, μη εχων να λεγη δια σας μηδεν κακον.",
      "paragraphStart": false
    },
    {
      "id": "gnt:titus.2.9",
      "translationId": "gnt",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Titus 2:9",
      "text": "Τους δουλους να υποτασσωνται εις τους εαυτων δεσποτας, να ευαρεστωσιν εις αυτους κατα παντα, να μη αντιλεγωσι,",
      "paragraphStart": false
    },
    {
      "id": "gnt:titus.2.10",
      "translationId": "gnt",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Titus 2:10",
      "text": "να μη σφετεριζωνται τα αλλοτρια, αλλα να δεικνυωσι πασαν πιστιν αγαθην, δια να στολιζωσι κατα παντα την διδασκαλιαν του σωτηρος ημων Θεου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:titus.2.11",
      "translationId": "gnt",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Titus 2:11",
      "text": "Διοτι εφανερωθη η χαρις του Θεου η σωτηριος εις παντας ανθρωπους,",
      "paragraphStart": false
    },
    {
      "id": "gnt:titus.2.12",
      "translationId": "gnt",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Titus 2:12",
      "text": "διδασκουσα ημας να αρνηθωμεν την ασεβειαν και τας κοσμικας επιθυμιας και να ζησωμεν σωφρονως και δικαιως και ευσεβως εν τω παροντι αιωνι,",
      "paragraphStart": false
    },
    {
      "id": "gnt:titus.2.13",
      "translationId": "gnt",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Titus 2:13",
      "text": "προσμενοντες την μακαριαν ελπιδα και επιφανειαν της δοξης του μεγαλου Θεου και Σωτηρος ημων Ιησου Χριστου,",
      "paragraphStart": false
    },
    {
      "id": "gnt:titus.2.14",
      "translationId": "gnt",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Titus 2:14",
      "text": "οστις εδωκεν εαυτον υπερ ημων, δια να μας λυτρωση απο πασης ανομιας και να μας καθαριση εις εαυτον λαον εκλεκτον, ζηλωτην καλων εργων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:titus.2.15",
      "translationId": "gnt",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Titus 2:15",
      "text": "Ταυτα λαλει και προτρεπε και ελεγχε μετα πασης εξουσιας ας μη σε περιφρονη μηδεις.",
      "paragraphStart": false
    }
  ]
}
