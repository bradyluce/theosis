{
  "chapter": {
    "id": "gnt:romans.3",
    "translationId": "gnt",
    "bookSlug": "romans",
    "chapterNumber": 3,
    "referenceLabel": "Romans 3",
    "summary": "Source text for Romans 3 in Greek New Testament."
  },
  "verses": [
    {
      "id": "gnt:romans.3.1",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Romans 3:1",
      "text": "Τις λοιπον η υπεροχη του Ιουδαιου, η τις η ωφελεια της περιτομης;",
      "paragraphStart": true
    },
    {
      "id": "gnt:romans.3.2",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Romans 3:2",
      "text": "Πολλη κατα παντα τροπον. Πρωτον μεν διοτι εις τους Ιουδαιους ενεπιστευθησαν τα λογια του Θεου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.3",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Romans 3:3",
      "text": "Επειδη αν τινες δεν επιστευσαν, τι εκ τουτου; μηπως η απιστια αυτων θελει καταργησει την πιστιν του Θεου;",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.4",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Romans 3:4",
      "text": "Μη γενοιτο. Αλλ' εστω ο Θεος αληθης, πας δε ανθρωπος ψευστης, καθως ειναι γεγραμμενον Δια να δικαιωθης εν τοις λογοις σου και να νικησης, οταν κρινησαι.",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.5",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Romans 3:5",
      "text": "Εαν δε η αδικια ημων δεικνυη την δικαιοσυνην του Θεου, τι θελομεν ειπει; μηπως ειναι αδικος ο Θεος ο επιφερων την οργην; ως ανθρωπος λαλω.",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.6",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Romans 3:6",
      "text": "Μη γενοιτο επειδη πως θελει κρινει ο Θεος τον κοσμον;",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.7",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Romans 3:7",
      "text": "Διοτι εαν η αληθεια του Θεου επερισσευσε προς δοξαν αυτου δια του εμου ψευσματος, δια τι πλεον εγω κρινομαι ως αμαρτωλος,",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.8",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Romans 3:8",
      "text": "και καθως βλασφημουμεθα και καθως κηρυττουσι τινες, οτι ημεις λεγομεν, Δια τι να μη πραττωμεν τα κακα, δια να ελθωσι τα αγαθα; των οποιων η κατακρισις ειναι δικαια.",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.9",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Romans 3:9",
      "text": "Τι λοιπον; υπερεχομεν των εθνικων; Ουχι βεβαιως διοτι προεξηλεγξαμεν Ιουδαιους τε και Ελληνας, οτι ειναι παντες υπο αμαρτιαν,",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.10",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Romans 3:10",
      "text": "καθως ειναι γεγραμμενον Οτι δεν υπαρχει δικαιος ουδε εις,",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.11",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Romans 3:11",
      "text": "δεν υπαρχει τις εχων συνεσιν δεν υπαρχει τις εκζητων τον Θεον.",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.12",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Romans 3:12",
      "text": "Παντες εξεκλιναν, ομου εξηχρειωθησαν δεν υπαρχει ο πραττων αγαθον, δεν υπαρχει ουδε εις.",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.13",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Romans 3:13",
      "text": "Ταφος ανεωγμενος ειναι ο λαρυγξ αυτων, με τας γλωσσας αυτων ελαλουν δολια φαρμακιον ασπιδων ειναι υπο τα χειλη αυτων",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.14",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Romans 3:14",
      "text": "των οποιων το στομα γεμει καταρας και πικριας",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.15",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Romans 3:15",
      "text": "οι ποδες αυτων ειναι ταχεις εις το να χυσωσιν αιμα",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.16",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Romans 3:16",
      "text": "ερημωσις και ταλαιπωρια εν ταις οδοις αυτων,",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.17",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Romans 3:17",
      "text": "Και οδον ειρηνης δεν εγνωρισαν.",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.18",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Romans 3:18",
      "text": "Δεν ειναι φοβος Θεου εμπροσθεν των οφθαλμων αυτων.",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.19",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Romans 3:19",
      "text": "Εξευρομεν δε οτι οσα λεγει ο νομος λαλει προς τους υπο τον νομον, δια να εμφραχθη παν στομα και να γεινη πας ο κοσμος υποδικος εις τον Θεον,",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.20",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Romans 3:20",
      "text": "διοτι εξ εργων νομου δεν θελει δικαιωθη ουδεμια σαρξ ενωπιον αυτου επειδη δια του νομου γινεται η γνωρισις της αμαρτιας.",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.21",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Romans 3:21",
      "text": "Τωρα δε χωρις νομου η δικαιοσυνη του Θεου εφανερωθη, μαρτυρουμενη υπο του νομου και των προφητων,",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.22",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Romans 3:22",
      "text": "δικαιοσυνη δε του Θεου δια πιστεως Ιησου Χριστου εις παντας και επι παντας τους πιστευοντας διοτι δεν υπαρχει διαφορα",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.23",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Romans 3:23",
      "text": "επειδη παντες ημαρτον και υστερουνται της δοξης του Θεου,",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.24",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Romans 3:24",
      "text": "δικαιουνται δε δωρεαν με την χαριν αυτου δια της απολυτρωσεως της εν Χριστω Ιησου,",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.25",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Romans 3:25",
      "text": "τον οποιον ο Θεος προεθετο μεσον εξιλεωσεως δια της πιστεως εν τω αιματι αυτου, προς φανερωσιν της δικαιοσυνης αυτου δια την αφεσιν των προγενομενων αμαρτηματων δια της μακροθυμιας του Θεου,",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.26",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Romans 3:26",
      "text": "προς φανερωσιν της δικαιοσυνης αυτου εν τω παροντι καιρω, δια να ηναι αυτος δικαιος και να δικαιονη τον πιστευοντα εις τον Ιησουν.",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.27",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Romans 3:27",
      "text": "Που λοιπον η καυχησις; Εκλεισθη εξω. Δια ποιου νομου; των εργων; Ουχι, αλλα δια του νομου της πιστεως.",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.28",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Romans 3:28",
      "text": "Συμπεραινομεν λοιπον οτι ο ανθρωπος δικαιουται δια της πιστεως χωρις των εργων του νομου.",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.29",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Romans 3:29",
      "text": "Η των Ιουδαιων μονον ειναι ο Θεος; Ουχι δε και των εθνων; Ναι, και των εθνων,",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.30",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Romans 3:30",
      "text": "επειδη εις ειναι ο Θεος οστις θελει δικαιωσει την περιτομην εκ πιστεως και την ακροβυστιαν δια της πιστεως.",
      "paragraphStart": false
    },
    {
      "id": "gnt:romans.3.31",
      "translationId": "gnt",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Romans 3:31",
      "text": "Νομον λοιπον καταργουμεν δια της πιστεως; μη γενοιτο, αλλα νομον συνιστωμεν.",
      "paragraphStart": false
    }
  ]
}
