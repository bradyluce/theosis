{
  "chapter": {
    "id": "web:first-thessalonians.5",
    "translationId": "web",
    "bookSlug": "first-thessalonians",
    "chapterNumber": 5,
    "referenceLabel": "1 Thessalonians 5",
    "summary": "Source text for 1 Thessalonians 5 in World English Bible."
  },
  "verses": [
    {
      "id": "web:first-thessalonians.5.1",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "1 Thessalonians 5:1",
      "text": "But concerning the times and the seasons, brothers, you have no need that anything be written to you.",
      "paragraphStart": true
    },
    {
      "id": "web:first-thessalonians.5.2",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "1 Thessalonians 5:2",
      "text": "For you yourselves know well that the day of the Lord comes like a thief in the night.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.3",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "1 Thessalonians 5:3",
      "text": "For when they are saying, “Peace and safety,” then sudden destruction will come on them, like birth pains on a pregnant woman. Then they will in no way escape.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.4",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "1 Thessalonians 5:4",
      "text": "But you, brothers, aren’t in darkness, that the day should overtake you like a thief.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.5",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "1 Thessalonians 5:5",
      "text": "You are all children of light and children of the day. We don’t belong to the night, nor to darkness,",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.6",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "1 Thessalonians 5:6",
      "text": "so then let’s not sleep, as the rest do, but let’s watch and be sober.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.7",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "1 Thessalonians 5:7",
      "text": "For those who sleep, sleep in the night; and those who are drunk are drunk in the night.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.8",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "1 Thessalonians 5:8",
      "text": "But since we belong to the day, let’s be sober, putting on the breastplate of faith and love, and for a helmet, the hope of salvation.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.9",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "1 Thessalonians 5:9",
      "text": "For God didn’t appoint us to wrath, but to the obtaining of salvation through our Lord Jesus Christ,",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.10",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "1 Thessalonians 5:10",
      "text": "who died for us, that, whether we wake or sleep, we should live together with him.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.11",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "1 Thessalonians 5:11",
      "text": "Therefore exhort one another, and build each other up, even as you also do.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.12",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "1 Thessalonians 5:12",
      "text": "But we beg you, brothers, to know those who labor among you, and are over you in the Lord and admonish you,",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.13",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "1 Thessalonians 5:13",
      "text": "and to respect and honor them in love for their work’s sake. Be at peace among yourselves.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.14",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "1 Thessalonians 5:14",
      "text": "We exhort you, brothers: Admonish the disorderly; encourage the faint-hearted; support the weak; be patient toward all.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.15",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "1 Thessalonians 5:15",
      "text": "See that no one returns evil for evil to anyone, but always follow after that which is good for one another and for all.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.16",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "1 Thessalonians 5:16",
      "text": "Always rejoice.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.17",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "1 Thessalonians 5:17",
      "text": "Pray without ceasing.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.18",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "1 Thessalonians 5:18",
      "text": "In everything give thanks, for this is the will of God in Christ Jesus toward you.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.19",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "1 Thessalonians 5:19",
      "text": "Don’t quench the Spirit.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.20",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "1 Thessalonians 5:20",
      "text": "Don’t despise prophecies.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.21",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "1 Thessalonians 5:21",
      "text": "Test all things, and hold firmly that which is good.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.22",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "1 Thessalonians 5:22",
      "text": "Abstain from every form of evil.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.23",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "1 Thessalonians 5:23",
      "text": "May the God of peace himself sanctify you completely. May your whole spirit, soul, and body be preserved blameless at the coming of our Lord Jesus Christ.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.24",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "1 Thessalonians 5:24",
      "text": "He who calls you is faithful, who will also do it.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.25",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "1 Thessalonians 5:25",
      "text": "Brothers, pray for us.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.26",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "1 Thessalonians 5:26",
      "text": "Greet all the brothers with a holy kiss.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.27",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "1 Thessalonians 5:27",
      "text": "I solemnly command you by the Lord that this letter be read to all the holy brothers.",
      "paragraphStart": false
    },
    {
      "id": "web:first-thessalonians.5.28",
      "translationId": "web",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "1 Thessalonians 5:28",
      "text": "The grace of our Lord Jesus Christ be with you. Amen.",
      "paragraphStart": false
    }
  ]
}
