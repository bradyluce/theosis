{
  "chapter": {
    "id": "web:lamentations.3",
    "translationId": "web",
    "bookSlug": "lamentations",
    "chapterNumber": 3,
    "referenceLabel": "Lamentations 3",
    "summary": "Source text for Lamentations 3 in World English Bible."
  },
  "verses": [
    {
      "id": "web:lamentations.3.1",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Lamentations 3:1",
      "text": "I am the man who has seen affliction by the rod of his wrath.",
      "paragraphStart": true
    },
    {
      "id": "web:lamentations.3.2",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Lamentations 3:2",
      "text": "He has led me and caused me to walk in darkness, and not in light.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.3",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Lamentations 3:3",
      "text": "Surely he turns his hand against me again and again all day long.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.4",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Lamentations 3:4",
      "text": "He has made my flesh and my skin old. He has broken my bones.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.5",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Lamentations 3:5",
      "text": "He has built against me, and surrounded me with bitterness and hardship.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.6",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Lamentations 3:6",
      "text": "He has made me dwell in dark places, as those who have been long dead.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.7",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Lamentations 3:7",
      "text": "He has walled me about, so that I can’t go out. He has made my chain heavy.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.8",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Lamentations 3:8",
      "text": "Yes, when I cry, and call for help, he shuts out my prayer.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.9",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Lamentations 3:9",
      "text": "He has walled up my ways with cut stone. He has made my paths crooked.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.10",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Lamentations 3:10",
      "text": "He is to me as a bear lying in wait, as a lion in hiding.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.11",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Lamentations 3:11",
      "text": "He has turned away my path, and pulled me in pieces. He has made me desolate.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.12",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Lamentations 3:12",
      "text": "He has bent his bow, and set me as a mark for the arrow.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.13",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Lamentations 3:13",
      "text": "He has caused the shafts of his quiver to enter into my kidneys.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.14",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Lamentations 3:14",
      "text": "I have become a derision to all my people, and their song all day long.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.15",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Lamentations 3:15",
      "text": "He has filled me with bitterness. He has stuffed me with wormwood.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.16",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Lamentations 3:16",
      "text": "He has also broken my teeth with gravel. He has covered me with ashes.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.17",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Lamentations 3:17",
      "text": "You have removed my soul far away from peace. I forgot prosperity.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.18",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Lamentations 3:18",
      "text": "I said, “My strength has perished, along with my expectation from Yahweh.”",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.19",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Lamentations 3:19",
      "text": "Remember my affliction and my misery, the wormwood and the bitterness.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.20",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Lamentations 3:20",
      "text": "My soul still remembers them, and is bowed down within me.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.21",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Lamentations 3:21",
      "text": "This I recall to my mind; therefore I have hope.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.22",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Lamentations 3:22",
      "text": "It is because of Yahweh’s loving kindnesses that we are not consumed, because his mercies don’t fail.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.23",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Lamentations 3:23",
      "text": "They are new every morning. Great is your faithfulness.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.24",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Lamentations 3:24",
      "text": "“Yahweh is my portion,” says my soul. “Therefore I will hope in him.”",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.25",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Lamentations 3:25",
      "text": "Yahweh is good to those who wait for him, to the soul who seeks him.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.26",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Lamentations 3:26",
      "text": "It is good that a man should hope and quietly wait for the salvation of Yahweh.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.27",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Lamentations 3:27",
      "text": "It is good for a man that he bear the yoke in his youth.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.28",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Lamentations 3:28",
      "text": "Let him sit alone and keep silence, because he has laid it on him.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.29",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Lamentations 3:29",
      "text": "Let him put his mouth in the dust, if it is so that there may be hope.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.30",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Lamentations 3:30",
      "text": "Let him give his cheek to him who strikes him. Let him be filled full of reproach.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.31",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Lamentations 3:31",
      "text": "For the Lord will not cast off forever.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.32",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "Lamentations 3:32",
      "text": "For though he causes grief, yet he will have compassion according to the multitude of his loving kindnesses.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.33",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "Lamentations 3:33",
      "text": "For he does not afflict willingly, nor grieve the children of men.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.34",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "Lamentations 3:34",
      "text": "To crush under foot all the prisoners of the earth,",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.35",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "Lamentations 3:35",
      "text": "to turn away the right of a man before the face of the Most High,",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.36",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 36,
      "referenceLabel": "Lamentations 3:36",
      "text": "to subvert a man in his cause, the Lord doesn’t approve.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.37",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 37,
      "referenceLabel": "Lamentations 3:37",
      "text": "Who is he who says, and it comes to pass, when the Lord doesn’t command it?",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.38",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 38,
      "referenceLabel": "Lamentations 3:38",
      "text": "Doesn’t evil and good come out of the mouth of the Most High?",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.39",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 39,
      "referenceLabel": "Lamentations 3:39",
      "text": "Why should a living man complain, a man for the punishment of his sins?",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.40",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 40,
      "referenceLabel": "Lamentations 3:40",
      "text": "Let us search and try our ways, and turn again to Yahweh.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.41",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 41,
      "referenceLabel": "Lamentations 3:41",
      "text": "Let’s lift up our heart with our hands to God in the heavens.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.42",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 42,
      "referenceLabel": "Lamentations 3:42",
      "text": "“We have transgressed and have rebelled. You have not pardoned.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.43",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 43,
      "referenceLabel": "Lamentations 3:43",
      "text": "“You have covered us with anger and pursued us. You have killed. You have not pitied.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.44",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 44,
      "referenceLabel": "Lamentations 3:44",
      "text": "You have covered yourself with a cloud, so that no prayer can pass through.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.45",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 45,
      "referenceLabel": "Lamentations 3:45",
      "text": "You have made us an off-scouring and refuse in the middle of the peoples.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.46",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 46,
      "referenceLabel": "Lamentations 3:46",
      "text": "“All our enemies have opened their mouth wide against us.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.47",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 47,
      "referenceLabel": "Lamentations 3:47",
      "text": "Terror and the pit have come on us, devastation and destruction.”",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.48",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 48,
      "referenceLabel": "Lamentations 3:48",
      "text": "My eye runs down with streams of water, for the destruction of the daughter of my people.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.49",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 49,
      "referenceLabel": "Lamentations 3:49",
      "text": "My eye pours down and doesn’t cease, without any intermission,",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.50",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 50,
      "referenceLabel": "Lamentations 3:50",
      "text": "until Yahweh looks down, and sees from heaven.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.51",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 51,
      "referenceLabel": "Lamentations 3:51",
      "text": "My eye affects my soul, because of all the daughters of my city.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.52",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 52,
      "referenceLabel": "Lamentations 3:52",
      "text": "They have chased me relentlessly like a bird, those who are my enemies without cause.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.53",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 53,
      "referenceLabel": "Lamentations 3:53",
      "text": "They have cut off my life in the dungeon, and have cast a stone on me.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.54",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 54,
      "referenceLabel": "Lamentations 3:54",
      "text": "Waters flowed over my head. I said, “I am cut off.”",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.55",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 55,
      "referenceLabel": "Lamentations 3:55",
      "text": "I called on your name, Yahweh, out of the lowest dungeon.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.56",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 56,
      "referenceLabel": "Lamentations 3:56",
      "text": "You heard my voice: “Don’t hide your ear from my sighing, and my cry.”",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.57",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 57,
      "referenceLabel": "Lamentations 3:57",
      "text": "You came near in the day that I called on you. You said, “Don’t be afraid.”",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.58",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 58,
      "referenceLabel": "Lamentations 3:58",
      "text": "Lord, you have pleaded the causes of my soul. You have redeemed my life.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.59",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 59,
      "referenceLabel": "Lamentations 3:59",
      "text": "Yahweh, you have seen my wrong. Judge my cause.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.60",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 60,
      "referenceLabel": "Lamentations 3:60",
      "text": "You have seen all their vengeance and all their plans against me.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.61",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 61,
      "referenceLabel": "Lamentations 3:61",
      "text": "You have heard their reproach, Yahweh, and all their plans against me,",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.62",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 62,
      "referenceLabel": "Lamentations 3:62",
      "text": "the lips of those that rose up against me, and their plots against me all day long.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.63",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 63,
      "referenceLabel": "Lamentations 3:63",
      "text": "You see their sitting down and their rising up. I am their song.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.64",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 64,
      "referenceLabel": "Lamentations 3:64",
      "text": "You will pay them back, Yahweh, according to the work of their hands.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.65",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 65,
      "referenceLabel": "Lamentations 3:65",
      "text": "You will give them hardness of heart, your curse to them.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.3.66",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 66,
      "referenceLabel": "Lamentations 3:66",
      "text": "You will pursue them in anger, and destroy them from under the heavens of Yahweh.",
      "paragraphStart": false
    }
  ]
}
