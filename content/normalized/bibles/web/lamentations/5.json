{
  "chapter": {
    "id": "web:lamentations.5",
    "translationId": "web",
    "bookSlug": "lamentations",
    "chapterNumber": 5,
    "referenceLabel": "Lamentations 5",
    "summary": "Source text for Lamentations 5 in World English Bible."
  },
  "verses": [
    {
      "id": "web:lamentations.5.1",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Lamentations 5:1",
      "text": "Remember, Yahweh, what has come on us. Look, and see our reproach.",
      "paragraphStart": true
    },
    {
      "id": "web:lamentations.5.2",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Lamentations 5:2",
      "text": "Our inheritance has been turned over to strangers, our houses to aliens.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.3",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Lamentations 5:3",
      "text": "We are orphans and fatherless. Our mothers are as widows.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.4",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Lamentations 5:4",
      "text": "We must pay for water to drink. Our wood is sold to us.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.5",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Lamentations 5:5",
      "text": "Our pursuers are on our necks. We are weary, and have no rest.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.6",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Lamentations 5:6",
      "text": "We have given our hands to the Egyptians, and to the Assyrians, to be satisfied with bread.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.7",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Lamentations 5:7",
      "text": "Our fathers sinned, and are no more. We have borne their iniquities.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.8",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Lamentations 5:8",
      "text": "Servants rule over us. There is no one to deliver us out of their hand.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.9",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Lamentations 5:9",
      "text": "We get our bread at the peril of our lives, because of the sword in the wilderness.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.10",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Lamentations 5:10",
      "text": "Our skin is black like an oven, because of the burning heat of famine.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.11",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Lamentations 5:11",
      "text": "They ravished the women in Zion, the virgins in the cities of Judah.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.12",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Lamentations 5:12",
      "text": "Princes were hanged up by their hands. The faces of elders were not honored.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.13",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Lamentations 5:13",
      "text": "The young men carry millstones. The children stumbled under loads of wood.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.14",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Lamentations 5:14",
      "text": "The elders have ceased from the gate, and the young men from their music.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.15",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Lamentations 5:15",
      "text": "The joy of our heart has ceased. Our dance is turned into mourning.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.16",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Lamentations 5:16",
      "text": "The crown has fallen from our head. Woe to us, for we have sinned!",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.17",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Lamentations 5:17",
      "text": "For this our heart is faint. For these things our eyes are dim:",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.18",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Lamentations 5:18",
      "text": "for the mountain of Zion, which is desolate. The foxes walk on it.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.19",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Lamentations 5:19",
      "text": "You, Yahweh, remain forever. Your throne is from generation to generation.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.20",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Lamentations 5:20",
      "text": "Why do you forget us forever, and forsake us for so long a time?",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.21",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Lamentations 5:21",
      "text": "Turn us to yourself, Yahweh, and we will be turned. Renew our days as of old.",
      "paragraphStart": false
    },
    {
      "id": "web:lamentations.5.22",
      "translationId": "web",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Lamentations 5:22",
      "text": "But you have utterly rejected us. You are very angry against us.",
      "paragraphStart": false
    }
  ]
}
