  "verses": [
    {
      "id": "web:tobit.9.1",
      "translationId": "web",
      "bookSlug": "tobit",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Tobit 9:1",
      "text": "And Tobias called Raphael, and said to him,",
      "paragraphStart": true
    },
    {
      "id": "web:tobit.9.2",
      "translationId": "web",
      "bookSlug": "tobit",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Tobit 9:2",
      "text": "“Brother Azarias, take with you a servant and two camels, and go to Rages of Media to Gabael, and receive the money for me, and bring him to the wedding feast,",
      "paragraphStart": false
    },
    {
      "id": "web:tobit.9.3",
      "translationId": "web",
      "bookSlug": "tobit",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Tobit 9:3",
      "text": "because Raguel has sworn that I must not depart.",
      "paragraphStart": false
    },
    {
      "id": "web:tobit.9.4",
      "translationId": "web",
      "bookSlug": "tobit",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Tobit 9:4",
      "text": "My father counts the days; and if I wait long, he will be very grieved.",
      "paragraphStart": false
    },
    {
      "id": "web:tobit.9.5",
      "translationId": "web",
      "bookSlug": "tobit",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Tobit 9:5",
      "text": "So Raphael went on his way, and lodged with Gabael, and gave him the handwriting; so he brought forth the bags with their seals, and gave them to him.",
      "paragraphStart": false
    },
    {
      "id": "web:tobit.9.6",
      "translationId": "web",
      "bookSlug": "tobit",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Tobit 9:6",
      "text": "Then they rose up early in the morning together, and came to the wedding feast. Tobias blessed his wife.",
      "paragraphStart": false
    }
  ]
}
