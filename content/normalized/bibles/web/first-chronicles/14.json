{
  "chapter": {
    "id": "web:first-chronicles.14",
    "translationId": "web",
    "bookSlug": "first-chronicles",
    "chapterNumber": 14,
    "referenceLabel": "1 Chronicles 14",
    "summary": "Source text for 1 Chronicles 14 in World English Bible."
  },
  "verses": [
    {
      "id": "web:first-chronicles.14.1",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 14:1",
      "text": "Hiram king of Tyre sent messengers to David with cedar trees, masons, and carpenters, to build him a house.",
      "paragraphStart": true
    },
    {
      "id": "web:first-chronicles.14.2",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 14:2",
      "text": "David perceived that Yahweh had established him king over Israel, for his kingdom was highly exalted, for his people Israel ’s sake.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.14.3",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 14:3",
      "text": "David took more wives in Jerusalem, and David became the father of more sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.14.4",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 14:4",
      "text": "These are the names of the children whom he had in Jerusalem: Shammua, Shobab, Nathan, Solomon,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.14.5",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 14:5",
      "text": "Ibhar, Elishua, Elpelet,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.14.6",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 14:6",
      "text": "Nogah, Nepheg, Japhia,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.14.7",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 14:7",
      "text": "Elishama, Beeliada, and Eliphelet.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.14.8",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 14:8",
      "text": "When the Philistines heard that David was anointed king over all Israel, all the Philistines went up to seek David; and David heard of it, and went out against them.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.14.9",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 14:9",
      "text": "Now the Philistines had come and made a raid in the valley of Rephaim.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.14.10",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 14:10",
      "text": "David inquired of God, saying, “ Shall I go up against the Philistines? Will you deliver them into my hand?” Yahweh said to him, “ Go up; for I will deliver them into your hand.”",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.14.11",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 14:11",
      "text": "So they came up to Baal Perazim, and David defeated them there. David said, God has broken my enemies by my hand, like waters breaking out. Therefore they called the name of that place Baal Perazim.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.14.12",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 14:12",
      "text": "They left their gods there; and David gave a command, and they were burned with fire.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.14.13",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 14:13",
      "text": "The Philistines made another raid in the valley.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.14.14",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 14:14",
      "text": "David inquired again of God; and God said to him, “ You shall not go up after them. Turn away from them, and come on them opposite the mulberry trees.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.14.15",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 14:15",
      "text": "When you hear the sound of marching in the tops of the mulberry trees, then go out to battle; for God has gone out before you to strike the army of the Philistines.”",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.14.16",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 14:16",
      "text": "David did as God commanded him; and they attacked the army of the Philistines from Gibeon even to Gezer.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.14.17",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 14:17",
      "text": "The fame of David went out into all lands; and Yahweh brought the fear of him on all nations.",
      "paragraphStart": false
    }
  ]
}
