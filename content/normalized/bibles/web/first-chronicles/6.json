{
  "chapter": {
    "id": "web:first-chronicles.6",
    "translationId": "web",
    "bookSlug": "first-chronicles",
    "chapterNumber": 6,
    "referenceLabel": "1 Chronicles 6",
    "summary": "Source text for 1 Chronicles 6 in World English Bible."
  },
  "verses": [
    {
      "id": "web:first-chronicles.6.1",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 6:1",
      "text": "The sons of Levi: Gershon, Kohath, and Merari.",
      "paragraphStart": true
    },
    {
      "id": "web:first-chronicles.6.2",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 6:2",
      "text": "The sons of Kohath: Amram, Izhar, Hebron, and Uzziel.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.3",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 6:3",
      "text": "The children of Amram: Aaron, Moses, and Miriam. The sons of Aaron: Nadab, Abihu, Eleazar, and Ithamar.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.4",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 6:4",
      "text": "Eleazar became the father of Phinehas, Phinehas became the father of Abishua,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.5",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 6:5",
      "text": "Abishua became the father of Bukki. Bukki became the father of Uzzi.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.6",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 6:6",
      "text": "Uzzi became the father of Zerahiah. Zerahiah became the father of Meraioth.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.7",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 6:7",
      "text": "Meraioth became the father of Amariah. Amariah became the father of Ahitub.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.8",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 6:8",
      "text": "Ahitub became the father of Zadok. Zadok became the father of Ahimaaz.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.9",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 6:9",
      "text": "Ahimaaz became the father of Azariah. Azariah became the father of Johanan.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.10",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 6:10",
      "text": "Johanan became the father of Azariah, who executed the priest’s office in the house that Solomon built in Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.11",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 6:11",
      "text": "Azariah became the father of Amariah. Amariah became the father of Ahitub.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.12",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 6:12",
      "text": "Ahitub became the father of Zadok. Zadok became the father of Shallum.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.13",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 6:13",
      "text": "Shallum became the father of Hilkiah. Hilkiah became the father of Azariah.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.14",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 6:14",
      "text": "Azariah became the father of Seraiah. Seraiah became the father of Jehozadak.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.15",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 6:15",
      "text": "Jehozadak went into captivity when Yahweh carried Judah and Jerusalem away by the hand of Nebuchadnezzar.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.16",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 6:16",
      "text": "The sons of Levi: Gershom, Kohath, and Merari.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.17",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 6:17",
      "text": "These are the names of the sons of Gershom: Libni and Shimei.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.18",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 6:18",
      "text": "The sons of Kohath were Amram, Izhar, Hebron, and Uzziel.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.19",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 6:19",
      "text": "The sons of Merari: Mahli and Mushi. These are the families of the Levites according to their fathers’ households.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.20",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 6:20",
      "text": "Of Gershom: Libni his son, Jahath his son, Zimmah his son,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.21",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 6:21",
      "text": "Joah his son, Iddo his son, Zerah his son, and Jeatherai his son.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.22",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 6:22",
      "text": "The sons of Kohath: Amminadab his son, Korah his son, Assir his son,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.23",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 6:23",
      "text": "Elkanah his son, Ebiasaph his son, Assir his son,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.24",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 6:24",
      "text": "Tahath his son, Uriel his son, Uzziah his son, and Shaul his son.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.25",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 6:25",
      "text": "The sons of Elkanah: Amasai and Ahimoth.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.26",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 6:26",
      "text": "As for Elkanah, the sons of Elkanah: Zophai his son, Nahath his son,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.27",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 6:27",
      "text": "Eliab his son, Jeroham his son, and Elkanah his son.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.28",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 6:28",
      "text": "The sons of Samuel: the firstborn, Joel, and the second, Abijah.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.29",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 6:29",
      "text": "The sons of Merari: Mahli, Libni his son, Shimei his son, Uzzah his son,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.30",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 6:30",
      "text": "Shimea his son, Haggiah his son, Asaiah his son.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.31",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 6:31",
      "text": "These are they whom David set over the service of song in Yahweh’s house after the ark came to rest there.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.32",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 6:32",
      "text": "They ministered with song before the tabernacle of the Tent of Meeting until Solomon had built Yahweh’s house in Jerusalem. They performed the duties of their office according to their order.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.33",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 6:33",
      "text": "These are those who served, and their sons. Of the sons of the Kohathites: Heman the singer, the son of Joel, the son of Samuel,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.34",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 6:34",
      "text": "the son of Elkanah, the son of Jeroham, the son of Eliel, the son of Toah,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.35",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 6:35",
      "text": "the son of Zuph, the son of Elkanah, the son of Mahath, the son of Amasai,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.36",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 6:36",
      "text": "the son of Elkanah, the son of Joel, the son of Azariah, the son of Zephaniah,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.37",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 6:37",
      "text": "the son of Tahath, the son of Assir, the son of Ebiasaph, the son of Korah,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.38",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 6:38",
      "text": "the son of Izhar, the son of Kohath, the son of Levi, the son of Israel.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.39",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 6:39",
      "text": "His brother Asaph, who stood on his right hand, even Asaph the son of Berechiah, the son of Shimea,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.40",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 6:40",
      "text": "the son of Michael, the son of Baaseiah, the son of Malchijah,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.41",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 41,
      "referenceLabel": "1 Chronicles 6:41",
      "text": "the son of Ethni, the son of Zerah, the son of Adaiah,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.42",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 42,
      "referenceLabel": "1 Chronicles 6:42",
      "text": "the son of Ethan, the son of Zimmah, the son of Shimei,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.43",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 43,
      "referenceLabel": "1 Chronicles 6:43",
      "text": "the son of Jahath, the son of Gershom, the son of Levi.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.44",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 44,
      "referenceLabel": "1 Chronicles 6:44",
      "text": "On the left hand their brothers the sons of Merari: Ethan the son of Kishi, the son of Abdi, the son of Malluch,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.45",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 45,
      "referenceLabel": "1 Chronicles 6:45",
      "text": "the son of Hashabiah, the son of Amaziah, the son of Hilkiah,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.46",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 46,
      "referenceLabel": "1 Chronicles 6:46",
      "text": "the son of Amzi, the son of Bani, the son of Shemer,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.47",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 47,
      "referenceLabel": "1 Chronicles 6:47",
      "text": "the son of Mahli, the son of Mushi, the son of Merari, the son of Levi.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.48",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 48,
      "referenceLabel": "1 Chronicles 6:48",
      "text": "Their brothers the Levites were appointed for all the service of the tabernacle of God’s house.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.49",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 49,
      "referenceLabel": "1 Chronicles 6:49",
      "text": "But Aaron and his sons offered on the altar of burnt offering, and on the altar of incense, for all the work of the most holy place, and to make atonement for Israel, according to all that Moses the servant of God had commanded.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.50",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 50,
      "referenceLabel": "1 Chronicles 6:50",
      "text": "These are the sons of Aaron: Eleazar his son, Phinehas his son, Abishua his son,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.51",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 51,
      "referenceLabel": "1 Chronicles 6:51",
      "text": "Bukki his son, Uzzi his son, Zerahiah his son,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.52",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 52,
      "referenceLabel": "1 Chronicles 6:52",
      "text": "Meraioth his son, Amariah his son, Ahitub his son,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.53",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 53,
      "referenceLabel": "1 Chronicles 6:53",
      "text": "Zadok his son, and Ahimaaz his son.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.54",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 54,
      "referenceLabel": "1 Chronicles 6:54",
      "text": "Now these are their dwelling places according to their encampments in their borders: to the sons of Aaron, of the families of the Kohathites (for theirs was the first lot),",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.55",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 55,
      "referenceLabel": "1 Chronicles 6:55",
      "text": "to them they gave Hebron in the land of Judah, and its pasture lands around it;",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.56",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 56,
      "referenceLabel": "1 Chronicles 6:56",
      "text": "but the fields of the city and its villages, they gave to Caleb the son of Jephunneh.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.57",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 57,
      "referenceLabel": "1 Chronicles 6:57",
      "text": "To the sons of Aaron they gave the cities of refuge, Hebron, Libnah also with its pasture lands, Jattir, Eshtemoa with its pasture lands,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.58",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 58,
      "referenceLabel": "1 Chronicles 6:58",
      "text": "Hilen with its pasture lands, Debir with its pasture lands,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.59",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 59,
      "referenceLabel": "1 Chronicles 6:59",
      "text": "Ashan with its pasture lands, and Beth Shemesh with its pasture lands;",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.60",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 60,
      "referenceLabel": "1 Chronicles 6:60",
      "text": "and out of the tribe of Benjamin, Geba with its pasture lands, Allemeth with its pasture lands, and Anathoth with its pasture lands. All their cities throughout their families were thirteen cities.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.61",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 61,
      "referenceLabel": "1 Chronicles 6:61",
      "text": "To the rest of the sons of Kohath were given by lot, out of the family of the tribe, out of the half-tribe, the half of Manasseh, ten cities.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.62",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 62,
      "referenceLabel": "1 Chronicles 6:62",
      "text": "To the sons of Gershom, according to their families, out of the tribe of Issachar, and out of the tribe of Asher, and out of the tribe of Naphtali, and out of the tribe of Manasseh in Bashan, thirteen cities.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.63",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 63,
      "referenceLabel": "1 Chronicles 6:63",
      "text": "To the sons of Merari were given by lot, according to their families, out of the tribe of Reuben, and out of the tribe of Gad, and out of the tribe of Zebulun, twelve cities.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.64",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 64,
      "referenceLabel": "1 Chronicles 6:64",
      "text": "The children of Israel gave to the Levites the cities with their pasture lands.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.6.65",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 65,
