{
  "chapter": {
    "id": "web:first-chronicles.1",
    "translationId": "web",
    "bookSlug": "first-chronicles",
    "chapterNumber": 1,
    "referenceLabel": "1 Chronicles 1",
    "summary": "Source text for 1 Chronicles 1 in World English Bible."
  },
  "verses": [
    {
      "id": "web:first-chronicles.1.1",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 1:1",
      "text": "Adam, Seth, Enosh,",
      "paragraphStart": true
    },
    {
      "id": "web:first-chronicles.1.2",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 1:2",
      "text": "Kenan, Mahalalel, Jared,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.3",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 1:3",
      "text": "Enoch, Methuselah, Lamech,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.4",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 1:4",
      "text": "Noah, Shem, Ham, and Japheth.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.5",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 1:5",
      "text": "The sons of Japheth: Gomer, Magog, Madai, Javan, Tubal, Meshech, and Tiras.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.6",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 1:6",
      "text": "The sons of Gomer: Ashkenaz, Diphath, and Togarmah.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.7",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 1:7",
      "text": "The sons of Javan: Elishah, Tarshish, Kittim, and Rodanim.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.8",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 1:8",
      "text": "The sons of Ham: Cush, Mizraim, Put, and Canaan.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.9",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 1:9",
      "text": "The sons of Cush: Seba, Havilah, Sabta, Raama, Sabteca. The sons of Raamah: Sheba and Dedan.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.10",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 1:10",
      "text": "Cush became the father of Nimrod. He began to be a mighty one in the earth.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.11",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 1:11",
      "text": "Mizraim became the father of Ludim, Anamim, Lehabim, Naphtuhim,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.12",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 1:12",
      "text": "Pathrusim, Casluhim (where the Philistines came from), and Caphtorim.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.13",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 1:13",
      "text": "Canaan became the father of Sidon his firstborn, Heth,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.14",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 1:14",
      "text": "the Jebusite, the Amorite, the Girgashite,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.15",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 1:15",
      "text": "the Hivite, the Arkite, the Sinite,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.16",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 1:16",
      "text": "the Arvadite, the Zemarite, and the Hamathite.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.17",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 1:17",
      "text": "The sons of Shem: Elam, Asshur, Arpachshad, Lud, Aram, Uz, Hul, Gether, and Meshech.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.18",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 1:18",
      "text": "Arpachshad became the father of Shelah, and Shelah became the father of Eber.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.19",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 1:19",
      "text": "To Eber were born two sons: the name of the one was Peleg, for in his days the earth was divided; and his brother’s name was Joktan.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.20",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 1:20",
      "text": "Joktan became the father of Almodad, Sheleph, Hazarmaveth, Jerah,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.21",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 1:21",
      "text": "Hadoram, Uzal, Diklah,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.22",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 1:22",
      "text": "Ebal, Abimael, Sheba,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.23",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 1:23",
      "text": "Ophir, Havilah, and Jobab. All these were the sons of Joktan.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.24",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 1:24",
      "text": "Shem, Arpachshad, Shelah,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.25",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 1:25",
      "text": "Eber, Peleg, Reu,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.26",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 1:26",
      "text": "Serug, Nahor, Terah,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.27",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 1:27",
      "text": "Abram (also called Abraham).",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.28",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 1:28",
      "text": "The sons of Abraham: Isaac and Ishmael.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.29",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 1:29",
      "text": "These are their generations: the firstborn of Ishmael, Nebaioth; then Kedar, Adbeel, Mibsam,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.30",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 1:30",
      "text": "Mishma, Dumah, Massa, Hadad, Tema,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.31",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 1:31",
      "text": "Jetur, Naphish, and Kedemah. These are the sons of Ishmael.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.32",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 1:32",
      "text": "The sons of Keturah, Abraham’s concubine: she bore Zimran, Jokshan, Medan, Midian, Ishbak, and Shuah. The sons of Jokshan: Sheba and Dedan.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.33",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 1:33",
      "text": "The sons of Midian: Ephah, Epher, Hanoch, Abida, and Eldaah. All these were the sons of Keturah.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.34",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 1:34",
      "text": "Abraham became the father of Isaac. The sons of Isaac: Esau and Israel.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.35",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 1:35",
      "text": "The sons of Esau: Eliphaz, Reuel, Jeush, Jalam, and Korah.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.36",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 1:36",
      "text": "The sons of Eliphaz: Teman, Omar, Zephi, Gatam, Kenaz, Timna, and Amalek.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.37",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 1:37",
      "text": "The sons of Reuel: Nahath, Zerah, Shammah, and Mizzah.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.38",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 1:38",
      "text": "The sons of Seir: Lotan, Shobal, Zibeon, Anah, Dishon, Ezer, and Dishan.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.39",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 1:39",
      "text": "The sons of Lotan: Hori and Homam; and Timna was Lotan ’s sister.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.40",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 1:40",
      "text": "The sons of Shobal: Alian, Manahath, Ebal, Shephi, and Onam. The sons of Zibeon: Aiah and Anah.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.41",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 41,
      "referenceLabel": "1 Chronicles 1:41",
      "text": "The son of Anah: Dishon. The sons of Dishon: Hamran, Eshban, Ithran, and Cheran.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.42",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 42,
      "referenceLabel": "1 Chronicles 1:42",
      "text": "The sons of Ezer: Bilhan, Zaavan, and Jaakan. The sons of Dishan: Uz and Aran.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.43",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 43,
      "referenceLabel": "1 Chronicles 1:43",
      "text": "Now these are the kings who reigned in the land of Edom, before any king reigned over the children of Israel: Bela the son of Beor; and the name of his city was Dinhabah.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.44",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 44,
      "referenceLabel": "1 Chronicles 1:44",
      "text": "Bela died, and Jobab the son of Zerah of Bozrah reigned in his place.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.45",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 45,
      "referenceLabel": "1 Chronicles 1:45",
      "text": "Jobab died, and Husham of the land of the Temanites reigned in his place.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.46",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 46,
      "referenceLabel": "1 Chronicles 1:46",
      "text": "Husham died, and Hadad the son of Bedad, who struck Midian in the field of Moab, reigned in his place; and the name of his city was Avith.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.47",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 47,
      "referenceLabel": "1 Chronicles 1:47",
      "text": "Hadad died, and Samlah of Masrekah reigned in his place.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.48",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 48,
      "referenceLabel": "1 Chronicles 1:48",
      "text": "Samlah died, and Shaul of Rehoboth by the River reigned in his place.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.49",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 49,
      "referenceLabel": "1 Chronicles 1:49",
      "text": "Shaul died, and Baal Hanan the son of Achbor reigned in his place.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.50",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 50,
      "referenceLabel": "1 Chronicles 1:50",
      "text": "Baal Hanan died, and Hadad reigned in his place; and the name of his city was Pai. His wife’s name was Mehetabel, the daughter of Matred, the daughter of Mezahab.",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.51",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 51,
      "referenceLabel": "1 Chronicles 1:51",
      "text": "Then Hadad died. The chiefs of Edom were: chief Timna, chief Aliah, chief Jetheth,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.52",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 52,
      "referenceLabel": "1 Chronicles 1:52",
      "text": "chief Oholibamah, chief Elah, chief Pinon,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.53",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 53,
      "referenceLabel": "1 Chronicles 1:53",
      "text": "chief Kenaz, chief Teman, chief Mibzar,",
      "paragraphStart": false
    },
    {
      "id": "web:first-chronicles.1.54",
      "translationId": "web",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 54,
      "referenceLabel": "1 Chronicles 1:54",
      "text": "chief Magdiel, and chief Iram. These are the chiefs of Edom.",
      "paragraphStart": false
    }
  ]
}
