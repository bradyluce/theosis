      "bookSlug": "joshua",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Joshua 12:9",
      "text": "the king of Jericho, one; the king of Ai, which is beside Bethel, one;",
      "paragraphStart": false
    },
    {
