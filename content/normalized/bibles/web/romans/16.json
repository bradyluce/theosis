{
  "chapter": {
    "id": "web:romans.16",
    "translationId": "web",
    "bookSlug": "romans",
    "chapterNumber": 16,
    "referenceLabel": "Romans 16",
    "summary": "Source text for Romans 16 in World English Bible."
  },
  "verses": [
    {
      "id": "web:romans.16.1",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Romans 16:1",
      "text": "I commend to you Phoebe, our sister, who is a servant of the assembly that is at Cenchreae,",
      "paragraphStart": true
    },
    {
      "id": "web:romans.16.2",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Romans 16:2",
      "text": "that you receive her in the Lord in a way worthy of the saints, and that you assist her in whatever matter she may need from you, for she herself also has been a helper of many, and of my own self.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.3",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Romans 16:3",
      "text": "Greet Prisca and Aquila, my fellow workers in Christ Jesus,",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.4",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Romans 16:4",
      "text": "who risked their own necks for my life, to whom not only I give thanks, but also all the assemblies of the Gentiles.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.5",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Romans 16:5",
      "text": "Greet the assembly that is in their house. Greet Epaenetus, my beloved, who is the first fruits of Achaia to Christ.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.6",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Romans 16:6",
      "text": "Greet Mary, who labored much for us.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.7",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Romans 16:7",
      "text": "Greet Andronicus and Junia, my relatives and my fellow prisoners, who are notable among the apostles, who were also in Christ before me.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.8",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Romans 16:8",
      "text": "Greet Amplias, my beloved in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.9",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Romans 16:9",
      "text": "Greet Urbanus, our fellow worker in Christ, and Stachys, my beloved.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.10",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Romans 16:10",
      "text": "Greet Apelles, the approved in Christ. Greet those who are of the household of Aristobulus.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.11",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Romans 16:11",
      "text": "Greet Herodion, my kinsman. Greet them of the household of Narcissus, who are in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.12",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Romans 16:12",
      "text": "Greet Tryphaena and Tryphosa, who labor in the Lord. Greet Persis, the beloved, who labored much in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.13",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Romans 16:13",
      "text": "Greet Rufus, the chosen in the Lord, and his mother and mine.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.14",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Romans 16:14",
      "text": "Greet Asyncritus, Phlegon, Hermes, Patrobas, Hermas, and the brothers who are with them.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.15",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Romans 16:15",
      "text": "Greet Philologus and Julia, Nereus and his sister, and Olympas, and all the saints who are with them.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.16",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Romans 16:16",
      "text": "Greet one another with a holy kiss. The assemblies of Christ greet you.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.17",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Romans 16:17",
      "text": "Now I beg you, brothers, look out for those who are causing the divisions and occasions of stumbling, contrary to the doctrine which you learned, and turn away from them.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.18",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Romans 16:18",
      "text": "For those who are such don’ t serve our Lord Jesus Christ, but their own belly; and by their smooth and flattering speech they deceive the hearts of the innocent.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.19",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Romans 16:19",
      "text": "For your obedience has become known to all. I rejoice therefore over you. But I desire to have you wise in that which is good, but innocent in that which is evil.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.20",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Romans 16:20",
      "text": "And the God of peace will quickly crush Satan under your feet. The grace of our Lord Jesus Christ be with you.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.21",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "Romans 16:21",
      "text": "Timothy, my fellow worker, greets you, as do Lucius, Jason, and Sosipater, my relatives.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.22",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "Romans 16:22",
      "text": "I, Tertius, who write the letter, greet you in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.23",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "Romans 16:23",
      "text": "Gaius, my host and host of the whole assembly, greets you. Erastus, the treasurer of the city, greets you, as does Quartus, the brother.",
      "paragraphStart": false
    },
    {
      "id": "web:romans.16.24",
      "translationId": "web",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "Romans 16:24",
      "text": "The grace of our Lord Jesus Christ be with you all! Amen.",
      "paragraphStart": false
    }
  ]
}
