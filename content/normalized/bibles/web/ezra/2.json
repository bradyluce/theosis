{
  "chapter": {
    "id": "web:ezra.2",
    "translationId": "web",
    "bookSlug": "ezra",
    "chapterNumber": 2,
    "referenceLabel": "Ezra 2",
    "summary": "Source text for Ezra 2 in World English Bible."
  },
  "verses": [
    {
      "id": "web:ezra.2.1",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Ezra 2:1",
      "text": "Now these are the children of the province who went up out of the captivity of those who had been carried away, whom Nebuchadnezzar the king of Babylon had carried away to Babylon, and who returned to Jerusalem and Judah, everyone to his city;",
      "paragraphStart": true
    },
    {
      "id": "web:ezra.2.2",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Ezra 2:2",
      "text": "who came with Zerubbabel, Jeshua, Nehemiah, Seraiah, Reelaiah, Mordecai, Bilshan, Mispar, Bigvai, Rehum, and Baanah. The number of the men of the people of Israel:",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.3",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Ezra 2:3",
      "text": "The children of Parosh, two thousand one hundred seventy-two.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.4",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Ezra 2:4",
      "text": "The children of Shephatiah, three hundred seventy-two.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.5",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Ezra 2:5",
      "text": "The children of Arah, seven hundred seventy-five.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.6",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Ezra 2:6",
      "text": "The children of Pahathmoab, of the children of Jeshua and Joab, two thousand eight hundred twelve.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.7",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Ezra 2:7",
      "text": "The children of Elam, one thousand two hundred fifty-four.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.8",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Ezra 2:8",
      "text": "The children of Zattu, nine hundred forty-five.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.9",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Ezra 2:9",
      "text": "The children of Zaccai, seven hundred sixty.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.10",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Ezra 2:10",
      "text": "The children of Bani, six hundred forty-two.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.11",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Ezra 2:11",
      "text": "The children of Bebai, six hundred twenty-three.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.12",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Ezra 2:12",
      "text": "The children of Azgad, one thousand two hundred twenty-two.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.13",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Ezra 2:13",
      "text": "The children of Adonikam, six hundred sixty-six.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.14",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Ezra 2:14",
      "text": "The children of Bigvai, two thousand fifty-six.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.15",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Ezra 2:15",
      "text": "The children of Adin, four hundred fifty-four.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.16",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Ezra 2:16",
      "text": "The children of Ater, of Hezekiah, ninety-eight.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.17",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Ezra 2:17",
      "text": "The children of Bezai, three hundred twenty-three.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.18",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Ezra 2:18",
      "text": "The children of Jorah, one hundred twelve.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.19",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Ezra 2:19",
      "text": "The children of Hashum, two hundred twenty-three.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.20",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Ezra 2:20",
      "text": "The children of Gibbar, ninety-five.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.21",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Ezra 2:21",
      "text": "The children of Bethlehem, one hundred twenty-three.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.22",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Ezra 2:22",
      "text": "The men of Netophah, fifty-six.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.23",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Ezra 2:23",
      "text": "The men of Anathoth, one hundred twenty-eight.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.24",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "Ezra 2:24",
      "text": "The children of Azmaveth, forty-two.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.25",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "Ezra 2:25",
      "text": "The children of Kiriath Arim, Chephirah, and Beeroth, seven hundred forty-three.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.26",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "Ezra 2:26",
      "text": "The children of Ramah and Geba, six hundred twenty-one.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.27",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "Ezra 2:27",
      "text": "The men of Michmas, one hundred twenty-two.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.28",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "Ezra 2:28",
      "text": "The men of Bethel and Ai, two hundred twenty-three.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.29",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 29,
      "referenceLabel": "Ezra 2:29",
      "text": "The children of Nebo, fifty-two.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.30",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 30,
      "referenceLabel": "Ezra 2:30",
      "text": "The children of Magbish, one hundred fifty-six.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.31",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 31,
      "referenceLabel": "Ezra 2:31",
      "text": "The children of the other Elam, one thousand two hundred fifty-four.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.32",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 32,
      "referenceLabel": "Ezra 2:32",
      "text": "The children of Harim, three hundred twenty.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.33",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 33,
      "referenceLabel": "Ezra 2:33",
      "text": "The children of Lod, Hadid, and Ono, seven hundred twenty-five.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.34",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 34,
      "referenceLabel": "Ezra 2:34",
      "text": "The children of Jericho, three hundred forty-five.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.35",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 35,
      "referenceLabel": "Ezra 2:35",
      "text": "The children of Senaah, three thousand six hundred thirty.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.36",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 36,
      "referenceLabel": "Ezra 2:36",
      "text": "The priests: the children of Jedaiah, of the house of Jeshua, nine hundred seventy-three.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.37",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 37,
      "referenceLabel": "Ezra 2:37",
      "text": "The children of Immer, one thousand fifty-two.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.38",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 38,
      "referenceLabel": "Ezra 2:38",
      "text": "The children of Pashhur, one thousand two hundred forty-seven.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.39",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 39,
      "referenceLabel": "Ezra 2:39",
      "text": "The children of Harim, one thousand seventeen.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.40",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 40,
      "referenceLabel": "Ezra 2:40",
      "text": "The Levites: the children of Jeshua and Kadmiel, of the children of Hodaviah, seventy-four.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.41",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 41,
      "referenceLabel": "Ezra 2:41",
      "text": "The singers: the children of Asaph, one hundred twenty-eight.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.42",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 42,
      "referenceLabel": "Ezra 2:42",
      "text": "The children of the gatekeepers: the children of Shallum, the children of Ater, the children of Talmon, the children of Akkub, the children of Hatita, the children of Shobai, in all one hundred thirty-nine.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.43",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 43,
      "referenceLabel": "Ezra 2:43",
      "text": "The temple servants: the children of Ziha, the children of Hasupha, the children of Tabbaoth,",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.44",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 44,
      "referenceLabel": "Ezra 2:44",
      "text": "the children of Keros, the children of Siaha, the children of Padon,",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.45",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 45,
      "referenceLabel": "Ezra 2:45",
      "text": "the children of Lebanah, the children of Hagabah, the children of Akkub,",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.46",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 46,
      "referenceLabel": "Ezra 2:46",
      "text": "the children of Hagab, the children of Shamlai, the children of Hanan,",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.47",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 47,
      "referenceLabel": "Ezra 2:47",
      "text": "the children of Giddel, the children of Gahar, the children of Reaiah,",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.48",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 48,
      "referenceLabel": "Ezra 2:48",
      "text": "the children of Rezin, the children of Nekoda, the children of Gazzam,",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.49",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 49,
      "referenceLabel": "Ezra 2:49",
      "text": "the children of Uzza, the children of Paseah, the children of Besai,",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.50",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 50,
      "referenceLabel": "Ezra 2:50",
      "text": "the children of Asnah, the children of Meunim, the children of Nephisim,",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.51",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 51,
      "referenceLabel": "Ezra 2:51",
      "text": "the children of Bakbuk, the children of Hakupha, the children of Harhur,",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.52",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 52,
      "referenceLabel": "Ezra 2:52",
      "text": "the children of Bazluth, the children of Mehida, the children of Harsha,",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.53",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 53,
      "referenceLabel": "Ezra 2:53",
      "text": "the children of Barkos, the children of Sisera, the children of Temah,",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.54",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 54,
      "referenceLabel": "Ezra 2:54",
      "text": "the children of Neziah, the children of Hatipha.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.55",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 55,
      "referenceLabel": "Ezra 2:55",
      "text": "The children of Solomon ’s servants: the children of Sotai, the children of Hassophereth, the children of Peruda,",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.56",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 56,
      "referenceLabel": "Ezra 2:56",
      "text": "the children of Jaalah, the children of Darkon, the children of Giddel,",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.57",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 57,
      "referenceLabel": "Ezra 2:57",
      "text": "the children of Shephatiah, the children of Hattil, the children of Pochereth Hazzebaim, the children of Ami.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.58",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 58,
      "referenceLabel": "Ezra 2:58",
      "text": "All the temple servants, and the children of Solomon ’s servants, were three hundred ninety-two.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.59",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 59,
      "referenceLabel": "Ezra 2:59",
      "text": "These were those who went up from Tel Melah, Tel Harsha, Cherub, Addan, and Immer; but they could not show their fathers’ houses and their offspring, whether they were of Israel:",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.60",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 60,
      "referenceLabel": "Ezra 2:60",
      "text": "the children of Delaiah, the children of Tobiah, the children of Nekoda, six hundred fifty-two.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.61",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 61,
      "referenceLabel": "Ezra 2:61",
      "text": "Of the children of the priests: the children of Habaiah, the children of Hakkoz, and the children of Barzillai, who took a wife of the daughters of Barzillai the Gileadite, and was called after their name.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.62",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 62,
      "referenceLabel": "Ezra 2:62",
      "text": "These sought their place among those who were registered by genealogy, but they were not found; therefore they were deemed disqualified and removed from the priesthood.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.63",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 63,
      "referenceLabel": "Ezra 2:63",
      "text": "The governor told them that they should not eat of the most holy things until a priest stood up to serve with Urim and with Thummim.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.64",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 64,
      "referenceLabel": "Ezra 2:64",
      "text": "The whole assembly together was forty-two thousand three hundred sixty,",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.65",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 65,
      "referenceLabel": "Ezra 2:65",
      "text": "in addition to their male servants and their female servants, of whom there were seven thousand three hundred thirty-seven; and they had two hundred singing men and singing women.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.66",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 66,
      "referenceLabel": "Ezra 2:66",
      "text": "Their horses were seven hundred thirty-six; their mules, two hundred forty-five;",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.67",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 67,
      "referenceLabel": "Ezra 2:67",
      "text": "their camels, four hundred thirty-five; their donkeys, six thousand seven hundred twenty.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.68",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 68,
      "referenceLabel": "Ezra 2:68",
      "text": "Some of the heads of fathers’ households, when they came to Yahweh ’s house which is in Jerusalem, offered willingly for God ’s house to set it up in its place.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.69",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 69,
      "referenceLabel": "Ezra 2:69",
      "text": "They gave according to their ability into the treasury of the work sixty-one thousand darics of gold, five thousand minas of silver, and one hundred priests ’ garments.",
      "paragraphStart": false
    },
    {
      "id": "web:ezra.2.70",
      "translationId": "web",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 70,
      "referenceLabel": "Ezra 2:70",
      "text": "So the priests and the Levites, with some of the people, the singers, the gatekeepers, and the temple servants, lived in their cities, and all Israel in their cities.",
      "paragraphStart": false
    }
  ]
}
