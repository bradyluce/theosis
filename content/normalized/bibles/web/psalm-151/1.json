  "verses": [
    {
      "id": "web:psalm-151.1.1",
      "translationId": "web",
      "bookSlug": "psalm-151",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Psalm 151 1:1",
      "text": "I was small among my brothers, and youngest in my father’s house. I tended my father’s sheep.",
      "paragraphStart": true
    },
    {
      "id": "web:psalm-151.1.2",
      "translationId": "web",
      "bookSlug": "psalm-151",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Psalm 151 1:2",
      "text": "My hands formed a musical instrument, and my fingers tuned a lyre.",
      "paragraphStart": false
    },
    {
      "id": "web:psalm-151.1.3",
      "translationId": "web",
      "bookSlug": "psalm-151",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Psalm 151 1:3",
      "text": "Who shall tell my Lord? The Lord himself, he himself hears.",
      "paragraphStart": false
    },
    {
      "id": "web:psalm-151.1.4",
      "translationId": "web",
      "bookSlug": "psalm-151",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Psalm 151 1:4",
      "text": "He sent forth his angel and took me from my father’s sheep, and he anointed me with his anointing oil.",
      "paragraphStart": false
    },
    {
      "id": "web:psalm-151.1.5",
      "translationId": "web",
      "bookSlug": "psalm-151",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Psalm 151 1:5",
      "text": "My brothers were handsome and tall; but the Lord didn’t take pleasure in them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalm-151.1.6",
      "translationId": "web",
      "bookSlug": "psalm-151",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Psalm 151 1:6",
      "text": "I went out to meet the Philistine, and he cursed me by his idols.",
      "paragraphStart": false
    },
    {
      "id": "web:psalm-151.1.7",
      "translationId": "web",
      "bookSlug": "psalm-151",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Psalm 151 1:7",
      "text": "But I drew his own sword and beheaded him, and removed reproach from the children of Israel.",
      "paragraphStart": false
    }
  ]
}
