{
  "chapter": {
    "id": "web:song-of-solomon.7",
    "translationId": "web",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 7,
    "referenceLabel": "Song of Solomon 7",
    "summary": "Source text for Song of Solomon 7 in World English Bible."
  },
  "verses": [
    {
      "id": "web:song-of-solomon.7.1",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 7:1",
      "text": "How beautiful are your feet in sandals, prince’s daughter! Your rounded thighs are like jewels, the work of the hands of a skillful workman.",
      "paragraphStart": true
    },
    {
      "id": "web:song-of-solomon.7.2",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 7:2",
      "text": "Your body is like a round goblet, no mixed wine is wanting. Your waist is like a heap of wheat, set about with lilies.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.7.3",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 7:3",
      "text": "Your two breasts are like two fawns, that are twins of a roe.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.7.4",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 7:4",
      "text": "Your neck is like an ivory tower. Your eyes are like the pools in Heshbon by the gate of Bathrabbim. Your nose is like the tower of Lebanon which looks toward Damascus.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.7.5",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 7:5",
      "text": "Your head on you is like Carmel. The hair of your head like purple. The king is held captive in its tresses.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.7.6",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 7:6",
      "text": "How beautiful and how pleasant you are, love, for delights!",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.7.7",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 7:7",
      "text": "This, your stature, is like a palm tree, your breasts like its fruit.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.7.8",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 7:8",
      "text": "I said, “ I will climb up into the palm tree. I will take hold of its fruit.” Let your breasts be like clusters of the vine, the smell of your breath like apples.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.7.9",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 7:9",
      "text": "Your mouth is like the best wine, that goes down smoothly for my beloved, gliding through the lips of those who are asleep.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.7.10",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 7:10",
      "text": "I am my beloved ’s. His desire is toward me.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.7.11",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 7:11",
      "text": "Come, my beloved! Let’s go out into the field. Let’s lodge in the villages.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.7.12",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 7:12",
      "text": "Let ’s go early up to the vineyards. Let ’s see whether the vine has budded, its blossom is open, and the pomegranates are in flower. There I will give you my love.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.7.13",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 7:13",
      "text": "The mandrakes produce fragrance. At our doors are all kinds of precious fruits, new and old, which I have stored up for you, my beloved.",
      "paragraphStart": false
    }
  ]
}
