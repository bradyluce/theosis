{
  "chapter": {
    "id": "web:song-of-solomon.2",
    "translationId": "web",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 2,
    "referenceLabel": "Song of Solomon 2",
    "summary": "Source text for Song of Solomon 2 in World English Bible."
  },
  "verses": [
    {
      "id": "web:song-of-solomon.2.1",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 2:1",
      "text": "I am a rose of Sharon, a lily of the valleys.",
      "paragraphStart": true
    },
    {
      "id": "web:song-of-solomon.2.2",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 2:2",
      "text": "As a lily among thorns, so is my love among the daughters.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.2.3",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 2:3",
      "text": "As the apple tree among the trees of the wood, so is my beloved among the sons. I sat down under his shadow with great delight, his fruit was sweet to my taste.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.2.4",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 2:4",
      "text": "He brought me to the banquet hall. His banner over me is love.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.2.5",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 2:5",
      "text": "Strengthen me with raisins, refresh me with apples; for I am faint with love.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.2.6",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 2:6",
      "text": "His left hand is under my head. His right hand embraces me.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.2.7",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 2:7",
      "text": "I adjure you, daughters of Jerusalem, by the roes, or by the hinds of the field, that you not stir up, nor awaken love, until it so desires.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.2.8",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 2:8",
      "text": "The voice of my beloved! Behold, he comes, leaping on the mountains, skipping on the hills.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.2.9",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 2:9",
      "text": "My beloved is like a roe or a young deer. Behold, he stands behind our wall! He looks in at the windows. He glances through the lattice.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.2.10",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 2:10",
      "text": "My beloved spoke, and said to me, “Rise up, my love, my beautiful one, and come away.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.2.11",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 2:11",
      "text": "For behold, the winter is past. The rain is over and gone.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.2.12",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 2:12",
      "text": "The flowers appear on the earth. The time of the singing has come, and the voice of the turtledove is heard in our land.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.2.13",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 2:13",
      "text": "The fig tree ripens her green figs. The vines are in blossom. They give out their fragrance. Arise, my love, my beautiful one, and come away.”",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.2.14",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Song of Solomon 2:14",
      "text": "My dove in the clefts of the rock, in the hiding places of the mountainside, let me see your face. Let me hear your voice; for your voice is sweet and your face is lovely.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.2.15",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Song of Solomon 2:15",
      "text": "Catch for us the foxes, the little foxes that plunder the vineyards; for our vineyards are in blossom.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.2.16",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Song of Solomon 2:16",
      "text": "My beloved is mine, and I am his. He browses among the lilies.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.2.17",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Song of Solomon 2:17",
      "text": "Until the day is cool, and the shadows flee away, turn, my beloved, and be like a roe or a young deer on the mountains of Bether.",
      "paragraphStart": false
    }
  ]
}
