{
  "chapter": {
    "id": "web:song-of-solomon.1",
    "translationId": "web",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 1,
    "referenceLabel": "Song of Solomon 1",
    "summary": "Source text for Song of Solomon 1 in World English Bible."
  },
  "verses": [
    {
      "id": "web:song-of-solomon.1.1",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 1:1",
      "text": "The Song of songs, which is Solomon’s.",
      "paragraphStart": true
    },
    {
      "id": "web:song-of-solomon.1.2",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 1:2",
      "text": "Let him kiss me with the kisses of his mouth; for your love is better than wine.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.1.3",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 1:3",
      "text": "Your oils have a pleasing fragrance. Your name is oil poured out, therefore the virgins love you.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.1.4",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 1:4",
      "text": "Take me away with you. Let’s hurry. The king has brought me into his rooms. Friends We will be glad and rejoice in you. We will praise your love more than wine! Beloved They are right to love you.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.1.5",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 1:5",
      "text": "I am dark, but lovely, you daughters of Jerusalem, like Kedar’s tents, like Solomon’s curtains.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.1.6",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 1:6",
      "text": "Don’t stare at me because I am dark, because the sun has scorched me. My mother’s sons were angry with me. They made me keeper of the vineyards. I haven’t kept my own vineyard.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.1.7",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 1:7",
      "text": "Tell me, you whom my soul loves, where you graze your flock, where you rest them at noon; for why should I be as one who is veiled beside the flocks of your companions?",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.1.8",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 1:8",
      "text": "If you don’t know, most beautiful among women, follow the tracks of the sheep. Graze your young goats beside the shepherds ’ tents.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.1.9",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 1:9",
      "text": "I have compared you, my love, to a steed in Pharaoh’s chariots.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.1.10",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 1:10",
      "text": "Your cheeks are beautiful with earrings, your neck with strings of jewels.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.1.11",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 1:11",
      "text": "We will make you earrings of gold, with studs of silver.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.1.12",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 1:12",
      "text": "While the king sat at his table, my perfume spread its fragrance.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.1.13",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 1:13",
      "text": "My beloved is to me a sachet of myrrh, that lies between my breasts.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.1.14",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Song of Solomon 1:14",
      "text": "My beloved is to me a cluster of henna blossoms from the vineyards of En Gedi.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.1.15",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Song of Solomon 1:15",
      "text": "Behold, you are beautiful, my love. Behold, you are beautiful. Your eyes are like doves.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.1.16",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Song of Solomon 1:16",
      "text": "Behold, you are beautiful, my beloved, yes, pleasant; and our couch is verdant.",
      "paragraphStart": false
    },
    {
      "id": "web:song-of-solomon.1.17",
      "translationId": "web",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Song of Solomon 1:17",
      "text": "The beams of our house are cedars. Our rafters are firs.",
      "paragraphStart": false
    }
  ]
}
