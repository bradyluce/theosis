{
  "chapter": {
    "id": "web:psalms.22",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 22,
    "referenceLabel": "Psalms 22",
    "summary": "Source text for Psalms 22 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.22.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Psalms 22:1",
      "text": "My God, my God, why have you forsaken me? Why are you so far from helping me, and from the words of my groaning?",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.22.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Psalms 22:2",
      "text": "My God, I cry in the daytime, but you don’t answer; in the night season, and am not silent.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Psalms 22:3",
      "text": "But you are holy, you who inhabit the praises of Israel.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Psalms 22:4",
      "text": "Our fathers trusted in you. They trusted, and you delivered them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Psalms 22:5",
      "text": "They cried to you, and were delivered. They trusted in you, and were not disappointed.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Psalms 22:6",
      "text": "But I am a worm, and no man; a reproach of men, and despised by the people.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Psalms 22:7",
      "text": "All those who see me mock me. They insult me with their lips. They shake their heads, saying,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Psalms 22:8",
      "text": "“ He trusts in Yahweh. Let him deliver him. Let him rescue him, since he delights in him.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Psalms 22:9",
      "text": "But you brought me out of the womb. You made me trust while at my mother’s breasts.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Psalms 22:10",
      "text": "I was thrown on you from my mother’s womb. You are my God since my mother bore me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Psalms 22:11",
      "text": "Don’t be far from me, for trouble is near. For there is no one to help.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Psalms 22:12",
      "text": "Many bulls have surrounded me. Strong bulls of Bashan have encircled me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Psalms 22:13",
      "text": "They open their mouths wide against me, lions tearing prey and roaring.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Psalms 22:14",
      "text": "I am poured out like water. All my bones are out of joint. My heart is like wax. It is melted within me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Psalms 22:15",
      "text": "My strength is dried up like a potsherd. My tongue sticks to the roof of my mouth. You have brought me into the dust of death.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Psalms 22:16",
      "text": "For dogs have surrounded me. A company of evildoers have enclosed me. They have pierced my hands and feet.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Psalms 22:17",
      "text": "I can count all of my bones. They look and stare at me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Psalms 22:18",
      "text": "They divide my garments among them. They cast lots for my clothing.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Psalms 22:19",
      "text": "But don’t be far off, Yahweh. You are my help. Hurry to help me!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Psalms 22:20",
      "text": "Deliver my soul from the sword, my precious life from the power of the dog.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Psalms 22:21",
      "text": "Save me from the lion’s mouth! Yes, you have rescued me from the horns of the wild oxen.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Psalms 22:22",
      "text": "I will declare your name to my brothers. Among the assembly, I will praise you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.23",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Psalms 22:23",
      "text": "You who fear Yahweh, praise him! All you descendants of Jacob, glorify him! Stand in awe of him, all you descendants of Israel!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.24",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Psalms 22:24",
      "text": "For he has not despised nor abhorred the affliction of the afflicted, neither has he hidden his face from him; but when he cried to him, he heard.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.25",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Psalms 22:25",
      "text": "My praise of you comes in the great assembly. I will pay my vows before those who fear him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.26",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Psalms 22:26",
      "text": "The humble shall eat and be satisfied. They shall praise Yahweh who seek after him. Let your hearts live forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.27",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Psalms 22:27",
      "text": "All the ends of the earth shall remember and turn to Yahweh. All the relatives of the nations shall worship before you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.28",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Psalms 22:28",
      "text": "For the kingdom is Yahweh ’s. He is the ruler over the nations.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.29",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Psalms 22:29",
      "text": "All the rich ones of the earth shall eat and worship. All those who go down to the dust shall bow before him, even he who can’t keep his soul alive.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.30",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "Psalms 22:30",
      "text": "Posterity shall serve him. Future generations shall be told about the Lord.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.22.31",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 31,
      "referenceLabel": "Psalms 22:31",
      "text": "They shall come and shall declare his righteousness to a people that shall be born, for he has done it.",
      "paragraphStart": false
    }
  ]
}
