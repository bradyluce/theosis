{
  "chapter": {
    "id": "web:psalms.103",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 103,
    "referenceLabel": "Psalms 103",
    "summary": "Source text for Psalms 103 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.103.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 1,
      "referenceLabel": "Psalms 103:1",
      "text": "Praise Yahweh, my soul! All that is within me, praise his holy name!",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.103.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 2,
      "referenceLabel": "Psalms 103:2",
      "text": "Praise Yahweh, my soul, and don’t forget all his benefits,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 3,
      "referenceLabel": "Psalms 103:3",
      "text": "who forgives all your sins, who heals all your diseases,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 4,
      "referenceLabel": "Psalms 103:4",
      "text": "who redeems your life from destruction, who crowns you with loving kindness and tender mercies,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 5,
      "referenceLabel": "Psalms 103:5",
      "text": "who satisfies your desire with good things, so that your youth is renewed like the eagle’s.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 6,
      "referenceLabel": "Psalms 103:6",
      "text": "Yahweh executes righteous acts, and justice for all who are oppressed.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 7,
      "referenceLabel": "Psalms 103:7",
      "text": "He made known his ways to Moses, his deeds to the children of Israel.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 8,
      "referenceLabel": "Psalms 103:8",
      "text": "Yahweh is merciful and gracious, slow to anger, and abundant in loving kindness.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 9,
      "referenceLabel": "Psalms 103:9",
      "text": "He will not always accuse; neither will he stay angry forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 10,
      "referenceLabel": "Psalms 103:10",
      "text": "He has not dealt with us according to our sins, nor repaid us for our iniquities.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 11,
      "referenceLabel": "Psalms 103:11",
      "text": "For as the heavens are high above the earth, so great is his loving kindness toward those who fear him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 12,
      "referenceLabel": "Psalms 103:12",
      "text": "As far as the east is from the west, so far has he removed our transgressions from us.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 13,
      "referenceLabel": "Psalms 103:13",
      "text": "Like a father has compassion on his children, so Yahweh has compassion on those who fear him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 14,
      "referenceLabel": "Psalms 103:14",
      "text": "For he knows how we are made. He remembers that we are dust.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 15,
      "referenceLabel": "Psalms 103:15",
      "text": "As for man, his days are like grass. As a flower of the field, so he flourishes.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 16,
      "referenceLabel": "Psalms 103:16",
      "text": "For the wind passes over it, and it is gone. Its place remembers it no more.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 17,
      "referenceLabel": "Psalms 103:17",
      "text": "But Yahweh’s loving kindness is from everlasting to everlasting with those who fear him, his righteousness to children’s children,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 18,
      "referenceLabel": "Psalms 103:18",
      "text": "to those who keep his covenant, to those who remember to obey his precepts.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 19,
      "referenceLabel": "Psalms 103:19",
      "text": "Yahweh has established his throne in the heavens. His kingdom rules over all.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 20,
      "referenceLabel": "Psalms 103:20",
      "text": "Praise Yahweh, you angels of his, who are mighty in strength, who fulfill his word, obeying the voice of his word.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 21,
      "referenceLabel": "Psalms 103:21",
      "text": "Praise Yahweh, all you armies of his, you servants of his, who do his pleasure.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.103.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 22,
      "referenceLabel": "Psalms 103:22",
      "text": "Praise Yahweh, all you works of his, in all places of his dominion. Praise Yahweh, my soul!",
      "paragraphStart": false
    }
  ]
}
