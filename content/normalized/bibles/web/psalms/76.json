{
  "chapter": {
    "id": "web:psalms.76",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 76,
    "referenceLabel": "Psalms 76",
    "summary": "Source text for Psalms 76 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.76.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 1,
      "referenceLabel": "Psalms 76:1",
      "text": "In Judah, God is known. His name is great in Israel.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.76.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 2,
      "referenceLabel": "Psalms 76:2",
      "text": "His tabernacle is also in Salem. His dwelling place in Zion.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.76.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 3,
      "referenceLabel": "Psalms 76:3",
      "text": "There he broke the flaming arrows of the bow, the shield, and the sword, and the weapons of war. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.76.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 4,
      "referenceLabel": "Psalms 76:4",
      "text": "Glorious are you, and excellent, more than mountains of game.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.76.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 5,
      "referenceLabel": "Psalms 76:5",
      "text": "Valiant men lie plundered, they have slept their last sleep. None of the men of war can lift their hands.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.76.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 6,
      "referenceLabel": "Psalms 76:6",
      "text": "At your rebuke, God of Jacob, both chariot and horse are cast into a dead sleep.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.76.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 7,
      "referenceLabel": "Psalms 76:7",
      "text": "You, even you, are to be feared. Who can stand in your sight when you are angry?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.76.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 8,
      "referenceLabel": "Psalms 76:8",
      "text": "You pronounced judgment from heaven. The earth feared, and was silent,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.76.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 9,
      "referenceLabel": "Psalms 76:9",
      "text": "when God arose to judgment, to save all the afflicted ones of the earth. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.76.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 10,
      "referenceLabel": "Psalms 76:10",
      "text": "Surely the wrath of man praises you. The survivors of your wrath are restrained.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.76.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 11,
      "referenceLabel": "Psalms 76:11",
      "text": "Make vows to Yahweh your God, and fulfill them! Let all of his neighbors bring presents to him who is to be feared.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.76.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 12,
      "referenceLabel": "Psalms 76:12",
      "text": "He will cut off the spirit of princes. He is feared by the kings of the earth.",
      "paragraphStart": false
    }
  ]
}
