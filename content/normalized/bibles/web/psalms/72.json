{
  "chapter": {
    "id": "web:psalms.72",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 72,
    "referenceLabel": "Psalms 72",
    "summary": "Source text for Psalms 72 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.72.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 1,
      "referenceLabel": "Psalms 72:1",
      "text": "God, give the king your justice; your righteousness to the royal son.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.72.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 2,
      "referenceLabel": "Psalms 72:2",
      "text": "He will judge your people with righteousness, and your poor with justice.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.72.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 3,
      "referenceLabel": "Psalms 72:3",
      "text": "The mountains shall bring prosperity to the people. The hills bring the fruit of righteousness.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.72.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 4,
      "referenceLabel": "Psalms 72:4",
      "text": "He will judge the poor of the people. He will save the children of the needy, and will break the oppressor in pieces.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.72.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 5,
      "referenceLabel": "Psalms 72:5",
      "text": "They shall fear you while the sun endures; and as long as the moon, throughout all generations.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.72.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 6,
      "referenceLabel": "Psalms 72:6",
      "text": "He will come down like rain on the mown grass, as showers that water the earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.72.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 7,
      "referenceLabel": "Psalms 72:7",
      "text": "In his days, the righteous shall flourish, and abundance of peace, until the moon is no more.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.72.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 8,
      "referenceLabel": "Psalms 72:8",
      "text": "He shall have dominion also from sea to sea, from the River to the ends of the earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.72.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 9,
      "referenceLabel": "Psalms 72:9",
      "text": "Those who dwell in the wilderness shall bow before him. His enemies shall lick the dust.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.72.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 10,
      "referenceLabel": "Psalms 72:10",
      "text": "The kings of Tarshish and of the islands will bring tribute. The kings of Sheba and Seba shall offer gifts.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.72.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 11,
      "referenceLabel": "Psalms 72:11",
      "text": "Yes, all kings shall fall down before him. All nations shall serve him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.72.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 12,
      "referenceLabel": "Psalms 72:12",
      "text": "For he will deliver the needy when he cries; the poor, who has no helper.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.72.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 13,
      "referenceLabel": "Psalms 72:13",
      "text": "He will have pity on the poor and needy. He will save the souls of the needy.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.72.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 14,
      "referenceLabel": "Psalms 72:14",
      "text": "He will redeem their soul from oppression and violence. Their blood will be precious in his sight.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.72.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 15,
      "referenceLabel": "Psalms 72:15",
      "text": "He will live; and Sheba ’s gold will be given to him. Men will pray for him continually. They will bless him all day long.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.72.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 16,
      "referenceLabel": "Psalms 72:16",
      "text": "Abundance of grain shall be throughout the land. Its fruit sways like Lebanon. Let it flourish, thriving like the grass of the field.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.72.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 17,
      "referenceLabel": "Psalms 72:17",
      "text": "His name endures forever. His name continues as long as the sun. Men shall be blessed by him. All nations will call him blessed.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.72.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 18,
      "referenceLabel": "Psalms 72:18",
      "text": "Praise be to Yahweh God, the God of Israel, who alone does marvelous deeds.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.72.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 19,
      "referenceLabel": "Psalms 72:19",
      "text": "Blessed be his glorious name forever! Let the whole earth be filled with his glory! Amen and amen.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.72.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 20,
      "referenceLabel": "Psalms 72:20",
      "text": "This ends the prayers by David, the son of Jesse.",
      "paragraphStart": false
    }
  ]
}
