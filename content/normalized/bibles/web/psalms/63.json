{
  "chapter": {
    "id": "web:psalms.63",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 63,
    "referenceLabel": "Psalms 63",
    "summary": "Source text for Psalms 63 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.63.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 1,
      "referenceLabel": "Psalms 63:1",
      "text": "God, you are my God. I will earnestly seek you. My soul thirsts for you. My flesh longs for you, in a dry and weary land, where there is no water.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.63.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 2,
      "referenceLabel": "Psalms 63:2",
      "text": "So I have seen you in the sanctuary, watching your power and your glory.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.63.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 3,
      "referenceLabel": "Psalms 63:3",
      "text": "Because your loving kindness is better than life, my lips shall praise you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.63.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 4,
      "referenceLabel": "Psalms 63:4",
      "text": "So I will bless you while I live. I will lift up my hands in your name.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.63.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 5,
      "referenceLabel": "Psalms 63:5",
      "text": "My soul shall be satisfied as with the richest food. My mouth shall praise you with joyful lips,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.63.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 6,
      "referenceLabel": "Psalms 63:6",
      "text": "when I remember you on my bed, and think about you in the night watches.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.63.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 7,
      "referenceLabel": "Psalms 63:7",
      "text": "For you have been my help. I will rejoice in the shadow of your wings.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.63.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 8,
      "referenceLabel": "Psalms 63:8",
      "text": "My soul stays close to you. Your right hand holds me up.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.63.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 9,
      "referenceLabel": "Psalms 63:9",
      "text": "But those who seek my soul to destroy it shall go into the lower parts of the earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.63.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 10,
      "referenceLabel": "Psalms 63:10",
      "text": "They shall be given over to the power of the sword. They shall be jackal food.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.63.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 11,
      "referenceLabel": "Psalms 63:11",
      "text": "But the king shall rejoice in God. Everyone who swears by him will praise him, for the mouth of those who speak lies shall be silenced.",
      "paragraphStart": false
    }
  ]
}
