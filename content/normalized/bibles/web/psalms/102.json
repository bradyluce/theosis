{
  "chapter": {
    "id": "web:psalms.102",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 102,
    "referenceLabel": "Psalms 102",
    "summary": "Source text for Psalms 102 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.102.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 1,
      "referenceLabel": "Psalms 102:1",
      "text": "Hear my prayer, Yahweh! Let my cry come to you.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.102.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 2,
      "referenceLabel": "Psalms 102:2",
      "text": "Don’t hide your face from me in the day of my distress. Turn your ear to me. Answer me quickly in the day when I call.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 3,
      "referenceLabel": "Psalms 102:3",
      "text": "For my days consume away like smoke. My bones are burned as a torch.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 4,
      "referenceLabel": "Psalms 102:4",
      "text": "My heart is blighted like grass, and withered, for I forget to eat my bread.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 5,
      "referenceLabel": "Psalms 102:5",
      "text": "By reason of the voice of my groaning, my bones stick to my skin.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 6,
      "referenceLabel": "Psalms 102:6",
      "text": "I am like a pelican of the wilderness. I have become as an owl of the waste places.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 7,
      "referenceLabel": "Psalms 102:7",
      "text": "I watch, and have become like a sparrow that is alone on the housetop.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 8,
      "referenceLabel": "Psalms 102:8",
      "text": "My enemies reproach me all day. Those who are mad at me use my name as a curse.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 9,
      "referenceLabel": "Psalms 102:9",
      "text": "For I have eaten ashes like bread, and mixed my drink with tears,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 10,
      "referenceLabel": "Psalms 102:10",
      "text": "because of your indignation and your wrath; for you have taken me up and thrown me away.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 11,
      "referenceLabel": "Psalms 102:11",
      "text": "My days are like a long shadow. I have withered like grass.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 12,
      "referenceLabel": "Psalms 102:12",
      "text": "But you, Yahweh, will remain forever; your renown endures to all generations.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 13,
      "referenceLabel": "Psalms 102:13",
      "text": "You will arise and have mercy on Zion, for it is time to have pity on her. Yes, the set time has come.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 14,
      "referenceLabel": "Psalms 102:14",
      "text": "For your servants take pleasure in her stones, and have pity on her dust.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 15,
      "referenceLabel": "Psalms 102:15",
      "text": "So the nations will fear Yahweh ’s name, all the kings of the earth your glory.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 16,
      "referenceLabel": "Psalms 102:16",
      "text": "For Yahweh has built up Zion. He has appeared in his glory.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 17,
      "referenceLabel": "Psalms 102:17",
      "text": "He has responded to the prayer of the destitute, and has not despised their prayer.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 18,
      "referenceLabel": "Psalms 102:18",
      "text": "This will be written for the generation to come. A people which will be created will praise Yah,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 19,
      "referenceLabel": "Psalms 102:19",
      "text": "for he has looked down from the height of his sanctuary. From heaven, Yahweh saw the earth,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 20,
      "referenceLabel": "Psalms 102:20",
      "text": "to hear the groans of the prisoner, to free those who are condemned to death,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 21,
      "referenceLabel": "Psalms 102:21",
      "text": "that men may declare Yahweh ’s name in Zion, and his praise in Jerusalem,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 22,
      "referenceLabel": "Psalms 102:22",
      "text": "when the peoples are gathered together, the kingdoms, to serve Yahweh.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.23",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 23,
      "referenceLabel": "Psalms 102:23",
      "text": "He weakened my strength along the course. He shortened my days.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.24",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 24,
      "referenceLabel": "Psalms 102:24",
      "text": "I said, “ My God, don’t take me away in the middle of my days. Your years are throughout all generations.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.25",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 25,
      "referenceLabel": "Psalms 102:25",
      "text": "Of old, you laid the foundation of the earth. The heavens are the work of your hands.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.26",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 26,
      "referenceLabel": "Psalms 102:26",
      "text": "They will perish, but you will endure. Yes, all of them will wear out like a garment. You will change them like a cloak, and they will be changed.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.27",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 27,
      "referenceLabel": "Psalms 102:27",
      "text": "But you are the same. Your years will have no end.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.102.28",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 28,
      "referenceLabel": "Psalms 102:28",
      "text": "The children of your servants will continue. Their offspring will be established before you.”",
      "paragraphStart": false
    }
  ]
}
