{
  "chapter": {
    "id": "web:psalms.50",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 50,
    "referenceLabel": "Psalms 50",
    "summary": "Source text for Psalms 50 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.50.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 1,
      "referenceLabel": "Psalms 50:1",
      "text": "The Mighty One, God, Yahweh, speaks, and calls the earth from sunrise to sunset.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.50.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 2,
      "referenceLabel": "Psalms 50:2",
      "text": "Out of Zion, the perfection of beauty, God shines out.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 3,
      "referenceLabel": "Psalms 50:3",
      "text": "Our God comes, and does not keep silent. A fire devours before him. It is very stormy around him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 4,
      "referenceLabel": "Psalms 50:4",
      "text": "He calls to the heavens above, to the earth, that he may judge his people:",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 5,
      "referenceLabel": "Psalms 50:5",
      "text": "“Gather my saints together to me, those who have made a covenant with me by sacrifice.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 6,
      "referenceLabel": "Psalms 50:6",
      "text": "The heavens shall declare his righteousness, for God himself is judge. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 7,
      "referenceLabel": "Psalms 50:7",
      "text": "“Hear, my people, and I will speak. Israel, I will testify against you. I am God, your God.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 8,
      "referenceLabel": "Psalms 50:8",
      "text": "I don’t rebuke you for your sacrifices. Your burnt offerings are continually before me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 9,
      "referenceLabel": "Psalms 50:9",
      "text": "I have no need for a bull from your stall, nor male goats from your pens.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 10,
      "referenceLabel": "Psalms 50:10",
      "text": "For every animal of the forest is mine, and the livestock on a thousand hills.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 11,
      "referenceLabel": "Psalms 50:11",
      "text": "I know all the birds of the mountains. The wild animals of the field are mine.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 12,
      "referenceLabel": "Psalms 50:12",
      "text": "If I were hungry, I would not tell you, for the world is mine, and all that is in it.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 13,
      "referenceLabel": "Psalms 50:13",
      "text": "Will I eat the meat of bulls, or drink the blood of goats?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 14,
      "referenceLabel": "Psalms 50:14",
      "text": "Offer to God the sacrifice of thanksgiving. Pay your vows to the Most High.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 15,
      "referenceLabel": "Psalms 50:15",
      "text": "Call on me in the day of trouble. I will deliver you, and you will honor me.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 16,
      "referenceLabel": "Psalms 50:16",
      "text": "But to the wicked God says, “What right do you have to declare my statutes, that you have taken my covenant on your lips,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 17,
      "referenceLabel": "Psalms 50:17",
      "text": "since you hate instruction, and throw my words behind you?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 18,
      "referenceLabel": "Psalms 50:18",
      "text": "When you saw a thief, you consented with him, and have participated with adulterers.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 19,
      "referenceLabel": "Psalms 50:19",
      "text": "“You give your mouth to evil. Your tongue frames deceit.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 20,
      "referenceLabel": "Psalms 50:20",
      "text": "You sit and speak against your brother. You slander your own mother’s son.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 21,
      "referenceLabel": "Psalms 50:21",
      "text": "You have done these things, and I kept silent. You thought that I was just like you. I will rebuke you, and accuse you in front of your eyes.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 22,
      "referenceLabel": "Psalms 50:22",
      "text": "“Now consider this, you who forget God, lest I tear you into pieces, and there be no one to deliver.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.50.23",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 23,
      "referenceLabel": "Psalms 50:23",
      "text": "Whoever offers the sacrifice of thanksgiving glorifies me, and prepares his way so that I will show God’s salvation to him.”",
      "paragraphStart": false
    }
  ]
}
