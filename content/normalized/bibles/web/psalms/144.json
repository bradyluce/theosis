{
  "chapter": {
    "id": "web:psalms.144",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 144,
    "referenceLabel": "Psalms 144",
    "summary": "Source text for Psalms 144 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.144.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 1,
      "referenceLabel": "Psalms 144:1",
      "text": "Blessed be Yahweh, my rock, who trains my hands to war, and my fingers to battle —",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.144.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 2,
      "referenceLabel": "Psalms 144:2",
      "text": "my loving kindness, my fortress, my high tower, my deliverer, my shield, and he in whom I take refuge, who subdues my people under me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.144.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 3,
      "referenceLabel": "Psalms 144:3",
      "text": "Yahweh, what is man, that you care for him? Or the son of man, that you think of him?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.144.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 4,
      "referenceLabel": "Psalms 144:4",
      "text": "Man is like a breath. His days are like a shadow that passes away.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.144.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 5,
      "referenceLabel": "Psalms 144:5",
      "text": "Part your heavens, Yahweh, and come down. Touch the mountains, and they will smoke.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.144.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 6,
      "referenceLabel": "Psalms 144:6",
      "text": "Throw out lightning, and scatter them. Send out your arrows, and rout them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.144.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 7,
      "referenceLabel": "Psalms 144:7",
      "text": "Stretch out your hand from above, rescue me, and deliver me out of great waters, out of the hands of foreigners,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.144.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 8,
      "referenceLabel": "Psalms 144:8",
      "text": "whose mouths speak deceit, whose right hand is a right hand of falsehood.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.144.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 9,
      "referenceLabel": "Psalms 144:9",
      "text": "I will sing a new song to you, God. On a ten-stringed lyre, I will sing praises to you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.144.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 10,
      "referenceLabel": "Psalms 144:10",
      "text": "You are he who gives salvation to kings, who rescues David, his servant, from the deadly sword.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.144.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 11,
      "referenceLabel": "Psalms 144:11",
      "text": "Rescue me, and deliver me out of the hands of foreigners, whose mouths speak deceit, whose right hand is a right hand of falsehood.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.144.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 12,
      "referenceLabel": "Psalms 144:12",
      "text": "Then our sons will be like well-nurtured plants, our daughters like pillars carved to adorn a palace.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.144.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 13,
      "referenceLabel": "Psalms 144:13",
      "text": "Our barns are full, filled with all kinds of provision. Our sheep produce thousands and ten thousands in our fields.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.144.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 14,
      "referenceLabel": "Psalms 144:14",
      "text": "Our oxen will pull heavy loads. There is no breaking in, and no going away, and no outcry in our streets.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.144.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 15,
      "referenceLabel": "Psalms 144:15",
      "text": "Happy are the people who are in such a situation. Happy are the people whose God is Yahweh.",
      "paragraphStart": false
    }
  ]
}
