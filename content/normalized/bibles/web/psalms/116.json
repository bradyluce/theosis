{
  "chapter": {
    "id": "web:psalms.116",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 116,
    "referenceLabel": "Psalms 116",
    "summary": "Source text for Psalms 116 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.116.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 1,
      "referenceLabel": "Psalms 116:1",
      "text": "I love Yahweh, because he listens to my voice, and my cries for mercy.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.116.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 2,
      "referenceLabel": "Psalms 116:2",
      "text": "Because he has turned his ear to me, therefore I will call on him as long as I live.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.116.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 3,
      "referenceLabel": "Psalms 116:3",
      "text": "The cords of death surrounded me, the pains of Sheol got a hold of me. I found trouble and sorrow.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.116.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 4,
      "referenceLabel": "Psalms 116:4",
      "text": "Then I called on Yahweh ’s name: “ Yahweh, I beg you, deliver my soul.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.116.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 5,
      "referenceLabel": "Psalms 116:5",
      "text": "Yahweh is gracious and righteous. Yes, our God is merciful.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.116.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 6,
      "referenceLabel": "Psalms 116:6",
      "text": "Yahweh preserves the simple. I was brought low, and he saved me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.116.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 7,
      "referenceLabel": "Psalms 116:7",
      "text": "Return to your rest, my soul, for Yahweh has dealt bountifully with you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.116.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 8,
      "referenceLabel": "Psalms 116:8",
      "text": "For you have delivered my soul from death, my eyes from tears, and my feet from falling.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.116.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 9,
      "referenceLabel": "Psalms 116:9",
      "text": "I will walk before Yahweh in the land of the living.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.116.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 10,
      "referenceLabel": "Psalms 116:10",
      "text": "I believed, therefore I said, “ I was greatly afflicted.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.116.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 11,
      "referenceLabel": "Psalms 116:11",
      "text": "I said in my haste, “ All people are liars.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.116.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 12,
      "referenceLabel": "Psalms 116:12",
      "text": "What will I give to Yahweh for all his benefits toward me?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.116.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 13,
      "referenceLabel": "Psalms 116:13",
      "text": "I will take the cup of salvation, and call on Yahweh ’s name.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.116.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 14,
      "referenceLabel": "Psalms 116:14",
      "text": "I will pay my vows to Yahweh, yes, in the presence of all his people.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.116.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 15,
      "referenceLabel": "Psalms 116:15",
      "text": "Precious in Yahweh ’s sight is the death of his saints.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.116.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 16,
      "referenceLabel": "Psalms 116:16",
      "text": "Yahweh, truly I am your servant. I am your servant, the son of your servant girl. You have freed me from my chains.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.116.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 17,
      "referenceLabel": "Psalms 116:17",
      "text": "I will offer to you the sacrifice of thanksgiving, and will call on Yahweh ’s name.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.116.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 18,
      "referenceLabel": "Psalms 116:18",
      "text": "I will pay my vows to Yahweh, yes, in the presence of all his people,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.116.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 19,
      "referenceLabel": "Psalms 116:19",
      "text": "in the courts of Yahweh ’s house, in the middle of you, Jerusalem. Praise Yah!",
      "paragraphStart": false
    }
  ]
}
