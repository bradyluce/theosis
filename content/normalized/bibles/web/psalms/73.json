{
  "chapter": {
    "id": "web:psalms.73",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 73,
    "referenceLabel": "Psalms 73",
    "summary": "Source text for Psalms 73 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.73.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 1,
      "referenceLabel": "Psalms 73:1",
      "text": "Surely God is good to Israel, to those who are pure in heart.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.73.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 2,
      "referenceLabel": "Psalms 73:2",
      "text": "But as for me, my feet were almost gone. My steps had nearly slipped.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 3,
      "referenceLabel": "Psalms 73:3",
      "text": "For I was envious of the arrogant, when I saw the prosperity of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 4,
      "referenceLabel": "Psalms 73:4",
      "text": "For there are no struggles in their death, but their strength is firm.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 5,
      "referenceLabel": "Psalms 73:5",
      "text": "They are free from burdens of men, neither are they plagued like other men.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 6,
      "referenceLabel": "Psalms 73:6",
      "text": "Therefore pride is like a chain around their neck. Violence covers them like a garment.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 7,
      "referenceLabel": "Psalms 73:7",
      "text": "Their eyes bulge with fat. Their minds pass the limits of conceit.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 8,
      "referenceLabel": "Psalms 73:8",
      "text": "They scoff and speak with malice. In arrogance, they threaten oppression.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 9,
      "referenceLabel": "Psalms 73:9",
      "text": "They have set their mouth in the heavens. Their tongue walks through the earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 10,
      "referenceLabel": "Psalms 73:10",
      "text": "Therefore their people return to them, and they drink up waters of abundance.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 11,
      "referenceLabel": "Psalms 73:11",
      "text": "They say, “How does God know? Is there knowledge in the Most High?”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 12,
      "referenceLabel": "Psalms 73:12",
      "text": "Behold, these are the wicked. Being always at ease, they increase in riches.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 13,
      "referenceLabel": "Psalms 73:13",
      "text": "Surely I have cleansed my heart in vain, and washed my hands in innocence,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 14,
      "referenceLabel": "Psalms 73:14",
      "text": "For all day long I have been plagued, and punished every morning.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 15,
      "referenceLabel": "Psalms 73:15",
      "text": "If I had said, “I will speak thus”, behold, I would have betrayed the generation of your children.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 16,
      "referenceLabel": "Psalms 73:16",
      "text": "When I tried to understand this, it was too painful for me —",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 17,
      "referenceLabel": "Psalms 73:17",
      "text": "until I entered God’s sanctuary, and considered their latter end.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 18,
      "referenceLabel": "Psalms 73:18",
      "text": "Surely you set them in slippery places. You throw them down to destruction.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 19,
      "referenceLabel": "Psalms 73:19",
      "text": "How they are suddenly destroyed! They are completely swept away with terrors.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 20,
      "referenceLabel": "Psalms 73:20",
      "text": "As a dream when one wakes up, so, Lord, when you awake, you will despise their fantasies.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 21,
      "referenceLabel": "Psalms 73:21",
      "text": "For my soul was grieved. I was embittered in my heart.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 22,
      "referenceLabel": "Psalms 73:22",
      "text": "I was so senseless and ignorant. I was a brute beast before you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.23",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 23,
      "referenceLabel": "Psalms 73:23",
      "text": "Nevertheless, I am continually with you. You have held my right hand.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.24",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 24,
      "referenceLabel": "Psalms 73:24",
      "text": "You will guide me with your counsel, and afterward receive me to glory.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.25",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 25,
      "referenceLabel": "Psalms 73:25",
      "text": "Whom do I have in heaven? There is no one on earth whom I desire besides you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.26",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 26,
      "referenceLabel": "Psalms 73:26",
      "text": "My flesh and my heart fails, but God is the strength of my heart and my portion forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.27",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 27,
      "referenceLabel": "Psalms 73:27",
      "text": "For, behold, those who are far from you shall perish. You have destroyed all those who are unfaithful to you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.73.28",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 28,
      "referenceLabel": "Psalms 73:28",
      "text": "But it is good for me to come close to God. I have made the Lord Yahweh my refuge, that I may tell of all your works.",
      "paragraphStart": false
    }
  ]
}
