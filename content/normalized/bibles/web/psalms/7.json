{
  "chapter": {
    "id": "web:psalms.7",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 7,
    "referenceLabel": "Psalms 7",
    "summary": "Source text for Psalms 7 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.7.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Psalms 7:1",
      "text": "Yahweh, my God, I take refuge in you. Save me from all those who pursue me, and deliver me,",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.7.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Psalms 7:2",
      "text": "lest they tear apart my soul like a lion, ripping it in pieces, while there is no one to deliver.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.7.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Psalms 7:3",
      "text": "Yahweh, my God, if I have done this, if there is iniquity in my hands,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.7.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Psalms 7:4",
      "text": "if I have rewarded evil to him who was at peace with me (yes, I have plundered him who without cause was my adversary),",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.7.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Psalms 7:5",
      "text": "let the enemy pursue my soul, and overtake it; yes, let him tread my life down to the earth, and lay my glory in the dust. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.7.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Psalms 7:6",
      "text": "Arise, Yahweh, in your anger. Lift up yourself against the rage of my adversaries. Awake for me. You have commanded judgment.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.7.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Psalms 7:7",
      "text": "Let the congregation of the peoples surround you. Rule over them on high.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.7.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Psalms 7:8",
      "text": "Yahweh administers judgment to the peoples. Judge me, Yahweh, according to my righteousness, and to my integrity that is in me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.7.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Psalms 7:9",
      "text": "Oh let the wickedness of the wicked come to an end, but establish the righteous; their minds and hearts are searched by the righteous God.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.7.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Psalms 7:10",
      "text": "My shield is with God, who saves the upright in heart.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.7.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Psalms 7:11",
      "text": "God is a righteous judge, yes, a God who has indignation every day.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.7.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Psalms 7:12",
      "text": "If a man doesn’t repent, he will sharpen his sword; he has bent and strung his bow.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.7.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Psalms 7:13",
      "text": "He has also prepared for himself the instruments of death. He makes ready his flaming arrows.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.7.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Psalms 7:14",
      "text": "Behold, he travails with iniquity. Yes, he has conceived mischief, and brought out falsehood.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.7.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Psalms 7:15",
      "text": "He has dug a hole, and has fallen into the pit which he made.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.7.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Psalms 7:16",
      "text": "The trouble he causes shall return to his own head. His violence shall come down on the crown of his own head.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.7.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Psalms 7:17",
      "text": "I will give thanks to Yahweh according to his righteousness, and will sing praise to the name of Yahweh Most High.",
      "paragraphStart": false
    }
  ]
}
