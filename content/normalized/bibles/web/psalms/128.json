{
  "chapter": {
    "id": "web:psalms.128",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 128,
    "referenceLabel": "Psalms 128",
    "summary": "Source text for Psalms 128 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.128.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 1,
      "referenceLabel": "Psalms 128:1",
      "text": "Blessed is everyone who fears Yahweh, who walks in his ways.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.128.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 2,
      "referenceLabel": "Psalms 128:2",
      "text": "For you will eat the labor of your hands. You will be happy, and it will be well with you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.128.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 3,
      "referenceLabel": "Psalms 128:3",
      "text": "Your wife will be as a fruitful vine in the innermost parts of your house, your children like olive shoots around your table.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.128.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 4,
      "referenceLabel": "Psalms 128:4",
      "text": "Behold, this is how the man who fears Yahweh is blessed.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.128.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 5,
      "referenceLabel": "Psalms 128:5",
      "text": "May Yahweh bless you out of Zion, and may you see the good of Jerusalem all the days of your life.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.128.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 6,
      "referenceLabel": "Psalms 128:6",
      "text": "Yes, may you see your children’s children. Peace be upon Israel.",
      "paragraphStart": false
    }
  ]
}
