{
  "chapter": {
    "id": "web:psalms.148",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 148,
    "referenceLabel": "Psalms 148",
    "summary": "Source text for Psalms 148 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.148.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 1,
      "referenceLabel": "Psalms 148:1",
      "text": "Praise Yah! Praise Yahweh from the heavens! Praise him in the heights!",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.148.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 2,
      "referenceLabel": "Psalms 148:2",
      "text": "Praise him, all his angels! Praise him, all his army!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.148.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 3,
      "referenceLabel": "Psalms 148:3",
      "text": "Praise him, sun and moon! Praise him, all you shining stars!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.148.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 4,
      "referenceLabel": "Psalms 148:4",
      "text": "Praise him, you heavens of heavens, you waters that are above the heavens.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.148.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 5,
      "referenceLabel": "Psalms 148:5",
      "text": "Let them praise Yahweh ’s name, for he commanded, and they were created.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.148.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 6,
      "referenceLabel": "Psalms 148:6",
      "text": "He has also established them forever and ever. He has made a decree which will not pass away.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.148.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 7,
      "referenceLabel": "Psalms 148:7",
      "text": "Praise Yahweh from the earth, you great sea creatures, and all depths,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.148.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 8,
      "referenceLabel": "Psalms 148:8",
      "text": "lightning and hail, snow and clouds, stormy wind, fulfilling his word,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.148.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 9,
      "referenceLabel": "Psalms 148:9",
      "text": "mountains and all hills, fruit trees and all cedars,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.148.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 10,
      "referenceLabel": "Psalms 148:10",
      "text": "wild animals and all livestock, small creatures and flying birds,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.148.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 11,
      "referenceLabel": "Psalms 148:11",
      "text": "kings of the earth and all peoples, princes and all judges of the earth,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.148.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 12,
      "referenceLabel": "Psalms 148:12",
      "text": "both young men and maidens, old men and children.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.148.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 13,
      "referenceLabel": "Psalms 148:13",
      "text": "Let them praise Yahweh ’s name, for his name alone is exalted. His glory is above the earth and the heavens.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.148.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 14,
      "referenceLabel": "Psalms 148:14",
      "text": "He has lifted up the horn of his people, the praise of all his saints, even of the children of Israel, a people near to him. Praise Yah!",
      "paragraphStart": false
    }
  ]
}
