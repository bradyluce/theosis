{
  "chapter": {
    "id": "web:psalms.68",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 68,
    "referenceLabel": "Psalms 68",
    "summary": "Source text for Psalms 68 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.68.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 1,
      "referenceLabel": "Psalms 68:1",
      "text": "Let God arise! Let his enemies be scattered! Let them who hate him also flee before him.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.68.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 2,
      "referenceLabel": "Psalms 68:2",
      "text": "As smoke is driven away, so drive them away. As wax melts before the fire, so let the wicked perish at the presence of God.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 3,
      "referenceLabel": "Psalms 68:3",
      "text": "But let the righteous be glad. Let them rejoice before God. Yes, let them rejoice with gladness.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 4,
      "referenceLabel": "Psalms 68:4",
      "text": "Sing to God! Sing praises to his name! Extol him who rides on the clouds: to Yah, his name! Rejoice before him!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 5,
      "referenceLabel": "Psalms 68:5",
      "text": "A father of the fatherless, and a defender of the widows, is God in his holy habitation.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 6,
      "referenceLabel": "Psalms 68:6",
      "text": "God sets the lonely in families. He brings out the prisoners with singing, but the rebellious dwell in a sun-scorched land.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 7,
      "referenceLabel": "Psalms 68:7",
      "text": "God, when you went out before your people, when you marched through the wilderness... Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 8,
      "referenceLabel": "Psalms 68:8",
      "text": "The earth trembled. The sky also poured down rain at the presence of the God of Sinai— at the presence of God, the God of Israel.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 9,
      "referenceLabel": "Psalms 68:9",
      "text": "You, God, sent a plentiful rain. You confirmed your inheritance when it was weary.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 10,
      "referenceLabel": "Psalms 68:10",
      "text": "Your congregation lived therein. You, God, prepared your goodness for the poor.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 11,
      "referenceLabel": "Psalms 68:11",
      "text": "The Lord announced the word. The ones who proclaim it are a great company.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 12,
      "referenceLabel": "Psalms 68:12",
      "text": "“Kings of armies flee! They flee!” She who waits at home divides the plunder,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 13,
      "referenceLabel": "Psalms 68:13",
      "text": "while you sleep among the camp fires, the wings of a dove sheathed with silver, her feathers with shining gold.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 14,
      "referenceLabel": "Psalms 68:14",
      "text": "When the Almighty scattered kings in her, it snowed on Zalmon.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 15,
      "referenceLabel": "Psalms 68:15",
      "text": "The mountains of Bashan are majestic mountains. The mountains of Bashan are rugged.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 16,
      "referenceLabel": "Psalms 68:16",
      "text": "Why do you look in envy, you rugged mountains, at the mountain where God chooses to reign? Yes, Yahweh will dwell there forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 17,
      "referenceLabel": "Psalms 68:17",
      "text": "The chariots of God are tens of thousands and thousands of thousands. The Lord is among them, from Sinai, into the sanctuary.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 18,
      "referenceLabel": "Psalms 68:18",
      "text": "You have ascended on high. You have led away captives. You have received gifts among people, yes, among the rebellious also, that Yah God might dwell there.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 19,
      "referenceLabel": "Psalms 68:19",
      "text": "Blessed be the Lord, who daily bears our burdens, even the God who is our salvation. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 20,
      "referenceLabel": "Psalms 68:20",
      "text": "God is to us a God of deliverance. To Yahweh, the Lord, belongs escape from death.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 21,
      "referenceLabel": "Psalms 68:21",
      "text": "But God will strike through the head of his enemies, the hairy scalp of such a one as still continues in his guiltiness.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 22,
      "referenceLabel": "Psalms 68:22",
      "text": "The Lord said, “I will bring you again from Bashan, I will bring you again from the depths of the sea,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.23",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 23,
      "referenceLabel": "Psalms 68:23",
      "text": "that you may crush them, dipping your foot in blood, that the tongues of your dogs may have their portion from your enemies.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.24",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 24,
      "referenceLabel": "Psalms 68:24",
      "text": "They have seen your processions, God, even the processions of my God, my King, into the sanctuary.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.25",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 25,
      "referenceLabel": "Psalms 68:25",
      "text": "The singers went before, the minstrels followed after, among the ladies playing with tambourines,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.26",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 26,
      "referenceLabel": "Psalms 68:26",
      "text": "“Bless God in the congregations, even the Lord in the assembly of Israel!”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.27",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 27,
      "referenceLabel": "Psalms 68:27",
      "text": "There is little Benjamin, their ruler, the princes of Judah, their council, the princes of Zebulun, and the princes of Naphtali.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.28",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 28,
      "referenceLabel": "Psalms 68:28",
      "text": "Your God has commanded your strength. Strengthen, God, that which you have done for us.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.29",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 29,
      "referenceLabel": "Psalms 68:29",
      "text": "Because of your temple at Jerusalem, kings shall bring presents to you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.30",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 30,
      "referenceLabel": "Psalms 68:30",
      "text": "Rebuke the wild animal of the reeds, the multitude of the bulls with the calves of the peoples. Trample under foot the bars of silver. Scatter the nations who delight in war.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.31",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 31,
      "referenceLabel": "Psalms 68:31",
      "text": "Princes shall come out of Egypt. Ethiopia shall hurry to stretch out her hands to God.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.32",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 32,
      "referenceLabel": "Psalms 68:32",
      "text": "Sing to God, you kingdoms of the earth! Sing praises to the Lord— Selah—",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.33",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 33,
      "referenceLabel": "Psalms 68:33",
      "text": "to him who rides on the heaven of heavens, which are of old; behold, he utters his voice, a mighty voice.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.34",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 34,
      "referenceLabel": "Psalms 68:34",
      "text": "Ascribe strength to God! His excellency is over Israel, his strength is in the skies.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.68.35",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 35,
      "referenceLabel": "Psalms 68:35",
      "text": "You are awesome, God, in your sanctuaries. The God of Israel gives strength and power to his people. Praise be to God!",
      "paragraphStart": false
    }
  ]
}
