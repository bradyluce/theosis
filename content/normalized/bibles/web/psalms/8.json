{
  "chapter": {
    "id": "web:psalms.8",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 8,
    "referenceLabel": "Psalms 8",
    "summary": "Source text for Psalms 8 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.8.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Psalms 8:1",
      "text": "Yahweh, our Lord, how majestic is your name in all the earth! You have set your glory above the heavens!",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.8.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Psalms 8:2",
      "text": "From the lips of babes and infants you have established strength, because of your adversaries, that you might silence the enemy and the avenger.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.8.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Psalms 8:3",
      "text": "When I consider your heavens, the work of your fingers, the moon and the stars, which you have ordained,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.8.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Psalms 8:4",
      "text": "what is man, that you think of him? What is the son of man, that you care for him?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.8.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Psalms 8:5",
      "text": "For you have made him a little lower than the angels, and crowned him with glory and honor.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.8.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Psalms 8:6",
      "text": "You make him ruler over the works of your hands. You have put all things under his feet:",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.8.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Psalms 8:7",
      "text": "All sheep and cattle, yes, and the animals of the field,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.8.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Psalms 8:8",
      "text": "the birds of the sky, the fish of the sea, and whatever passes through the paths of the seas.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.8.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Psalms 8:9",
      "text": "Yahweh, our Lord, how majestic is your name in all the earth!",
      "paragraphStart": false
    }
  ]
}
