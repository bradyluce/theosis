{
  "chapter": {
    "id": "web:psalms.118",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 118,
    "referenceLabel": "Psalms 118",
    "summary": "Source text for Psalms 118 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.118.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 1,
      "referenceLabel": "Psalms 118:1",
      "text": "Give thanks to Yahweh, for he is good, for his loving kindness endures forever.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.118.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 2,
      "referenceLabel": "Psalms 118:2",
      "text": "Let Israel now say that his loving kindness endures forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 3,
      "referenceLabel": "Psalms 118:3",
      "text": "Let the house of Aaron now say that his loving kindness endures forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 4,
      "referenceLabel": "Psalms 118:4",
      "text": "Now let those who fear Yahweh say that his loving kindness endures forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 5,
      "referenceLabel": "Psalms 118:5",
      "text": "Out of my distress, I called on Yah. Yah answered me with freedom.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 6,
      "referenceLabel": "Psalms 118:6",
      "text": "Yahweh is on my side. I will not be afraid. What can man do to me?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 7,
      "referenceLabel": "Psalms 118:7",
      "text": "Yahweh is on my side among those who help me. Therefore I will look in triumph at those who hate me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 8,
      "referenceLabel": "Psalms 118:8",
      "text": "It is better to take refuge in Yahweh, than to put confidence in man.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 9,
      "referenceLabel": "Psalms 118:9",
      "text": "It is better to take refuge in Yahweh, than to put confidence in princes.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 10,
      "referenceLabel": "Psalms 118:10",
      "text": "All the nations surrounded me, but in Yahweh ’s name I cut them off.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 11,
      "referenceLabel": "Psalms 118:11",
      "text": "They surrounded me, yes, they surrounded me. In Yahweh ’s name I indeed cut them off.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 12,
      "referenceLabel": "Psalms 118:12",
      "text": "They surrounded me like bees. They are quenched like the burning thorns. In Yahweh ’s name I cut them off.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 13,
      "referenceLabel": "Psalms 118:13",
      "text": "You pushed me back hard, to make me fall, but Yahweh helped me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 14,
      "referenceLabel": "Psalms 118:14",
      "text": "Yah is my strength and song. He has become my salvation.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 15,
      "referenceLabel": "Psalms 118:15",
      "text": "The voice of rejoicing and salvation is in the tents of the righteous. “ The right hand of Yahweh does valiantly.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 16,
      "referenceLabel": "Psalms 118:16",
      "text": "The right hand of Yahweh is exalted! The right hand of Yahweh does valiantly!”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 17,
      "referenceLabel": "Psalms 118:17",
      "text": "I will not die, but live, and declare Yah ’s works.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 18,
      "referenceLabel": "Psalms 118:18",
      "text": "Yah has punished me severely, but he has not given me over to death.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 19,
      "referenceLabel": "Psalms 118:19",
      "text": "Open to me the gates of righteousness. I will enter into them. I will give thanks to Yah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 20,
      "referenceLabel": "Psalms 118:20",
      "text": "This is the gate of Yahweh; the righteous will enter into it.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 21,
      "referenceLabel": "Psalms 118:21",
      "text": "I will give thanks to you, for you have answered me, and have become my salvation.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 22,
      "referenceLabel": "Psalms 118:22",
      "text": "The stone which the builders rejected has become the cornerstone.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.23",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 23,
      "referenceLabel": "Psalms 118:23",
      "text": "This is Yahweh ’s doing. It is marvelous in our eyes.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.24",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 24,
      "referenceLabel": "Psalms 118:24",
      "text": "This is the day that Yahweh has made. We will rejoice and be glad in it!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.25",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 25,
      "referenceLabel": "Psalms 118:25",
      "text": "Save us now, we beg you, Yahweh! Yahweh, we beg you, send prosperity now.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.26",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 26,
      "referenceLabel": "Psalms 118:26",
      "text": "Blessed is he who comes in Yahweh ’s name! We have blessed you out of Yahweh ’s house.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.27",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 27,
      "referenceLabel": "Psalms 118:27",
      "text": "Yahweh is God, and he has given us light. Bind the sacrifice with cords, even to the horns of the altar.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.28",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 28,
      "referenceLabel": "Psalms 118:28",
      "text": "You are my God, and I will give thanks to you. You are my God, I will exalt you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.118.29",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 29,
      "referenceLabel": "Psalms 118:29",
      "text": "Oh give thanks to Yahweh, for he is good, for his loving kindness endures forever.",
      "paragraphStart": false
    }
  ]
}
