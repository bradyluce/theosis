{
  "chapter": {
    "id": "web:psalms.47",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 47,
    "referenceLabel": "Psalms 47",
    "summary": "Source text for Psalms 47 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.47.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 1,
      "referenceLabel": "Psalms 47:1",
      "text": "Oh clap your hands, all you nations. Shout to God with the voice of triumph!",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.47.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 2,
      "referenceLabel": "Psalms 47:2",
      "text": "For Yahweh Most High is awesome. He is a great King over all the earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.47.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 3,
      "referenceLabel": "Psalms 47:3",
      "text": "He subdues nations under us, and peoples under our feet.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.47.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 4,
      "referenceLabel": "Psalms 47:4",
      "text": "He chooses our inheritance for us, the glory of Jacob whom he loved. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.47.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 5,
      "referenceLabel": "Psalms 47:5",
      "text": "God has gone up with a shout, Yahweh with the sound of a trumpet.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.47.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 6,
      "referenceLabel": "Psalms 47:6",
      "text": "Sing praises to God! Sing praises! Sing praises to our King! Sing praises!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.47.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 7,
      "referenceLabel": "Psalms 47:7",
      "text": "For God is the King of all the earth. Sing praises with understanding.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.47.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 8,
      "referenceLabel": "Psalms 47:8",
      "text": "God reigns over the nations. God sits on his holy throne.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.47.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 9,
      "referenceLabel": "Psalms 47:9",
      "text": "The princes of the peoples are gathered together, the people of the God of Abraham. For the shields of the earth belong to God. He is greatly exalted!",
      "paragraphStart": false
    }
  ]
}
