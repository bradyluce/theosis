{
  "chapter": {
    "id": "web:psalms.77",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 77,
    "referenceLabel": "Psalms 77",
    "summary": "Source text for Psalms 77 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.77.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 1,
      "referenceLabel": "Psalms 77:1",
      "text": "My cry goes to God! Indeed, I cry to God for help, and for him to listen to me.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.77.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 2,
      "referenceLabel": "Psalms 77:2",
      "text": "In the day of my trouble I sought the Lord. My hand was stretched out in the night, and didn’t get tired. My soul refused to be comforted.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.77.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 3,
      "referenceLabel": "Psalms 77:3",
      "text": "I remember God, and I groan. I complain, and my spirit is overwhelmed. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.77.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 4,
      "referenceLabel": "Psalms 77:4",
      "text": "You hold my eyelids open. I am so troubled that I can’t speak.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.77.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 5,
      "referenceLabel": "Psalms 77:5",
      "text": "I have considered the days of old, the years of ancient times.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.77.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 6,
      "referenceLabel": "Psalms 77:6",
      "text": "I remember my song in the night. I consider in my own heart; my spirit diligently inquires:",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.77.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 7,
      "referenceLabel": "Psalms 77:7",
      "text": "“Will the Lord reject us forever? Will he be favorable no more?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.77.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 8,
      "referenceLabel": "Psalms 77:8",
      "text": "Has his loving kindness vanished forever? Does his promise fail for generations?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.77.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 9,
      "referenceLabel": "Psalms 77:9",
      "text": "Has God forgotten to be gracious? Has he, in anger, withheld his compassion?” Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.77.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 10,
      "referenceLabel": "Psalms 77:10",
      "text": "Then I thought, “I will appeal to this: the years of the right hand of the Most High.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.77.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 11,
      "referenceLabel": "Psalms 77:11",
      "text": "I will remember Yah’s deeds; for I will remember your wonders of old.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.77.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 12,
      "referenceLabel": "Psalms 77:12",
      "text": "I will also meditate on all your work, and consider your doings.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.77.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 13,
      "referenceLabel": "Psalms 77:13",
      "text": "Your way, God, is in the sanctuary. What god is great like God?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.77.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 14,
      "referenceLabel": "Psalms 77:14",
      "text": "You are the God who does wonders. You have made your strength known among the peoples.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.77.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 15,
      "referenceLabel": "Psalms 77:15",
      "text": "You have redeemed your people with your arm, the sons of Jacob and Joseph. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.77.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 16,
      "referenceLabel": "Psalms 77:16",
      "text": "The waters saw you, God. The waters saw you, and they writhed. The depths also convulsed.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.77.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 17,
      "referenceLabel": "Psalms 77:17",
      "text": "The clouds poured out water. The skies resounded with thunder. Your arrows also flashed around.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.77.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 18,
      "referenceLabel": "Psalms 77:18",
      "text": "The voice of your thunder was in the whirlwind. The lightnings lit up the world. The earth trembled and shook.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.77.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 19,
      "referenceLabel": "Psalms 77:19",
      "text": "Your way was through the sea, your paths through the great waters. Your footsteps were not known.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.77.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 20,
      "referenceLabel": "Psalms 77:20",
      "text": "You led your people like a flock, by the hand of Moses and Aaron.",
      "paragraphStart": false
    }
  ]
}
