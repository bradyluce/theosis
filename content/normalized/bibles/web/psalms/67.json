  "verses": [
    {
      "id": "web:psalms.67.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 1,
      "referenceLabel": "Psalms 67:1",
      "text": "May God be merciful to us, bless us, and cause his face to shine on us. Selah.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.67.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 2,
      "referenceLabel": "Psalms 67:2",
      "text": "That your way may be known on earth, and your salvation among all nations,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.67.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 3,
      "referenceLabel": "Psalms 67:3",
      "text": "let the peoples praise you, God. Let all the peoples praise you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.67.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 4,
      "referenceLabel": "Psalms 67:4",
      "text": "Oh let the nations be glad and sing for joy, for you will judge the peoples with equity, and govern the nations on earth. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.67.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 5,
      "referenceLabel": "Psalms 67:5",
      "text": "Let the peoples praise you, God. Let all the peoples praise you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.67.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 6,
      "referenceLabel": "Psalms 67:6",
      "text": "The earth has yielded its increase. God, even our own God, will bless us.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.67.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 7,
      "referenceLabel": "Psalms 67:7",
      "text": "God will bless us. All the ends of the earth shall fear him.",
      "paragraphStart": false
    }
  ]
}
