{
  "chapter": {
    "id": "web:psalms.36",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 36,
    "referenceLabel": "Psalms 36",
    "summary": "Source text for Psalms 36 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.36.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 1,
      "referenceLabel": "Psalms 36:1",
      "text": "A revelation is within my heart about the disobedience of the wicked: There is no fear of God before his eyes.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.36.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 2,
      "referenceLabel": "Psalms 36:2",
      "text": "For he flatters himself in his own eyes, too much to detect and hate his sin.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.36.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 3,
      "referenceLabel": "Psalms 36:3",
      "text": "The words of his mouth are iniquity and deceit. He has ceased to be wise and to do good.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.36.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 4,
      "referenceLabel": "Psalms 36:4",
      "text": "He plots iniquity on his bed. He sets himself in a way that is not good. He doesn’t abhor evil.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.36.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 5,
      "referenceLabel": "Psalms 36:5",
      "text": "Your loving kindness, Yahweh, is in the heavens. Your faithfulness reaches to the skies.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.36.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 6,
      "referenceLabel": "Psalms 36:6",
      "text": "Your righteousness is like the mountains of God. Your judgments are like a great deep. Yahweh, you preserve man and animal.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.36.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 7,
      "referenceLabel": "Psalms 36:7",
      "text": "How precious is your loving kindness, God! The children of men take refuge under the shadow of your wings.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.36.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 8,
      "referenceLabel": "Psalms 36:8",
      "text": "They shall be abundantly satisfied with the abundance of your house. You will make them drink of the river of your pleasures.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.36.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 9,
      "referenceLabel": "Psalms 36:9",
      "text": "For with you is the spring of life. In your light we will see light.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.36.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 10,
      "referenceLabel": "Psalms 36:10",
      "text": "Oh continue your loving kindness to those who know you, your righteousness to the upright in heart.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.36.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 11,
      "referenceLabel": "Psalms 36:11",
      "text": "Don’t let the foot of pride come against me. Don’t let the hand of the wicked drive me away.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.36.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 12,
      "referenceLabel": "Psalms 36:12",
      "text": "There the workers of iniquity are fallen. They are thrust down, and shall not be able to rise.",
      "paragraphStart": false
    }
  ]
}
