{
  "chapter": {
    "id": "web:psalms.110",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 110,
    "referenceLabel": "Psalms 110",
    "summary": "Source text for Psalms 110 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.110.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 1,
      "referenceLabel": "Psalms 110:1",
      "text": "Yahweh says to my Lord, “ Sit at my right hand, until I make your enemies your footstool for your feet.”",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.110.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 2,
      "referenceLabel": "Psalms 110:2",
      "text": "Yahweh will send out the rod of your strength out of Zion. Rule among your enemies.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.110.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 3,
      "referenceLabel": "Psalms 110:3",
      "text": "Your people offer themselves willingly in the day of your power, in holy array. Out of the womb of the morning, you have the dew of your youth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.110.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 4,
      "referenceLabel": "Psalms 110:4",
      "text": "Yahweh has sworn, and will not change his mind: “ You are a priest forever in the order of Melchizedek.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.110.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 5,
      "referenceLabel": "Psalms 110:5",
      "text": "The Lord is at your right hand. He will crush kings in the day of his wrath.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.110.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 6,
      "referenceLabel": "Psalms 110:6",
      "text": "He will judge among the nations. He will heap up dead bodies. He will crush the ruler of the whole earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.110.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 7,
      "referenceLabel": "Psalms 110:7",
      "text": "He will drink of the brook on the way; therefore he will lift up his head.",
      "paragraphStart": false
    }
  ]
}
