{
  "chapter": {
    "id": "web:psalms.4",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 4,
    "referenceLabel": "Psalms 4",
    "summary": "Source text for Psalms 4 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.4.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Psalms 4:1",
      "text": "Answer me when I call, God of my righteousness. Give me relief from my distress. Have mercy on me, and hear my prayer.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.4.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Psalms 4:2",
      "text": "You sons of men, how long shall my glory be turned into dishonor? Will you love vanity and seek after falsehood? Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.4.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Psalms 4:3",
      "text": "But know that Yahweh has set apart for himself him who is godly; Yahweh will hear when I call to him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.4.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Psalms 4:4",
      "text": "Stand in awe, and don’t sin. Search your own heart on your bed, and be still. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.4.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Psalms 4:5",
      "text": "Offer the sacrifices of righteousness. Put your trust in Yahweh.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.4.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Psalms 4:6",
      "text": "Many say, “Who will show us any good?” Yahweh, let the light of your face shine on us.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.4.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Psalms 4:7",
      "text": "You have put gladness in my heart, more than when their grain and their new wine are increased.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.4.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Psalms 4:8",
      "text": "In peace I will both lay myself down and sleep, for you alone, Yahweh, make me live in safety.",
      "paragraphStart": false
    }
  ]
}
