{
  "chapter": {
    "id": "web:psalms.88",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 88,
    "referenceLabel": "Psalms 88",
    "summary": "Source text for Psalms 88 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.88.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 1,
      "referenceLabel": "Psalms 88:1",
      "text": "Yahweh, the God of my salvation, I have cried day and night before you.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.88.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 2,
      "referenceLabel": "Psalms 88:2",
      "text": "Let my prayer enter into your presence. Turn your ear to my cry.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.88.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 3,
      "referenceLabel": "Psalms 88:3",
      "text": "For my soul is full of troubles. My life draws near to Sheol.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.88.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 4,
      "referenceLabel": "Psalms 88:4",
      "text": "I am counted among those who go down into the pit. I am like a man who has no help,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.88.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 5,
      "referenceLabel": "Psalms 88:5",
      "text": "set apart among the dead, like the slain who lie in the grave, whom you remember no more. They are cut off from your hand.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.88.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 6,
      "referenceLabel": "Psalms 88:6",
      "text": "You have laid me in the lowest pit, in the darkest depths.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.88.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 7,
      "referenceLabel": "Psalms 88:7",
      "text": "Your wrath lies heavily on me. You have afflicted me with all your waves. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.88.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 8,
      "referenceLabel": "Psalms 88:8",
      "text": "You have taken my friends from me. You have made me an abomination to them. I am confined, and I can’t escape.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.88.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 9,
      "referenceLabel": "Psalms 88:9",
      "text": "My eyes are dim from grief. I have called on you daily, Yahweh. I have spread out my hands to you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.88.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 10,
      "referenceLabel": "Psalms 88:10",
      "text": "Do you show wonders to the dead? Do the departed spirits rise up and praise you? Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.88.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 11,
      "referenceLabel": "Psalms 88:11",
      "text": "Is your loving kindness declared in the grave? Or your faithfulness in Destruction?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.88.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 12,
      "referenceLabel": "Psalms 88:12",
      "text": "Are your wonders made known in the dark? Or your righteousness in the land of forgetfulness?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.88.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 13,
      "referenceLabel": "Psalms 88:13",
      "text": "But to you, Yahweh, I have cried. In the morning, my prayer comes before you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.88.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 14,
      "referenceLabel": "Psalms 88:14",
      "text": "Yahweh, why do you reject my soul? Why do you hide your face from me?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.88.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 15,
      "referenceLabel": "Psalms 88:15",
      "text": "I am afflicted and ready to die from my youth up. While I suffer your terrors, I am distracted.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.88.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 16,
      "referenceLabel": "Psalms 88:16",
      "text": "Your fierce wrath has gone over me. Your terrors have cut me off.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.88.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 17,
      "referenceLabel": "Psalms 88:17",
      "text": "They came around me like water all day long. They completely engulfed me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.88.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 18,
      "referenceLabel": "Psalms 88:18",
      "text": "You have put lover and friend far from me, and my friends into darkness.",
      "paragraphStart": false
    }
  ]
}
