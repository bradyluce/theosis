{
  "chapter": {
    "id": "web:psalms.75",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 75,
    "referenceLabel": "Psalms 75",
    "summary": "Source text for Psalms 75 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.75.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 1,
      "referenceLabel": "Psalms 75:1",
      "text": "We give thanks to you, God. We give thanks, for your Name is near. Men tell about your wondrous works.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.75.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 2,
      "referenceLabel": "Psalms 75:2",
      "text": "When I choose the appointed time, I will judge blamelessly.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.75.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 3,
      "referenceLabel": "Psalms 75:3",
      "text": "The earth and all its inhabitants quake. I firmly hold its pillars. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.75.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 4,
      "referenceLabel": "Psalms 75:4",
      "text": "I said to the arrogant, “Don’t boast!” I said to the wicked, “Don’t lift up the horn.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.75.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 5,
      "referenceLabel": "Psalms 75:5",
      "text": "Don’t lift up your horn on high. Don’t speak with a stiff neck.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.75.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 6,
      "referenceLabel": "Psalms 75:6",
      "text": "For neither from the east, nor from the west, nor yet from the south, comes exaltation.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.75.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 7,
      "referenceLabel": "Psalms 75:7",
      "text": "But God is the judge. He puts down one, and lifts up another.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.75.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 8,
      "referenceLabel": "Psalms 75:8",
      "text": "For in Yahweh’s hand there is a cup, full of foaming wine mixed with spices. He pours it out. Indeed the wicked of the earth drink and drink it to its very dregs.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.75.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 9,
      "referenceLabel": "Psalms 75:9",
      "text": "But I will declare this forever: I will sing praises to the God of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.75.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 10,
      "referenceLabel": "Psalms 75:10",
      "text": "I will cut off all the horns of the wicked, but the horns of the righteous shall be lifted up.",
      "paragraphStart": false
    }
  ]
}
