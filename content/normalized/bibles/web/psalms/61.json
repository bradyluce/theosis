{
  "chapter": {
    "id": "web:psalms.61",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 61,
    "referenceLabel": "Psalms 61",
    "summary": "Source text for Psalms 61 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.61.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 1,
      "referenceLabel": "Psalms 61:1",
      "text": "Hear my cry, God. Listen to my prayer.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.61.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 2,
      "referenceLabel": "Psalms 61:2",
      "text": "From the end of the earth, I will call to you when my heart is overwhelmed. Lead me to the rock that is higher than I.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.61.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 3,
      "referenceLabel": "Psalms 61:3",
      "text": "For you have been a refuge for me, a strong tower from the enemy.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.61.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 4,
      "referenceLabel": "Psalms 61:4",
      "text": "I will dwell in your tent forever. I will take refuge in the shelter of your wings. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.61.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 5,
      "referenceLabel": "Psalms 61:5",
      "text": "For you, God, have heard my vows. You have given me the heritage of those who fear your name.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.61.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 6,
      "referenceLabel": "Psalms 61:6",
      "text": "You will prolong the king’s life. His years will be for generations.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.61.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 7,
      "referenceLabel": "Psalms 61:7",
      "text": "He shall be enthroned in God’s presence forever. Appoint your loving kindness and truth, that they may preserve him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.61.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 8,
      "referenceLabel": "Psalms 61:8",
      "text": "So I will sing praise to your name forever, that I may fulfill my vows daily.",
      "paragraphStart": false
    }
  ]
}
