    },
    {
      "id": "web:psalms.136.26",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 26,
      "referenceLabel": "Psalms 136:26",
      "text": "Oh give thanks to the God of heaven, for his loving kindness endures forever.",
      "paragraphStart": false
    }
