  "verses": [
    {
      "id": "web:psalms.136.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 1,
      "referenceLabel": "Psalms 136:1",
      "text": "Give thanks to Yahweh, for he is good, for his loving kindness endures forever.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.136.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 2,
      "referenceLabel": "Psalms 136:2",
      "text": "Give thanks to the God of gods, for his loving kindness endures forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 3,
      "referenceLabel": "Psalms 136:3",
      "text": "Give thanks to the Lord of lords, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 4,
      "referenceLabel": "Psalms 136:4",
      "text": "to him who alone does great wonders, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 5,
      "referenceLabel": "Psalms 136:5",
      "text": "to him who by understanding made the heavens, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 6,
      "referenceLabel": "Psalms 136:6",
      "text": "to him who spread out the earth above the waters, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 7,
      "referenceLabel": "Psalms 136:7",
      "text": "to him who made the great lights, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 8,
      "referenceLabel": "Psalms 136:8",
      "text": "the sun to rule by day, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 9,
      "referenceLabel": "Psalms 136:9",
      "text": "the moon and stars to rule by night, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 10,
      "referenceLabel": "Psalms 136:10",
      "text": "to him who struck down the Egyptian firstborn, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 11,
      "referenceLabel": "Psalms 136:11",
      "text": "and brought out Israel from among them, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 12,
      "referenceLabel": "Psalms 136:12",
      "text": "with a strong hand, and with an outstretched arm, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 13,
      "referenceLabel": "Psalms 136:13",
      "text": "to him who divided the Red Sea apart, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 14,
      "referenceLabel": "Psalms 136:14",
      "text": "and made Israel to pass through the middle of it, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 15,
      "referenceLabel": "Psalms 136:15",
      "text": "but overthrew Pharaoh and his army in the Red Sea, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 16,
      "referenceLabel": "Psalms 136:16",
      "text": "to him who led his people through the wilderness, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 17,
      "referenceLabel": "Psalms 136:17",
      "text": "to him who struck great kings, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 18,
      "referenceLabel": "Psalms 136:18",
      "text": "and killed mighty kings, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 19,
      "referenceLabel": "Psalms 136:19",
      "text": "Sihon king of the Amorites, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 20,
      "referenceLabel": "Psalms 136:20",
      "text": "Og king of Bashan, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 21,
      "referenceLabel": "Psalms 136:21",
      "text": "and gave their land as an inheritance, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 22,
      "referenceLabel": "Psalms 136:22",
      "text": "even a heritage to Israel his servant, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.23",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 23,
      "referenceLabel": "Psalms 136:23",
      "text": "who remembered us in our low estate, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.24",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 24,
      "referenceLabel": "Psalms 136:24",
      "text": "and has delivered us from our adversaries, for his loving kindness endures forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.136.25",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 25,
      "referenceLabel": "Psalms 136:25",
      "text": "who gives food to every creature, for his loving kindness endures forever.",
