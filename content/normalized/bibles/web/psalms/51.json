{
  "chapter": {
    "id": "web:psalms.51",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 51,
    "referenceLabel": "Psalms 51",
    "summary": "Source text for Psalms 51 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.51.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 1,
      "referenceLabel": "Psalms 51:1",
      "text": "Have mercy on me, God, according to your loving kindness. According to the multitude of your tender mercies, blot out my transgressions.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.51.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 2,
      "referenceLabel": "Psalms 51:2",
      "text": "Wash me thoroughly from my iniquity. Cleanse me from my sin.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.51.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 3,
      "referenceLabel": "Psalms 51:3",
      "text": "For I know my transgressions. My sin is constantly before me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.51.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 4,
      "referenceLabel": "Psalms 51:4",
      "text": "Against you, and you only, I have sinned, and done that which is evil in your sight, so you may be proved right when you speak, and justified when you judge.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.51.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 5,
      "referenceLabel": "Psalms 51:5",
      "text": "Behold, I was born in iniquity. My mother conceived me in sin.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.51.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 6,
      "referenceLabel": "Psalms 51:6",
      "text": "Behold, you desire truth in the inward parts. You teach me wisdom in the inmost place.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.51.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 7,
      "referenceLabel": "Psalms 51:7",
      "text": "Purify me with hyssop, and I will be clean. Wash me, and I will be whiter than snow.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.51.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 8,
      "referenceLabel": "Psalms 51:8",
      "text": "Let me hear joy and gladness, that the bones which you have broken may rejoice.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.51.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 9,
      "referenceLabel": "Psalms 51:9",
      "text": "Hide your face from my sins, and blot out all of my iniquities.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.51.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 10,
      "referenceLabel": "Psalms 51:10",
      "text": "Create in me a clean heart, O God. Renew a right spirit within me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.51.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 11,
      "referenceLabel": "Psalms 51:11",
      "text": "Don’t throw me from your presence, and don’t take your Holy Spirit from me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.51.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 12,
      "referenceLabel": "Psalms 51:12",
      "text": "Restore to me the joy of your salvation. Uphold me with a willing spirit.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.51.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 13,
      "referenceLabel": "Psalms 51:13",
      "text": "Then I will teach transgressors your ways. Sinners will be converted to you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.51.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 14,
      "referenceLabel": "Psalms 51:14",
      "text": "Deliver me from the guilt of bloodshed, O God, the God of my salvation. My tongue will sing aloud of your righteousness.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.51.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 15,
      "referenceLabel": "Psalms 51:15",
      "text": "Lord, open my lips. My mouth will declare your praise.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.51.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 16,
      "referenceLabel": "Psalms 51:16",
      "text": "For you don’t delight in sacrifice, or else I would give it. You have no pleasure in burnt offering.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.51.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 17,
      "referenceLabel": "Psalms 51:17",
      "text": "The sacrifices of God are a broken spirit. O God, you will not despise a broken and contrite heart.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.51.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 18,
      "referenceLabel": "Psalms 51:18",
      "text": "Do well in your good pleasure to Zion. Build the walls of Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.51.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 19,
      "referenceLabel": "Psalms 51:19",
      "text": "Then you will delight in the sacrifices of righteousness, in burnt offerings and in whole burnt offerings. Then they will offer bulls on your altar.",
      "paragraphStart": false
    }
  ]
}
