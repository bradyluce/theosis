{
  "chapter": {
    "id": "web:psalms.58",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 58,
    "referenceLabel": "Psalms 58",
    "summary": "Source text for Psalms 58 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.58.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 1,
      "referenceLabel": "Psalms 58:1",
      "text": "Do you indeed speak righteousness, silent ones? Do you judge blamelessly, you sons of men?",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.58.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 2,
      "referenceLabel": "Psalms 58:2",
      "text": "No, in your heart you plot injustice. You measure out the violence of your hands in the earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.58.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 3,
      "referenceLabel": "Psalms 58:3",
      "text": "The wicked go astray from the womb. They are wayward as soon as they are born, speaking lies.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.58.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 4,
      "referenceLabel": "Psalms 58:4",
      "text": "Their poison is like the poison of a snake, like a deaf cobra that stops its ear,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.58.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 5,
      "referenceLabel": "Psalms 58:5",
      "text": "which doesn’t listen to the voice of charmers, no matter how skillful the charmer may be.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.58.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 6,
      "referenceLabel": "Psalms 58:6",
      "text": "Break their teeth, God, in their mouth. Break out the great teeth of the young lions, Yahweh.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.58.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 7,
      "referenceLabel": "Psalms 58:7",
      "text": "Let them vanish like water that flows away. When they draw the bow, let their arrows be made blunt.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.58.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 8,
      "referenceLabel": "Psalms 58:8",
      "text": "Let them be like a snail which melts and passes away, like the stillborn child, who has not seen the sun.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.58.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 9,
      "referenceLabel": "Psalms 58:9",
      "text": "Before your pots can feel the heat of the thorns, he will sweep away the green and the burning alike.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.58.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 10,
      "referenceLabel": "Psalms 58:10",
      "text": "The righteous shall rejoice when he sees the vengeance. He shall wash his feet in the blood of the wicked,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.58.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 11,
      "referenceLabel": "Psalms 58:11",
      "text": "so that men shall say, “Most certainly there is a reward for the righteous. Most certainly there is a God who judges the earth.”",
      "paragraphStart": false
    }
  ]
}
