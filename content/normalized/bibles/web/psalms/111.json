{
  "chapter": {
    "id": "web:psalms.111",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 111,
    "referenceLabel": "Psalms 111",
    "summary": "Source text for Psalms 111 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.111.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 1,
      "referenceLabel": "Psalms 111:1",
      "text": "Praise Yah! I will give thanks to Yahweh with my whole heart, in the council of the upright, and in the congregation.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.111.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 2,
      "referenceLabel": "Psalms 111:2",
      "text": "Yahweh’s works are great, pondered by all those who delight in them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.111.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 3,
      "referenceLabel": "Psalms 111:3",
      "text": "His work is honor and majesty. His righteousness endures forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.111.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 4,
      "referenceLabel": "Psalms 111:4",
      "text": "He has caused his wonderful works to be remembered. Yahweh is gracious and merciful.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.111.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 5,
      "referenceLabel": "Psalms 111:5",
      "text": "He has given food to those who fear him. He always remembers his covenant.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.111.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 6,
      "referenceLabel": "Psalms 111:6",
      "text": "He has shown his people the power of his works, in giving them the heritage of the nations.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.111.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 7,
      "referenceLabel": "Psalms 111:7",
      "text": "The works of his hands are truth and justice. All his precepts are sure.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.111.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 8,
      "referenceLabel": "Psalms 111:8",
      "text": "They are established forever and ever. They are done in truth and uprightness.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.111.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 9,
      "referenceLabel": "Psalms 111:9",
      "text": "He has sent redemption to his people. He has ordained his covenant forever. His name is holy and awesome!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.111.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 10,
      "referenceLabel": "Psalms 111:10",
      "text": "The fear of Yahweh is the beginning of wisdom. All those who do his work have a good understanding. His praise endures forever!",
      "paragraphStart": false
    }
  ]
}
