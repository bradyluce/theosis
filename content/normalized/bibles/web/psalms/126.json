    "bookSlug": "psalms",
    "chapterNumber": 126,
    "referenceLabel": "Psalms 126",
    "summary": "Source text for Psalms 126 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.126.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 1,
      "referenceLabel": "Psalms 126:1",
      "text": "When Yahweh brought back those who returned to Zion, we were like those who dream.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.126.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 2,
      "referenceLabel": "Psalms 126:2",
      "text": "Then our mouth was filled with laughter, and our tongue with singing. Then they said among the nations, “ Yahweh has done great things for them.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.126.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 3,
      "referenceLabel": "Psalms 126:3",
      "text": "Yahweh has done great things for us, and we are glad.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.126.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 4,
      "referenceLabel": "Psalms 126:4",
      "text": "Restore our fortunes again, Yahweh, like the streams in the Negev.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.126.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 5,
      "referenceLabel": "Psalms 126:5",
      "text": "Those who sow in tears will reap in joy.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.126.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 6,
      "referenceLabel": "Psalms 126:6",
      "text": "He who goes out weeping, carrying seed for sowing, will certainly come again with joy, carrying his sheaves.",
      "paragraphStart": false
    }
  ]
}
