{
  "chapter": {
    "id": "web:psalms.86",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 86,
    "referenceLabel": "Psalms 86",
    "summary": "Source text for Psalms 86 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.86.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 1,
      "referenceLabel": "Psalms 86:1",
      "text": "Hear, Yahweh, and answer me, for I am poor and needy.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.86.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 2,
      "referenceLabel": "Psalms 86:2",
      "text": "Preserve my soul, for I am godly. You, my God, save your servant who trusts in you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.86.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 3,
      "referenceLabel": "Psalms 86:3",
      "text": "Be merciful to me, Lord, for I call to you all day long.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.86.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 4,
      "referenceLabel": "Psalms 86:4",
      "text": "Bring joy to the soul of your servant, for to you, Lord, do I lift up my soul.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.86.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 5,
      "referenceLabel": "Psalms 86:5",
      "text": "For you, Lord, are good, and ready to forgive, abundant in loving kindness to all those who call on you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.86.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 6,
      "referenceLabel": "Psalms 86:6",
      "text": "Hear, Yahweh, my prayer. Listen to the voice of my petitions.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.86.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 7,
      "referenceLabel": "Psalms 86:7",
      "text": "In the day of my trouble I will call on you, for you will answer me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.86.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 8,
      "referenceLabel": "Psalms 86:8",
      "text": "There is no one like you among the gods, Lord, nor any deeds like your deeds.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.86.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 9,
      "referenceLabel": "Psalms 86:9",
      "text": "All nations you have made will come and worship before you, Lord. They shall glorify your name.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.86.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 10,
      "referenceLabel": "Psalms 86:10",
      "text": "For you are great, and do wondrous things. You are God alone.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.86.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 11,
      "referenceLabel": "Psalms 86:11",
      "text": "Teach me your way, Yahweh. I will walk in your truth. Make my heart undivided to fear your name.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.86.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 12,
      "referenceLabel": "Psalms 86:12",
      "text": "I will praise you, Lord my God, with my whole heart. I will glorify your name forever more.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.86.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 13,
      "referenceLabel": "Psalms 86:13",
      "text": "For your loving kindness is great toward me. You have delivered my soul from the lowest Sheol.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.86.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 14,
      "referenceLabel": "Psalms 86:14",
      "text": "God, the proud have risen up against me. A company of violent men have sought after my soul, and they don’t hold regard for you before them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.86.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 15,
      "referenceLabel": "Psalms 86:15",
      "text": "But you, Lord, are a merciful and gracious God, slow to anger, and abundant in loving kindness and truth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.86.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 16,
      "referenceLabel": "Psalms 86:16",
      "text": "Turn to me, and have mercy on me! Give your strength to your servant. Save the son of your servant.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.86.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 17,
      "referenceLabel": "Psalms 86:17",
      "text": "Show me a sign of your goodness, that those who hate me may see it, and be shamed, because you, Yahweh, have helped me, and comforted me.",
      "paragraphStart": false
    }
  ]
}
