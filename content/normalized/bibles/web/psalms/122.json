{
  "chapter": {
    "id": "web:psalms.122",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 122,
    "referenceLabel": "Psalms 122",
    "summary": "Source text for Psalms 122 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.122.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 1,
      "referenceLabel": "Psalms 122:1",
      "text": "I was glad when they said to me, “Let’s go to Yahweh’s house!”",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.122.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 2,
      "referenceLabel": "Psalms 122:2",
      "text": "Our feet are standing within your gates, Jerusalem!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.122.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 3,
      "referenceLabel": "Psalms 122:3",
      "text": "Jerusalem is built as a city that is compact together,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.122.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 4,
      "referenceLabel": "Psalms 122:4",
      "text": "where the tribes go up, even Yah’s tribes, according to an ordinance for Israel, to give thanks to Yahweh’s name.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.122.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 5,
      "referenceLabel": "Psalms 122:5",
      "text": "For there are set thrones for judgment, the thrones of David’s house.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.122.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 6,
      "referenceLabel": "Psalms 122:6",
      "text": "Pray for the peace of Jerusalem. Those who love you will prosper.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.122.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 7,
      "referenceLabel": "Psalms 122:7",
      "text": "Peace be within your walls, and prosperity within your palaces.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.122.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 8,
      "referenceLabel": "Psalms 122:8",
      "text": "For my brothers’ and companions ’ sakes, I will now say, “Peace be within you.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.122.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 9,
      "referenceLabel": "Psalms 122:9",
      "text": "For the sake of the house of Yahweh our God, I will seek your good.",
      "paragraphStart": false
    }
  ]
}
