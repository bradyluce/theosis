{
  "chapter": {
    "id": "web:psalms.142",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 142,
    "referenceLabel": "Psalms 142",
    "summary": "Source text for Psalms 142 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.142.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 1,
      "referenceLabel": "Psalms 142:1",
      "text": "I cry with my voice to Yahweh. With my voice, I ask Yahweh for mercy.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.142.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 2,
      "referenceLabel": "Psalms 142:2",
      "text": "I pour out my complaint before him. I tell him my troubles.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.142.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 3,
      "referenceLabel": "Psalms 142:3",
      "text": "When my spirit was overwhelmed within me, you knew my route. On the path in which I walk, they have hidden a snare for me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.142.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 4,
      "referenceLabel": "Psalms 142:4",
      "text": "Look on my right, and see; for there is no one who is concerned for me. Refuge has fled from me. No one cares for my soul.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.142.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 5,
      "referenceLabel": "Psalms 142:5",
      "text": "I cried to you, Yahweh. I said, “You are my refuge, my portion in the land of the living.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.142.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 6,
      "referenceLabel": "Psalms 142:6",
      "text": "Listen to my cry, for I am in desperate need. Deliver me from my persecutors, for they are too strong for me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.142.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 7,
      "referenceLabel": "Psalms 142:7",
      "text": "Bring my soul out of prison, that I may give thanks to your name. The righteous will surround me, for you will be good to me.",
      "paragraphStart": false
    }
  ]
}
