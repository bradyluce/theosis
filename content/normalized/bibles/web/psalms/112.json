{
  "chapter": {
    "id": "web:psalms.112",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 112,
    "referenceLabel": "Psalms 112",
    "summary": "Source text for Psalms 112 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.112.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 1,
      "referenceLabel": "Psalms 112:1",
      "text": "Praise Yah! Blessed is the man who fears Yahweh, who delights greatly in his commandments.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.112.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 2,
      "referenceLabel": "Psalms 112:2",
      "text": "His offspring will be mighty in the land. The generation of the upright will be blessed.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.112.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 3,
      "referenceLabel": "Psalms 112:3",
      "text": "Wealth and riches are in his house. His righteousness endures forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.112.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 4,
      "referenceLabel": "Psalms 112:4",
      "text": "Light dawns in the darkness for the upright, gracious, merciful, and righteous.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.112.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 5,
      "referenceLabel": "Psalms 112:5",
      "text": "It is well with the man who deals graciously and lends. He will maintain his cause in judgment.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.112.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 6,
      "referenceLabel": "Psalms 112:6",
      "text": "For he will never be shaken. The righteous will be remembered forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.112.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 7,
      "referenceLabel": "Psalms 112:7",
      "text": "He will not be afraid of evil news. His heart is steadfast, trusting in Yahweh.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.112.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 8,
      "referenceLabel": "Psalms 112:8",
      "text": "His heart is established. He will not be afraid in the end when he sees his adversaries.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.112.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 9,
      "referenceLabel": "Psalms 112:9",
      "text": "He has dispersed, he has given to the poor. His righteousness endures forever. His horn will be exalted with honor.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.112.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 10,
      "referenceLabel": "Psalms 112:10",
      "text": "The wicked will see it, and be grieved. He shall gnash with his teeth, and melt away. The desire of the wicked will perish.",
      "paragraphStart": false
    }
  ]
}
