{
  "chapter": {
    "id": "web:psalms.60",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 60,
    "referenceLabel": "Psalms 60",
    "summary": "Source text for Psalms 60 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.60.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 1,
      "referenceLabel": "Psalms 60:1",
      "text": "God, you have rejected us. You have broken us down. You have been angry. Restore us, again.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.60.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 2,
      "referenceLabel": "Psalms 60:2",
      "text": "You have made the land tremble. You have torn it. Mend its fractures, for it quakes.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.60.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 3,
      "referenceLabel": "Psalms 60:3",
      "text": "You have shown your people hard things. You have made us drink the wine that makes us stagger.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.60.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 4,
      "referenceLabel": "Psalms 60:4",
      "text": "You have given a banner to those who fear you, that it may be displayed because of the truth. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.60.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 5,
      "referenceLabel": "Psalms 60:5",
      "text": "So that your beloved may be delivered, save with your right hand, and answer us.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.60.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 6,
      "referenceLabel": "Psalms 60:6",
      "text": "God has spoken from his sanctuary: “ I will triumph. I will divide Shechem, and measure out the valley of Succoth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.60.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 7,
      "referenceLabel": "Psalms 60:7",
      "text": "Gilead is mine, and Manasseh is mine. Ephraim also is the defense of my head. Judah is my scepter.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.60.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 8,
      "referenceLabel": "Psalms 60:8",
      "text": "Moab is my wash basin. I will throw my sandal on Edom. I shout in triumph over Philistia.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.60.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 9,
      "referenceLabel": "Psalms 60:9",
      "text": "Who will bring me into the strong city? Who has led me to Edom?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.60.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 10,
      "referenceLabel": "Psalms 60:10",
      "text": "Haven’t you, God, rejected us? You don’t go out with our armies, God.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.60.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 11,
      "referenceLabel": "Psalms 60:11",
      "text": "Give us help against the adversary, for the help of man is vain.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.60.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 12,
      "referenceLabel": "Psalms 60:12",
      "text": "Through God we will do valiantly, for it is he who will tread down our adversaries.",
      "paragraphStart": false
    }
  ]
}
