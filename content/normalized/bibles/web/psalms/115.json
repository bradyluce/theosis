{
  "chapter": {
    "id": "web:psalms.115",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 115,
    "referenceLabel": "Psalms 115",
    "summary": "Source text for Psalms 115 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.115.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 1,
      "referenceLabel": "Psalms 115:1",
      "text": "Not to us, Yahweh, not to us, but to your name give glory, for your loving kindness, and for your truth’s sake.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.115.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 2,
      "referenceLabel": "Psalms 115:2",
      "text": "Why should the nations say, “Where is their God, now?”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.115.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 3,
      "referenceLabel": "Psalms 115:3",
      "text": "But our God is in the heavens. He does whatever he pleases.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.115.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 4,
      "referenceLabel": "Psalms 115:4",
      "text": "Their idols are silver and gold, the work of men’s hands.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.115.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 5,
      "referenceLabel": "Psalms 115:5",
      "text": "They have mouths, but they don’t speak. They have eyes, but they don’t see.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.115.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 6,
      "referenceLabel": "Psalms 115:6",
      "text": "They have ears, but they don’t hear. They have noses, but they don’t smell.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.115.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 7,
      "referenceLabel": "Psalms 115:7",
      "text": "They have hands, but they don’t feel. They have feet, but they don’t walk, neither do they speak through their throat.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.115.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 8,
      "referenceLabel": "Psalms 115:8",
      "text": "Those who make them will be like them; yes, everyone who trusts in them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.115.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 9,
      "referenceLabel": "Psalms 115:9",
      "text": "Israel, trust in Yahweh! He is their help and their shield.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.115.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 10,
      "referenceLabel": "Psalms 115:10",
      "text": "House of Aaron, trust in Yahweh! He is their help and their shield.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.115.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 11,
      "referenceLabel": "Psalms 115:11",
      "text": "You who fear Yahweh, trust in Yahweh! He is their help and their shield.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.115.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 12,
      "referenceLabel": "Psalms 115:12",
      "text": "Yahweh remembers us. He will bless us. He will bless the house of Israel. He will bless the house of Aaron.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.115.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 13,
      "referenceLabel": "Psalms 115:13",
      "text": "He will bless those who fear Yahweh, both small and great.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.115.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 14,
      "referenceLabel": "Psalms 115:14",
      "text": "May Yahweh increase you more and more, you and your children.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.115.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 15,
      "referenceLabel": "Psalms 115:15",
      "text": "Blessed are you by Yahweh, who made heaven and earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.115.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 16,
      "referenceLabel": "Psalms 115:16",
      "text": "The heavens are Yahweh’s heavens, but he has given the earth to the children of men.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.115.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 17,
      "referenceLabel": "Psalms 115:17",
      "text": "The dead don’t praise Yah, nor any who go down into silence,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.115.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 18,
      "referenceLabel": "Psalms 115:18",
      "text": "but we will bless Yah, from this time forward and forever more. Praise Yah!",
      "paragraphStart": false
    }
  ]
}
