{
  "chapter": {
    "id": "web:psalms.3",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 3,
    "referenceLabel": "Psalms 3",
    "summary": "Source text for Psalms 3 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.3.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Psalms 3:1",
      "text": "Yahweh, how my adversaries have increased! Many are those who rise up against me.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.3.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Psalms 3:2",
      "text": "Many there are who say of my soul, “ There is no help for him in God.” Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.3.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Psalms 3:3",
      "text": "But you, Yahweh, are a shield around me, my glory, and the one who lifts up my head.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.3.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Psalms 3:4",
      "text": "I cry to Yahweh with my voice, and he answers me out of his holy hill. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.3.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Psalms 3:5",
      "text": "I laid myself down and slept. I awakened, for Yahweh sustains me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.3.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Psalms 3:6",
      "text": "I will not be afraid of tens of thousands of people who have set themselves against me on every side.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.3.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Psalms 3:7",
      "text": "Arise, Yahweh! Save me, my God! For you have struck all of my enemies on the cheek bone. You have broken the teeth of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.3.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Psalms 3:8",
      "text": "Salvation belongs to Yahweh. May your blessing be on your people. Selah.",
      "paragraphStart": false
    }
  ]
}
