{
  "chapter": {
    "id": "web:psalms.19",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 19,
    "referenceLabel": "Psalms 19",
    "summary": "Source text for Psalms 19 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.19.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Psalms 19:1",
      "text": "The heavens declare the glory of God. The expanse shows his handiwork.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.19.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Psalms 19:2",
      "text": "Day after day they pour out speech, and night after night they display knowledge.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.19.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Psalms 19:3",
      "text": "There is no speech nor language where their voice is not heard.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.19.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Psalms 19:4",
      "text": "Their voice has gone out through all the earth, their words to the end of the world. In them he has set a tent for the sun,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.19.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Psalms 19:5",
      "text": "which is as a bridegroom coming out of his room, like a strong man rejoicing to run his course.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.19.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Psalms 19:6",
      "text": "His going out is from the end of the heavens, his circuit to its ends. There is nothing hidden from its heat.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.19.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Psalms 19:7",
      "text": "Yahweh’s law is perfect, restoring the soul. Yahweh’s covenant is sure, making wise the simple.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.19.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Psalms 19:8",
      "text": "Yahweh’s precepts are right, rejoicing the heart. Yahweh’s commandment is pure, enlightening the eyes.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.19.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Psalms 19:9",
      "text": "The fear of Yahweh is clean, enduring forever. Yahweh’s ordinances are true, and righteous altogether.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.19.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Psalms 19:10",
      "text": "They are more to be desired than gold, yes, than much fine gold, sweeter also than honey and the extract of the honeycomb.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.19.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Psalms 19:11",
      "text": "Moreover your servant is warned by them. In keeping them there is great reward.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.19.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Psalms 19:12",
      "text": "Who can discern his errors? Forgive me from hidden errors.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.19.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Psalms 19:13",
      "text": "Keep back your servant also from presumptuous sins. Let them not have dominion over me. Then I will be upright. I will be blameless and innocent of great transgression.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.19.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Psalms 19:14",
      "text": "Let the words of my mouth and the meditation of my heart be acceptable in your sight, Yahweh, my rock, and my redeemer.",
      "paragraphStart": false
    }
  ]
}
