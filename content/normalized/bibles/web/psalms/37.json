{
  "chapter": {
    "id": "web:psalms.37",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 37,
    "referenceLabel": "Psalms 37",
    "summary": "Source text for Psalms 37 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.37.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 1,
      "referenceLabel": "Psalms 37:1",
      "text": "Don’t fret because of evildoers, neither be envious against those who work unrighteousness.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.37.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 2,
      "referenceLabel": "Psalms 37:2",
      "text": "For they shall soon be cut down like the grass, and wither like the green herb.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 3,
      "referenceLabel": "Psalms 37:3",
      "text": "Trust in Yahweh, and do good. Dwell in the land, and enjoy safe pasture.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 4,
      "referenceLabel": "Psalms 37:4",
      "text": "Also delight yourself in Yahweh, and he will give you the desires of your heart.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 5,
      "referenceLabel": "Psalms 37:5",
      "text": "Commit your way to Yahweh. Trust also in him, and he will do this:",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 6,
      "referenceLabel": "Psalms 37:6",
      "text": "he will make your righteousness shine out like light, and your justice as the noon day sun.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 7,
      "referenceLabel": "Psalms 37:7",
      "text": "Rest in Yahweh, and wait patiently for him. Don’t fret because of him who prospers in his way, because of the man who makes wicked plots happen.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 8,
      "referenceLabel": "Psalms 37:8",
      "text": "Cease from anger, and forsake wrath. Don’t fret; it leads only to evildoing.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 9,
      "referenceLabel": "Psalms 37:9",
      "text": "For evildoers shall be cut off, but those who wait for Yahweh shall inherit the land.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 10,
      "referenceLabel": "Psalms 37:10",
      "text": "For yet a little while, and the wicked will be no more. Yes, though you look for his place, he isn’t there.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 11,
      "referenceLabel": "Psalms 37:11",
      "text": "But the humble shall inherit the land, and shall delight themselves in the abundance of peace.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 12,
      "referenceLabel": "Psalms 37:12",
      "text": "The wicked plots against the just, and gnashes at him with his teeth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 13,
      "referenceLabel": "Psalms 37:13",
      "text": "The Lord will laugh at him, for he sees that his day is coming.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 14,
      "referenceLabel": "Psalms 37:14",
      "text": "The wicked have drawn out the sword, and have bent their bow, to cast down the poor and needy, to kill those who are upright on the path.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 15,
      "referenceLabel": "Psalms 37:15",
      "text": "Their sword shall enter into their own heart. Their bows shall be broken.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 16,
      "referenceLabel": "Psalms 37:16",
      "text": "Better is a little that the righteous has, than the abundance of many wicked.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 17,
      "referenceLabel": "Psalms 37:17",
      "text": "For the arms of the wicked shall be broken, but Yahweh upholds the righteous.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 18,
      "referenceLabel": "Psalms 37:18",
      "text": "Yahweh knows the days of the perfect. Their inheritance shall be forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 19,
      "referenceLabel": "Psalms 37:19",
      "text": "They shall not be disappointed in the time of evil. In the days of famine they shall be satisfied.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 20,
      "referenceLabel": "Psalms 37:20",
      "text": "But the wicked shall perish. The enemies of Yahweh shall be like the beauty of the fields. They will vanish — vanish like smoke.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 21,
      "referenceLabel": "Psalms 37:21",
      "text": "The wicked borrow, and don’t pay back, but the righteous give generously.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 22,
      "referenceLabel": "Psalms 37:22",
      "text": "For such as are blessed by him shall inherit the land. Those who are cursed by him shall be cut off.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.23",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 23,
      "referenceLabel": "Psalms 37:23",
      "text": "A man’s steps are established by Yahweh. He delights in his way.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.24",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 24,
      "referenceLabel": "Psalms 37:24",
      "text": "Though he stumble, he shall not fall, for Yahweh holds him up with his hand.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.25",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 25,
      "referenceLabel": "Psalms 37:25",
      "text": "I have been young, and now am old, yet I have not seen the righteous forsaken, nor his children begging for bread.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.26",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 26,
      "referenceLabel": "Psalms 37:26",
      "text": "All day long he deals graciously, and lends. His offspring is blessed.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.27",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 27,
      "referenceLabel": "Psalms 37:27",
      "text": "Depart from evil, and do good. Live securely forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.28",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 28,
      "referenceLabel": "Psalms 37:28",
      "text": "For Yahweh loves justice, and doesn’t forsake his saints. They are preserved forever, but the children of the wicked shall be cut off.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.29",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 29,
      "referenceLabel": "Psalms 37:29",
      "text": "The righteous shall inherit the land, and live in it forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.30",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 30,
      "referenceLabel": "Psalms 37:30",
      "text": "The mouth of the righteous talks of wisdom. His tongue speaks justice.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.31",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 31,
      "referenceLabel": "Psalms 37:31",
      "text": "The law of his God is in his heart. None of his steps shall slide.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.32",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 32,
      "referenceLabel": "Psalms 37:32",
      "text": "The wicked watch the righteous, and seek to kill him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.33",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 33,
      "referenceLabel": "Psalms 37:33",
      "text": "Yahweh will not leave him in his hand, nor condemn him when he is judged.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.34",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 34,
      "referenceLabel": "Psalms 37:34",
      "text": "Wait for Yahweh, and keep his way, and he will exalt you to inherit the land. When the wicked are cut off, you shall see it.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.35",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 35,
      "referenceLabel": "Psalms 37:35",
      "text": "I have seen the wicked in great power, spreading himself like a green tree in its native soil.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.36",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 36,
      "referenceLabel": "Psalms 37:36",
      "text": "But he passed away, and behold, he was not. Yes, I sought him, but he could not be found.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.37",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 37,
      "referenceLabel": "Psalms 37:37",
      "text": "Mark the perfect man, and see the upright, for there is a future for the man of peace.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.38",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 38,
      "referenceLabel": "Psalms 37:38",
      "text": "As for transgressors, they shall be destroyed together. The future of the wicked shall be cut off.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.39",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 39,
      "referenceLabel": "Psalms 37:39",
      "text": "But the salvation of the righteous is from Yahweh. He is their stronghold in the time of trouble.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.37.40",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 40,
      "referenceLabel": "Psalms 37:40",
      "text": "Yahweh helps them and rescues them. He rescues them from the wicked and saves them, because they have taken refuge in him.",
      "paragraphStart": false
    }
  ]
}
