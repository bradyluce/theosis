{
  "chapter": {
    "id": "web:psalms.34",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 34,
    "referenceLabel": "Psalms 34",
    "summary": "Source text for Psalms 34 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.34.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 1,
      "referenceLabel": "Psalms 34:1",
      "text": "I will bless Yahweh at all times. His praise will always be in my mouth.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.34.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 2,
      "referenceLabel": "Psalms 34:2",
      "text": "My soul shall boast in Yahweh. The humble shall hear of it and be glad.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 3,
      "referenceLabel": "Psalms 34:3",
      "text": "Oh magnify Yahweh with me. Let ’s exalt his name together.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 4,
      "referenceLabel": "Psalms 34:4",
      "text": "I sought Yahweh, and he answered me, and delivered me from all my fears.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 5,
      "referenceLabel": "Psalms 34:5",
      "text": "They looked to him, and were radiant. Their faces shall never be covered with shame.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 6,
      "referenceLabel": "Psalms 34:6",
      "text": "This poor man cried, and Yahweh heard him, and saved him out of all his troubles.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 7,
      "referenceLabel": "Psalms 34:7",
      "text": "Yahweh ’s angel encamps around those who fear him, and delivers them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 8,
      "referenceLabel": "Psalms 34:8",
      "text": "Oh taste and see that Yahweh is good. Blessed is the man who takes refuge in him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 9,
      "referenceLabel": "Psalms 34:9",
      "text": "Oh fear Yahweh, you his saints, for there is no lack with those who fear him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 10,
      "referenceLabel": "Psalms 34:10",
      "text": "The young lions do lack, and suffer hunger, but those who seek Yahweh shall not lack any good thing.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 11,
      "referenceLabel": "Psalms 34:11",
      "text": "Come, you children, listen to me. I will teach you the fear of Yahweh.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 12,
      "referenceLabel": "Psalms 34:12",
      "text": "Who is someone who desires life, and loves many days, that he may see good?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 13,
      "referenceLabel": "Psalms 34:13",
      "text": "Keep your tongue from evil, and your lips from speaking lies.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 14,
      "referenceLabel": "Psalms 34:14",
      "text": "Depart from evil, and do good. Seek peace, and pursue it.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 15,
      "referenceLabel": "Psalms 34:15",
      "text": "Yahweh ’s eyes are toward the righteous. His ears listen to their cry.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 16,
      "referenceLabel": "Psalms 34:16",
      "text": "Yahweh ’s face is against those who do evil, to cut off their memory from the earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 17,
      "referenceLabel": "Psalms 34:17",
      "text": "The righteous cry, and Yahweh hears, and delivers them out of all their troubles.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 18,
      "referenceLabel": "Psalms 34:18",
      "text": "Yahweh is near to those who have a broken heart, and saves those who have a crushed spirit.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 19,
      "referenceLabel": "Psalms 34:19",
      "text": "Many are the afflictions of the righteous, but Yahweh delivers him out of them all.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 20,
      "referenceLabel": "Psalms 34:20",
      "text": "He protects all of his bones. Not one of them is broken.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 21,
      "referenceLabel": "Psalms 34:21",
      "text": "Evil shall kill the wicked. Those who hate the righteous shall be condemned.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.34.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 22,
      "referenceLabel": "Psalms 34:22",
      "text": "Yahweh redeems the soul of his servants. None of those who take refuge in him shall be condemned.",
      "paragraphStart": false
    }
  ]
}
