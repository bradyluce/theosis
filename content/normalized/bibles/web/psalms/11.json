{
  "chapter": {
    "id": "web:psalms.11",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 11,
    "referenceLabel": "Psalms 11",
    "summary": "Source text for Psalms 11 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.11.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Psalms 11:1",
      "text": "In Yahweh, I take refuge. How can you say to my soul, “ Flee as a bird to your mountain ”?",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.11.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Psalms 11:2",
      "text": "For, behold, the wicked bend their bows. They set their arrows on the strings, that they may shoot in darkness at the upright in heart.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.11.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Psalms 11:3",
      "text": "If the foundations are destroyed, what can the righteous do?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.11.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Psalms 11:4",
      "text": "Yahweh is in his holy temple. Yahweh is on his throne in heaven. His eyes observe. His eyes examine the children of men.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.11.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Psalms 11:5",
      "text": "Yahweh examines the righteous, but his soul hates the wicked and him who loves violence.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.11.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Psalms 11:6",
      "text": "On the wicked he will rain blazing coals; fire, sulfur, and scorching wind shall be the portion of their cup.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.11.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Psalms 11:7",
      "text": "For Yahweh is righteous. He loves righteousness. The upright shall see his face.",
      "paragraphStart": false
    }
  ]
}
