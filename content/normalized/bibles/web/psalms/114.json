{
  "chapter": {
    "id": "web:psalms.114",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 114,
    "referenceLabel": "Psalms 114",
    "summary": "Source text for Psalms 114 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.114.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 1,
      "referenceLabel": "Psalms 114:1",
      "text": "When Israel went out of Egypt, the house of Jacob from a people of foreign language,",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.114.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 2,
      "referenceLabel": "Psalms 114:2",
      "text": "Judah became his sanctuary, Israel his dominion.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.114.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 3,
      "referenceLabel": "Psalms 114:3",
      "text": "The sea saw it, and fled. The Jordan was driven back.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.114.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 4,
      "referenceLabel": "Psalms 114:4",
      "text": "The mountains skipped like rams, the little hills like lambs.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.114.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 5,
      "referenceLabel": "Psalms 114:5",
      "text": "What was it, you sea, that you fled? You Jordan, that you turned back?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.114.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 6,
      "referenceLabel": "Psalms 114:6",
      "text": "You mountains, that you skipped like rams? You little hills, like lambs?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.114.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 7,
      "referenceLabel": "Psalms 114:7",
      "text": "Tremble, you earth, at the presence of the Lord, at the presence of the God of Jacob,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.114.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 8,
      "referenceLabel": "Psalms 114:8",
      "text": "who turned the rock into a pool of water, the flint into a spring of waters.",
      "paragraphStart": false
    }
  ]
}
