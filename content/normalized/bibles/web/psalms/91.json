{
  "chapter": {
    "id": "web:psalms.91",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 91,
    "referenceLabel": "Psalms 91",
    "summary": "Source text for Psalms 91 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.91.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 1,
      "referenceLabel": "Psalms 91:1",
      "text": "He who dwells in the secret place of the Most High will rest in the shadow of the Almighty.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.91.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 2,
      "referenceLabel": "Psalms 91:2",
      "text": "I will say of Yahweh, “He is my refuge and my fortress; my God, in whom I trust.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.91.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 3,
      "referenceLabel": "Psalms 91:3",
      "text": "For he will deliver you from the snare of the fowler, and from the deadly pestilence.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.91.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 4,
      "referenceLabel": "Psalms 91:4",
      "text": "He will cover you with his feathers. Under his wings you will take refuge. His faithfulness is your shield and rampart.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.91.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 5,
      "referenceLabel": "Psalms 91:5",
      "text": "You shall not be afraid of the terror by night, nor of the arrow that flies by day,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.91.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 6,
      "referenceLabel": "Psalms 91:6",
      "text": "nor of the pestilence that walks in darkness, nor of the destruction that wastes at noonday.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.91.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 7,
      "referenceLabel": "Psalms 91:7",
      "text": "A thousand may fall at your side, and ten thousand at your right hand; but it will not come near you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.91.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 8,
      "referenceLabel": "Psalms 91:8",
      "text": "You will only look with your eyes, and see the recompense of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.91.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 9,
      "referenceLabel": "Psalms 91:9",
      "text": "Because you have made Yahweh your refuge, and the Most High your dwelling place,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.91.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 10,
      "referenceLabel": "Psalms 91:10",
      "text": "no evil shall happen to you, neither shall any plague come near your dwelling.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.91.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 11,
      "referenceLabel": "Psalms 91:11",
      "text": "For he will put his angels in charge of you, to guard you in all your ways.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.91.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 12,
      "referenceLabel": "Psalms 91:12",
      "text": "They will bear you up in their hands, so that you won’t dash your foot against a stone.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.91.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 13,
      "referenceLabel": "Psalms 91:13",
      "text": "You will tread on the lion and cobra. You will trample the young lion and the serpent underfoot.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.91.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 14,
      "referenceLabel": "Psalms 91:14",
      "text": "“Because he has set his love on me, therefore I will deliver him. I will set him on high, because he has known my name.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.91.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 15,
      "referenceLabel": "Psalms 91:15",
      "text": "He will call on me, and I will answer him. I will be with him in trouble. I will deliver him, and honor him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.91.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 16,
      "referenceLabel": "Psalms 91:16",
      "text": "I will satisfy him with long life, and show him my salvation.”",
      "paragraphStart": false
    }
  ]
}
