{
  "chapter": {
    "id": "web:psalms.99",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 99,
    "referenceLabel": "Psalms 99",
    "summary": "Source text for Psalms 99 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.99.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 1,
      "referenceLabel": "Psalms 99:1",
      "text": "Yahweh reigns! Let the peoples tremble. He sits enthroned among the cherubim. Let the earth be moved.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.99.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 2,
      "referenceLabel": "Psalms 99:2",
      "text": "Yahweh is great in Zion. He is high above all the peoples.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.99.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 3,
      "referenceLabel": "Psalms 99:3",
      "text": "Let them praise your great and awesome name. He is Holy!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.99.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 4,
      "referenceLabel": "Psalms 99:4",
      "text": "The King’s strength also loves justice. You establish equity. You execute justice and righteousness in Jacob.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.99.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 5,
      "referenceLabel": "Psalms 99:5",
      "text": "Exalt Yahweh our God. Worship at his footstool. He is Holy!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.99.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 6,
      "referenceLabel": "Psalms 99:6",
      "text": "Moses and Aaron were among his priests, Samuel was among those who call on his name. They called on Yahweh, and he answered them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.99.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 7,
      "referenceLabel": "Psalms 99:7",
      "text": "He spoke to them in the pillar of cloud. They kept his testimonies, the statute that he gave them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.99.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 8,
      "referenceLabel": "Psalms 99:8",
      "text": "You answered them, Yahweh our God. You are a God who forgave them, although you took vengeance for their doings.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.99.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 9,
      "referenceLabel": "Psalms 99:9",
      "text": "Exalt Yahweh, our God. Worship at his holy hill, for Yahweh, our God, is holy!",
      "paragraphStart": false
    }
  ]
}
