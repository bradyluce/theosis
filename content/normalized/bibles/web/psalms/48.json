{
  "chapter": {
    "id": "web:psalms.48",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 48,
    "referenceLabel": "Psalms 48",
    "summary": "Source text for Psalms 48 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.48.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 1,
      "referenceLabel": "Psalms 48:1",
      "text": "Great is Yahweh, and greatly to be praised, in the city of our God, in his holy mountain.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.48.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 2,
      "referenceLabel": "Psalms 48:2",
      "text": "Beautiful in elevation, the joy of the whole earth, is Mount Zion, on the north sides, the city of the great King.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.48.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 3,
      "referenceLabel": "Psalms 48:3",
      "text": "God has shown himself in her citadels as a refuge.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.48.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 4,
      "referenceLabel": "Psalms 48:4",
      "text": "For, behold, the kings assembled themselves, they passed by together.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.48.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 5,
      "referenceLabel": "Psalms 48:5",
      "text": "They saw it, then they were amazed. They were dismayed. They hurried away.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.48.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 6,
      "referenceLabel": "Psalms 48:6",
      "text": "Trembling took hold of them there, pain, as of a woman in travail.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.48.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 7,
      "referenceLabel": "Psalms 48:7",
      "text": "With the east wind, you break the ships of Tarshish.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.48.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 8,
      "referenceLabel": "Psalms 48:8",
      "text": "As we have heard, so we have seen, in the city of Yahweh of Armies, in the city of our God. God will establish it forever. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.48.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 9,
      "referenceLabel": "Psalms 48:9",
      "text": "We have thought about your loving kindness, God, in the middle of your temple.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.48.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 10,
      "referenceLabel": "Psalms 48:10",
      "text": "As is your name, God, so is your praise to the ends of the earth. Your right hand is full of righteousness.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.48.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 11,
      "referenceLabel": "Psalms 48:11",
      "text": "Let Mount Zion be glad! Let the daughters of Judah rejoice because of your judgments.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.48.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 12,
      "referenceLabel": "Psalms 48:12",
      "text": "Walk about Zion, and go around her. Number its towers.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.48.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 13,
      "referenceLabel": "Psalms 48:13",
      "text": "Notice her bulwarks. Consider her palaces, that you may tell it to the next generation.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.48.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 14,
      "referenceLabel": "Psalms 48:14",
      "text": "For this God is our God forever and ever. He will be our guide even to death.",
      "paragraphStart": false
    }
  ]
}
