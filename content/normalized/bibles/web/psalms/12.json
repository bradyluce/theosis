{
  "chapter": {
    "id": "web:psalms.12",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 12,
    "referenceLabel": "Psalms 12",
    "summary": "Source text for Psalms 12 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.12.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Psalms 12:1",
      "text": "Help, Yahweh; for the godly man ceases. For the faithful fail from among the children of men.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.12.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Psalms 12:2",
      "text": "Everyone lies to his neighbor. They speak with flattering lips, and with a double heart.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.12.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Psalms 12:3",
      "text": "May Yahweh cut off all flattering lips, and the tongue that boasts,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.12.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Psalms 12:4",
      "text": "who have said, “With our tongue we will prevail. Our lips are our own. Who is lord over us?”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.12.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Psalms 12:5",
      "text": "“Because of the oppression of the weak and because of the groaning of the needy, I will now arise,” says Yahweh; “I will set him in safety from those who malign him.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.12.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Psalms 12:6",
      "text": "Yahweh’s words are flawless words, as silver refined in a clay furnace, purified seven times.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.12.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Psalms 12:7",
      "text": "You will keep them, Yahweh. You will preserve them from this generation forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.12.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Psalms 12:8",
      "text": "The wicked walk on every side, when what is vile is exalted among the sons of men.",
      "paragraphStart": false
    }
  ]
}
