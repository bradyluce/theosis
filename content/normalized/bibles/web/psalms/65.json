{
  "chapter": {
    "id": "web:psalms.65",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 65,
    "referenceLabel": "Psalms 65",
    "summary": "Source text for Psalms 65 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.65.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 1,
      "referenceLabel": "Psalms 65:1",
      "text": "Praise waits for you, God, in Zion. Vows shall be performed to you.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.65.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 2,
      "referenceLabel": "Psalms 65:2",
      "text": "You who hear prayer, all men will come to you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.65.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 3,
      "referenceLabel": "Psalms 65:3",
      "text": "Sins overwhelmed me, but you atoned for our transgressions.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.65.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 4,
      "referenceLabel": "Psalms 65:4",
      "text": "Blessed is the one whom you choose and cause to come near, that he may live in your courts. We will be filled with the goodness of your house, your holy temple.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.65.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 5,
      "referenceLabel": "Psalms 65:5",
      "text": "By awesome deeds of righteousness, you answer us, God of our salvation. You who are the hope of all the ends of the earth, of those who are far away on the sea.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.65.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 6,
      "referenceLabel": "Psalms 65:6",
      "text": "By your power, you form the mountains, having armed yourself with strength.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.65.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 7,
      "referenceLabel": "Psalms 65:7",
      "text": "You still the roaring of the seas, the roaring of their waves, and the turmoil of the nations.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.65.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 8,
      "referenceLabel": "Psalms 65:8",
      "text": "They also who dwell in faraway places are afraid at your wonders. You call the morning’s dawn and the evening with songs of joy.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.65.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 9,
      "referenceLabel": "Psalms 65:9",
      "text": "You visit the earth, and water it. You greatly enrich it. The river of God is full of water. You provide them grain, for so you have ordained it.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.65.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 10,
      "referenceLabel": "Psalms 65:10",
      "text": "You drench its furrows. You level its ridges. You soften it with showers. You bless it with a crop.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.65.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 11,
      "referenceLabel": "Psalms 65:11",
      "text": "You crown the year with your bounty. Your carts overflow with abundance.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.65.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 12,
      "referenceLabel": "Psalms 65:12",
      "text": "The wilderness grasslands overflow. The hills are clothed with gladness.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.65.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 13,
      "referenceLabel": "Psalms 65:13",
      "text": "The pastures are covered with flocks. The valleys also are clothed with grain. They shout for joy! They also sing.",
      "paragraphStart": false
    }
  ]
}
