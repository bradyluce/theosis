{
  "chapter": {
    "id": "web:psalms.132",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 132,
    "referenceLabel": "Psalms 132",
    "summary": "Source text for Psalms 132 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.132.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 1,
      "referenceLabel": "Psalms 132:1",
      "text": "Yahweh, remember David and all his affliction,",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.132.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 2,
      "referenceLabel": "Psalms 132:2",
      "text": "how he swore to Yahweh, and vowed to the Mighty One of Jacob:",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.132.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 3,
      "referenceLabel": "Psalms 132:3",
      "text": "“ Surely I will not come into the structure of my house, nor go up into my bed;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.132.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 4,
      "referenceLabel": "Psalms 132:4",
      "text": "I will not give sleep to my eyes, or slumber to my eyelids,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.132.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 5,
      "referenceLabel": "Psalms 132:5",
      "text": "until I find out a place for Yahweh, a dwelling for the Mighty One of Jacob.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.132.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 6,
      "referenceLabel": "Psalms 132:6",
      "text": "Behold, we heard of it in Ephrathah. We found it in the field of Jaar.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.132.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 7,
      "referenceLabel": "Psalms 132:7",
      "text": "“We will go into his dwelling place. We will worship at his footstool.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.132.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 8,
      "referenceLabel": "Psalms 132:8",
      "text": "Arise, Yahweh, into your resting place, you, and the ark of your strength.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.132.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 9,
      "referenceLabel": "Psalms 132:9",
      "text": "Let your priests be clothed with righteousness. Let your saints shout for joy!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.132.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 10,
      "referenceLabel": "Psalms 132:10",
      "text": "For your servant David ’s sake, don’t turn away the face of your anointed one.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.132.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 11,
      "referenceLabel": "Psalms 132:11",
      "text": "Yahweh has sworn to David in truth. He will not turn from it: “ I will set the fruit of your body on your throne.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.132.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 12,
      "referenceLabel": "Psalms 132:12",
      "text": "If your children will keep my covenant, my testimony that I will teach them, their children also will sit on your throne forever more.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.132.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 13,
      "referenceLabel": "Psalms 132:13",
      "text": "For Yahweh has chosen Zion. He has desired it for his habitation.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.132.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 14,
      "referenceLabel": "Psalms 132:14",
      "text": "“ This is my resting place forever. I will live here, for I have desired it.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.132.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 15,
      "referenceLabel": "Psalms 132:15",
      "text": "I will abundantly bless her provision. I will satisfy her poor with bread.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.132.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 16,
      "referenceLabel": "Psalms 132:16",
      "text": "I will also clothe her priests with salvation. Her saints will shout aloud for joy.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.132.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 17,
      "referenceLabel": "Psalms 132:17",
      "text": "I will make the horn of David to bud there. I have ordained a lamp for my anointed.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.132.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 18,
      "referenceLabel": "Psalms 132:18",
      "text": "I will clothe his enemies with shame, but on himself, his crown will shine.”",
      "paragraphStart": false
    }
  ]
}
