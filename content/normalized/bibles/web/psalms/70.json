  "verses": [
    {
      "id": "web:psalms.70.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 1,
      "referenceLabel": "Psalms 70:1",
      "text": "Hurry, God, to deliver me. Come quickly to help me, Yahweh.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.70.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 2,
      "referenceLabel": "Psalms 70:2",
      "text": "Let them be disappointed and confounded who seek my soul. Let those who desire my ruin be turned back in disgrace.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.70.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 3,
      "referenceLabel": "Psalms 70:3",
      "text": "Let them be turned because of their shame who say, “Aha! Aha!”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.70.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 4,
      "referenceLabel": "Psalms 70:4",
      "text": "Let all those who seek you rejoice and be glad in you. Let those who love your salvation continually say, “Let God be exalted!”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.70.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 5,
      "referenceLabel": "Psalms 70:5",
      "text": "But I am poor and needy. Come to me quickly, God. You are my help and my deliverer. Yahweh, don’t delay.",
      "paragraphStart": false
    }
  ]
}
