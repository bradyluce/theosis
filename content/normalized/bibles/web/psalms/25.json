{
  "chapter": {
    "id": "web:psalms.25",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 25,
    "referenceLabel": "Psalms 25",
    "summary": "Source text for Psalms 25 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.25.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Psalms 25:1",
      "text": "To you, Yahweh, I lift up my soul.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.25.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Psalms 25:2",
      "text": "My God, I have trusted in you. Don’t let me be shamed. Don’t let my enemies triumph over me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Psalms 25:3",
      "text": "Yes, no one who waits for you will be shamed. They will be shamed who deal treacherously without cause.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Psalms 25:4",
      "text": "Show me your ways, Yahweh. Teach me your paths.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Psalms 25:5",
      "text": "Guide me in your truth, and teach me, for you are the God of my salvation. I wait for you all day long.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Psalms 25:6",
      "text": "Yahweh, remember your tender mercies and your loving kindness, for they are from old times.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Psalms 25:7",
      "text": "Don’t remember the sins of my youth, nor my transgressions. Remember me according to your loving kindness, for your goodness ’ sake, Yahweh.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Psalms 25:8",
      "text": "Good and upright is Yahweh, therefore he will instruct sinners in the way.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Psalms 25:9",
      "text": "He will guide the humble in justice. He will teach the humble his way.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Psalms 25:10",
      "text": "All the paths of Yahweh are loving kindness and truth to such as keep his covenant and his testimonies.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Psalms 25:11",
      "text": "For your name ’s sake, Yahweh, pardon my iniquity, for it is great.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Psalms 25:12",
      "text": "What man is he who fears Yahweh? He shall instruct him in the way that he shall choose.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "Psalms 25:13",
      "text": "His soul will dwell at ease. His offspring will inherit the land.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "Psalms 25:14",
      "text": "The friendship of Yahweh is with those who fear him. He will show them his covenant.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 15,
      "referenceLabel": "Psalms 25:15",
      "text": "My eyes are ever on Yahweh, for he will pluck my feet out of the net.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 16,
      "referenceLabel": "Psalms 25:16",
      "text": "Turn to me, and have mercy on me, for I am desolate and afflicted.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 17,
      "referenceLabel": "Psalms 25:17",
      "text": "The troubles of my heart are enlarged. Oh bring me out of my distresses.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 18,
      "referenceLabel": "Psalms 25:18",
      "text": "Consider my affliction and my travail. Forgive all my sins.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 19,
      "referenceLabel": "Psalms 25:19",
      "text": "Consider my enemies, for they are many. They hate me with cruel hatred.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 20,
      "referenceLabel": "Psalms 25:20",
      "text": "Oh keep my soul, and deliver me. Let me not be disappointed, for I take refuge in you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 21,
      "referenceLabel": "Psalms 25:21",
      "text": "Let integrity and uprightness preserve me, for I wait for you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.25.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 22,
      "referenceLabel": "Psalms 25:22",
      "text": "God, redeem Israel out of all his troubles.",
      "paragraphStart": false
    }
  ]
}
