{
  "chapter": {
    "id": "web:psalms.24",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 24,
    "referenceLabel": "Psalms 24",
    "summary": "Source text for Psalms 24 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.24.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Psalms 24:1",
      "text": "The earth is Yahweh ’s, with its fullness; the world, and those who dwell in it.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.24.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Psalms 24:2",
      "text": "For he has founded it on the seas, and established it on the floods.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.24.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Psalms 24:3",
      "text": "Who may ascend to Yahweh ’s hill? Who may stand in his holy place?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.24.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Psalms 24:4",
      "text": "He who has clean hands and a pure heart; who has not lifted up his soul to falsehood, and has not sworn deceitfully.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.24.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Psalms 24:5",
      "text": "He shall receive a blessing from Yahweh, righteousness from the God of his salvation.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.24.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Psalms 24:6",
      "text": "This is the generation of those who seek Him, who seek your face —even Jacob. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.24.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Psalms 24:7",
      "text": "Lift up your heads, you gates! Be lifted up, you everlasting doors, and the King of glory will come in.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.24.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Psalms 24:8",
      "text": "Who is the King of glory? Yahweh strong and mighty, Yahweh mighty in battle.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.24.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Psalms 24:9",
      "text": "Lift up your heads, you gates; yes, lift them up, you everlasting doors, and the King of glory will come in.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.24.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Psalms 24:10",
      "text": "Who is this King of glory? Yahweh of Armies is the King of glory! Selah.",
      "paragraphStart": false
    }
  ]
}
