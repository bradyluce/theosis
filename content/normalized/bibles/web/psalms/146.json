{
  "chapter": {
    "id": "web:psalms.146",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 146,
    "referenceLabel": "Psalms 146",
    "summary": "Source text for Psalms 146 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.146.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 1,
      "referenceLabel": "Psalms 146:1",
      "text": "Praise Yah! Praise Yahweh, my soul.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.146.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 2,
      "referenceLabel": "Psalms 146:2",
      "text": "While I live, I will praise Yahweh. I will sing praises to my God as long as I exist.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.146.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 3,
      "referenceLabel": "Psalms 146:3",
      "text": "Don’t put your trust in princes, in a son of man in whom there is no help.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.146.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 4,
      "referenceLabel": "Psalms 146:4",
      "text": "His spirit departs, and he returns to the earth. In that very day, his thoughts perish.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.146.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 5,
      "referenceLabel": "Psalms 146:5",
      "text": "Happy is he who has the God of Jacob for his help, whose hope is in Yahweh, his God,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.146.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 6,
      "referenceLabel": "Psalms 146:6",
      "text": "who made heaven and earth, the sea, and all that is in them; who keeps truth forever;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.146.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 7,
      "referenceLabel": "Psalms 146:7",
      "text": "who executes justice for the oppressed; who gives food to the hungry. Yahweh frees the prisoners.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.146.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 8,
      "referenceLabel": "Psalms 146:8",
      "text": "Yahweh opens the eyes of the blind. Yahweh raises up those who are bowed down. Yahweh loves the righteous.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.146.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 9,
      "referenceLabel": "Psalms 146:9",
      "text": "Yahweh preserves the foreigners. He upholds the fatherless and widow, but he turns the way of the wicked upside down.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.146.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 10,
      "referenceLabel": "Psalms 146:10",
      "text": "Yahweh will reign forever; your God, O Zion, to all generations. Praise Yah!",
      "paragraphStart": false
    }
  ]
}
