{
  "chapter": {
    "id": "web:psalms.92",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 92,
    "referenceLabel": "Psalms 92",
    "summary": "Source text for Psalms 92 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.92.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 1,
      "referenceLabel": "Psalms 92:1",
      "text": "It is a good thing to give thanks to Yahweh, to sing praises to your name, Most High,",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.92.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 2,
      "referenceLabel": "Psalms 92:2",
      "text": "to proclaim your loving kindness in the morning, and your faithfulness every night,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.92.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 3,
      "referenceLabel": "Psalms 92:3",
      "text": "with the ten-stringed lute, with the harp, and with the melody of the lyre.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.92.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 4,
      "referenceLabel": "Psalms 92:4",
      "text": "For you, Yahweh, have made me glad through your work. I will triumph in the works of your hands.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.92.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 5,
      "referenceLabel": "Psalms 92:5",
      "text": "How great are your works, Yahweh! Your thoughts are very deep.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.92.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 6,
      "referenceLabel": "Psalms 92:6",
      "text": "A senseless man doesn’t know, neither does a fool understand this:",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.92.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 7,
      "referenceLabel": "Psalms 92:7",
      "text": "though the wicked spring up as the grass, and all the evildoers flourish, they will be destroyed forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.92.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 8,
      "referenceLabel": "Psalms 92:8",
      "text": "But you, Yahweh, are on high forever more.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.92.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 9,
      "referenceLabel": "Psalms 92:9",
      "text": "For behold, your enemies, Yahweh, for behold, your enemies shall perish. All the evildoers will be scattered.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.92.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 10,
      "referenceLabel": "Psalms 92:10",
      "text": "But you have exalted my horn like that of the wild ox. I am anointed with fresh oil.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.92.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 11,
      "referenceLabel": "Psalms 92:11",
      "text": "My eye has also seen my enemies. My ears have heard of the wicked enemies who rise up against me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.92.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 12,
      "referenceLabel": "Psalms 92:12",
      "text": "The righteous shall flourish like the palm tree. He will grow like a cedar in Lebanon.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.92.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 13,
      "referenceLabel": "Psalms 92:13",
      "text": "They are planted in Yahweh ’s house. They will flourish in our God’s courts.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.92.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 14,
      "referenceLabel": "Psalms 92:14",
      "text": "They will still produce fruit in old age. They will be full of sap and green,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.92.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 15,
      "referenceLabel": "Psalms 92:15",
      "text": "to show that Yahweh is upright. He is my rock, and there is no unrighteousness in him.",
      "paragraphStart": false
    }
  ]
}
