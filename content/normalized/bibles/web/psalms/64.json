{
  "chapter": {
    "id": "web:psalms.64",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 64,
    "referenceLabel": "Psalms 64",
    "summary": "Source text for Psalms 64 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.64.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 1,
      "referenceLabel": "Psalms 64:1",
      "text": "Hear my voice, God, in my complaint. Preserve my life from fear of the enemy.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.64.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 2,
      "referenceLabel": "Psalms 64:2",
      "text": "Hide me from the conspiracy of the wicked, from the noisy crowd of the ones doing evil;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.64.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 3,
      "referenceLabel": "Psalms 64:3",
      "text": "who sharpen their tongue like a sword, and aim their arrows, deadly words,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.64.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 4,
      "referenceLabel": "Psalms 64:4",
      "text": "to shoot innocent men from ambushes. They shoot at him suddenly and fearlessly.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.64.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 5,
      "referenceLabel": "Psalms 64:5",
      "text": "They encourage themselves in evil plans. They talk about laying snares secretly. They say, “Who will see them?”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.64.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 6,
      "referenceLabel": "Psalms 64:6",
      "text": "They plot injustice, saying, “We have made a perfect plan!” Surely man’s mind and heart are cunning.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.64.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 7,
      "referenceLabel": "Psalms 64:7",
      "text": "But God will shoot at them. They will be suddenly struck down with an arrow.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.64.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 8,
      "referenceLabel": "Psalms 64:8",
      "text": "Their own tongues shall ruin them. All who see them will shake their heads.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.64.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 9,
      "referenceLabel": "Psalms 64:9",
      "text": "All mankind shall be afraid. They shall declare the work of God, and shall wisely ponder what he has done.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.64.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 10,
      "referenceLabel": "Psalms 64:10",
      "text": "The righteous shall be glad in Yahweh, and shall take refuge in him. All the upright in heart shall praise him!",
      "paragraphStart": false
    }
  ]
}
