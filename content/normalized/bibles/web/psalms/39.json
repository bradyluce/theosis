{
  "chapter": {
    "id": "web:psalms.39",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 39,
    "referenceLabel": "Psalms 39",
    "summary": "Source text for Psalms 39 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.39.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 39,
      "verseNumber": 1,
      "referenceLabel": "Psalms 39:1",
      "text": "I said, “I will watch my ways, so that I don’t sin with my tongue. I will keep my mouth with a bridle while the wicked is before me.”",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.39.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 39,
      "verseNumber": 2,
      "referenceLabel": "Psalms 39:2",
      "text": "I was mute with silence. I held my peace, even from good. My sorrow was stirred.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.39.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 39,
      "verseNumber": 3,
      "referenceLabel": "Psalms 39:3",
      "text": "My heart was hot within me. While I meditated, the fire burned. I spoke with my tongue:",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.39.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 39,
      "verseNumber": 4,
      "referenceLabel": "Psalms 39:4",
      "text": "“Yahweh, show me my end, what is the measure of my days. Let me know how frail I am.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.39.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 39,
      "verseNumber": 5,
      "referenceLabel": "Psalms 39:5",
      "text": "Behold, you have made my days hand widths. My lifetime is as nothing before you. Surely every man stands as a breath.” Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.39.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 39,
      "verseNumber": 6,
      "referenceLabel": "Psalms 39:6",
      "text": "“Surely every man walks like a shadow. Surely they busy themselves in vain. He heaps up, and doesn’t know who shall gather.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.39.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 39,
      "verseNumber": 7,
      "referenceLabel": "Psalms 39:7",
      "text": "Now, Lord, what do I wait for? My hope is in you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.39.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 39,
      "verseNumber": 8,
      "referenceLabel": "Psalms 39:8",
      "text": "Deliver me from all my transgressions. Don’t make me the reproach of the foolish.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.39.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 39,
      "verseNumber": 9,
      "referenceLabel": "Psalms 39:9",
      "text": "I was mute. I didn’t open my mouth, because you did it.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.39.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 39,
      "verseNumber": 10,
      "referenceLabel": "Psalms 39:10",
      "text": "Remove your scourge away from me. I am overcome by the blow of your hand.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.39.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 39,
      "verseNumber": 11,
      "referenceLabel": "Psalms 39:11",
      "text": "When you rebuke and correct man for iniquity, you consume his wealth like a moth. Surely every man is but a breath.” Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.39.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 39,
      "verseNumber": 12,
      "referenceLabel": "Psalms 39:12",
      "text": "“Hear my prayer, Yahweh, and give ear to my cry. Don’t be silent at my tears. For I am a stranger with you, a foreigner, as all my fathers were.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.39.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 39,
      "verseNumber": 13,
      "referenceLabel": "Psalms 39:13",
      "text": "Oh spare me, that I may recover strength, before I go away and exist no more.”",
      "paragraphStart": false
    }
  ]
}
