{
  "chapter": {
    "id": "web:psalms.109",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 109,
    "referenceLabel": "Psalms 109",
    "summary": "Source text for Psalms 109 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.109.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 1,
      "referenceLabel": "Psalms 109:1",
      "text": "God of my praise, don’t remain silent,",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.109.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 2,
      "referenceLabel": "Psalms 109:2",
      "text": "for they have opened the mouth of the wicked and the mouth of deceit against me. They have spoken to me with a lying tongue.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 3,
      "referenceLabel": "Psalms 109:3",
      "text": "They have also surrounded me with words of hatred, and fought against me without a cause.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 4,
      "referenceLabel": "Psalms 109:4",
      "text": "In return for my love, they are my adversaries; but I am in prayer.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 5,
      "referenceLabel": "Psalms 109:5",
      "text": "They have rewarded me evil for good, and hatred for my love.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 6,
      "referenceLabel": "Psalms 109:6",
      "text": "Set a wicked man over him. Let an adversary stand at his right hand.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 7,
      "referenceLabel": "Psalms 109:7",
      "text": "When he is judged, let him come out guilty. Let his prayer be turned into sin.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 8,
      "referenceLabel": "Psalms 109:8",
      "text": "Let his days be few. Let another take his office.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 9,
      "referenceLabel": "Psalms 109:9",
      "text": "Let his children be fatherless, and his wife a widow.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 10,
      "referenceLabel": "Psalms 109:10",
      "text": "Let his children be wandering beggars. Let them be sought from their ruins.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 11,
      "referenceLabel": "Psalms 109:11",
      "text": "Let the creditor seize all that he has. Let strangers plunder the fruit of his labor.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 12,
      "referenceLabel": "Psalms 109:12",
      "text": "Let there be no one to extend kindness to him, neither let there be anyone to have pity on his fatherless children.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 13,
      "referenceLabel": "Psalms 109:13",
      "text": "Let his posterity be cut off. In the generation following let their name be blotted out.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 14,
      "referenceLabel": "Psalms 109:14",
      "text": "Let the iniquity of his fathers be remembered by Yahweh. Don’t let the sin of his mother be blotted out.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 15,
      "referenceLabel": "Psalms 109:15",
      "text": "Let them be before Yahweh continually, that he may cut off their memory from the earth;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 16,
      "referenceLabel": "Psalms 109:16",
      "text": "because he didn’t remember to show kindness, but persecuted the poor and needy man, the broken in heart, to kill them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 17,
      "referenceLabel": "Psalms 109:17",
      "text": "Yes, he loved cursing, and it came to him. He didn’t delight in blessing, and it was far from him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 18,
      "referenceLabel": "Psalms 109:18",
      "text": "He clothed himself also with cursing as with his garment. It came into his inward parts like water, like oil into his bones.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 19,
      "referenceLabel": "Psalms 109:19",
      "text": "Let it be to him as the clothing with which he covers himself, for the belt that is always around him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 20,
      "referenceLabel": "Psalms 109:20",
      "text": "This is the reward of my adversaries from Yahweh, of those who speak evil against my soul.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 21,
      "referenceLabel": "Psalms 109:21",
      "text": "But deal with me, Yahweh the Lord, for your name ’s sake, because your loving kindness is good, deliver me;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 22,
      "referenceLabel": "Psalms 109:22",
      "text": "for I am poor and needy. My heart is wounded within me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.23",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 23,
      "referenceLabel": "Psalms 109:23",
      "text": "I fade away like an evening shadow. I am shaken off like a locust.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.24",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 24,
      "referenceLabel": "Psalms 109:24",
      "text": "My knees are weak through fasting. My body is thin and lacks fat.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.25",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 25,
      "referenceLabel": "Psalms 109:25",
      "text": "I have also become a reproach to them. When they see me, they shake their head.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.26",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 26,
      "referenceLabel": "Psalms 109:26",
      "text": "Help me, Yahweh, my God. Save me according to your loving kindness;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.27",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 27,
      "referenceLabel": "Psalms 109:27",
      "text": "that they may know that this is your hand; that you, Yahweh, have done it.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.28",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 28,
      "referenceLabel": "Psalms 109:28",
      "text": "They may curse, but you bless. When they arise, they will be shamed, but your servant shall rejoice.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.29",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 29,
      "referenceLabel": "Psalms 109:29",
      "text": "Let my adversaries be clothed with dishonor. Let them cover themselves with their own shame as with a robe.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.30",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 30,
      "referenceLabel": "Psalms 109:30",
      "text": "I will give great thanks to Yahweh with my mouth. Yes, I will praise him among the multitude.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.109.31",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 31,
      "referenceLabel": "Psalms 109:31",
      "text": "For he will stand at the right hand of the needy, to save him from those who judge his soul.",
      "paragraphStart": false
    }
  ]
}
