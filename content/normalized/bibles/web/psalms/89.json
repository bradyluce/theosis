{
  "chapter": {
    "id": "web:psalms.89",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 89,
    "referenceLabel": "Psalms 89",
    "summary": "Source text for Psalms 89 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.89.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 1,
      "referenceLabel": "Psalms 89:1",
      "text": "I will sing of the loving kindness of Yahweh forever. With my mouth, I will make known your faithfulness to all generations.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.89.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 2,
      "referenceLabel": "Psalms 89:2",
      "text": "I indeed declare, “ Love stands firm forever. You established the heavens. Your faithfulness is in them.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 3,
      "referenceLabel": "Psalms 89:3",
      "text": "“ I have made a covenant with my chosen one, I have sworn to David, my servant,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 4,
      "referenceLabel": "Psalms 89:4",
      "text": "‘ I will establish your offspring forever, and build up your throne to all generations.’” Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 5,
      "referenceLabel": "Psalms 89:5",
      "text": "The heavens will praise your wonders, Yahweh, your faithfulness also in the assembly of the holy ones.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 6,
      "referenceLabel": "Psalms 89:6",
      "text": "For who in the skies can be compared to Yahweh? Who among the sons of the heavenly beings is like Yahweh,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 7,
      "referenceLabel": "Psalms 89:7",
      "text": "a very awesome God in the council of the holy ones, to be feared above all those who are around him?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 8,
      "referenceLabel": "Psalms 89:8",
      "text": "Yahweh, God of Armies, who is a mighty one, like you? Yah, your faithfulness is around you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 9,
      "referenceLabel": "Psalms 89:9",
      "text": "You rule the pride of the sea. When its waves rise up, you calm them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 10,
      "referenceLabel": "Psalms 89:10",
      "text": "You have broken Rahab in pieces, like one of the slain. You have scattered your enemies with your mighty arm.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 11,
      "referenceLabel": "Psalms 89:11",
      "text": "The heavens are yours. The earth also is yours, the world and its fullness. You have founded them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 12,
      "referenceLabel": "Psalms 89:12",
      "text": "You have created the north and the south. Tabor and Hermon rejoice in your name.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 13,
      "referenceLabel": "Psalms 89:13",
      "text": "You have a mighty arm. Your hand is strong, and your right hand is exalted.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 14,
      "referenceLabel": "Psalms 89:14",
      "text": "Righteousness and justice are the foundation of your throne. Loving kindness and truth go before your face.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 15,
      "referenceLabel": "Psalms 89:15",
      "text": "Blessed are the people who learn to acclaim you. They walk in the light of your presence, Yahweh.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 16,
      "referenceLabel": "Psalms 89:16",
      "text": "In your name they rejoice all day. In your righteousness, they are exalted.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 17,
      "referenceLabel": "Psalms 89:17",
      "text": "For you are the glory of their strength. In your favor, our horn will be exalted.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 18,
      "referenceLabel": "Psalms 89:18",
      "text": "For our shield belongs to Yahweh, our king to the Holy One of Israel.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 19,
      "referenceLabel": "Psalms 89:19",
      "text": "Then you spoke in vision to your saints, and said, “ I have given strength to the warrior. I have exalted a young man from the people.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 20,
      "referenceLabel": "Psalms 89:20",
      "text": "I have found David, my servant. I have anointed him with my holy oil,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 21,
      "referenceLabel": "Psalms 89:21",
      "text": "with whom my hand shall be established. My arm will also strengthen him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 22,
      "referenceLabel": "Psalms 89:22",
      "text": "No enemy will tax him. No wicked man will oppress him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.23",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 23,
      "referenceLabel": "Psalms 89:23",
      "text": "I will beat down his adversaries before him, and strike those who hate him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.24",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 24,
      "referenceLabel": "Psalms 89:24",
      "text": "But my faithfulness and my loving kindness will be with him. In my name, his horn will be exalted.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.25",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 25,
      "referenceLabel": "Psalms 89:25",
      "text": "I will set his hand also on the sea, and his right hand on the rivers.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.26",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 26,
      "referenceLabel": "Psalms 89:26",
      "text": "He will call to me, ‘ You are my Father, my God, and the rock of my salvation!’",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.27",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 27,
      "referenceLabel": "Psalms 89:27",
      "text": "I will also appoint him my firstborn, the highest of the kings of the earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.28",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 28,
      "referenceLabel": "Psalms 89:28",
      "text": "I will keep my loving kindness for him forever more. My covenant will stand firm with him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.29",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 29,
      "referenceLabel": "Psalms 89:29",
      "text": "I will also make his offspring endure forever, and his throne as the days of heaven.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.30",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 30,
      "referenceLabel": "Psalms 89:30",
      "text": "If his children forsake my law, and don’t walk in my ordinances;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.31",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 31,
      "referenceLabel": "Psalms 89:31",
      "text": "if they break my statutes, and don’t keep my commandments;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.32",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 32,
      "referenceLabel": "Psalms 89:32",
      "text": "then I will punish their sin with the rod, and their iniquity with stripes.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.33",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 33,
      "referenceLabel": "Psalms 89:33",
      "text": "But I will not completely take my loving kindness from him, nor allow my faithfulness to fail.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.34",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 34,
      "referenceLabel": "Psalms 89:34",
      "text": "I will not break my covenant, nor alter what my lips have uttered.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.35",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 35,
      "referenceLabel": "Psalms 89:35",
      "text": "Once I have sworn by my holiness, I will not lie to David.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.36",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 36,
      "referenceLabel": "Psalms 89:36",
      "text": "His offspring will endure forever, his throne like the sun before me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.37",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 37,
      "referenceLabel": "Psalms 89:37",
      "text": "It will be established forever like the moon, the faithful witness in the sky.” Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.38",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 38,
      "referenceLabel": "Psalms 89:38",
      "text": "But you have rejected and spurned. You have been angry with your anointed.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.39",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 39,
      "referenceLabel": "Psalms 89:39",
      "text": "You have renounced the covenant of your servant. You have defiled his crown in the dust.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.40",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 40,
      "referenceLabel": "Psalms 89:40",
      "text": "You have broken down all his hedges. You have brought his strongholds to ruin.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.41",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 41,
      "referenceLabel": "Psalms 89:41",
      "text": "All who pass by the way rob him. He has become a reproach to his neighbors.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.42",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 42,
      "referenceLabel": "Psalms 89:42",
      "text": "You have exalted the right hand of his adversaries. You have made all of his enemies rejoice.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.43",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 43,
      "referenceLabel": "Psalms 89:43",
      "text": "Yes, you turn back the edge of his sword, and haven’t supported him in battle.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.44",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 44,
      "referenceLabel": "Psalms 89:44",
      "text": "You have ended his splendor, and thrown his throne down to the ground.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.45",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 45,
      "referenceLabel": "Psalms 89:45",
      "text": "You have shortened the days of his youth. You have covered him with shame. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.46",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 46,
      "referenceLabel": "Psalms 89:46",
      "text": "How long, Yahweh? Will you hide yourself forever? Will your wrath burn like fire?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.47",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 47,
      "referenceLabel": "Psalms 89:47",
      "text": "Remember how short my time is, for what vanity you have created all the children of men!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.48",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 48,
      "referenceLabel": "Psalms 89:48",
      "text": "What man is he who shall live and not see death, who shall deliver his soul from the power of Sheol? Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.49",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 49,
      "referenceLabel": "Psalms 89:49",
      "text": "Lord, where are your former loving kindnesses, which you swore to David in your faithfulness?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.50",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 50,
      "referenceLabel": "Psalms 89:50",
      "text": "Remember, Lord, the reproach of your servants, how I bear in my heart the taunts of all the mighty peoples,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.51",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 51,
      "referenceLabel": "Psalms 89:51",
      "text": "With which your enemies have mocked, Yahweh, with which they have mocked the footsteps of your anointed one.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.89.52",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 52,
      "referenceLabel": "Psalms 89:52",
      "text": "Blessed be Yahweh forever more. Amen, and Amen.",
      "paragraphStart": false
    }
  ]
}
