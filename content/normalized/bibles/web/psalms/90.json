{
  "chapter": {
    "id": "web:psalms.90",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 90,
    "referenceLabel": "Psalms 90",
    "summary": "Source text for Psalms 90 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.90.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 1,
      "referenceLabel": "Psalms 90:1",
      "text": "Lord, you have been our dwelling place for all generations.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.90.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 2,
      "referenceLabel": "Psalms 90:2",
      "text": "Before the mountains were born, before you had formed the earth and the world, even from everlasting to everlasting, you are God.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.90.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 3,
      "referenceLabel": "Psalms 90:3",
      "text": "You turn man to destruction, saying, “ Return, you children of men.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.90.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 4,
      "referenceLabel": "Psalms 90:4",
      "text": "For a thousand years in your sight are just like yesterday when it is past, like a watch in the night.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.90.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 5,
      "referenceLabel": "Psalms 90:5",
      "text": "You sweep them away as they sleep. In the morning they sprout like new grass.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.90.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 6,
      "referenceLabel": "Psalms 90:6",
      "text": "In the morning it sprouts and springs up. By evening, it is withered and dry.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.90.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 7,
      "referenceLabel": "Psalms 90:7",
      "text": "For we are consumed in your anger. We are troubled in your wrath.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.90.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 8,
      "referenceLabel": "Psalms 90:8",
      "text": "You have set our iniquities before you, our secret sins in the light of your presence.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.90.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 9,
      "referenceLabel": "Psalms 90:9",
      "text": "For all our days have passed away in your wrath. We bring our years to an end as a sigh.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.90.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 10,
      "referenceLabel": "Psalms 90:10",
      "text": "The days of our years are seventy, or even by reason of strength eighty years; yet their pride is but labor and sorrow, for it passes quickly, and we fly away.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.90.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 11,
      "referenceLabel": "Psalms 90:11",
      "text": "Who knows the power of your anger, your wrath according to the fear that is due to you?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.90.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 12,
      "referenceLabel": "Psalms 90:12",
      "text": "So teach us to count our days, that we may gain a heart of wisdom.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.90.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 13,
      "referenceLabel": "Psalms 90:13",
      "text": "Relent, Yahweh! How long? Have compassion on your servants!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.90.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 14,
      "referenceLabel": "Psalms 90:14",
      "text": "Satisfy us in the morning with your loving kindness, that we may rejoice and be glad all our days.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.90.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 15,
      "referenceLabel": "Psalms 90:15",
      "text": "Make us glad for as many days as you have afflicted us, for as many years as we have seen evil.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.90.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 16,
      "referenceLabel": "Psalms 90:16",
      "text": "Let your work appear to your servants, your glory to their children.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.90.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 17,
      "referenceLabel": "Psalms 90:17",
      "text": "Let the favor of the Lord our God be on us. Establish the work of our hands for us. Yes, establish the work of our hands.",
      "paragraphStart": false
    }
  ]
}
