{
  "chapter": {
    "id": "web:psalms.139",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 139,
    "referenceLabel": "Psalms 139",
    "summary": "Source text for Psalms 139 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.139.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 1,
      "referenceLabel": "Psalms 139:1",
      "text": "Yahweh, you have searched me, and you know me.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.139.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 2,
      "referenceLabel": "Psalms 139:2",
      "text": "You know my sitting down and my rising up. You perceive my thoughts from afar.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 3,
      "referenceLabel": "Psalms 139:3",
      "text": "You search out my path and my lying down, and are acquainted with all my ways.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 4,
      "referenceLabel": "Psalms 139:4",
      "text": "For there is not a word on my tongue, but behold, Yahweh, you know it altogether.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 5,
      "referenceLabel": "Psalms 139:5",
      "text": "You hem me in behind and before. You laid your hand on me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 6,
      "referenceLabel": "Psalms 139:6",
      "text": "This knowledge is beyond me. It ’s lofty. I can ’t attain it.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 7,
      "referenceLabel": "Psalms 139:7",
      "text": "Where could I go from your Spirit? Or where could I flee from your presence?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 8,
      "referenceLabel": "Psalms 139:8",
      "text": "If I ascend up into heaven, you are there. If I make my bed in Sheol, behold, you are there!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 9,
      "referenceLabel": "Psalms 139:9",
      "text": "If I take the wings of the dawn, and settle in the uttermost parts of the sea,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 10,
      "referenceLabel": "Psalms 139:10",
      "text": "even there your hand will lead me, and your right hand will hold me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 11,
      "referenceLabel": "Psalms 139:11",
      "text": "If I say, “Surely the darkness will overwhelm me. The light around me will be night,”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 12,
      "referenceLabel": "Psalms 139:12",
      "text": "even the darkness doesn’t hide from you, but the night shines as the day. The darkness is like light to you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 13,
      "referenceLabel": "Psalms 139:13",
      "text": "For you formed my inmost being. You knit me together in my mother’s womb.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 14,
      "referenceLabel": "Psalms 139:14",
      "text": "I will give thanks to you, for I am fearfully and wonderfully made. Your works are wonderful. My soul knows that very well.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 15,
      "referenceLabel": "Psalms 139:15",
      "text": "My frame wasn’t hidden from you, when I was made in secret, woven together in the depths of the earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 16,
      "referenceLabel": "Psalms 139:16",
      "text": "Your eyes saw my body. In your book they were all written, the days that were ordained for me, when as yet there were none of them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 17,
      "referenceLabel": "Psalms 139:17",
      "text": "How precious to me are your thoughts, God! How vast is their sum!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 18,
      "referenceLabel": "Psalms 139:18",
      "text": "If I would count them, they are more in number than the sand. When I wake up, I am still with you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 19,
      "referenceLabel": "Psalms 139:19",
      "text": "If only you, God, would kill the wicked. Get away from me, you bloodthirsty men!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 20,
      "referenceLabel": "Psalms 139:20",
      "text": "For they speak against you wickedly. Your enemies take your name in vain.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 21,
      "referenceLabel": "Psalms 139:21",
      "text": "Yahweh, don’t I hate those who hate you? Am I not grieved with those who rise up against you?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 22,
      "referenceLabel": "Psalms 139:22",
      "text": "I hate them with perfect hatred. They have become my enemies.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.23",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 23,
      "referenceLabel": "Psalms 139:23",
      "text": "Search me, God, and know my heart. Try me, and know my thoughts.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.139.24",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 24,
      "referenceLabel": "Psalms 139:24",
      "text": "See if there is any wicked way in me, and lead me in the everlasting way.",
      "paragraphStart": false
    }
  ]
}
