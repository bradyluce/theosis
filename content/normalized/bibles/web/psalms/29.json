{
  "chapter": {
    "id": "web:psalms.29",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 29,
    "referenceLabel": "Psalms 29",
    "summary": "Source text for Psalms 29 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.29.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Psalms 29:1",
      "text": "Ascribe to Yahweh, you sons of the mighty, ascribe to Yahweh glory and strength.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.29.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Psalms 29:2",
      "text": "Ascribe to Yahweh the glory due to his name. Worship Yahweh in holy array.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.29.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Psalms 29:3",
      "text": "Yahweh’s voice is on the waters. The God of glory thunders, even Yahweh on many waters.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.29.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Psalms 29:4",
      "text": "Yahweh’s voice is powerful. Yahweh’s voice is full of majesty.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.29.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Psalms 29:5",
      "text": "Yahweh’s voice breaks the cedars. Yes, Yahweh breaks in pieces the cedars of Lebanon.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.29.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Psalms 29:6",
      "text": "He makes them also to skip like a calf; Lebanon and Sirion like a young, wild ox.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.29.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Psalms 29:7",
      "text": "Yahweh’s voice strikes with flashes of lightning.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.29.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Psalms 29:8",
      "text": "Yahweh’s voice shakes the wilderness. Yahweh shakes the wilderness of Kadesh.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.29.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Psalms 29:9",
      "text": "Yahweh’s voice makes the deer calve, and strips the forests bare. In his temple everything says, “Glory!”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.29.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Psalms 29:10",
      "text": "Yahweh sat enthroned at the Flood. Yes, Yahweh sits as King forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.29.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Psalms 29:11",
      "text": "Yahweh will give strength to his people. Yahweh will bless his people with peace.",
      "paragraphStart": false
    }
  ]
}
