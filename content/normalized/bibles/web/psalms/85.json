{
  "chapter": {
    "id": "web:psalms.85",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 85,
    "referenceLabel": "Psalms 85",
    "summary": "Source text for Psalms 85 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.85.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 1,
      "referenceLabel": "Psalms 85:1",
      "text": "Yahweh, you have been favorable to your land. You have restored the fortunes of Jacob.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.85.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 2,
      "referenceLabel": "Psalms 85:2",
      "text": "You have forgiven the iniquity of your people. You have covered all their sin. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.85.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 3,
      "referenceLabel": "Psalms 85:3",
      "text": "You have taken away all your wrath. You have turned from the fierceness of your anger.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.85.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 4,
      "referenceLabel": "Psalms 85:4",
      "text": "Turn us, God of our salvation, and cause your indignation toward us to cease.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.85.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 5,
      "referenceLabel": "Psalms 85:5",
      "text": "Will you be angry with us forever? Will you draw out your anger to all generations?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.85.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 6,
      "referenceLabel": "Psalms 85:6",
      "text": "Won’t you revive us again, that your people may rejoice in you?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.85.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 7,
      "referenceLabel": "Psalms 85:7",
      "text": "Show us your loving kindness, Yahweh. Grant us your salvation.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.85.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 8,
      "referenceLabel": "Psalms 85:8",
      "text": "I will hear what God, Yahweh, will speak, for he will speak peace to his people, his saints; but let them not turn again to folly.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.85.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 9,
      "referenceLabel": "Psalms 85:9",
      "text": "Surely his salvation is near those who fear him, that glory may dwell in our land.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.85.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 10,
      "referenceLabel": "Psalms 85:10",
      "text": "Mercy and truth meet together. Righteousness and peace have kissed each other.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.85.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 11,
      "referenceLabel": "Psalms 85:11",
      "text": "Truth springs out of the earth. Righteousness has looked down from heaven.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.85.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 12,
      "referenceLabel": "Psalms 85:12",
      "text": "Yes, Yahweh will give that which is good. Our land will yield its increase.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.85.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 13,
      "referenceLabel": "Psalms 85:13",
      "text": "Righteousness goes before him, and prepares the way for his steps.",
      "paragraphStart": false
    }
  ]
}
