{
  "chapter": {
    "id": "web:psalms.96",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 96,
    "referenceLabel": "Psalms 96",
    "summary": "Source text for Psalms 96 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.96.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 1,
      "referenceLabel": "Psalms 96:1",
      "text": "Sing to Yahweh a new song! Sing to Yahweh, all the earth.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.96.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 2,
      "referenceLabel": "Psalms 96:2",
      "text": "Sing to Yahweh! Bless his name! Proclaim his salvation from day to day!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.96.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 3,
      "referenceLabel": "Psalms 96:3",
      "text": "Declare his glory among the nations, his marvelous works among all the peoples.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.96.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 4,
      "referenceLabel": "Psalms 96:4",
      "text": "For Yahweh is great, and greatly to be praised! He is to be feared above all gods.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.96.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 5,
      "referenceLabel": "Psalms 96:5",
      "text": "For all the gods of the peoples are idols, but Yahweh made the heavens.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.96.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 6,
      "referenceLabel": "Psalms 96:6",
      "text": "Honor and majesty are before him. Strength and beauty are in his sanctuary.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.96.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 7,
      "referenceLabel": "Psalms 96:7",
      "text": "Ascribe to Yahweh, you families of nations, ascribe to Yahweh glory and strength.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.96.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 8,
      "referenceLabel": "Psalms 96:8",
      "text": "Ascribe to Yahweh the glory due to his name. Bring an offering, and come into his courts.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.96.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 9,
      "referenceLabel": "Psalms 96:9",
      "text": "Worship Yahweh in holy array. Tremble before him, all the earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.96.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 10,
      "referenceLabel": "Psalms 96:10",
      "text": "Say among the nations, “ Yahweh reigns.” The world is also established. It can’t be moved. He will judge the peoples with equity.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.96.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 11,
      "referenceLabel": "Psalms 96:11",
      "text": "Let the heavens be glad, and let the earth rejoice. Let the sea roar, and its fullness!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.96.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 12,
      "referenceLabel": "Psalms 96:12",
      "text": "Let the field and all that is in it exult! Then all the trees of the woods shall sing for joy",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.96.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 13,
      "referenceLabel": "Psalms 96:13",
      "text": "before Yahweh; for he comes, for he comes to judge the earth. He will judge the world with righteousness, the peoples with his truth.",
      "paragraphStart": false
    }
  ]
}
