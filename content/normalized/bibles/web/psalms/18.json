{
  "chapter": {
    "id": "web:psalms.18",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 18,
    "referenceLabel": "Psalms 18",
    "summary": "Source text for Psalms 18 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.18.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Psalms 18:1",
      "text": "I love you, Yahweh, my strength.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.18.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Psalms 18:2",
      "text": "Yahweh is my rock, my fortress, and my deliverer; my God, my rock, in whom I take refuge; my shield, and the horn of my salvation, my high tower.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Psalms 18:3",
      "text": "I call on Yahweh, who is worthy to be praised; and I am saved from my enemies.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Psalms 18:4",
      "text": "The cords of death surrounded me. The floods of ungodliness made me afraid.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Psalms 18:5",
      "text": "The cords of Sheol were around me. The snares of death came on me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Psalms 18:6",
      "text": "In my distress I called on Yahweh, and cried to my God. He heard my voice out of his temple. My cry before him came into his ears.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Psalms 18:7",
      "text": "Then the earth shook and trembled. The foundations also of the mountains quaked and were shaken, because he was angry.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Psalms 18:8",
      "text": "Smoke went out of his nostrils. Consuming fire came out of his mouth. Coals were kindled by it.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Psalms 18:9",
      "text": "He bowed the heavens also, and came down. Thick darkness was under his feet.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Psalms 18:10",
      "text": "He rode on a cherub, and flew. Yes, he soared on the wings of the wind.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Psalms 18:11",
      "text": "He made darkness his hiding place, his pavilion around him, darkness of waters, thick clouds of the skies.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Psalms 18:12",
      "text": "At the brightness before him his thick clouds passed, hailstones and coals of fire.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "Psalms 18:13",
      "text": "Yahweh also thundered in the sky. The Most High uttered his voice: hailstones and coals of fire.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "Psalms 18:14",
      "text": "He sent out his arrows, and scattered them. He routed them with great lightning bolts.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "Psalms 18:15",
      "text": "Then the channels of waters appeared. The foundations of the world were laid bare at your rebuke, Yahweh, at the blast of the breath of your nostrils.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 16,
      "referenceLabel": "Psalms 18:16",
      "text": "He sent from on high. He took me. He drew me out of many waters.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 17,
      "referenceLabel": "Psalms 18:17",
      "text": "He delivered me from my strong enemy, from those who hated me; for they were too mighty for me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 18,
      "referenceLabel": "Psalms 18:18",
      "text": "They came on me in the day of my calamity, but Yahweh was my support.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 19,
      "referenceLabel": "Psalms 18:19",
      "text": "He brought me out also into a large place. He delivered me, because he delighted in me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 20,
      "referenceLabel": "Psalms 18:20",
      "text": "Yahweh has rewarded me according to my righteousness. According to the cleanness of my hands, he has recompensed me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 21,
      "referenceLabel": "Psalms 18:21",
      "text": "For I have kept the ways of Yahweh, and have not wickedly departed from my God.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 22,
      "referenceLabel": "Psalms 18:22",
      "text": "For all his ordinances were before me. I didn’t put away his statutes from me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.23",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 23,
      "referenceLabel": "Psalms 18:23",
      "text": "I was also blameless with him. I kept myself from my iniquity.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.24",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 24,
      "referenceLabel": "Psalms 18:24",
      "text": "Therefore Yahweh has rewarded me according to my righteousness, according to the cleanness of my hands in his eyesight.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.25",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 25,
      "referenceLabel": "Psalms 18:25",
      "text": "With the merciful you will show yourself merciful. With the perfect man, you will show yourself perfect.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.26",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 26,
      "referenceLabel": "Psalms 18:26",
      "text": "With the pure, you will show yourself pure. With the crooked you will show yourself shrewd.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.27",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 27,
      "referenceLabel": "Psalms 18:27",
      "text": "For you will save the afflicted people, but the arrogant eyes you will bring down.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.28",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 28,
      "referenceLabel": "Psalms 18:28",
      "text": "For you will light my lamp, Yahweh. My God will light up my darkness.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.29",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 29,
      "referenceLabel": "Psalms 18:29",
      "text": "For by you, I advance through a troop. By my God, I leap over a wall.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.30",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 30,
      "referenceLabel": "Psalms 18:30",
      "text": "As for God, his way is perfect. Yahweh ’s word is tried. He is a shield to all those who take refuge in him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.31",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 31,
      "referenceLabel": "Psalms 18:31",
      "text": "For who is God, except Yahweh? Who is a rock, besides our God,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.32",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 32,
      "referenceLabel": "Psalms 18:32",
      "text": "the God who arms me with strength, and makes my way perfect?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.33",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 33,
      "referenceLabel": "Psalms 18:33",
      "text": "He makes my feet like deer’s feet, and sets me on my high places.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.34",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 34,
      "referenceLabel": "Psalms 18:34",
      "text": "He teaches my hands to war, so that my arms bend a bow of bronze.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.35",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 35,
      "referenceLabel": "Psalms 18:35",
      "text": "You have also given me the shield of your salvation. Your right hand sustains me. Your gentleness has made me great.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.36",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 36,
      "referenceLabel": "Psalms 18:36",
      "text": "You have enlarged my steps under me, My feet have not slipped.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.37",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 37,
      "referenceLabel": "Psalms 18:37",
      "text": "I will pursue my enemies, and overtake them. I won’t turn away until they are consumed.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.38",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 38,
      "referenceLabel": "Psalms 18:38",
      "text": "I will strike them through, so that they will not be able to rise. They shall fall under my feet.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.39",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 39,
      "referenceLabel": "Psalms 18:39",
      "text": "For you have armed me with strength to the battle. You have subdued under me those who rose up against me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.40",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 40,
      "referenceLabel": "Psalms 18:40",
      "text": "You have also made my enemies turn their backs to me, that I might cut off those who hate me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.41",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 41,
      "referenceLabel": "Psalms 18:41",
      "text": "They cried, but there was no one to save; even to Yahweh, but he didn’t answer them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.42",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 42,
      "referenceLabel": "Psalms 18:42",
      "text": "Then I beat them small as the dust before the wind. I cast them out as the mire of the streets.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.43",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 43,
      "referenceLabel": "Psalms 18:43",
      "text": "You have delivered me from the strivings of the people. You have made me the head of the nations. A people whom I have not known shall serve me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.44",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 44,
      "referenceLabel": "Psalms 18:44",
      "text": "As soon as they hear of me they shall obey me. The foreigners shall submit themselves to me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.45",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 45,
      "referenceLabel": "Psalms 18:45",
      "text": "The foreigners shall fade away, and shall come trembling out of their strongholds.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.46",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 46,
      "referenceLabel": "Psalms 18:46",
      "text": "Yahweh lives! Blessed be my rock. Exalted be the God of my salvation,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.47",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 47,
      "referenceLabel": "Psalms 18:47",
      "text": "even the God who executes vengeance for me, and subdues peoples under me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.48",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 48,
      "referenceLabel": "Psalms 18:48",
      "text": "He rescues me from my enemies. Yes, you lift me up above those who rise up against me. You deliver me from the violent man.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.49",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 49,
      "referenceLabel": "Psalms 18:49",
      "text": "Therefore I will give thanks to you, Yahweh, among the nations, and will sing praises to your name.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.18.50",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 50,
      "referenceLabel": "Psalms 18:50",
      "text": "He gives great deliverance to his king, and shows loving kindness to his anointed, to David and to his offspring, forever more.",
      "paragraphStart": false
    }
  ]
}
