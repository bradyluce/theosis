{
  "chapter": {
    "id": "web:psalms.16",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 16,
    "referenceLabel": "Psalms 16",
    "summary": "Source text for Psalms 16 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.16.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Psalms 16:1",
      "text": "Preserve me, God, for I take refuge in you.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.16.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Psalms 16:2",
      "text": "My soul, you have said to Yahweh, “You are my Lord. Apart from you I have no good thing.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.16.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Psalms 16:3",
      "text": "As for the saints who are in the earth, they are the excellent ones in whom is all my delight.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.16.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Psalms 16:4",
      "text": "Their sorrows shall be multiplied who give gifts to another god. Their drink offerings of blood I will not offer, nor take their names on my lips.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.16.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Psalms 16:5",
      "text": "Yahweh assigned my portion and my cup. You made my lot secure.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.16.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Psalms 16:6",
      "text": "The lines have fallen to me in pleasant places. Yes, I have a good inheritance.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.16.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Psalms 16:7",
      "text": "I will bless Yahweh, who has given me counsel. Yes, my heart instructs me in the night seasons.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.16.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Psalms 16:8",
      "text": "I have set Yahweh always before me. Because he is at my right hand, I shall not be moved.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.16.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Psalms 16:9",
      "text": "Therefore my heart is glad, and my tongue rejoices. My body shall also dwell in safety.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.16.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Psalms 16:10",
      "text": "For you will not leave my soul in Sheol, neither will you allow your holy one to see corruption.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.16.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Psalms 16:11",
      "text": "You will show me the path of life. In your presence is fullness of joy. In your right hand there are pleasures forever more.",
      "paragraphStart": false
    }
  ]
}
