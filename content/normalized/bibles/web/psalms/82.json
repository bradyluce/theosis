{
  "chapter": {
    "id": "web:psalms.82",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 82,
    "referenceLabel": "Psalms 82",
    "summary": "Source text for Psalms 82 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.82.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 1,
      "referenceLabel": "Psalms 82:1",
      "text": "God presides in the great assembly. He judges among the gods.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.82.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 2,
      "referenceLabel": "Psalms 82:2",
      "text": "“ How long will you judge unjustly, and show partiality to the wicked?” Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.82.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 3,
      "referenceLabel": "Psalms 82:3",
      "text": "“ Defend the weak, the poor, and the fatherless. Maintain the rights of the poor and oppressed.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.82.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 4,
      "referenceLabel": "Psalms 82:4",
      "text": "Rescue the weak and needy. Deliver them out of the hand of the wicked.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.82.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 5,
      "referenceLabel": "Psalms 82:5",
      "text": "They don’t know, neither do they understand. They walk back and forth in darkness. All the foundations of the earth are shaken.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.82.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 6,
      "referenceLabel": "Psalms 82:6",
      "text": "I said, “ You are gods, all of you are sons of the Most High.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.82.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 7,
      "referenceLabel": "Psalms 82:7",
      "text": "Nevertheless you shall die like men, and fall like one of the rulers.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.82.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 8,
      "referenceLabel": "Psalms 82:8",
      "text": "Arise, God, judge the earth, for you inherit all of the nations.",
      "paragraphStart": false
    }
  ]
}
