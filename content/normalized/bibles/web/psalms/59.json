{
  "chapter": {
    "id": "web:psalms.59",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 59,
    "referenceLabel": "Psalms 59",
    "summary": "Source text for Psalms 59 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.59.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 1,
      "referenceLabel": "Psalms 59:1",
      "text": "Deliver me from my enemies, my God. Set me on high from those who rise up against me.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.59.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 2,
      "referenceLabel": "Psalms 59:2",
      "text": "Deliver me from the workers of iniquity. Save me from the bloodthirsty men.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.59.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 3,
      "referenceLabel": "Psalms 59:3",
      "text": "For, behold, they lie in wait for my soul. The mighty gather themselves together against me, not for my disobedience, nor for my sin, Yahweh.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.59.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 4,
      "referenceLabel": "Psalms 59:4",
      "text": "I have done no wrong, yet they are ready to attack me. Rise up, behold, and help me!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.59.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 5,
      "referenceLabel": "Psalms 59:5",
      "text": "You, Yahweh God of Armies, the God of Israel, rouse yourself to punish the nations. Show no mercy to the wicked traitors. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.59.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 6,
      "referenceLabel": "Psalms 59:6",
      "text": "They return at evening, howling like dogs, and prowl around the city.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.59.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 7,
      "referenceLabel": "Psalms 59:7",
      "text": "Behold, they spew with their mouth. Swords are in their lips, “For”, they say, “who hears us?”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.59.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 8,
      "referenceLabel": "Psalms 59:8",
      "text": "But you, Yahweh, laugh at them. You scoff at all the nations.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.59.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 9,
      "referenceLabel": "Psalms 59:9",
      "text": "Oh, my Strength, I watch for you, for God is my high tower.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.59.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 10,
      "referenceLabel": "Psalms 59:10",
      "text": "My God will go before me with his loving kindness. God will let me look at my enemies in triumph.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.59.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 11,
      "referenceLabel": "Psalms 59:11",
      "text": "Don’t kill them, or my people may forget. Scatter them by your power, and bring them down, Lord our shield.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.59.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 12,
      "referenceLabel": "Psalms 59:12",
      "text": "For the sin of their mouth, and the words of their lips, let them be caught in their pride, for the curses and lies which they utter.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.59.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 13,
      "referenceLabel": "Psalms 59:13",
      "text": "Consume them in wrath. Consume them, and they will be no more. Let them know that God rules in Jacob, to the ends of the earth. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.59.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 14,
      "referenceLabel": "Psalms 59:14",
      "text": "At evening let them return. Let them howl like a dog, and go around the city.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.59.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 15,
      "referenceLabel": "Psalms 59:15",
      "text": "They shall wander up and down for food, and wait all night if they aren’t satisfied.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.59.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 16,
      "referenceLabel": "Psalms 59:16",
      "text": "But I will sing of your strength. Yes, I will sing aloud of your loving kindness in the morning. For you have been my high tower, a refuge in the day of my distress.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.59.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 17,
      "referenceLabel": "Psalms 59:17",
      "text": "To you, my strength, I will sing praises. For God is my high tower, the God of my mercy.",
      "paragraphStart": false
    }
  ]
}
