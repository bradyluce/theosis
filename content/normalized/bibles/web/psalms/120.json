  "verses": [
    {
      "id": "web:psalms.120.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 1,
      "referenceLabel": "Psalms 120:1",
      "text": "In my distress, I cried to Yahweh. He answered me.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.120.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 2,
      "referenceLabel": "Psalms 120:2",
      "text": "Deliver my soul, Yahweh, from lying lips, from a deceitful tongue.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.120.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 3,
      "referenceLabel": "Psalms 120:3",
      "text": "What will be given to you, and what will be done more to you, you deceitful tongue?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.120.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 4,
      "referenceLabel": "Psalms 120:4",
      "text": "Sharp arrows of the mighty, with coals of juniper.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.120.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 5,
      "referenceLabel": "Psalms 120:5",
      "text": "Woe is me, that I live in Meshech, that I dwell among the tents of Kedar!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.120.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 6,
      "referenceLabel": "Psalms 120:6",
      "text": "My soul has had her dwelling too long with him who hates peace.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.120.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 7,
      "referenceLabel": "Psalms 120:7",
      "text": "I am for peace, but when I speak, they are for war.",
      "paragraphStart": false
    }
  ]
}
