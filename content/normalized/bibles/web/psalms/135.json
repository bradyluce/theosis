{
  "chapter": {
    "id": "web:psalms.135",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 135,
    "referenceLabel": "Psalms 135",
    "summary": "Source text for Psalms 135 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.135.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 1,
      "referenceLabel": "Psalms 135:1",
      "text": "Praise Yah! Praise Yahweh’s name! Praise him, you servants of Yahweh,",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.135.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 2,
      "referenceLabel": "Psalms 135:2",
      "text": "you who stand in Yahweh’s house, in the courts of our God’s house.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.135.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 3,
      "referenceLabel": "Psalms 135:3",
      "text": "Praise Yah, for Yahweh is good. Sing praises to his name, for that is pleasant.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.135.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 4,
      "referenceLabel": "Psalms 135:4",
      "text": "For Yah has chosen Jacob for himself, Israel for his own possession.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.135.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 5,
      "referenceLabel": "Psalms 135:5",
      "text": "For I know that Yahweh is great, that our Lord is above all gods.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.135.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 6,
      "referenceLabel": "Psalms 135:6",
      "text": "Whatever Yahweh pleased, that he has done, in heaven and in earth, in the seas and in all deeps.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.135.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 7,
      "referenceLabel": "Psalms 135:7",
      "text": "He causes the clouds to rise from the ends of the earth. He makes lightnings with the rain. He brings the wind out of his treasuries.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.135.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 8,
      "referenceLabel": "Psalms 135:8",
      "text": "He struck the firstborn of Egypt, both of man and animal.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.135.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 9,
      "referenceLabel": "Psalms 135:9",
      "text": "He sent signs and wonders into the middle of you, Egypt, on Pharaoh, and on all his servants.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.135.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 10,
      "referenceLabel": "Psalms 135:10",
      "text": "He struck many nations, and killed mighty kings —",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.135.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 11,
      "referenceLabel": "Psalms 135:11",
      "text": "Sihon king of the Amorites, Og king of Bashan, and all the kingdoms of Canaan —",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.135.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 12,
      "referenceLabel": "Psalms 135:12",
      "text": "and gave their land for a heritage, a heritage to Israel, his people.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.135.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 13,
      "referenceLabel": "Psalms 135:13",
      "text": "Your name, Yahweh, endures forever; your renown, Yahweh, throughout all generations.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.135.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 14,
      "referenceLabel": "Psalms 135:14",
      "text": "For Yahweh will judge his people and have compassion on his servants.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.135.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 15,
      "referenceLabel": "Psalms 135:15",
      "text": "The idols of the nations are silver and gold, the work of men’s hands.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.135.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 16,
      "referenceLabel": "Psalms 135:16",
      "text": "They have mouths, but they can’t speak. They have eyes, but they can’t see.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.135.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 17,
      "referenceLabel": "Psalms 135:17",
      "text": "They have ears, but they can’t hear, neither is there any breath in their mouths.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.135.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 18,
      "referenceLabel": "Psalms 135:18",
      "text": "Those who make them will be like them, yes, everyone who trusts in them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.135.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 19,
      "referenceLabel": "Psalms 135:19",
      "text": "House of Israel, praise Yahweh! House of Aaron, praise Yahweh!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.135.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 20,
      "referenceLabel": "Psalms 135:20",
      "text": "House of Levi, praise Yahweh! You who fear Yahweh, praise Yahweh!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.135.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 21,
      "referenceLabel": "Psalms 135:21",
      "text": "Blessed be Yahweh from Zion, who dwells in Jerusalem. Praise Yah!",
      "paragraphStart": false
    }
  ]
}
