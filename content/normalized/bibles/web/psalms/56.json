{
  "chapter": {
    "id": "web:psalms.56",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 56,
    "referenceLabel": "Psalms 56",
    "summary": "Source text for Psalms 56 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.56.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 1,
      "referenceLabel": "Psalms 56:1",
      "text": "Be merciful to me, God, for man wants to swallow me up. All day long, he attacks and oppresses me.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.56.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 2,
      "referenceLabel": "Psalms 56:2",
      "text": "My enemies want to swallow me up all day long, for they are many who fight proudly against me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.56.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 3,
      "referenceLabel": "Psalms 56:3",
      "text": "When I am afraid, I will put my trust in you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.56.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 4,
      "referenceLabel": "Psalms 56:4",
      "text": "In God, I praise his word. In God, I put my trust. I will not be afraid. What can flesh do to me?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.56.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 5,
      "referenceLabel": "Psalms 56:5",
      "text": "All day long they twist my words. All their thoughts are against me for evil.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.56.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 6,
      "referenceLabel": "Psalms 56:6",
      "text": "They conspire and lurk, watching my steps. They are eager to take my life.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.56.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 7,
      "referenceLabel": "Psalms 56:7",
      "text": "Shall they escape by iniquity? In anger cast down the peoples, God.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.56.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 8,
      "referenceLabel": "Psalms 56:8",
      "text": "You count my wanderings. You put my tears into your container. Aren’t they in your book?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.56.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 9,
      "referenceLabel": "Psalms 56:9",
      "text": "Then my enemies shall turn back in the day that I call. I know this: that God is for me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.56.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 10,
      "referenceLabel": "Psalms 56:10",
      "text": "In God, I will praise his word. In Yahweh, I will praise his word.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.56.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 11,
      "referenceLabel": "Psalms 56:11",
      "text": "I have put my trust in God. I will not be afraid. What can man do to me?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.56.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 12,
      "referenceLabel": "Psalms 56:12",
      "text": "Your vows are on me, God. I will give thank offerings to you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.56.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 13,
      "referenceLabel": "Psalms 56:13",
      "text": "For you have delivered my soul from death, and prevented my feet from falling, that I may walk before God in the light of the living.",
      "paragraphStart": false
    }
  ]
}
