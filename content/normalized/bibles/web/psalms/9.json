{
  "chapter": {
    "id": "web:psalms.9",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 9,
    "referenceLabel": "Psalms 9",
    "summary": "Source text for Psalms 9 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.9.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Psalms 9:1",
      "text": "I will give thanks to Yahweh with my whole heart. I will tell of all your marvelous works.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.9.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Psalms 9:2",
      "text": "I will be glad and rejoice in you. I will sing praise to your name, O Most High.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.9.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Psalms 9:3",
      "text": "When my enemies turn back, they stumble and perish in your presence.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.9.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Psalms 9:4",
      "text": "For you have maintained my just cause. You sit on the throne judging righteously.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.9.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Psalms 9:5",
      "text": "You have rebuked the nations. You have destroyed the wicked. You have blotted out their name forever and ever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.9.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Psalms 9:6",
      "text": "The enemy is overtaken by endless ruin. The very memory of the cities which you have overthrown has perished.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.9.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Psalms 9:7",
      "text": "But Yahweh reigns forever. He has prepared his throne for judgment.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.9.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Psalms 9:8",
      "text": "He will judge the world in righteousness. He will administer judgment to the peoples in uprightness.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.9.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Psalms 9:9",
      "text": "Yahweh will also be a high tower for the oppressed; a high tower in times of trouble.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.9.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Psalms 9:10",
      "text": "Those who know your name will put their trust in you, for you, Yahweh, have not forsaken those who seek you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.9.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Psalms 9:11",
      "text": "Sing praises to Yahweh, who dwells in Zion, and declare among the people what he has done.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.9.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Psalms 9:12",
      "text": "For he who avenges blood remembers them. He doesn’t forget the cry of the afflicted.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.9.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Psalms 9:13",
      "text": "Have mercy on me, Yahweh. See my affliction by those who hate me, and lift me up from the gates of death,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.9.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Psalms 9:14",
      "text": "that I may show all of your praise. I will rejoice in your salvation in the gates of the daughter of Zion.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.9.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Psalms 9:15",
      "text": "The nations have sunk down in the pit that they made. In the net which they hid, their own foot is taken.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.9.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Psalms 9:16",
      "text": "Yahweh has made himself known. He has executed judgment. The wicked is snared by the work of his own hands. Meditation. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.9.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Psalms 9:17",
      "text": "The wicked shall be turned back to Sheol, even all the nations that forget God.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.9.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Psalms 9:18",
      "text": "For the needy shall not always be forgotten, nor the hope of the poor perish forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.9.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Psalms 9:19",
      "text": "Arise, Yahweh! Don’t let man prevail. Let the nations be judged in your sight.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.9.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Psalms 9:20",
      "text": "Put them in fear, Yahweh. Let the nations know that they are only men. Selah.",
      "paragraphStart": false
    }
  ]
}
