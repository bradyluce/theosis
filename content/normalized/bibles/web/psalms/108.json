{
  "chapter": {
    "id": "web:psalms.108",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 108,
    "referenceLabel": "Psalms 108",
    "summary": "Source text for Psalms 108 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.108.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 1,
      "referenceLabel": "Psalms 108:1",
      "text": "My heart is steadfast, God. I will sing and I will make music with my soul.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.108.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 2,
      "referenceLabel": "Psalms 108:2",
      "text": "Wake up, harp and lyre! I will wake up the dawn.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.108.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 3,
      "referenceLabel": "Psalms 108:3",
      "text": "I will give thanks to you, Yahweh, among the nations. I will sing praises to you among the peoples.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.108.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 4,
      "referenceLabel": "Psalms 108:4",
      "text": "For your loving kindness is great above the heavens. Your faithfulness reaches to the skies.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.108.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 5,
      "referenceLabel": "Psalms 108:5",
      "text": "Be exalted, God, above the heavens! Let your glory be over all the earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.108.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 6,
      "referenceLabel": "Psalms 108:6",
      "text": "That your beloved may be delivered, save with your right hand, and answer us.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.108.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 7,
      "referenceLabel": "Psalms 108:7",
      "text": "God has spoken from his sanctuary: “In triumph, I will divide Shechem, and measure out the valley of Succoth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.108.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 8,
      "referenceLabel": "Psalms 108:8",
      "text": "Gilead is mine. Manasseh is mine. Ephraim also is my helmet. Judah is my scepter.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.108.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 9,
      "referenceLabel": "Psalms 108:9",
      "text": "Moab is my wash pot. I will toss my sandal on Edom. I will shout over Philistia.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.108.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 10,
      "referenceLabel": "Psalms 108:10",
      "text": "Who will bring me into the fortified city? Who will lead me to Edom?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.108.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 11,
      "referenceLabel": "Psalms 108:11",
      "text": "Haven’t you rejected us, God? You don’t go out, God, with our armies.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.108.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 12,
      "referenceLabel": "Psalms 108:12",
      "text": "Give us help against the enemy, for the help of man is vain.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.108.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 13,
      "referenceLabel": "Psalms 108:13",
      "text": "Through God, we will do valiantly, for it is he who will tread down our enemies.",
      "paragraphStart": false
    }
  ]
}
