{
  "chapter": {
    "id": "web:psalms.95",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 95,
    "referenceLabel": "Psalms 95",
    "summary": "Source text for Psalms 95 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.95.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 1,
      "referenceLabel": "Psalms 95:1",
      "text": "Oh come, let’s sing to Yahweh. Let’s shout aloud to the rock of our salvation!",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.95.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 2,
      "referenceLabel": "Psalms 95:2",
      "text": "Let’s come before his presence with thanksgiving. Let’s extol him with songs!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.95.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 3,
      "referenceLabel": "Psalms 95:3",
      "text": "For Yahweh is a great God, a great King above all gods.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.95.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 4,
      "referenceLabel": "Psalms 95:4",
      "text": "In his hand are the deep places of the earth. The heights of the mountains are also his.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.95.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 5,
      "referenceLabel": "Psalms 95:5",
      "text": "The sea is his, and he made it. His hands formed the dry land.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.95.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 6,
      "referenceLabel": "Psalms 95:6",
      "text": "Oh come, let’s worship and bow down. Let’s kneel before Yahweh, our Maker,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.95.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 7,
      "referenceLabel": "Psalms 95:7",
      "text": "for he is our God. We are the people of his pasture, and the sheep in his care. Today, oh that you would hear his voice!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.95.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 8,
      "referenceLabel": "Psalms 95:8",
      "text": "Don’t harden your heart, as at Meribah, as in the day of Massah in the wilderness,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.95.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 9,
      "referenceLabel": "Psalms 95:9",
      "text": "when your fathers tempted me, tested me, and saw my work.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.95.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 10,
      "referenceLabel": "Psalms 95:10",
      "text": "Forty long years I was grieved with that generation, and said, “They are a people who err in their heart. They have not known my ways.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.95.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 11,
      "referenceLabel": "Psalms 95:11",
      "text": "Therefore I swore in my wrath, “They won’t enter into my rest.”",
      "paragraphStart": false
    }
  ]
}
