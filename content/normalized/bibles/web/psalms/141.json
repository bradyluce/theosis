{
  "chapter": {
    "id": "web:psalms.141",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 141,
    "referenceLabel": "Psalms 141",
    "summary": "Source text for Psalms 141 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.141.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 1,
      "referenceLabel": "Psalms 141:1",
      "text": "Yahweh, I have called on you. Come to me quickly! Listen to my voice when I call to you.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.141.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 2,
      "referenceLabel": "Psalms 141:2",
      "text": "Let my prayer be set before you like incense; the lifting up of my hands like the evening sacrifice.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.141.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 3,
      "referenceLabel": "Psalms 141:3",
      "text": "Set a watch, Yahweh, before my mouth. Keep the door of my lips.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.141.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 4,
      "referenceLabel": "Psalms 141:4",
      "text": "Don’t incline my heart to any evil thing, to practice deeds of wickedness with men who work iniquity. Don’t let me eat of their delicacies.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.141.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 5,
      "referenceLabel": "Psalms 141:5",
      "text": "Let the righteous strike me, it is kindness; let him reprove me, it is like oil on the head; don’t let my head refuse it; Yet my prayer is always against evil deeds.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.141.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 6,
      "referenceLabel": "Psalms 141:6",
      "text": "Their judges are thrown down by the sides of the rock. They will hear my words, for they are well spoken.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.141.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 7,
      "referenceLabel": "Psalms 141:7",
      "text": "“ As when one plows and breaks up the earth, our bones are scattered at the mouth of Sheol.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.141.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 8,
      "referenceLabel": "Psalms 141:8",
      "text": "For my eyes are on you, Yahweh, the Lord. I take refuge in you. Don’t leave my soul destitute.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.141.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 9,
      "referenceLabel": "Psalms 141:9",
      "text": "Keep me from the snare which they have laid for me, from the traps of the workers of iniquity.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.141.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 10,
      "referenceLabel": "Psalms 141:10",
      "text": "Let the wicked fall together into their own nets while I pass by.",
      "paragraphStart": false
    }
  ]
}
