  "verses": [
    {
      "id": "web:psalms.13.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Psalms 13:1",
      "text": "How long, Yahweh? Will you forget me forever? How long will you hide your face from me?",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.13.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Psalms 13:2",
      "text": "How long shall I take counsel in my soul, having sorrow in my heart every day? How long shall my enemy triumph over me?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.13.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Psalms 13:3",
      "text": "Behold, and answer me, Yahweh, my God. Give light to my eyes, lest I sleep in death;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.13.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Psalms 13:4",
      "text": "lest my enemy say, “I have prevailed against him;” lest my adversaries rejoice when I fall.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.13.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Psalms 13:5",
      "text": "But I trust in your loving kindness. My heart rejoices in your salvation.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.13.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Psalms 13:6",
      "text": "I will sing to Yahweh, because he has been good to me.",
      "paragraphStart": false
    }
  ]
}
