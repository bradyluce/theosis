  "verses": [
    {
      "id": "web:psalms.93.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 1,
      "referenceLabel": "Psalms 93:1",
      "text": "Yahweh reigns! He is clothed with majesty! Yahweh is armed with strength. The world also is established. It can’t be moved.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.93.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 2,
      "referenceLabel": "Psalms 93:2",
      "text": "Your throne is established from long ago. You are from everlasting.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.93.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 3,
      "referenceLabel": "Psalms 93:3",
      "text": "The floods have lifted up, Yahweh, the floods have lifted up their voice. The floods lift up their waves.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.93.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 4,
      "referenceLabel": "Psalms 93:4",
      "text": "Above the voices of many waters, the mighty breakers of the sea, Yahweh on high is mighty.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.93.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 5,
      "referenceLabel": "Psalms 93:5",
      "text": "Your statutes stand firm. Holiness adorns your house, Yahweh, forever more.",
      "paragraphStart": false
    }
  ]
}
