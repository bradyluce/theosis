{
  "chapter": {
    "id": "web:psalms.46",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 46,
    "referenceLabel": "Psalms 46",
    "summary": "Source text for Psalms 46 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.46.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 1,
      "referenceLabel": "Psalms 46:1",
      "text": "God is our refuge and strength, a very present help in trouble.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.46.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 2,
      "referenceLabel": "Psalms 46:2",
      "text": "Therefore we won’t be afraid, though the earth changes, though the mountains are shaken into the heart of the seas;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.46.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 3,
      "referenceLabel": "Psalms 46:3",
      "text": "though its waters roar and are troubled, though the mountains tremble with their swelling. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.46.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 4,
      "referenceLabel": "Psalms 46:4",
      "text": "There is a river, the streams of which make the city of God glad, the holy place of the tents of the Most High.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.46.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 5,
      "referenceLabel": "Psalms 46:5",
      "text": "God is within her. She shall not be moved. God will help her at dawn.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.46.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 6,
      "referenceLabel": "Psalms 46:6",
      "text": "The nations raged. The kingdoms were moved. He lifted his voice and the earth melted.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.46.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 7,
      "referenceLabel": "Psalms 46:7",
      "text": "Yahweh of Armies is with us. The God of Jacob is our refuge. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.46.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 8,
      "referenceLabel": "Psalms 46:8",
      "text": "Come, see Yahweh ’s works, what desolations he has made in the earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.46.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 9,
      "referenceLabel": "Psalms 46:9",
      "text": "He makes wars cease to the end of the earth. He breaks the bow, and shatters the spear. He burns the chariots in the fire.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.46.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 10,
      "referenceLabel": "Psalms 46:10",
      "text": "“ Be still, and know that I am God. I will be exalted among the nations. I will be exalted in the earth.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.46.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 11,
      "referenceLabel": "Psalms 46:11",
      "text": "Yahweh of Armies is with us. The God of Jacob is our refuge. Selah.",
      "paragraphStart": false
    }
  ]
}
