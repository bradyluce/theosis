{
  "chapter": {
    "id": "web:psalms.104",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 104,
    "referenceLabel": "Psalms 104",
    "summary": "Source text for Psalms 104 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.104.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 1,
      "referenceLabel": "Psalms 104:1",
      "text": "Bless Yahweh, my soul. Yahweh, my God, you are very great. You are clothed with honor and majesty.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.104.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 2,
      "referenceLabel": "Psalms 104:2",
      "text": "He covers himself with light as with a garment. He stretches out the heavens like a curtain.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 3,
      "referenceLabel": "Psalms 104:3",
      "text": "He lays the beams of his rooms in the waters. He makes the clouds his chariot. He walks on the wings of the wind.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 4,
      "referenceLabel": "Psalms 104:4",
      "text": "He makes his messengers winds, and his servants flames of fire.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 5,
      "referenceLabel": "Psalms 104:5",
      "text": "He laid the foundations of the earth, that it should not be moved forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 6,
      "referenceLabel": "Psalms 104:6",
      "text": "You covered it with the deep as with a cloak. The waters stood above the mountains.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 7,
      "referenceLabel": "Psalms 104:7",
      "text": "At your rebuke they fled. At the voice of your thunder they hurried away.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 8,
      "referenceLabel": "Psalms 104:8",
      "text": "The mountains rose, the valleys sank down, to the place which you had assigned to them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 9,
      "referenceLabel": "Psalms 104:9",
      "text": "You have set a boundary that they may not pass over, that they don’t turn again to cover the earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 10,
      "referenceLabel": "Psalms 104:10",
      "text": "He sends springs into the valleys. They run among the mountains.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 11,
      "referenceLabel": "Psalms 104:11",
      "text": "They give drink to every animal of the field. The wild donkeys quench their thirst.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 12,
      "referenceLabel": "Psalms 104:12",
      "text": "The birds of the sky nest by them. They sing among the branches.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 13,
      "referenceLabel": "Psalms 104:13",
      "text": "He waters the mountains from his rooms. The earth is filled with the fruit of your works.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 14,
      "referenceLabel": "Psalms 104:14",
      "text": "He causes the grass to grow for the livestock, and plants for man to cultivate, that he may produce food out of the earth:",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 15,
      "referenceLabel": "Psalms 104:15",
      "text": "wine that makes the heart of man glad, oil to make his face to shine, and bread that strengthens man’s heart.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 16,
      "referenceLabel": "Psalms 104:16",
      "text": "Yahweh’s trees are well watered, the cedars of Lebanon, which he has planted,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 17,
      "referenceLabel": "Psalms 104:17",
      "text": "where the birds make their nests. The stork makes its home in the cypress trees.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 18,
      "referenceLabel": "Psalms 104:18",
      "text": "The high mountains are for the wild goats. The rocks are a refuge for the rock badgers.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 19,
      "referenceLabel": "Psalms 104:19",
      "text": "He appointed the moon for seasons. The sun knows when to set.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 20,
      "referenceLabel": "Psalms 104:20",
      "text": "You make darkness, and it is night, in which all the animals of the forest prowl.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 21,
      "referenceLabel": "Psalms 104:21",
      "text": "The young lions roar after their prey, and seek their food from God.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 22,
      "referenceLabel": "Psalms 104:22",
      "text": "The sun rises, and they steal away, and lie down in their dens.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.23",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 23,
      "referenceLabel": "Psalms 104:23",
      "text": "Man goes out to his work, to his labor until the evening.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.24",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 24,
      "referenceLabel": "Psalms 104:24",
      "text": "Yahweh, how many are your works! In wisdom, you have made them all. The earth is full of your riches.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.25",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 25,
      "referenceLabel": "Psalms 104:25",
      "text": "There is the sea, great and wide, in which are innumerable living things, both small and large animals.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.26",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 26,
      "referenceLabel": "Psalms 104:26",
      "text": "There the ships go, and leviathan, whom you formed to play there.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.27",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 27,
      "referenceLabel": "Psalms 104:27",
      "text": "These all wait for you, that you may give them their food in due season.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.28",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 28,
      "referenceLabel": "Psalms 104:28",
      "text": "You give to them; they gather. You open your hand; they are satisfied with good.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.29",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 29,
      "referenceLabel": "Psalms 104:29",
      "text": "You hide your face; they are troubled. You take away their breath; they die and return to the dust.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.30",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 30,
      "referenceLabel": "Psalms 104:30",
      "text": "You send out your Spirit and they are created. You renew the face of the ground.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.31",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 31,
      "referenceLabel": "Psalms 104:31",
      "text": "Let Yahweh’s glory endure forever. Let Yahweh rejoice in his works.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.32",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 32,
      "referenceLabel": "Psalms 104:32",
      "text": "He looks at the earth, and it trembles. He touches the mountains, and they smoke.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.33",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 33,
      "referenceLabel": "Psalms 104:33",
      "text": "I will sing to Yahweh as long as I live. I will sing praise to my God while I have any being.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.34",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 34,
      "referenceLabel": "Psalms 104:34",
      "text": "Let my meditation be sweet to him. I will rejoice in Yahweh.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.104.35",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 35,
      "referenceLabel": "Psalms 104:35",
      "text": "Let sinners be consumed out of the earth. Let the wicked be no more. Bless Yahweh, my soul. Praise Yah!",
      "paragraphStart": false
    }
  ]
}
