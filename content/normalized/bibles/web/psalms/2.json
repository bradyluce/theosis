{
  "chapter": {
    "id": "web:psalms.2",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 2,
    "referenceLabel": "Psalms 2",
    "summary": "Source text for Psalms 2 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.2.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Psalms 2:1",
      "text": "Why do the nations rage, and the peoples plot a vain thing?",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.2.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Psalms 2:2",
      "text": "The kings of the earth take a stand, and the rulers take counsel together, against Yahweh, and against his Anointed, saying,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.2.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Psalms 2:3",
      "text": "“Let’s break their bonds apart, and cast their cords from us.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.2.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Psalms 2:4",
      "text": "He who sits in the heavens will laugh. The Lord will have them in derision.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.2.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Psalms 2:5",
      "text": "Then he will speak to them in his anger, and terrify them in his wrath:",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.2.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Psalms 2:6",
      "text": "“ Yet I have set my King on my holy hill of Zion.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.2.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Psalms 2:7",
      "text": "I will tell of the decree: Yahweh said to me, “ You are my son. Today I have become your father.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.2.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Psalms 2:8",
      "text": "Ask of me, and I will give the nations for your inheritance, the uttermost parts of the earth for your possession.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.2.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Psalms 2:9",
      "text": "You shall break them with a rod of iron. You shall dash them in pieces like a potter ’s vessel.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.2.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Psalms 2:10",
      "text": "Now therefore be wise, you kings. Be instructed, you judges of the earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.2.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Psalms 2:11",
      "text": "Serve Yahweh with fear, and rejoice with trembling.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.2.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Psalms 2:12",
      "text": "Give sincere homage to the Son, lest he be angry, and you perish on the way, for his wrath will soon be kindled. Blessed are all those who take refuge in him.",
      "paragraphStart": false
    }
  ]
}
