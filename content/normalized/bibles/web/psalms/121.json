{
  "chapter": {
    "id": "web:psalms.121",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 121,
    "referenceLabel": "Psalms 121",
    "summary": "Source text for Psalms 121 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.121.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 1,
      "referenceLabel": "Psalms 121:1",
      "text": "I will lift up my eyes to the hills. Where does my help come from?",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.121.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 2,
      "referenceLabel": "Psalms 121:2",
      "text": "My help comes from Yahweh, who made heaven and earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.121.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 3,
      "referenceLabel": "Psalms 121:3",
      "text": "He will not allow your foot to be moved. He who keeps you will not slumber.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.121.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 4,
      "referenceLabel": "Psalms 121:4",
      "text": "Behold, he who keeps Israel will neither slumber nor sleep.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.121.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 5,
      "referenceLabel": "Psalms 121:5",
      "text": "Yahweh is your keeper. Yahweh is your shade on your right hand.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.121.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 6,
      "referenceLabel": "Psalms 121:6",
      "text": "The sun will not harm you by day, nor the moon by night.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.121.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 7,
      "referenceLabel": "Psalms 121:7",
      "text": "Yahweh will keep you from all evil. He will keep your soul.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.121.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 8,
      "referenceLabel": "Psalms 121:8",
      "text": "Yahweh will keep your going out and your coming in, from this time forward, and forever more.",
      "paragraphStart": false
    }
  ]
}
