{
  "chapter": {
    "id": "web:psalms.52",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 52,
    "referenceLabel": "Psalms 52",
    "summary": "Source text for Psalms 52 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.52.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 1,
      "referenceLabel": "Psalms 52:1",
      "text": "Why do you boast of mischief, mighty man? God’s loving kindness endures continually.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.52.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 2,
      "referenceLabel": "Psalms 52:2",
      "text": "Your tongue plots destruction, like a sharp razor, working deceitfully.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.52.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 3,
      "referenceLabel": "Psalms 52:3",
      "text": "You love evil more than good, lying rather than speaking the truth. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.52.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 4,
      "referenceLabel": "Psalms 52:4",
      "text": "You love all devouring words, you deceitful tongue.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.52.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 5,
      "referenceLabel": "Psalms 52:5",
      "text": "God will likewise destroy you forever. He will take you up, and pluck you out of your tent, and root you out of the land of the living. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.52.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 6,
      "referenceLabel": "Psalms 52:6",
      "text": "The righteous also will see it, and fear, and laugh at him, saying,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.52.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 7,
      "referenceLabel": "Psalms 52:7",
      "text": "“Behold, this is the man who didn’t make God his strength, but trusted in the abundance of his riches, and strengthened himself in his wickedness.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.52.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 8,
      "referenceLabel": "Psalms 52:8",
      "text": "But as for me, I am like a green olive tree in God’s house. I trust in God’s loving kindness forever and ever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.52.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 9,
      "referenceLabel": "Psalms 52:9",
      "text": "I will give you thanks forever, because you have done it. I will hope in your name, for it is good, in the presence of your saints.",
      "paragraphStart": false
    }
  ]
}
