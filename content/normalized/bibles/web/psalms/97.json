{
  "chapter": {
    "id": "web:psalms.97",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 97,
    "referenceLabel": "Psalms 97",
    "summary": "Source text for Psalms 97 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.97.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 1,
      "referenceLabel": "Psalms 97:1",
      "text": "Yahweh reigns! Let the earth rejoice! Let the multitude of islands be glad!",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.97.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 2,
      "referenceLabel": "Psalms 97:2",
      "text": "Clouds and darkness are around him. Righteousness and justice are the foundation of his throne.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.97.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 3,
      "referenceLabel": "Psalms 97:3",
      "text": "A fire goes before him, and burns up his adversaries on every side.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.97.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 4,
      "referenceLabel": "Psalms 97:4",
      "text": "His lightning lights up the world. The earth sees, and trembles.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.97.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 5,
      "referenceLabel": "Psalms 97:5",
      "text": "The mountains melt like wax at the presence of Yahweh, at the presence of the Lord of the whole earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.97.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 6,
      "referenceLabel": "Psalms 97:6",
      "text": "The heavens declare his righteousness. All the peoples have seen his glory.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.97.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 7,
      "referenceLabel": "Psalms 97:7",
      "text": "Let all them be shamed who serve engraved images, who boast in their idols. Worship him, all you gods!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.97.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 8,
      "referenceLabel": "Psalms 97:8",
      "text": "Zion heard and was glad. The daughters of Judah rejoiced because of your judgments, Yahweh.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.97.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 9,
      "referenceLabel": "Psalms 97:9",
      "text": "For you, Yahweh, are most high above all the earth. You are exalted far above all gods.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.97.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 10,
      "referenceLabel": "Psalms 97:10",
      "text": "You who love Yahweh, hate evil! He preserves the souls of his saints. He delivers them out of the hand of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.97.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 11,
      "referenceLabel": "Psalms 97:11",
      "text": "Light is sown for the righteous, and gladness for the upright in heart.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.97.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 12,
      "referenceLabel": "Psalms 97:12",
      "text": "Be glad in Yahweh, you righteous people! Give thanks to his holy Name.",
      "paragraphStart": false
    }
  ]
}
