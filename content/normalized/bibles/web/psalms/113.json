{
  "chapter": {
    "id": "web:psalms.113",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 113,
    "referenceLabel": "Psalms 113",
    "summary": "Source text for Psalms 113 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.113.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 1,
      "referenceLabel": "Psalms 113:1",
      "text": "Praise Yah! Praise, you servants of Yahweh, praise Yahweh’s name.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.113.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 2,
      "referenceLabel": "Psalms 113:2",
      "text": "Blessed be Yahweh’s name, from this time forward and forever more.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.113.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 3,
      "referenceLabel": "Psalms 113:3",
      "text": "From the rising of the sun to its going down, Yahweh’s name is to be praised.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.113.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 4,
      "referenceLabel": "Psalms 113:4",
      "text": "Yahweh is high above all nations, his glory above the heavens.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.113.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 5,
      "referenceLabel": "Psalms 113:5",
      "text": "Who is like Yahweh, our God, who has his seat on high,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.113.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 6,
      "referenceLabel": "Psalms 113:6",
      "text": "who stoops down to see in heaven and in the earth?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.113.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 7,
      "referenceLabel": "Psalms 113:7",
      "text": "He raises up the poor out of the dust, and lifts up the needy from the ash heap,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.113.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 8,
      "referenceLabel": "Psalms 113:8",
      "text": "that he may set him with princes, even with the princes of his people.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.113.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 9,
      "referenceLabel": "Psalms 113:9",
      "text": "He settles the barren woman in her home as a joyful mother of children. Praise Yah!",
      "paragraphStart": false
    }
  ]
}
