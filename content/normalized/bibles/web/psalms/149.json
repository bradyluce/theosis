{
  "chapter": {
    "id": "web:psalms.149",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 149,
    "referenceLabel": "Psalms 149",
    "summary": "Source text for Psalms 149 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.149.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 1,
      "referenceLabel": "Psalms 149:1",
      "text": "Praise Yahweh! Sing to Yahweh a new song, his praise in the assembly of the saints.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.149.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 2,
      "referenceLabel": "Psalms 149:2",
      "text": "Let Israel rejoice in him who made them. Let the children of Zion be joyful in their King.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.149.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 3,
      "referenceLabel": "Psalms 149:3",
      "text": "Let them praise his name in the dance! Let them sing praises to him with tambourine and harp!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.149.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 4,
      "referenceLabel": "Psalms 149:4",
      "text": "For Yahweh takes pleasure in his people. He crowns the humble with salvation.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.149.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 5,
      "referenceLabel": "Psalms 149:5",
      "text": "Let the saints rejoice in honor. Let them sing for joy on their beds.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.149.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 6,
      "referenceLabel": "Psalms 149:6",
      "text": "May the high praises of God be in their mouths, and a two-edged sword in their hand,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.149.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 7,
      "referenceLabel": "Psalms 149:7",
      "text": "to execute vengeance on the nations, and punishments on the peoples;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.149.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 8,
      "referenceLabel": "Psalms 149:8",
      "text": "to bind their kings with chains, and their nobles with fetters of iron;",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.149.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 9,
      "referenceLabel": "Psalms 149:9",
      "text": "to execute on them the written judgment. All his saints have this honor. Praise Yah!",
      "paragraphStart": false
    }
  ]
}
