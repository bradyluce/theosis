{
  "chapter": {
    "id": "web:psalms.35",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 35,
    "referenceLabel": "Psalms 35",
    "summary": "Source text for Psalms 35 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.35.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 1,
      "referenceLabel": "Psalms 35:1",
      "text": "Contend, Yahweh, with those who contend with me. Fight against those who fight against me.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.35.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 2,
      "referenceLabel": "Psalms 35:2",
      "text": "Take hold of shield and buckler, and stand up for my help.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 3,
      "referenceLabel": "Psalms 35:3",
      "text": "Brandish the spear and block those who pursue me. Tell my soul, “ I am your salvation.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 4,
      "referenceLabel": "Psalms 35:4",
      "text": "Let those who seek after my soul be disappointed and brought to dishonor. Let those who plot my ruin be turned back and confounded.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 5,
      "referenceLabel": "Psalms 35:5",
      "text": "Let them be as chaff before the wind, Yahweh ’s angel driving them on.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 6,
      "referenceLabel": "Psalms 35:6",
      "text": "Let their way be dark and slippery, Yahweh ’s angel pursuing them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 7,
      "referenceLabel": "Psalms 35:7",
      "text": "For without cause they have hidden their net in a pit for me. Without cause they have dug a pit for my soul.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 8,
      "referenceLabel": "Psalms 35:8",
      "text": "Let destruction come on him unawares. Let his net that he has hidden catch himself. Let him fall into that destruction.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 9,
      "referenceLabel": "Psalms 35:9",
      "text": "My soul shall be joyful in Yahweh. It shall rejoice in his salvation.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 10,
      "referenceLabel": "Psalms 35:10",
      "text": "All my bones shall say, “ Yahweh, who is like you, who delivers the poor from him who is too strong for him; yes, the poor and the needy from him who robs him?”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 11,
      "referenceLabel": "Psalms 35:11",
      "text": "Unrighteous witnesses rise up. They ask me about things that I don’t know about.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 12,
      "referenceLabel": "Psalms 35:12",
      "text": "They reward me evil for good, to the bereaving of my soul.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 13,
      "referenceLabel": "Psalms 35:13",
      "text": "But as for me, when they were sick, my clothing was sackcloth. I afflicted my soul with fasting. My prayer returned into my own bosom.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 14,
      "referenceLabel": "Psalms 35:14",
      "text": "I behaved myself as though it had been my friend or my brother. I bowed down mourning, as one who mourns his mother.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 15,
      "referenceLabel": "Psalms 35:15",
      "text": "But in my adversity, they rejoiced, and gathered themselves together. The attackers gathered themselves together against me, and I didn’t know it. They tore at me, and didn’t cease.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 16,
      "referenceLabel": "Psalms 35:16",
      "text": "Like the profane mockers in feasts, they gnashed their teeth at me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 17,
      "referenceLabel": "Psalms 35:17",
      "text": "Lord, how long will you look on? Rescue my soul from their destruction, my precious life from the lions.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 18,
      "referenceLabel": "Psalms 35:18",
      "text": "I will give you thanks in the great assembly. I will praise you among many people.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 19,
      "referenceLabel": "Psalms 35:19",
      "text": "Don’t let those who are my enemies wrongfully rejoice over me; neither let those who hate me without a cause wink their eyes.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 20,
      "referenceLabel": "Psalms 35:20",
      "text": "For they don’t speak peace, but they devise deceitful words against those who are quiet in the land.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 21,
      "referenceLabel": "Psalms 35:21",
      "text": "Yes, they opened their mouth wide against me. They said, “ Aha! Aha! Our eye has seen it!”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 22,
      "referenceLabel": "Psalms 35:22",
      "text": "You have seen it, Yahweh. Don’t keep silent. Lord, don’t be far from me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.23",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 23,
      "referenceLabel": "Psalms 35:23",
      "text": "Wake up! Rise up to defend me, my God! My Lord, contend for me!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.24",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 24,
      "referenceLabel": "Psalms 35:24",
      "text": "Vindicate me, Yahweh my God, according to your righteousness. Don’t let them gloat over me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.25",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 25,
      "referenceLabel": "Psalms 35:25",
      "text": "Don’t let them say in their heart, “ Aha! That ’s the way we want it!” Don’t let them say, “ We have swallowed him up!”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.26",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 26,
      "referenceLabel": "Psalms 35:26",
      "text": "Let them be disappointed and confounded together who rejoice at my calamity. Let them be clothed with shame and dishonor who magnify themselves against me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.27",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 27,
      "referenceLabel": "Psalms 35:27",
      "text": "Let those who favor my righteous cause shout for joy and be glad. Yes, let them say continually, “ May Yahweh be magnified, who has pleasure in the prosperity of his servant!”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.35.28",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 28,
      "referenceLabel": "Psalms 35:28",
      "text": "My tongue shall talk about your righteousness and about your praise all day long.",
      "paragraphStart": false
    }
  ]
}
