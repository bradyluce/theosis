{
  "chapter": {
    "id": "web:psalms.30",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 30,
    "referenceLabel": "Psalms 30",
    "summary": "Source text for Psalms 30 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.30.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 1,
      "referenceLabel": "Psalms 30:1",
      "text": "I will extol you, Yahweh, for you have raised me up, and have not made my foes to rejoice over me.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.30.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 2,
      "referenceLabel": "Psalms 30:2",
      "text": "Yahweh my God, I cried to you, and you have healed me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.30.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 3,
      "referenceLabel": "Psalms 30:3",
      "text": "Yahweh, you have brought up my soul from Sheol. You have kept me alive, that I should not go down to the pit.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.30.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 4,
      "referenceLabel": "Psalms 30:4",
      "text": "Sing praise to Yahweh, you saints of his. Give thanks to his holy name.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.30.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 5,
      "referenceLabel": "Psalms 30:5",
      "text": "For his anger is but for a moment. His favor is for a lifetime. Weeping may stay for the night, but joy comes in the morning.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.30.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 6,
      "referenceLabel": "Psalms 30:6",
      "text": "As for me, I said in my prosperity, “ I shall never be moved.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.30.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 7,
      "referenceLabel": "Psalms 30:7",
      "text": "You, Yahweh, when you favored me, made my mountain stand strong; but when you hid your face, I was troubled.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.30.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 8,
      "referenceLabel": "Psalms 30:8",
      "text": "I cried to you, Yahweh. I made supplication to the Lord:",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.30.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 9,
      "referenceLabel": "Psalms 30:9",
      "text": "“What profit is there in my destruction, if I go down to the pit? Shall the dust praise you? Shall it declare your truth?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.30.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 10,
      "referenceLabel": "Psalms 30:10",
      "text": "Hear, Yahweh, and have mercy on me. Yahweh, be my helper.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.30.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 11,
      "referenceLabel": "Psalms 30:11",
      "text": "You have turned my mourning into dancing for me. You have removed my sackcloth, and clothed me with gladness,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.30.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 12,
      "referenceLabel": "Psalms 30:12",
      "text": "to the end that my heart may sing praise to you, and not be silent. Yahweh my God, I will give thanks to you forever!",
      "paragraphStart": false
    }
  ]
}
