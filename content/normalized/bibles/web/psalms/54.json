{
  "chapter": {
    "id": "web:psalms.54",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 54,
    "referenceLabel": "Psalms 54",
    "summary": "Source text for Psalms 54 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.54.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 1,
      "referenceLabel": "Psalms 54:1",
      "text": "Save me, God, by your name. Vindicate me in your might.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.54.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 2,
      "referenceLabel": "Psalms 54:2",
      "text": "Hear my prayer, God. Listen to the words of my mouth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.54.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 3,
      "referenceLabel": "Psalms 54:3",
      "text": "For strangers have risen up against me. Violent men have sought after my soul. They haven’t set God before them. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.54.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 4,
      "referenceLabel": "Psalms 54:4",
      "text": "Behold, God is my helper. The Lord is the one who sustains my soul.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.54.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 5,
      "referenceLabel": "Psalms 54:5",
      "text": "He will repay the evil to my enemies. Destroy them in your truth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.54.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 6,
      "referenceLabel": "Psalms 54:6",
      "text": "With a free will offering, I will sacrifice to you. I will give thanks to your name, Yahweh, for it is good.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.54.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 7,
      "referenceLabel": "Psalms 54:7",
      "text": "For he has delivered me out of all trouble. My eye has seen triumph over my enemies.",
      "paragraphStart": false
    }
  ]
}
