{
  "chapter": {
    "id": "web:psalms.124",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 124,
    "referenceLabel": "Psalms 124",
    "summary": "Source text for Psalms 124 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.124.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 1,
      "referenceLabel": "Psalms 124:1",
      "text": "If it had not been Yahweh who was on our side, let Israel now say,",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.124.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 2,
      "referenceLabel": "Psalms 124:2",
      "text": "if it had not been Yahweh who was on our side, when men rose up against us,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.124.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 3,
      "referenceLabel": "Psalms 124:3",
      "text": "then they would have swallowed us up alive, when their wrath was kindled against us,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.124.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 4,
      "referenceLabel": "Psalms 124:4",
      "text": "then the waters would have overwhelmed us, the stream would have gone over our soul.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.124.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 5,
      "referenceLabel": "Psalms 124:5",
      "text": "Then the proud waters would have gone over our soul.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.124.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 6,
      "referenceLabel": "Psalms 124:6",
      "text": "Blessed be Yahweh, who has not given us as a prey to their teeth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.124.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 7,
      "referenceLabel": "Psalms 124:7",
      "text": "Our soul has escaped like a bird out of the fowler’s snare. The snare is broken, and we have escaped.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.124.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 8,
      "referenceLabel": "Psalms 124:8",
      "text": "Our help is in Yahweh’s name, who made heaven and earth.",
      "paragraphStart": false
    }
  ]
}
