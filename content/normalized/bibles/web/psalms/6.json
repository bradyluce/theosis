{
  "chapter": {
    "id": "web:psalms.6",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 6,
    "referenceLabel": "Psalms 6",
    "summary": "Source text for Psalms 6 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.6.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Psalms 6:1",
      "text": "Yahweh, don’t rebuke me in your anger, neither discipline me in your wrath.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.6.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Psalms 6:2",
      "text": "Have mercy on me, Yahweh, for I am faint. Yahweh, heal me, for my bones are troubled.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.6.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Psalms 6:3",
      "text": "My soul is also in great anguish. But you, Yahweh — how long?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.6.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Psalms 6:4",
      "text": "Return, Yahweh. Deliver my soul, and save me for your loving kindness’ sake.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.6.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Psalms 6:5",
      "text": "For in death there is no memory of you. In Sheol, who shall give you thanks?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.6.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Psalms 6:6",
      "text": "I am weary with my groaning. Every night I flood my bed. I drench my couch with my tears.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.6.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Psalms 6:7",
      "text": "My eye wastes away because of grief. It grows old because of all my adversaries.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.6.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Psalms 6:8",
      "text": "Depart from me, all you workers of iniquity, for Yahweh has heard the voice of my weeping.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.6.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Psalms 6:9",
      "text": "Yahweh has heard my supplication. Yahweh accepts my prayer.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.6.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Psalms 6:10",
      "text": "May all my enemies be ashamed and dismayed. They shall turn back, they shall be disgraced suddenly.",
      "paragraphStart": false
    }
  ]
}
