{
  "chapter": {
    "id": "web:psalms.80",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 80,
    "referenceLabel": "Psalms 80",
    "summary": "Source text for Psalms 80 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.80.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 1,
      "referenceLabel": "Psalms 80:1",
      "text": "Hear us, Shepherd of Israel, you who lead Joseph like a flock, you who sit above the cherubim, shine out.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.80.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 2,
      "referenceLabel": "Psalms 80:2",
      "text": "Before Ephraim, Benjamin, and Manasseh, stir up your might! Come to save us!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.80.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 3,
      "referenceLabel": "Psalms 80:3",
      "text": "Turn us again, God. Cause your face to shine, and we will be saved.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.80.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 4,
      "referenceLabel": "Psalms 80:4",
      "text": "Yahweh God of Armies, how long will you be angry against the prayer of your people?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.80.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 5,
      "referenceLabel": "Psalms 80:5",
      "text": "You have fed them with the bread of tears, and given them tears to drink in large measure.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.80.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 6,
      "referenceLabel": "Psalms 80:6",
      "text": "You make us a source of contention to our neighbors. Our enemies laugh among themselves.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.80.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 7,
      "referenceLabel": "Psalms 80:7",
      "text": "Turn us again, God of Armies. Cause your face to shine, and we will be saved.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.80.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 8,
      "referenceLabel": "Psalms 80:8",
      "text": "You brought a vine out of Egypt. You drove out the nations, and planted it.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.80.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 9,
      "referenceLabel": "Psalms 80:9",
      "text": "You cleared the ground for it. It took deep root, and filled the land.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.80.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 10,
      "referenceLabel": "Psalms 80:10",
      "text": "The mountains were covered with its shadow. Its boughs were like God’s cedars.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.80.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 11,
      "referenceLabel": "Psalms 80:11",
      "text": "It sent out its branches to the sea, its shoots to the River.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.80.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 12,
      "referenceLabel": "Psalms 80:12",
      "text": "Why have you broken down its walls, so that all those who pass by the way pluck it?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.80.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 13,
      "referenceLabel": "Psalms 80:13",
      "text": "The boar out of the wood ravages it. The wild animals of the field feed on it.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.80.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 14,
      "referenceLabel": "Psalms 80:14",
      "text": "Turn again, we beg you, God of Armies. Look down from heaven, and see, and visit this vine,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.80.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 15,
      "referenceLabel": "Psalms 80:15",
      "text": "the stock which your right hand planted, the branch that you made strong for yourself.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.80.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 16,
      "referenceLabel": "Psalms 80:16",
      "text": "It’s burned with fire. It’s cut down. They perish at your rebuke.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.80.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 17,
      "referenceLabel": "Psalms 80:17",
      "text": "Let your hand be on the man of your right hand, on the son of man whom you made strong for yourself.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.80.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 18,
      "referenceLabel": "Psalms 80:18",
      "text": "So we will not turn away from you. Revive us, and we will call on your name.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.80.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 19,
      "referenceLabel": "Psalms 80:19",
      "text": "Turn us again, Yahweh God of Armies. Cause your face to shine, and we will be saved.",
      "paragraphStart": false
    }
  ]
}
