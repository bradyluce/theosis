{
  "chapter": {
    "id": "web:psalms.21",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 21,
    "referenceLabel": "Psalms 21",
    "summary": "Source text for Psalms 21 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.21.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Psalms 21:1",
      "text": "The king rejoices in your strength, Yahweh! How greatly he rejoices in your salvation!",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.21.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Psalms 21:2",
      "text": "You have given him his heart’s desire, and have not withheld the request of his lips. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.21.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Psalms 21:3",
      "text": "For you meet him with the blessings of goodness. You set a crown of fine gold on his head.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.21.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Psalms 21:4",
      "text": "He asked life of you and you gave it to him, even length of days forever and ever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.21.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Psalms 21:5",
      "text": "His glory is great in your salvation. You lay honor and majesty on him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.21.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Psalms 21:6",
      "text": "For you make him most blessed forever. You make him glad with joy in your presence.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.21.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Psalms 21:7",
      "text": "For the king trusts in Yahweh. Through the loving kindness of the Most High, he shall not be moved.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.21.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Psalms 21:8",
      "text": "Your hand will find out all of your enemies. Your right hand will find out those who hate you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.21.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Psalms 21:9",
      "text": "You will make them as a fiery furnace in the time of your anger. Yahweh will swallow them up in his wrath. The fire shall devour them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.21.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Psalms 21:10",
      "text": "You will destroy their descendants from the earth, their posterity from among the children of men.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.21.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Psalms 21:11",
      "text": "For they intended evil against you. They plotted evil against you which cannot succeed.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.21.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Psalms 21:12",
      "text": "For you will make them turn their back, when you aim drawn bows at their face.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.21.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Psalms 21:13",
      "text": "Be exalted, Yahweh, in your strength, so we will sing and praise your power.",
      "paragraphStart": false
    }
  ]
}
