{
  "chapter": {
    "id": "web:psalms.41",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 41,
    "referenceLabel": "Psalms 41",
    "summary": "Source text for Psalms 41 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.41.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 1,
      "referenceLabel": "Psalms 41:1",
      "text": "Blessed is he who considers the poor. Yahweh will deliver him in the day of evil.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.41.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 2,
      "referenceLabel": "Psalms 41:2",
      "text": "Yahweh will preserve him, and keep him alive. He shall be blessed on the earth, and he will not surrender him to the will of his enemies.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.41.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 3,
      "referenceLabel": "Psalms 41:3",
      "text": "Yahweh will sustain him on his sickbed, and restore him from his bed of illness.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.41.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 4,
      "referenceLabel": "Psalms 41:4",
      "text": "I said, “ Yahweh, have mercy on me! Heal me, for I have sinned against you.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.41.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 5,
      "referenceLabel": "Psalms 41:5",
      "text": "My enemies speak evil against me: “ When will he die, and his name perish?”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.41.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 6,
      "referenceLabel": "Psalms 41:6",
      "text": "If he comes to see me, he speaks falsehood. His heart gathers iniquity to itself. When he goes abroad, he tells it.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.41.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 7,
      "referenceLabel": "Psalms 41:7",
      "text": "All who hate me whisper together against me. They imagine the worst for me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.41.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 8,
      "referenceLabel": "Psalms 41:8",
      "text": "“ An evil disease”, they say, “ has afflicted him. Now that he lies he shall rise up no more.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.41.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 9,
      "referenceLabel": "Psalms 41:9",
      "text": "Yes, my own familiar friend, in whom I trusted, who ate bread with me, has lifted up his heel against me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.41.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 10,
      "referenceLabel": "Psalms 41:10",
      "text": "But you, Yahweh, have mercy on me, and raise me up, that I may repay them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.41.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 11,
      "referenceLabel": "Psalms 41:11",
      "text": "By this I know that you delight in me, because my enemy doesn’t triumph over me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.41.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 12,
      "referenceLabel": "Psalms 41:12",
      "text": "As for me, you uphold me in my integrity, and set me in your presence forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.41.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 13,
      "referenceLabel": "Psalms 41:13",
      "text": "Blessed be Yahweh, the God of Israel, from everlasting and to everlasting! Amen and amen.",
      "paragraphStart": false
    }
  ]
}
