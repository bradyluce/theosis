{
  "chapter": {
    "id": "web:psalms.137",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 137,
    "referenceLabel": "Psalms 137",
    "summary": "Source text for Psalms 137 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.137.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 1,
      "referenceLabel": "Psalms 137:1",
      "text": "By the rivers of Babylon, there we sat down. Yes, we wept, when we remembered Zion.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.137.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 2,
      "referenceLabel": "Psalms 137:2",
      "text": "On the willows in that land, we hung up our harps.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.137.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 3,
      "referenceLabel": "Psalms 137:3",
      "text": "For there, those who led us captive asked us for songs. Those who tormented us demanded songs of joy: “Sing us one of the songs of Zion!”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.137.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 4,
      "referenceLabel": "Psalms 137:4",
      "text": "How can we sing Yahweh’s song in a foreign land?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.137.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 5,
      "referenceLabel": "Psalms 137:5",
      "text": "If I forget you, Jerusalem, let my right hand forget its skill.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.137.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 6,
      "referenceLabel": "Psalms 137:6",
      "text": "Let my tongue stick to the roof of my mouth if I don’t remember you, if I don’t prefer Jerusalem above my chief joy.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.137.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 7,
      "referenceLabel": "Psalms 137:7",
      "text": "Remember, Yahweh, against the children of Edom in the day of Jerusalem, who said, “Raze it! Raze it even to its foundation!”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.137.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 8,
      "referenceLabel": "Psalms 137:8",
      "text": "Daughter of Babylon, doomed to destruction, he will be happy who repays you, as you have done to us.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.137.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 9,
      "referenceLabel": "Psalms 137:9",
      "text": "Happy shall he be, who takes and dashes your little ones against the rock.",
      "paragraphStart": false
    }
  ]
}
