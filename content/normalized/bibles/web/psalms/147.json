{
  "chapter": {
    "id": "web:psalms.147",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 147,
    "referenceLabel": "Psalms 147",
    "summary": "Source text for Psalms 147 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.147.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 1,
      "referenceLabel": "Psalms 147:1",
      "text": "Praise Yah, for it is good to sing praises to our God; for it is pleasant and fitting to praise him.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.147.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 2,
      "referenceLabel": "Psalms 147:2",
      "text": "Yahweh builds up Jerusalem. He gathers together the outcasts of Israel.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.147.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 3,
      "referenceLabel": "Psalms 147:3",
      "text": "He heals the broken in heart, and binds up their wounds.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.147.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 4,
      "referenceLabel": "Psalms 147:4",
      "text": "He counts the number of the stars. He calls them all by their names.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.147.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 5,
      "referenceLabel": "Psalms 147:5",
      "text": "Great is our Lord, and mighty in power. His understanding is infinite.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.147.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 6,
      "referenceLabel": "Psalms 147:6",
      "text": "Yahweh upholds the humble. He brings the wicked down to the ground.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.147.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 7,
      "referenceLabel": "Psalms 147:7",
      "text": "Sing to Yahweh with thanksgiving. Sing praises on the harp to our God,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.147.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 8,
      "referenceLabel": "Psalms 147:8",
      "text": "who covers the sky with clouds, who prepares rain for the earth, who makes grass grow on the mountains.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.147.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 9,
      "referenceLabel": "Psalms 147:9",
      "text": "He provides food for the livestock, and for the young ravens when they call.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.147.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 10,
      "referenceLabel": "Psalms 147:10",
      "text": "He doesn’t delight in the strength of the horse. He takes no pleasure in the legs of a man.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.147.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 11,
      "referenceLabel": "Psalms 147:11",
      "text": "Yahweh takes pleasure in those who fear him, in those who hope in his loving kindness.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.147.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 12,
      "referenceLabel": "Psalms 147:12",
      "text": "Praise Yahweh, Jerusalem! Praise your God, Zion!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.147.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 13,
      "referenceLabel": "Psalms 147:13",
      "text": "For he has strengthened the bars of your gates. He has blessed your children within you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.147.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 14,
      "referenceLabel": "Psalms 147:14",
      "text": "He makes peace in your borders. He fills you with the finest of the wheat.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.147.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 15,
      "referenceLabel": "Psalms 147:15",
      "text": "He sends out his commandment to the earth. His word runs very swiftly.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.147.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 16,
      "referenceLabel": "Psalms 147:16",
      "text": "He gives snow like wool, and scatters frost like ashes.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.147.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 17,
      "referenceLabel": "Psalms 147:17",
      "text": "He hurls down his hail like pebbles. Who can stand before his cold?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.147.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 18,
      "referenceLabel": "Psalms 147:18",
      "text": "He sends out his word, and melts them. He causes his wind to blow, and the waters flow.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.147.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 19,
      "referenceLabel": "Psalms 147:19",
      "text": "He shows his word to Jacob, his statutes and his ordinances to Israel.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.147.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 20,
      "referenceLabel": "Psalms 147:20",
      "text": "He has not done this for just any nation. They don’t know his ordinances. Praise Yah!",
      "paragraphStart": false
    }
  ]
}
