{
  "chapter": {
    "id": "web:psalms.140",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 140,
    "referenceLabel": "Psalms 140",
    "summary": "Source text for Psalms 140 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.140.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 1,
      "referenceLabel": "Psalms 140:1",
      "text": "Deliver me, Yahweh, from evil men. Preserve me from violent men:",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.140.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 2,
      "referenceLabel": "Psalms 140:2",
      "text": "those who devise mischief in their hearts. They continually gather themselves together for war.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.140.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 3,
      "referenceLabel": "Psalms 140:3",
      "text": "They have sharpened their tongues like a serpent. Viper’s poison is under their lips. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.140.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 4,
      "referenceLabel": "Psalms 140:4",
      "text": "Yahweh, keep me from the hands of the wicked. Preserve me from the violent men who have determined to trip my feet.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.140.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 5,
      "referenceLabel": "Psalms 140:5",
      "text": "The proud have hidden a snare for me, they have spread the cords of a net by the path. They have set traps for me. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.140.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 6,
      "referenceLabel": "Psalms 140:6",
      "text": "I said to Yahweh, “ You are my God.” Listen to the cry of my petitions, Yahweh.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.140.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 7,
      "referenceLabel": "Psalms 140:7",
      "text": "Yahweh, the Lord, the strength of my salvation, you have covered my head in the day of battle.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.140.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 8,
      "referenceLabel": "Psalms 140:8",
      "text": "Yahweh, don’t grant the desires of the wicked. Don’t let their evil plans succeed, or they will become proud. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.140.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 9,
      "referenceLabel": "Psalms 140:9",
      "text": "As for the head of those who surround me, let the mischief of their own lips cover them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.140.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 10,
      "referenceLabel": "Psalms 140:10",
      "text": "Let burning coals fall on them. Let them be thrown into the fire, into miry pits, from where they never rise.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.140.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 11,
      "referenceLabel": "Psalms 140:11",
      "text": "An evil speaker won’t be established in the earth. Evil will hunt the violent man to overthrow him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.140.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 12,
      "referenceLabel": "Psalms 140:12",
      "text": "I know that Yahweh will maintain the cause of the afflicted, and justice for the needy.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.140.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 13,
      "referenceLabel": "Psalms 140:13",
      "text": "Surely the righteous will give thanks to your name. The upright will dwell in your presence.",
      "paragraphStart": false
    }
  ]
}
