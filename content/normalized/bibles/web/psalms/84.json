{
  "chapter": {
    "id": "web:psalms.84",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 84,
    "referenceLabel": "Psalms 84",
    "summary": "Source text for Psalms 84 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.84.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 1,
      "referenceLabel": "Psalms 84:1",
      "text": "How lovely are your dwellings, Yahweh of Armies!",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.84.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 2,
      "referenceLabel": "Psalms 84:2",
      "text": "My soul longs, and even faints for the courts of Yahweh. My heart and my flesh cry out for the living God.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.84.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 3,
      "referenceLabel": "Psalms 84:3",
      "text": "Yes, the sparrow has found a home, and the swallow a nest for herself, where she may have her young, near your altars, Yahweh of Armies, my King, and my God.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.84.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 4,
      "referenceLabel": "Psalms 84:4",
      "text": "Blessed are those who dwell in your house. They are always praising you. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.84.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 5,
      "referenceLabel": "Psalms 84:5",
      "text": "Blessed are those whose strength is in you, who have set their hearts on a pilgrimage.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.84.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 6,
      "referenceLabel": "Psalms 84:6",
      "text": "Passing through the valley of Weeping, they make it a place of springs. Yes, the autumn rain covers it with blessings.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.84.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 7,
      "referenceLabel": "Psalms 84:7",
      "text": "They go from strength to strength. Every one of them appears before God in Zion.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.84.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 8,
      "referenceLabel": "Psalms 84:8",
      "text": "Yahweh, God of Armies, hear my prayer. Listen, God of Jacob. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.84.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 9,
      "referenceLabel": "Psalms 84:9",
      "text": "Behold, God our shield, look at the face of your anointed.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.84.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 10,
      "referenceLabel": "Psalms 84:10",
      "text": "For a day in your courts is better than a thousand. I would rather be a doorkeeper in the house of my God, than to dwell in the tents of wickedness.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.84.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 11,
      "referenceLabel": "Psalms 84:11",
      "text": "For Yahweh God is a sun and a shield. Yahweh will give grace and glory. He withholds no good thing from those who walk blamelessly.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.84.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 12,
      "referenceLabel": "Psalms 84:12",
      "text": "Yahweh of Armies, blessed is the man who trusts in you.",
      "paragraphStart": false
    }
  ]
}
