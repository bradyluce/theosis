{
  "chapter": {
    "id": "web:psalms.66",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 66,
    "referenceLabel": "Psalms 66",
    "summary": "Source text for Psalms 66 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.66.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 1,
      "referenceLabel": "Psalms 66:1",
      "text": "Make a joyful shout to God, all the earth!",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.66.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 2,
      "referenceLabel": "Psalms 66:2",
      "text": "Sing to the glory of his name! Offer glory and praise!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.66.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 3,
      "referenceLabel": "Psalms 66:3",
      "text": "Tell God, “How awesome are your deeds! Through the greatness of your power, your enemies submit themselves to you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.66.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 4,
      "referenceLabel": "Psalms 66:4",
      "text": "All the earth will worship you, and will sing to you; they will sing to your name.” Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.66.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 5,
      "referenceLabel": "Psalms 66:5",
      "text": "Come, and see God’s deeds — awesome work on behalf of the children of men.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.66.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 6,
      "referenceLabel": "Psalms 66:6",
      "text": "He turned the sea into dry land. They went through the river on foot. There, we rejoiced in him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.66.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 7,
      "referenceLabel": "Psalms 66:7",
      "text": "He rules by his might forever. His eyes watch the nations. Don’t let the rebellious rise up against him. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.66.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 8,
      "referenceLabel": "Psalms 66:8",
      "text": "Praise our God, you peoples! Make the sound of his praise heard,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.66.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 9,
      "referenceLabel": "Psalms 66:9",
      "text": "who preserves our life among the living, and doesn’t allow our feet to be moved.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.66.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 10,
      "referenceLabel": "Psalms 66:10",
      "text": "For you, God, have tested us. You have refined us, as silver is refined.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.66.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 11,
      "referenceLabel": "Psalms 66:11",
      "text": "You brought us into prison. You laid a burden on our backs.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.66.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 12,
      "referenceLabel": "Psalms 66:12",
      "text": "You allowed men to ride over our heads. We went through fire and through water, but you brought us to the place of abundance.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.66.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 13,
      "referenceLabel": "Psalms 66:13",
      "text": "I will come into your temple with burnt offerings. I will pay my vows to you,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.66.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 14,
      "referenceLabel": "Psalms 66:14",
      "text": "which my lips promised, and my mouth spoke, when I was in distress.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.66.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 15,
      "referenceLabel": "Psalms 66:15",
      "text": "I will offer to you burnt offerings of fat animals, with the offering of rams, I will offer bulls with goats. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.66.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 16,
      "referenceLabel": "Psalms 66:16",
      "text": "Come and hear, all you who fear God. I will declare what he has done for my soul.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.66.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 17,
      "referenceLabel": "Psalms 66:17",
      "text": "I cried to him with my mouth. He was extolled with my tongue.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.66.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 18,
      "referenceLabel": "Psalms 66:18",
      "text": "If I cherished sin in my heart, the Lord wouldn’t have listened.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.66.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 19,
      "referenceLabel": "Psalms 66:19",
      "text": "But most certainly, God has listened. He has heard the voice of my prayer.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.66.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 20,
      "referenceLabel": "Psalms 66:20",
      "text": "Blessed be God, who has not turned away my prayer, nor his loving kindness from me.",
      "paragraphStart": false
    }
  ]
}
