{
  "chapter": {
    "id": "web:psalms.20",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 20,
    "referenceLabel": "Psalms 20",
    "summary": "Source text for Psalms 20 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.20.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Psalms 20:1",
      "text": "May Yahweh answer you in the day of trouble. May the name of the God of Jacob set you up on high,",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.20.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Psalms 20:2",
      "text": "send you help from the sanctuary, grant you support from Zion,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.20.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Psalms 20:3",
      "text": "remember all your offerings, and accept your burned sacrifice. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.20.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Psalms 20:4",
      "text": "May he grant you your heart’s desire, and fulfill all your counsel.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.20.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Psalms 20:5",
      "text": "We will triumph in your salvation. In the name of our God, we will set up our banners. May Yahweh grant all your requests.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.20.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Psalms 20:6",
      "text": "Now I know that Yahweh saves his anointed. He will answer him from his holy heaven, with the saving strength of his right hand.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.20.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Psalms 20:7",
      "text": "Some trust in chariots, and some in horses, but we trust in the name of Yahweh our God.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.20.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Psalms 20:8",
      "text": "They are bowed down and fallen, but we rise up, and stand upright.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.20.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Psalms 20:9",
      "text": "Save, Yahweh! Let the King answer us when we call!",
      "paragraphStart": false
    }
  ]
}
