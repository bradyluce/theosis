{
  "chapter": {
    "id": "web:psalms.94",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 94,
    "referenceLabel": "Psalms 94",
    "summary": "Source text for Psalms 94 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.94.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 1,
      "referenceLabel": "Psalms 94:1",
      "text": "Yahweh, you God to whom vengeance belongs, you God to whom vengeance belongs, shine out.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.94.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 2,
      "referenceLabel": "Psalms 94:2",
      "text": "Rise up, you judge of the earth. Pay back the proud what they deserve.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 3,
      "referenceLabel": "Psalms 94:3",
      "text": "Yahweh, how long will the wicked, how long will the wicked triumph?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 4,
      "referenceLabel": "Psalms 94:4",
      "text": "They pour out arrogant words. All the evildoers boast.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 5,
      "referenceLabel": "Psalms 94:5",
      "text": "They break your people in pieces, Yahweh, and afflict your heritage.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 6,
      "referenceLabel": "Psalms 94:6",
      "text": "They kill the widow and the alien, and murder the fatherless.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 7,
      "referenceLabel": "Psalms 94:7",
      "text": "They say, “ Yah will not see, neither will Jacob ’s God consider.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 8,
      "referenceLabel": "Psalms 94:8",
      "text": "Consider, you senseless among the people; you fools, when will you be wise?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 9,
      "referenceLabel": "Psalms 94:9",
      "text": "He who implanted the ear, won’t he hear? He who formed the eye, won’t he see?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 10,
      "referenceLabel": "Psalms 94:10",
      "text": "He who disciplines the nations, won’t he punish? He who teaches man knows.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 11,
      "referenceLabel": "Psalms 94:11",
      "text": "Yahweh knows the thoughts of man, that they are futile.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 12,
      "referenceLabel": "Psalms 94:12",
      "text": "Blessed is the man whom you discipline, Yah, and teach out of your law,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 13,
      "referenceLabel": "Psalms 94:13",
      "text": "that you may give him rest from the days of adversity, until the pit is dug for the wicked.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 14,
      "referenceLabel": "Psalms 94:14",
      "text": "For Yahweh won’t reject his people, neither will he forsake his inheritance.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 15,
      "referenceLabel": "Psalms 94:15",
      "text": "For judgment will return to righteousness. All the upright in heart shall follow it.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 16,
      "referenceLabel": "Psalms 94:16",
      "text": "Who will rise up for me against the wicked? Who will stand up for me against the evildoers?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 17,
      "referenceLabel": "Psalms 94:17",
      "text": "Unless Yahweh had been my help, my soul would have soon lived in silence.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 18,
      "referenceLabel": "Psalms 94:18",
      "text": "When I said, “ My foot is slipping!” Your loving kindness, Yahweh, held me up.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 19,
      "referenceLabel": "Psalms 94:19",
      "text": "In the multitude of my thoughts within me, your comforts delight my soul.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 20,
      "referenceLabel": "Psalms 94:20",
      "text": "Shall the throne of wickedness have fellowship with you, which brings about mischief by statute?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 21,
      "referenceLabel": "Psalms 94:21",
      "text": "They gather themselves together against the soul of the righteous, and condemn the innocent blood.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 22,
      "referenceLabel": "Psalms 94:22",
      "text": "But Yahweh has been my high tower, my God, the rock of my refuge.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.94.23",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 23,
      "referenceLabel": "Psalms 94:23",
      "text": "He has brought on them their own iniquity, and will cut them off in their own wickedness. Yahweh, our God, will cut them off.",
      "paragraphStart": false
    }
  ]
}
