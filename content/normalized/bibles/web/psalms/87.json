{
  "chapter": {
    "id": "web:psalms.87",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 87,
    "referenceLabel": "Psalms 87",
    "summary": "Source text for Psalms 87 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.87.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 1,
      "referenceLabel": "Psalms 87:1",
      "text": "His foundation is in the holy mountains.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.87.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 2,
      "referenceLabel": "Psalms 87:2",
      "text": "Yahweh loves the gates of Zion more than all the dwellings of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.87.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 3,
      "referenceLabel": "Psalms 87:3",
      "text": "Glorious things are spoken about you, city of God. Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.87.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 4,
      "referenceLabel": "Psalms 87:4",
      "text": "I will record Rahab and Babylon among those who acknowledge me. Behold, Philistia, Tyre, and also Ethiopia: “This one was born there.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.87.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 5,
      "referenceLabel": "Psalms 87:5",
      "text": "Yes, of Zion it will be said, “This one and that one was born in her;” the Most High himself will establish her.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.87.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 6,
      "referenceLabel": "Psalms 87:6",
      "text": "Yahweh will count, when he writes up the peoples, “This one was born there.” Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.87.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 7,
      "referenceLabel": "Psalms 87:7",
      "text": "Those who sing as well as those who dance say, “All my springs are in you.”",
      "paragraphStart": false
    }
  ]
}
