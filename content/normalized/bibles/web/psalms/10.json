{
  "chapter": {
    "id": "web:psalms.10",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 10,
    "referenceLabel": "Psalms 10",
    "summary": "Source text for Psalms 10 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.10.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Psalms 10:1",
      "text": "Why do you stand far off, Yahweh? Why do you hide yourself in times of trouble?",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.10.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Psalms 10:2",
      "text": "In arrogance, the wicked hunt down the weak. They are caught in the schemes that they devise.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.10.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Psalms 10:3",
      "text": "For the wicked boasts of his heart’s cravings. He blesses the greedy and condemns Yahweh.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.10.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Psalms 10:4",
      "text": "The wicked, in the pride of his face, has no room in his thoughts for God.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.10.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Psalms 10:5",
      "text": "His ways are prosperous at all times. He is arrogant, and your laws are far from his sight. As for all his adversaries, he sneers at them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.10.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Psalms 10:6",
      "text": "He says in his heart, “I shall not be shaken. For generations I shall have no trouble.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.10.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Psalms 10:7",
      "text": "His mouth is full of cursing, deceit, and oppression. Under his tongue is mischief and iniquity.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.10.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Psalms 10:8",
      "text": "He lies in wait near the villages. From ambushes, he murders the innocent. His eyes are secretly set against the helpless.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.10.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Psalms 10:9",
      "text": "He lurks in secret as a lion in his ambush. He lies in wait to catch the helpless. He catches the helpless when he draws him in his net.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.10.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Psalms 10:10",
      "text": "The helpless are crushed. They collapse. They fall under his strength.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.10.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Psalms 10:11",
      "text": "He says in his heart, “God has forgotten. He hides his face. He will never see it.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.10.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Psalms 10:12",
      "text": "Arise, Yahweh! God, lift up your hand! Don’t forget the helpless.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.10.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Psalms 10:13",
      "text": "Why does the wicked person condemn God, and say in his heart, “God won’t call me into account”?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.10.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Psalms 10:14",
      "text": "But you do see trouble and grief. You consider it to take it into your hand. You help the victim and the fatherless.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.10.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Psalms 10:15",
      "text": "Break the arm of the wicked. As for the evil man, seek out his wickedness until you find none.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.10.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Psalms 10:16",
      "text": "Yahweh is King forever and ever! The nations will perish out of his land.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.10.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Psalms 10:17",
      "text": "Yahweh, you have heard the desire of the humble. You will prepare their heart. You will cause your ear to hear,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.10.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Psalms 10:18",
      "text": "to judge the fatherless and the oppressed, that man who is of the earth may terrify no more.",
      "paragraphStart": false
    }
  ]
}
