{
  "chapter": {
    "id": "web:psalms.129",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 129,
    "referenceLabel": "Psalms 129",
    "summary": "Source text for Psalms 129 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.129.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 1,
      "referenceLabel": "Psalms 129:1",
      "text": "Many times they have afflicted me from my youth up. Let Israel now say:",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.129.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 2,
      "referenceLabel": "Psalms 129:2",
      "text": "many times they have afflicted me from my youth up, yet they have not prevailed against me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.129.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 3,
      "referenceLabel": "Psalms 129:3",
      "text": "The plowers plowed on my back. They made their furrows long.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.129.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 4,
      "referenceLabel": "Psalms 129:4",
      "text": "Yahweh is righteous. He has cut apart the cords of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.129.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 5,
      "referenceLabel": "Psalms 129:5",
      "text": "Let them be disappointed and turned backward, all those who hate Zion.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.129.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 6,
      "referenceLabel": "Psalms 129:6",
      "text": "Let them be as the grass on the housetops, which withers before it grows up,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.129.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 7,
      "referenceLabel": "Psalms 129:7",
      "text": "with which the reaper doesn’t fill his hand, nor he who binds sheaves, his bosom.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.129.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 8,
      "referenceLabel": "Psalms 129:8",
      "text": "Neither do those who go by say, “ The blessing of Yahweh be on you. We bless you in Yahweh ’s name.”",
      "paragraphStart": false
    }
  ]
}
