{
  "chapter": {
    "id": "web:psalms.26",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 26,
    "referenceLabel": "Psalms 26",
    "summary": "Source text for Psalms 26 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.26.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Psalms 26:1",
      "text": "Judge me, Yahweh, for I have walked in my integrity. I have trusted also in Yahweh without wavering.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.26.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Psalms 26:2",
      "text": "Examine me, Yahweh, and prove me. Try my heart and my mind.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.26.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Psalms 26:3",
      "text": "For your loving kindness is before my eyes. I have walked in your truth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.26.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Psalms 26:4",
      "text": "I have not sat with deceitful men, neither will I go in with hypocrites.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.26.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Psalms 26:5",
      "text": "I hate the assembly of evildoers, and will not sit with the wicked.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.26.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Psalms 26:6",
      "text": "I will wash my hands in innocence, so I will go about your altar, Yahweh,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.26.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Psalms 26:7",
      "text": "that I may make the voice of thanksgiving to be heard and tell of all your wondrous deeds.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.26.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Psalms 26:8",
      "text": "Yahweh, I love the habitation of your house, the place where your glory dwells.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.26.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Psalms 26:9",
      "text": "Don’t gather my soul with sinners, nor my life with bloodthirsty men",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.26.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Psalms 26:10",
      "text": "in whose hands is wickedness; their right hand is full of bribes.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.26.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Psalms 26:11",
      "text": "But as for me, I will walk in my integrity. Redeem me, and be merciful to me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.26.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Psalms 26:12",
      "text": "My foot stands in an even place. In the congregations I will bless Yahweh.",
      "paragraphStart": false
    }
  ]
}
