{
  "chapter": {
    "id": "web:psalms.17",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 17,
    "referenceLabel": "Psalms 17",
    "summary": "Source text for Psalms 17 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.17.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Psalms 17:1",
      "text": "Hear, Yahweh, my righteous plea. Give ear to my prayer that doesn’t go out of deceitful lips.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.17.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Psalms 17:2",
      "text": "Let my sentence come out of your presence. Let your eyes look on equity.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.17.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Psalms 17:3",
      "text": "You have proved my heart. You have visited me in the night. You have tried me, and found nothing. I have resolved that my mouth shall not disobey.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.17.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Psalms 17:4",
      "text": "As for the deeds of men, by the word of your lips, I have kept myself from the ways of the violent.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.17.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Psalms 17:5",
      "text": "My steps have held fast to your paths. My feet have not slipped.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.17.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Psalms 17:6",
      "text": "I have called on you, for you will answer me, God. Turn your ear to me. Hear my speech.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.17.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Psalms 17:7",
      "text": "Show your marvelous loving kindness, you who save those who take refuge by your right hand from their enemies.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.17.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Psalms 17:8",
      "text": "Keep me as the apple of your eye. Hide me under the shadow of your wings,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.17.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Psalms 17:9",
      "text": "from the wicked who oppress me, my deadly enemies, who surround me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.17.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Psalms 17:10",
      "text": "They close up their callous hearts. With their mouth they speak proudly.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.17.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Psalms 17:11",
      "text": "They have now surrounded us in our steps. They set their eyes to cast us down to the earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.17.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Psalms 17:12",
      "text": "He is like a lion that is greedy of his prey, as it were a young lion lurking in secret places.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.17.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Psalms 17:13",
      "text": "Arise, Yahweh, confront him. Cast him down. Deliver my soul from the wicked by your sword,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.17.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Psalms 17:14",
      "text": "from men by your hand, Yahweh, from men of the world, whose portion is in this life. You fill the belly of your cherished ones. Your sons have plenty, and they store up wealth for their children.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.17.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Psalms 17:15",
      "text": "As for me, I shall see your face in righteousness. I shall be satisfied, when I awake, with seeing your form.",
      "paragraphStart": false
    }
  ]
}
