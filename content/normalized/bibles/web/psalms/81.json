{
  "chapter": {
    "id": "web:psalms.81",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 81,
    "referenceLabel": "Psalms 81",
    "summary": "Source text for Psalms 81 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.81.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 1,
      "referenceLabel": "Psalms 81:1",
      "text": "Sing aloud to God, our strength! Make a joyful shout to the God of Jacob!",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.81.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 2,
      "referenceLabel": "Psalms 81:2",
      "text": "Raise a song, and bring here the tambourine, the pleasant lyre with the harp.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.81.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 3,
      "referenceLabel": "Psalms 81:3",
      "text": "Blow the trumpet at the New Moon, at the full moon, on our feast day.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.81.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 4,
      "referenceLabel": "Psalms 81:4",
      "text": "For it is a statute for Israel, an ordinance of the God of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.81.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 5,
      "referenceLabel": "Psalms 81:5",
      "text": "He appointed it in Joseph for a covenant, when he went out over the land of Egypt, I heard a language that I didn’t know.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.81.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 6,
      "referenceLabel": "Psalms 81:6",
      "text": "“I removed his shoulder from the burden. His hands were freed from the basket.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.81.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 7,
      "referenceLabel": "Psalms 81:7",
      "text": "You called in trouble, and I delivered you. I answered you in the secret place of thunder. I tested you at the waters of Meribah.” Selah.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.81.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 8,
      "referenceLabel": "Psalms 81:8",
      "text": "“Hear, my people, and I will testify to you, Israel, if you would listen to me!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.81.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 9,
      "referenceLabel": "Psalms 81:9",
      "text": "There shall be no strange god in you, neither shall you worship any foreign god.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.81.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 10,
      "referenceLabel": "Psalms 81:10",
      "text": "I am Yahweh, your God, who brought you up out of the land of Egypt. Open your mouth wide, and I will fill it.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.81.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 11,
      "referenceLabel": "Psalms 81:11",
      "text": "But my people didn’t listen to my voice. Israel desired none of me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.81.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 12,
      "referenceLabel": "Psalms 81:12",
      "text": "So I let them go after the stubbornness of their hearts, that they might walk in their own counsels.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.81.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 13,
      "referenceLabel": "Psalms 81:13",
      "text": "Oh that my people would listen to me, that Israel would walk in my ways!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.81.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 14,
      "referenceLabel": "Psalms 81:14",
      "text": "I would soon subdue their enemies, and turn my hand against their adversaries.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.81.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 15,
      "referenceLabel": "Psalms 81:15",
      "text": "The haters of Yahweh would cringe before him, and their punishment would last forever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.81.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 16,
      "referenceLabel": "Psalms 81:16",
      "text": "But he would have also fed them with the finest of the wheat. I will satisfy you with honey out of the rock.”",
      "paragraphStart": false
    }
  ]
}
