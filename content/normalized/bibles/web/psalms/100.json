{
  "chapter": {
    "id": "web:psalms.100",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 100,
    "referenceLabel": "Psalms 100",
    "summary": "Source text for Psalms 100 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.100.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 1,
      "referenceLabel": "Psalms 100:1",
      "text": "Shout for joy to Yahweh, all you lands!",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.100.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 2,
      "referenceLabel": "Psalms 100:2",
      "text": "Serve Yahweh with gladness. Come before his presence with singing.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.100.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 3,
      "referenceLabel": "Psalms 100:3",
      "text": "Know that Yahweh, he is God. It is he who has made us, and we are his. We are his people, and the sheep of his pasture.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.100.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 4,
      "referenceLabel": "Psalms 100:4",
      "text": "Enter into his gates with thanksgiving, and into his courts with praise. Give thanks to him, and bless his name.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.100.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 5,
      "referenceLabel": "Psalms 100:5",
      "text": "For Yahweh is good. His loving kindness endures forever, his faithfulness to all generations.",
      "paragraphStart": false
    }
  ]
}
