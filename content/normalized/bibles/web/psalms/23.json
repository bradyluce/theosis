{
  "chapter": {
    "id": "web:psalms.23",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 23,
    "referenceLabel": "Psalms 23",
    "summary": "Source text for Psalms 23 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.23.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Psalms 23:1",
      "text": "Yahweh is my shepherd; I shall lack nothing.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.23.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Psalms 23:2",
      "text": "He makes me lie down in green pastures. He leads me beside still waters.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.23.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Psalms 23:3",
      "text": "He restores my soul. He guides me in the paths of righteousness for his name ’s sake.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.23.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Psalms 23:4",
      "text": "Even though I walk through the valley of the shadow of death, I will fear no evil, for you are with me. Your rod and your staff, they comfort me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.23.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Psalms 23:5",
      "text": "You prepare a table before me in the presence of my enemies. You anoint my head with oil. My cup runs over.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.23.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Psalms 23:6",
      "text": "Surely goodness and loving kindness shall follow me all the days of my life, and I will dwell in Yahweh ’s house forever.",
      "paragraphStart": false
    }
  ]
}
