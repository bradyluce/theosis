{
  "chapter": {
    "id": "web:psalms.71",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 71,
    "referenceLabel": "Psalms 71",
    "summary": "Source text for Psalms 71 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.71.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 1,
      "referenceLabel": "Psalms 71:1",
      "text": "In you, Yahweh, I take refuge. Never let me be disappointed.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.71.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 2,
      "referenceLabel": "Psalms 71:2",
      "text": "Deliver me in your righteousness, and rescue me. Turn your ear to me, and save me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 3,
      "referenceLabel": "Psalms 71:3",
      "text": "Be to me a rock of refuge to which I may always go. Give the command to save me, for you are my rock and my fortress.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 4,
      "referenceLabel": "Psalms 71:4",
      "text": "Rescue me, my God, from the hand of the wicked, from the hand of the unrighteous and cruel man.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 5,
      "referenceLabel": "Psalms 71:5",
      "text": "For you are my hope, Lord Yahweh, my confidence from my youth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 6,
      "referenceLabel": "Psalms 71:6",
      "text": "I have relied on you from the womb. You are he who took me out of my mother’s womb. I will always praise you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 7,
      "referenceLabel": "Psalms 71:7",
      "text": "I am a marvel to many, but you are my strong refuge.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 8,
      "referenceLabel": "Psalms 71:8",
      "text": "My mouth shall be filled with your praise, with your honor all day long.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 9,
      "referenceLabel": "Psalms 71:9",
      "text": "Don’t reject me in my old age. Don’t forsake me when my strength fails.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 10,
      "referenceLabel": "Psalms 71:10",
      "text": "For my enemies talk about me. Those who watch for my soul conspire together,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 11,
      "referenceLabel": "Psalms 71:11",
      "text": "saying, “God has forsaken him. Pursue and take him, for no one will rescue him.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 12,
      "referenceLabel": "Psalms 71:12",
      "text": "God, don’t be far from me. My God, hurry to help me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 13,
      "referenceLabel": "Psalms 71:13",
      "text": "Let my accusers be disappointed and consumed. Let them be covered with disgrace and scorn who want to harm me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 14,
      "referenceLabel": "Psalms 71:14",
      "text": "But I will always hope, and will add to all of your praise.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 15,
      "referenceLabel": "Psalms 71:15",
      "text": "My mouth will tell about your righteousness, and of your salvation all day, though I don’t know its full measure.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 16,
      "referenceLabel": "Psalms 71:16",
      "text": "I will come with the mighty acts of the Lord Yahweh. I will make mention of your righteousness, even of yours alone.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 17,
      "referenceLabel": "Psalms 71:17",
      "text": "God, you have taught me from my youth. Until now, I have declared your wondrous works.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 18,
      "referenceLabel": "Psalms 71:18",
      "text": "Yes, even when I am old and gray-haired, God, don’t forsake me, until I have declared your strength to the next generation, your might to everyone who is to come.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 19,
      "referenceLabel": "Psalms 71:19",
      "text": "God, your righteousness also reaches to the heavens. You have done great things. God, who is like you?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 20,
      "referenceLabel": "Psalms 71:20",
      "text": "You, who have shown us many and bitter troubles, you will let me live. You will bring us up again from the depths of the earth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 21,
      "referenceLabel": "Psalms 71:21",
      "text": "Increase my honor and comfort me again.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 22,
      "referenceLabel": "Psalms 71:22",
      "text": "I will also praise you with the harp for your faithfulness, my God. I sing praises to you with the lyre, Holy One of Israel.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.23",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 23,
      "referenceLabel": "Psalms 71:23",
      "text": "My lips shall shout for joy! My soul, which you have redeemed, sings praises to you!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.71.24",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 24,
      "referenceLabel": "Psalms 71:24",
      "text": "My tongue will also talk about your righteousness all day long, for they are disappointed, and they are confounded, who want to harm me.",
      "paragraphStart": false
    }
  ]
}
