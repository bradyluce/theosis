{
  "chapter": {
    "id": "web:psalms.145",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 145,
    "referenceLabel": "Psalms 145",
    "summary": "Source text for Psalms 145 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.145.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 1,
      "referenceLabel": "Psalms 145:1",
      "text": "I will exalt you, my God, the King. I will praise your name forever and ever.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.145.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 2,
      "referenceLabel": "Psalms 145:2",
      "text": "Every day I will praise you. I will extol your name forever and ever.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.145.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 3,
      "referenceLabel": "Psalms 145:3",
      "text": "Great is Yahweh, and greatly to be praised! His greatness is unsearchable.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.145.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 4,
      "referenceLabel": "Psalms 145:4",
      "text": "One generation will commend your works to another, and will declare your mighty acts.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.145.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 5,
      "referenceLabel": "Psalms 145:5",
      "text": "I will meditate on the glorious majesty of your honor, on your wondrous works.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.145.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 6,
      "referenceLabel": "Psalms 145:6",
      "text": "Men will speak of the might of your awesome acts. I will declare your greatness.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.145.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 7,
      "referenceLabel": "Psalms 145:7",
      "text": "They will utter the memory of your great goodness, and will sing of your righteousness.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.145.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 8,
      "referenceLabel": "Psalms 145:8",
      "text": "Yahweh is gracious, merciful, slow to anger, and of great loving kindness.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.145.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 9,
      "referenceLabel": "Psalms 145:9",
      "text": "Yahweh is good to all. His tender mercies are over all his works.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.145.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 10,
      "referenceLabel": "Psalms 145:10",
      "text": "All your works will give thanks to you, Yahweh. Your saints will extol you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.145.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 11,
      "referenceLabel": "Psalms 145:11",
      "text": "They will speak of the glory of your kingdom, and talk about your power,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.145.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 12,
      "referenceLabel": "Psalms 145:12",
      "text": "to make known to the sons of men his mighty acts, the glory of the majesty of his kingdom.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.145.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 13,
      "referenceLabel": "Psalms 145:13",
      "text": "Your kingdom is an everlasting kingdom. Your dominion endures throughout all generations. Yahweh is faithful in all his words, and loving in all his deeds.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.145.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 14,
      "referenceLabel": "Psalms 145:14",
      "text": "Yahweh upholds all who fall, and raises up all those who are bowed down.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.145.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 15,
      "referenceLabel": "Psalms 145:15",
      "text": "The eyes of all wait for you. You give them their food in due season.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.145.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 16,
      "referenceLabel": "Psalms 145:16",
      "text": "You open your hand, and satisfy the desire of every living thing.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.145.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 17,
      "referenceLabel": "Psalms 145:17",
      "text": "Yahweh is righteous in all his ways, and gracious in all his works.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.145.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 18,
      "referenceLabel": "Psalms 145:18",
      "text": "Yahweh is near to all those who call on him, to all who call on him in truth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.145.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 19,
      "referenceLabel": "Psalms 145:19",
      "text": "He will fulfill the desire of those who fear him. He also will hear their cry, and will save them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.145.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 20,
      "referenceLabel": "Psalms 145:20",
      "text": "Yahweh preserves all those who love him, but he will destroy all the wicked.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.145.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 21,
      "referenceLabel": "Psalms 145:21",
      "text": "My mouth will speak the praise of Yahweh. Let all flesh bless his holy name forever and ever.",
      "paragraphStart": false
    }
  ]
}
