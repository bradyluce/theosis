  },
  "verses": [
    {
      "id": "web:psalms.150.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 1,
      "referenceLabel": "Psalms 150:1",
      "text": "Praise Yah! Praise God in his sanctuary! Praise him in his heavens for his acts of power!",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.150.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 2,
      "referenceLabel": "Psalms 150:2",
      "text": "Praise him for his mighty acts! Praise him according to his excellent greatness!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.150.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 3,
      "referenceLabel": "Psalms 150:3",
      "text": "Praise him with the sounding of the trumpet! Praise him with harp and lyre!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.150.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 4,
      "referenceLabel": "Psalms 150:4",
      "text": "Praise him with tambourine and dancing! Praise him with stringed instruments and flute!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.150.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 5,
      "referenceLabel": "Psalms 150:5",
      "text": "Praise him with loud cymbals! Praise him with resounding cymbals!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.150.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 6,
      "referenceLabel": "Psalms 150:6",
      "text": "Let everything that has breath praise Yah! Praise Yah!",
      "paragraphStart": false
    }
  ]
}
