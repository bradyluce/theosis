{
  "chapter": {
    "id": "web:psalms.38",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 38,
    "referenceLabel": "Psalms 38",
    "summary": "Source text for Psalms 38 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.38.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 1,
      "referenceLabel": "Psalms 38:1",
      "text": "Yahweh, don’t rebuke me in your wrath, neither chasten me in your hot displeasure.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.38.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 2,
      "referenceLabel": "Psalms 38:2",
      "text": "For your arrows have pierced me, your hand presses hard on me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 3,
      "referenceLabel": "Psalms 38:3",
      "text": "There is no soundness in my flesh because of your indignation, neither is there any health in my bones because of my sin.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 4,
      "referenceLabel": "Psalms 38:4",
      "text": "For my iniquities have gone over my head. As a heavy burden, they are too heavy for me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 5,
      "referenceLabel": "Psalms 38:5",
      "text": "My wounds are loathsome and corrupt because of my foolishness.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 6,
      "referenceLabel": "Psalms 38:6",
      "text": "I am in pain and bowed down greatly. I go mourning all day long.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 7,
      "referenceLabel": "Psalms 38:7",
      "text": "For my waist is filled with burning. There is no soundness in my flesh.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 8,
      "referenceLabel": "Psalms 38:8",
      "text": "I am faint and severely bruised. I have groaned by reason of the anguish of my heart.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 9,
      "referenceLabel": "Psalms 38:9",
      "text": "Lord, all my desire is before you. My groaning is not hidden from you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 10,
      "referenceLabel": "Psalms 38:10",
      "text": "My heart throbs. My strength fails me. As for the light of my eyes, it has also left me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 11,
      "referenceLabel": "Psalms 38:11",
      "text": "My lovers and my friends stand aloof from my plague. My kinsmen stand far away.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 12,
      "referenceLabel": "Psalms 38:12",
      "text": "They also who seek after my life lay snares. Those who seek my hurt speak mischievous things, and meditate deceits all day long.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 13,
      "referenceLabel": "Psalms 38:13",
      "text": "But I, as a deaf man, don’t hear. I am as a mute man who doesn’t open his mouth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 14,
      "referenceLabel": "Psalms 38:14",
      "text": "Yes, I am as a man who doesn’t hear, in whose mouth are no reproofs.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 15,
      "referenceLabel": "Psalms 38:15",
      "text": "For I hope in you, Yahweh. You will answer, Lord my God.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 16,
      "referenceLabel": "Psalms 38:16",
      "text": "For I said, “Don’t let them gloat over me, or exalt themselves over me when my foot slips.”",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 17,
      "referenceLabel": "Psalms 38:17",
      "text": "For I am ready to fall. My pain is continually before me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 18,
      "referenceLabel": "Psalms 38:18",
      "text": "For I will declare my iniquity. I will be sorry for my sin.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 19,
      "referenceLabel": "Psalms 38:19",
      "text": "But my enemies are vigorous and many. Those who hate me without reason are numerous.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 20,
      "referenceLabel": "Psalms 38:20",
      "text": "They who give evil for good are also adversaries to me, because I follow what is good.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 21,
      "referenceLabel": "Psalms 38:21",
      "text": "Don’t forsake me, Yahweh. My God, don’t be far from me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.38.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 22,
      "referenceLabel": "Psalms 38:22",
      "text": "Hurry to help me, Lord, my salvation.",
      "paragraphStart": false
    }
  ]
}
