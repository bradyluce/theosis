{
  "chapter": {
    "id": "web:psalms.69",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 69,
    "referenceLabel": "Psalms 69",
    "summary": "Source text for Psalms 69 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.69.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 1,
      "referenceLabel": "Psalms 69:1",
      "text": "Save me, God, for the waters have come up to my neck!",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.69.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 2,
      "referenceLabel": "Psalms 69:2",
      "text": "I sink in deep mire, where there is no foothold. I have come into deep waters, where the floods overflow me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 3,
      "referenceLabel": "Psalms 69:3",
      "text": "I am weary with my crying. My throat is dry. My eyes fail looking for my God.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 4,
      "referenceLabel": "Psalms 69:4",
      "text": "Those who hate me without a cause are more than the hairs of my head. Those who want to cut me off, being my enemies wrongfully, are mighty. I have to restore what I didn’t take away.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 5,
      "referenceLabel": "Psalms 69:5",
      "text": "God, you know my foolishness. My sins aren’t hidden from you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 6,
      "referenceLabel": "Psalms 69:6",
      "text": "Don’t let those who wait for you be shamed through me, Lord Yahweh of Armies. Don’t let those who seek you be brought to dishonor through me, God of Israel.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 7,
      "referenceLabel": "Psalms 69:7",
      "text": "Because for your sake, I have borne reproach. Shame has covered my face.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 8,
      "referenceLabel": "Psalms 69:8",
      "text": "I have become a stranger to my brothers, an alien to my mother’s children.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 9,
      "referenceLabel": "Psalms 69:9",
      "text": "For the zeal of your house consumes me. The reproaches of those who reproach you have fallen on me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 10,
      "referenceLabel": "Psalms 69:10",
      "text": "When I wept and I fasted, that was to my reproach.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 11,
      "referenceLabel": "Psalms 69:11",
      "text": "When I made sackcloth my clothing, I became a byword to them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 12,
      "referenceLabel": "Psalms 69:12",
      "text": "Those who sit in the gate talk about me. I am the song of the drunkards.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 13,
      "referenceLabel": "Psalms 69:13",
      "text": "But as for me, my prayer is to you, Yahweh, in an acceptable time. God, in the abundance of your loving kindness, answer me in the truth of your salvation.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 14,
      "referenceLabel": "Psalms 69:14",
      "text": "Deliver me out of the mire, and don’t let me sink. Let me be delivered from those who hate me, and out of the deep waters.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 15,
      "referenceLabel": "Psalms 69:15",
      "text": "Don’t let the flood waters overwhelm me, neither let the deep swallow me up. Don’t let the pit shut its mouth on me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 16,
      "referenceLabel": "Psalms 69:16",
      "text": "Answer me, Yahweh, for your loving kindness is good. According to the multitude of your tender mercies, turn to me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 17,
      "referenceLabel": "Psalms 69:17",
      "text": "Don’t hide your face from your servant, for I am in distress. Answer me speedily!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 18,
      "referenceLabel": "Psalms 69:18",
      "text": "Draw near to my soul and redeem it. Ransom me because of my enemies.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 19,
      "referenceLabel": "Psalms 69:19",
      "text": "You know my reproach, my shame, and my dishonor. My adversaries are all before you.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 20,
      "referenceLabel": "Psalms 69:20",
      "text": "Reproach has broken my heart, and I am full of heaviness. I looked for some to take pity, but there was none; for comforters, but I found none.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 21,
      "referenceLabel": "Psalms 69:21",
      "text": "They also gave me poison for my food. In my thirst, they gave me vinegar to drink.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 22,
      "referenceLabel": "Psalms 69:22",
      "text": "Let their table before them become a snare. May it become a retribution and a trap.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.23",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 23,
      "referenceLabel": "Psalms 69:23",
      "text": "Let their eyes be darkened, so that they can’t see. Let their backs be continually bent.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.24",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 24,
      "referenceLabel": "Psalms 69:24",
      "text": "Pour out your indignation on them. Let the fierceness of your anger overtake them.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.25",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 25,
      "referenceLabel": "Psalms 69:25",
      "text": "Let their habitation be desolate. Let no one dwell in their tents.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.26",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 26,
      "referenceLabel": "Psalms 69:26",
      "text": "For they persecute him whom you have wounded. They tell of the sorrow of those whom you have hurt.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.27",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 27,
      "referenceLabel": "Psalms 69:27",
      "text": "Charge them with crime upon crime. Don’t let them come into your righteousness.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.28",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 28,
      "referenceLabel": "Psalms 69:28",
      "text": "Let them be blotted out of the book of life, and not be written with the righteous.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.29",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 29,
      "referenceLabel": "Psalms 69:29",
      "text": "But I am in pain and distress. Let your salvation, God, protect me.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.30",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 30,
      "referenceLabel": "Psalms 69:30",
      "text": "I will praise the name of God with a song, and will magnify him with thanksgiving.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.31",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 31,
      "referenceLabel": "Psalms 69:31",
      "text": "It will please Yahweh better than an ox, or a bull that has horns and hoofs.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.32",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 32,
      "referenceLabel": "Psalms 69:32",
      "text": "The humble have seen it, and are glad. You who seek after God, let your heart live.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.33",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 33,
      "referenceLabel": "Psalms 69:33",
      "text": "For Yahweh hears the needy, and doesn’t despise his captive people.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.34",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 34,
      "referenceLabel": "Psalms 69:34",
      "text": "Let heaven and earth praise him; the seas, and everything that moves therein!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.35",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 35,
      "referenceLabel": "Psalms 69:35",
      "text": "For God will save Zion, and build the cities of Judah. They shall settle there, and own it.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.69.36",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 36,
      "referenceLabel": "Psalms 69:36",
      "text": "The children also of his servants shall inherit it. Those who love his name shall dwell therein.",
      "paragraphStart": false
    }
  ]
}
