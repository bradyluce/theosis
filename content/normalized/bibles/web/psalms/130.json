{
  "chapter": {
    "id": "web:psalms.130",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 130,
    "referenceLabel": "Psalms 130",
    "summary": "Source text for Psalms 130 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.130.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 1,
      "referenceLabel": "Psalms 130:1",
      "text": "Out of the depths I have cried to you, Yahweh.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.130.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 2,
      "referenceLabel": "Psalms 130:2",
      "text": "Lord, hear my voice. Let your ears be attentive to the voice of my petitions.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.130.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 3,
      "referenceLabel": "Psalms 130:3",
      "text": "If you, Yah, kept a record of sins, Lord, who could stand?",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.130.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 4,
      "referenceLabel": "Psalms 130:4",
      "text": "But there is forgiveness with you, therefore you are feared.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.130.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 5,
      "referenceLabel": "Psalms 130:5",
      "text": "I wait for Yahweh. My soul waits. I hope in his word.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.130.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 6,
      "referenceLabel": "Psalms 130:6",
      "text": "My soul longs for the Lord more than watchmen long for the morning, more than watchmen for the morning.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.130.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 7,
      "referenceLabel": "Psalms 130:7",
      "text": "Israel, hope in Yahweh, for there is loving kindness with Yahweh. Abundant redemption is with him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.130.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 8,
      "referenceLabel": "Psalms 130:8",
      "text": "He will redeem Israel from all their sins.",
      "paragraphStart": false
    }
  ]
}
