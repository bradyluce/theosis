{
  "chapter": {
    "id": "web:psalms.33",
    "translationId": "web",
    "bookSlug": "psalms",
    "chapterNumber": 33,
    "referenceLabel": "Psalms 33",
    "summary": "Source text for Psalms 33 in World English Bible."
  },
  "verses": [
    {
      "id": "web:psalms.33.1",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 1,
      "referenceLabel": "Psalms 33:1",
      "text": "Rejoice in Yahweh, you righteous! Praise is fitting for the upright.",
      "paragraphStart": true
    },
    {
      "id": "web:psalms.33.2",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 2,
      "referenceLabel": "Psalms 33:2",
      "text": "Give thanks to Yahweh with the lyre. Sing praises to him with the harp of ten strings.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.3",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 3,
      "referenceLabel": "Psalms 33:3",
      "text": "Sing to him a new song. Play skillfully with a shout of joy!",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.4",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 4,
      "referenceLabel": "Psalms 33:4",
      "text": "For Yahweh ’s word is right. All his work is done in faithfulness.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.5",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 5,
      "referenceLabel": "Psalms 33:5",
      "text": "He loves righteousness and justice. The earth is full of the loving kindness of Yahweh.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.6",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 6,
      "referenceLabel": "Psalms 33:6",
      "text": "By Yahweh ’s word, the heavens were made: all their army by the breath of his mouth.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.7",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 7,
      "referenceLabel": "Psalms 33:7",
      "text": "He gathers the waters of the sea together as a heap. He lays up the deeps in storehouses.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.8",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 8,
      "referenceLabel": "Psalms 33:8",
      "text": "Let all the earth fear Yahweh. Let all the inhabitants of the world stand in awe of him.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.9",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 9,
      "referenceLabel": "Psalms 33:9",
      "text": "For he spoke, and it was done. He commanded, and it stood firm.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.10",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 10,
      "referenceLabel": "Psalms 33:10",
      "text": "Yahweh brings the counsel of the nations to nothing. He makes the thoughts of the peoples to be of no effect.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.11",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 11,
      "referenceLabel": "Psalms 33:11",
      "text": "The counsel of Yahweh stands fast forever, the thoughts of his heart to all generations.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.12",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 12,
      "referenceLabel": "Psalms 33:12",
      "text": "Blessed is the nation whose God is Yahweh, the people whom he has chosen for his own inheritance.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.13",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 13,
      "referenceLabel": "Psalms 33:13",
      "text": "Yahweh looks from heaven. He sees all the sons of men.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.14",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 14,
      "referenceLabel": "Psalms 33:14",
      "text": "From the place of his habitation he looks out on all the inhabitants of the earth,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.15",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 15,
      "referenceLabel": "Psalms 33:15",
      "text": "he who fashions all of their hearts; and he considers all of their works.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.16",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 16,
      "referenceLabel": "Psalms 33:16",
      "text": "There is no king saved by the multitude of an army. A mighty man is not delivered by great strength.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.17",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 17,
      "referenceLabel": "Psalms 33:17",
      "text": "A horse is a vain thing for safety, neither does he deliver any by his great power.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.18",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 18,
      "referenceLabel": "Psalms 33:18",
      "text": "Behold, Yahweh ’s eye is on those who fear him, on those who hope in his loving kindness,",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.19",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 19,
      "referenceLabel": "Psalms 33:19",
      "text": "to deliver their soul from death, to keep them alive in famine.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.20",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 20,
      "referenceLabel": "Psalms 33:20",
      "text": "Our soul has waited for Yahweh. He is our help and our shield.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.21",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 21,
      "referenceLabel": "Psalms 33:21",
      "text": "For our heart rejoices in him, because we have trusted in his holy name.",
      "paragraphStart": false
    },
    {
      "id": "web:psalms.33.22",
      "translationId": "web",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 22,
      "referenceLabel": "Psalms 33:22",
      "text": "Let your loving kindness be on us, Yahweh, since we have hoped in you.",
      "paragraphStart": false
    }
  ]
}
