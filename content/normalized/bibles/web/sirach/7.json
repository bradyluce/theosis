{
  "chapter": {
    "id": "web:sirach.7",
    "translationId": "web",
    "bookSlug": "sirach",
    "chapterNumber": 7,
    "referenceLabel": "Sirach 7",
    "summary": "Source text for Sirach 7 in World English Bible."
  },
  "verses": [
    {
      "id": "web:sirach.7.1",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Sirach 7:1",
      "text": "Do no evil, so no evil will overtake you.",
      "paragraphStart": true
    },
    {
      "id": "web:sirach.7.2",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Sirach 7:2",
      "text": "Depart from wrong, and it will turn away from you.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.3",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Sirach 7:3",
      "text": "My son, don’t sow upon the furrows of unrighteousness, and you won’t reap them sevenfold.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.4",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Sirach 7:4",
      "text": "Don’t seek preeminence from the Lord, nor the seat of honor from the king.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.5",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Sirach 7:5",
      "text": "Don’t justify yourself in the presence of the Lord, and don’t display your wisdom before the king.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.6",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Sirach 7:6",
      "text": "Don’t seek to be a judge, lest you not be able to take away iniquities, lest perhaps you fear the person of a mighty man, and lay a stumbling block in the way of your uprightness.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.7",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Sirach 7:7",
      "text": "Don’t sin against the multitude of the city. Don’t disgrace yourself in the crowd.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.8",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Sirach 7:8",
      "text": "Don’t commit a sin twice, for even in one you will not be unpunished.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.9",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Sirach 7:9",
      "text": "Don’t say, “He will look upon the multitude of my gifts. When I make an offering to the Most High God, he will accept it.”",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.10",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Sirach 7:10",
      "text": "Don’t be faint-hearted in your prayer. Don’t neglect to give alms.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.11",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Sirach 7:11",
      "text": "Don’t laugh a man to scorn when he is in the bitterness of his soul, for there is one who humbles and exalts.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.12",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Sirach 7:12",
      "text": "Don’t devise a lie against your brother, or do the same to a friend.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.13",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Sirach 7:13",
      "text": "Refuse to utter a lie, for that habit results in no good.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.14",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Sirach 7:14",
      "text": "Don’t babble in the assembly of elders. Don’t repeat your words in your prayer.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.15",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Sirach 7:15",
      "text": "Don’t hate hard labor or farm work, which the Most High has created.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.16",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Sirach 7:16",
      "text": "Don’t number yourself among the multitude of sinners. Remember that wrath will not wait.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.17",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Sirach 7:17",
      "text": "Humble your soul greatly, for the punishment of the ungodly man is fire and the worm.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.18",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Sirach 7:18",
      "text": "Don’t exchange a friend for something, neither a true brother for the gold of Ophir.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.19",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Sirach 7:19",
      "text": "Don’t deprive yourself of a wise and good wife, for her grace is worth more than gold.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.20",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Sirach 7:20",
      "text": "Don’t abuse a servant who works faithfully, or a hireling who gives you his life.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.21",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Sirach 7:21",
      "text": "Let your soul love a wise servant. Don’t defraud him of liberty.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.22",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Sirach 7:22",
      "text": "Do you have cattle? Look after them. If they are profitable to you, let them stay by you.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.23",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Sirach 7:23",
      "text": "Do you have children? Correct them, and make them obedient from their youth.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.24",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Sirach 7:24",
      "text": "Do you have daughters? Take care of their bodies, and don’t be overly indulgent toward them.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.25",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Sirach 7:25",
      "text": "Give your daughter in marriage, and you will have accomplished a great matter. Give her to a man of understanding.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.26",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "Sirach 7:26",
      "text": "Do you have a wife who pleases you? Don’t cast her out. But don’t trust yourself to one who is hateful.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.27",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "Sirach 7:27",
      "text": "Honor your father with your whole heart, and don’t forget the birth pangs of your mother.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.28",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "Sirach 7:28",
      "text": "Remember that you were born of them. What will you repay them for the things that they have done for you?",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.29",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "Sirach 7:29",
      "text": "Fear the Lord with all your soul; and revere his priests.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.30",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 30,
      "referenceLabel": "Sirach 7:30",
      "text": "With all your strength love him who made you. Don’t forsake his ministers.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.31",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 31,
      "referenceLabel": "Sirach 7:31",
      "text": "Fear the Lord and honor the priest. Give him his portion, even as it is commanded you: the first fruits, the trespass offering, the gift of the shoulders, the sacrifice of sanctification, and the first fruits of holy things.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.32",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 32,
      "referenceLabel": "Sirach 7:32",
      "text": "Also stretch out your hand to the poor man, that your blessing may be complete.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.33",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 33,
      "referenceLabel": "Sirach 7:33",
      "text": "A gift has grace in the sight of every living man. Don’t withhold grace for a dead man.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.34",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 34,
      "referenceLabel": "Sirach 7:34",
      "text": "Don’t avoid those who weep, and mourn with those who mourn.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.35",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 35,
      "referenceLabel": "Sirach 7:35",
      "text": "Don’t be slow to visit a sick man, for by such things you will gain love.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.7.36",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 36,
      "referenceLabel": "Sirach 7:36",
      "text": "In all your words, remember eternity, and you will never sin.",
      "paragraphStart": false
    }
  ]
}
