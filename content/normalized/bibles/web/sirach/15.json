{
  "chapter": {
    "id": "web:sirach.15",
    "translationId": "web",
    "bookSlug": "sirach",
    "chapterNumber": 15,
    "referenceLabel": "Sirach 15",
    "summary": "Source text for Sirach 15 in World English Bible."
  },
  "verses": [
    {
      "id": "web:sirach.15.1",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Sirach 15:1",
      "text": "He who fears the Lord will do this. He who has possession of the law will obtain her.",
      "paragraphStart": true
    },
    {
      "id": "web:sirach.15.2",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Sirach 15:2",
      "text": "She will meet him like a mother, and receive him like a wife married in her virginity.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.15.3",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Sirach 15:3",
      "text": "She will feed him with bread of understanding and give him water of wisdom to drink.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.15.4",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Sirach 15:4",
      "text": "He will be stayed upon her, and will not be moved. He will rely upon her, and will not be confounded.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.15.5",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Sirach 15:5",
      "text": "She will exalt him above his neighbors. She will open his mouth in the midst of the congregation.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.15.6",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Sirach 15:6",
      "text": "He will inherit joy, a crown of gladness, and an everlasting name.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.15.7",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Sirach 15:7",
      "text": "Foolish men will not obtain her. Sinners will not see her.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.15.8",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Sirach 15:8",
      "text": "She is far from pride. Liars will not remember her.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.15.9",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Sirach 15:9",
      "text": "Praise is not attractive in the mouth of a sinner; for it was not sent to him from the Lord.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.15.10",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Sirach 15:10",
      "text": "For praise will be spoken in wisdom; The Lord will prosper it.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.15.11",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Sirach 15:11",
      "text": "Don’t say, “It is through the Lord that I fell away;” for you shall not do the things that he hates.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.15.12",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Sirach 15:12",
      "text": "Don’t say, “It is he that caused me to err;” for he has no need of a sinful man.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.15.13",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Sirach 15:13",
      "text": "The Lord hates every abomination; and those who fear him don’t love them.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.15.14",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Sirach 15:14",
      "text": "He himself made man from the beginning and left him in the hand of his own counsel.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.15.15",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Sirach 15:15",
      "text": "If you choose, you can keep the commandments. To be faithful is a matter of your choice.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.15.16",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Sirach 15:16",
      "text": "He has set fire and water before you. You will stretch forth your hand to whichever you desire.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.15.17",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Sirach 15:17",
      "text": "Before man is life and death. Whichever he likes, it will be given to him.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.15.18",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Sirach 15:18",
      "text": "For the wisdom of the Lord is great. He is mighty in power, and sees all things.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.15.19",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Sirach 15:19",
      "text": "His eyes are upon those who fear him. He knows every act of man.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.15.20",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Sirach 15:20",
      "text": "He has not commanded any man to be ungodly. He has not given any man license to sin.",
      "paragraphStart": false
    }
  ]
}
