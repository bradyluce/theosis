{
  "chapter": {
    "id": "web:sirach.2",
    "translationId": "web",
    "bookSlug": "sirach",
    "chapterNumber": 2,
    "referenceLabel": "Sirach 2",
    "summary": "Source text for Sirach 2 in World English Bible."
  },
  "verses": [
    {
      "id": "web:sirach.2.1",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Sirach 2:1",
      "text": "My son, if you come to serve the Lord, prepare your soul for temptation.",
      "paragraphStart": true
    },
    {
      "id": "web:sirach.2.2",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Sirach 2:2",
      "text": "Set your heart aright, constantly endure, and don’t make haste in time of calamity.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.2.3",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Sirach 2:3",
      "text": "Cling to him, and don’t depart, that you may be increased at your latter end.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.2.4",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Sirach 2:4",
      "text": "Accept whatever is brought upon you, and be patient when you suffer humiliation.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.2.5",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Sirach 2:5",
      "text": "For gold is tried in the fire, and acceptable men in the furnace of humiliation.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.2.6",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Sirach 2:6",
      "text": "Put your trust in him, and he will help you. Make your ways straight, and set your hope on him.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.2.7",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Sirach 2:7",
      "text": "All you who fear the Lord, wait for his mercy. Don’t turn aside, lest you fall.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.2.8",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Sirach 2:8",
      "text": "All you who fear the Lord, put your trust in him, and your reward will not fail.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.2.9",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Sirach 2:9",
      "text": "All you who fear the Lord, hope for good things, and for eternal gladness and mercy.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.2.10",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Sirach 2:10",
      "text": "Look at the generations of old, and see: Who ever put his trust in the Lord, and was ashamed? Or who remained in his fear, and was forsaken? Or who called upon him, and he neglected him?",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.2.11",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Sirach 2:11",
      "text": "For the Lord is full of compassion and mercy. He forgives sins and saves in time of affliction.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.2.12",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Sirach 2:12",
      "text": "Woe to fearful hearts, to faint hands, and to the sinner who goes two ways!",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.2.13",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Sirach 2:13",
      "text": "Woe to the faint heart! For it doesn’t believe. Therefore it won’t be defended.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.2.14",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Sirach 2:14",
      "text": "Woe to you who have lost your patience! And what will you all do when the Lord visits you?",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.2.15",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Sirach 2:15",
      "text": "Those who fear the Lord will not disobey his words. Those who love him will keep his ways.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.2.16",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Sirach 2:16",
      "text": "Those who fear the Lord will seek his good pleasure. Those who love him will be filled with the law.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.2.17",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Sirach 2:17",
      "text": "Those who fear the Lord will prepare their hearts, and will humble their souls in his sight.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.2.18",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Sirach 2:18",
      "text": "We will fall into the hands of the Lord, and not into the hands of men; for as his majesty is, so also is his mercy.",
      "paragraphStart": false
    }
  ]
}
