{
  "chapter": {
    "id": "web:sirach.4",
    "translationId": "web",
    "bookSlug": "sirach",
    "chapterNumber": 4,
    "referenceLabel": "Sirach 4",
    "summary": "Source text for Sirach 4 in World English Bible."
  },
  "verses": [
    {
      "id": "web:sirach.4.1",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Sirach 4:1",
      "text": "My son, don’t deprive the poor of his living. Don’t make the needy eyes wait long.",
      "paragraphStart": true
    },
    {
      "id": "web:sirach.4.2",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Sirach 4:2",
      "text": "Don’t make a hungry soul sorrowful, or provoke a man in his distress.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.3",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Sirach 4:3",
      "text": "Don’t add more trouble to a heart that is provoked. Don’t put off giving to him who is in need.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.4",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Sirach 4:4",
      "text": "Don’t reject a suppliant in his affliction. Don’t turn your face away from a poor man.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.5",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Sirach 4:5",
      "text": "Don’t turn your eye away from one who asks. Give no occasion to a man to curse you.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.6",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Sirach 4:6",
      "text": "For if he curses you in the bitterness of his soul, he who made him will hear his supplication.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.7",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Sirach 4:7",
      "text": "Endear yourself to the assembly. Bow your head to a great man.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.8",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Sirach 4:8",
      "text": "Incline your ear to a poor man. Answer him with peaceful words in humility.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.9",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Sirach 4:9",
      "text": "Deliver him who is wronged from the hand of him who wrongs him; Don’t be hesitant in giving judgment.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.10",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Sirach 4:10",
      "text": "Be as a father to the fatherless, and like a husband to their mother. So you will be as a son of the Most High, and he will love you more than your mother does.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.11",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Sirach 4:11",
      "text": "Wisdom exalts her sons, and takes hold of those who seek her.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.12",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Sirach 4:12",
      "text": "He who loves her loves life. Those who seek her early will be filled with gladness.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.13",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Sirach 4:13",
      "text": "He who holds her fast will inherit glory. Where he enters, the Lord will bless.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.14",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Sirach 4:14",
      "text": "Those who serve her minister to the Holy One. The Lord loves those who love her.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.15",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Sirach 4:15",
      "text": "He who listens to her will judge the nations. He who heeds her will dwell securely.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.16",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Sirach 4:16",
      "text": "If he trusts her, he will inherit her, and his generations will possess her.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.17",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Sirach 4:17",
      "text": "For at the first she will walk with him in crooked ways, and will bring fear and dread upon him, and torment him with her discipline, until she may trust his soul, and try him by her judgments.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.18",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Sirach 4:18",
      "text": "Then she will return him again to the straight way, and will gladden him, and reveal to him her secrets.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.19",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Sirach 4:19",
      "text": "If he goes astray, she will forsake him, and hand him over to his fall.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.20",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Sirach 4:20",
      "text": "Watch for the opportunity, and beware of evil. Don’t be ashamed of your soul.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.21",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Sirach 4:21",
      "text": "For there is a shame that brings sin, and there is a shame that is glory and grace.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.22",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Sirach 4:22",
      "text": "Don’t show partiality, discrediting your soul. Don’t revere any man to your falling.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.23",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Sirach 4:23",
      "text": "Don’t refrain from speaking when it is for safety. Don’t hide your wisdom for the sake of seeming fair.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.24",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Sirach 4:24",
      "text": "For wisdom will be known by speech, and instruction by the word of the tongue.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.25",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Sirach 4:25",
      "text": "Don’t speak against the truth and be shamed for your ignorance.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.26",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Sirach 4:26",
      "text": "Don’t be ashamed to confess your sins. Don’t fight the river’s current.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.27",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Sirach 4:27",
      "text": "Don’t lay yourself down for a fool to tread upon. Don’t be partial to one who is mighty.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.28",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "Sirach 4:28",
      "text": "Strive for the truth to death, and the Lord God will fight for you.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.29",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "Sirach 4:29",
      "text": "Don’t be hasty with your tongue, or slack and negligent in your deeds.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.30",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "Sirach 4:30",
      "text": "Don’t be like a lion in your house, or suspicious of your servants.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.4.31",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "Sirach 4:31",
      "text": "Don’t let your hand be stretched out to receive, and closed when you should repay.",
      "paragraphStart": false
    }
  ]
}
