{
  "chapter": {
    "id": "web:sirach.8",
    "translationId": "web",
    "bookSlug": "sirach",
    "chapterNumber": 8,
    "referenceLabel": "Sirach 8",
    "summary": "Source text for Sirach 8 in World English Bible."
  },
  "verses": [
    {
      "id": "web:sirach.8.1",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Sirach 8:1",
      "text": "Don’t contend with a mighty man, lest perhaps you fall into his hands.",
      "paragraphStart": true
    },
    {
      "id": "web:sirach.8.2",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Sirach 8:2",
      "text": "Don’t strive with a rich man, lest perhaps he overpower you; for gold has destroyed many, and turned away the hearts of kings.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.8.3",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Sirach 8:3",
      "text": "Don’t argue with a loudmouthed man. Don’t heap wood upon his fire.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.8.4",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Sirach 8:4",
      "text": "Don’t make fun of a rude man, lest your ancestors be dishonored.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.8.5",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Sirach 8:5",
      "text": "Don’t reproach a man when he turns from sin. Remember that we are all worthy of punishment.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.8.6",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Sirach 8:6",
      "text": "Don’t dishonor a man in his old age, for some of us are also growing old.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.8.7",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Sirach 8:7",
      "text": "Don’t rejoice over anyone’s death. Remember that we all die.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.8.8",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Sirach 8:8",
      "text": "Don’t neglect the discourse of the wise. Be conversant with their proverbs; for from them you will learn discipline and how to serve great men.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.8.9",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Sirach 8:9",
      "text": "Don’t miss the discourse of the aged, for they also learned from their parents, because from them you will learn understanding, and to give an answer in time of need.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.8.10",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Sirach 8:10",
      "text": "Don’t kindle the coals of a sinner, lest you be burned with the flame of his fire.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.8.11",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Sirach 8:11",
      "text": "Don’t rise up from the presence of an insolent man, lest he lie in wait as an ambush for your mouth.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.8.12",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Sirach 8:12",
      "text": "Don’t lend to a man who is stronger than you; and if you lend, count it as a loss.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.8.13",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Sirach 8:13",
      "text": "Don’t be surety beyond your means. If you give surety, think as one who will have to pay.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.8.14",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Sirach 8:14",
      "text": "Don’t go to law with a judge; for according to his honor they will give judgment for him.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.8.15",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Sirach 8:15",
      "text": "Don’t travel with a reckless man, lest he be burdensome to you; for he will do as he pleases, and you will perish with his folly.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.8.16",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Sirach 8:16",
      "text": "Don’t fight with a wrathful man. Don’t travel with him through the desert, for blood is as nothing in his sight. Where there is no help, he will overthrow you.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.8.17",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Sirach 8:17",
      "text": "Don’t consult with a fool, for he will not be able to keep a secret.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.8.18",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Sirach 8:18",
      "text": "Do no secret thing before a stranger, for you don’t know what it will cause.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.8.19",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Sirach 8:19",
      "text": "Don’t open your heart to every man. Don’t let him return you a favor.",
      "paragraphStart": false
    }
  ]
}
