{
  "chapter": {
    "id": "web:sirach.36",
    "translationId": "web",
    "bookSlug": "sirach",
    "chapterNumber": 36,
    "referenceLabel": "Sirach 36",
    "summary": "Source text for Sirach 36 in World English Bible."
  },
  "verses": [
    {
      "id": "web:sirach.36.1",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 1,
      "referenceLabel": "Sirach 36:1",
      "text": "Have mercy upon us, O Lord the God of all, and look at us with favor;",
      "paragraphStart": true
    },
    {
      "id": "web:sirach.36.2",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 2,
      "referenceLabel": "Sirach 36:2",
      "text": "and send your fear upon all the nations.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.3",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 3,
      "referenceLabel": "Sirach 36:3",
      "text": "Lift up your hand against the foreign nations and let them see your mighty power.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.4",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 4,
      "referenceLabel": "Sirach 36:4",
      "text": "As you showed your holiness in us before them, so be magnified in them before us.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.5",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 5,
      "referenceLabel": "Sirach 36:5",
      "text": "Let them know you, as we also have known you, that there is no God but only you, O God.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.6",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 6,
      "referenceLabel": "Sirach 36:6",
      "text": "Show new signs, and work various wonders. Glorify your hand and your right arm.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.7",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 7,
      "referenceLabel": "Sirach 36:7",
      "text": "Raise up indignation and pour out wrath. Take away the adversary and destroy the enemy.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.8",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 8,
      "referenceLabel": "Sirach 36:8",
      "text": "Hasten the time and remember your oath. Let them declare your mighty works.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.9",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 9,
      "referenceLabel": "Sirach 36:9",
      "text": "Let him who escapes be devoured by raging fire. May those who harm your people find destruction.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.10",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 10,
      "referenceLabel": "Sirach 36:10",
      "text": "Crush the heads of the rulers of the enemies who say, “There is no one but ourselves.”",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.11",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 11,
      "referenceLabel": "Sirach 36:11",
      "text": "Gather all the tribes of Jacob together, and take them for your inheritance, as from the beginning.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.12",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 12,
      "referenceLabel": "Sirach 36:12",
      "text": "O Lord, have mercy upon the people that is called by your name, and upon Israel, whom you likened to a firstborn.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.13",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 13,
      "referenceLabel": "Sirach 36:13",
      "text": "Have compassion upon the city of your sanctuary, Jerusalem, the place of your rest.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.14",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 14,
      "referenceLabel": "Sirach 36:14",
      "text": "Fill Zion. Exalt your oracles and fill your people with your glory.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.15",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 15,
      "referenceLabel": "Sirach 36:15",
      "text": "Give testimony to those who were your creatures in the beginning, and fulfill the prophecies that have been spoken in your name.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.16",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 16,
      "referenceLabel": "Sirach 36:16",
      "text": "Reward those who wait for you, and men will put their trust in your prophets.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.17",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 17,
      "referenceLabel": "Sirach 36:17",
      "text": "Listen, O Lord, to the prayer of your servants, according to the blessing of Aaron concerning your people; and all those who are on the earth will know that you are the Lord, the eternal God.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.18",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 18,
      "referenceLabel": "Sirach 36:18",
      "text": "The belly will eat any food, but one food is better than another.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.19",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 19,
      "referenceLabel": "Sirach 36:19",
      "text": "The mouth tastes meats taken in hunting, so does an understanding heart detect false speech.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.20",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 20,
      "referenceLabel": "Sirach 36:20",
      "text": "A contrary heart will cause heaviness. A man of experience will pay him back.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.21",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 21,
      "referenceLabel": "Sirach 36:21",
      "text": "A woman will receive any man, but one daughter is better than another.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.22",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 22,
      "referenceLabel": "Sirach 36:22",
      "text": "The beauty of a woman cheers the countenance. A man desires nothing more.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.23",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 23,
      "referenceLabel": "Sirach 36:23",
      "text": "If kindness and humility are on her tongue, her husband is not like other sons of men.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.24",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 24,
      "referenceLabel": "Sirach 36:24",
      "text": "He who gets a wife gets his richest treasure, a help meet for him and a pillar of support.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.25",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 25,
      "referenceLabel": "Sirach 36:25",
      "text": "Where no hedge is, the property will be plundered. He who has no wife will mourn as he wanders.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.36.26",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 26,
      "referenceLabel": "Sirach 36:26",
      "text": "For who would trust a nimble robber who skips from city to city? Even so, who would trust a man who has no nest, and lodges wherever he finds himself at nightfall?",
      "paragraphStart": false
    }
  ]
}
