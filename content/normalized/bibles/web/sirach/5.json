{
  "chapter": {
    "id": "web:sirach.5",
    "translationId": "web",
    "bookSlug": "sirach",
    "chapterNumber": 5,
    "referenceLabel": "Sirach 5",
    "summary": "Source text for Sirach 5 in World English Bible."
  },
  "verses": [
    {
      "id": "web:sirach.5.1",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Sirach 5:1",
      "text": "Don’t set your heart upon your goods. Don’t say, “They are sufficient for me.”",
      "paragraphStart": true
    },
    {
      "id": "web:sirach.5.2",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Sirach 5:2",
      "text": "Don’t follow your own mind and your strength to walk in the desires of your heart.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.5.3",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Sirach 5:3",
      "text": "Don’t say, “Who will have dominion over me?” for the Lord will surely take vengeance on you.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.5.4",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Sirach 5:4",
      "text": "Don’t say, “I sinned, and what happened to me?” for the Lord is patient.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.5.5",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Sirach 5:5",
      "text": "Don’t be so confident of atonement that you add sin upon sins.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.5.6",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Sirach 5:6",
      "text": "Don’t say, “His compassion is great. He will be pacified for the multitude of my sins,” for mercy and wrath are with him, and his indignation will rest on sinners.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.5.7",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Sirach 5:7",
      "text": "Don’t wait to turn to the Lord. Don’t put off from day to day; for suddenly the wrath of the Lord will come on you, and you will perish in the time of vengeance.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.5.8",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Sirach 5:8",
      "text": "Don’t set your heart upon unrighteous gains, for you will profit nothing in the day of calamity.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.5.9",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Sirach 5:9",
      "text": "Don’t winnow with every wind. Don’t walk in every path. This is what the sinner who has a double tongue does.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.5.10",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Sirach 5:10",
      "text": "Be steadfast in your understanding. Let your speech be consistent.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.5.11",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Sirach 5:11",
      "text": "Be swift to hear and answer with patience.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.5.12",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Sirach 5:12",
      "text": "If you have understanding, answer your neighbor; but if not, put your hand over your mouth.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.5.13",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Sirach 5:13",
      "text": "Glory and dishonor is in talk. A man’s tongue may be his downfall.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.5.14",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Sirach 5:14",
      "text": "Don’t be called a whisperer. Don’t lie in wait with your tongue; for shame is on the thief, and an evil condemnation is on him who has a double tongue.",
      "paragraphStart": false
    },
    {
      "id": "web:sirach.5.15",
      "translationId": "web",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Sirach 5:15",
      "text": "Don’t be ignorant in a great or small matter.",
      "paragraphStart": false
    }
  ]
}
