{
  "chapter": {
    "id": "web:proverbs.12",
    "translationId": "web",
    "bookSlug": "proverbs",
    "chapterNumber": 12,
    "referenceLabel": "Proverbs 12",
    "summary": "Source text for Proverbs 12 in World English Bible."
  },
  "verses": [
    {
      "id": "web:proverbs.12.1",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 12:1",
      "text": "Whoever loves correction loves knowledge, but he who hates reproof is stupid.",
      "paragraphStart": true
    },
    {
      "id": "web:proverbs.12.2",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 12:2",
      "text": "A good man shall obtain favor from Yahweh, but he will condemn a man of wicked plans.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.3",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 12:3",
      "text": "A man shall not be established by wickedness, but the root of the righteous shall not be moved.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.4",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 12:4",
      "text": "A worthy woman is the crown of her husband, but a disgraceful wife is as rottenness in his bones.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.5",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 12:5",
      "text": "The thoughts of the righteous are just, but the advice of the wicked is deceitful.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.6",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 12:6",
      "text": "The words of the wicked are about lying in wait for blood, but the speech of the upright rescues them.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.7",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 12:7",
      "text": "The wicked are overthrown, and are no more, but the house of the righteous shall stand.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.8",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 12:8",
      "text": "A man shall be commended according to his wisdom, but he who has a warped mind shall be despised.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.9",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 12:9",
      "text": "Better is he who is little known, and has a servant, than he who honors himself and lacks bread.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.10",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 12:10",
      "text": "A righteous man respects the life of his animal, but the tender mercies of the wicked are cruel.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.11",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 12:11",
      "text": "He who tills his land shall have plenty of bread, but he who chases fantasies is void of understanding.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.12",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 12:12",
      "text": "The wicked desires the plunder of evil men, but the root of the righteous flourishes.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.13",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 12:13",
      "text": "An evil man is trapped by sinfulness of lips, but the righteous shall come out of trouble.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.14",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 12:14",
      "text": "A man shall be satisfied with good by the fruit of his mouth. The work of a man’s hands shall be rewarded to him.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.15",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 12:15",
      "text": "The way of a fool is right in his own eyes, but he who is wise listens to counsel.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.16",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 12:16",
      "text": "A fool shows his annoyance the same day, but one who overlooks an insult is prudent.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.17",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 12:17",
      "text": "He who is truthful testifies honestly, but a false witness lies.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.18",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 12:18",
      "text": "There is one who speaks rashly like the piercing of a sword, but the tongue of the wise heals.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.19",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 12:19",
      "text": "Truth’s lips will be established forever, but a lying tongue is only momentary.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.20",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 12:20",
      "text": "Deceit is in the heart of those who plot evil, but joy comes to the promoters of peace.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.21",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 12:21",
      "text": "No mischief shall happen to the righteous, but the wicked shall be filled with evil.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.22",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 12:22",
      "text": "Lying lips are an abomination to Yahweh, but those who do the truth are his delight.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.23",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 12:23",
      "text": "A prudent man keeps his knowledge, but the hearts of fools proclaim foolishness.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.24",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 12:24",
      "text": "The hands of the diligent ones shall rule, but laziness ends in slave labor.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.25",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 12:25",
      "text": "Anxiety in a man’s heart weighs it down, but a kind word makes it glad.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.26",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 12:26",
      "text": "A righteous person is cautious in friendship, but the way of the wicked leads them astray.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.27",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 12:27",
      "text": "The slothful man doesn’t roast his game, but the possessions of diligent men are prized.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.12.28",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 12:28",
      "text": "In the way of righteousness is life; in its path there is no death.",
      "paragraphStart": false
    }
  ]
}
