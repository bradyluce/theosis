{
  "chapter": {
    "id": "web:proverbs.13",
    "translationId": "web",
    "bookSlug": "proverbs",
    "chapterNumber": 13,
    "referenceLabel": "Proverbs 13",
    "summary": "Source text for Proverbs 13 in World English Bible."
  },
  "verses": [
    {
      "id": "web:proverbs.13.1",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 13:1",
      "text": "A wise son listens to his father’s instruction, but a scoffer doesn’t listen to rebuke.",
      "paragraphStart": true
    },
    {
      "id": "web:proverbs.13.2",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 13:2",
      "text": "By the fruit of his lips, a man enjoys good things, but the unfaithful crave violence.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.3",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 13:3",
      "text": "He who guards his mouth guards his soul. One who opens wide his lips comes to ruin.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.4",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 13:4",
      "text": "The soul of the sluggard desires, and has nothing, but the desire of the diligent shall be fully satisfied.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.5",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 13:5",
      "text": "A righteous man hates lies, but a wicked man brings shame and disgrace.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.6",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 13:6",
      "text": "Righteousness guards the way of integrity, but wickedness overthrows the sinner.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.7",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 13:7",
      "text": "There are some who pretend to be rich, yet have nothing. There are some who pretend to be poor, yet have great wealth.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.8",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 13:8",
      "text": "The ransom of a man’s life is his riches, but the poor hear no threats.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.9",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 13:9",
      "text": "The light of the righteous shines brightly, but the lamp of the wicked is snuffed out.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.10",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 13:10",
      "text": "Pride only breeds quarrels, but wisdom is with people who take advice.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.11",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 13:11",
      "text": "Wealth gained dishonestly dwindles away, but he who gathers by hand makes it grow.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.12",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 13:12",
      "text": "Hope deferred makes the heart sick, but when longing is fulfilled, it is a tree of life.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.13",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 13:13",
      "text": "Whoever despises instruction will pay for it, but he who respects a command will be rewarded.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.14",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 13:14",
      "text": "The teaching of the wise is a spring of life, to turn from the snares of death.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.15",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 13:15",
      "text": "Good understanding wins favor, but the way of the unfaithful is hard.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.16",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 13:16",
      "text": "Every prudent man acts from knowledge, but a fool exposes folly.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.17",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 13:17",
      "text": "A wicked messenger falls into trouble, but a trustworthy envoy gains healing.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.18",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 13:18",
      "text": "Poverty and shame come to him who refuses discipline, but he who heeds correction shall be honored.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.19",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 13:19",
      "text": "Longing fulfilled is sweet to the soul, but fools detest turning from evil.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.20",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 13:20",
      "text": "One who walks with wise men grows wise, but a companion of fools suffers harm.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.21",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 13:21",
      "text": "Misfortune pursues sinners, but prosperity rewards the righteous.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.22",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 13:22",
      "text": "A good man leaves an inheritance to his children’s children, but the wealth of the sinner is stored for the righteous.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.23",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 13:23",
      "text": "An abundance of food is in poor people’s fields, but injustice sweeps it away.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.24",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 13:24",
      "text": "One who spares the rod hates his son, but one who loves him is careful to discipline him.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.13.25",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 13:25",
      "text": "The righteous one eats to the satisfying of his soul, but the belly of the wicked goes hungry.",
      "paragraphStart": false
    }
  ]
}
