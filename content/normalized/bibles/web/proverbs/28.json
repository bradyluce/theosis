{
  "chapter": {
    "id": "web:proverbs.28",
    "translationId": "web",
    "bookSlug": "proverbs",
    "chapterNumber": 28,
    "referenceLabel": "Proverbs 28",
    "summary": "Source text for Proverbs 28 in World English Bible."
  },
  "verses": [
    {
      "id": "web:proverbs.28.1",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 28:1",
      "text": "The wicked flee when no one pursues; but the righteous are as bold as a lion.",
      "paragraphStart": true
    },
    {
      "id": "web:proverbs.28.2",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 28:2",
      "text": "In rebellion, a land has many rulers, but order is maintained by a man of understanding and knowledge.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.3",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 28:3",
      "text": "A needy man who oppresses the poor is like a driving rain which leaves no crops.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.4",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 28:4",
      "text": "Those who forsake the law praise the wicked; but those who keep the law contend with them.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.5",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 28:5",
      "text": "Evil men don’t understand justice; but those who seek Yahweh understand it fully.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.6",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 28:6",
      "text": "Better is the poor who walks in his integrity than he who is perverse in his ways, and he is rich.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.7",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 28:7",
      "text": "Whoever keeps the law is a wise son; but he who is a companion of gluttons shames his father.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.8",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 28:8",
      "text": "He who increases his wealth by excessive interest gathers it for one who has pity on the poor.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.9",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 28:9",
      "text": "He who turns away his ear from hearing the law, even his prayer is an abomination.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.10",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 28:10",
      "text": "Whoever causes the upright to go astray in an evil way, he will fall into his own trap; but the blameless will inherit good.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.11",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 28:11",
      "text": "The rich man is wise in his own eyes; but the poor who has understanding sees through him.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.12",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 28:12",
      "text": "When the righteous triumph, there is great glory; but when the wicked rise, men hide themselves.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.13",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 28:13",
      "text": "He who conceals his sins doesn’t prosper, but whoever confesses and renounces them finds mercy.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.14",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 28:14",
      "text": "Blessed is the man who always fears; but one who hardens his heart falls into trouble.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.15",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 28:15",
      "text": "As a roaring lion or a charging bear, so is a wicked ruler over helpless people.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.16",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 28:16",
      "text": "A tyrannical ruler lacks judgment. One who hates ill-gotten gain will have long days.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.17",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 28:17",
      "text": "A man who is tormented by blood guilt will be a fugitive until death. No one will support him.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.18",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 28:18",
      "text": "Whoever walks blamelessly is kept safe; but one with perverse ways will fall suddenly.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.19",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 28:19",
      "text": "One who works his land will have an abundance of food; but one who chases fantasies will have his fill of poverty.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.20",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 28:20",
      "text": "A faithful man is rich with blessings; but one who is eager to be rich will not go unpunished.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.21",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 28:21",
      "text": "To show partiality is not good, yet a man will do wrong for a piece of bread.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.22",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 28:22",
      "text": "A stingy man hurries after riches, and doesn’t know that poverty waits for him.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.23",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 28:23",
      "text": "One who rebukes a man will afterward find more favor than one who flatters with the tongue.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.24",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 28:24",
      "text": "Whoever robs his father or his mother and says, “It’s not wrong,” is a partner with a destroyer.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.25",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 28:25",
      "text": "One who is greedy stirs up strife; but one who trusts in Yahweh will prosper.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.26",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 28:26",
      "text": "One who trusts in himself is a fool; but one who walks in wisdom is kept safe.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.27",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 28:27",
      "text": "One who gives to the poor has no lack; but one who closes his eyes will have many curses.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.28.28",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 28:28",
      "text": "When the wicked rise, men hide themselves; but when they perish, the righteous thrive.",
      "paragraphStart": false
    }
  ]
}
