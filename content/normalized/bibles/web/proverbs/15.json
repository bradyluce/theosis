{
  "chapter": {
    "id": "web:proverbs.15",
    "translationId": "web",
    "bookSlug": "proverbs",
    "chapterNumber": 15,
    "referenceLabel": "Proverbs 15",
    "summary": "Source text for Proverbs 15 in World English Bible."
  },
  "verses": [
    {
      "id": "web:proverbs.15.1",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 15:1",
      "text": "A gentle answer turns away wrath, but a harsh word stirs up anger.",
      "paragraphStart": true
    },
    {
      "id": "web:proverbs.15.2",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 15:2",
      "text": "The tongue of the wise commends knowledge, but the mouths of fools gush out folly.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.3",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 15:3",
      "text": "Yahweh ’s eyes are everywhere, keeping watch on the evil and the good.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.4",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 15:4",
      "text": "A gentle tongue is a tree of life, but deceit in it crushes the spirit.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.5",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 15:5",
      "text": "A fool despises his father’s correction, but he who heeds reproof shows prudence.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.6",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 15:6",
      "text": "In the house of the righteous is much treasure, but the income of the wicked brings trouble.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.7",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 15:7",
      "text": "The lips of the wise spread knowledge; not so with the heart of fools.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.8",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 15:8",
      "text": "The sacrifice made by the wicked is an abomination to Yahweh, but the prayer of the upright is his delight.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.9",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 15:9",
      "text": "The way of the wicked is an abomination to Yahweh, but he loves him who follows after righteousness.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.10",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 15:10",
      "text": "There is stern discipline for one who forsakes the way. Whoever hates reproof shall die.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.11",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 15:11",
      "text": "Sheol and Abaddon are before Yahweh — how much more then the hearts of the children of men!",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.12",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 15:12",
      "text": "A scoffer doesn’t love to be reproved; he will not go to the wise.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.13",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 15:13",
      "text": "A glad heart makes a cheerful face, but an aching heart breaks the spirit.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.14",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 15:14",
      "text": "The heart of one who has understanding seeks knowledge, but the mouths of fools feed on folly.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.15",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 15:15",
      "text": "All the days of the afflicted are wretched, but one who has a cheerful heart enjoys a continual feast.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.16",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 15:16",
      "text": "Better is little, with the fear of Yahweh, than great treasure with trouble.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.17",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 15:17",
      "text": "Better is a dinner of herbs, where love is, than a fattened calf with hatred.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.18",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 15:18",
      "text": "A wrathful man stirs up contention, but one who is slow to anger appeases strife.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.19",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 15:19",
      "text": "The way of the sluggard is like a thorn patch, but the path of the upright is a highway.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.20",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 15:20",
      "text": "A wise son makes a father glad, but a foolish man despises his mother.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.21",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 15:21",
      "text": "Folly is joy to one who is void of wisdom, but a man of understanding keeps his way straight.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.22",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 15:22",
      "text": "Where there is no counsel, plans fail; but in a multitude of counselors they are established.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.23",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 15:23",
      "text": "Joy comes to a man with the reply of his mouth. How good is a word at the right time!",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.24",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 15:24",
      "text": "The path of life leads upward for the wise, to keep him from going downward to Sheol.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.25",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 15:25",
      "text": "Yahweh will uproot the house of the proud, but he will keep the widow’s borders intact.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.26",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 15:26",
      "text": "Yahweh detests the thoughts of the wicked, but the thoughts of the pure are pleasing.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.27",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 15:27",
      "text": "He who is greedy for gain troubles his own house, but he who hates bribes will live.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.28",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 15:28",
      "text": "The heart of the righteous weighs answers, but the mouth of the wicked gushes out evil.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.29",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 15:29",
      "text": "Yahweh is far from the wicked, but he hears the prayer of the righteous.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.30",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 15:30",
      "text": "The light of the eyes rejoices the heart. Good news gives health to the bones.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.31",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 15:31",
      "text": "The ear that listens to reproof lives, and will be at home among the wise.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.32",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 15:32",
      "text": "He who refuses correction despises his own soul, but he who listens to reproof gets understanding.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.15.33",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 15:33",
      "text": "The fear of Yahweh teaches wisdom. Before honor is humility.",
      "paragraphStart": false
    }
  ]
}
