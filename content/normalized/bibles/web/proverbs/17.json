{
  "chapter": {
    "id": "web:proverbs.17",
    "translationId": "web",
    "bookSlug": "proverbs",
    "chapterNumber": 17,
    "referenceLabel": "Proverbs 17",
    "summary": "Source text for Proverbs 17 in World English Bible."
  },
  "verses": [
    {
      "id": "web:proverbs.17.1",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 17:1",
      "text": "Better is a dry morsel with quietness, than a house full of feasting with strife.",
      "paragraphStart": true
    },
    {
      "id": "web:proverbs.17.2",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 17:2",
      "text": "A servant who deals wisely will rule over a son who causes shame, and shall have a part in the inheritance among the brothers.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.3",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 17:3",
      "text": "The refining pot is for silver, and the furnace for gold, but Yahweh tests the hearts.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.4",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 17:4",
      "text": "An evildoer heeds wicked lips. A liar gives ear to a mischievous tongue.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.5",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 17:5",
      "text": "Whoever mocks the poor reproaches his Maker. He who is glad at calamity shall not be unpunished.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.6",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 17:6",
      "text": "Children ’s children are the crown of old men; the glory of children is their parents.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.7",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 17:7",
      "text": "Excellent speech isn’t fitting for a fool, much less do lying lips fit a prince.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.8",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 17:8",
      "text": "A bribe is a precious stone in the eyes of him who gives it; wherever he turns, he prospers.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.9",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 17:9",
      "text": "He who covers an offense promotes love; but he who repeats a matter separates best friends.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.10",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 17:10",
      "text": "A rebuke enters deeper into one who has understanding than a hundred lashes into a fool.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.11",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 17:11",
      "text": "An evil man seeks only rebellion; therefore a cruel messenger shall be sent against him.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.12",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 17:12",
      "text": "Let a bear robbed of her cubs meet a man, rather than a fool in his folly.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.13",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 17:13",
      "text": "Whoever rewards evil for good, evil shall not depart from his house.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.14",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 17:14",
      "text": "The beginning of strife is like breaching a dam, therefore stop contention before quarreling breaks out.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.15",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 17:15",
      "text": "He who justifies the wicked, and he who condemns the righteous, both of them alike are an abomination to Yahweh.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.16",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 17:16",
      "text": "Why is there money in the hand of a fool to buy wisdom, since he has no understanding?",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.17",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 17:17",
      "text": "A friend loves at all times; and a brother is born for adversity.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.18",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 17:18",
      "text": "A man void of understanding strikes hands, and becomes collateral in the presence of his neighbor.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.19",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 17:19",
      "text": "He who loves disobedience loves strife. One who builds a high gate seeks destruction.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.20",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 17:20",
      "text": "One who has a perverse heart doesn’t find prosperity, and one who has a deceitful tongue falls into trouble.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.21",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 17:21",
      "text": "He who becomes the father of a fool grieves. The father of a fool has no joy.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.22",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 17:22",
      "text": "A cheerful heart makes good medicine, but a crushed spirit dries up the bones.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.23",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 17:23",
      "text": "A wicked man receives a bribe in secret, to pervert the ways of justice.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.24",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 17:24",
      "text": "Wisdom is before the face of one who has understanding, but the eyes of a fool wander to the ends of the earth.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.25",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 17:25",
      "text": "A foolish son brings grief to his father, and bitterness to her who bore him.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.26",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 17:26",
      "text": "Also to punish the righteous is not good, nor to flog officials for their integrity.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.27",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 17:27",
      "text": "He who spares his words has knowledge. He who is even tempered is a man of understanding.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.17.28",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 17:28",
      "text": "Even a fool, when he keeps silent, is counted wise. When he shuts his lips, he is thought to be discerning.",
      "paragraphStart": false
    }
  ]
}
