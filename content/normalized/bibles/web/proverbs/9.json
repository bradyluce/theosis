{
  "chapter": {
    "id": "web:proverbs.9",
    "translationId": "web",
    "bookSlug": "proverbs",
    "chapterNumber": 9,
    "referenceLabel": "Proverbs 9",
    "summary": "Source text for Proverbs 9 in World English Bible."
  },
  "verses": [
    {
      "id": "web:proverbs.9.1",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 9:1",
      "text": "Wisdom has built her house. She has carved out her seven pillars.",
      "paragraphStart": true
    },
    {
      "id": "web:proverbs.9.2",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 9:2",
      "text": "She has prepared her meat. She has mixed her wine. She has also set her table.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.9.3",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 9:3",
      "text": "She has sent out her maidens. She cries from the highest places of the city:",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.9.4",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 9:4",
      "text": "“ Whoever is simple, let him turn in here!” As for him who is void of understanding, she says to him,",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.9.5",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 9:5",
      "text": "“ Come, eat some of my bread, Drink some of the wine which I have mixed!",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.9.6",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 9:6",
      "text": "Leave your simple ways, and live. Walk in the way of understanding.”",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.9.7",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 9:7",
      "text": "One who corrects a mocker invites insult. One who reproves a wicked man invites abuse.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.9.8",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 9:8",
      "text": "Don’t reprove a scoffer, lest he hate you. Reprove a wise person, and he will love you.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.9.9",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 9:9",
      "text": "Instruct a wise person, and he will be still wiser. Teach a righteous person, and he will increase in learning.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.9.10",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 9:10",
      "text": "The fear of Yahweh is the beginning of wisdom. The knowledge of the Holy One is understanding.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.9.11",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 9:11",
      "text": "For by me your days will be multiplied. The years of your life will be increased.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.9.12",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 9:12",
      "text": "If you are wise, you are wise for yourself. If you mock, you alone will bear it.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.9.13",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 9:13",
      "text": "The foolish woman is loud, undisciplined, and knows nothing.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.9.14",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 9:14",
      "text": "She sits at the door of her house, on a seat in the high places of the city,",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.9.15",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 9:15",
      "text": "to call to those who pass by, who go straight on their ways,",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.9.16",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 9:16",
      "text": "“ Whoever is simple, let him turn in here.” As for him who is void of understanding, she says to him,",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.9.17",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 9:17",
      "text": "“ Stolen water is sweet. Food eaten in secret is pleasant.”",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.9.18",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 9:18",
      "text": "But he doesn’t know that the departed spirits are there, that her guests are in the depths of Sheol.",
      "paragraphStart": false
    }
  ]
}
