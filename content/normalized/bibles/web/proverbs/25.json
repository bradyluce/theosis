{
  "chapter": {
    "id": "web:proverbs.25",
    "translationId": "web",
    "bookSlug": "proverbs",
    "chapterNumber": 25,
    "referenceLabel": "Proverbs 25",
    "summary": "Source text for Proverbs 25 in World English Bible."
  },
  "verses": [
    {
      "id": "web:proverbs.25.1",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 25:1",
      "text": "These also are proverbs of Solomon, which the men of Hezekiah king of Judah copied out.",
      "paragraphStart": true
    },
    {
      "id": "web:proverbs.25.2",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 25:2",
      "text": "It is the glory of God to conceal a thing, but the glory of kings is to search out a matter.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.3",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 25:3",
      "text": "As the heavens for height, and the earth for depth, so the hearts of kings are unsearchable.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.4",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 25:4",
      "text": "Take away the dross from the silver, and material comes out for the refiner.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.5",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 25:5",
      "text": "Take away the wicked from the king ’s presence, and his throne will be established in righteousness.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.6",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 25:6",
      "text": "Don’t exalt yourself in the presence of the king, or claim a place among great men;",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.7",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 25:7",
      "text": "for it is better that it be said to you, “ Come up here,” than that you should be put lower in the presence of the prince, whom your eyes have seen.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.8",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 25:8",
      "text": "Don’t be hasty in bringing charges to court. What will you do in the end when your neighbor shames you?",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.9",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 25:9",
      "text": "Debate your case with your neighbor, and don’t betray the confidence of another,",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.10",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 25:10",
      "text": "lest one who hears it put you to shame, and your bad reputation never depart.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.11",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 25:11",
      "text": "A word fitly spoken is like apples of gold in settings of silver.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.12",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 25:12",
      "text": "As an earring of gold, and an ornament of fine gold, so is a wise reprover to an obedient ear.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.13",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 25:13",
      "text": "As the cold of snow in the time of harvest, so is a faithful messenger to those who send him; for he refreshes the soul of his masters.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.14",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 25:14",
      "text": "As clouds and wind without rain, so is he who boasts of gifts deceptively.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.15",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 25:15",
      "text": "By patience a ruler is persuaded. A soft tongue breaks the bone.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.16",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 25:16",
      "text": "Have you found honey? Eat as much as is sufficient for you, lest you eat too much, and vomit it.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.17",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 25:17",
      "text": "Let your foot be seldom in your neighbor ’s house, lest he be weary of you, and hate you.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.18",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 25:18",
      "text": "A man who gives false testimony against his neighbor is like a club, a sword, or a sharp arrow.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.19",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 25:19",
      "text": "Confidence in someone unfaithful in time of trouble is like a bad tooth or a lame foot.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.20",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 25:20",
      "text": "As one who takes away a garment in cold weather, or vinegar on soda, so is one who sings songs to a heavy heart.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.21",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 25:21",
      "text": "If your enemy is hungry, give him food to eat. If he is thirsty, give him water to drink;",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.22",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 25:22",
      "text": "for you will heap coals of fire on his head, and Yahweh will reward you.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.23",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 25:23",
      "text": "The north wind produces rain; so a backbiting tongue brings an angry face.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.24",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 25:24",
      "text": "It is better to dwell in the corner of the housetop than to share a house with a contentious woman.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.25",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 25:25",
      "text": "Like cold water to a thirsty soul, so is good news from a far country.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.26",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 25:26",
      "text": "Like a muddied spring and a polluted well, so is a righteous man who gives way before the wicked.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.27",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 25:27",
      "text": "It is not good to eat much honey, nor is it honorable to seek one ’s own honor.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.25.28",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 25:28",
      "text": "Like a city that is broken down and without walls is a man whose spirit is without restraint.",
      "paragraphStart": false
    }
  ]
}
