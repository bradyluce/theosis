{
  "chapter": {
    "id": "web:proverbs.14",
    "translationId": "web",
    "bookSlug": "proverbs",
    "chapterNumber": 14,
    "referenceLabel": "Proverbs 14",
    "summary": "Source text for Proverbs 14 in World English Bible."
  },
  "verses": [
    {
      "id": "web:proverbs.14.1",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 14:1",
      "text": "Every wise woman builds her house, but the foolish one tears it down with her own hands.",
      "paragraphStart": true
    },
    {
      "id": "web:proverbs.14.2",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 14:2",
      "text": "He who walks in his uprightness fears Yahweh, but he who is perverse in his ways despises him.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.3",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 14:3",
      "text": "The fool’s talk brings a rod to his back, but the lips of the wise protect them.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.4",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 14:4",
      "text": "Where no oxen are, the crib is clean, but much increase is by the strength of the ox.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.5",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 14:5",
      "text": "A truthful witness will not lie, but a false witness pours out lies.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.6",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 14:6",
      "text": "A scoffer seeks wisdom, and doesn’t find it, but knowledge comes easily to a discerning person.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.7",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 14:7",
      "text": "Stay away from a foolish man, for you won’t find knowledge on his lips.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.8",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 14:8",
      "text": "The wisdom of the prudent is to think about his way, but the folly of fools is deceit.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.9",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 14:9",
      "text": "Fools mock at making atonement for sins, but among the upright there is good will.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.10",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 14:10",
      "text": "The heart knows its own bitterness and joy; he will not share these with a stranger.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.11",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 14:11",
      "text": "The house of the wicked will be overthrown, but the tent of the upright will flourish.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.12",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 14:12",
      "text": "There is a way which seems right to a man, but in the end it leads to death.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.13",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 14:13",
      "text": "Even in laughter the heart may be sorrowful, and mirth may end in heaviness.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.14",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 14:14",
      "text": "The unfaithful will be repaid for his own ways; likewise a good man will be rewarded for his ways.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.15",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 14:15",
      "text": "A simple man believes everything, but the prudent man carefully considers his ways.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.16",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 14:16",
      "text": "A wise man fears and shuns evil, but the fool is hot headed and reckless.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.17",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 14:17",
      "text": "He who is quick to become angry will commit folly, and a crafty man is hated.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.18",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 14:18",
      "text": "The simple inherit folly, but the prudent are crowned with knowledge.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.19",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 14:19",
      "text": "The evil bow down before the good, and the wicked at the gates of the righteous.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.20",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 14:20",
      "text": "The poor person is shunned even by his own neighbor, but the rich person has many friends.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.21",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 14:21",
      "text": "He who despises his neighbor sins, but he who has pity on the poor is blessed.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.22",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 14:22",
      "text": "Don’t they go astray who plot evil? But love and faithfulness belong to those who plan good.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.23",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 14:23",
      "text": "In all hard work there is profit, but the talk of the lips leads only to poverty.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.24",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 14:24",
      "text": "The crown of the wise is their riches, but the folly of fools crowns them with folly.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.25",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 14:25",
      "text": "A truthful witness saves souls, but a false witness is deceitful.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.26",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 14:26",
      "text": "In the fear of Yahweh is a secure fortress, and he will be a refuge for his children.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.27",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 14:27",
      "text": "The fear of Yahweh is a fountain of life, turning people from the snares of death.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.28",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 14:28",
      "text": "In the multitude of people is the king ’s glory, but in the lack of people is the destruction of the prince.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.29",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 14:29",
      "text": "He who is slow to anger has great understanding, but he who has a quick temper displays folly.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.30",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 14:30",
      "text": "The life of the body is a heart at peace, but envy rots the bones.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.31",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 14:31",
      "text": "He who oppresses the poor shows contempt for his Maker, but he who is kind to the needy honors him.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.32",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 14:32",
      "text": "The wicked is brought down in his calamity, but in death, the righteous has a refuge.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.33",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 14:33",
      "text": "Wisdom rests in the heart of one who has understanding, and is even made known in the inward part of fools.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.34",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 14:34",
      "text": "Righteousness exalts a nation, but sin is a disgrace to any people.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.14.35",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 14:35",
      "text": "The king ’s favor is toward a servant who deals wisely, but his wrath is toward one who causes shame.",
      "paragraphStart": false
    }
  ]
}
