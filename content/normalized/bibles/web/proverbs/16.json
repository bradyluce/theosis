{
  "chapter": {
    "id": "web:proverbs.16",
    "translationId": "web",
    "bookSlug": "proverbs",
    "chapterNumber": 16,
    "referenceLabel": "Proverbs 16",
    "summary": "Source text for Proverbs 16 in World English Bible."
  },
  "verses": [
    {
      "id": "web:proverbs.16.1",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 16:1",
      "text": "The plans of the heart belong to man, but the answer of the tongue is from Yahweh.",
      "paragraphStart": true
    },
    {
      "id": "web:proverbs.16.2",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 16:2",
      "text": "All the ways of a man are clean in his own eyes, but Yahweh weighs the motives.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.3",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 16:3",
      "text": "Commit your deeds to Yahweh, and your plans shall succeed.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.4",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 16:4",
      "text": "Yahweh has made everything for its own end— yes, even the wicked for the day of evil.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.5",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 16:5",
      "text": "Everyone who is proud in heart is an abomination to Yahweh; they shall certainly not be unpunished.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.6",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 16:6",
      "text": "By mercy and truth iniquity is atoned for. By the fear of Yahweh men depart from evil.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.7",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 16:7",
      "text": "When a man’s ways please Yahweh, he makes even his enemies to be at peace with him.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.8",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 16:8",
      "text": "Better is a little with righteousness, than great revenues with injustice.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.9",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 16:9",
      "text": "A man’s heart plans his course, but Yahweh directs his steps.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.10",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 16:10",
      "text": "Inspired judgments are on the lips of the king. He shall not betray his mouth.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.11",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 16:11",
      "text": "Honest balances and scales are Yahweh’s; all the weights in the bag are his work.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.12",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 16:12",
      "text": "It is an abomination for kings to do wrong, for the throne is established by righteousness.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.13",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 16:13",
      "text": "Righteous lips are the delight of kings. They value one who speaks the truth.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.14",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 16:14",
      "text": "The king’s wrath is a messenger of death, but a wise man will pacify it.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.15",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 16:15",
      "text": "In the light of the king’s face is life. His favor is like a cloud of the spring rain.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.16",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 16:16",
      "text": "How much better it is to get wisdom than gold! Yes, to get understanding is to be chosen rather than silver.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.17",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 16:17",
      "text": "The highway of the upright is to depart from evil. He who keeps his way preserves his soul.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.18",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 16:18",
      "text": "Pride goes before destruction, and an arrogant spirit before a fall.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.19",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 16:19",
      "text": "It is better to be of a lowly spirit with the poor, than to divide the plunder with the proud.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.20",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 16:20",
      "text": "He who heeds the Word finds prosperity. Whoever trusts in Yahweh is blessed.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.21",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 16:21",
      "text": "The wise in heart shall be called prudent. Pleasantness of the lips promotes instruction.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.22",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 16:22",
      "text": "Understanding is a fountain of life to one who has it, but the punishment of fools is their folly.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.23",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 16:23",
      "text": "The heart of the wise instructs his mouth, and adds learning to his lips.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.24",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 16:24",
      "text": "Pleasant words are a honeycomb, sweet to the soul, and health to the bones.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.25",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 16:25",
      "text": "There is a way which seems right to a man, but in the end it leads to death.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.26",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 16:26",
      "text": "The appetite of the laboring man labors for him, for his mouth urges him on.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.27",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 16:27",
      "text": "A worthless man devises mischief. His speech is like a scorching fire.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.28",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 16:28",
      "text": "A perverse man stirs up strife. A whisperer separates close friends.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.29",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 16:29",
      "text": "A man of violence entices his neighbor, and leads him in a way that is not good.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.30",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 16:30",
      "text": "One who winks his eyes to plot perversities, one who compresses his lips, is bent on evil.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.31",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 16:31",
      "text": "Gray hair is a crown of glory. It is attained by a life of righteousness.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.32",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 16:32",
      "text": "One who is slow to anger is better than the mighty; one who rules his spirit, than he who takes a city.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.16.33",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 16:33",
      "text": "The lot is cast into the lap, but its every decision is from Yahweh.",
      "paragraphStart": false
    }
  ]
}
