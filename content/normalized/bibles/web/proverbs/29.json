{
  "chapter": {
    "id": "web:proverbs.29",
    "translationId": "web",
    "bookSlug": "proverbs",
    "chapterNumber": 29,
    "referenceLabel": "Proverbs 29",
    "summary": "Source text for Proverbs 29 in World English Bible."
  },
  "verses": [
    {
      "id": "web:proverbs.29.1",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 29:1",
      "text": "He who is often rebuked and stiffens his neck will be destroyed suddenly, with no remedy.",
      "paragraphStart": true
    },
    {
      "id": "web:proverbs.29.2",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 29:2",
      "text": "When the righteous thrive, the people rejoice; but when the wicked rule, the people groan.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.3",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 29:3",
      "text": "Whoever loves wisdom brings joy to his father; but a companion of prostitutes squanders his wealth.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.4",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 29:4",
      "text": "The king by justice makes the land stable, but he who takes bribes tears it down.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.5",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 29:5",
      "text": "A man who flatters his neighbor spreads a net for his feet.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.6",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 29:6",
      "text": "An evil man is snared by his sin, but the righteous can sing and be glad.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.7",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 29:7",
      "text": "The righteous care about justice for the poor. The wicked aren’t concerned about knowledge.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.8",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 29:8",
      "text": "Mockers stir up a city, but wise men turn away anger.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.9",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 29:9",
      "text": "If a wise man goes to court with a foolish man, the fool rages or scoffs, and there is no peace.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.10",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 29:10",
      "text": "The bloodthirsty hate a man of integrity; and they seek the life of the upright.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.11",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 29:11",
      "text": "A fool vents all of his anger, but a wise man brings himself under control.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.12",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 29:12",
      "text": "If a ruler listens to lies, all of his officials are wicked.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.13",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 29:13",
      "text": "The poor man and the oppressor have this in common: Yahweh gives sight to the eyes of both.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.14",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 29:14",
      "text": "The king who fairly judges the poor, his throne shall be established forever.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.15",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 29:15",
      "text": "The rod of correction gives wisdom, but a child left to himself causes shame to his mother.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.16",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 29:16",
      "text": "When the wicked increase, sin increases; but the righteous will see their downfall.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.17",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 29:17",
      "text": "Correct your son, and he will give you peace; yes, he will bring delight to your soul.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.18",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 29:18",
      "text": "Where there is no revelation, the people cast off restraint; but one who keeps the law is blessed.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.19",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 29:19",
      "text": "A servant can ’t be corrected by words. Though he understands, yet he will not respond.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.20",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 29:20",
      "text": "Do you see a man who is hasty in his words? There is more hope for a fool than for him.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.21",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 29:21",
      "text": "He who pampers his servant from youth will have him become a son in the end.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.22",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 29:22",
      "text": "An angry man stirs up strife, and a wrathful man abounds in sin.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.23",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 29:23",
      "text": "A man ’s pride brings him low, but one of lowly spirit gains honor.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.24",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 29:24",
      "text": "Whoever is an accomplice of a thief is an enemy of his own soul. He takes an oath, but dares not testify.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.25",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 29:25",
      "text": "The fear of man proves to be a snare, but whoever puts his trust in Yahweh is kept safe.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.26",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 29:26",
      "text": "Many seek the ruler ’s favor, but a man ’s justice comes from Yahweh.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.29.27",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 29:27",
      "text": "A dishonest man detests the righteous, and the upright in their ways detest the wicked.",
      "paragraphStart": false
    }
  ]
}
