{
  "chapter": {
    "id": "web:proverbs.10",
    "translationId": "web",
    "bookSlug": "proverbs",
    "chapterNumber": 10,
    "referenceLabel": "Proverbs 10",
    "summary": "Source text for Proverbs 10 in World English Bible."
  },
  "verses": [
    {
      "id": "web:proverbs.10.1",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 10:1",
      "text": "The proverbs of Solomon. A wise son makes a glad father; but a foolish son brings grief to his mother.",
      "paragraphStart": true
    },
    {
      "id": "web:proverbs.10.2",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 10:2",
      "text": "Treasures of wickedness profit nothing, but righteousness delivers from death.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.3",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 10:3",
      "text": "Yahweh will not allow the soul of the righteous to go hungry, but he thrusts away the desire of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.4",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 10:4",
      "text": "He becomes poor who works with a lazy hand, but the hand of the diligent brings wealth.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.5",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 10:5",
      "text": "He who gathers in summer is a wise son, but he who sleeps during the harvest is a son who causes shame.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.6",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 10:6",
      "text": "Blessings are on the head of the righteous, but violence covers the mouth of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.7",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 10:7",
      "text": "The memory of the righteous is blessed, but the name of the wicked will rot.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.8",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 10:8",
      "text": "The wise in heart accept commandments, but a chattering fool will fall.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.9",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 10:9",
      "text": "He who walks blamelessly walks surely, but he who perverts his ways will be found out.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.10",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 10:10",
      "text": "One who winks with the eye causes sorrow, but a chattering fool will fall.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.11",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 10:11",
      "text": "The mouth of the righteous is a spring of life, but violence covers the mouth of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.12",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 10:12",
      "text": "Hatred stirs up strife, but love covers all wrongs.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.13",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 10:13",
      "text": "Wisdom is found on the lips of him who has discernment, but a rod is for the back of him who is void of understanding.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.14",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 10:14",
      "text": "Wise men lay up knowledge, but the mouth of the foolish is near ruin.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.15",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 10:15",
      "text": "The rich man ’s wealth is his strong city. The destruction of the poor is their poverty.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.16",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 10:16",
      "text": "The labor of the righteous leads to life. The increase of the wicked leads to sin.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.17",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 10:17",
      "text": "He is in the way of life who heeds correction, but he who forsakes reproof leads others astray.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.18",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 10:18",
      "text": "He who hides hatred has lying lips. He who utters a slander is a fool.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.19",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 10:19",
      "text": "In the multitude of words there is no lack of disobedience, but he who restrains his lips does wisely.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.20",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 10:20",
      "text": "The tongue of the righteous is like choice silver. The heart of the wicked is of little worth.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.21",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 10:21",
      "text": "The lips of the righteous feed many, but the foolish die for lack of understanding.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.22",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 10:22",
      "text": "Yahweh ’s blessing brings wealth, and he adds no trouble to it.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.23",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 10:23",
      "text": "It is a fool ’s pleasure to do wickedness, but wisdom is a man of understanding ’s pleasure.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.24",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 10:24",
      "text": "What the wicked fear will overtake them, but the desire of the righteous will be granted.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.25",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 10:25",
      "text": "When the whirlwind passes, the wicked is no more; but the righteous stand firm forever.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.26",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 10:26",
      "text": "As vinegar to the teeth, and as smoke to the eyes, so is the sluggard to those who send him.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.27",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 10:27",
      "text": "The fear of Yahweh prolongs days, but the years of the wicked shall be shortened.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.28",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 10:28",
      "text": "The prospect of the righteous is joy, but the hope of the wicked will perish.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.29",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 10:29",
      "text": "The way of Yahweh is a stronghold to the upright, but it is a destruction to the workers of iniquity.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.30",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 10:30",
      "text": "The righteous will never be removed, but the wicked will not dwell in the land.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.31",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 10:31",
      "text": "The mouth of the righteous produces wisdom, but the perverse tongue will be cut off.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.10.32",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 10:32",
      "text": "The lips of the righteous know what is acceptable, but the mouth of the wicked is perverse.",
      "paragraphStart": false
    }
  ]
}
