{
  "chapter": {
    "id": "web:proverbs.11",
    "translationId": "web",
    "bookSlug": "proverbs",
    "chapterNumber": 11,
    "referenceLabel": "Proverbs 11",
    "summary": "Source text for Proverbs 11 in World English Bible."
  },
  "verses": [
    {
      "id": "web:proverbs.11.1",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 11:1",
      "text": "A false balance is an abomination to Yahweh, but accurate weights are his delight.",
      "paragraphStart": true
    },
    {
      "id": "web:proverbs.11.2",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 11:2",
      "text": "When pride comes, then comes shame, but with humility comes wisdom.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.3",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 11:3",
      "text": "The integrity of the upright shall guide them, but the perverseness of the treacherous shall destroy them.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.4",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 11:4",
      "text": "Riches don’t profit in the day of wrath, but righteousness delivers from death.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.5",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 11:5",
      "text": "The righteousness of the blameless will direct his way, but the wicked shall fall by his own wickedness.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.6",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 11:6",
      "text": "The righteousness of the upright shall deliver them, but the unfaithful will be trapped by evil desires.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.7",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 11:7",
      "text": "When a wicked man dies, hope perishes, and expectation of power comes to nothing.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.8",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 11:8",
      "text": "A righteous person is delivered out of trouble, and the wicked takes his place.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.9",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 11:9",
      "text": "With his mouth the godless man destroys his neighbor, but the righteous will be delivered through knowledge.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.10",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 11:10",
      "text": "When it goes well with the righteous, the city rejoices. When the wicked perish, there is shouting.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.11",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 11:11",
      "text": "By the blessing of the upright, the city is exalted, but it is overthrown by the mouth of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.12",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 11:12",
      "text": "One who despises his neighbor is void of wisdom, but a man of understanding holds his peace.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.13",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 11:13",
      "text": "One who brings gossip betrays a confidence, but one who is of a trustworthy spirit is one who keeps a secret.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.14",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 11:14",
      "text": "Where there is no wise guidance, the nation falls, but in the multitude of counselors there is victory.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.15",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 11:15",
      "text": "He who is collateral for a stranger will suffer for it, but he who refuses pledges of collateral is secure.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.16",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 11:16",
      "text": "A gracious woman obtains honor, but violent men obtain riches.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.17",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 11:17",
      "text": "The merciful man does good to his own soul, but he who is cruel troubles his own flesh.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.18",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 11:18",
      "text": "Wicked people earn deceitful wages, but one who sows righteousness reaps a sure reward.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.19",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 11:19",
      "text": "He who is truly righteous gets life. He who pursues evil gets death.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.20",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 11:20",
      "text": "Those who are perverse in heart are an abomination to Yahweh, but those whose ways are blameless are his delight.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.21",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 11:21",
      "text": "Most certainly, the evil man will not be unpunished, but the offspring of the righteous will be delivered.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.22",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 11:22",
      "text": "Like a gold ring in a pig ’s snout, is a beautiful woman who lacks discretion.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.23",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 11:23",
      "text": "The desire of the righteous is only good. The expectation of the wicked is wrath.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.24",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 11:24",
      "text": "There is one who scatters, and increases yet more. There is one who withholds more than is appropriate, but gains poverty.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.25",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 11:25",
      "text": "The liberal soul shall be made fat. He who waters shall be watered also himself.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.26",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 11:26",
      "text": "People curse someone who withholds grain, but blessing will be on the head of him who sells it.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.27",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 11:27",
      "text": "He who diligently seeks good seeks favor, but he who searches after evil, it shall come to him.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.28",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 11:28",
      "text": "He who trusts in his riches will fall, but the righteous shall flourish as the green leaf.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.29",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 11:29",
      "text": "He who troubles his own house shall inherit the wind. The foolish shall be servant to the wise of heart.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.30",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 11:30",
      "text": "The fruit of the righteous is a tree of life. He who is wise wins souls.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.11.31",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 11:31",
      "text": "Behold, the righteous shall be repaid in the earth, how much more the wicked and the sinner!",
      "paragraphStart": false
    }
  ]
}
