{
  "chapter": {
    "id": "web:proverbs.21",
    "translationId": "web",
    "bookSlug": "proverbs",
    "chapterNumber": 21,
    "referenceLabel": "Proverbs 21",
    "summary": "Source text for Proverbs 21 in World English Bible."
  },
  "verses": [
    {
      "id": "web:proverbs.21.1",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 21:1",
      "text": "The king’s heart is in Yahweh’s hand like the watercourses. He turns it wherever he desires.",
      "paragraphStart": true
    },
    {
      "id": "web:proverbs.21.2",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 21:2",
      "text": "Every way of a man is right in his own eyes, but Yahweh weighs the hearts.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.3",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 21:3",
      "text": "To do righteousness and justice is more acceptable to Yahweh than sacrifice.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.4",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 21:4",
      "text": "A high look and a proud heart, the lamp of the wicked, is sin.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.5",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 21:5",
      "text": "The plans of the diligent surely lead to profit; and everyone who is hasty surely rushes to poverty.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.6",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 21:6",
      "text": "Getting treasures by a lying tongue is a fleeting vapor for those who seek death.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.7",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 21:7",
      "text": "The violence of the wicked will drive them away, because they refuse to do what is right.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.8",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 21:8",
      "text": "The way of the guilty is devious, but the conduct of the innocent is upright.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.9",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 21:9",
      "text": "It is better to dwell in the corner of the housetop than to share a house with a contentious woman.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.10",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 21:10",
      "text": "The soul of the wicked desires evil; his neighbor finds no mercy in his eyes.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.11",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 21:11",
      "text": "When the mocker is punished, the simple gains wisdom. When the wise is instructed, he receives knowledge.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.12",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 21:12",
      "text": "The Righteous One considers the house of the wicked, and brings the wicked to ruin.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.13",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 21:13",
      "text": "Whoever stops his ears at the cry of the poor, he will also cry out, but shall not be heard.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.14",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 21:14",
      "text": "A gift in secret pacifies anger, and a bribe in the cloak, strong wrath.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.15",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 21:15",
      "text": "It is joy to the righteous to do justice; but it is a destruction to the workers of iniquity.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.16",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 21:16",
      "text": "The man who wanders out of the way of understanding shall rest in the assembly of the departed spirits.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.17",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 21:17",
      "text": "He who loves pleasure will be a poor man. He who loves wine and oil won’t be rich.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.18",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 21:18",
      "text": "The wicked is a ransom for the righteous, the treacherous for the upright.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.19",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 21:19",
      "text": "It is better to dwell in a desert land, than with a contentious and fretful woman.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.20",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 21:20",
      "text": "There is precious treasure and oil in the dwelling of the wise, but a foolish man swallows it up.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.21",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 21:21",
      "text": "He who follows after righteousness and kindness finds life, righteousness, and honor.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.22",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 21:22",
      "text": "A wise man scales the city of the mighty, and brings down the strength of its confidence.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.23",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 21:23",
      "text": "Whoever guards his mouth and his tongue keeps his soul from troubles.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.24",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 21:24",
      "text": "The proud and arrogant man—“Scoffer” is his name — he works in the arrogance of pride.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.25",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 21:25",
      "text": "The desire of the sluggard kills him, for his hands refuse to labor.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.26",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 21:26",
      "text": "There are those who covet greedily all day long; but the righteous give and don’t withhold.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.27",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 21:27",
      "text": "The sacrifice of the wicked is an abomination — how much more, when he brings it with a wicked mind!",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.28",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 21:28",
      "text": "A false witness will perish. A man who listens speaks to eternity.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.29",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 21:29",
      "text": "A wicked man hardens his face; but as for the upright, he establishes his ways.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.30",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 21:30",
      "text": "There is no wisdom nor understanding nor counsel against Yahweh.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.21.31",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 21:31",
      "text": "The horse is prepared for the day of battle; but victory is with Yahweh.",
      "paragraphStart": false
    }
  ]
}
