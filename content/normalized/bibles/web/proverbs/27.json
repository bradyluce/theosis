{
  "chapter": {
    "id": "web:proverbs.27",
    "translationId": "web",
    "bookSlug": "proverbs",
    "chapterNumber": 27,
    "referenceLabel": "Proverbs 27",
    "summary": "Source text for Proverbs 27 in World English Bible."
  },
  "verses": [
    {
      "id": "web:proverbs.27.1",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 27:1",
      "text": "Don’t boast about tomorrow; for you don’t know what a day may bring.",
      "paragraphStart": true
    },
    {
      "id": "web:proverbs.27.2",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 27:2",
      "text": "Let another man praise you, and not your own mouth; a stranger, and not your own lips.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.3",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 27:3",
      "text": "A stone is heavy, and sand is a burden; but a fool’s provocation is heavier than both.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.4",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 27:4",
      "text": "Wrath is cruel, and anger is overwhelming; but who is able to stand before jealousy?",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.5",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 27:5",
      "text": "Better is open rebuke than hidden love.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.6",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 27:6",
      "text": "The wounds of a friend are faithful, although the kisses of an enemy are profuse.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.7",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 27:7",
      "text": "A full soul loathes a honeycomb; but to a hungry soul, every bitter thing is sweet.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.8",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 27:8",
      "text": "As a bird that wanders from her nest, so is a man who wanders from his home.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.9",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 27:9",
      "text": "Perfume and incense bring joy to the heart; so does earnest counsel from a man’s friend.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.10",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 27:10",
      "text": "Don’t forsake your friend and your father’s friend. Don’t go to your brother’s house in the day of your disaster. A neighbor who is near is better than a distant brother.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.11",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 27:11",
      "text": "Be wise, my son, and bring joy to my heart, then I can answer my tormentor.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.12",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 27:12",
      "text": "A prudent man sees danger and takes refuge; but the simple pass on, and suffer for it.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.13",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 27:13",
      "text": "Take his garment when he puts up collateral for a stranger. Hold it for a wayward woman!",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.14",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 27:14",
      "text": "He who blesses his neighbor with a loud voice early in the morning, it will be taken as a curse by him.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.15",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 27:15",
      "text": "A continual dropping on a rainy day and a contentious wife are alike:",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.16",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 27:16",
      "text": "restraining her is like restraining the wind, or like grasping oil in his right hand.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.17",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 27:17",
      "text": "Iron sharpens iron; so a man sharpens his friend’s countenance.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.18",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 27:18",
      "text": "Whoever tends the fig tree shall eat its fruit. He who looks after his master shall be honored.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.19",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 27:19",
      "text": "Like water reflects a face, so a man’s heart reflects the man.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.20",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 27:20",
      "text": "Sheol and Abaddon are never satisfied; and a man’s eyes are never satisfied.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.21",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 27:21",
      "text": "The crucible is for silver, and the furnace for gold; but man is refined by his praise.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.22",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 27:22",
      "text": "Though you grind a fool in a mortar with a pestle along with grain, yet his foolishness will not be removed from him.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.23",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 27:23",
      "text": "Know well the state of your flocks, and pay attention to your herds,",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.24",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 27:24",
      "text": "for riches are not forever, nor does the crown endure to all generations.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.25",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 27:25",
      "text": "The hay is removed, and the new growth appears, the grasses of the hills are gathered in.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.26",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 27:26",
      "text": "The lambs are for your clothing, and the goats are the price of a field.",
      "paragraphStart": false
    },
    {
      "id": "web:proverbs.27.27",
      "translationId": "web",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 27:27",
      "text": "There will be plenty of goats ’ milk for your food, for your family’s food, and for the nourishment of your servant girls.",
      "paragraphStart": false
    }
  ]
}
