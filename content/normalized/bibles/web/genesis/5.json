{
  "chapter": {
    "id": "web:genesis.5",
    "translationId": "web",
    "bookSlug": "genesis",
    "chapterNumber": 5,
    "referenceLabel": "Genesis 5",
    "summary": "Source text for Genesis 5 in World English Bible."
  },
  "verses": [
    {
      "id": "web:genesis.5.1",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Genesis 5:1",
      "text": "This is the book of the generations of Adam. In the day that God created man, he made him in God’s likeness.",
      "paragraphStart": true
    },
    {
      "id": "web:genesis.5.2",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Genesis 5:2",
      "text": "He created them male and female, and blessed them. On the day they were created, he named them Adam.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.3",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Genesis 5:3",
      "text": "Adam lived one hundred thirty years, and became the father of a son in his own likeness, after his image, and named him Seth.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.4",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Genesis 5:4",
      "text": "The days of Adam after he became the father of Seth were eight hundred years, and he became the father of other sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.5",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Genesis 5:5",
      "text": "All the days that Adam lived were nine hundred thirty years, then he died.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.6",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Genesis 5:6",
      "text": "Seth lived one hundred five years, then became the father of Enosh.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.7",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Genesis 5:7",
      "text": "Seth lived after he became the father of Enosh eight hundred seven years, and became the father of other sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.8",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Genesis 5:8",
      "text": "All of the days of Seth were nine hundred twelve years, then he died.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.9",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Genesis 5:9",
      "text": "Enosh lived ninety years, and became the father of Kenan.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.10",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Genesis 5:10",
      "text": "Enosh lived after he became the father of Kenan eight hundred fifteen years, and became the father of other sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.11",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Genesis 5:11",
      "text": "All of the days of Enosh were nine hundred five years, then he died.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.12",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Genesis 5:12",
      "text": "Kenan lived seventy years, then became the father of Mahalalel.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.13",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Genesis 5:13",
      "text": "Kenan lived after he became the father of Mahalalel eight hundred forty years, and became the father of other sons and daughters",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.14",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Genesis 5:14",
      "text": "and all of the days of Kenan were nine hundred ten years, then he died.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.15",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Genesis 5:15",
      "text": "Mahalalel lived sixty-five years, then became the father of Jared.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.16",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Genesis 5:16",
      "text": "Mahalalel lived after he became the father of Jared eight hundred thirty years, and became the father of other sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.17",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Genesis 5:17",
      "text": "All of the days of Mahalalel were eight hundred ninety-five years, then he died.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.18",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Genesis 5:18",
      "text": "Jared lived one hundred sixty-two years, then became the father of Enoch.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.19",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Genesis 5:19",
      "text": "Jared lived after he became the father of Enoch eight hundred years, and became the father of other sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.20",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Genesis 5:20",
      "text": "All of the days of Jared were nine hundred sixty-two years, then he died.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.21",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Genesis 5:21",
      "text": "Enoch lived sixty-five years, then became the father of Methuselah.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.22",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Genesis 5:22",
      "text": "After Methuselah ’s birth, Enoch walked with God for three hundred years, and became the father of more sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.23",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Genesis 5:23",
      "text": "All the days of Enoch were three hundred sixty-five years.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.24",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Genesis 5:24",
      "text": "Enoch walked with God, and he was not found, for God took him.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.25",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Genesis 5:25",
      "text": "Methuselah lived one hundred eighty-seven years, then became the father of Lamech.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.26",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Genesis 5:26",
      "text": "Methuselah lived after he became the father of Lamech seven hundred eighty-two years, and became the father of other sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.27",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Genesis 5:27",
      "text": "All the days of Methuselah were nine hundred sixty-nine years, then he died.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.28",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "Genesis 5:28",
      "text": "Lamech lived one hundred eighty-two years, then became the father of a son.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.29",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "Genesis 5:29",
      "text": "He named him Noah, saying, “ This one will comfort us in our work and in the toil of our hands, caused by the ground which Yahweh has cursed.”",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.30",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "Genesis 5:30",
      "text": "Lamech lived after he became the father of Noah five hundred ninety-five years, and became the father of other sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.31",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "Genesis 5:31",
      "text": "All the days of Lamech were seven hundred seventy-seven years, then he died.",
      "paragraphStart": false
    },
    {
      "id": "web:genesis.5.32",
      "translationId": "web",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 32,
      "referenceLabel": "Genesis 5:32",
      "text": "Noah was five hundred years old, then Noah became the father of Shem, Ham, and Japheth.",
      "paragraphStart": false
    }
  ]
}
