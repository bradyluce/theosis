{
  "chapter": {
    "id": "web:colossians.3",
    "translationId": "web",
    "bookSlug": "colossians",
    "chapterNumber": 3,
    "referenceLabel": "Colossians 3",
    "summary": "Source text for Colossians 3 in World English Bible."
  },
  "verses": [
    {
      "id": "web:colossians.3.1",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Colossians 3:1",
      "text": "If then you were raised together with Christ, seek the things that are above, where Christ is, seated on the right hand of God.",
      "paragraphStart": true
    },
    {
      "id": "web:colossians.3.2",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Colossians 3:2",
      "text": "Set your mind on the things that are above, not on the things that are on the earth.",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.3",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Colossians 3:3",
      "text": "For you died, and your life is hidden with Christ in God.",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.4",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Colossians 3:4",
      "text": "When Christ, our life, is revealed, then you will also be revealed with him in glory.",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.5",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Colossians 3:5",
      "text": "Put to death therefore your members which are on the earth: sexual immorality, uncleanness, depraved passion, evil desire, and covetousness, which is idolatry.",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.6",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Colossians 3:6",
      "text": "For these things ’ sake the wrath of God comes on the children of disobedience.",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.7",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Colossians 3:7",
      "text": "You also once walked in those, when you lived in them,",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.8",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Colossians 3:8",
      "text": "but now you must put them all away: anger, wrath, malice, slander, and shameful speaking out of your mouth.",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.9",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Colossians 3:9",
      "text": "Don’ t lie to one another, seeing that you have put off the old man with his doings,",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.10",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Colossians 3:10",
      "text": "and have put on the new man, who is being renewed in knowledge after the image of his Creator,",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.11",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Colossians 3:11",
      "text": "where there can’ t be Greek and Jew, circumcision and uncircumcision, barbarian, Scythian, bondservant, or free person; but Christ is all, and in all.",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.12",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Colossians 3:12",
      "text": "Put on therefore, as God ’s chosen ones, holy and beloved, a heart of compassion, kindness, lowliness, humility, and perseverance;",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.13",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Colossians 3:13",
      "text": "bearing with one another, and forgiving each other, if any man has a complaint against any; even as Christ forgave you, so you also do.",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.14",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Colossians 3:14",
      "text": "Above all these things, walk in love, which is the bond of perfection.",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.15",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Colossians 3:15",
      "text": "And let the peace of God rule in your hearts, to which also you were called in one body, and be thankful.",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.16",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Colossians 3:16",
      "text": "Let the word of Christ dwell in you richly; in all wisdom teaching and admonishing one another with psalms, hymns, and spiritual songs, singing with grace in your heart to the Lord.",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.17",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Colossians 3:17",
      "text": "Whatever you do, in word or in deed, do all in the name of the Lord Jesus, giving thanks to God the Father through him.",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.18",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Colossians 3:18",
      "text": "Wives, be in subjection to your husbands, as is fitting in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.19",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Colossians 3:19",
      "text": "Husbands, love your wives, and don’ t be bitter against them.",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.20",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Colossians 3:20",
      "text": "Children, obey your parents in all things, for this pleases the Lord.",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.21",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Colossians 3:21",
      "text": "Fathers, don’ t provoke your children, so that they won’ t be discouraged.",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.22",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Colossians 3:22",
      "text": "Servants, obey in all things those who are your masters according to the flesh, not just when they are looking, as men pleasers, but in singleness of heart, fearing God.",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.23",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Colossians 3:23",
      "text": "And whatever you do, work heartily, as for the Lord and not for men,",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.24",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Colossians 3:24",
      "text": "knowing that from the Lord you will receive the reward of the inheritance; for you serve the Lord Christ.",
      "paragraphStart": false
    },
    {
      "id": "web:colossians.3.25",
      "translationId": "web",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Colossians 3:25",
      "text": "But he who does wrong will receive again for the wrong that he has done, and there is no partiality.",
      "paragraphStart": false
    }
  ]
}
