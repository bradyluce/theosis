{
  "chapter": {
    "id": "web:job.18",
    "translationId": "web",
    "bookSlug": "job",
    "chapterNumber": 18,
    "referenceLabel": "Job 18",
    "summary": "Source text for Job 18 in World English Bible."
  },
  "verses": [
    {
      "id": "web:job.18.1",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Job 18:1",
      "text": "Then Bildad the Shuhite answered,",
      "paragraphStart": true
    },
    {
      "id": "web:job.18.2",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Job 18:2",
      "text": "“How long will you hunt for words? Consider, and afterwards we will speak.",
      "paragraphStart": false
    },
    {
      "id": "web:job.18.3",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Job 18:3",
      "text": "Why are we counted as animals, which have become unclean in your sight?",
      "paragraphStart": false
    },
    {
      "id": "web:job.18.4",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Job 18:4",
      "text": "You who tear yourself in your anger, will the earth be forsaken for you? Or will the rock be removed out of its place?",
      "paragraphStart": false
    },
    {
      "id": "web:job.18.5",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Job 18:5",
      "text": "“Yes, the light of the wicked will be put out. The spark of his fire won’t shine.",
      "paragraphStart": false
    },
    {
      "id": "web:job.18.6",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Job 18:6",
      "text": "The light will be dark in his tent. His lamp above him will be put out.",
      "paragraphStart": false
    },
    {
      "id": "web:job.18.7",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Job 18:7",
      "text": "The steps of his strength will be shortened. His own counsel will cast him down.",
      "paragraphStart": false
    },
    {
      "id": "web:job.18.8",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Job 18:8",
      "text": "For he is cast into a net by his own feet, and he wanders into its mesh.",
      "paragraphStart": false
    },
    {
      "id": "web:job.18.9",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Job 18:9",
      "text": "A snare will take him by the heel. A trap will catch him.",
      "paragraphStart": false
    },
    {
      "id": "web:job.18.10",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Job 18:10",
      "text": "A noose is hidden for him in the ground, a trap for him on the path.",
      "paragraphStart": false
    },
    {
      "id": "web:job.18.11",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Job 18:11",
      "text": "Terrors will make him afraid on every side, and will chase him at his heels.",
      "paragraphStart": false
    },
    {
      "id": "web:job.18.12",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Job 18:12",
      "text": "His strength will be famished. Calamity will be ready at his side.",
      "paragraphStart": false
    },
    {
      "id": "web:job.18.13",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "Job 18:13",
      "text": "The members of his body will be devoured. The firstborn of death will devour his members.",
      "paragraphStart": false
    },
    {
      "id": "web:job.18.14",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "Job 18:14",
      "text": "He will be rooted out of the security of his tent. He will be brought to the king of terrors.",
      "paragraphStart": false
    },
    {
      "id": "web:job.18.15",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "Job 18:15",
      "text": "There will dwell in his tent that which is none of his. Sulfur will be scattered on his habitation.",
      "paragraphStart": false
    },
    {
      "id": "web:job.18.16",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 16,
      "referenceLabel": "Job 18:16",
      "text": "His roots will be dried up beneath. His branch will be cut off above.",
      "paragraphStart": false
    },
    {
      "id": "web:job.18.17",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 17,
      "referenceLabel": "Job 18:17",
      "text": "His memory will perish from the earth. He will have no name in the street.",
      "paragraphStart": false
    },
    {
      "id": "web:job.18.18",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 18,
      "referenceLabel": "Job 18:18",
      "text": "He will be driven from light into darkness, and chased out of the world.",
      "paragraphStart": false
    },
    {
      "id": "web:job.18.19",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 19,
      "referenceLabel": "Job 18:19",
      "text": "He will have neither son nor grandson among his people, nor any remaining where he lived.",
      "paragraphStart": false
    },
    {
      "id": "web:job.18.20",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 20,
      "referenceLabel": "Job 18:20",
      "text": "Those who come after will be astonished at his day, as those who went before were frightened.",
      "paragraphStart": false
    },
    {
      "id": "web:job.18.21",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 21,
      "referenceLabel": "Job 18:21",
      "text": "Surely such are the dwellings of the unrighteous. This is the place of him who doesn’t know God.”",
      "paragraphStart": false
    }
  ]
}
