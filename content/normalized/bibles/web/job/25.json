      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Job 25:1",
      "text": "Then Bildad the Shuhite answered,",
      "paragraphStart": true
    },
    {
      "id": "web:job.25.2",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Job 25:2",
      "text": "“ Dominion and fear are with him. He makes peace in his high places.",
      "paragraphStart": false
    },
    {
      "id": "web:job.25.3",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Job 25:3",
      "text": "Can his armies be counted? On whom does his light not arise?",
      "paragraphStart": false
    },
    {
      "id": "web:job.25.4",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Job 25:4",
      "text": "How then can man be just with God? Or how can he who is born of a woman be clean?",
      "paragraphStart": false
    },
    {
      "id": "web:job.25.5",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Job 25:5",
      "text": "Behold, even the moon has no brightness, and the stars are not pure in his sight;",
      "paragraphStart": false
    },
    {
      "id": "web:job.25.6",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Job 25:6",
      "text": "How much less man, who is a worm, and the son of man, who is a worm!”",
      "paragraphStart": false
    }
  ]
}
