{
  "chapter": {
    "id": "web:job.26",
    "translationId": "web",
    "bookSlug": "job",
    "chapterNumber": 26,
    "referenceLabel": "Job 26",
    "summary": "Source text for Job 26 in World English Bible."
  },
  "verses": [
    {
      "id": "web:job.26.1",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Job 26:1",
      "text": "Then Job answered,",
      "paragraphStart": true
    },
    {
      "id": "web:job.26.2",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Job 26:2",
      "text": "“How have you helped him who is without power! How have you saved the arm that has no strength!",
      "paragraphStart": false
    },
    {
      "id": "web:job.26.3",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Job 26:3",
      "text": "How have you counseled him who has no wisdom, and plentifully declared sound knowledge!",
      "paragraphStart": false
    },
    {
      "id": "web:job.26.4",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Job 26:4",
      "text": "To whom have you uttered words? Whose spirit came out of you?",
      "paragraphStart": false
    },
    {
      "id": "web:job.26.5",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Job 26:5",
      "text": "“The departed spirits tremble, those beneath the waters and all that live in them.",
      "paragraphStart": false
    },
    {
      "id": "web:job.26.6",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Job 26:6",
      "text": "Sheol is naked before God, and Abaddon has no covering.",
      "paragraphStart": false
    },
    {
      "id": "web:job.26.7",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Job 26:7",
      "text": "He stretches out the north over empty space, and hangs the earth on nothing.",
      "paragraphStart": false
    },
    {
      "id": "web:job.26.8",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Job 26:8",
      "text": "He binds up the waters in his thick clouds, and the cloud is not burst under them.",
      "paragraphStart": false
    },
    {
      "id": "web:job.26.9",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Job 26:9",
      "text": "He encloses the face of his throne, and spreads his cloud on it.",
      "paragraphStart": false
    },
    {
      "id": "web:job.26.10",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Job 26:10",
      "text": "He has described a boundary on the surface of the waters, and to the confines of light and darkness.",
      "paragraphStart": false
    },
    {
      "id": "web:job.26.11",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Job 26:11",
      "text": "The pillars of heaven tremble and are astonished at his rebuke.",
      "paragraphStart": false
    },
    {
      "id": "web:job.26.12",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Job 26:12",
      "text": "He stirs up the sea with his power, and by his understanding he strikes through Rahab.",
      "paragraphStart": false
    },
    {
      "id": "web:job.26.13",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 13,
      "referenceLabel": "Job 26:13",
      "text": "By his Spirit the heavens are garnished. His hand has pierced the swift serpent.",
      "paragraphStart": false
    },
    {
      "id": "web:job.26.14",
      "translationId": "web",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 14,
      "referenceLabel": "Job 26:14",
      "text": "Behold, these are but the outskirts of his ways. How small a whisper do we hear of him! But the thunder of his power who can understand?”",
      "paragraphStart": false
    }
  ]
}
