{
  "chapter": {
    "id": "web:second-timothy.4",
    "translationId": "web",
    "bookSlug": "second-timothy",
    "chapterNumber": 4,
    "referenceLabel": "2 Timothy 4",
    "summary": "Source text for 2 Timothy 4 in World English Bible."
  },
  "verses": [
    {
      "id": "web:second-timothy.4.1",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "2 Timothy 4:1",
      "text": "I command you therefore before God and the Lord Jesus Christ, who will judge the living and the dead at his appearing and his Kingdom:",
      "paragraphStart": true
    },
    {
      "id": "web:second-timothy.4.2",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "2 Timothy 4:2",
      "text": "preach the word; be urgent in season and out of season; reprove, rebuke, and exhort with all patience and teaching.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.3",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "2 Timothy 4:3",
      "text": "For the time will come when they will not listen to the sound doctrine, but having itching ears, will heap up for themselves teachers after their own lusts,",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.4",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "2 Timothy 4:4",
      "text": "and will turn away their ears from the truth, and turn away to fables.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.5",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "2 Timothy 4:5",
      "text": "But you be sober in all things, suffer hardship, do the work of an evangelist, and fulfill your ministry.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.6",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "2 Timothy 4:6",
      "text": "For I am already being offered, and the time of my departure has come.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.7",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "2 Timothy 4:7",
      "text": "I have fought the good fight. I have finished the course. I have kept the faith.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.8",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "2 Timothy 4:8",
      "text": "From now on, the crown of righteousness is stored up for me, which the Lord, the righteous judge, will give to me on that day; and not to me only, but also to all those who have loved his appearing.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.9",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "2 Timothy 4:9",
      "text": "Be diligent to come to me soon,",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.10",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "2 Timothy 4:10",
      "text": "for Demas left me, having loved this present world, and went to Thessalonica; Crescens to Galatia; and Titus to Dalmatia.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.11",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "2 Timothy 4:11",
      "text": "Only Luke is with me. Take Mark and bring him with you, for he is useful to me for service.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.12",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "2 Timothy 4:12",
      "text": "But I sent Tychicus to Ephesus.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.13",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "2 Timothy 4:13",
      "text": "Bring the cloak that I left at Troas with Carpus when you come — and the books, especially the parchments.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.14",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "2 Timothy 4:14",
      "text": "Alexander the coppersmith did much evil to me. The Lord will repay him according to his deeds.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.15",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "2 Timothy 4:15",
      "text": "Beware of him, for he greatly opposed our words.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.16",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "2 Timothy 4:16",
      "text": "At my first defense, no one came to help me, but all left me. May it not be held against them.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.17",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "2 Timothy 4:17",
      "text": "But the Lord stood by me and strengthened me, that through me the message might be fully proclaimed, and that all the Gentiles might hear. So I was delivered out of the mouth of the lion.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.18",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "2 Timothy 4:18",
      "text": "And the Lord will deliver me from every evil work and will preserve me for his heavenly Kingdom. To him be the glory forever and ever. Amen.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.19",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "2 Timothy 4:19",
      "text": "Greet Prisca and Aquila, and the house of Onesiphorus.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.20",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "2 Timothy 4:20",
      "text": "Erastus remained at Corinth, but I left Trophimus at Miletus sick.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.21",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "2 Timothy 4:21",
      "text": "Be diligent to come before winter. Eubulus salutes you, as do Pudens, Linus, Claudia, and all the brothers.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.4.22",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "2 Timothy 4:22",
      "text": "The Lord Jesus Christ be with your spirit. Grace be with you. Amen.",
      "paragraphStart": false
    }
  ]
}
