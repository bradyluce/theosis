{
  "chapter": {
    "id": "web:second-timothy.3",
    "translationId": "web",
    "bookSlug": "second-timothy",
    "chapterNumber": 3,
    "referenceLabel": "2 Timothy 3",
    "summary": "Source text for 2 Timothy 3 in World English Bible."
  },
  "verses": [
    {
      "id": "web:second-timothy.3.1",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "2 Timothy 3:1",
      "text": "But know this: that in the last days, grievous times will come.",
      "paragraphStart": true
    },
    {
      "id": "web:second-timothy.3.2",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "2 Timothy 3:2",
      "text": "For men will be lovers of self, lovers of money, boastful, arrogant, blasphemers, disobedient to parents, unthankful, unholy,",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.3.3",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "2 Timothy 3:3",
      "text": "without natural affection, unforgiving, slanderers, without self-control, fierce, not lovers of good,",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.3.4",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "2 Timothy 3:4",
      "text": "traitors, headstrong, conceited, lovers of pleasure rather than lovers of God,",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.3.5",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "2 Timothy 3:5",
      "text": "holding a form of godliness but having denied its power. Turn away from these, also.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.3.6",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "2 Timothy 3:6",
      "text": "For some of these are people who creep into houses and take captive gullible women loaded down with sins, led away by various lusts,",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.3.7",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "2 Timothy 3:7",
      "text": "always learning and never able to come to the knowledge of the truth.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.3.8",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "2 Timothy 3:8",
      "text": "Even as Jannes and Jambres opposed Moses, so these also oppose the truth, men corrupted in mind, who concerning the faith are rejected.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.3.9",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "2 Timothy 3:9",
      "text": "But they will proceed no further. For their folly will be evident to all men, as theirs also came to be.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.3.10",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "2 Timothy 3:10",
      "text": "But you followed my teaching, conduct, purpose, faith, patience, love, steadfastness,",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.3.11",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "2 Timothy 3:11",
      "text": "persecutions, and sufferings — those things that happened to me at Antioch, Iconium, and Lystra. I endured those persecutions. The Lord delivered me out of them all.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.3.12",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "2 Timothy 3:12",
      "text": "Yes, and all who desire to live godly in Christ Jesus will suffer persecution.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.3.13",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "2 Timothy 3:13",
      "text": "But evil men and impostors will grow worse and worse, deceiving and being deceived.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.3.14",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "2 Timothy 3:14",
      "text": "But you remain in the things which you have learned and have been assured of, knowing from whom you have learned them.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.3.15",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "2 Timothy 3:15",
      "text": "From infancy, you have known the holy Scriptures which are able to make you wise for salvation through faith which is in Christ Jesus.",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.3.16",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "2 Timothy 3:16",
      "text": "Every Scripture is God-breathed and profitable for teaching, for reproof, for correction, and for instruction in righteousness,",
      "paragraphStart": false
    },
    {
      "id": "web:second-timothy.3.17",
      "translationId": "web",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "2 Timothy 3:17",
      "text": "that each person who belongs to God may be complete, thoroughly equipped for every good work.",
      "paragraphStart": false
    }
  ]
}
