{
  "chapter": {
    "id": "cu-elizabeth:ecclesiastes.10",
    "translationId": "cu-elizabeth",
    "bookSlug": "ecclesiastes",
    "chapterNumber": 10,
    "referenceLabel": "Ecclesiastes 10",
    "summary": "Source text for Ecclesiastes 10 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:ecclesiastes.10.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Ecclesiastes 10:1",
      "text": "Мухи умершыя згнояют елеа сладость: честно малое мудрости паче славы велики безумия.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:ecclesiastes.10.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Ecclesiastes 10:2",
      "text": "Сердце мудраго одесную его, сердце же безумнаго ошуюю его:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ecclesiastes.10.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Ecclesiastes 10:3",
      "text": "и в путь егда безумный идет, сердце его лишается, и яже помышляет, вся безумие суть.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ecclesiastes.10.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Ecclesiastes 10:4",
      "text": "Аще дух владеющаго взыдет на тя, места твоего не остави: яко изцеление утолит грехи велики.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ecclesiastes.10.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Ecclesiastes 10:5",
      "text": "Есть лукавство, еже видех под солнцем, аки невольно изыде от лица владеющаго:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ecclesiastes.10.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Ecclesiastes 10:6",
      "text": "вдан безумный в высоты велики, а богатии во смиренных сядут:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ecclesiastes.10.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Ecclesiastes 10:7",
      "text": "видех рабов на конех, и князей идущих яко рабов на земли.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ecclesiastes.10.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Ecclesiastes 10:8",
      "text": "Копаяй яму впадет в ню, и разоряющаго ограду угрызнет его змий.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ecclesiastes.10.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Ecclesiastes 10:9",
      "text": "Иземляй камение поболит от них, разсецаяй дрова беду приимет в них:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ecclesiastes.10.10",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Ecclesiastes 10:10",
      "text": "аще спадет сечиво, и сам лицем смятется: и силы укрепит, и изюбилие мужу мудрость.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ecclesiastes.10.11",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Ecclesiastes 10:11",
      "text": "Аще угрызнет змий не в шепте, и несть излишества обавающему.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ecclesiastes.10.12",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Ecclesiastes 10:12",
      "text": "Словеса уст премудраго благодать, устне же безумнаго потопят его:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ecclesiastes.10.13",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Ecclesiastes 10:13",
      "text": "начало словес уст его безумие, и последняя уст его прелесть лукава.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ecclesiastes.10.14",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Ecclesiastes 10:14",
      "text": "Безумный умножает словеса: не разуме человек, что бывшее и что будущее, что созади его, (и) кто возвестит ему?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ecclesiastes.10.15",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Ecclesiastes 10:15",
      "text": "Труд безумных озлобит их, иже не разуме ити во град.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ecclesiastes.10.16",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Ecclesiastes 10:16",
      "text": "Горе тебе, граде, в немже царь твой юн, и князи твои рано ядят.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ecclesiastes.10.17",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Ecclesiastes 10:17",
      "text": "Блаженна ты, земле, еяже царь твой сын свободных, и князи твои во время ядят в силе и не постыдятся.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ecclesiastes.10.18",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Ecclesiastes 10:18",
      "text": "В леностех смирится строп, и в празднестве рук прокаплет храмина.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ecclesiastes.10.19",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Ecclesiastes 10:19",
      "text": "Во смех творят хлеб и вино и елей, еже веселитися живущым: и сребра со смирением послушают всяческая.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ecclesiastes.10.20",
      "translationId": "cu-elizabeth",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Ecclesiastes 10:20",
      "text": "И в совести убо твоей не клени царя, и в клети ложницы твоея не клени богатаго: яко птица небесная донесет глас твой, и имеяй криле возвестит слово твое.",
      "paragraphStart": false
    }
  ]
}
