{
  "chapter": {
    "id": "cu-elizabeth:proverbs.16",
    "translationId": "cu-elizabeth",
    "bookSlug": "proverbs",
    "chapterNumber": 16,
    "referenceLabel": "Proverbs 16",
    "summary": "Source text for Proverbs 16 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:proverbs.16.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 16:1",
      "text": "Человеку предложение сердца: и от Господа ответ языка.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:proverbs.16.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 16:2",
      "text": "Вся дела смиреннаго явленна пред Богом, и укрепляяй духи Господь.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 16:3",
      "text": "Приближи ко Господу дела твоя, и утвердятся помышления твоя.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 16:4",
      "text": "Вся содела Господь Себе ради: нечестивии же в день зол погибнут.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 16:5",
      "text": "Нечист пред Богом всяк высокосердый: в руку же руце влагаяй неправедно не обезвинится.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 16:6",
      "text": "Начало пути блага, еже творити праведная, приятна же пред Богом паче, нежели жрети жертвы.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 16:7",
      "text": "Ищай Господа обрящет разум со правдою:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 16:8",
      "text": "праве же ищущии его обрящут мир.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 16:9",
      "text": "Вся дела Господня со правдою: хранится же нечестивый на день зол.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.10",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 16:10",
      "text": "Пророчество во устнех царевых, в судищи же не погрешат уста его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.11",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 16:11",
      "text": "Превеса мерила правда у Господа: дела же Его мерила праведная.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.12",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 16:12",
      "text": "Мерзость цареви творяй злая: со правдою бо уготовляется престол началства.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.13",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 16:13",
      "text": "Приятны царю устне праведны, словеса же правая любит Господь.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.14",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 16:14",
      "text": "Ярость царева вестник смерти: муж же премудр утолит его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.15",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 16:15",
      "text": "Во свете жизни сын царев: приятнии же ему яко облак позден.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.16",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 16:16",
      "text": "Угнеждения премудрости избраннее злата: вселения же разума дражайши сребра.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.17",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 16:17",
      "text": "Путие жизни укланяются от злых: долгота же жития путие праведни. Приемляй наказание во благих будет, храняй же обличения умудрится. Иже хранит своя пути, соблюдает свою душу: любяй же живот свой щадит своя уста.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.18",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 16:18",
      "text": "Прежде сокрушения предваряет досаждение, прежде же падения злопомышление.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.19",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 16:19",
      "text": "Лучше кроткодушен со смирением, нежели иже разделяет корысти с досадительми.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.20",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 16:20",
      "text": "Разумный в вещех обретатель благих, надеяйся же на Господа блажен.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.21",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 16:21",
      "text": "Премудрыя и разумныя злыми наричут, сладции же в словеси множае услышани будут.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.22",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 16:22",
      "text": "Источник животен разум стяжавшым, наказание же безумных зло.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.23",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 16:23",
      "text": "Сердце премудраго уразумеет яже от своих ему уст, во устнах же носит разум.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.24",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 16:24",
      "text": "Сотове медовнии словеса добрая, сладость же их изцеление души.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.25",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 16:25",
      "text": "Суть путие мнящиися прави быти мужу, обаче последняя их зрят во дно адово.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.26",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 16:26",
      "text": "Муж в трудех труждается себе и изнуждает погибель свою: строптивый во своих устах носит погибель.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.27",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 16:27",
      "text": "Муж безумен копает себе злая и во устнах своих сокровищствует огнь.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.28",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 16:28",
      "text": "Муж строптивый разсылает злая, и светилник льсти вжигает злым, и разлучает други.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.29",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 16:29",
      "text": "Муж законопреступен прельщает други и отводит их в пути не благи.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.30",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 16:30",
      "text": "Утверждаяй очи свои мыслит развращенная, грызый же устне свои определяет вся злая: сей пещь есть злобы.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.31",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 16:31",
      "text": "Венец хвалы старость, на путех же правды обретается.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.32",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 16:32",
      "text": "Лучше муж долотерпелив паче крепкаго, (и муж разум имеяй паче земледелца великаго:) удержаваяй же гнев паче вземлющаго град.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.16.33",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 16:33",
      "text": "В недра входят вся неправедным: от Господа же вся праведная.",
      "paragraphStart": false
    }
  ]
}
