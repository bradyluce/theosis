{
  "chapter": {
    "id": "cu-elizabeth:proverbs.21",
    "translationId": "cu-elizabeth",
    "bookSlug": "proverbs",
    "chapterNumber": 21,
    "referenceLabel": "Proverbs 21",
    "summary": "Source text for Proverbs 21 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:proverbs.21.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 21:1",
      "text": "Якоже устремление воды, тако сердце царево в руце Божией: аможе аще восхощет обратити, тамо уклонит е.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:proverbs.21.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 21:2",
      "text": "Всяк муж является себе праведен: управляет же сердца Господь.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 21:3",
      "text": "Творити праведная и истинствовати угодна Богу паче, нежели жертв кровь.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 21:4",
      "text": "Велемудрый во укоризне дерзосерд, светило же нечестивых греси.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 21:5",
      "text": "Помышления тщаливаго во изюбилии, и всяк нерадивый в лишении.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 21:6",
      "text": "Делаяй сокровища языком лживым суетная гонит в сети смертныя.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 21:7",
      "text": "Всегубителство на нечестивыя устремляется: не хотят бо творити праведная.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 21:8",
      "text": "К стропотным стропотныя пути посылает Бог: чиста бо и права дела Его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 21:9",
      "text": "Лучше жити во угле непокровеннем, нежели в повапленных с неправдою и в храмине общей.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.10",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 21:10",
      "text": "Душа нечестиваго не помилуется ни от единаго от человеков.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.11",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 21:11",
      "text": "Тщету приемлющу невоздержному, коварнейший будет незлобивый, разумеваяй же мудрый приимет разум.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.12",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 21:12",
      "text": "Разумевает праведный сердца нечестивых и уничтожает нечестивыя в злых.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.13",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 21:13",
      "text": "Иже затыкает ушеса своя, еже не послушати немощнаго, и той призовет, и не будет послушаяй его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.14",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 21:14",
      "text": "Даяние тайно отвращает гневы, щадяй же даров воздвизает ярость крепкую.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.15",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 21:15",
      "text": "Веселие праведных творити суд: преподобный же нечист у злодеев.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.16",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 21:16",
      "text": "Муж заблуждаяй от пути правды в сонмищи исполинов почиет.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.17",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 21:17",
      "text": "Муж скуден любит веселие, любяй же вино и елей не обогатится.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.18",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 21:18",
      "text": "Отребие же праведнику беззаконник.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.19",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 21:19",
      "text": "Лучше жити в земли пусте, неже жити с женою сварливою и язычною и гневливою.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.20",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 21:20",
      "text": "Сокровище вожделенно почиет во устех мудраго: безумнии же мужие пожирают е.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.21",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 21:21",
      "text": "Путь правды и милостыни обрящет живот и славу.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.22",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 21:22",
      "text": "Во грады крепки вниде премудрый и разруши утверждение, на неже надеяшася нечестивии.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.23",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 21:23",
      "text": "Иже хранит своя уста и язык, соблюдает от печали душу свою.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.24",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 21:24",
      "text": "Продерзый и величавый и горделивый губитель нарицается: а иже памятозлобствует, беззаконен.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.25",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 21:25",
      "text": "Похоти лениваго убивают: не произволяют бо руце его творити что.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.26",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 21:26",
      "text": "Нечестивый желает весь день похоти злыя, праведный же милует и щедрит нещадно.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.27",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 21:27",
      "text": "Жертвы нечестивых мерзость Господеви: ибо беззаконно приносят я.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.28",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 21:28",
      "text": "Свидетель ложный погибнет, муж же послушлив сохраняемь возглаголет.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.29",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 21:29",
      "text": "Нечестив муж безстудно стоит лицем: правый же сам разумевает пути своя.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.30",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 21:30",
      "text": "Несть премудрости, несть мужества, несть совета у нечестиваго.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.21.31",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 21:31",
      "text": "Конь уготовляется на день брани: от Господа же помощь.",
      "paragraphStart": false
    }
  ]
}
