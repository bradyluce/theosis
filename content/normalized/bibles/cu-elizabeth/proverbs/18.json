{
  "chapter": {
    "id": "cu-elizabeth:proverbs.18",
    "translationId": "cu-elizabeth",
    "bookSlug": "proverbs",
    "chapterNumber": 18,
    "referenceLabel": "Proverbs 18",
    "summary": "Source text for Proverbs 18 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:proverbs.18.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 18:1",
      "text": "Вины ищет муж хотя отлучитися от другов, на всяко же время поносимь будет.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:proverbs.18.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 18:2",
      "text": "Не требует премудрости муж скудоумен, зане паче водится безумием.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 18:3",
      "text": "Егда приидет нечестивый во глубину зол, нерадит: находит же ему безчестие и поношение.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 18:4",
      "text": "Вода глубока слово в сердцы мужа, река же изскачущи и источник жизни.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 18:5",
      "text": "Чудитися лицу нечестиваго не добро, ниже преподобно укланяти праведное на суде.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 18:6",
      "text": "Устне безумнаго приводят его на зло, уста же его дерзостная призывают смерть.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 18:7",
      "text": "Уста безумнаго сокрушение ему, устне же его сеть души его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 18:8",
      "text": "Ленивыя низлагает страх: души же мужей женам подобных взалчут.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 18:9",
      "text": "Не изцеляяй себе во своих делех брат есть погубляющему себе самаго.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.10",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 18:10",
      "text": "Из величества крепости имя Господне, к немуже притекающе праведницы возносятся.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.11",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 18:11",
      "text": "Имение богату мужу град тверд, слава же его вельми присеняет.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.12",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 18:12",
      "text": "Прежде сокрушения возносится сердце мужу и прежде славы смиряется.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.13",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 18:13",
      "text": "Иже отвещает слово прежде слышания, безумие ему есть и поношение.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.14",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 18:14",
      "text": "Гнев мужа укрощает раб разумный: малодушна же человека кто стерпит?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.15",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 18:15",
      "text": "Сердце разумнаго стяжет чувствие, ушеса же мудрых ищут смысла.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.16",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 18:16",
      "text": "Даяние человека распространяет его и с сильными посаждает его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.17",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 18:17",
      "text": "Праведный себе самаго оглаголник во первословии: егда же приложит супостат, обличается.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.18",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 18:18",
      "text": "Прекословия утоляет молчаливый и во властех определяет.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.19",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 18:19",
      "text": "Брат от брата помогаемь, яко град тверд и высок, укрепляется же якоже основаное царство.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.20",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 18:20",
      "text": "От плодов уст муж насыщает чрево свое, и от плодов устен своих насытится.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.21",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 18:21",
      "text": "Смерть и живот в руце языка: удержавающии же его снедят плоды его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.22",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 18:22",
      "text": "Иже обрете жену добру, обрете благодать, приял же есть от Господа тишину.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.23",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 18:23",
      "text": "Иже изгоняет жену добрую, изгоняет благая: держай же прелюбодейцу безумен и нечестив.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.24",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 18:24",
      "text": "С молении глаголет убогий, богатый же отвещает жестоко.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:proverbs.18.25",
      "translationId": "cu-elizabeth",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 18:25",
      "text": "Муж любовен к дружбе, и есть друг прилепивыйся паче брата.",
      "paragraphStart": false
    }
  ]
}
