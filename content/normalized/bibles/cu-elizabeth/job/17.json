{
  "chapter": {
    "id": "cu-elizabeth:job.17",
    "translationId": "cu-elizabeth",
    "bookSlug": "job",
    "chapterNumber": 17,
    "referenceLabel": "Job 17",
    "summary": "Source text for Job 17 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:job.17.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Job 17:1",
      "text": "Тлею духом носимь, прошу же гроба и не улучаю.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:job.17.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Job 17:2",
      "text": "Молю болезнуя, и что сотворю? Украдоша же ми имение чуждии.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.17.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Job 17:3",
      "text": "Кто есть сей? Рукою моею связан да будет.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.17.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Job 17:4",
      "text": "Яко сердце их сокрыл еси от мудрости, сего ради да не вознесеши их.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.17.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Job 17:5",
      "text": "Части возвестит злобы: очи же на сынех истаяста.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.17.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Job 17:6",
      "text": "Положил же мя еси в притчу во языцех, смех же бых им.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.17.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Job 17:7",
      "text": "Ослепоста бо от гнева очи мои, повоеван бых вельми от всех:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.17.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Job 17:8",
      "text": "чудо объя истинных о сем, праведник же на беззаконника да востанет:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.17.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Job 17:9",
      "text": "да содержит же верный путь свой, чистый же рукама да приимет дерзость.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.17.10",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Job 17:10",
      "text": "Но обаче вси належите и приидите, не бо обретаю в вас истины.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.17.11",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Job 17:11",
      "text": "Дние мои преидоша в течении, расторгошася же удове сердца моего.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.17.12",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Job 17:12",
      "text": "Нощь в день преложих: свет близ от лица тмы.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.17.13",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Job 17:13",
      "text": "Аще бо стерплю, ад ми есть дом, в сумраце же постлася ми постеля.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.17.14",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Job 17:14",
      "text": "Смерть назвах отца моего быти, матерь же и сестру ми гной.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.17.15",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Job 17:15",
      "text": "Где убо еще есть ми надежда, или благая моя узрю?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.17.16",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Job 17:16",
      "text": "Или со мною во ад снидут, или вкупе в персть снидем.",
      "paragraphStart": false
    }
  ]
}
