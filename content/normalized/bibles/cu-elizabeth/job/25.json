  "verses": [
    {
      "id": "cu-elizabeth:job.25.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Job 25:1",
      "text": "Отвещав же Валдад Савхейский, рече:",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:job.25.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Job 25:2",
      "text": "что бо начало, аще не страх от Него, иже творит всяческая в вышних?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.25.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Job 25:3",
      "text": "Да никтоже бо мнит, яко есть умедление воинством: и на кого не найдет навет от Него?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.25.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Job 25:4",
      "text": "Како бо будет праведен человек пред Богом? Или кто очистит себе рожденный от жены?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.25.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Job 25:5",
      "text": "Аще луне повелевает, и не сияет, звезды же нечисты суть пред Ним,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.25.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Job 25:6",
      "text": "кольми паче человек гной, и сын человеческий червь.",
      "paragraphStart": false
    }
  ]
}
