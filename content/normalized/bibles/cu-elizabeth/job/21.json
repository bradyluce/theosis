{
  "chapter": {
    "id": "cu-elizabeth:job.21",
    "translationId": "cu-elizabeth",
    "bookSlug": "job",
    "chapterNumber": 21,
    "referenceLabel": "Job 21",
    "summary": "Source text for Job 21 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:job.21.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Job 21:1",
      "text": "Отвещав же Иов, рече:",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:job.21.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Job 21:2",
      "text": "послушайте, послушайте словес моих, да не будет ми от вас сие утешение:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Job 21:3",
      "text": "потерпите ми, аз же возглаголю, таже не посмеетемися.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Job 21:4",
      "text": "Что бо? Еда человеческо ми обличение? Или почто не возярюся?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Job 21:5",
      "text": "Воззревшии на мя удивитеся, руку положше на ланите.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Job 21:6",
      "text": "Аще бо воспомяну, ужаснуся: обдержат бо плоть мою болезни.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Job 21:7",
      "text": "Почто нечестивии живут, обетшаша же в богатстве?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Job 21:8",
      "text": "Семя их по души, чада же их пред очима.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Job 21:9",
      "text": "Домове их обилнии суть, страх же нигде, раны же от Господа несть на них.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.10",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Job 21:10",
      "text": "Говядо их не изверже: спасена же бысть их имущая во чреве и не лишися.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.11",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Job 21:11",
      "text": "Пребывают же яко овцы вечныя, дети же их предиграют,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.12",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Job 21:12",
      "text": "вземше псалтирь и гусли, и веселятся гласом песни.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.13",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Job 21:13",
      "text": "Скончаша во благих житие свое, в покои же адове успоша.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.14",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Job 21:14",
      "text": "Глаголют же Господеви: отступи от нас, путий Твоих ведети не хощем:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.15",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Job 21:15",
      "text": "что достоин, яко да поработаем Ему? И кая польза, яко да взыщем Его?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.16",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Job 21:16",
      "text": "В руках бо их бяху благая, дел же нечестивых не надзирает.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.17",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Job 21:17",
      "text": "Обаче же и нечестивых светилник угаснет, найдет же им развращение, болезни же их оымут от гнева:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.18",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Job 21:18",
      "text": "будут же аки плевы пред ветром, или якоже прах, егоже взя вихр.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.19",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Job 21:19",
      "text": "Да оскудеют сыном имения его: воздаст противу ему, и уразумеет.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.20",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Job 21:20",
      "text": "Да узрят очи его свое убиение, от Господа же да не спасется.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.21",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Job 21:21",
      "text": "Яко воля его с ним в дому его, и числа месяцей его разделишася.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.22",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Job 21:22",
      "text": "Не Господь ли есть научаяй разуму и хитрости? Тойже мудрых разсуждает.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.23",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Job 21:23",
      "text": "Той умрет в силе простоты своея, всецел же благодушествуяй и благоуспеваяй,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.24",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Job 21:24",
      "text": "утроба же его исполнена тука, мозг же его разливается.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.25",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Job 21:25",
      "text": "Ов же умирает в горести души, не ядый ничтоже блага.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.26",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Job 21:26",
      "text": "Вкупе же на земли спят, гнилость же их покры.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.27",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Job 21:27",
      "text": "Темже вем вас, яко дерзостию належите ми,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.28",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Job 21:28",
      "text": "яко речете: где есть дом княжь? И где есть покров селений нечестивых?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.29",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Job 21:29",
      "text": "Вопросите мимоходящих путем, и знамения их не чужда сотворите.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.30",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Job 21:30",
      "text": "Яко на день пагубы соблюдается нечестивый, и в день гнева Его отведен будет.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.31",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Job 21:31",
      "text": "Кто возвестит пред лицем его путь его, и еже той сотвори, кто воздаст ему?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.32",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 32,
      "referenceLabel": "Job 21:32",
      "text": "И той во гроб отнесен бысть, и на гробищих побде.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.33",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 33,
      "referenceLabel": "Job 21:33",
      "text": "Усладися ему дробное камение потока, и вслед его всяк человек отидет, и пред ним безчисленнии.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.21.34",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 34,
      "referenceLabel": "Job 21:34",
      "text": "Како же мя утешаете суетными? А еже бы мне почити от вас, ничтоже.",
      "paragraphStart": false
    }
  ]
}
