{
  "chapter": {
    "id": "cu-elizabeth:job.35",
    "translationId": "cu-elizabeth",
    "bookSlug": "job",
    "chapterNumber": 35,
    "referenceLabel": "Job 35",
    "summary": "Source text for Job 35 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:job.35.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 1,
      "referenceLabel": "Job 35:1",
      "text": "Отвещав же еще Елиус, рече:",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:job.35.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 2,
      "referenceLabel": "Job 35:2",
      "text": "что сие мнил еси на суде? Ты кто еси, яко рекл еси: прав есмь пред Господем?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.35.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 3,
      "referenceLabel": "Job 35:3",
      "text": "Или речеши: что сотворю согрешив?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.35.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 4,
      "referenceLabel": "Job 35:4",
      "text": "Аз же ти дам ответ и трием другом твоим.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.35.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 5,
      "referenceLabel": "Job 35:5",
      "text": "Воззри на небо и виждь: смотри же на облаки, коль высоки суть от тебе.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.35.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 6,
      "referenceLabel": "Job 35:6",
      "text": "Аще согрешил еси, что сотвориши? Аще же и много беззаконновал еси, что можеши сотворити?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.35.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 7,
      "referenceLabel": "Job 35:7",
      "text": "Понеже убо праведен еси, что даси Ему? Или что из руки твоея возмет?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.35.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 8,
      "referenceLabel": "Job 35:8",
      "text": "Мужеви подобному тебе нечестие твое, и сыну человеческому правда твоя.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.35.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 9,
      "referenceLabel": "Job 35:9",
      "text": "От множества оклеветаемии воззовут, возопиют от мышцы многих:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.35.10",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 10,
      "referenceLabel": "Job 35:10",
      "text": "и не рече: где есть Бог сотворивый мя, устрояяй стражбы нощныя,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.35.11",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 11,
      "referenceLabel": "Job 35:11",
      "text": "отделяяй мя от четвероногих земных и от небесных птиц?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.35.12",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 12,
      "referenceLabel": "Job 35:12",
      "text": "Тамо воззовут, и не имаши услышати, и от досады злых.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.35.13",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 13,
      "referenceLabel": "Job 35:13",
      "text": "Безместная бо видети не хощет Господь: Сам бо Вседержитель зритель есть творящих беззаконная, и спасет мя.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.35.14",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 14,
      "referenceLabel": "Job 35:14",
      "text": "Судися же пред Ним, аще можеши похвалити Его, якоже есть и ныне.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.35.15",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 15,
      "referenceLabel": "Job 35:15",
      "text": "Яко несть посещаяй гневом Своим, и не позна прегрешения коеголибо зело.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:job.35.16",
      "translationId": "cu-elizabeth",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 16,
      "referenceLabel": "Job 35:16",
      "text": "Иов же всуе отверзает уста своя, неведением словеса отягощает.",
      "paragraphStart": false
    }
  ]
}
