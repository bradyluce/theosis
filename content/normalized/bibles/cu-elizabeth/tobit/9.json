{
  "chapter": {
    "id": "cu-elizabeth:tobit.9",
    "translationId": "cu-elizabeth",
    "bookSlug": "tobit",
    "chapterNumber": 9,
    "referenceLabel": "Tobit 9",
    "summary": "Source text for Tobit 9 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:tobit.9.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "tobit",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Tobit 9:1",
      "text": "И призва Товиа Рафаила и рече ему:",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:tobit.9.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "tobit",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Tobit 9:2",
      "text": "Азариа брате возми с собою отрока и два велблюда, и пойди в Раги Мидииския ко Гаваилу, и принеси ми сребро, и самого приведи ми на брак,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:tobit.9.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "tobit",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Tobit 9:3",
      "text": "понеже закля Рагуил не исходити ми,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:tobit.9.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "tobit",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Tobit 9:4",
      "text": "а отец мой сочисляет дни, и аще премедлю много, скорбети будет зело.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:tobit.9.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "tobit",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Tobit 9:5",
      "text": "И иде Рафаил, и пребысть у Гаваила, и даде ему рукописание: он же изнесе мешцы с печатьми и вдаде ему.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:tobit.9.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "tobit",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Tobit 9:6",
      "text": "И обутреневаста купно и приидоста на брак. И благослови Товиа жену свою.",
      "paragraphStart": false
    }
  ]
}
