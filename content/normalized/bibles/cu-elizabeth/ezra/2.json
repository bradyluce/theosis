{
  "chapter": {
    "id": "cu-elizabeth:ezra.2",
    "translationId": "cu-elizabeth",
    "bookSlug": "ezra",
    "chapterNumber": 2,
    "referenceLabel": "Ezra 2",
    "summary": "Source text for Ezra 2 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:ezra.2.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Ezra 2:1",
      "text": "Сии же суть сынове страны, иже взыдоша от плена преселения, ихже пресели Навуходоносор царь Вавилонский в Вавилон: и возвратишася во Иерусалим и Иудею кийждо муж во град свой.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:ezra.2.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Ezra 2:2",
      "text": "Иже приидоша с Зоровавелем: Иисус, Неемиа, Сараиа, Реелиа, Мардохей, Валасан, Масфар, Вагуй, Реум, Ваана. Сие число мужем людий Израилевых:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Ezra 2:3",
      "text": "сынове Фаресовы две тысящы сто седмьдесят и два,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Ezra 2:4",
      "text": "сынове Сафатиевы триста седмьдесят два,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Ezra 2:5",
      "text": "сынове Аресовы седмь сот седмьдесят пять,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Ezra 2:6",
      "text": "сынове Фааф-Моавли от сынов Иисуевух и Иоавлих две тысящы осмь сот дванадесять,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Ezra 2:7",
      "text": "сынове Еламли тысяща двести пятьдесят четыри,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Ezra 2:8",
      "text": "сынове Зафуевы девять сот четыредесять пять,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Ezra 2:9",
      "text": "сынове Закхани седмь сот шестьдесят,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.10",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Ezra 2:10",
      "text": "сынове Вануевы шесть сот четыредесять два,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.11",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Ezra 2:11",
      "text": "сынове Ваваевы шесть сот двадесять три,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.12",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Ezra 2:12",
      "text": "сынове Авгадовы тысяща двести двадесять два,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.13",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Ezra 2:13",
      "text": "сынове Адоникамовы шесть сот шестьдесят шесть,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.14",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Ezra 2:14",
      "text": "сынове Вагуевы две тысящы пятьдесят шесть,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.15",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Ezra 2:15",
      "text": "сынове Адины четыриста пятьдесят четыри,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.16",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Ezra 2:16",
      "text": "сынове Атировы, иже бяху от Езекии, девятьдесят осмь,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.17",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Ezra 2:17",
      "text": "сынове Вассуевы триста двадесять три,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.18",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Ezra 2:18",
      "text": "сынове Иоравовы сто дванадесять,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.19",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Ezra 2:19",
      "text": "сынове Асумли двести двадесять три,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.20",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Ezra 2:20",
      "text": "сынове Гаверовы девятьдесят пять,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.21",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Ezra 2:21",
      "text": "сынове Вефлаемли сто двадесять три,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.22",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Ezra 2:22",
      "text": "сынове Нетофаевы пятьдесят шесть,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.23",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Ezra 2:23",
      "text": "сынове Анафофовы сто двадесять осмь,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.24",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "Ezra 2:24",
      "text": "сынове Азмофовы четыредесять три,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.25",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "Ezra 2:25",
      "text": "сынове Кариафиаримли, Хафира и Вироф, седмь сот четыредесять три,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.26",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "Ezra 2:26",
      "text": "сынове от Рамы и Гаваи шесть сот двадесять един,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.27",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "Ezra 2:27",
      "text": "мужей Махмаских сто двадесять два,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.28",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "Ezra 2:28",
      "text": "мужей Вефилских и Гайских четыреста двадесять три,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.29",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 29,
      "referenceLabel": "Ezra 2:29",
      "text": "сынове от Навы пятьдесят два,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.30",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 30,
      "referenceLabel": "Ezra 2:30",
      "text": "сынове Магевисовы сто пятьдесят шесть,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.31",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 31,
      "referenceLabel": "Ezra 2:31",
      "text": "сынове Иламаровы тысяща двести пятьдесят четыри,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.32",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 32,
      "referenceLabel": "Ezra 2:32",
      "text": "сынове Ирамли триста двадесять,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.33",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 33,
      "referenceLabel": "Ezra 2:33",
      "text": "сынове Лиддоновы, Лодадидовы и Оновы седмь сот двадесять пять,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.34",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 34,
      "referenceLabel": "Ezra 2:34",
      "text": "сынове Иерихони триста четыредесять пять,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.35",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 35,
      "referenceLabel": "Ezra 2:35",
      "text": "сынове Сеннааевы три тысящы шесть сот тридесять.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.36",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 36,
      "referenceLabel": "Ezra 2:36",
      "text": "Священницы же: сынове Иедуевы в дому Иисуеве девять сот седмьдесят три,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.37",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 37,
      "referenceLabel": "Ezra 2:37",
      "text": "сынове Еммировы тысяща пятьдесят два,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.38",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 38,
      "referenceLabel": "Ezra 2:38",
      "text": "сынове Фассуровы тысяща двести четыредесять седмь,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.39",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 39,
      "referenceLabel": "Ezra 2:39",
      "text": "сынове Иремли тысяща седмьнадесять.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.40",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 40,
      "referenceLabel": "Ezra 2:40",
      "text": "Левити же сынове Иисуевы и Кадмиили от сынов Одуиевых седмьдесят четыри.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.41",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 41,
      "referenceLabel": "Ezra 2:41",
      "text": "Певцы же сынове Асафовы сто двадесять осмь.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.42",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 42,
      "referenceLabel": "Ezra 2:42",
      "text": "Сынове дверников: сынове Селлумли, сынове Атироы, сынове Телмоновы, сынове Акувовы, сынове Атитовы, сынове Соваиевы, всех сто тридесять девять.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.43",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 43,
      "referenceLabel": "Ezra 2:43",
      "text": "Нафинее: сынове Суавли, сынове Суфатовы, сынове Тавваофли,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.44",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 44,
      "referenceLabel": "Ezra 2:44",
      "text": "сынове Кирасовы, сынове Сирсавли, сынове Фадонины,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.45",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 45,
      "referenceLabel": "Ezra 2:45",
      "text": "сынове Лавановы, сынове Агавовы, сынове Акувовы,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.46",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 46,
      "referenceLabel": "Ezra 2:46",
      "text": "сынове Агавовы, сынове Селамиины, сынове Анановы,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.47",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 47,
      "referenceLabel": "Ezra 2:47",
      "text": "сынове Геддилины, сынове Гааровы, сынове Раиаевы,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.48",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 48,
      "referenceLabel": "Ezra 2:48",
      "text": "сынове Расоновы, сынове Некодовы, сынове Газемли,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.49",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 49,
      "referenceLabel": "Ezra 2:49",
      "text": "сынове Азоковы, сынове Фасиевы, сынове Расиины,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.50",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 50,
      "referenceLabel": "Ezra 2:50",
      "text": "сынове Асенаевы, сынове Мунниновы, сынове Нефусимли,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.51",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 51,
      "referenceLabel": "Ezra 2:51",
      "text": "сынове Ваквуковы, сынове Акуфаевы, сынове Ануровы,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.52",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 52,
      "referenceLabel": "Ezra 2:52",
      "text": "сынове Васалофовы, сынове Мидановы, сынове Арсановы,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.53",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 53,
      "referenceLabel": "Ezra 2:53",
      "text": "сынове Варкосовы, сынове Сисарины, сынове Фемавли,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.54",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 54,
      "referenceLabel": "Ezra 2:54",
      "text": "сынове Нафиевы, сынове Атифовы.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.55",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 55,
      "referenceLabel": "Ezra 2:55",
      "text": "Сынове слуг Соломоновых: сынове Сотаевы, сынове Сефирины, сынове Фадуровы,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.56",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 56,
      "referenceLabel": "Ezra 2:56",
      "text": "сынове Иеалаевы, сынове Дерконовы, сынове Геддилины,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.57",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 57,
      "referenceLabel": "Ezra 2:57",
      "text": "сынове Сафатиевы, сынове Аттилевы, сынове Фахерафовы, сынове Асевоимли, сынове Имеевы:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.58",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 58,
      "referenceLabel": "Ezra 2:58",
      "text": "вси нафанимовы и сынове слуг Соломоновых триста девятьдесят два.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.59",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 59,
      "referenceLabel": "Ezra 2:59",
      "text": "И сии, иже восхождаху от Фелмелеха, Фелариса, Херув, Идан, Еммир, и не могоша сказати дому отечества своего и семене своего, от Израиля ли быша:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.60",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 60,
      "referenceLabel": "Ezra 2:60",
      "text": "сынове Далаиевы, сынове Товиевы, сынове Некодаевы, шесть сот пятьдесят два:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.61",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 61,
      "referenceLabel": "Ezra 2:61",
      "text": "и от сынов священнических сынове Оваиевы, сынове Аккусовы, сынове Верзеллаевы, иже поя от дщерей Верзеллаа Галаадитина жену и наречеся именем их:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.62",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 62,
      "referenceLabel": "Ezra 2:62",
      "text": "тии искаша писания роду своему и не обретоша, и изгнани суть от священства.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.63",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 63,
      "referenceLabel": "Ezra 2:63",
      "text": "И рече Аферсафа им, да не ядят от святаго святых, дондеже востанет священник со изявлением и истиною.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.64",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 64,
      "referenceLabel": "Ezra 2:64",
      "text": "Все же множество купно яко четыри тмы две тысящы триста шестьдесят,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.65",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 65,
      "referenceLabel": "Ezra 2:65",
      "text": "кроме рабов их и рабынь их, сих седмь тысящ триста тридесять седмь: и сии певцы и певницы двести.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.66",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 66,
      "referenceLabel": "Ezra 2:66",
      "text": "Коней их седмь сот тридесять шесть, мсков их двести четыредесять пять,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.67",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 67,
      "referenceLabel": "Ezra 2:67",
      "text": "велблюдов их четыреста тридесять пять, ослов их шесть тысящ седмь сот двадесять.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.68",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 68,
      "referenceLabel": "Ezra 2:68",
      "text": "И от князей отечеств, егда вхождаху тии в церковь Господню, яже во Иерусалиме, добровольно принесоша в дом Божий, поставити его на основании его:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.69",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 69,
      "referenceLabel": "Ezra 2:69",
      "text": "по силе своей даша в росход дела, злата драхм шестьдесят тысящ и тысящу, и сребра мнас пять тысящ, и одеяний священнических сто.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:ezra.2.70",
      "translationId": "cu-elizabeth",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 70,
      "referenceLabel": "Ezra 2:70",
      "text": "И седоша священницы и левити, и иже от людий, и певцы и дверницы и нафинимляне во градех своих, и весь Израиль во градех своих.",
      "paragraphStart": false
    }
  ]
}
