      "translationId": "cu-elizabeth",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 66,
      "referenceLabel": "Matthew 27:66",
      "text": "Они же шедше утвердиша гроб, знаменавше камень с кустодиею.",
