{
  "chapter": {
    "id": "cu-elizabeth:first-chronicles.6",
    "translationId": "cu-elizabeth",
    "bookSlug": "first-chronicles",
    "chapterNumber": 6,
    "referenceLabel": "1 Chronicles 6",
    "summary": "Source text for 1 Chronicles 6 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:first-chronicles.6.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 6:1",
      "text": "Сынове Левии: Герсон, Кааф и Мерари.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 6:2",
      "text": "Сынове же Каафовы: Амрам и Иссаар, Хеврон и Озиил.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 6:3",
      "text": "Сынове же Амрамли: Аарон и Моисей и Мариам. Сынове же Аароновы: Надав и Авиуд, Елеазар и Ифамар.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 6:4",
      "text": "И Елеазар роди Финееса, и Финеес роди Авиуда,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 6:5",
      "text": "и Авиуд роди Воккиа, и Воккий роди Озию,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 6:6",
      "text": "Озиа же роди Сареа, и Сарей роди Мариофа,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 6:7",
      "text": "Мариоф же роди Амарию, Амариа же роди Ахитова,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 6:8",
      "text": "Ахитов же роди Садока, и Садок роди Ахимааса,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 6:9",
      "text": "Ахимаас же роди Азарию и Азариа роди Иоанана,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.10",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 6:10",
      "text": "Иоанан же роди Азарию, той есть Азариа, иже священствова в дому, егоже созда Соломон во Иерусалиме.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.11",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 6:11",
      "text": "Роди же Азариа Амарию, и Амариа роди Ахитова,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.12",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 6:12",
      "text": "Ахитов же роди Садока, и Садок роди Селлума,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.13",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 6:13",
      "text": "и Селлум роди Хелкию, и Хелкиа роди Азарию,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.14",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 6:14",
      "text": "и Азариа роди Сареа, и Сарей роди Иоседека.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.15",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 6:15",
      "text": "Иоседек же изыде, егда пресели Господь Иуду и Иерусалима рукою Навуходоносора в Вавилон.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.16",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 6:16",
      "text": "Сынове же Левиини: Герсон, Кааф и Мерари.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.17",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 6:17",
      "text": "И сия имена сынов Герсоних: Ловений и Семей.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.18",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 6:18",
      "text": "Сынове же Каафовы: Амрам и Иссаар, Хеврон и Озиил.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.19",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 6:19",
      "text": "Сынове же Мерарины: Мооли и Муси. И сии роди Левиини по отечеством их.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.20",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 6:20",
      "text": "Герсонови: Ловений сын его, Иеф сын его, Семна сын его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.21",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 6:21",
      "text": "Иола сын его, Аддо сын его, Зара сын его, Иефри сын его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.22",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 6:22",
      "text": "Сынове Каафовы: Иссаар сын его, Аминадав сын его, Корей сын его, Асир сын его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.23",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 6:23",
      "text": "Елкана сын его, Ависаф сын его, Асир сын его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.24",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 6:24",
      "text": "Кааф сын его, Уриил сын его, Озиа сын его, Саул сын его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.25",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 6:25",
      "text": "Сынове же Елкановы: Амаси сын его, Амиоф сын его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.26",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 6:26",
      "text": "Елкана сын его, Суфий сын его, и Нааф сын его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.27",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 6:27",
      "text": "Елиав сын его, Иеремеил сын его, Елкана сын его, Самуил сын его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.28",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 6:28",
      "text": "Сынове же Самуили: первенец его Иоиль и вторый Авиа.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.29",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 6:29",
      "text": "Сынове же Мерарины: Мооли сын его, Ловений сим его, Семей сын его, Озиа сын его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.30",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 6:30",
      "text": "Саммаа сын его, Ананий сын его, Асаиа сын его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.31",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 6:31",
      "text": "Сии же суть, ихже постави Давид над певцы в дому Господни, егда постави кивот:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.32",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 6:32",
      "text": "и бяху служаще пред скиниею дому свидения в пении, дондеже созда Соломон дом Господень во Иерусалиме, и стояху по чину своему в служении своем.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.33",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 6:33",
      "text": "И сии предстоящии и сынове их от сынов Каафовых: Еман певец сын Иоиля, сына Самуилева,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.34",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 6:34",
      "text": "сына Елканова, сына Еремеилева, сына Елиавля, сына Наафова,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.35",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 6:35",
      "text": "сына Суфова, сына Елканаева, сына Амиофова, сына Амасова,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.36",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 6:36",
      "text": "сына Елканова, сына Иоилева, сына Азариева, сына Сафаниева,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.37",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 6:37",
      "text": "сына Маафова, сына ассерова, сына Авиасафова, сына Асирова, сына Кореова,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.38",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 6:38",
      "text": "сына аминадавова, сына Исаарова, сына Каафова, сына Левиина, сына Израилева:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.39",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 6:39",
      "text": "и брат его Асаф, иже стояша одесную его: Асаф сын Варахии, сына Самааева,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.40",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 6:40",
      "text": "сына Михаилова, сына Масилова, сына Мелхиева,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.41",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 41,
      "referenceLabel": "1 Chronicles 6:41",
      "text": "сына Афаниева, сына Зараева, сына Адаиева,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.42",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 42,
      "referenceLabel": "1 Chronicles 6:42",
      "text": "сына Ифамова, сына Земмина, сына Семеиева,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.43",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 43,
      "referenceLabel": "1 Chronicles 6:43",
      "text": "сына Иеефова, сына Герсонова, сына Левиина.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.44",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 44,
      "referenceLabel": "1 Chronicles 6:44",
      "text": "Сынове же Мерарины братия их ошуюю: Ефам сын Хусии, сына Авдиина, сына Малохова,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.45",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 45,
      "referenceLabel": "1 Chronicles 6:45",
      "text": "сына Савиева, сына Амасиева, сына Хелкиева,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.46",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 46,
      "referenceLabel": "1 Chronicles 6:46",
      "text": "сына Амасиева, сына Ваниина, сына Семирова,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.47",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 47,
      "referenceLabel": "1 Chronicles 6:47",
      "text": "сына Моолиина, сына Мусиева, сына Мерарина, сына Левиина.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.48",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 48,
      "referenceLabel": "1 Chronicles 6:48",
      "text": "Братия же их по домом отечеств их, левитяне даны во всякое дело служения скинии дому Божия:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.49",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 49,
      "referenceLabel": "1 Chronicles 6:49",
      "text": "и Аарон и сынове его кадяху над олтарем всесожжений и над олтарем фимиама во всякое дело Святых Святым, и да молятся за Израиля по всему, елика повеле Моисей раб Божий.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.50",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 50,
      "referenceLabel": "1 Chronicles 6:50",
      "text": "Сии же сынове Аарони: Елеазар сын его, Финеес сын его, Авиуд сын его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.51",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 51,
      "referenceLabel": "1 Chronicles 6:51",
      "text": "Вокхий сын его, Озий сын его, Сарей сын его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.52",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 52,
      "referenceLabel": "1 Chronicles 6:52",
      "text": "Мариоф сын его, Амариа сын его, Ахитов сын его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.53",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 53,
      "referenceLabel": "1 Chronicles 6:53",
      "text": "Садок сын его, Ахимаас сын его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.54",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 54,
      "referenceLabel": "1 Chronicles 6:54",
      "text": "И сия обитания их, по селам их и в пределех их, сыном Аароним племени Каафову, тем бо бысть жребий:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.55",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 55,
      "referenceLabel": "1 Chronicles 6:55",
      "text": "и даша им Хеврон в земли Иудине и подградия его окрест его:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.56",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 56,
      "referenceLabel": "1 Chronicles 6:56",
      "text": "и села града и веси его даша Халеву сыну Иефонниину.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.57",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 57,
      "referenceLabel": "1 Chronicles 6:57",
      "text": "Сыном же Аароним даша грады убежищ: Хеврон и подградия его, и Ловну и подградия ея, и Алом и окрестная его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.58",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 58,
      "referenceLabel": "1 Chronicles 6:58",
      "text": "и Келом и окрестная его, и Давир и окрестная его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.59",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 59,
      "referenceLabel": "1 Chronicles 6:59",
      "text": "и Асан и подградия его, и Вефсамис и подградия его, и Вефсур и подградия его:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.60",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 60,
      "referenceLabel": "1 Chronicles 6:60",
      "text": "от колена же Вениаминова Гаваон и подградия его, и Еламоф и подградия его, и еламвей и подградия его, и Анафоф и подградия его: всех градов их тринадесять, градов по племенем их.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.61",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 61,
      "referenceLabel": "1 Chronicles 6:61",
      "text": "И сыном Каафовым оставшымся от племене рода, от полуплемене Манассиина, даша по жребию десять градов.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.62",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 62,
      "referenceLabel": "1 Chronicles 6:62",
      "text": "И сыном Герсоним по племенем их от колена Иссахарова и от колена Асирова, и от колена Неффалимова и от колена Манассиина в Васане, грады тринадесять.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.63",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 63,
      "referenceLabel": "1 Chronicles 6:63",
      "text": "И сыном Мерариным по племенем их от колена Рувимова и от колена Гадова и от колена Завулоня даша по жребию градов дванадесять.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.64",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 64,
      "referenceLabel": "1 Chronicles 6:64",
      "text": "Даша же сынове Израилевы левитом грады и подградия их.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.65",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 65,
      "referenceLabel": "1 Chronicles 6:65",
      "text": "Даша же по жребию от колена сынов Иудиных и от колена сынов Симеоних и от колена сынов Вениаминих грады сия, ихже назваша имены (своими).",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.66",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 66,
      "referenceLabel": "1 Chronicles 6:66",
      "text": "И от племен сынов Каафовых, и быша грады пределов их от колена Ефремова:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.67",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 67,
      "referenceLabel": "1 Chronicles 6:67",
      "text": "и даша им грады убежищ: Сихем с подградиями его в горе Ефремове и Газер с подградиями его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.68",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 68,
      "referenceLabel": "1 Chronicles 6:68",
      "text": "и Екмаан с подградиями его, и Вефорон и подградие его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.69",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 69,
      "referenceLabel": "1 Chronicles 6:69",
      "text": "и Елон с подградиями его, и Гефремон с подградиями его:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.70",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 70,
      "referenceLabel": "1 Chronicles 6:70",
      "text": "и от половины колена Манассиина Анеир и подградия его, и Иевлаам и подградная его, по племени сыном Каафовым оставшымся.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.71",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 71,
      "referenceLabel": "1 Chronicles 6:71",
      "text": "Сыном Герсоним от отечеств полуплемене Манассиина Гавлон от Васана и подградная его, и Асироф с подградными его:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.72",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 72,
      "referenceLabel": "1 Chronicles 6:72",
      "text": "и от колена Иссахарова Кедес с подградными его, и Надар с подградными его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.73",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 73,
      "referenceLabel": "1 Chronicles 6:73",
      "text": "и Рамоф и подградная его, и Енан с подградными его:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.74",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 74,
      "referenceLabel": "1 Chronicles 6:74",
      "text": "и от колена Асирова Масию с подградными его, и Рамоф и подградие его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.75",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 75,
      "referenceLabel": "1 Chronicles 6:75",
      "text": "и Акак и подградие его, и Роов с подградными его:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.76",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 76,
      "referenceLabel": "1 Chronicles 6:76",
      "text": "и от колена Неффалимля Кадис в Галилеи и подградная его, и Хамоф с подградными его, и Кариафаим и подградная его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.77",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 77,
      "referenceLabel": "1 Chronicles 6:77",
      "text": "И сыном Мерариным оставшымся от колена Завулоня Реммон и подградная его, и Фавор с подградными его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.78",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 78,
      "referenceLabel": "1 Chronicles 6:78",
      "text": "и за Иорданом Иерихон противу востока Иорданова: от колена Рувимова Восор в пустыни с подградными его, и Есса с подградными его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.79",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 79,
      "referenceLabel": "1 Chronicles 6:79",
      "text": "и Кадимоф и подградная его, и Моапсаф с подградными его:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.80",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 80,
      "referenceLabel": "1 Chronicles 6:80",
      "text": "и от колена Гадова Раммоф Галаадский и подградная его, и Наим с подградными его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.6.81",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 81,
      "referenceLabel": "1 Chronicles 6:81",
      "text": "и Есевон с подградными его, и Иазир с подградными его.",
      "paragraphStart": false
    }
  ]
}
