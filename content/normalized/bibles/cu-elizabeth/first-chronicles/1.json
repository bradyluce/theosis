{
  "chapter": {
    "id": "cu-elizabeth:first-chronicles.1",
    "translationId": "cu-elizabeth",
    "bookSlug": "first-chronicles",
    "chapterNumber": 1,
    "referenceLabel": "1 Chronicles 1",
    "summary": "Source text for 1 Chronicles 1 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:first-chronicles.1.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 1:1",
      "text": "Адам, Сиф, Енос,",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 1:2",
      "text": "Каинан, Малелеил, Иаред,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 1:3",
      "text": "Енох, Мафусал, Ламех,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 1:4",
      "text": "Ное, Сим, Хам, Иафеф.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 1:5",
      "text": "Сынове Иафефовы: Гамер и Магог и Мадай, Иован, Елиса и Фовел, и Мосох и Фирас.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 1:6",
      "text": "Сынове же Гамеровы: Асханаз и Рифаф и Форгама.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 1:7",
      "text": "Сынове же Иовани: Елиса и Фарсис, и Хеттим и Доданим.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 1:8",
      "text": "Сынове же Хамовы: Хус и Месраим, Фуд и Ханаан.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 1:9",
      "text": "Сынове же Хусовы: Сава и Евила, и Савафа и Регма и Севефаха. Сынове же Регмановы: Сава и Дадан.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.10",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 1:10",
      "text": "Хус же роди Неврода: сей нача быти исполин ловец на земли.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.11",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 1:11",
      "text": "Месраим же роди Лодиима и Анамиима, и Лавиима и Неффосеимы,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.12",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 1:12",
      "text": "и Фафероимы и Патросониимы, и Хаслоимы, от нихже изыдоша Филистими, и Каффориимы.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.13",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 1:13",
      "text": "Ханаан же роди Сидона первенца своего и Хеттеа,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.14",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 1:14",
      "text": "и Иевусеа и Аморреа, и Гергесеа",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.15",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 1:15",
      "text": "и Евеа, и Арукеа и Асенеа,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.16",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 1:16",
      "text": "и Арадиа и Самареа и Амафиа.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.17",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 1:17",
      "text": "Сынове же Симовы: Елам и Ассур, и Арфаксад и Луд и Арам. Сынове же Арамли: Уз и Ул, и Гефер и Мосох.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.18",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 1:18",
      "text": "Арфаксад же роди Каинана, Каинан же роди Салу, Сала же роди Евера.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.19",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 1:19",
      "text": "Еверу же родистася два сына: имя единому Фалек, яко бо дни его разделена бысть земля, и имя брату его Иектан.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.20",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 1:20",
      "text": "Иектан же роди Елмодада и Салефа, и Асермофа и Иадера,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.21",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 1:21",
      "text": "и Адорама и Узала, и Деклу",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.22",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 1:22",
      "text": "и Гамаала, и Авимеила и Саву,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.23",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 1:23",
      "text": "и Уфира и Евилата и Иоава: вси сии сынове Иектановы.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.24",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 1:24",
      "text": "Сынове же Симовы: Арфаксад, Каинан, Сала,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.25",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 1:25",
      "text": "Евер, Фалек, Рагав,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.26",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 1:26",
      "text": "Серух, Нахор, Фара,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.27",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 1:27",
      "text": "Аврам, той есть Авраам.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.28",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 1:28",
      "text": "Сынове же Авраамли: Исаак и Исмаил.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.29",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 1:29",
      "text": "Сии же роди их: первенец Исмаилов Наваиоф и Кидар, и Навдеил и Мавсан,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.30",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 1:30",
      "text": "и Масма и Идума, и Массий и Ходдад, и Феман",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.31",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 1:31",
      "text": "и Иетур, и Нафес и Кедма: сии суть сынове Исмаили.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.32",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 1:32",
      "text": "Сынове же Хеттуры подложницы Авраамовы, и роди ему Зомврана и Иезана, и Мадала и Мадиама, и Иесвока и Суеа. Сынове же Иезани: Сава и Дедан. Сынове же Дедановы: Рагуил и Навдеил, и Ассуриим и Латусиим и Асомин.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.33",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 1:33",
      "text": "Сынове же Мадиамли: Гефар и Офер, и Енох и Авида и Елдад: вси тии сынове Хеттурини. Роди же Авраам Исаака.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.34",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 1:34",
      "text": "Сынове же Исааковы Исав и Израиль.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.35",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 1:35",
      "text": "Сынове же Исавовы: Елифаз и Рагуил, и Иевул и Иеглом и Корей.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.36",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 1:36",
      "text": "Сынове Елифазовы: Феман и Омар, и Софар и Гофам и Кенез. Фамна же подложница Елифазова роди ему Амалика.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.37",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 1:37",
      "text": "Сынове же Рагуилевы: Нахеф и Заре, и Сомме и Мозе.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.38",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 1:38",
      "text": "Сынове же Сиировы: Лотан и Совал, и Севегон и Ана, и Дисон и Асар и Рисон.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.39",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 1:39",
      "text": "Сынове же Лотани: Хорри и Еман, и сестре Лотаня Фамна.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.40",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 1:40",
      "text": "Сынове же Совали: Адуар и Манааф, и Увал и Саифи и онан. Сынове же Севегони: Аиа и Онам.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.41",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 41,
      "referenceLabel": "1 Chronicles 1:41",
      "text": "Сынове же Анани: Дисон и Еливама, дщи Ананя, двое. Сынове же Дисоновы: Амада и Есеван, и Ефран и Харран.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.42",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 42,
      "referenceLabel": "1 Chronicles 1:42",
      "text": "Сынове же Асаровы: Валаам и Занан и Илакан, и сынове Дисони: Ос и Арран.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.43",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 43,
      "referenceLabel": "1 Chronicles 1:43",
      "text": "И сии царие их, иже царствоваша в земли Едомли, прежде неже бысть царь над сыны Израилевыми: Валак сын Веоров, и имя граду его Деннава:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.44",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 44,
      "referenceLabel": "1 Chronicles 1:44",
      "text": "умре же Валак, и царствова вместо его Иовав, сын Зарин, от Восорры.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.45",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 45,
      "referenceLabel": "1 Chronicles 1:45",
      "text": "И умре Иовав, и царствова вместо его Асом от земли Феманони.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.46",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 46,
      "referenceLabel": "1 Chronicles 1:46",
      "text": "И умре Асом, и царствова вместо его Адад, сын Варадов, иже порази Мадиама на поли Моавли: и имя граду его Гетфем.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.47",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 47,
      "referenceLabel": "1 Chronicles 1:47",
      "text": "И умре Адад, и царствова вместо его Самаа от Мессеккаса.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.48",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 48,
      "referenceLabel": "1 Chronicles 1:48",
      "text": "И умре Самаа, и царствова вместо его Саул от Роовофа, иже близ реки.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.49",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 49,
      "referenceLabel": "1 Chronicles 1:49",
      "text": "Умре же Саул, и царствова вместо его Валаеннон сын Аховоров.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.50",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 50,
      "referenceLabel": "1 Chronicles 1:50",
      "text": "И умре Валаеннон, и царствова вместо его Адад сын Варадов, егоже граду имя бе Фогор и имя жене его Метевеиль, дщерь Матраифа.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.51",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 51,
      "referenceLabel": "1 Chronicles 1:51",
      "text": "И умре Адад, и начаша быти князи Едомли: князь Феман, князь Алуа, князь Иефаф,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.52",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 52,
      "referenceLabel": "1 Chronicles 1:52",
      "text": "князь Еливама, князь Ила, князь Финон,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.53",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 53,
      "referenceLabel": "1 Chronicles 1:53",
      "text": "князь Кенез, князь Феман, князь Вамаил,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:first-chronicles.1.54",
      "translationId": "cu-elizabeth",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 54,
      "referenceLabel": "1 Chronicles 1:54",
      "text": "князь Гамесил, князь Арераман. Сии быша князи Едомстии.",
      "paragraphStart": false
    }
  ]
}
