{
  "chapter": {
    "id": "cu-elizabeth:psalms.123",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 123,
    "referenceLabel": "Psalms 123",
    "summary": "Source text for Psalms 123 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.123.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 1,
      "referenceLabel": "Psalms 123:1",
      "text": "Яко аще не Господь бы был в нас, да речет убо Израиль:",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.123.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 2,
      "referenceLabel": "Psalms 123:2",
      "text": "яко аще не Господь бы был в нас, внегда востати человеком на ны, убо живых пожерли быша нас:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.123.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 3,
      "referenceLabel": "Psalms 123:3",
      "text": "внегда прогневатися ярости их на ны, убо вода потопила бы нас.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.123.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 4,
      "referenceLabel": "Psalms 123:4",
      "text": "Поток прейде душа наша:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.123.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 5,
      "referenceLabel": "Psalms 123:5",
      "text": "убо прейде душа наша воду непостоянную.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.123.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 6,
      "referenceLabel": "Psalms 123:6",
      "text": "Благословен Господь, иже не даде нас в ловитву зубом их.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.123.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 7,
      "referenceLabel": "Psalms 123:7",
      "text": "Душа наша яко птица избавися от сети ловящих: сеть сокрушися, и мы избавлени быхом.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.123.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 8,
      "referenceLabel": "Psalms 123:8",
      "text": "Помощь наша во имя Господа, сотворшаго небо и землю.",
      "paragraphStart": false
    }
  ]
}
