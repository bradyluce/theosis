{
  "chapter": {
    "id": "cu-elizabeth:psalms.97",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 97,
    "referenceLabel": "Psalms 97",
    "summary": "Source text for Psalms 97 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.97.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 1,
      "referenceLabel": "Psalms 97:1",
      "text": "Воспойте Господеви песнь нову, яко дивна сотвори Господь: спасе Его десница Его и мышца святая Его.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.97.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 2,
      "referenceLabel": "Psalms 97:2",
      "text": "Сказа Господь спасение Свое, пред языки откры правду Свою.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.97.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 3,
      "referenceLabel": "Psalms 97:3",
      "text": "Помяну милость Свою Иакову и истину Свою дому Израилеву: видеша вси концы земли спасение Бога нашего.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.97.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 4,
      "referenceLabel": "Psalms 97:4",
      "text": "Воскликните Богови, вся земля, воспойте и радуйтеся и пойте.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.97.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 5,
      "referenceLabel": "Psalms 97:5",
      "text": "Пойте Господеви в гуслех, в гуслех и гласе псаломсте,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.97.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 6,
      "referenceLabel": "Psalms 97:6",
      "text": "в трубах кованых и гласом трубы рожаны: вострубите пред Царем Господем.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.97.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 7,
      "referenceLabel": "Psalms 97:7",
      "text": "Да подвижится море и исполнение его, вселенная и вси живущии на ней.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.97.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 8,
      "referenceLabel": "Psalms 97:8",
      "text": "Реки восплещут рукою вкупе, горы возрадуются",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.97.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 9,
      "referenceLabel": "Psalms 97:9",
      "text": "от лица Господня, яко грядет, яко идет судити земли: судити вселенней в правду, и людем правостию.",
      "paragraphStart": false
    }
  ]
}
