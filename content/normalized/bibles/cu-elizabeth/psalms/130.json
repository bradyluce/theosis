    {
      "id": "cu-elizabeth:psalms.130.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 1,
      "referenceLabel": "Psalms 130:1",
      "text": "Господи, не вознесеся сердце мое, ниже вознесостеся очи мои: ниже ходих в великих, ниже в дивных паче мене.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.130.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 2,
      "referenceLabel": "Psalms 130:2",
      "text": "Аще не смиреномудрствовах, но вознесох душу мою, яко отдоеное на матерь свою, тако воздаси на душу мою.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.130.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 3,
      "referenceLabel": "Psalms 130:3",
      "text": "Да уповает Израиль на Господа отныне и до века.",
      "paragraphStart": false
    }
  ]
}
