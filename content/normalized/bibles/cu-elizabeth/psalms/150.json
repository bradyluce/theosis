{
  "chapter": {
    "id": "cu-elizabeth:psalms.150",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 150,
    "referenceLabel": "Psalms 150",
    "summary": "Source text for Psalms 150 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.150.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 1,
      "referenceLabel": "Psalms 150:1",
      "text": "Хвалите Бога во святых Его, хвалите Его во утвержении силы Его:",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.150.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 2,
      "referenceLabel": "Psalms 150:2",
      "text": "хвалите Его на силах Его, хвалите Его по множеству величествия Его:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.150.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 3,
      "referenceLabel": "Psalms 150:3",
      "text": "хвалите Его во гласе трубнем, хвалите Его во псалтири и гуслех:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.150.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 4,
      "referenceLabel": "Psalms 150:4",
      "text": "хвалите Его в тимпане и лице, хвалите Его во струнах и органе:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.150.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 5,
      "referenceLabel": "Psalms 150:5",
      "text": "хвалите Его в кимвалех доброгласных, хвалите Его в кимвалех восклицания.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.150.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 6,
      "referenceLabel": "Psalms 150:6",
      "text": "Всякое дыхание да хвалит Господа.",
      "paragraphStart": false
    }
  ]
}
