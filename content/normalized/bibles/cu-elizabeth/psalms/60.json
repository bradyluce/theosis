{
  "chapter": {
    "id": "cu-elizabeth:psalms.60",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 60,
    "referenceLabel": "Psalms 60",
    "summary": "Source text for Psalms 60 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.60.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 1,
      "referenceLabel": "Psalms 60:1",
      "text": "В конец, в песнех, Давиду Псалом.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.60.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 2,
      "referenceLabel": "Psalms 60:2",
      "text": "Услыши, Боже, моление мое, вонми молитве моей:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.60.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 3,
      "referenceLabel": "Psalms 60:3",
      "text": "от конец земли к Тебе воззвах, внегда уны сердце мое: на камень вознесл мя еси, наставил мя еси,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.60.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 4,
      "referenceLabel": "Psalms 60:4",
      "text": "яко был еси упование мое, столп крепости от лица вражия.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.60.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 5,
      "referenceLabel": "Psalms 60:5",
      "text": "Вселюся в селении Твоем во веки, покрыюся в крове крил Твоих.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.60.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 6,
      "referenceLabel": "Psalms 60:6",
      "text": "Яко Ты, Боже, услышал еси молитвы моя, дал еси достояние боящымся имене Твоего.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.60.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 7,
      "referenceLabel": "Psalms 60:7",
      "text": "Дни на дни царевы приложиши, лета его до дне рода и рода.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.60.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 8,
      "referenceLabel": "Psalms 60:8",
      "text": "Пребудет в век пред Богом: милость и истину его кто взыщет?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.60.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 9,
      "referenceLabel": "Psalms 60:9",
      "text": "Тако воспою имени Твоему во веки, воздати ми молитвы моя день от дне.",
      "paragraphStart": false
    }
  ]
}
