{
  "chapter": {
    "id": "cu-elizabeth:psalms.121",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 121,
    "referenceLabel": "Psalms 121",
    "summary": "Source text for Psalms 121 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.121.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 1,
      "referenceLabel": "Psalms 121:1",
      "text": "Возвеселихся о рекших мне: в дом Господень пойдем.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.121.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 2,
      "referenceLabel": "Psalms 121:2",
      "text": "Стояще бяху ноги нашя во дворех твоих, Иерусалиме.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.121.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 3,
      "referenceLabel": "Psalms 121:3",
      "text": "Иерусалим зиждемый яко град, емуже причастие его вкупе.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.121.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 4,
      "referenceLabel": "Psalms 121:4",
      "text": "Тамо бо взыдоша колена, колена Господня, свидение Израилево, исповедатися имени Господню:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.121.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 5,
      "referenceLabel": "Psalms 121:5",
      "text": "яко тамо седоша престоли на суд, престоли в дому Давидове.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.121.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 6,
      "referenceLabel": "Psalms 121:6",
      "text": "Вопросите же яже о мире Иерусалима: и обилие любящым тя.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.121.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 7,
      "referenceLabel": "Psalms 121:7",
      "text": "Буди же мир в силе твоей, и обилие в столпостенах твоих.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.121.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 8,
      "referenceLabel": "Psalms 121:8",
      "text": "Ради братий моих и ближних моих глаголах убо мир о тебе.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.121.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 9,
      "referenceLabel": "Psalms 121:9",
      "text": "Дому ради Господа Бога нашего взысках благая тебе.",
      "paragraphStart": false
    }
  ]
}
