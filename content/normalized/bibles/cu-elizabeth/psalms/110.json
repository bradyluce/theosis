{
  "chapter": {
    "id": "cu-elizabeth:psalms.110",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 110,
    "referenceLabel": "Psalms 110",
    "summary": "Source text for Psalms 110 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.110.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 1,
      "referenceLabel": "Psalms 110:1",
      "text": "Исповемся Тебе, Господи, всем сердцем моим в совете правых и сонме.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.110.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 2,
      "referenceLabel": "Psalms 110:2",
      "text": "Велия дела Господня, изыскана во всех волях его:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.110.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 3,
      "referenceLabel": "Psalms 110:3",
      "text": "исповедание и великолепие дело Его, и правда Его пребывает в век века.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.110.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 4,
      "referenceLabel": "Psalms 110:4",
      "text": "Память сотворил есть чудес Своих: милостив и щедр Господь.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.110.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 5,
      "referenceLabel": "Psalms 110:5",
      "text": "Пищу даде боящымся Его: помянет в век завет Свой.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.110.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 6,
      "referenceLabel": "Psalms 110:6",
      "text": "Крепость дел Своих возвести людем Своим, дати им достояние язык.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.110.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 7,
      "referenceLabel": "Psalms 110:7",
      "text": "Дела рук Его истина и суд, верны вся заповеди Его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.110.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 8,
      "referenceLabel": "Psalms 110:8",
      "text": "утвержены в век века, сотворены во истине и правоте.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.110.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 9,
      "referenceLabel": "Psalms 110:9",
      "text": "Избавление посла людем Своим: заповеда в век завет Свой: свято и страшно имя Его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.110.10",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 10,
      "referenceLabel": "Psalms 110:10",
      "text": "Начало премудрости страх Господень, разум же благ всем творящым и: хвала Его пребывает в век века.",
      "paragraphStart": false
    }
  ]
}
