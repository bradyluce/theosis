{
  "chapter": {
    "id": "cu-elizabeth:psalms.134",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 134,
    "referenceLabel": "Psalms 134",
    "summary": "Source text for Psalms 134 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.134.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 1,
      "referenceLabel": "Psalms 134:1",
      "text": "Хвалите имя Господне, хвалите, раби Господа,",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.134.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 2,
      "referenceLabel": "Psalms 134:2",
      "text": "стоящии во храме Господни, во дворех дому Бога нашего.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.134.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 3,
      "referenceLabel": "Psalms 134:3",
      "text": "Хвалите Господа, яко благ Господь: пойте имени Его, яко добро:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.134.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 4,
      "referenceLabel": "Psalms 134:4",
      "text": "яко Иакова избра Себе Господь, Израиля в достояние Себе:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.134.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 5,
      "referenceLabel": "Psalms 134:5",
      "text": "яко аз познах, яко велий Господь, и Господь наш над всеми боги:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.134.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 6,
      "referenceLabel": "Psalms 134:6",
      "text": "вся, елика восхоте Господь, сотвори на небеси и на земли, в морях и во всех безднах.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.134.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 7,
      "referenceLabel": "Psalms 134:7",
      "text": "Возводя облаки от последних земли, молнии в дождь сотвори, изводяй ветры от сокровищ Своих.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.134.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 8,
      "referenceLabel": "Psalms 134:8",
      "text": "Иже порази первенцы Египетския от человека до скота:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.134.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 9,
      "referenceLabel": "Psalms 134:9",
      "text": "посла знамения и чудеса посреде тебе, Египте, на фараона и на вся рабы его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.134.10",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 10,
      "referenceLabel": "Psalms 134:10",
      "text": "Иже порази языки многи и изби цари крепки:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.134.11",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 11,
      "referenceLabel": "Psalms 134:11",
      "text": "Сиона царя Аморрейска и Ога царя Васанска, и вся царствия Ханаанска:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.134.12",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 12,
      "referenceLabel": "Psalms 134:12",
      "text": "и даде землю их достояние, достояние Израилю людем Своим.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.134.13",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 13,
      "referenceLabel": "Psalms 134:13",
      "text": "Господи, имя Твое в век, и память Твоя в род и род:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.134.14",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 14,
      "referenceLabel": "Psalms 134:14",
      "text": "яко судити имать Господь людем Своим, и о рабех Своих умолится.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.134.15",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 15,
      "referenceLabel": "Psalms 134:15",
      "text": "Идоли язык сребро и злато, дела рук человеческих:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.134.16",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 16,
      "referenceLabel": "Psalms 134:16",
      "text": "уста имут, и не возглаголют: очи имут, и не узрят:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.134.17",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 17,
      "referenceLabel": "Psalms 134:17",
      "text": "уши имут, и не услышат: ниже бо есть дух во устех их.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.134.18",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 18,
      "referenceLabel": "Psalms 134:18",
      "text": "Подобни им да будут творящии я и вси надеющиися на ня.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.134.19",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 19,
      "referenceLabel": "Psalms 134:19",
      "text": "Доме Израилев, благословите Господа: доме Ааронь, благословите Господа: доме Левиин, благословите Господа:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.134.20",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 20,
      "referenceLabel": "Psalms 134:20",
      "text": "боящиися Господа, благословите Господа.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.134.21",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 21,
      "referenceLabel": "Psalms 134:21",
      "text": "Благословен Господь от Сиона, живый во Иерусалиме.",
      "paragraphStart": false
    }
  ]
}
