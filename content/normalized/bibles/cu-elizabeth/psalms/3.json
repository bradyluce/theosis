{
  "chapter": {
    "id": "cu-elizabeth:psalms.3",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 3,
    "referenceLabel": "Psalms 3",
    "summary": "Source text for Psalms 3 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.3.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Psalms 3:1",
      "text": "Псалом Давиду, внегда отбегаше от лица Авессалома сына своего.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.3.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Psalms 3:2",
      "text": "Господи, что ся умножиша стужающии ми? Мнози востают на мя,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.3.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Psalms 3:3",
      "text": "мнози глаголют души моей: несть спасения ему в Бозе его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.3.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Psalms 3:4",
      "text": "Ты же, Господи, заступник мой еси, слава моя, и возносяй главу мою.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.3.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Psalms 3:5",
      "text": "Гласом моим ко Господу воззвах, и услыша мя от горы святыя Своея.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.3.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Psalms 3:6",
      "text": "Аз уснух, и спах, востах, яко Господь заступит мя.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.3.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Psalms 3:7",
      "text": "Не убоюся от тем людий, окрест нападающих на мя.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.3.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Psalms 3:8",
      "text": "Воскресени, Господи, спаси мя, Боже мой: яко Ты поразил еси вся враждующыя ми всуе, зубы грешников сокрушил еси.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.3.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Psalms 3:9",
      "text": "Господне есть спасение, и на людех Твоих благословение Твое.",
      "paragraphStart": false
    }
  ]
}
