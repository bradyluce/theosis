{
  "chapter": {
    "id": "cu-elizabeth:psalms.147",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 147,
    "referenceLabel": "Psalms 147",
    "summary": "Source text for Psalms 147 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.147.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 1,
      "referenceLabel": "Psalms 147:1",
      "text": "Похвали, Иерусалиме, Господа, хвали Бога твоего, Сионе:",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.147.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 2,
      "referenceLabel": "Psalms 147:2",
      "text": "яко укрепи вереи врат твоих, благослови сыны твоя в тебе.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.147.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 3,
      "referenceLabel": "Psalms 147:3",
      "text": "Полагаяй пределы твоя мир, и тука пшенична насыщаяй тя:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.147.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 4,
      "referenceLabel": "Psalms 147:4",
      "text": "посылаяй слово Свое земли, до скорости течет слово Его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.147.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 5,
      "referenceLabel": "Psalms 147:5",
      "text": "дающаго снег свой яко волну, мглу яко пепел посыпающаго,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.147.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 6,
      "referenceLabel": "Psalms 147:6",
      "text": "метающаго голоть Свой яко хлебы: противу лица мраза Его кто постоит?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.147.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 7,
      "referenceLabel": "Psalms 147:7",
      "text": "Послет слово Свое, и истает я: дхнет дух Его, и потекут воды.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.147.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 8,
      "referenceLabel": "Psalms 147:8",
      "text": "Возвещаяй слово Свое Иакову, оправдания и судбы Своя Израилеви:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.147.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 9,
      "referenceLabel": "Psalms 147:9",
      "text": "не сотвори тако всякому языку, и судбы Своя не яви им.",
      "paragraphStart": false
    }
  ]
}
