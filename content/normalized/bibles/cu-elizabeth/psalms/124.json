{
  "chapter": {
    "id": "cu-elizabeth:psalms.124",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 124,
    "referenceLabel": "Psalms 124",
    "summary": "Source text for Psalms 124 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.124.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 1,
      "referenceLabel": "Psalms 124:1",
      "text": "Надеющиися на Господа, яко гора Сион: не подвижится в век живый во Иерусалиме.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.124.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 2,
      "referenceLabel": "Psalms 124:2",
      "text": "Горы окрест его, и Господь окрест людий Своих, отныне и до века.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.124.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 3,
      "referenceLabel": "Psalms 124:3",
      "text": "Яко не оставит Господь жезла грешных на жребий праведных, яко да не прострут праведнии в беззакония рук своих.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.124.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 4,
      "referenceLabel": "Psalms 124:4",
      "text": "Ублажи, Господи, благия и правыя сердцем.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.124.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 5,
      "referenceLabel": "Psalms 124:5",
      "text": "Уклоняющыяся же в развращения отведет Господь с делающими беззаконие: мир на Израиля.",
      "paragraphStart": false
    }
  ]
}
