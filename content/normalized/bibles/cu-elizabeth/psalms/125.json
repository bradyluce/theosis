{
  "chapter": {
    "id": "cu-elizabeth:psalms.125",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 125,
    "referenceLabel": "Psalms 125",
    "summary": "Source text for Psalms 125 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.125.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 1,
      "referenceLabel": "Psalms 125:1",
      "text": "Внегда возвратити Господу плен Сионь, быхом яко утешени.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.125.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 2,
      "referenceLabel": "Psalms 125:2",
      "text": "Тогда исполнишася радости уста наша, и язык наш веселия: тогда рекут во языцех: возвеличил есть Господь сотворити с ними.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.125.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 3,
      "referenceLabel": "Psalms 125:3",
      "text": "Возвеличил есть Господь сотворити с нами: быхом веселящеся.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.125.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 4,
      "referenceLabel": "Psalms 125:4",
      "text": "Возврати, Господи, пленение наше, яко потоки югом.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.125.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 5,
      "referenceLabel": "Psalms 125:5",
      "text": "Сеющии слезами, радостию пожнут.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.125.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 6,
      "referenceLabel": "Psalms 125:6",
      "text": "Ходящии хождаху и плакахуся, метающе семена своя: грядуще же приидут радостию, вземлюще рукояти своя.",
      "paragraphStart": false
    }
  ]
}
