{
  "chapter": {
    "id": "cu-elizabeth:psalms.86",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 86,
    "referenceLabel": "Psalms 86",
    "summary": "Source text for Psalms 86 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.86.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 1,
      "referenceLabel": "Psalms 86:1",
      "text": "Сыном Кореовым, псалом песни.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.86.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 2,
      "referenceLabel": "Psalms 86:2",
      "text": "Основания его на горах святых: любит Господь врата Сионя паче всех селений Иаковлих.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.86.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 3,
      "referenceLabel": "Psalms 86:3",
      "text": "Преславная глаголашася о тебе, граде Божий.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.86.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 4,
      "referenceLabel": "Psalms 86:4",
      "text": "Помяну Раав и Вавилона ведущым мя: и се, иноплеменницы и Тир и людие Ефиопстии, сии быша тамо.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.86.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 5,
      "referenceLabel": "Psalms 86:5",
      "text": "Мати Сион речет: человек и человек родися в нем, и Той основа и Вышний.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.86.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 6,
      "referenceLabel": "Psalms 86:6",
      "text": "Господь повесть в писании людий и князей, сих бывших в нем.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.86.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 7,
      "referenceLabel": "Psalms 86:7",
      "text": "Яко веселящихся всех жилище в тебе.",
      "paragraphStart": false
    }
  ]
}
