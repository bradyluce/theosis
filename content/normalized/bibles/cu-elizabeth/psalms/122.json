  "verses": [
    {
      "id": "cu-elizabeth:psalms.122.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 1,
      "referenceLabel": "Psalms 122:1",
      "text": "К Тебе возведох очи мои, Живущему на небеси.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.122.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 2,
      "referenceLabel": "Psalms 122:2",
      "text": "Се, яко очи раб в руку господий своих, яко очи рабыни в руку госпожи своея: тако очи наши ко Господу Богу нашему, дондеже ущедрит ны.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.122.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 3,
      "referenceLabel": "Psalms 122:3",
      "text": "Помилуй нас, Господи, помилуй нас, яко помногу исполнихомся уничижения:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.122.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 4,
      "referenceLabel": "Psalms 122:4",
      "text": "наипаче наполнися душа наша поношения гобзующих и уничижения гордых.",
      "paragraphStart": false
    }
  ]
}
