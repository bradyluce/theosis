{
  "chapter": {
    "id": "cu-elizabeth:psalms.128",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 128,
    "referenceLabel": "Psalms 128",
    "summary": "Source text for Psalms 128 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.128.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 1,
      "referenceLabel": "Psalms 128:1",
      "text": "Множицею брашася со мною от юности моея, да речет убо Израиль:",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.128.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 2,
      "referenceLabel": "Psalms 128:2",
      "text": "множицею брашася со мною от юности моея, ибо не премогоша мя.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.128.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 3,
      "referenceLabel": "Psalms 128:3",
      "text": "На хребте моем делаша грешницы, продолжиша беззаконие свое.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.128.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 4,
      "referenceLabel": "Psalms 128:4",
      "text": "Господь праведен ссече выя грешников.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.128.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 5,
      "referenceLabel": "Psalms 128:5",
      "text": "Да постыдятся и возвратятся вспять вси ненавидящии Сиона:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.128.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 6,
      "referenceLabel": "Psalms 128:6",
      "text": "да будут яко трава на здех, яже прежде восторжения изсше:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.128.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 7,
      "referenceLabel": "Psalms 128:7",
      "text": "еюже не исполни руки своея жняй, и недра своего рукояти собираяй:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.128.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 8,
      "referenceLabel": "Psalms 128:8",
      "text": "и не реша мимоходящии: благословение Господне на вы, благословихом вы во имя Господне.",
      "paragraphStart": false
    }
  ]
}
