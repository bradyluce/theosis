{
  "chapter": {
    "id": "cu-elizabeth:psalms.120",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 120,
    "referenceLabel": "Psalms 120",
    "summary": "Source text for Psalms 120 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.120.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 1,
      "referenceLabel": "Psalms 120:1",
      "text": "Возведох очи мои в горы, отнюдуже приидет помощь моя.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.120.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 2,
      "referenceLabel": "Psalms 120:2",
      "text": "Помощь моя от Господа, сотворшаго небо и землю.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.120.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 3,
      "referenceLabel": "Psalms 120:3",
      "text": "Не даждь во смятение ноги твоея, ниже воздремлет храняй тя:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.120.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 4,
      "referenceLabel": "Psalms 120:4",
      "text": "се, не воздремлет, ниже уснет храняй Израиля.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.120.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 5,
      "referenceLabel": "Psalms 120:5",
      "text": "Господь сохранит тя, Господь покров твой на руку десную твою.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.120.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 6,
      "referenceLabel": "Psalms 120:6",
      "text": "Во дни солнце не ожжет тебе, ниже луна нощию.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.120.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 7,
      "referenceLabel": "Psalms 120:7",
      "text": "Господь сохранит тя от всякаго зла, сохранит душу твою Господь:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.120.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 8,
      "referenceLabel": "Psalms 120:8",
      "text": "Господь сохранит вхождение твое и исхождение твое, отныне и до века.",
      "paragraphStart": false
    }
  ]
}
