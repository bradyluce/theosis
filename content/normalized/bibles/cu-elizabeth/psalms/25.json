{
  "chapter": {
    "id": "cu-elizabeth:psalms.25",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 25,
    "referenceLabel": "Psalms 25",
    "summary": "Source text for Psalms 25 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.25.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Psalms 25:1",
      "text": "Суди ми, Господи, яко аз незлобою моею ходих: и на Господа уповая не изнемогу.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.25.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Psalms 25:2",
      "text": "Искуси мя, Господи, и испытай мя, разжжи утробы моя и сердце мое.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.25.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Psalms 25:3",
      "text": "Яко милость Твоя пред очима моима есть, и благоугодих во истине Твоей.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.25.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Psalms 25:4",
      "text": "Не седох с сонмом суетным, и со законопреступными не вниду.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.25.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Psalms 25:5",
      "text": "Возненавидех церковь лукавнующих, и с нечестивыми не сяду.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.25.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Psalms 25:6",
      "text": "Умыю в неповинных руце мои, и обыду жертвенник Твой, Господи,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.25.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Psalms 25:7",
      "text": "еже услышати ми глас хвалы Твоея и поведати вся чудеса Твоя.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.25.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Psalms 25:8",
      "text": "Господи, возлюбих благолепие дому Твоего и место селения славы Твоея.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.25.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Psalms 25:9",
      "text": "Да не погубиши с нечестивыми душу мою и с мужи кровей живот мой,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.25.10",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Psalms 25:10",
      "text": "ихже в руку беззакония, десница их исполнися мзды.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.25.11",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Psalms 25:11",
      "text": "Аз же незлобою моею ходих: избави мя, Господи, и помилуй мя.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.25.12",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Psalms 25:12",
      "text": "Нога моя ста на правоте: в церквах благословлю Тя, Господи.",
      "paragraphStart": false
    }
  ]
}
