{
  "chapter": {
    "id": "cu-elizabeth:psalms.84",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 84,
    "referenceLabel": "Psalms 84",
    "summary": "Source text for Psalms 84 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.84.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 1,
      "referenceLabel": "Psalms 84:1",
      "text": "В конец, сыном Кореовым, псалом.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.84.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 2,
      "referenceLabel": "Psalms 84:2",
      "text": "Благоволил еси, Господи, землю Твою, возвратил еси плен Иаковль.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.84.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 3,
      "referenceLabel": "Psalms 84:3",
      "text": "Оставил еси беззакония людий Твоих, покрыл еси вся грехи их.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.84.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 4,
      "referenceLabel": "Psalms 84:4",
      "text": "Укротил еси весь гнев Твой, возвратился еси от гнева ярости Твоея.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.84.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 5,
      "referenceLabel": "Psalms 84:5",
      "text": "Возврати нас, Боже спасений наших, и отврати ярость Твою от нас.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.84.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 6,
      "referenceLabel": "Psalms 84:6",
      "text": "Еда во веки прогневаешися на ны? Или простреши гнев Твой от рода в род?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.84.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 7,
      "referenceLabel": "Psalms 84:7",
      "text": "Боже, Ты обращься оживиши ны, и людие Твои возвеселятся о Тебе.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.84.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 8,
      "referenceLabel": "Psalms 84:8",
      "text": "Яви нам, Господи, милость Твою, и спасение Твое даждь нам.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.84.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 9,
      "referenceLabel": "Psalms 84:9",
      "text": "Услышу, что речет о мне Господь Бог: яко речет мир на люди Своя, и на преподобныя Своя, и на обращающыя сердца к нему.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.84.10",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 10,
      "referenceLabel": "Psalms 84:10",
      "text": "Обаче близ боящихся Его спасение Его, вселити славу в землю нашу.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.84.11",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 11,
      "referenceLabel": "Psalms 84:11",
      "text": "Милость и истина сретостеся, правда и мир облобызастася:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.84.12",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 12,
      "referenceLabel": "Psalms 84:12",
      "text": "истина от земли возсия, и правда с небесе приниче:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.84.13",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 13,
      "referenceLabel": "Psalms 84:13",
      "text": "ибо Господь даст благость, и земля наша даст плод свой.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.84.14",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 14,
      "referenceLabel": "Psalms 84:14",
      "text": "Правда пред Ним предидет, и положит в путь стопы своя.",
      "paragraphStart": false
    }
  ]
}
