{
  "chapter": {
    "id": "cu-elizabeth:psalms.115",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 115,
    "referenceLabel": "Psalms 115",
    "summary": "Source text for Psalms 115 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.115.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 1,
      "referenceLabel": "Psalms 115:1",
      "text": "Веровах, темже возглаголах: аз же смирихся зело.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.115.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 2,
      "referenceLabel": "Psalms 115:2",
      "text": "Аз же рех во изступлении моем: всяк человек ложь.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.115.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 3,
      "referenceLabel": "Psalms 115:3",
      "text": "Что воздам Господеви о всех, яже воздаде ми?",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.115.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 4,
      "referenceLabel": "Psalms 115:4",
      "text": "Чашу спасения прииму и имя Господне призову:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.115.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 5,
      "referenceLabel": "Psalms 115:5",
      "text": "молитвы моя Господеви воздам пред всеми людьми Его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.115.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 6,
      "referenceLabel": "Psalms 115:6",
      "text": "Честна пред Господем смерть преподобных Его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.115.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 7,
      "referenceLabel": "Psalms 115:7",
      "text": "О, Господи, аз раб Твой, аз раб Твой и сын рабыни Твоея: растерзал еси узы моя.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.115.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 8,
      "referenceLabel": "Psalms 115:8",
      "text": "Тебе пожру жертву хвалы, и во имя Господне призову.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.115.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 9,
      "referenceLabel": "Psalms 115:9",
      "text": "Молитвы моя Господеви воздам пред всеми людьми Его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.115.10",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 10,
      "referenceLabel": "Psalms 115:10",
      "text": "во дворех дому Господня, посреде тебе, Иерусалиме.",
      "paragraphStart": false
    }
  ]
}
