{
  "chapter": {
    "id": "cu-elizabeth:psalms.149",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 149,
    "referenceLabel": "Psalms 149",
    "summary": "Source text for Psalms 149 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.149.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 1,
      "referenceLabel": "Psalms 149:1",
      "text": "Воспойте Господеви песнь нову: хваление Его в церкви преподобных.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.149.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 2,
      "referenceLabel": "Psalms 149:2",
      "text": "Да возвеселится Израиль о сотворшем его, и сынове Сиони возрадуются о Цари своем.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.149.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 3,
      "referenceLabel": "Psalms 149:3",
      "text": "Да восхвалят имя Его в лице, в тимпане и псалтири да поют Ему.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.149.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 4,
      "referenceLabel": "Psalms 149:4",
      "text": "Яко благоволит Господь в людех Своих, и вознесет кроткия во спасение.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.149.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 5,
      "referenceLabel": "Psalms 149:5",
      "text": "Восхвалятся преподобнии во славе и возрадуются на ложах своих.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.149.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 6,
      "referenceLabel": "Psalms 149:6",
      "text": "Возношения Божия в гортани их, и мечи обоюду остры в руках их:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.149.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 7,
      "referenceLabel": "Psalms 149:7",
      "text": "сотворити отмщение во языцех, обличения в людех:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.149.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 8,
      "referenceLabel": "Psalms 149:8",
      "text": "связати цари их путы, и славныя их ручными оковы железными:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.149.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 9,
      "referenceLabel": "Psalms 149:9",
      "text": "сотворити в них суд написан. Слава сия будет всем преподобным Его.",
      "paragraphStart": false
    }
  ]
}
