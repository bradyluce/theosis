{
  "chapter": {
    "id": "cu-elizabeth:psalms.112",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 112,
    "referenceLabel": "Psalms 112",
    "summary": "Source text for Psalms 112 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.112.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 1,
      "referenceLabel": "Psalms 112:1",
      "text": "Хвалите, отроцы, Господа, хвалите имя Господне.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.112.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 2,
      "referenceLabel": "Psalms 112:2",
      "text": "Буди имя Господне благословено отныне и до века.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.112.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 3,
      "referenceLabel": "Psalms 112:3",
      "text": "От восток солнца до запад хвально имя Господне.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.112.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 4,
      "referenceLabel": "Psalms 112:4",
      "text": "Высок над всеми языки Господь: над небесы слава Его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.112.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 5,
      "referenceLabel": "Psalms 112:5",
      "text": "Кто яко Господь Бог наш? На высоких живый,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.112.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 6,
      "referenceLabel": "Psalms 112:6",
      "text": "и на смиренныя призираяй на небеси и на земли:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.112.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 7,
      "referenceLabel": "Psalms 112:7",
      "text": "воздвизаяй от земли нища, и от гноища возвышаяй убога:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.112.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 8,
      "referenceLabel": "Psalms 112:8",
      "text": "посадити его с князи, с князи людий своих:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.112.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 9,
      "referenceLabel": "Psalms 112:9",
      "text": "вселяя неплодовь в дом, матерь о чадех веселящуся.",
      "paragraphStart": false
    }
  ]
}
