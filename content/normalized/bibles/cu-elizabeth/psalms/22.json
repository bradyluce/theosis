{
  "chapter": {
    "id": "cu-elizabeth:psalms.22",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 22,
    "referenceLabel": "Psalms 22",
    "summary": "Source text for Psalms 22 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.22.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Psalms 22:1",
      "text": "Господь пасет мя, и ничтоже мя лишит.",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.22.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Psalms 22:2",
      "text": "На месте злачне, тамо всели мя, на воде покойне воспита мя.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.22.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Psalms 22:3",
      "text": "Душу мою обрати, настави мя на стези правды, имене ради Своего.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.22.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Psalms 22:4",
      "text": "Аще бо и пойду посреде сени смертныя, не убоюся зла, яко Ты со мною еси: жезл Твой и палица Твоя, та мя утешиста.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.22.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Psalms 22:5",
      "text": "Уготовал еси предо мною трапезу сопротив стужающым мне: умастил еси елеом главу мою, и чаша твоя упоявающи мя, яко державна.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.22.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Psalms 22:6",
      "text": "И милость Твоя поженет мя вся дни живота моего, и еже вселитимися в дом Господень в долготу дний.",
      "paragraphStart": false
    }
  ]
}
