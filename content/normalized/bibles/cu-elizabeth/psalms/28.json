{
  "chapter": {
    "id": "cu-elizabeth:psalms.28",
    "translationId": "cu-elizabeth",
    "bookSlug": "psalms",
    "chapterNumber": 28,
    "referenceLabel": "Psalms 28",
    "summary": "Source text for Psalms 28 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:psalms.28.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Psalms 28:1",
      "text": "Принесите Господеви, сынове Божии, принесите Господеви сыны овни, принесите Господеви славу и честь:",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:psalms.28.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Psalms 28:2",
      "text": "принесите Господеви славу имени Его: поклонитеся Господеви во дворе святем Его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.28.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Psalms 28:3",
      "text": "Глас Господень на водах, Бог славы возгреме, Господь на водах многих.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.28.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Psalms 28:4",
      "text": "Глас Господень в крепости, глас Господень в великолепии.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.28.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Psalms 28:5",
      "text": "Глас Господа, сокрушающаго кедры: и стрыет Господь кедры Ливанския,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.28.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Psalms 28:6",
      "text": "и истнит я яко телца Ливанска: и возлюбленный яко сын единорожь.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.28.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Psalms 28:7",
      "text": "Глас Господа, пресецающаго пламень огня.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.28.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Psalms 28:8",
      "text": "Глас Господа, стрясающаго пустыню: и стрясет Господь пустыню Каддийскую.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.28.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Psalms 28:9",
      "text": "Глас Господень, свершающий елени, и открыет дубравы: и в храме Его всякий глаголет славу.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.28.10",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Psalms 28:10",
      "text": "Господь потоп населяет, и сядет Господь царь в век.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:psalms.28.11",
      "translationId": "cu-elizabeth",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Psalms 28:11",
      "text": "Господь крепость людем Своим даст, Господь благословит люди Своя миром.",
      "paragraphStart": false
    }
  ]
}
