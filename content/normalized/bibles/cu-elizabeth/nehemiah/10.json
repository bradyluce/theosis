{
  "chapter": {
    "id": "cu-elizabeth:nehemiah.10",
    "translationId": "cu-elizabeth",
    "bookSlug": "nehemiah",
    "chapterNumber": 10,
    "referenceLabel": "Nehemiah 10",
    "summary": "Source text for Nehemiah 10 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:nehemiah.10.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Nehemiah 10:1",
      "text": "И в печатлеющих быша сии: Неемиа Артасаста сын Ахалиев и Седекиа",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:nehemiah.10.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Nehemiah 10:2",
      "text": "сын Араиев, и Азариа и Иеремиа,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Nehemiah 10:3",
      "text": "Фасур, Амариа, Мелхиа,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Nehemiah 10:4",
      "text": "Аттус, Севаниа, Маллух,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Nehemiah 10:5",
      "text": "Ирам, Мерамоф, Авдиа,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Nehemiah 10:6",
      "text": "Даниил, Ганафон, Варух,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Nehemiah 10:7",
      "text": "Месуллам, Авиа, Миамин,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Nehemiah 10:8",
      "text": "Маазиа, Велгаи, Самаиа: сии священницы.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Nehemiah 10:9",
      "text": "Левити же: Иисус сын Азариин, Ваней от сынов Инададовых, Кадмиил",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.10",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Nehemiah 10:10",
      "text": "и братия его Саваниа, Одуиа, Калитан, Фелиа, Анан,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.11",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Nehemiah 10:11",
      "text": "Миха, Роов, Асевиа,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.12",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Nehemiah 10:12",
      "text": "Закхор, Саравиа, Севаниа,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.13",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Nehemiah 10:13",
      "text": "Одуа, сынове Вануини.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.14",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Nehemiah 10:14",
      "text": "Началницы людий: Форос, Фааф-Моав, Илам, Зафуиа,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.15",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Nehemiah 10:15",
      "text": "сынове Ванниины Азгад, Вивай,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.16",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Nehemiah 10:16",
      "text": "Ананиа, Вагой, Идин,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.17",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Nehemiah 10:17",
      "text": "Атир, Езекиа, Азур,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.18",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Nehemiah 10:18",
      "text": "Одувиа, Исам, Висий,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.19",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Nehemiah 10:19",
      "text": "Ариф, Анафоф, Новай,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.20",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Nehemiah 10:20",
      "text": "Мегафис, Месуллам, Изир,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.21",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Nehemiah 10:21",
      "text": "Месозевил, Садук, Иеддуа,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.22",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Nehemiah 10:22",
      "text": "Фалтиа, Анан, Анаиа,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.23",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Nehemiah 10:23",
      "text": "Осиа, Ананиа, Асув,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.24",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Nehemiah 10:24",
      "text": "Адой, Фалаа, Совик,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.25",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Nehemiah 10:25",
      "text": "Раум, Ессавана, Маасиа",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.26",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Nehemiah 10:26",
      "text": "и Аиа, Енан, Инам,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.27",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Nehemiah 10:27",
      "text": "Малух, Ирам, Ваана.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.28",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Nehemiah 10:28",
      "text": "И прочии от людий, священницы, левити, дверницы, певцы, нафиними и всяк приходяй от людий земских ко закону Божию, жены их, сынове их, дщери их, всяк ведяй и разумеяй,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.29",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Nehemiah 10:29",
      "text": "укрепляхуся над братиею своею, и заклинаша их, и внидоша в клятву и в роту, еже ходити в законе Божии, иже дан есть рукою Моисеа раба Божия, да сотворят и сохранят вся заповеди Господни и судбы Его и повеления Его,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.30",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Nehemiah 10:30",
      "text": "и еже не дати дщерей наших людем земским, и дщерей их не возмем сыновом нашым:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.31",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Nehemiah 10:31",
      "text": "людие же земли носящии продаемая и вся купуемая во дни субботы продавати, не купим от них в субботы, ни в день святый: и оставим лето седмое, и даяние всех рук.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.32",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Nehemiah 10:32",
      "text": "И поставим над нами заповедь даяти нам третию часть дидрахмы на лето, на дело дому Бога нашего,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.33",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "Nehemiah 10:33",
      "text": "на хлебы предложения и на жертвы повседневныя, и во всесожжение присное суббот, новомесячий, в праздники и во святая, и яже о гресех, помолитися за Израиля, и на дела дому Бога нашего.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.34",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 34,
      "referenceLabel": "Nehemiah 10:34",
      "text": "И жребий метнухом о ношении древес, священницы и левити и людие, носити в дом Бога нашего, по домом отечеств наших, от времене до времене, от лета до лета возжигати на олтари Господу Богу нашему, якоже писано есть в законе,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.35",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 35,
      "referenceLabel": "Nehemiah 10:35",
      "text": "и приносити первородная земли нашея и первородная плода всякаго древа, от лета до лета, в дом Господень,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.36",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 36,
      "referenceLabel": "Nehemiah 10:36",
      "text": "и первенцы сынов наших и скотов наших, якоже писано есть в законе, и первенцы волов наших и стад наших приносити в дом Бога нашего, священником служащым в дому Бога нашего:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.37",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 37,
      "referenceLabel": "Nehemiah 10:37",
      "text": "и начатки жит наших и плод всякаго древа, вина и елеа, приносити будем священником в сокровище дому Божия, и десятину земли нашея левитом, и тии левити десятину приемлют во всех градех дел наших.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.38",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 38,
      "referenceLabel": "Nehemiah 10:38",
      "text": "Будет же священник сын Ааронов с левиты в десятинах левитов, и левити имут приносити десятую часть десятины в дом Бога нашего в сокровище дому Божия,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.10.39",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 39,
      "referenceLabel": "Nehemiah 10:39",
      "text": "яко в сокровища принесут сынове Израилевы и сынове левитстии начатки пшеницы и вина и елеа, и тамо (будут) сосуди святии, и священницы и служителие и дверницы и певцы, и не оставим дому Бога нашего.",
      "paragraphStart": false
    }
  ]
}
