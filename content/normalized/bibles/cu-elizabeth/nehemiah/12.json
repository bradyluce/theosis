{
  "chapter": {
    "id": "cu-elizabeth:nehemiah.12",
    "translationId": "cu-elizabeth",
    "bookSlug": "nehemiah",
    "chapterNumber": 12,
    "referenceLabel": "Nehemiah 12",
    "summary": "Source text for Nehemiah 12 in Church Slavonic (Elizabeth Bible)."
  },
  "verses": [
    {
      "id": "cu-elizabeth:nehemiah.12.1",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Nehemiah 12:1",
      "text": "И сии суть священницы и левити, возшедшии с Зоровавелем сыном Салафиилевым и Иисусом: Сараиа, Иеремиа, Ездра,",
      "paragraphStart": true
    },
    {
      "id": "cu-elizabeth:nehemiah.12.2",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Nehemiah 12:2",
      "text": "Амариа, Малух, Аттуй,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.3",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Nehemiah 12:3",
      "text": "Сехениа, Реум, Маримоф,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.4",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Nehemiah 12:4",
      "text": "Адаиа, Генафон, Авиа,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.5",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Nehemiah 12:5",
      "text": "Миамин, Маадиа, Велга,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.6",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Nehemiah 12:6",
      "text": "Семиа, Иоиарив, Идиа,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.7",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Nehemiah 12:7",
      "text": "Салуй, Амук Хелкиа, Одуиа: сии началницы священников и братия их во дни Иисуса.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.8",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Nehemiah 12:8",
      "text": "И левити: Иисус, Вануй, Кадмиил, Саравиа, Иодай и Матфаниа, при руках той, и братия их в чредныя служения:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.9",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Nehemiah 12:9",
      "text": "и Ваквакиа и Анай, братия их, прямо их во чреды дневныя.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.10",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Nehemiah 12:10",
      "text": "Иисус же роди Иоакима, Иоаким роди Елиасива, Елиасив роди Иодаа,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.11",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Nehemiah 12:11",
      "text": "Иодай же роди Ионафана, и Ионафан роди Адуа.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.12",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Nehemiah 12:12",
      "text": "Во дни же Иоакима беху братия его священницы и началницы отечеств: Сараии Амариа, Иеремии Ананиа,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.13",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Nehemiah 12:13",
      "text": "Ездре Месуллам, Амарии Иоанан,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.14",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Nehemiah 12:14",
      "text": "Амалуху Ионафан, Сехении Иосиф,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.15",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Nehemiah 12:15",
      "text": "Аресу Еднас, Мариофу Елкей,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.16",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Nehemiah 12:16",
      "text": "Аддаю Захариа, Ганафону Месуллам,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.17",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Nehemiah 12:17",
      "text": "Авии Зехрий, Миамину Маадай, Фелетию,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.18",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Nehemiah 12:18",
      "text": "Валгасу Самуей, Семии Ионафан,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.19",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Nehemiah 12:19",
      "text": "Иоариву Матфанай, Едию Озий,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.20",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Nehemiah 12:20",
      "text": "Салаию Калаиа, Амеку Авед,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.21",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Nehemiah 12:21",
      "text": "Елкии Асавиа, Иедии Нафанаил.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.22",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Nehemiah 12:22",
      "text": "Левити во дни Елиасива, Иоада и Иоа, и Иоанан и Идуа, написани началницы отечеств, и священницы в царство Дариа Персскаго.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.23",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Nehemiah 12:23",
      "text": "И сынове Левии началницы отечеств писани в книзе словес дний и даже до дний Иоанана сына Елисуева.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.24",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Nehemiah 12:24",
      "text": "И началницы левитом Асавиа и Саравиа и Иисус, и сынове Кадмииловы и братия их пред ними в песнех хвалити и исповедовати, по заповеди Давида человека Божия, по чредам от дне до дне.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.25",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Nehemiah 12:25",
      "text": "Матфаниа и Ваквакиа, Авдиа, Месуллам, Телмон, Акув, стрегущии дверницы стражу, внегда собрати ми дверники.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.26",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "Nehemiah 12:26",
      "text": "Во дни Иоакима сына Иисусова, сына Иоседекова, и во дни Неемии и Ездры священника и книгочии,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.27",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "Nehemiah 12:27",
      "text": "и во обновлении стены Иерусалимския, взыскаша левитов в местех их да возведут их во Иерусалим сотворити обновление и веселие во хвалении и песнех, в кимвалех и псалтирех и гуслех.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.28",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "Nehemiah 12:28",
      "text": "И собрашася сынове поющих и от страны окрестныя во Иерусалим, и от сел Нетофатиевых,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.29",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 29,
      "referenceLabel": "Nehemiah 12:29",
      "text": "и от Дому (Галгал) и от стран (Гева и Азмавет), яко села создаша себе певцы окрест Иерусалима:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.30",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 30,
      "referenceLabel": "Nehemiah 12:30",
      "text": "и очистишася священницы и левити, и очистиша людий и врата и стену.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.31",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 31,
      "referenceLabel": "Nehemiah 12:31",
      "text": "И возведох началников Иудиных на стену, и поставих два клироса велика, хвалы ради, и проидоша от десныя страны на стену ко вратом Гнойным.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.32",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 32,
      "referenceLabel": "Nehemiah 12:32",
      "text": "И идоша за ними Осаиа и половина началников Иудиных,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.33",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 33,
      "referenceLabel": "Nehemiah 12:33",
      "text": "и Азариа и Ездра и Месуллам,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.34",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 34,
      "referenceLabel": "Nehemiah 12:34",
      "text": "Иуда и Вениамин, и Самаиа и Иеремиа:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.35",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 35,
      "referenceLabel": "Nehemiah 12:35",
      "text": "и от сынов священничих с трубами Захариа сын Ионафанов, сын Самаии, сын Мафаниин, сын Михаин, сын Закхуров, сын Асафов,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.36",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 36,
      "referenceLabel": "Nehemiah 12:36",
      "text": "и братия его Самаиа и Озиил, Гелол, Маиа, Нафанаил и Иуда и Ананий, еже хвалити в песнех Давида человека Божия:",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.37",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 37,
      "referenceLabel": "Nehemiah 12:37",
      "text": "и Ездра книгочий пред ними при вратех Источника, хвалити прямо их. И взыдоша на лествицы града Давидова, на восход стены выше дому Давидова и даже до врат Водных к востоку.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.38",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 38,
      "referenceLabel": "Nehemiah 12:38",
      "text": "И клирос вторый хвалу воздающих идяше сопротив их, и аз по нем, и половина людий по стене, верху столпа Фануримля и даже до стены пространнейшия,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.39",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 39,
      "referenceLabel": "Nehemiah 12:39",
      "text": "и на врата Ефраима, и на врата старая, и на врата Рыбная, и на столп Анамеиль, и на столп Емаф, и даже до врат Овчих.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.40",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 40,
      "referenceLabel": "Nehemiah 12:40",
      "text": "И сташа на вратех Стражи, сташа же два клироса хваляща в дому Божии, и аз и половина воевод со мною,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.41",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 41,
      "referenceLabel": "Nehemiah 12:41",
      "text": "и священницы Елиаким, Маасиа, Миамин, Михеа, Елиона, Захариа, Ананиа с трубами,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.42",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 42,
      "referenceLabel": "Nehemiah 12:42",
      "text": "и Маасиа и Семеиа, и Елеазар и Озиа, и Иоанан и Мелхиа, и Елеамий и Иезур. И слышани быша певцы и Иезриа, и соглядани, и восхвалиша.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.43",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 43,
      "referenceLabel": "Nehemiah 12:43",
      "text": "И пожроша в день той жертвы великия и возвеселишася, яко Бог возвесели их вельми: и жены их и чада их радовахуся, и слышано бысть веселие то во Иерусалиме издалеча.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.44",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 44,
      "referenceLabel": "Nehemiah 12:44",
      "text": "И поставиша в день той мужей над сокровищными хранилищи, на начатки и десятины, и да собирают сими началниками от градов части священником и левитом, яко веселие бе во Иудеи, во священницех и в левитех предстоящих,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.45",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 45,
      "referenceLabel": "Nehemiah 12:45",
      "text": "и стрежаху стражу Бога своего, и хранение очищения, и певцев и дверников, по повелению Давида и Соломона сына его.",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.46",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 46,
      "referenceLabel": "Nehemiah 12:46",
      "text": "Яко во дни Давидовы Асаф от начала первый в певцех и в песнех и хвалении Богу,",
      "paragraphStart": false
    },
    {
      "id": "cu-elizabeth:nehemiah.12.47",
      "translationId": "cu-elizabeth",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 47,
      "referenceLabel": "Nehemiah 12:47",
      "text": "и весь Израиль во дни Зоровавеля и во дни Неемии даяху оброк певцем и дверником от дне до дне и освящаху левитом, левити же освящаху сыновом Аароним.",
      "paragraphStart": false
    }
  ]
}
