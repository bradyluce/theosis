{
  "chapter": {
    "id": "rus-synodal:proverbs.14",
    "translationId": "rus-synodal",
    "bookSlug": "proverbs",
    "chapterNumber": 14,
    "referenceLabel": "Proverbs 14",
    "summary": "Source text for Proverbs 14 in Russian Synodal Translation."
  },
  "verses": [
    {
      "id": "rus-synodal:proverbs.14.1",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 14:1",
      "text": "Мудрая жена устроит дом свой, а глупая разрушит его своими руками.",
      "paragraphStart": true
    },
    {
      "id": "rus-synodal:proverbs.14.2",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 14:2",
      "text": "Идущий прямым путем боится Господа; но чьи пути кривы, тот небрежет о Нем.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.3",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 14:3",
      "text": "В устах глупого - бич гордости; уста же мудрых охраняют их.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.4",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 14:4",
      "text": "Где нет волов, там ясли пусты; а много прибыли от силы волов.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.5",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 14:5",
      "text": "Верный свидетель не лжет, а свидетель ложный наговорит много лжи.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.6",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 14:6",
      "text": "Распутный ищет мудрости, и не находит; а для разумного знание легко.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.7",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 14:7",
      "text": "Отойди от человека глупого, у которого ты не замечаешь разумных уст.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.8",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 14:8",
      "text": "Мудрость разумного - знание пути своего, глупость же безрассудных - заблуждение.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.9",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 14:9",
      "text": "Глупые смеются над грехом, а посреди праведных - благоволение.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.10",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 14:10",
      "text": "Сердце знает горе души своей, и в радость его не вмешается чужой.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.11",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 14:11",
      "text": "Дом беззаконных разорится, а жилище праведных процветет.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.12",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 14:12",
      "text": "Есть пути, которые кажутся человеку прямыми; но конец их - путь к смерти.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.13",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 14:13",
      "text": "И при смехе иногда болит сердце, и концом радости бывает печаль.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.14",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 14:14",
      "text": "Человек с развращенным сердцем насытится от путей своих, и добрый - от своих.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.15",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 14:15",
      "text": "Глупый верит всякому слову, благоразумный же внимателен к путям своим.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.16",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 14:16",
      "text": "Мудрый боится и удаляется от зла, а глупый раздражителен и самонадеян.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.17",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 14:17",
      "text": "Вспыльчивый может сделать глупость; но человек, умышленно делающий зло, ненавистен.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.18",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 14:18",
      "text": "Невежды получают в удел себе глупость, а благоразумные увенчаются знанием.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.19",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 14:19",
      "text": "Преклонятся злые пред добрыми и нечестивые - у ворот праведника.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.20",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 14:20",
      "text": "Бедный ненавидим бывает даже близким своим, а у богатого много друзей.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.21",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 14:21",
      "text": "Кто презирает ближнего своего, тот грешит; а кто милосерд к бедным, тот блажен.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.22",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 14:22",
      "text": "Не заблуждаются ли умышляющие зло? [не знают милости и верности делающие зло;] но милость и верность у благомыслящих.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.23",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 14:23",
      "text": "От всякого труда есть прибыль, а от пустословия только ущерб.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.24",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 14:24",
      "text": "Венец мудрых - богатство их, а глупость невежд глупость и есть.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.25",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 14:25",
      "text": "Верный свидетель спасает души, а лживый наговорит много лжи.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.26",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 14:26",
      "text": "В страхе пред Господом - надежда твердая, и сынам Своим Он прибежище.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.27",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 14:27",
      "text": "Страх Господень - источник жизни, удаляющий от сетей смерти.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.28",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 14:28",
      "text": "Во множестве народа - величие царя, а при малолюдстве народа беда государю.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.29",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 14:29",
      "text": "У терпеливого человека много разума, а раздражительный выказывает глупость.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.30",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 14:30",
      "text": "Кроткое сердце - жизнь для тела, а зависть - гниль для костей.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.31",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 14:31",
      "text": "Кто теснит бедного, тот хулит Творца его; чтущий же Его благотворит нуждающемуся.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.32",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 14:32",
      "text": "За зло свое нечестивый будет отвергнут, а праведный и при смерти своей имеет надежду.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.33",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 14:33",
      "text": "Мудрость почиет в сердце разумного, и среди глупых дает знать о себе.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.34",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 14:34",
      "text": "Праведность возвышает народ, а беззаконие - бесчестие народов.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:proverbs.14.35",
      "translationId": "rus-synodal",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 14:35",
      "text": "Благоволение царя - к рабу разумному, а гнев его - против того, кто позорит его.",
      "paragraphStart": false
    }
  ]
}
