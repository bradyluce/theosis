  "verses": [
    {
      "id": "rus-synodal:job.25.1",
      "translationId": "rus-synodal",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Job 25:1",
      "text": "И отвечал Вилдад Савхеянин и сказал:",
      "paragraphStart": true
    },
    {
      "id": "rus-synodal:job.25.2",
      "translationId": "rus-synodal",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Job 25:2",
      "text": "держава и страх у Него; Он творит мир на высотах Своих!",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:job.25.3",
      "translationId": "rus-synodal",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Job 25:3",
      "text": "Есть ли счет воинствам Его? и над кем не восходит свет Его?",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:job.25.4",
      "translationId": "rus-synodal",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Job 25:4",
      "text": "И как человеку быть правым пред Богом, и как быть чистым рожденному женщиною?",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:job.25.5",
      "translationId": "rus-synodal",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Job 25:5",
      "text": "Вот даже луна, и та несветла, и звезды нечисты пред очами Его.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:job.25.6",
      "translationId": "rus-synodal",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Job 25:6",
      "text": "Тем менее человек, который есть червь, и сын человеческий, который есть моль.",
      "paragraphStart": false
    }
  ]
}
