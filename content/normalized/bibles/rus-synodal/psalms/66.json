{
  "chapter": {
    "id": "rus-synodal:psalms.66",
    "translationId": "rus-synodal",
    "bookSlug": "psalms",
    "chapterNumber": 66,
    "referenceLabel": "Psalms 66",
    "summary": "Source text for Psalms 66 in Russian Synodal Translation."
  },
  "verses": [
    {
      "id": "rus-synodal:psalms.66.1",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 1,
      "referenceLabel": "Psalms 66:1",
      "text": "Начальнику хора. На струнных орудиях. Псалом. Песнь.",
      "paragraphStart": true
    },
    {
      "id": "rus-synodal:psalms.66.2",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 2,
      "referenceLabel": "Psalms 66:2",
      "text": "Боже! будь милостив к нам и благослови нас, освети нас лицем Твоим,",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.66.3",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 3,
      "referenceLabel": "Psalms 66:3",
      "text": "дабы познали на земле путь Твой, во всех народах спасение Твое.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.66.4",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 4,
      "referenceLabel": "Psalms 66:4",
      "text": "Да восхвалят Тебя народы, Боже; да восхвалят Тебя народы все.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.66.5",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 5,
      "referenceLabel": "Psalms 66:5",
      "text": "Да веселятся и радуются племена, ибо Ты судишь народы праведно и управляешь на земле племенами.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.66.6",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 6,
      "referenceLabel": "Psalms 66:6",
      "text": "Да восхвалят Тебя народы, Боже, да восхвалят Тебя народы все.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.66.7",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 7,
      "referenceLabel": "Psalms 66:7",
      "text": "Земля дала плод свой; да благословит нас Бог, Бог наш.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.66.8",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 8,
      "referenceLabel": "Psalms 66:8",
      "text": "Да благословит нас Бог, и да убоятся Его все пределы земли.",
      "paragraphStart": false
    }
  ]
}
