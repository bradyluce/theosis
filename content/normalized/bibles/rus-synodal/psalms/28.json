{
  "chapter": {
    "id": "rus-synodal:psalms.28",
    "translationId": "rus-synodal",
    "bookSlug": "psalms",
    "chapterNumber": 28,
    "referenceLabel": "Psalms 28",
    "summary": "Source text for Psalms 28 in Russian Synodal Translation."
  },
  "verses": [
    {
      "id": "rus-synodal:psalms.28.1",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Psalms 28:1",
      "text": "Воздайте Господу, сыны Божии, воздайте Господу славу и честь,",
      "paragraphStart": true
    },
    {
      "id": "rus-synodal:psalms.28.2",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Psalms 28:2",
      "text": "воздайте Господу славу имени Его; поклонитесь Господу в благолепном святилище Его.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.28.3",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Psalms 28:3",
      "text": "Глас Господень над водами; Бог славы возгремел, Господь над водами многими.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.28.4",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Psalms 28:4",
      "text": "Глас Господа силен, глас Господа величествен.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.28.5",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Psalms 28:5",
      "text": "Глас Господа сокрушает кедры; Господь сокрушает кедры Ливанские",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.28.6",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Psalms 28:6",
      "text": "и заставляет их скакать подобно тельцу, Ливан и Сирион, подобно молодому единорогу.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.28.7",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Psalms 28:7",
      "text": "Глас Господа высекает пламень огня.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.28.8",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Psalms 28:8",
      "text": "Глас Господа потрясает пустыню; потрясает Господь пустыню Кадес.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.28.9",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Psalms 28:9",
      "text": "Глас Господа разрешает от бремени ланей и обнажает леса; и во храме Его все возвещает о Его славе.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.28.10",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Psalms 28:10",
      "text": "Господь восседал над потопом, и будет восседать Господь царем вовек.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.28.11",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Psalms 28:11",
      "text": "Господь даст силу народу Своему, Господь благословит народ Свой миром.",
      "paragraphStart": false
    }
  ]
}
