{
  "chapter": {
    "id": "rus-synodal:psalms.119",
    "translationId": "rus-synodal",
    "bookSlug": "psalms",
    "chapterNumber": 119,
    "referenceLabel": "Psalms 119",
    "summary": "Source text for Psalms 119 in Russian Synodal Translation."
  },
  "verses": [
    {
      "id": "rus-synodal:psalms.119.1",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 1,
      "referenceLabel": "Psalms 119:1",
      "text": "К Господу воззвал я в скорби моей, и Он услышал меня.",
      "paragraphStart": true
    },
    {
      "id": "rus-synodal:psalms.119.2",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 2,
      "referenceLabel": "Psalms 119:2",
      "text": "Господи! избавь душу мою от уст лживых, от языка лукавого.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.119.3",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 3,
      "referenceLabel": "Psalms 119:3",
      "text": "Что даст тебе и что прибавит тебе язык лукавый?",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.119.4",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 4,
      "referenceLabel": "Psalms 119:4",
      "text": "Изощренные стрелы сильного, с горящими углями дроковыми.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.119.5",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 5,
      "referenceLabel": "Psalms 119:5",
      "text": "Горе мне, что я пребываю у Мосоха, живу у шатров Кидарских.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.119.6",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 6,
      "referenceLabel": "Psalms 119:6",
      "text": "Долго жила душа моя с ненавидящими мир.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.119.7",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 7,
      "referenceLabel": "Psalms 119:7",
      "text": "Я мирен: но только заговорю, они - к войне.",
      "paragraphStart": false
    }
  ]
}
