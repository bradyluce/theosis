    "referenceLabel": "Psalms 92",
    "summary": "Source text for Psalms 92 in Russian Synodal Translation."
  },
  "verses": [
    {
      "id": "rus-synodal:psalms.92.1",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 1,
      "referenceLabel": "Psalms 92:1",
      "text": "Господь царствует; Он облечен величием, облечен Господь могуществом [и] препоясан: потому вселенная тверда, не подвигнется.",
      "paragraphStart": true
    },
    {
      "id": "rus-synodal:psalms.92.2",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 2,
      "referenceLabel": "Psalms 92:2",
      "text": "Престол Твой утвержден искони: Ты - от века.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.92.3",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 3,
      "referenceLabel": "Psalms 92:3",
      "text": "Возвышают реки, Господи, возвышают реки голос свой, возвышают реки волны свои.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.92.4",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 4,
      "referenceLabel": "Psalms 92:4",
      "text": "Но паче шума вод многих, сильных волн морских, силен в вышних Господь.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.92.5",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 5,
      "referenceLabel": "Psalms 92:5",
      "text": "Откровения Твои несомненно верны. Дому Твоему, Господи, принадлежит святость на долгие дни.",
      "paragraphStart": false
    }
  ]
}
