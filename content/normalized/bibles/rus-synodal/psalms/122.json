  "verses": [
    {
      "id": "rus-synodal:psalms.122.1",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 1,
      "referenceLabel": "Psalms 122:1",
      "text": "К Тебе возвожу очи мои, Живущий на небесах!",
      "paragraphStart": true
    },
    {
      "id": "rus-synodal:psalms.122.2",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 2,
      "referenceLabel": "Psalms 122:2",
      "text": "Вот, как очи рабов обращены на руку господ их, как очи рабы - на руку госпожи ее, так очи наши - к Господу, Богу нашему, доколе Он помилует нас.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.122.3",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 3,
      "referenceLabel": "Psalms 122:3",
      "text": "Помилуй нас, Господи, помилуй нас, ибо довольно мы насыщены презрением;",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.122.4",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 4,
      "referenceLabel": "Psalms 122:4",
      "text": "довольно насыщена душа наша поношением от надменных и уничижением от гордых.",
      "paragraphStart": false
    }
  ]
}
