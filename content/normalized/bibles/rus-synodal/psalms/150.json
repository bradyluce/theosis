{
  "chapter": {
    "id": "rus-synodal:psalms.150",
    "translationId": "rus-synodal",
    "bookSlug": "psalms",
    "chapterNumber": 150,
    "referenceLabel": "Psalms 150",
    "summary": "Source text for Psalms 150 in Russian Synodal Translation."
  },
  "verses": [
    {
      "id": "rus-synodal:psalms.150.1",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 1,
      "referenceLabel": "Psalms 150:1",
      "text": "Хвалите Бога во святыне Его, хвалите Его на тверди силы Его.",
      "paragraphStart": true
    },
    {
      "id": "rus-synodal:psalms.150.2",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 2,
      "referenceLabel": "Psalms 150:2",
      "text": "Хвалите Его по могуществу Его, хвалите Его по множеству величия Его.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.150.3",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 3,
      "referenceLabel": "Psalms 150:3",
      "text": "Хвалите Его со звуком трубным, хвалите Его на псалтири и гуслях.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.150.4",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 4,
      "referenceLabel": "Psalms 150:4",
      "text": "Хвалите Его с тимпаном и ликами, хвалите Его на струнах и органе.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.150.5",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 5,
      "referenceLabel": "Psalms 150:5",
      "text": "Хвалите Его на звучных кимвалах, хвалите Его на кимвалах громогласных.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.150.6",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 6,
      "referenceLabel": "Psalms 150:6",
      "text": "Все дышащее да хвалит Господа! Аллилуия.",
      "paragraphStart": false
    }
  ]
}
