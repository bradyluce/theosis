{
  "chapter": {
    "id": "rus-synodal:psalms.120",
    "translationId": "rus-synodal",
    "bookSlug": "psalms",
    "chapterNumber": 120,
    "referenceLabel": "Psalms 120",
    "summary": "Source text for Psalms 120 in Russian Synodal Translation."
  },
  "verses": [
    {
      "id": "rus-synodal:psalms.120.1",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 1,
      "referenceLabel": "Psalms 120:1",
      "text": "Возвожу очи мои к горам, откуда придет помощь моя.",
      "paragraphStart": true
    },
    {
      "id": "rus-synodal:psalms.120.2",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 2,
      "referenceLabel": "Psalms 120:2",
      "text": "Помощь моя от Господа, сотворившего небо и землю.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.120.3",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 3,
      "referenceLabel": "Psalms 120:3",
      "text": "Не даст Он поколебаться ноге твоей, не воздремлет хранящий тебя;",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.120.4",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 4,
      "referenceLabel": "Psalms 120:4",
      "text": "не дремлет и не спит хранящий Израиля.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.120.5",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 5,
      "referenceLabel": "Psalms 120:5",
      "text": "Господь - хранитель твой; Господь - сень твоя с правой руки твоей.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.120.6",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 6,
      "referenceLabel": "Psalms 120:6",
      "text": "Днем солнце не поразит тебя, ни луна ночью.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.120.7",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 7,
      "referenceLabel": "Psalms 120:7",
      "text": "Господь сохранит тебя от всякого зла; сохранит душу твою [Господь].",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:psalms.120.8",
      "translationId": "rus-synodal",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 8,
      "referenceLabel": "Psalms 120:8",
      "text": "Господь будет охранять выхождение твое и вхождение твое отныне и вовек.",
      "paragraphStart": false
    }
  ]
}
