      "translationId": "rus-synodal",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 48,
      "referenceLabel": "Numbers 7:48",
      "text": "В седьмой день начальник сынов Ефремовых Елишама, сын Аммиуда.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:numbers.7.49",
