      "id": "rus-synodal:numbers.7.58",
      "translationId": "rus-synodal",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 58,
      "referenceLabel": "Numbers 7:58",
      "text": "один козел в жертву за грех,",
      "paragraphStart": false
