      "id": "rus-synodal:numbers.7.56",
      "translationId": "rus-synodal",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 56,
      "referenceLabel": "Numbers 7:56",
      "text": "одна золотая кадильница в десять сиклей, наполненная курением,",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:numbers.7.57",
      "translationId": "rus-synodal",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 57,
      "referenceLabel": "Numbers 7:57",
      "text": "один телец, один овен, один однолетний агнец, во всесожжение,",
      "paragraphStart": false
