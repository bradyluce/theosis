{
  "chapter": {
    "id": "rus-synodal:first-chronicles.1",
    "translationId": "rus-synodal",
    "bookSlug": "first-chronicles",
    "chapterNumber": 1,
    "referenceLabel": "1 Chronicles 1",
    "summary": "Source text for 1 Chronicles 1 in Russian Synodal Translation."
  },
  "verses": [
    {
      "id": "rus-synodal:first-chronicles.1.1",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 1:1",
      "text": "Адам, Сиф, Енос,",
      "paragraphStart": true
    },
    {
      "id": "rus-synodal:first-chronicles.1.2",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 1:2",
      "text": "Каинан, Малелеил, Иаред,",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.3",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 1:3",
      "text": "Енох, Мафусал, Ламех,",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.4",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 1:4",
      "text": "Ной, Сим, Хам и Иафет.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.5",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 1:5",
      "text": "Сыновья Иафета: Гомер, Магог, Мадай, Иаван, [Елиса,] Фувал, Мешех и Фирас.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.6",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 1:6",
      "text": "Сыновья Гомера: Аскеназ, Рифат и Фогарма.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.7",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 1:7",
      "text": "Сыновья Иавана: Елиса, Фарсис, Киттим и Доданим.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.8",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 1:8",
      "text": "Сыновья Хама: Хуш, Мицраим, Фут и Ханаан.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.9",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 1:9",
      "text": "Сыновья Хуша: Сева, Хавила, Савта, Раама и Савтеха. Сыновья Раамы: Шева и Дедан.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.10",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 1:10",
      "text": "Хуш родил также Нимрода: сей начал быть сильным на земле.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.11",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 1:11",
      "text": "Мицраим родил: Лудима, Анамима, Легавима, Нафтухима,",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.12",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 1:12",
      "text": "Патрусима, Каслухима, от которого произошли Филистимляне, и Кафторима.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.13",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 1:13",
      "text": "Ханаан родил Сидона, первенца своего, Хета,",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.14",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 1:14",
      "text": "Иевусея, Аморрея, Гергесея,",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.15",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 1:15",
      "text": "Евея, Аркея, Синея,",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.16",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 1:16",
      "text": "Арвадея, Цемарея и Хамафея.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.17",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 1:17",
      "text": "Сыновья Сима: Елам, Ассур, Арфаксад, Луд и Арам. [Сыновья Арама:] Уц, Хул, Гефер и Мешех.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.18",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 1:18",
      "text": "Арфаксад [родил Каинана, Каинан же] родил Салу, Сала же родил Евера.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.19",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 1:19",
      "text": "У Евера родились два сына: имя одному Фалек, потому что во дни его разделилась земля; имя брату его Иоктан.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.20",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 1:20",
      "text": "Иоктан родил Алмодада, Шалефа, Хацармавета, Иераха,",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.21",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 1:21",
      "text": "Гадорама, Узала, Диклу,",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.22",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 1:22",
      "text": "Евала, Авимаила, Шеву,",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.23",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 1:23",
      "text": "Офира, Хавилу и Иовава. Все эти сыновья Иоктана.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.24",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 1:24",
      "text": "[Сыновья же] Симовы: Арфаксад, [Каинан,] Сала,",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.25",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 1:25",
      "text": "Евер, Фалек, Рагав,",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.26",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 1:26",
      "text": "Серух, Нахор, Фарра,",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.27",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 1:27",
      "text": "Аврам, он же Авраам.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.28",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 1:28",
      "text": "Сыновья Авраама: Исаак и Измаил.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.29",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 1:29",
      "text": "Вот родословие их: первенец Измаилов Наваиоф, за ним Кедар, Адбеел, Мивсам,",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.30",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 1:30",
      "text": "Мишма, Дума, Масса, Хадад, Фема,",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.31",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 1:31",
      "text": "Иетур, Нафиш и Кедма. Это сыновья Измаиловы.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.32",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 1:32",
      "text": "Сыновья Хеттуры, наложницы Авраамовой: она родила Зимрана, Иокшана, Медана, Мадиана, Ишбака и Шуаха. Сыновья Иокшана: Шева и Дедан. [Сыновья Дедановы: Рагуил, Навдеил, Ассуриим, Астусиим и Асомин.]",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.33",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 1:33",
      "text": "Сыновья Мадиана: Ефа, Ефер, Ханох, Авида и Елдага. Все эти сыновья Хеттуры.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.34",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 1:34",
      "text": "И родил Авраам Исаака. Сыновья Исаака: Исав и Израиль.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.35",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 1:35",
      "text": "Сыновья Исава: Елифаз, Рагуил, Иеус, Иеглом и Корей.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.36",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 1:36",
      "text": "Сыновья Елифаза: Феман, Омар, Цефо, Гафам, Кеназ; [Фимна же, наложница Елифазова, родила ему] Амалика.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.37",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 1:37",
      "text": "Сыновья Рагуила: Нахаф, Зерах, Шамма и Миза.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.38",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 1:38",
      "text": "Сыновья Сеира: Лотан, Шовал, Цивеон, Ана, Дишон, Ецер и Дишан.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.39",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 1:39",
      "text": "Сыновья Лотана: Хори и Гемам; а сестра у Лотана: Фимна.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.40",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 1:40",
      "text": "Сыновья Шовала: Алеан, Манахаф, Евал, Шефо и Онам. Сыновья Цивеона: Аиа и Ана.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.41",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 41,
      "referenceLabel": "1 Chronicles 1:41",
      "text": "Дети Аны: Дишон [и Оливема дочь Аны]. Сыновья Дишона: Хемдан, Ешбан, Ифран и Херан.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.42",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 42,
      "referenceLabel": "1 Chronicles 1:42",
      "text": "Сыновья Ецера: Билган, Зааван и Акан. Сыновья Дишана: Уц и Аран.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.43",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 43,
      "referenceLabel": "1 Chronicles 1:43",
      "text": "Сии суть цари, царствовавшие в земле Едома, прежде нежели воцарился царь над сынами Израилевыми: Бела, сын Веора, и имя городу его — Дингава;",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.44",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 44,
      "referenceLabel": "1 Chronicles 1:44",
      "text": "и умер Бела, и воцарился по нем Иовав, сын Зераха, из Восоры.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.45",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 45,
      "referenceLabel": "1 Chronicles 1:45",
      "text": "И умер Иовав, и воцарился по нем Хушам, из земли Феманитян.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.46",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 46,
      "referenceLabel": "1 Chronicles 1:46",
      "text": "И умер Хушам, и воцарился по нем Гадад, сын Бедадов, который поразил Мадианитян на поле Моава; имя городу его: Авив.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.47",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 47,
      "referenceLabel": "1 Chronicles 1:47",
      "text": "И умер Гадад, и воцарился по нем Самла, из Масреки.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.48",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 48,
      "referenceLabel": "1 Chronicles 1:48",
      "text": "И умер Самла, и воцарился по нем Саул из Реховофа, что при реке.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.49",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 49,
      "referenceLabel": "1 Chronicles 1:49",
      "text": "И умер Саул, и воцарился по нем Баал-Ханан, сын Ахбора.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.50",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 50,
      "referenceLabel": "1 Chronicles 1:50",
      "text": "И умер Баал-Ханан, и воцарился по нем Гадар; имя городу его Пау; имя жене его Мегетавеель, дочь Матреда, дочь Мезагава.",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.51",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 51,
      "referenceLabel": "1 Chronicles 1:51",
      "text": "И умер Гадар. И были старейшины у Едома: старейшина Фимна, старейшина Алва, старейшина Иетеф,",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.52",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 52,
      "referenceLabel": "1 Chronicles 1:52",
      "text": "старейшина Оливема, старейшина Эла, старейшина Пинон,",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.53",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 53,
      "referenceLabel": "1 Chronicles 1:53",
      "text": "старейшина Кеназ, старейшина Феман, старейшина Мивцар,",
      "paragraphStart": false
    },
    {
      "id": "rus-synodal:first-chronicles.1.54",
      "translationId": "rus-synodal",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 54,
      "referenceLabel": "1 Chronicles 1:54",
      "text": "старейшина Магдиил, старейшина Ирам. Вот старейшины Идумейские.",
      "paragraphStart": false
    }
  ]
}
