{
  "chapter": {
    "id": "kjva:second-corinthians.6",
    "translationId": "kjva",
    "bookSlug": "second-corinthians",
    "chapterNumber": 6,
    "referenceLabel": "2 Corinthians 6",
    "summary": "Source text for 2 Corinthians 6 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:second-corinthians.6.1",
      "translationId": "kjva",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 6:1",
      "text": "We then, as workers together with him, beseech you also that ye receive not the grace of God in vain.",
      "paragraphStart": true
    },
    {
      "id": "kjva:second-corinthians.6.2",
      "translationId": "kjva",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 6:2",
      "text": "(For he saith, I have heard thee in a time accepted, and in the day of salvation have I succoured thee: behold, now is the accepted time; behold, now is the day of salvation.)",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-corinthians.6.3",
      "translationId": "kjva",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 6:3",
      "text": "Giving no offence in any thing, that the ministry be not blamed:",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-corinthians.6.4",
      "translationId": "kjva",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 6:4",
      "text": "But in all things approving ourselves as the ministers of God, in much patience, in afflictions, in necessities, in distresses,",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-corinthians.6.5",
      "translationId": "kjva",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 6:5",
      "text": "In stripes, in imprisonments, in tumults, in labours, in watchings, in fastings;",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-corinthians.6.6",
      "translationId": "kjva",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 6:6",
      "text": "By pureness, by knowledge, by longsuffering, by kindness, by the Holy Ghost, by love unfeigned,",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-corinthians.6.7",
      "translationId": "kjva",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 6:7",
      "text": "By the word of truth, by the power of God, by the armour of righteousness on the right hand and on the left,",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-corinthians.6.8",
      "translationId": "kjva",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 6:8",
      "text": "By honour and dishonour, by evil report and good report: as deceivers, and yet true;",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-corinthians.6.9",
      "translationId": "kjva",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 6:9",
      "text": "As unknown, and yet well known; as dying, and, behold, we live; as chastened, and not killed;",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-corinthians.6.10",
      "translationId": "kjva",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 6:10",
      "text": "As sorrowful, yet alway rejoicing; as poor, yet making many rich; as having nothing, and yet possessing all things.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-corinthians.6.11",
      "translationId": "kjva",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 6:11",
      "text": "O ye Corinthians, our mouth is open unto you, our heart is enlarged.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-corinthians.6.12",
      "translationId": "kjva",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 6:12",
      "text": "Ye are not straitened in us, but ye are straitened in your own bowels.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-corinthians.6.13",
      "translationId": "kjva",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 6:13",
      "text": "Now for a recompence in the same, (I speak as unto my children,) be ye also enlarged.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-corinthians.6.14",
      "translationId": "kjva",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 6:14",
      "text": "Be ye not unequally yoked together with unbelievers: for what fellowship hath righteousness with unrighteousness? and what communion hath light with darkness?",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-corinthians.6.15",
      "translationId": "kjva",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 6:15",
      "text": "And what concord hath Christ with Belial? or what part hath he that believeth with an infidel?",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-corinthians.6.16",
      "translationId": "kjva",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 6:16",
      "text": "And what agreement hath the temple of God with idols? for ye are the temple of the living God; as God hath said, I will dwell in them, and walk in them; and I will be their God, and they shall be my people.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-corinthians.6.17",
      "translationId": "kjva",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 6:17",
      "text": "Wherefore come out from among them, and be ye separate, saith the Lord, and touch not the unclean thing; and I will receive you,",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-corinthians.6.18",
      "translationId": "kjva",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "2 Corinthians 6:18",
      "text": "And will be a Father unto you, and ye shall be my sons and daughters, saith the Lord Almighty.",
      "paragraphStart": false
    }
  ]
}
