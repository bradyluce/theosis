{
  "chapter": {
    "id": "kjva:psalms.122",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 122,
    "referenceLabel": "Psalms 122",
    "summary": "Source text for Psalms 122 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.122.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 1,
      "referenceLabel": "Psalms 122:1",
      "text": "I was glad when they said unto me, Let us go into the house of the Lord.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.122.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 2,
      "referenceLabel": "Psalms 122:2",
      "text": "Our feet shall stand within thy gates, O Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.122.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 3,
      "referenceLabel": "Psalms 122:3",
      "text": "Jerusalem is builded as a city that is compact together:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.122.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 4,
      "referenceLabel": "Psalms 122:4",
      "text": "Whither the tribes go up, the tribes of the Lord, unto the testimony of Israel, to give thanks unto the name of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.122.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 5,
      "referenceLabel": "Psalms 122:5",
      "text": "For there are set thrones of judgment, the thrones of the house of David.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.122.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 6,
      "referenceLabel": "Psalms 122:6",
      "text": "Pray for the peace of Jerusalem: they shall prosper that love thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.122.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 7,
      "referenceLabel": "Psalms 122:7",
      "text": "Peace be within thy walls, and prosperity within thy palaces.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.122.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 8,
      "referenceLabel": "Psalms 122:8",
      "text": "For my brethren and companions’ sakes, I will now say, Peace be within thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.122.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 9,
      "referenceLabel": "Psalms 122:9",
      "text": "Because of the house of the Lord our God I will seek thy good.",
      "paragraphStart": false
    }
  ]
}
