{
  "chapter": {
    "id": "kjva:psalms.113",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 113,
    "referenceLabel": "Psalms 113",
    "summary": "Source text for Psalms 113 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.113.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 1,
      "referenceLabel": "Psalms 113:1",
      "text": "Praise ye the Lord. Praise, O ye servants of the Lord, praise the name of the Lord.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.113.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 2,
      "referenceLabel": "Psalms 113:2",
      "text": "Blessed be the name of the Lord from this time forth and for evermore.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.113.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 3,
      "referenceLabel": "Psalms 113:3",
      "text": "From the rising of the sun unto the going down of the same the Lord’s name is to be praised.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.113.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 4,
      "referenceLabel": "Psalms 113:4",
      "text": "The Lord is high above all nations, and his glory above the heavens.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.113.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 5,
      "referenceLabel": "Psalms 113:5",
      "text": "Who is like unto the Lord our God, who dwelleth on high,",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.113.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 6,
      "referenceLabel": "Psalms 113:6",
      "text": "Who humbleth himself to behold the things that are in heaven, and in the earth!",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.113.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 7,
      "referenceLabel": "Psalms 113:7",
      "text": "He raiseth up the poor out of the dust, and lifteth the needy out of the dunghill;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.113.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 8,
      "referenceLabel": "Psalms 113:8",
      "text": "That he may set him with princes, even with the princes of his people.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.113.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 9,
      "referenceLabel": "Psalms 113:9",
      "text": "He maketh the barren woman to keep house, and to be a joyful mother of children. Praise ye the Lord.",
      "paragraphStart": false
    }
  ]
}
