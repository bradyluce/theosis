{
  "chapter": {
    "id": "kjva:psalms.147",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 147,
    "referenceLabel": "Psalms 147",
    "summary": "Source text for Psalms 147 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.147.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 1,
      "referenceLabel": "Psalms 147:1",
      "text": "Praise ye the Lord: for it is good to sing praises unto our God; for it is pleasant; and praise is comely.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.147.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 2,
      "referenceLabel": "Psalms 147:2",
      "text": "The Lord doth build up Jerusalem: he gathereth together the outcasts of Israel.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.147.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 3,
      "referenceLabel": "Psalms 147:3",
      "text": "He healeth the broken in heart, and bindeth up their wounds.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.147.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 4,
      "referenceLabel": "Psalms 147:4",
      "text": "He telleth the number of the stars; he calleth them all by their names.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.147.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 5,
      "referenceLabel": "Psalms 147:5",
      "text": "Great is our Lord, and of great power: his understanding is infinite.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.147.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 6,
      "referenceLabel": "Psalms 147:6",
      "text": "The Lord lifteth up the meek: he casteth the wicked down to the ground.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.147.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 7,
      "referenceLabel": "Psalms 147:7",
      "text": "Sing unto the Lord with thanksgiving; sing praise upon the harp unto our God:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.147.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 8,
      "referenceLabel": "Psalms 147:8",
      "text": "Who covereth the heaven with clouds, who prepareth rain for the earth, who maketh grass to grow upon the mountains.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.147.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 9,
      "referenceLabel": "Psalms 147:9",
      "text": "He giveth to the beast his food, and to the young ravens which cry.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.147.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 10,
      "referenceLabel": "Psalms 147:10",
      "text": "He delighteth not in the strength of the horse: he taketh not pleasure in the legs of a man.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.147.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 11,
      "referenceLabel": "Psalms 147:11",
      "text": "The Lord taketh pleasure in them that fear him, in those that hope in his mercy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.147.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 12,
      "referenceLabel": "Psalms 147:12",
      "text": "Praise the Lord, O Jerusalem; praise thy God, O Zion.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.147.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 13,
      "referenceLabel": "Psalms 147:13",
      "text": "For he hath strengthened the bars of thy gates; he hath blessed thy children within thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.147.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 14,
      "referenceLabel": "Psalms 147:14",
      "text": "He maketh peace in thy borders, and filleth thee with the finest of the wheat.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.147.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 15,
      "referenceLabel": "Psalms 147:15",
      "text": "He sendeth forth his commandment upon earth: his word runneth very swiftly.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.147.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 16,
      "referenceLabel": "Psalms 147:16",
      "text": "He giveth snow like wool: he scattereth the hoarfrost like ashes.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.147.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 17,
      "referenceLabel": "Psalms 147:17",
      "text": "He casteth forth his ice like morsels: who can stand before his cold?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.147.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 18,
      "referenceLabel": "Psalms 147:18",
      "text": "He sendeth out his word, and melteth them: he causeth his wind to blow, and the waters flow.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.147.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 19,
      "referenceLabel": "Psalms 147:19",
      "text": "He sheweth his word unto Jacob, his statutes and his judgments unto Israel.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.147.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 20,
      "referenceLabel": "Psalms 147:20",
      "text": "He hath not dealt so with any nation: and as for his judgments, they have not known them. Praise ye the Lord.",
      "paragraphStart": false
    }
  ]
}
