{
  "chapter": {
    "id": "kjva:psalms.112",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 112,
    "referenceLabel": "Psalms 112",
    "summary": "Source text for Psalms 112 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.112.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 1,
      "referenceLabel": "Psalms 112:1",
      "text": "Praise ye the Lord. Blessed is the man that feareth the Lord, that delighteth greatly in his commandments.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.112.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 2,
      "referenceLabel": "Psalms 112:2",
      "text": "His seed shall be mighty upon earth: the generation of the upright shall be blessed.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.112.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 3,
      "referenceLabel": "Psalms 112:3",
      "text": "Wealth and riches shall be in his house: and his righteousness endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.112.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 4,
      "referenceLabel": "Psalms 112:4",
      "text": "Unto the upright there ariseth light in the darkness: he is gracious, and full of compassion, and righteous.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.112.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 5,
      "referenceLabel": "Psalms 112:5",
      "text": "A good man sheweth favour, and lendeth: he will guide his affairs with discretion.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.112.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 6,
      "referenceLabel": "Psalms 112:6",
      "text": "Surely he shall not be moved for ever: the righteous shall be in everlasting remembrance.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.112.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 7,
      "referenceLabel": "Psalms 112:7",
      "text": "He shall not be afraid of evil tidings: his heart is fixed, trusting in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.112.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 8,
      "referenceLabel": "Psalms 112:8",
      "text": "His heart is established, he shall not be afraid, until he see his desire upon his enemies.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.112.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 9,
      "referenceLabel": "Psalms 112:9",
      "text": "He hath dispersed, he hath given to the poor; his righteousness endureth for ever; his horn shall be exalted with honour.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.112.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 10,
      "referenceLabel": "Psalms 112:10",
      "text": "The wicked shall see it, and be grieved; he shall gnash with his teeth, and melt away: the desire of the wicked shall perish.",
      "paragraphStart": false
    }
  ]
}
