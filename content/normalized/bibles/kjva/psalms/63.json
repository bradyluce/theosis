{
  "chapter": {
    "id": "kjva:psalms.63",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 63,
    "referenceLabel": "Psalms 63",
    "summary": "Source text for Psalms 63 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.63.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 1,
      "referenceLabel": "Psalms 63:1",
      "text": "O God, thou art my God; early will I seek thee: my soul thirsteth for thee, my flesh longeth for thee in a dry and thirsty land, where no water is;",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.63.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 2,
      "referenceLabel": "Psalms 63:2",
      "text": "To see thy power and thy glory, so as I have seen thee in the sanctuary.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.63.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 3,
      "referenceLabel": "Psalms 63:3",
      "text": "Because thy lovingkindness is better than life, my lips shall praise thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.63.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 4,
      "referenceLabel": "Psalms 63:4",
      "text": "Thus will I bless thee while I live: I will lift up my hands in thy name.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.63.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 5,
      "referenceLabel": "Psalms 63:5",
      "text": "My soul shall be satisfied as with marrow and fatness; and my mouth shall praise thee with joyful lips:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.63.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 6,
      "referenceLabel": "Psalms 63:6",
      "text": "When I remember thee upon my bed, and meditate on thee in the night watches.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.63.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 7,
      "referenceLabel": "Psalms 63:7",
      "text": "Because thou hast been my help, therefore in the shadow of thy wings will I rejoice.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.63.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 8,
      "referenceLabel": "Psalms 63:8",
      "text": "My soul followeth hard after thee: thy right hand upholdeth me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.63.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 9,
      "referenceLabel": "Psalms 63:9",
      "text": "But those that seek my soul, to destroy it, shall go into the lower parts of the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.63.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 10,
      "referenceLabel": "Psalms 63:10",
      "text": "They shall fall by the sword: they shall be a portion for foxes.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.63.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 11,
      "referenceLabel": "Psalms 63:11",
      "text": "But the king shall rejoice in God; every one that sweareth by him shall glory: but the mouth of them that speak lies shall be stopped.",
      "paragraphStart": false
    }
  ]
}
