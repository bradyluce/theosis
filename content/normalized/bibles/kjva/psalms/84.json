{
  "chapter": {
    "id": "kjva:psalms.84",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 84,
    "referenceLabel": "Psalms 84",
    "summary": "Source text for Psalms 84 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.84.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 1,
      "referenceLabel": "Psalms 84:1",
      "text": "How amiable are thy tabernacles, O Lord of hosts!",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.84.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 2,
      "referenceLabel": "Psalms 84:2",
      "text": "My soul longeth, yea, even fainteth for the courts of the Lord: my heart and my flesh crieth out for the living God.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.84.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 3,
      "referenceLabel": "Psalms 84:3",
      "text": "Yea, the sparrow hath found an house, and the swallow a nest for herself, where she may lay her young, even thine altars, O Lord of hosts, my King, and my God.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.84.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 4,
      "referenceLabel": "Psalms 84:4",
      "text": "Blessed are they that dwell in thy house: they will be still praising thee. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.84.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 5,
      "referenceLabel": "Psalms 84:5",
      "text": "Blessed is the man whose strength is in thee; in whose heart are the ways of them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.84.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 6,
      "referenceLabel": "Psalms 84:6",
      "text": "Who passing through the valley of Baca make it a well; the rain also filleth the pools.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.84.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 7,
      "referenceLabel": "Psalms 84:7",
      "text": "They go from strength to strength, every one of them in Zion appeareth before God.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.84.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 8,
      "referenceLabel": "Psalms 84:8",
      "text": "O Lord God of hosts, hear my prayer: give ear, O God of Jacob. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.84.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 9,
      "referenceLabel": "Psalms 84:9",
      "text": "Behold, O God our shield, and look upon the face of thine anointed.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.84.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 10,
      "referenceLabel": "Psalms 84:10",
      "text": "For a day in thy courts is better than a thousand. I had rather be a doorkeeper in the house of my God, than to dwell in the tents of wickedness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.84.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 11,
      "referenceLabel": "Psalms 84:11",
      "text": "For the Lord God is a sun and shield: the Lord will give grace and glory: no good thing will he withhold from them that walk uprightly.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.84.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 12,
      "referenceLabel": "Psalms 84:12",
      "text": "O Lord of hosts, blessed is the man that trusteth in thee.",
      "paragraphStart": false
    }
  ]
}
