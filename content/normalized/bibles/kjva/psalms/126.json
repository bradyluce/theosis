    "bookSlug": "psalms",
    "chapterNumber": 126,
    "referenceLabel": "Psalms 126",
    "summary": "Source text for Psalms 126 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.126.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 1,
      "referenceLabel": "Psalms 126:1",
      "text": "When the Lord turned again the captivity of Zion, we were like them that dream.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.126.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 2,
      "referenceLabel": "Psalms 126:2",
      "text": "Then was our mouth filled with laughter, and our tongue with singing: then said they among the heathen, The Lord hath done great things for them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.126.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 3,
      "referenceLabel": "Psalms 126:3",
      "text": "The Lord hath done great things for us; whereof we are glad.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.126.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 4,
      "referenceLabel": "Psalms 126:4",
      "text": "Turn again our captivity, O Lord, as the streams in the south.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.126.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 5,
      "referenceLabel": "Psalms 126:5",
      "text": "They that sow in tears shall reap in joy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.126.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 6,
      "referenceLabel": "Psalms 126:6",
      "text": "He that goeth forth and weepeth, bearing precious seed, shall doubtless come again with rejoicing, bringing his sheaves with him.",
      "paragraphStart": false
    }
  ]
}
