{
  "chapter": {
    "id": "kjva:psalms.97",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 97,
    "referenceLabel": "Psalms 97",
    "summary": "Source text for Psalms 97 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.97.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 1,
      "referenceLabel": "Psalms 97:1",
      "text": "The Lord reigneth; let the earth rejoice; let the multitude of isles be glad thereof.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.97.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 2,
      "referenceLabel": "Psalms 97:2",
      "text": "Clouds and darkness are round about him: righteousness and judgment are the habitation of his throne.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.97.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 3,
      "referenceLabel": "Psalms 97:3",
      "text": "A fire goeth before him, and burneth up his enemies round about.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.97.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 4,
      "referenceLabel": "Psalms 97:4",
      "text": "His lightnings enlightened the world: the earth saw, and trembled.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.97.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 5,
      "referenceLabel": "Psalms 97:5",
      "text": "The hills melted like wax at the presence of the Lord, at the presence of the Lord of the whole earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.97.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 6,
      "referenceLabel": "Psalms 97:6",
      "text": "The heavens declare his righteousness, and all the people see his glory.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.97.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 7,
      "referenceLabel": "Psalms 97:7",
      "text": "Confounded be all they that serve graven images, that boast themselves of idols: worship him, all ye gods.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.97.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 8,
      "referenceLabel": "Psalms 97:8",
      "text": "Zion heard, and was glad; and the daughters of Judah rejoiced because of thy judgments, O Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.97.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 9,
      "referenceLabel": "Psalms 97:9",
      "text": "For thou, Lord, art high above all the earth: thou art exalted far above all gods.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.97.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 10,
      "referenceLabel": "Psalms 97:10",
      "text": "Ye that love the Lord, hate evil: he preserveth the souls of his saints; he delivereth them out of the hand of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.97.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 11,
      "referenceLabel": "Psalms 97:11",
      "text": "Light is sown for the righteous, and gladness for the upright in heart.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.97.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 12,
      "referenceLabel": "Psalms 97:12",
      "text": "Rejoice in the Lord, ye righteous; and give thanks at the remembrance of his holiness.",
      "paragraphStart": false
    }
  ]
}
