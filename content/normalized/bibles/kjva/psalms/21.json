{
  "chapter": {
    "id": "kjva:psalms.21",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 21,
    "referenceLabel": "Psalms 21",
    "summary": "Source text for Psalms 21 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.21.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Psalms 21:1",
      "text": "The king shall joy in thy strength, O Lord; and in thy salvation how greatly shall he rejoice!",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.21.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Psalms 21:2",
      "text": "Thou hast given him his heart’s desire, and hast not withholden the request of his lips. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.21.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Psalms 21:3",
      "text": "For thou preventest him with the blessings of goodness: thou settest a crown of pure gold on his head.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.21.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Psalms 21:4",
      "text": "He asked life of thee, and thou gavest it him, even length of days for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.21.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Psalms 21:5",
      "text": "His glory is great in thy salvation: honour and majesty hast thou laid upon him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.21.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Psalms 21:6",
      "text": "For thou hast made him most blessed for ever: thou hast made him exceeding glad with thy countenance.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.21.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Psalms 21:7",
      "text": "For the king trusteth in the Lord, and through the mercy of the most High he shall not be moved.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.21.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Psalms 21:8",
      "text": "Thine hand shall find out all thine enemies: thy right hand shall find out those that hate thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.21.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Psalms 21:9",
      "text": "Thou shalt make them as a fiery oven in the time of thine anger: the Lord shall swallow them up in his wrath, and the fire shall devour them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.21.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Psalms 21:10",
      "text": "Their fruit shalt thou destroy from the earth, and their seed from among the children of men.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.21.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Psalms 21:11",
      "text": "For they intended evil against thee: they imagined a mischievous device, which they are not able to perform.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.21.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Psalms 21:12",
      "text": "Therefore shalt thou make them turn their back, when thou shalt make ready thine arrows upon thy strings against the face of them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.21.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Psalms 21:13",
      "text": "Be thou exalted, Lord, in thine own strength: so will we sing and praise thy power.",
      "paragraphStart": false
    }
  ]
}
