{
  "chapter": {
    "id": "kjva:psalms.116",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 116,
    "referenceLabel": "Psalms 116",
    "summary": "Source text for Psalms 116 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.116.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 1,
      "referenceLabel": "Psalms 116:1",
      "text": "I love the Lord, because he hath heard my voice and my supplications.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.116.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 2,
      "referenceLabel": "Psalms 116:2",
      "text": "Because he hath inclined his ear unto me, therefore will I call upon him as long as I live.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.116.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 3,
      "referenceLabel": "Psalms 116:3",
      "text": "The sorrows of death compassed me, and the pains of hell gat hold upon me: I found trouble and sorrow.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.116.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 4,
      "referenceLabel": "Psalms 116:4",
      "text": "Then called I upon the name of the Lord; O Lord, I beseech thee, deliver my soul.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.116.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 5,
      "referenceLabel": "Psalms 116:5",
      "text": "Gracious is the Lord, and righteous; yea, our God is merciful.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.116.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 6,
      "referenceLabel": "Psalms 116:6",
      "text": "The Lord preserveth the simple: I was brought low, and he helped me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.116.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 7,
      "referenceLabel": "Psalms 116:7",
      "text": "Return unto thy rest, O my soul; for the Lord hath dealt bountifully with thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.116.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 8,
      "referenceLabel": "Psalms 116:8",
      "text": "For thou hast delivered my soul from death, mine eyes from tears, and my feet from falling.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.116.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 9,
      "referenceLabel": "Psalms 116:9",
      "text": "I will walk before the Lord in the land of the living.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.116.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 10,
      "referenceLabel": "Psalms 116:10",
      "text": "I believed, therefore have I spoken: I was greatly afflicted:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.116.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 11,
      "referenceLabel": "Psalms 116:11",
      "text": "I said in my haste, All men are liars.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.116.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 12,
      "referenceLabel": "Psalms 116:12",
      "text": "What shall I render unto the Lord for all his benefits toward me?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.116.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 13,
      "referenceLabel": "Psalms 116:13",
      "text": "I will take the cup of salvation, and call upon the name of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.116.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 14,
      "referenceLabel": "Psalms 116:14",
      "text": "I will pay my vows unto the Lord now in the presence of all his people.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.116.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 15,
      "referenceLabel": "Psalms 116:15",
      "text": "Precious in the sight of the Lord is the death of his saints.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.116.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 16,
      "referenceLabel": "Psalms 116:16",
      "text": "O Lord, truly I am thy servant; I am thy servant, and the son of thine handmaid: thou hast loosed my bonds.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.116.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 17,
      "referenceLabel": "Psalms 116:17",
      "text": "I will offer to thee the sacrifice of thanksgiving, and will call upon the name of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.116.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 18,
      "referenceLabel": "Psalms 116:18",
      "text": "I will pay my vows unto the Lord now in the presence of all his people,",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.116.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 19,
      "referenceLabel": "Psalms 116:19",
      "text": "In the courts of the Lord’s house, in the midst of thee, O Jerusalem. Praise ye the Lord.",
      "paragraphStart": false
    }
  ]
}
