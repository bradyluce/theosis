{
  "chapter": {
    "id": "kjva:psalms.26",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 26,
    "referenceLabel": "Psalms 26",
    "summary": "Source text for Psalms 26 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.26.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Psalms 26:1",
      "text": "Judge me, O Lord; for I have walked in mine integrity: I have trusted also in the Lord; therefore I shall not slide.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.26.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Psalms 26:2",
      "text": "Examine me, O Lord, and prove me; try my reins and my heart.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.26.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Psalms 26:3",
      "text": "For thy lovingkindness is before mine eyes: and I have walked in thy truth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.26.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Psalms 26:4",
      "text": "I have not sat with vain persons, neither will I go in with dissemblers.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.26.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Psalms 26:5",
      "text": "I have hated the congregation of evil doers; and will not sit with the wicked.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.26.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Psalms 26:6",
      "text": "I will wash mine hands in innocency: so will I compass thine altar, O Lord:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.26.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Psalms 26:7",
      "text": "That I may publish with the voice of thanksgiving, and tell of all thy wondrous works.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.26.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Psalms 26:8",
      "text": "Lord, I have loved the habitation of thy house, and the place where thine honour dwelleth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.26.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Psalms 26:9",
      "text": "Gather not my soul with sinners, nor my life with bloody men:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.26.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Psalms 26:10",
      "text": "In whose hands is mischief, and their right hand is full of bribes.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.26.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Psalms 26:11",
      "text": "But as for me, I will walk in mine integrity: redeem me, and be merciful unto me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.26.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Psalms 26:12",
      "text": "My foot standeth in an even place: in the congregations will I bless the Lord.",
      "paragraphStart": false
    }
  ]
}
