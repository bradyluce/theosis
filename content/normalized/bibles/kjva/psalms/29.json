{
  "chapter": {
    "id": "kjva:psalms.29",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 29,
    "referenceLabel": "Psalms 29",
    "summary": "Source text for Psalms 29 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.29.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Psalms 29:1",
      "text": "Give unto the Lord, O ye mighty, give unto the Lord glory and strength.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.29.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Psalms 29:2",
      "text": "Give unto the Lord the glory due unto his name; worship the Lord in the beauty of holiness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.29.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Psalms 29:3",
      "text": "The voice of the Lord is upon the waters: the God of glory thundereth: the Lord is upon many waters.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.29.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Psalms 29:4",
      "text": "The voice of the Lord is powerful; the voice of the Lord is full of majesty.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.29.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Psalms 29:5",
      "text": "The voice of the Lord breaketh the cedars; yea, the Lord breaketh the cedars of Lebanon.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.29.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Psalms 29:6",
      "text": "He maketh them also to skip like a calf; Lebanon and Sirion like a young unicorn.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.29.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Psalms 29:7",
      "text": "The voice of the Lord divideth the flames of fire.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.29.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Psalms 29:8",
      "text": "The voice of the Lord shaketh the wilderness; the Lord shaketh the wilderness of Kadesh.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.29.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Psalms 29:9",
      "text": "The voice of the Lord maketh the hinds to calve, and discovereth the forests: and in his temple doth every one speak of his glory.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.29.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Psalms 29:10",
      "text": "The Lord sitteth upon the flood; yea, the Lord sitteth King for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.29.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Psalms 29:11",
      "text": "The Lord will give strength unto his people; the Lord will bless his people with peace.",
      "paragraphStart": false
    }
  ]
}
