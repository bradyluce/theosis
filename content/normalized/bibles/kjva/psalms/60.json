{
  "chapter": {
    "id": "kjva:psalms.60",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 60,
    "referenceLabel": "Psalms 60",
    "summary": "Source text for Psalms 60 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.60.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 1,
      "referenceLabel": "Psalms 60:1",
      "text": "O God, thou hast cast us off, thou hast scattered us, thou hast been displeased; O turn thyself to us again.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.60.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 2,
      "referenceLabel": "Psalms 60:2",
      "text": "Thou hast made the earth to tremble; thou hast broken it: heal the breaches thereof; for it shaketh.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.60.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 3,
      "referenceLabel": "Psalms 60:3",
      "text": "Thou hast shewed thy people hard things: thou hast made us to drink the wine of astonishment.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.60.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 4,
      "referenceLabel": "Psalms 60:4",
      "text": "Thou hast given a banner to them that fear thee, that it may be displayed because of the truth. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.60.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 5,
      "referenceLabel": "Psalms 60:5",
      "text": "That thy beloved may be delivered; save with thy right hand, and hear me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.60.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 6,
      "referenceLabel": "Psalms 60:6",
      "text": "God hath spoken in his holiness; I will rejoice, I will divide Shechem, and mete out the valley of Succoth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.60.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 7,
      "referenceLabel": "Psalms 60:7",
      "text": "Gilead is mine, and Manasseh is mine; Ephraim also is the strength of mine head; Judah is my lawgiver;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.60.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 8,
      "referenceLabel": "Psalms 60:8",
      "text": "Moab is my washpot; over Edom will I cast out my shoe: Philistia, triumph thou because of me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.60.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 9,
      "referenceLabel": "Psalms 60:9",
      "text": "Who will bring me into the strong city? who will lead me into Edom?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.60.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 10,
      "referenceLabel": "Psalms 60:10",
      "text": "Wilt not thou, O God, which hadst cast us off? and thou, O God, which didst not go out with our armies?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.60.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 11,
      "referenceLabel": "Psalms 60:11",
      "text": "Give us help from trouble: for vain is the help of man.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.60.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 12,
      "referenceLabel": "Psalms 60:12",
      "text": "Through God we shall do valiantly: for he it is that shall tread down our enemies.",
      "paragraphStart": false
    }
  ]
}
