{
  "chapter": {
    "id": "kjva:psalms.33",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 33,
    "referenceLabel": "Psalms 33",
    "summary": "Source text for Psalms 33 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.33.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 1,
      "referenceLabel": "Psalms 33:1",
      "text": "Rejoice in the Lord, O ye righteous: for praise is comely for the upright.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.33.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 2,
      "referenceLabel": "Psalms 33:2",
      "text": "Praise the Lord with harp: sing unto him with the psaltery and an instrument of ten strings.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 3,
      "referenceLabel": "Psalms 33:3",
      "text": "Sing unto him a new song; play skilfully with a loud noise.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 4,
      "referenceLabel": "Psalms 33:4",
      "text": "For the word of the Lord is right; and all his works are done in truth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 5,
      "referenceLabel": "Psalms 33:5",
      "text": "He loveth righteousness and judgment: the earth is full of the goodness of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 6,
      "referenceLabel": "Psalms 33:6",
      "text": "By the word of the Lord were the heavens made; and all the host of them by the breath of his mouth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 7,
      "referenceLabel": "Psalms 33:7",
      "text": "He gathereth the waters of the sea together as an heap: he layeth up the depth in storehouses.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 8,
      "referenceLabel": "Psalms 33:8",
      "text": "Let all the earth fear the Lord: let all the inhabitants of the world stand in awe of him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 9,
      "referenceLabel": "Psalms 33:9",
      "text": "For he spake, and it was done; he commanded, and it stood fast.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 10,
      "referenceLabel": "Psalms 33:10",
      "text": "The Lord bringeth the counsel of the heathen to nought: he maketh the devices of the people of none effect.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 11,
      "referenceLabel": "Psalms 33:11",
      "text": "The counsel of the Lord standeth for ever, the thoughts of his heart to all generations.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 12,
      "referenceLabel": "Psalms 33:12",
      "text": "Blessed is the nation whose God is the Lord; and the people whom he hath chosen for his own inheritance.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 13,
      "referenceLabel": "Psalms 33:13",
      "text": "The Lord looketh from heaven; he beholdeth all the sons of men.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 14,
      "referenceLabel": "Psalms 33:14",
      "text": "From the place of his habitation he looketh upon all the inhabitants of the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 15,
      "referenceLabel": "Psalms 33:15",
      "text": "He fashioneth their hearts alike; he considereth all their works.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 16,
      "referenceLabel": "Psalms 33:16",
      "text": "There is no king saved by the multitude of an host: a mighty man is not delivered by much strength.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 17,
      "referenceLabel": "Psalms 33:17",
      "text": "An horse is a vain thing for safety: neither shall he deliver any by his great strength.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 18,
      "referenceLabel": "Psalms 33:18",
      "text": "Behold, the eye of the Lord is upon them that fear him, upon them that hope in his mercy;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 19,
      "referenceLabel": "Psalms 33:19",
      "text": "To deliver their soul from death, and to keep them alive in famine.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 20,
      "referenceLabel": "Psalms 33:20",
      "text": "Our soul waiteth for the Lord: he is our help and our shield.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 21,
      "referenceLabel": "Psalms 33:21",
      "text": "For our heart shall rejoice in him, because we have trusted in his holy name.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.33.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 22,
      "referenceLabel": "Psalms 33:22",
      "text": "Let thy mercy, O Lord, be upon us, according as we hope in thee.",
      "paragraphStart": false
    }
  ]
}
