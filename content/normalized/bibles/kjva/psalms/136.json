{
  "chapter": {
    "id": "kjva:psalms.136",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 136,
    "referenceLabel": "Psalms 136",
    "summary": "Source text for Psalms 136 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.136.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 1,
      "referenceLabel": "Psalms 136:1",
      "text": "O give thanks unto the Lord; for he is good: for his mercy endureth for ever.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.136.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 2,
      "referenceLabel": "Psalms 136:2",
      "text": "O give thanks unto the God of gods: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 3,
      "referenceLabel": "Psalms 136:3",
      "text": "O give thanks to the Lord of lords: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 4,
      "referenceLabel": "Psalms 136:4",
      "text": "To him who alone doeth great wonders: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 5,
      "referenceLabel": "Psalms 136:5",
      "text": "To him that by wisdom made the heavens: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 6,
      "referenceLabel": "Psalms 136:6",
      "text": "To him that stretched out the earth above the waters: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 7,
      "referenceLabel": "Psalms 136:7",
      "text": "To him that made great lights: for his mercy endureth for ever:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 8,
      "referenceLabel": "Psalms 136:8",
      "text": "The sun to rule by day: for his mercy endureth for ever:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 9,
      "referenceLabel": "Psalms 136:9",
      "text": "The moon and stars to rule by night: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 10,
      "referenceLabel": "Psalms 136:10",
      "text": "To him that smote Egypt in their firstborn: for his mercy endureth for ever:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 11,
      "referenceLabel": "Psalms 136:11",
      "text": "And brought out Israel from among them: for his mercy endureth for ever:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 12,
      "referenceLabel": "Psalms 136:12",
      "text": "With a strong hand, and with a stretched out arm: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 13,
      "referenceLabel": "Psalms 136:13",
      "text": "To him which divided the Red sea into parts: for his mercy endureth for ever:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 14,
      "referenceLabel": "Psalms 136:14",
      "text": "And made Israel to pass through the midst of it: for his mercy endureth for ever:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 15,
      "referenceLabel": "Psalms 136:15",
      "text": "But overthrew Pharaoh and his host in the Red sea: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 16,
      "referenceLabel": "Psalms 136:16",
      "text": "To him which led his people through the wilderness: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 17,
      "referenceLabel": "Psalms 136:17",
      "text": "To him which smote great kings: for his mercy endureth for ever:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 18,
      "referenceLabel": "Psalms 136:18",
      "text": "And slew famous kings: for his mercy endureth for ever:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 19,
      "referenceLabel": "Psalms 136:19",
      "text": "Sihon king of the Amorites: for his mercy endureth for ever:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 20,
      "referenceLabel": "Psalms 136:20",
      "text": "And Og the king of Bashan: for his mercy endureth for ever:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 21,
      "referenceLabel": "Psalms 136:21",
      "text": "And gave their land for an heritage: for his mercy endureth for ever:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 22,
      "referenceLabel": "Psalms 136:22",
      "text": "Even an heritage unto Israel his servant: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.23",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 23,
      "referenceLabel": "Psalms 136:23",
      "text": "Who remembered us in our low estate: for his mercy endureth for ever:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.24",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 24,
      "referenceLabel": "Psalms 136:24",
      "text": "And hath redeemed us from our enemies: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.25",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 25,
      "referenceLabel": "Psalms 136:25",
      "text": "Who giveth food to all flesh: for his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.136.26",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 26,
      "referenceLabel": "Psalms 136:26",
      "text": "O give thanks unto the God of heaven: for his mercy endureth for ever.",
      "paragraphStart": false
    }
  ]
}
