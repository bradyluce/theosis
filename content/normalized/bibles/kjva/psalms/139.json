{
  "chapter": {
    "id": "kjva:psalms.139",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 139,
    "referenceLabel": "Psalms 139",
    "summary": "Source text for Psalms 139 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.139.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 1,
      "referenceLabel": "Psalms 139:1",
      "text": "O Lord, thou hast searched me, and known me.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.139.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 2,
      "referenceLabel": "Psalms 139:2",
      "text": "Thou knowest my downsitting and mine uprising, thou understandest my thought afar off.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 3,
      "referenceLabel": "Psalms 139:3",
      "text": "Thou compassest my path and my lying down, and art acquainted with all my ways.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 4,
      "referenceLabel": "Psalms 139:4",
      "text": "For there is not a word in my tongue, but, lo, O Lord, thou knowest it altogether.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 5,
      "referenceLabel": "Psalms 139:5",
      "text": "Thou hast beset me behind and before, and laid thine hand upon me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 6,
      "referenceLabel": "Psalms 139:6",
      "text": "Such knowledge is too wonderful for me; it is high, I cannot attain unto it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 7,
      "referenceLabel": "Psalms 139:7",
      "text": "Whither shall I go from thy spirit? or whither shall I flee from thy presence?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 8,
      "referenceLabel": "Psalms 139:8",
      "text": "If I ascend up into heaven, thou art there: if I make my bed in hell, behold, thou art there.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 9,
      "referenceLabel": "Psalms 139:9",
      "text": "If I take the wings of the morning, and dwell in the uttermost parts of the sea;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 10,
      "referenceLabel": "Psalms 139:10",
      "text": "Even there shall thy hand lead me, and thy right hand shall hold me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 11,
      "referenceLabel": "Psalms 139:11",
      "text": "If I say, Surely the darkness shall cover me; even the night shall be light about me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 12,
      "referenceLabel": "Psalms 139:12",
      "text": "Yea, the darkness hideth not from thee; but the night shineth as the day: the darkness and the light are both alike to thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 13,
      "referenceLabel": "Psalms 139:13",
      "text": "For thou hast possessed my reins: thou hast covered me in my mother’s womb.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 14,
      "referenceLabel": "Psalms 139:14",
      "text": "I will praise thee; for I am fearfully and wonderfully made: marvellous are thy works; and that my soul knoweth right well.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 15,
      "referenceLabel": "Psalms 139:15",
      "text": "My substance was not hid from thee, when I was made in secret, and curiously wrought in the lowest parts of the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 16,
      "referenceLabel": "Psalms 139:16",
      "text": "Thine eyes did see my substance, yet being unperfect; and in thy book all my members were written, which in continuance were fashioned, when as yet there was none of them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 17,
      "referenceLabel": "Psalms 139:17",
      "text": "How precious also are thy thoughts unto me, O God! how great is the sum of them!",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 18,
      "referenceLabel": "Psalms 139:18",
      "text": "If I should count them, they are more in number than the sand: when I awake, I am still with thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 19,
      "referenceLabel": "Psalms 139:19",
      "text": "Surely thou wilt slay the wicked, O God: depart from me therefore, ye bloody men.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 20,
      "referenceLabel": "Psalms 139:20",
      "text": "For they speak against thee wickedly, and thine enemies take thy name in vain.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 21,
      "referenceLabel": "Psalms 139:21",
      "text": "Do not I hate them, O Lord, that hate thee? and am not I grieved with those that rise up against thee?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 22,
      "referenceLabel": "Psalms 139:22",
      "text": "I hate them with perfect hatred: I count them mine enemies.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.23",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 23,
      "referenceLabel": "Psalms 139:23",
      "text": "Search me, O God, and know my heart: try me, and know my thoughts:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.139.24",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 24,
      "referenceLabel": "Psalms 139:24",
      "text": "And see if there be any wicked way in me, and lead me in the way everlasting.",
      "paragraphStart": false
    }
  ]
}
