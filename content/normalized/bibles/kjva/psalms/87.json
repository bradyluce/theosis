{
  "chapter": {
    "id": "kjva:psalms.87",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 87,
    "referenceLabel": "Psalms 87",
    "summary": "Source text for Psalms 87 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.87.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 1,
      "referenceLabel": "Psalms 87:1",
      "text": "His foundation is in the holy mountains.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.87.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 2,
      "referenceLabel": "Psalms 87:2",
      "text": "The Lord loveth the gates of Zion more than all the dwellings of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.87.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 3,
      "referenceLabel": "Psalms 87:3",
      "text": "Glorious things are spoken of thee, O city of God. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.87.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 4,
      "referenceLabel": "Psalms 87:4",
      "text": "I will make mention of Rahab and Babylon to them that know me: behold Philistia, and Tyre, with Ethiopia; this man was born there.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.87.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 5,
      "referenceLabel": "Psalms 87:5",
      "text": "And of Zion it shall be said, This and that man was born in her: and the highest himself shall establish her.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.87.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 6,
      "referenceLabel": "Psalms 87:6",
      "text": "The Lord shall count, when he writeth up the people, that this man was born there. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.87.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 7,
      "referenceLabel": "Psalms 87:7",
      "text": "As well the singers as the players on instruments shall be there: all my springs are in thee.",
      "paragraphStart": false
    }
  ]
}
