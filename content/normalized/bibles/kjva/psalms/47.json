{
  "chapter": {
    "id": "kjva:psalms.47",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 47,
    "referenceLabel": "Psalms 47",
    "summary": "Source text for Psalms 47 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.47.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 1,
      "referenceLabel": "Psalms 47:1",
      "text": "O clap your hands, all ye people; shout unto God with the voice of triumph.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.47.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 2,
      "referenceLabel": "Psalms 47:2",
      "text": "For the Lord most high is terrible; he is a great King over all the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.47.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 3,
      "referenceLabel": "Psalms 47:3",
      "text": "He shall subdue the people under us, and the nations under our feet.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.47.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 4,
      "referenceLabel": "Psalms 47:4",
      "text": "He shall choose our inheritance for us, the excellency of Jacob whom he loved. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.47.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 5,
      "referenceLabel": "Psalms 47:5",
      "text": "God is gone up with a shout, the Lord with the sound of a trumpet.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.47.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 6,
      "referenceLabel": "Psalms 47:6",
      "text": "Sing praises to God, sing praises: sing praises unto our King, sing praises.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.47.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 7,
      "referenceLabel": "Psalms 47:7",
      "text": "For God is the King of all the earth: sing ye praises with understanding.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.47.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 8,
      "referenceLabel": "Psalms 47:8",
      "text": "God reigneth over the heathen: God sitteth upon the throne of his holiness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.47.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 9,
      "referenceLabel": "Psalms 47:9",
      "text": "The princes of the people are gathered together, even the people of the God of Abraham: for the shields of the earth belong unto God: he is greatly exalted.",
      "paragraphStart": false
    }
  ]
}
