{
  "chapter": {
    "id": "kjva:psalms.48",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 48,
    "referenceLabel": "Psalms 48",
    "summary": "Source text for Psalms 48 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.48.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 1,
      "referenceLabel": "Psalms 48:1",
      "text": "Great is the Lord, and greatly to be praised in the city of our God, in the mountain of his holiness.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.48.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 2,
      "referenceLabel": "Psalms 48:2",
      "text": "Beautiful for situation, the joy of the whole earth, is mount Zion, on the sides of the north, the city of the great King.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.48.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 3,
      "referenceLabel": "Psalms 48:3",
      "text": "God is known in her palaces for a refuge.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.48.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 4,
      "referenceLabel": "Psalms 48:4",
      "text": "For, lo, the kings were assembled, they passed by together.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.48.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 5,
      "referenceLabel": "Psalms 48:5",
      "text": "They saw it, and so they marvelled; they were troubled, and hasted away.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.48.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 6,
      "referenceLabel": "Psalms 48:6",
      "text": "Fear took hold upon them there, and pain, as of a woman in travail.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.48.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 7,
      "referenceLabel": "Psalms 48:7",
      "text": "Thou breakest the ships of Tarshish with an east wind.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.48.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 8,
      "referenceLabel": "Psalms 48:8",
      "text": "As we have heard, so have we seen in the city of the Lord of hosts, in the city of our God: God will establish it for ever. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.48.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 9,
      "referenceLabel": "Psalms 48:9",
      "text": "We have thought of thy lovingkindness, O God, in the midst of thy temple.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.48.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 10,
      "referenceLabel": "Psalms 48:10",
      "text": "According to thy name, O God, so is thy praise unto the ends of the earth: thy right hand is full of righteousness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.48.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 11,
      "referenceLabel": "Psalms 48:11",
      "text": "Let mount Zion rejoice, let the daughters of Judah be glad, because of thy judgments.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.48.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 12,
      "referenceLabel": "Psalms 48:12",
      "text": "Walk about Zion, and go round about her: tell the towers thereof.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.48.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 13,
      "referenceLabel": "Psalms 48:13",
      "text": "Mark ye well her bulwarks, consider her palaces; that ye may tell it to the generation following.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.48.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 14,
      "referenceLabel": "Psalms 48:14",
      "text": "For this God is our God for ever and ever: he will be our guide even unto death.",
      "paragraphStart": false
    }
  ]
}
