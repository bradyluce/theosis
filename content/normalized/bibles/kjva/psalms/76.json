{
  "chapter": {
    "id": "kjva:psalms.76",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 76,
    "referenceLabel": "Psalms 76",
    "summary": "Source text for Psalms 76 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.76.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 1,
      "referenceLabel": "Psalms 76:1",
      "text": "In Judah is God known: his name is great in Israel.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.76.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 2,
      "referenceLabel": "Psalms 76:2",
      "text": "In Salem also is his tabernacle, and his dwelling place in Zion.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.76.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 3,
      "referenceLabel": "Psalms 76:3",
      "text": "There brake he the arrows of the bow, the shield, and the sword, and the battle. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.76.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 4,
      "referenceLabel": "Psalms 76:4",
      "text": "Thou art more glorious and excellent than the mountains of prey.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.76.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 5,
      "referenceLabel": "Psalms 76:5",
      "text": "The stouthearted are spoiled, they have slept their sleep: and none of the men of might have found their hands.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.76.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 6,
      "referenceLabel": "Psalms 76:6",
      "text": "At thy rebuke, O God of Jacob, both the chariot and horse are cast into a dead sleep.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.76.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 7,
      "referenceLabel": "Psalms 76:7",
      "text": "Thou, even thou, art to be feared: and who may stand in thy sight when once thou art angry?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.76.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 8,
      "referenceLabel": "Psalms 76:8",
      "text": "Thou didst cause judgment to be heard from heaven; the earth feared, and was still,",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.76.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 9,
      "referenceLabel": "Psalms 76:9",
      "text": "When God arose to judgment, to save all the meek of the earth. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.76.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 10,
      "referenceLabel": "Psalms 76:10",
      "text": "Surely the wrath of man shall praise thee: the remainder of wrath shalt thou restrain.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.76.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 11,
      "referenceLabel": "Psalms 76:11",
      "text": "Vow, and pay unto the Lord your God: let all that be round about him bring presents unto him that ought to be feared.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.76.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 12,
      "referenceLabel": "Psalms 76:12",
      "text": "He shall cut off the spirit of princes: he is terrible to the kings of the earth.",
      "paragraphStart": false
    }
  ]
}
