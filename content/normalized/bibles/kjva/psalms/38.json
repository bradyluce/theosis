{
  "chapter": {
    "id": "kjva:psalms.38",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 38,
    "referenceLabel": "Psalms 38",
    "summary": "Source text for Psalms 38 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.38.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 1,
      "referenceLabel": "Psalms 38:1",
      "text": "O Lord, rebuke me not in thy wrath: neither chasten me in thy hot displeasure.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.38.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 2,
      "referenceLabel": "Psalms 38:2",
      "text": "For thine arrows stick fast in me, and thy hand presseth me sore.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 3,
      "referenceLabel": "Psalms 38:3",
      "text": "There is no soundness in my flesh because of thine anger; neither is there any rest in my bones because of my sin.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 4,
      "referenceLabel": "Psalms 38:4",
      "text": "For mine iniquities are gone over mine head: as an heavy burden they are too heavy for me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 5,
      "referenceLabel": "Psalms 38:5",
      "text": "My wounds stink and are corrupt because of my foolishness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 6,
      "referenceLabel": "Psalms 38:6",
      "text": "I am troubled; I am bowed down greatly; I go mourning all the day long.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 7,
      "referenceLabel": "Psalms 38:7",
      "text": "For my loins are filled with a loathsome disease: and there is no soundness in my flesh.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 8,
      "referenceLabel": "Psalms 38:8",
      "text": "I am feeble and sore broken: I have roared by reason of the disquietness of my heart.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 9,
      "referenceLabel": "Psalms 38:9",
      "text": "Lord, all my desire is before thee; and my groaning is not hid from thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 10,
      "referenceLabel": "Psalms 38:10",
      "text": "My heart panteth, my strength faileth me: as for the light of mine eyes, it also is gone from me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 11,
      "referenceLabel": "Psalms 38:11",
      "text": "My lovers and my friends stand aloof from my sore; and my kinsmen stand afar off.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 12,
      "referenceLabel": "Psalms 38:12",
      "text": "They also that seek after my life lay snares for me: and they that seek my hurt speak mischievous things, and imagine deceits all the day long.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 13,
      "referenceLabel": "Psalms 38:13",
      "text": "But I, as a deaf man, heard not; and I was as a dumb man that openeth not his mouth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 14,
      "referenceLabel": "Psalms 38:14",
      "text": "Thus I was as a man that heareth not, and in whose mouth are no reproofs.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 15,
      "referenceLabel": "Psalms 38:15",
      "text": "For in thee, O Lord, do I hope: thou wilt hear, O Lord my God.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 16,
      "referenceLabel": "Psalms 38:16",
      "text": "For I said, Hear me, lest otherwise they should rejoice over me: when my foot slippeth, they magnify themselves against me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 17,
      "referenceLabel": "Psalms 38:17",
      "text": "For I am ready to halt, and my sorrow is continually before me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 18,
      "referenceLabel": "Psalms 38:18",
      "text": "For I will declare mine iniquity; I will be sorry for my sin.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 19,
      "referenceLabel": "Psalms 38:19",
      "text": "But mine enemies are lively, and they are strong: and they that hate me wrongfully are multiplied.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 20,
      "referenceLabel": "Psalms 38:20",
      "text": "They also that render evil for good are mine adversaries; because I follow the thing that good is.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 21,
      "referenceLabel": "Psalms 38:21",
      "text": "Forsake me not, O Lord: O my God, be not far from me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.38.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 22,
      "referenceLabel": "Psalms 38:22",
      "text": "Make haste to help me, O Lord my salvation.",
      "paragraphStart": false
    }
  ]
}
