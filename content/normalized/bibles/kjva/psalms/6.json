{
  "chapter": {
    "id": "kjva:psalms.6",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 6,
    "referenceLabel": "Psalms 6",
    "summary": "Source text for Psalms 6 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.6.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Psalms 6:1",
      "text": "O Lord, rebuke me not in thine anger, neither chasten me in thy hot displeasure.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.6.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Psalms 6:2",
      "text": "Have mercy upon me, O Lord; for I am weak: O Lord, heal me; for my bones are vexed.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.6.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Psalms 6:3",
      "text": "My soul is also sore vexed: but thou, O Lord, how long?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.6.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Psalms 6:4",
      "text": "Return, O Lord, deliver my soul: oh save me for thy mercies’ sake.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.6.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Psalms 6:5",
      "text": "For in death there is no remembrance of thee: in the grave who shall give thee thanks?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.6.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Psalms 6:6",
      "text": "I am weary with my groaning; all the night make I my bed to swim; I water my couch with my tears.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.6.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Psalms 6:7",
      "text": "Mine eye is consumed because of grief; it waxeth old because of all mine enemies.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.6.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Psalms 6:8",
      "text": "Depart from me, all ye workers of iniquity; for the Lord hath heard the voice of my weeping.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.6.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Psalms 6:9",
      "text": "The Lord hath heard my supplication; the Lord will receive my prayer.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.6.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Psalms 6:10",
      "text": "Let all mine enemies be ashamed and sore vexed: let them return and be ashamed suddenly.",
      "paragraphStart": false
    }
  ]
}
