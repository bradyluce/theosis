{
  "chapter": {
    "id": "kjva:psalms.9",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 9,
    "referenceLabel": "Psalms 9",
    "summary": "Source text for Psalms 9 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.9.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Psalms 9:1",
      "text": "I will praise thee, O Lord, with my whole heart; I will shew forth all thy marvellous works.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.9.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Psalms 9:2",
      "text": "I will be glad and rejoice in thee: I will sing praise to thy name, O thou most High.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.9.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Psalms 9:3",
      "text": "When mine enemies are turned back, they shall fall and perish at thy presence.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.9.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Psalms 9:4",
      "text": "For thou hast maintained my right and my cause; thou satest in the throne judging right.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.9.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Psalms 9:5",
      "text": "Thou hast rebuked the heathen, thou hast destroyed the wicked, thou hast put out their name for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.9.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Psalms 9:6",
      "text": "O thou enemy, destructions are come to a perpetual end: and thou hast destroyed cities; their memorial is perished with them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.9.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Psalms 9:7",
      "text": "But the Lord shall endure for ever: he hath prepared his throne for judgment.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.9.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Psalms 9:8",
      "text": "And he shall judge the world in righteousness, he shall minister judgment to the people in uprightness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.9.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Psalms 9:9",
      "text": "The Lord also will be a refuge for the oppressed, a refuge in times of trouble.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.9.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Psalms 9:10",
      "text": "And they that know thy name will put their trust in thee: for thou, Lord, hast not forsaken them that seek thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.9.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Psalms 9:11",
      "text": "Sing praises to the Lord, which dwelleth in Zion: declare among the people his doings.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.9.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Psalms 9:12",
      "text": "When he maketh inquisition for blood, he remembereth them: he forgetteth not the cry of the humble.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.9.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Psalms 9:13",
      "text": "Have mercy upon me, O Lord; consider my trouble which I suffer of them that hate me, thou that liftest me up from the gates of death:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.9.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Psalms 9:14",
      "text": "That I may shew forth all thy praise in the gates of the daughter of Zion: I will rejoice in thy salvation.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.9.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Psalms 9:15",
      "text": "The heathen are sunk down in the pit that they made: in the net which they hid is their own foot taken.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.9.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Psalms 9:16",
      "text": "The Lord is known by the judgment which he executeth: the wicked is snared in the work of his own hands. Higgaion. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.9.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Psalms 9:17",
      "text": "The wicked shall be turned into hell, and all the nations that forget God.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.9.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Psalms 9:18",
      "text": "For the needy shall not alway be forgotten: the expectation of the poor shall not perish for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.9.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Psalms 9:19",
      "text": "Arise, O Lord; let not man prevail: let the heathen be judged in thy sight.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.9.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Psalms 9:20",
      "text": "Put them in fear, O Lord: that the nations may know themselves to be but men. Selah.",
      "paragraphStart": false
    }
  ]
}
