{
  "chapter": {
    "id": "kjva:psalms.128",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 128,
    "referenceLabel": "Psalms 128",
    "summary": "Source text for Psalms 128 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.128.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 1,
      "referenceLabel": "Psalms 128:1",
      "text": "Blessed is every one that feareth the Lord; that walketh in his ways.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.128.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 2,
      "referenceLabel": "Psalms 128:2",
      "text": "For thou shalt eat the labour of thine hands: happy shalt thou be, and it shall be well with thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.128.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 3,
      "referenceLabel": "Psalms 128:3",
      "text": "Thy wife shall be as a fruitful vine by the sides of thine house: thy children like olive plants round about thy table.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.128.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 4,
      "referenceLabel": "Psalms 128:4",
      "text": "Behold, that thus shall the man be blessed that feareth the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.128.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 5,
      "referenceLabel": "Psalms 128:5",
      "text": "The Lord shall bless thee out of Zion: and thou shalt see the good of Jerusalem all the days of thy life.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.128.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 6,
      "referenceLabel": "Psalms 128:6",
      "text": "Yea, thou shalt see thy children’s children, and peace upon Israel.",
      "paragraphStart": false
    }
  ]
}
