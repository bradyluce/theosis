{
  "chapter": {
    "id": "kjva:psalms.22",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 22,
    "referenceLabel": "Psalms 22",
    "summary": "Source text for Psalms 22 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.22.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Psalms 22:1",
      "text": "My God, my God, why hast thou forsaken me? why art thou so far from helping me, and from the words of my roaring?",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.22.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Psalms 22:2",
      "text": "O my God, I cry in the daytime, but thou hearest not; and in the night season, and am not silent.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Psalms 22:3",
      "text": "But thou art holy, O thou that inhabitest the praises of Israel.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Psalms 22:4",
      "text": "Our fathers trusted in thee: they trusted, and thou didst deliver them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Psalms 22:5",
      "text": "They cried unto thee, and were delivered: they trusted in thee, and were not confounded.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Psalms 22:6",
      "text": "But I am a worm, and no man; a reproach of men, and despised of the people.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Psalms 22:7",
      "text": "All they that see me laugh me to scorn: they shoot out the lip, they shake the head, saying,",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Psalms 22:8",
      "text": "He trusted on the Lord that he would deliver him: let him deliver him, seeing he delighted in him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Psalms 22:9",
      "text": "But thou art he that took me out of the womb: thou didst make me hope when I was upon my mother’s breasts.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Psalms 22:10",
      "text": "I was cast upon thee from the womb: thou art my God from my mother’s belly.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Psalms 22:11",
      "text": "Be not far from me; for trouble is near; for there is none to help.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Psalms 22:12",
      "text": "Many bulls have compassed me: strong bulls of Bashan have beset me round.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Psalms 22:13",
      "text": "They gaped upon me with their mouths, as a ravening and a roaring lion.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Psalms 22:14",
      "text": "I am poured out like water, and all my bones are out of joint: my heart is like wax; it is melted in the midst of my bowels.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Psalms 22:15",
      "text": "My strength is dried up like a potsherd; and my tongue cleaveth to my jaws; and thou hast brought me into the dust of death.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Psalms 22:16",
      "text": "For dogs have compassed me: the assembly of the wicked have inclosed me: they pierced my hands and my feet.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Psalms 22:17",
      "text": "I may tell all my bones: they look and stare upon me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Psalms 22:18",
      "text": "They part my garments among them, and cast lots upon my vesture.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Psalms 22:19",
      "text": "But be not thou far from me, O Lord: O my strength, haste thee to help me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Psalms 22:20",
      "text": "Deliver my soul from the sword; my darling from the power of the dog.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Psalms 22:21",
      "text": "Save me from the lion’s mouth: for thou hast heard me from the horns of the unicorns.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Psalms 22:22",
      "text": "I will declare thy name unto my brethren: in the midst of the congregation will I praise thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.23",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Psalms 22:23",
      "text": "Ye that fear the Lord, praise him; all ye the seed of Jacob, glorify him; and fear him, all ye the seed of Israel.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.24",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Psalms 22:24",
      "text": "For he hath not despised nor abhorred the affliction of the afflicted; neither hath he hid his face from him; but when he cried unto him, he heard.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.25",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Psalms 22:25",
      "text": "My praise shall be of thee in the great congregation: I will pay my vows before them that fear him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.26",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Psalms 22:26",
      "text": "The meek shall eat and be satisfied: they shall praise the Lord that seek him: your heart shall live for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.27",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Psalms 22:27",
      "text": "All the ends of the world shall remember and turn unto the Lord: and all the kindreds of the nations shall worship before thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.28",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Psalms 22:28",
      "text": "For the kingdom is the Lord’s: and he is the governor among the nations.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.29",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Psalms 22:29",
      "text": "All they that be fat upon earth shall eat and worship: all they that go down to the dust shall bow before him: and none can keep alive his own soul.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.30",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "Psalms 22:30",
      "text": "A seed shall serve him; it shall be accounted to the Lord for a generation.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.22.31",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 31,
      "referenceLabel": "Psalms 22:31",
      "text": "They shall come, and shall declare his righteousness unto a people that shall be born, that he hath done this.",
      "paragraphStart": false
    }
  ]
}
