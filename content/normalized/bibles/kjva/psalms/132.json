{
  "chapter": {
    "id": "kjva:psalms.132",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 132,
    "referenceLabel": "Psalms 132",
    "summary": "Source text for Psalms 132 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.132.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 1,
      "referenceLabel": "Psalms 132:1",
      "text": "Lord, remember David, and all his afflictions:",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.132.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 2,
      "referenceLabel": "Psalms 132:2",
      "text": "How he sware unto the Lord, and vowed unto the mighty God of Jacob;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.132.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 3,
      "referenceLabel": "Psalms 132:3",
      "text": "Surely I will not come into the tabernacle of my house, nor go up into my bed;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.132.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 4,
      "referenceLabel": "Psalms 132:4",
      "text": "I will not give sleep to mine eyes, or slumber to mine eyelids,",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.132.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 5,
      "referenceLabel": "Psalms 132:5",
      "text": "Until I find out a place for the Lord, an habitation for the mighty God of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.132.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 6,
      "referenceLabel": "Psalms 132:6",
      "text": "Lo, we heard of it at Ephratah: we found it in the fields of the wood.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.132.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 7,
      "referenceLabel": "Psalms 132:7",
      "text": "We will go into his tabernacles: we will worship at his footstool.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.132.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 8,
      "referenceLabel": "Psalms 132:8",
      "text": "Arise, O Lord, into thy rest; thou, and the ark of thy strength.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.132.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 9,
      "referenceLabel": "Psalms 132:9",
      "text": "Let thy priests be clothed with righteousness; and let thy saints shout for joy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.132.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 10,
      "referenceLabel": "Psalms 132:10",
      "text": "For thy servant David’s sake turn not away the face of thine anointed.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.132.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 11,
      "referenceLabel": "Psalms 132:11",
      "text": "The Lord hath sworn in truth unto David; he will not turn from it; Of the fruit of thy body will I set upon thy throne.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.132.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 12,
      "referenceLabel": "Psalms 132:12",
      "text": "If thy children will keep my covenant and my testimony that I shall teach them, their children shall also sit upon thy throne for evermore.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.132.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 13,
      "referenceLabel": "Psalms 132:13",
      "text": "For the Lord hath chosen Zion; he hath desired it for his habitation.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.132.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 14,
      "referenceLabel": "Psalms 132:14",
      "text": "This is my rest for ever: here will I dwell; for I have desired it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.132.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 15,
      "referenceLabel": "Psalms 132:15",
      "text": "I will abundantly bless her provision: I will satisfy her poor with bread.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.132.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 16,
      "referenceLabel": "Psalms 132:16",
      "text": "I will also clothe her priests with salvation: and her saints shall shout aloud for joy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.132.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 17,
      "referenceLabel": "Psalms 132:17",
      "text": "There will I make the horn of David to bud: I have ordained a lamp for mine anointed.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.132.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 18,
      "referenceLabel": "Psalms 132:18",
      "text": "His enemies will I clothe with shame: but upon himself shall his crown flourish.",
      "paragraphStart": false
    }
  ]
}
