{
  "chapter": {
    "id": "kjva:psalms.52",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 52,
    "referenceLabel": "Psalms 52",
    "summary": "Source text for Psalms 52 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.52.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 1,
      "referenceLabel": "Psalms 52:1",
      "text": "Why boastest thou thyself in mischief, O mighty man? the goodness of God endureth continually.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.52.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 2,
      "referenceLabel": "Psalms 52:2",
      "text": "Thy tongue deviseth mischiefs; like a sharp razor, working deceitfully.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.52.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 3,
      "referenceLabel": "Psalms 52:3",
      "text": "Thou lovest evil more than good; and lying rather than to speak righteousness. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.52.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 4,
      "referenceLabel": "Psalms 52:4",
      "text": "Thou lovest all devouring words, O thou deceitful tongue.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.52.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 5,
      "referenceLabel": "Psalms 52:5",
      "text": "God shall likewise destroy thee for ever, he shall take thee away, and pluck thee out of thy dwelling place, and root thee out of the land of the living. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.52.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 6,
      "referenceLabel": "Psalms 52:6",
      "text": "The righteous also shall see, and fear, and shall laugh at him:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.52.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 7,
      "referenceLabel": "Psalms 52:7",
      "text": "Lo, this is the man that made not God his strength; but trusted in the abundance of his riches, and strengthened himself in his wickedness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.52.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 8,
      "referenceLabel": "Psalms 52:8",
      "text": "But I am like a green olive tree in the house of God: I trust in the mercy of God for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.52.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 9,
      "referenceLabel": "Psalms 52:9",
      "text": "I will praise thee for ever, because thou hast done it: and I will wait on thy name; for it is good before thy saints.",
      "paragraphStart": false
    }
  ]
}
