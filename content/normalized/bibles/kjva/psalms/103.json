{
  "chapter": {
    "id": "kjva:psalms.103",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 103,
    "referenceLabel": "Psalms 103",
    "summary": "Source text for Psalms 103 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.103.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 1,
      "referenceLabel": "Psalms 103:1",
      "text": "Bless the Lord, O my soul: and all that is within me, bless his holy name.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.103.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 2,
      "referenceLabel": "Psalms 103:2",
      "text": "Bless the Lord, O my soul, and forget not all his benefits:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 3,
      "referenceLabel": "Psalms 103:3",
      "text": "Who forgiveth all thine iniquities; who healeth all thy diseases;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 4,
      "referenceLabel": "Psalms 103:4",
      "text": "Who redeemeth thy life from destruction; who crowneth thee with lovingkindness and tender mercies;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 5,
      "referenceLabel": "Psalms 103:5",
      "text": "Who satisfieth thy mouth with good things; so that thy youth is renewed like the eagle’s.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 6,
      "referenceLabel": "Psalms 103:6",
      "text": "The Lord executeth righteousness and judgment for all that are oppressed.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 7,
      "referenceLabel": "Psalms 103:7",
      "text": "He made known his ways unto Moses, his acts unto the children of Israel.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 8,
      "referenceLabel": "Psalms 103:8",
      "text": "The Lord is merciful and gracious, slow to anger, and plenteous in mercy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 9,
      "referenceLabel": "Psalms 103:9",
      "text": "He will not always chide: neither will he keep his anger for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 10,
      "referenceLabel": "Psalms 103:10",
      "text": "He hath not dealt with us after our sins; nor rewarded us according to our iniquities.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 11,
      "referenceLabel": "Psalms 103:11",
      "text": "For as the heaven is high above the earth, so great is his mercy toward them that fear him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 12,
      "referenceLabel": "Psalms 103:12",
      "text": "As far as the east is from the west, so far hath he removed our transgressions from us.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 13,
      "referenceLabel": "Psalms 103:13",
      "text": "Like as a father pitieth his children, so the Lord pitieth them that fear him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 14,
      "referenceLabel": "Psalms 103:14",
      "text": "For he knoweth our frame; he remembereth that we are dust.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 15,
      "referenceLabel": "Psalms 103:15",
      "text": "As for man, his days are as grass: as a flower of the field, so he flourisheth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 16,
      "referenceLabel": "Psalms 103:16",
      "text": "For the wind passeth over it, and it is gone; and the place thereof shall know it no more.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 17,
      "referenceLabel": "Psalms 103:17",
      "text": "But the mercy of the Lord is from everlasting to everlasting upon them that fear him, and his righteousness unto children’s children;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 18,
      "referenceLabel": "Psalms 103:18",
      "text": "To such as keep his covenant, and to those that remember his commandments to do them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 19,
      "referenceLabel": "Psalms 103:19",
      "text": "The Lord hath prepared his throne in the heavens; and his kingdom ruleth over all.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 20,
      "referenceLabel": "Psalms 103:20",
      "text": "Bless the Lord, ye his angels, that excel in strength, that do his commandments, hearkening unto the voice of his word.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 21,
      "referenceLabel": "Psalms 103:21",
      "text": "Bless ye the Lord, all ye his hosts; ye ministers of his, that do his pleasure.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.103.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 22,
      "referenceLabel": "Psalms 103:22",
      "text": "Bless the Lord, all his works in all places of his dominion: bless the Lord, O my soul.",
      "paragraphStart": false
    }
  ]
}
