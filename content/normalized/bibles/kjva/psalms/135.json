{
  "chapter": {
    "id": "kjva:psalms.135",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 135,
    "referenceLabel": "Psalms 135",
    "summary": "Source text for Psalms 135 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.135.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 1,
      "referenceLabel": "Psalms 135:1",
      "text": "Praise ye the Lord. Praise ye the name of the Lord; praise him, O ye servants of the Lord.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.135.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 2,
      "referenceLabel": "Psalms 135:2",
      "text": "Ye that stand in the house of the Lord, in the courts of the house of our God,",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.135.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 3,
      "referenceLabel": "Psalms 135:3",
      "text": "Praise the Lord; for the Lord is good: sing praises unto his name; for it is pleasant.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.135.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 4,
      "referenceLabel": "Psalms 135:4",
      "text": "For the Lord hath chosen Jacob unto himself, and Israel for his peculiar treasure.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.135.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 5,
      "referenceLabel": "Psalms 135:5",
      "text": "For I know that the Lord is great, and that our Lord is above all gods.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.135.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 6,
      "referenceLabel": "Psalms 135:6",
      "text": "Whatsoever the Lord pleased, that did he in heaven, and in earth, in the seas, and all deep places.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.135.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 7,
      "referenceLabel": "Psalms 135:7",
      "text": "He causeth the vapours to ascend from the ends of the earth; he maketh lightnings for the rain; he bringeth the wind out of his treasuries.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.135.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 8,
      "referenceLabel": "Psalms 135:8",
      "text": "Who smote the firstborn of Egypt, both of man and beast.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.135.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 9,
      "referenceLabel": "Psalms 135:9",
      "text": "Who sent tokens and wonders into the midst of thee, O Egypt, upon Pharaoh, and upon all his servants.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.135.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 10,
      "referenceLabel": "Psalms 135:10",
      "text": "Who smote great nations, and slew mighty kings;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.135.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 11,
      "referenceLabel": "Psalms 135:11",
      "text": "Sihon king of the Amorites, and Og king of Bashan, and all the kingdoms of Canaan:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.135.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 12,
      "referenceLabel": "Psalms 135:12",
      "text": "And gave their land for an heritage, an heritage unto Israel his people.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.135.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 13,
      "referenceLabel": "Psalms 135:13",
      "text": "Thy name, O Lord, endureth for ever; and thy memorial, O Lord, throughout all generations.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.135.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 14,
      "referenceLabel": "Psalms 135:14",
      "text": "For the Lord will judge his people, and he will repent himself concerning his servants.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.135.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 15,
      "referenceLabel": "Psalms 135:15",
      "text": "The idols of the heathen are silver and gold, the work of men’s hands.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.135.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 16,
      "referenceLabel": "Psalms 135:16",
      "text": "They have mouths, but they speak not; eyes have they, but they see not;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.135.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 17,
      "referenceLabel": "Psalms 135:17",
      "text": "They have ears, but they hear not; neither is there any breath in their mouths.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.135.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 18,
      "referenceLabel": "Psalms 135:18",
      "text": "They that make them are like unto them: so is every one that trusteth in them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.135.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 19,
      "referenceLabel": "Psalms 135:19",
      "text": "Bless the Lord, O house of Israel: bless the Lord, O house of Aaron:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.135.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 20,
      "referenceLabel": "Psalms 135:20",
      "text": "Bless the Lord, O house of Levi: ye that fear the Lord, bless the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.135.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 21,
      "referenceLabel": "Psalms 135:21",
      "text": "Blessed be the Lord out of Zion, which dwelleth at Jerusalem. Praise ye the Lord.",
      "paragraphStart": false
    }
  ]
}
