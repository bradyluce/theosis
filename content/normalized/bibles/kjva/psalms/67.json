    {
      "id": "kjva:psalms.67.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 1,
      "referenceLabel": "Psalms 67:1",
      "text": "God be merciful unto us, and bless us; and cause his face to shine upon us; Selah.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.67.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 2,
      "referenceLabel": "Psalms 67:2",
      "text": "That thy way may be known upon earth, thy saving health among all nations.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.67.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 3,
      "referenceLabel": "Psalms 67:3",
      "text": "Let the people praise thee, O God; let all the people praise thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.67.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 4,
      "referenceLabel": "Psalms 67:4",
      "text": "O let the nations be glad and sing for joy: for thou shalt judge the people righteously, and govern the nations upon earth. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.67.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 5,
      "referenceLabel": "Psalms 67:5",
      "text": "Let the people praise thee, O God; let all the people praise thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.67.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 6,
      "referenceLabel": "Psalms 67:6",
      "text": "Then shall the earth yield her increase; and God, even our own God, shall bless us.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.67.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 7,
      "referenceLabel": "Psalms 67:7",
      "text": "God shall bless us; and all the ends of the earth shall fear him.",
      "paragraphStart": false
    }
  ]
