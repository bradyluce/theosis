{
  "chapter": {
    "id": "kjva:psalms.92",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 92,
    "referenceLabel": "Psalms 92",
    "summary": "Source text for Psalms 92 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.92.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 1,
      "referenceLabel": "Psalms 92:1",
      "text": "It is a good thing to give thanks unto the Lord, and to sing praises unto thy name, O most High:",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.92.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 2,
      "referenceLabel": "Psalms 92:2",
      "text": "To shew forth thy lovingkindness in the morning, and thy faithfulness every night,",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.92.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 3,
      "referenceLabel": "Psalms 92:3",
      "text": "Upon an instrument of ten strings, and upon the psaltery; upon the harp with a solemn sound.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.92.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 4,
      "referenceLabel": "Psalms 92:4",
      "text": "For thou, Lord, hast made me glad through thy work: I will triumph in the works of thy hands.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.92.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 5,
      "referenceLabel": "Psalms 92:5",
      "text": "O Lord, how great are thy works! and thy thoughts are very deep.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.92.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 6,
      "referenceLabel": "Psalms 92:6",
      "text": "A brutish man knoweth not; neither doth a fool understand this.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.92.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 7,
      "referenceLabel": "Psalms 92:7",
      "text": "When the wicked spring as the grass, and when all the workers of iniquity do flourish; it is that they shall be destroyed for ever:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.92.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 8,
      "referenceLabel": "Psalms 92:8",
      "text": "But thou, Lord, art most high for evermore.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.92.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 9,
      "referenceLabel": "Psalms 92:9",
      "text": "For, lo, thine enemies, O Lord, for, lo, thine enemies shall perish; all the workers of iniquity shall be scattered.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.92.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 10,
      "referenceLabel": "Psalms 92:10",
      "text": "But my horn shalt thou exalt like the horn of an unicorn: I shall be anointed with fresh oil.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.92.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 11,
      "referenceLabel": "Psalms 92:11",
      "text": "Mine eye also shall see my desire on mine enemies, and mine ears shall hear my desire of the wicked that rise up against me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.92.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 12,
      "referenceLabel": "Psalms 92:12",
      "text": "The righteous shall flourish like the palm tree: he shall grow like a cedar in Lebanon.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.92.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 13,
      "referenceLabel": "Psalms 92:13",
      "text": "Those that be planted in the house of the Lord shall flourish in the courts of our God.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.92.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 14,
      "referenceLabel": "Psalms 92:14",
      "text": "They shall still bring forth fruit in old age; they shall be fat and flourishing;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.92.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 15,
      "referenceLabel": "Psalms 92:15",
      "text": "To shew that the Lord is upright: he is my rock, and there is no unrighteousness in him.",
      "paragraphStart": false
    }
  ]
}
