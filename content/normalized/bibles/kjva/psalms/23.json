{
  "chapter": {
    "id": "kjva:psalms.23",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 23,
    "referenceLabel": "Psalms 23",
    "summary": "Source text for Psalms 23 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.23.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Psalms 23:1",
      "text": "The Lord is my shepherd; I shall not want.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.23.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Psalms 23:2",
      "text": "He maketh me to lie down in green pastures: he leadeth me beside the still waters.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.23.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Psalms 23:3",
      "text": "He restoreth my soul: he leadeth me in the paths of righteousness for his name’s sake.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.23.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Psalms 23:4",
      "text": "Yea, though I walk through the valley of the shadow of death, I will fear no evil: for thou art with me; thy rod and thy staff they comfort me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.23.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Psalms 23:5",
      "text": "Thou preparest a table before me in the presence of mine enemies: thou anointest my head with oil; my cup runneth over.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.23.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Psalms 23:6",
      "text": "Surely goodness and mercy shall follow me all the days of my life: and I will dwell in the house of the Lord for ever.",
      "paragraphStart": false
    }
  ]
}
