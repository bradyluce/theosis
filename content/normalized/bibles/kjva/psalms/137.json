{
  "chapter": {
    "id": "kjva:psalms.137",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 137,
    "referenceLabel": "Psalms 137",
    "summary": "Source text for Psalms 137 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.137.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 1,
      "referenceLabel": "Psalms 137:1",
      "text": "By the rivers of Babylon, there we sat down, yea, we wept, when we remembered Zion.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.137.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 2,
      "referenceLabel": "Psalms 137:2",
      "text": "We hanged our harps upon the willows in the midst thereof.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.137.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 3,
      "referenceLabel": "Psalms 137:3",
      "text": "For there they that carried us away captive required of us a song; and they that wasted us required of us mirth, saying, Sing us one of the songs of Zion.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.137.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 4,
      "referenceLabel": "Psalms 137:4",
      "text": "How shall we sing the Lord’s song in a strange land?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.137.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 5,
      "referenceLabel": "Psalms 137:5",
      "text": "If I forget thee, O Jerusalem, let my right hand forget her cunning.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.137.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 6,
      "referenceLabel": "Psalms 137:6",
      "text": "If I do not remember thee, let my tongue cleave to the roof of my mouth; if I prefer not Jerusalem above my chief joy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.137.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 7,
      "referenceLabel": "Psalms 137:7",
      "text": "Remember, O Lord, the children of Edom in the day of Jerusalem; who said, Rase it, rase it, even to the foundation thereof.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.137.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 8,
      "referenceLabel": "Psalms 137:8",
      "text": "O daughter of Babylon, who art to be destroyed; happy shall he be, that rewardeth thee as thou hast served us.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.137.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 9,
      "referenceLabel": "Psalms 137:9",
      "text": "Happy shall he be, that taketh and dasheth thy little ones against the stones.",
      "paragraphStart": false
    }
  ]
}
