{
  "chapter": {
    "id": "kjva:psalms.20",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 20,
    "referenceLabel": "Psalms 20",
    "summary": "Source text for Psalms 20 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.20.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Psalms 20:1",
      "text": "The Lord hear thee in the day of trouble; the name of the God of Jacob defend thee;",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.20.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Psalms 20:2",
      "text": "Send thee help from the sanctuary, and strengthen thee out of Zion;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.20.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Psalms 20:3",
      "text": "Remember all thy offerings, and accept thy burnt sacrifice; Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.20.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Psalms 20:4",
      "text": "Grant thee according to thine own heart, and fulfil all thy counsel.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.20.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Psalms 20:5",
      "text": "We will rejoice in thy salvation, and in the name of our God we will set up our banners: the Lord fulfil all thy petitions.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.20.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Psalms 20:6",
      "text": "Now know I that the Lord saveth his anointed; he will hear him from his holy heaven with the saving strength of his right hand.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.20.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Psalms 20:7",
      "text": "Some trust in chariots, and some in horses: but we will remember the name of the Lord our God.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.20.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Psalms 20:8",
      "text": "They are brought down and fallen: but we are risen, and stand upright.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.20.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Psalms 20:9",
      "text": "Save, Lord: let the king hear us when we call.",
      "paragraphStart": false
    }
  ]
}
