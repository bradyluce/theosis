{
  "chapter": {
    "id": "kjva:psalms.130",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 130,
    "referenceLabel": "Psalms 130",
    "summary": "Source text for Psalms 130 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.130.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 1,
      "referenceLabel": "Psalms 130:1",
      "text": "Out of the depths have I cried unto thee, O Lord.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.130.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 2,
      "referenceLabel": "Psalms 130:2",
      "text": "Lord, hear my voice: let thine ears be attentive to the voice of my supplications.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.130.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 3,
      "referenceLabel": "Psalms 130:3",
      "text": "If thou, Lord, shouldest mark iniquities, O Lord, who shall stand?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.130.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 4,
      "referenceLabel": "Psalms 130:4",
      "text": "But there is forgiveness with thee, that thou mayest be feared.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.130.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 5,
      "referenceLabel": "Psalms 130:5",
      "text": "I wait for the Lord, my soul doth wait, and in his word do I hope.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.130.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 6,
      "referenceLabel": "Psalms 130:6",
      "text": "My soul waiteth for the Lord more than they that watch for the morning: I say, more than they that watch for the morning.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.130.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 7,
      "referenceLabel": "Psalms 130:7",
      "text": "Let Israel hope in the Lord: for with the Lord there is mercy, and with him is plenteous redemption.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.130.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 8,
      "referenceLabel": "Psalms 130:8",
      "text": "And he shall redeem Israel from all his iniquities.",
      "paragraphStart": false
    }
  ]
}
