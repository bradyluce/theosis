{
  "chapter": {
    "id": "kjva:psalms.109",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 109,
    "referenceLabel": "Psalms 109",
    "summary": "Source text for Psalms 109 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.109.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 1,
      "referenceLabel": "Psalms 109:1",
      "text": "Hold not thy peace, O God of my praise;",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.109.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 2,
      "referenceLabel": "Psalms 109:2",
      "text": "For the mouth of the wicked and the mouth of the deceitful are opened against me: they have spoken against me with a lying tongue.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 3,
      "referenceLabel": "Psalms 109:3",
      "text": "They compassed me about also with words of hatred; and fought against me without a cause.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 4,
      "referenceLabel": "Psalms 109:4",
      "text": "For my love they are my adversaries: but I give myself unto prayer.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 5,
      "referenceLabel": "Psalms 109:5",
      "text": "And they have rewarded me evil for good, and hatred for my love.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 6,
      "referenceLabel": "Psalms 109:6",
      "text": "Set thou a wicked man over him: and let Satan stand at his right hand.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 7,
      "referenceLabel": "Psalms 109:7",
      "text": "When he shall be judged, let him be condemned: and let his prayer become sin.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 8,
      "referenceLabel": "Psalms 109:8",
      "text": "Let his days be few; and let another take his office.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 9,
      "referenceLabel": "Psalms 109:9",
      "text": "Let his children be fatherless, and his wife a widow.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 10,
      "referenceLabel": "Psalms 109:10",
      "text": "Let his children be continually vagabonds, and beg: let them seek their bread also out of their desolate places.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 11,
      "referenceLabel": "Psalms 109:11",
      "text": "Let the extortioner catch all that he hath; and let the strangers spoil his labour.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 12,
      "referenceLabel": "Psalms 109:12",
      "text": "Let there be none to extend mercy unto him: neither let there be any to favour his fatherless children.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 13,
      "referenceLabel": "Psalms 109:13",
      "text": "Let his posterity be cut off; and in the generation following let their name be blotted out.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 14,
      "referenceLabel": "Psalms 109:14",
      "text": "Let the iniquity of his fathers be remembered with the Lord; and let not the sin of his mother be blotted out.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 15,
      "referenceLabel": "Psalms 109:15",
      "text": "Let them be before the Lord continually, that he may cut off the memory of them from the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 16,
      "referenceLabel": "Psalms 109:16",
      "text": "Because that he remembered not to shew mercy, but persecuted the poor and needy man, that he might even slay the broken in heart.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 17,
      "referenceLabel": "Psalms 109:17",
      "text": "As he loved cursing, so let it come unto him: as he delighted not in blessing, so let it be far from him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 18,
      "referenceLabel": "Psalms 109:18",
      "text": "As he clothed himself with cursing like as with his garment, so let it come into his bowels like water, and like oil into his bones.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 19,
      "referenceLabel": "Psalms 109:19",
      "text": "Let it be unto him as the garment which covereth him, and for a girdle wherewith he is girded continually.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 20,
      "referenceLabel": "Psalms 109:20",
      "text": "Let this be the reward of mine adversaries from the Lord, and of them that speak evil against my soul.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 21,
      "referenceLabel": "Psalms 109:21",
      "text": "But do thou for me, O God the Lord, for thy name’s sake: because thy mercy is good, deliver thou me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 22,
      "referenceLabel": "Psalms 109:22",
      "text": "For I am poor and needy, and my heart is wounded within me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.23",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 23,
      "referenceLabel": "Psalms 109:23",
      "text": "I am gone like the shadow when it declineth: I am tossed up and down as the locust.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.24",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 24,
      "referenceLabel": "Psalms 109:24",
      "text": "My knees are weak through fasting; and my flesh faileth of fatness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.25",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 25,
      "referenceLabel": "Psalms 109:25",
      "text": "I became also a reproach unto them: when they looked upon me they shaked their heads.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.26",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 26,
      "referenceLabel": "Psalms 109:26",
      "text": "Help me, O Lord my God: O save me according to thy mercy:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.27",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 27,
      "referenceLabel": "Psalms 109:27",
      "text": "That they may know that this is thy hand; that thou, Lord, hast done it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.28",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 28,
      "referenceLabel": "Psalms 109:28",
      "text": "Let them curse, but bless thou: when they arise, let them be ashamed; but let thy servant rejoice.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.29",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 29,
      "referenceLabel": "Psalms 109:29",
      "text": "Let mine adversaries be clothed with shame, and let them cover themselves with their own confusion, as with a mantle.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.30",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 30,
      "referenceLabel": "Psalms 109:30",
      "text": "I will greatly praise the Lord with my mouth; yea, I will praise him among the multitude.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.109.31",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 31,
      "referenceLabel": "Psalms 109:31",
      "text": "For he shall stand at the right hand of the poor, to save him from those that condemn his soul.",
      "paragraphStart": false
    }
  ]
}
