{
  "chapter": {
    "id": "kjva:psalms.75",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 75,
    "referenceLabel": "Psalms 75",
    "summary": "Source text for Psalms 75 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.75.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 1,
      "referenceLabel": "Psalms 75:1",
      "text": "Unto thee, O God, do we give thanks, unto thee do we give thanks: for that thy name is near thy wondrous works declare.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.75.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 2,
      "referenceLabel": "Psalms 75:2",
      "text": "When I shall receive the congregation I will judge uprightly.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.75.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 3,
      "referenceLabel": "Psalms 75:3",
      "text": "The earth and all the inhabitants thereof are dissolved: I bear up the pillars of it. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.75.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 4,
      "referenceLabel": "Psalms 75:4",
      "text": "I said unto the fools, Deal not foolishly: and to the wicked, Lift not up the horn:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.75.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 5,
      "referenceLabel": "Psalms 75:5",
      "text": "Lift not up your horn on high: speak not with a stiff neck.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.75.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 6,
      "referenceLabel": "Psalms 75:6",
      "text": "For promotion cometh neither from the east, nor from the west, nor from the south.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.75.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 7,
      "referenceLabel": "Psalms 75:7",
      "text": "But God is the judge: he putteth down one, and setteth up another.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.75.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 8,
      "referenceLabel": "Psalms 75:8",
      "text": "For in the hand of the Lord there is a cup, and the wine is red; it is full of mixture; and he poureth out of the same: but the dregs thereof, all the wicked of the earth shall wring them out, and drink them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.75.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 9,
      "referenceLabel": "Psalms 75:9",
      "text": "But I will declare for ever; I will sing praises to the God of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.75.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 10,
      "referenceLabel": "Psalms 75:10",
      "text": "All the horns of the wicked also will I cut off; but the horns of the righteous shall be exalted.",
      "paragraphStart": false
    }
  ]
}
