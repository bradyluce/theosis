{
  "chapter": {
    "id": "kjva:psalms.50",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 50,
    "referenceLabel": "Psalms 50",
    "summary": "Source text for Psalms 50 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.50.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 1,
      "referenceLabel": "Psalms 50:1",
      "text": "The mighty God, even the Lord, hath spoken, and called the earth from the rising of the sun unto the going down thereof.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.50.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 2,
      "referenceLabel": "Psalms 50:2",
      "text": "Out of Zion, the perfection of beauty, God hath shined.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 3,
      "referenceLabel": "Psalms 50:3",
      "text": "Our God shall come, and shall not keep silence: a fire shall devour before him, and it shall be very tempestuous round about him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 4,
      "referenceLabel": "Psalms 50:4",
      "text": "He shall call to the heavens from above, and to the earth, that he may judge his people.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 5,
      "referenceLabel": "Psalms 50:5",
      "text": "Gather my saints together unto me; those that have made a covenant with me by sacrifice.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 6,
      "referenceLabel": "Psalms 50:6",
      "text": "And the heavens shall declare his righteousness: for God is judge himself. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 7,
      "referenceLabel": "Psalms 50:7",
      "text": "Hear, O my people, and I will speak; O Israel, and I will testify against thee: I am God, even thy God.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 8,
      "referenceLabel": "Psalms 50:8",
      "text": "I will not reprove thee for thy sacrifices or thy burnt offerings, to have been continually before me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 9,
      "referenceLabel": "Psalms 50:9",
      "text": "I will take no bullock out of thy house, nor he goats out of thy folds.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 10,
      "referenceLabel": "Psalms 50:10",
      "text": "For every beast of the forest is mine, and the cattle upon a thousand hills.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 11,
      "referenceLabel": "Psalms 50:11",
      "text": "I know all the fowls of the mountains: and the wild beasts of the field are mine.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 12,
      "referenceLabel": "Psalms 50:12",
      "text": "If I were hungry, I would not tell thee: for the world is mine, and the fulness thereof.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 13,
      "referenceLabel": "Psalms 50:13",
      "text": "Will I eat the flesh of bulls, or drink the blood of goats?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 14,
      "referenceLabel": "Psalms 50:14",
      "text": "Offer unto God thanksgiving; and pay thy vows unto the most High:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 15,
      "referenceLabel": "Psalms 50:15",
      "text": "And call upon me in the day of trouble: I will deliver thee, and thou shalt glorify me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 16,
      "referenceLabel": "Psalms 50:16",
      "text": "But unto the wicked God saith, What hast thou to do to declare my statutes, or that thou shouldest take my covenant in thy mouth?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 17,
      "referenceLabel": "Psalms 50:17",
      "text": "Seeing thou hatest instruction, and castest my words behind thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 18,
      "referenceLabel": "Psalms 50:18",
      "text": "When thou sawest a thief, then thou consentedst with him, and hast been partaker with adulterers.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 19,
      "referenceLabel": "Psalms 50:19",
      "text": "Thou givest thy mouth to evil, and thy tongue frameth deceit.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 20,
      "referenceLabel": "Psalms 50:20",
      "text": "Thou sittest and speakest against thy brother; thou slanderest thine own mother’s son.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 21,
      "referenceLabel": "Psalms 50:21",
      "text": "These things hast thou done, and I kept silence; thou thoughtest that I was altogether such an one as thyself: but I will reprove thee, and set them in order before thine eyes.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 22,
      "referenceLabel": "Psalms 50:22",
      "text": "Now consider this, ye that forget God, lest I tear you in pieces, and there be none to deliver.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.50.23",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 23,
      "referenceLabel": "Psalms 50:23",
      "text": "Whoso offereth praise glorifieth me: and to him that ordereth his conversation aright will I shew the salvation of God.",
      "paragraphStart": false
    }
  ]
}
