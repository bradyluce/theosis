{
  "chapter": {
    "id": "kjva:psalms.36",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 36,
    "referenceLabel": "Psalms 36",
    "summary": "Source text for Psalms 36 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.36.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 1,
      "referenceLabel": "Psalms 36:1",
      "text": "The transgression of the wicked saith within my heart, that there is no fear of God before his eyes.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.36.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 2,
      "referenceLabel": "Psalms 36:2",
      "text": "For he flattereth himself in his own eyes, until his iniquity be found to be hateful.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.36.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 3,
      "referenceLabel": "Psalms 36:3",
      "text": "The words of his mouth are iniquity and deceit: he hath left off to be wise, and to do good.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.36.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 4,
      "referenceLabel": "Psalms 36:4",
      "text": "He deviseth mischief upon his bed; he setteth himself in a way that is not good; he abhorreth not evil.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.36.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 5,
      "referenceLabel": "Psalms 36:5",
      "text": "Thy mercy, O Lord, is in the heavens; and thy faithfulness reacheth unto the clouds.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.36.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 6,
      "referenceLabel": "Psalms 36:6",
      "text": "Thy righteousness is like the great mountains; thy judgments are a great deep: O Lord, thou preservest man and beast.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.36.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 7,
      "referenceLabel": "Psalms 36:7",
      "text": "How excellent is thy lovingkindness, O God! therefore the children of men put their trust under the shadow of thy wings.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.36.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 8,
      "referenceLabel": "Psalms 36:8",
      "text": "They shall be abundantly satisfied with the fatness of thy house; and thou shalt make them drink of the river of thy pleasures.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.36.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 9,
      "referenceLabel": "Psalms 36:9",
      "text": "For with thee is the fountain of life: in thy light shall we see light.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.36.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 10,
      "referenceLabel": "Psalms 36:10",
      "text": "O continue thy lovingkindness unto them that know thee; and thy righteousness to the upright in heart.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.36.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 11,
      "referenceLabel": "Psalms 36:11",
      "text": "Let not the foot of pride come against me, and let not the hand of the wicked remove me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.36.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 12,
      "referenceLabel": "Psalms 36:12",
      "text": "There are the workers of iniquity fallen: they are cast down, and shall not be able to rise.",
      "paragraphStart": false
    }
  ]
}
