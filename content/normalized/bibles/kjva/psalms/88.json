{
  "chapter": {
    "id": "kjva:psalms.88",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 88,
    "referenceLabel": "Psalms 88",
    "summary": "Source text for Psalms 88 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.88.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 1,
      "referenceLabel": "Psalms 88:1",
      "text": "O Lord God of my salvation, I have cried day and night before thee:",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.88.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 2,
      "referenceLabel": "Psalms 88:2",
      "text": "Let my prayer come before thee: incline thine ear unto my cry;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.88.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 3,
      "referenceLabel": "Psalms 88:3",
      "text": "For my soul is full of troubles: and my life draweth nigh unto the grave.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.88.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 4,
      "referenceLabel": "Psalms 88:4",
      "text": "I am counted with them that go down into the pit: I am as a man that hath no strength:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.88.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 5,
      "referenceLabel": "Psalms 88:5",
      "text": "Free among the dead, like the slain that lie in the grave, whom thou rememberest no more: and they are cut off from thy hand.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.88.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 6,
      "referenceLabel": "Psalms 88:6",
      "text": "Thou hast laid me in the lowest pit, in darkness, in the deeps.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.88.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 7,
      "referenceLabel": "Psalms 88:7",
      "text": "Thy wrath lieth hard upon me, and thou hast afflicted me with all thy waves. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.88.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 8,
      "referenceLabel": "Psalms 88:8",
      "text": "Thou hast put away mine acquaintance far from me; thou hast made me an abomination unto them: I am shut up, and I cannot come forth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.88.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 9,
      "referenceLabel": "Psalms 88:9",
      "text": "Mine eye mourneth by reason of affliction: Lord, I have called daily upon thee, I have stretched out my hands unto thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.88.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 10,
      "referenceLabel": "Psalms 88:10",
      "text": "Wilt thou shew wonders to the dead? shall the dead arise and praise thee? Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.88.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 11,
      "referenceLabel": "Psalms 88:11",
      "text": "Shall thy lovingkindness be declared in the grave? or thy faithfulness in destruction?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.88.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 12,
      "referenceLabel": "Psalms 88:12",
      "text": "Shall thy wonders be known in the dark? and thy righteousness in the land of forgetfulness?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.88.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 13,
      "referenceLabel": "Psalms 88:13",
      "text": "But unto thee have I cried, O Lord; and in the morning shall my prayer prevent thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.88.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 14,
      "referenceLabel": "Psalms 88:14",
      "text": "Lord, why castest thou off my soul? why hidest thou thy face from me?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.88.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 15,
      "referenceLabel": "Psalms 88:15",
      "text": "I am afflicted and ready to die from my youth up: while I suffer thy terrors I am distracted.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.88.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 16,
      "referenceLabel": "Psalms 88:16",
      "text": "Thy fierce wrath goeth over me; thy terrors have cut me off.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.88.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 17,
      "referenceLabel": "Psalms 88:17",
      "text": "They came round about me daily like water; they compassed me about together.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.88.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 18,
      "referenceLabel": "Psalms 88:18",
      "text": "Lover and friend hast thou put far from me, and mine acquaintance into darkness.",
      "paragraphStart": false
    }
  ]
}
