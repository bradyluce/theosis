{
  "chapter": {
    "id": "kjva:psalms.90",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 90,
    "referenceLabel": "Psalms 90",
    "summary": "Source text for Psalms 90 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.90.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 1,
      "referenceLabel": "Psalms 90:1",
      "text": "Lord, thou hast been our dwelling place in all generations.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.90.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 2,
      "referenceLabel": "Psalms 90:2",
      "text": "Before the mountains were brought forth, or ever thou hadst formed the earth and the world, even from everlasting to everlasting, thou art God.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.90.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 3,
      "referenceLabel": "Psalms 90:3",
      "text": "Thou turnest man to destruction; and sayest, Return, ye children of men.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.90.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 4,
      "referenceLabel": "Psalms 90:4",
      "text": "For a thousand years in thy sight are but as yesterday when it is past, and as a watch in the night.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.90.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 5,
      "referenceLabel": "Psalms 90:5",
      "text": "Thou carriest them away as with a flood; they are as a sleep: in the morning they are like grass which groweth up.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.90.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 6,
      "referenceLabel": "Psalms 90:6",
      "text": "In the morning it flourisheth, and groweth up; in the evening it is cut down, and withereth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.90.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 7,
      "referenceLabel": "Psalms 90:7",
      "text": "For we are consumed by thine anger, and by thy wrath are we troubled.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.90.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 8,
      "referenceLabel": "Psalms 90:8",
      "text": "Thou hast set our iniquities before thee, our secret sins in the light of thy countenance.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.90.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 9,
      "referenceLabel": "Psalms 90:9",
      "text": "For all our days are passed away in thy wrath: we spend our years as a tale that is told.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.90.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 10,
      "referenceLabel": "Psalms 90:10",
      "text": "The days of our years are threescore years and ten; and if by reason of strength they be fourscore years, yet is their strength labour and sorrow; for it is soon cut off, and we fly away.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.90.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 11,
      "referenceLabel": "Psalms 90:11",
      "text": "Who knoweth the power of thine anger? even according to thy fear, so is thy wrath.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.90.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 12,
      "referenceLabel": "Psalms 90:12",
      "text": "So teach us to number our days, that we may apply our hearts unto wisdom.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.90.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 13,
      "referenceLabel": "Psalms 90:13",
      "text": "Return, O Lord, how long? and let it repent thee concerning thy servants.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.90.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 14,
      "referenceLabel": "Psalms 90:14",
      "text": "O satisfy us early with thy mercy; that we may rejoice and be glad all our days.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.90.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 15,
      "referenceLabel": "Psalms 90:15",
      "text": "Make us glad according to the days wherein thou hast afflicted us, and the years wherein we have seen evil.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.90.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 16,
      "referenceLabel": "Psalms 90:16",
      "text": "Let thy work appear unto thy servants, and thy glory unto their children.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.90.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 17,
      "referenceLabel": "Psalms 90:17",
      "text": "And let the beauty of the Lord our God be upon us: and establish thou the work of our hands upon us; yea, the work of our hands establish thou it.",
      "paragraphStart": false
    }
  ]
}
