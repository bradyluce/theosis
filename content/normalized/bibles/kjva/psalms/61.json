{
  "chapter": {
    "id": "kjva:psalms.61",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 61,
    "referenceLabel": "Psalms 61",
    "summary": "Source text for Psalms 61 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.61.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 1,
      "referenceLabel": "Psalms 61:1",
      "text": "Hear my cry, O God; attend unto my prayer.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.61.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 2,
      "referenceLabel": "Psalms 61:2",
      "text": "From the end of the earth will I cry unto thee, when my heart is overwhelmed: lead me to the rock that is higher than I.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.61.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 3,
      "referenceLabel": "Psalms 61:3",
      "text": "For thou hast been a shelter for me, and a strong tower from the enemy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.61.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 4,
      "referenceLabel": "Psalms 61:4",
      "text": "I will abide in thy tabernacle for ever: I will trust in the covert of thy wings. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.61.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 5,
      "referenceLabel": "Psalms 61:5",
      "text": "For thou, O God, hast heard my vows: thou hast given me the heritage of those that fear thy name.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.61.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 6,
      "referenceLabel": "Psalms 61:6",
      "text": "Thou wilt prolong the king’s life: and his years as many generations.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.61.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 7,
      "referenceLabel": "Psalms 61:7",
      "text": "He shall abide before God for ever: O prepare mercy and truth, which may preserve him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.61.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 8,
      "referenceLabel": "Psalms 61:8",
      "text": "So will I sing praise unto thy name for ever, that I may daily perform my vows.",
      "paragraphStart": false
    }
  ]
}
