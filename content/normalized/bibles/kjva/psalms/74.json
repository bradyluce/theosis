{
  "chapter": {
    "id": "kjva:psalms.74",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 74,
    "referenceLabel": "Psalms 74",
    "summary": "Source text for Psalms 74 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.74.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 1,
      "referenceLabel": "Psalms 74:1",
      "text": "O God, why hast thou cast us off for ever? why doth thine anger smoke against the sheep of thy pasture?",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.74.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 2,
      "referenceLabel": "Psalms 74:2",
      "text": "Remember thy congregation, which thou hast purchased of old; the rod of thine inheritance, which thou hast redeemed; this mount Zion, wherein thou hast dwelt.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 3,
      "referenceLabel": "Psalms 74:3",
      "text": "Lift up thy feet unto the perpetual desolations; even all that the enemy hath done wickedly in the sanctuary.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 4,
      "referenceLabel": "Psalms 74:4",
      "text": "Thine enemies roar in the midst of thy congregations; they set up their ensigns for signs.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 5,
      "referenceLabel": "Psalms 74:5",
      "text": "A man was famous according as he had lifted up axes upon the thick trees.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 6,
      "referenceLabel": "Psalms 74:6",
      "text": "But now they break down the carved work thereof at once with axes and hammers.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 7,
      "referenceLabel": "Psalms 74:7",
      "text": "They have cast fire into thy sanctuary, they have defiled by casting down the dwelling place of thy name to the ground.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 8,
      "referenceLabel": "Psalms 74:8",
      "text": "They said in their hearts, Let us destroy them together: they have burned up all the synagogues of God in the land.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 9,
      "referenceLabel": "Psalms 74:9",
      "text": "We see not our signs: there is no more any prophet: neither is there among us any that knoweth how long.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 10,
      "referenceLabel": "Psalms 74:10",
      "text": "O God, how long shall the adversary reproach? shall the enemy blaspheme thy name for ever?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 11,
      "referenceLabel": "Psalms 74:11",
      "text": "Why withdrawest thou thy hand, even thy right hand? pluck it out of thy bosom.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 12,
      "referenceLabel": "Psalms 74:12",
      "text": "For God is my King of old, working salvation in the midst of the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 13,
      "referenceLabel": "Psalms 74:13",
      "text": "Thou didst divide the sea by thy strength: thou brakest the heads of the dragons in the waters.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 14,
      "referenceLabel": "Psalms 74:14",
      "text": "Thou brakest the heads of leviathan in pieces, and gavest him to be meat to the people inhabiting the wilderness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 15,
      "referenceLabel": "Psalms 74:15",
      "text": "Thou didst cleave the fountain and the flood: thou driedst up mighty rivers.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 16,
      "referenceLabel": "Psalms 74:16",
      "text": "The day is thine, the night also is thine: thou hast prepared the light and the sun.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 17,
      "referenceLabel": "Psalms 74:17",
      "text": "Thou hast set all the borders of the earth: thou hast made summer and winter.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 18,
      "referenceLabel": "Psalms 74:18",
      "text": "Remember this, that the enemy hath reproached, O Lord, and that the foolish people have blasphemed thy name.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 19,
      "referenceLabel": "Psalms 74:19",
      "text": "O deliver not the soul of thy turtledove unto the multitude of the wicked: forget not the congregation of thy poor for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 20,
      "referenceLabel": "Psalms 74:20",
      "text": "Have respect unto the covenant: for the dark places of the earth are full of the habitations of cruelty.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 21,
      "referenceLabel": "Psalms 74:21",
      "text": "O let not the oppressed return ashamed: let the poor and needy praise thy name.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 22,
      "referenceLabel": "Psalms 74:22",
      "text": "Arise, O God, plead thine own cause: remember how the foolish man reproacheth thee daily.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.74.23",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 23,
      "referenceLabel": "Psalms 74:23",
      "text": "Forget not the voice of thine enemies: the tumult of those that rise up against thee increaseth continually.",
      "paragraphStart": false
    }
  ]
}
