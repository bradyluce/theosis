{
  "chapter": {
    "id": "kjva:psalms.140",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 140,
    "referenceLabel": "Psalms 140",
    "summary": "Source text for Psalms 140 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.140.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 1,
      "referenceLabel": "Psalms 140:1",
      "text": "Deliver me, O Lord, from the evil man: preserve me from the violent man;",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.140.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 2,
      "referenceLabel": "Psalms 140:2",
      "text": "Which imagine mischiefs in their heart; continually are they gathered together for war.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.140.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 3,
      "referenceLabel": "Psalms 140:3",
      "text": "They have sharpened their tongues like a serpent; adders’ poison is under their lips. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.140.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 4,
      "referenceLabel": "Psalms 140:4",
      "text": "Keep me, O Lord, from the hands of the wicked; preserve me from the violent man; who have purposed to overthrow my goings.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.140.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 5,
      "referenceLabel": "Psalms 140:5",
      "text": "The proud have hid a snare for me, and cords; they have spread a net by the wayside; they have set gins for me. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.140.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 6,
      "referenceLabel": "Psalms 140:6",
      "text": "I said unto the Lord, Thou art my God: hear the voice of my supplications, O Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.140.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 7,
      "referenceLabel": "Psalms 140:7",
      "text": "O God the Lord, the strength of my salvation, thou hast covered my head in the day of battle.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.140.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 8,
      "referenceLabel": "Psalms 140:8",
      "text": "Grant not, O Lord, the desires of the wicked: further not his wicked device; lest they exalt themselves. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.140.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 9,
      "referenceLabel": "Psalms 140:9",
      "text": "As for the head of those that compass me about, let the mischief of their own lips cover them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.140.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 10,
      "referenceLabel": "Psalms 140:10",
      "text": "Let burning coals fall upon them: let them be cast into the fire; into deep pits, that they rise not up again.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.140.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 11,
      "referenceLabel": "Psalms 140:11",
      "text": "Let not an evil speaker be established in the earth: evil shall hunt the violent man to overthrow him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.140.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 12,
      "referenceLabel": "Psalms 140:12",
      "text": "I know that the Lord will maintain the cause of the afflicted, and the right of the poor.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.140.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 13,
      "referenceLabel": "Psalms 140:13",
      "text": "Surely the righteous shall give thanks unto thy name: the upright shall dwell in thy presence.",
      "paragraphStart": false
    }
  ]
}
