{
  "chapter": {
    "id": "kjva:psalms.98",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 98,
    "referenceLabel": "Psalms 98",
    "summary": "Source text for Psalms 98 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.98.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 1,
      "referenceLabel": "Psalms 98:1",
      "text": "O sing unto the Lord a new song; for he hath done marvellous things: his right hand, and his holy arm, hath gotten him the victory.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.98.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 2,
      "referenceLabel": "Psalms 98:2",
      "text": "The Lord hath made known his salvation: his righteousness hath he openly shewed in the sight of the heathen.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.98.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 3,
      "referenceLabel": "Psalms 98:3",
      "text": "He hath remembered his mercy and his truth toward the house of Israel: all the ends of the earth have seen the salvation of our God.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.98.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 4,
      "referenceLabel": "Psalms 98:4",
      "text": "Make a joyful noise unto the Lord, all the earth: make a loud noise, and rejoice, and sing praise.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.98.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 5,
      "referenceLabel": "Psalms 98:5",
      "text": "Sing unto the Lord with the harp; with the harp, and the voice of a psalm.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.98.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 6,
      "referenceLabel": "Psalms 98:6",
      "text": "With trumpets and sound of cornet make a joyful noise before the Lord, the King.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.98.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 7,
      "referenceLabel": "Psalms 98:7",
      "text": "Let the sea roar, and the fulness thereof; the world, and they that dwell therein.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.98.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 8,
      "referenceLabel": "Psalms 98:8",
      "text": "Let the floods clap their hands: let the hills be joyful together",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.98.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 9,
      "referenceLabel": "Psalms 98:9",
      "text": "Before the Lord; for he cometh to judge the earth: with righteousness shall he judge the world, and the people with equity.",
      "paragraphStart": false
    }
  ]
}
