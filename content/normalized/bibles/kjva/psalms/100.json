    "bookSlug": "psalms",
    "chapterNumber": 100,
    "referenceLabel": "Psalms 100",
    "summary": "Source text for Psalms 100 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.100.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 1,
      "referenceLabel": "Psalms 100:1",
      "text": "Make a joyful noise unto the Lord, all ye lands.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.100.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 2,
      "referenceLabel": "Psalms 100:2",
      "text": "Serve the Lord with gladness: come before his presence with singing.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.100.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 3,
      "referenceLabel": "Psalms 100:3",
      "text": "Know ye that the Lord he is God: it is he that hath made us, and not we ourselves; we are his people, and the sheep of his pasture.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.100.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 4,
      "referenceLabel": "Psalms 100:4",
      "text": "Enter into his gates with thanksgiving, and into his courts with praise: be thankful unto him, and bless his name.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.100.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 5,
      "referenceLabel": "Psalms 100:5",
      "text": "For the Lord is good; his mercy is everlasting; and his truth endureth to all generations.",
      "paragraphStart": false
    }
  ]
}
