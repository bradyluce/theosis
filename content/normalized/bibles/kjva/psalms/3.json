{
  "chapter": {
    "id": "kjva:psalms.3",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 3,
    "referenceLabel": "Psalms 3",
    "summary": "Source text for Psalms 3 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.3.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Psalms 3:1",
      "text": "Lord, how are they increased that trouble me! many are they that rise up against me.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.3.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Psalms 3:2",
      "text": "Many there be which say of my soul, There is no help for him in God. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.3.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Psalms 3:3",
      "text": "But thou, O Lord, art a shield for me; my glory, and the lifter up of mine head.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.3.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Psalms 3:4",
      "text": "I cried unto the Lord with my voice, and he heard me out of his holy hill. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.3.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Psalms 3:5",
      "text": "I laid me down and slept; I awaked; for the Lord sustained me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.3.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Psalms 3:6",
      "text": "I will not be afraid of ten thousands of people, that have set themselves against me round about.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.3.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Psalms 3:7",
      "text": "Arise, O Lord; save me, O my God: for thou hast smitten all mine enemies upon the cheek bone; thou hast broken the teeth of the ungodly.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.3.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Psalms 3:8",
      "text": "Salvation belongeth unto the Lord: thy blessing is upon thy people. Selah.",
      "paragraphStart": false
    }
  ]
}
