{
  "chapter": {
    "id": "kjva:psalms.95",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 95,
    "referenceLabel": "Psalms 95",
    "summary": "Source text for Psalms 95 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.95.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 1,
      "referenceLabel": "Psalms 95:1",
      "text": "O come, let us sing unto the Lord: let us make a joyful noise to the rock of our salvation.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.95.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 2,
      "referenceLabel": "Psalms 95:2",
      "text": "Let us come before his presence with thanksgiving, and make a joyful noise unto him with psalms.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.95.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 3,
      "referenceLabel": "Psalms 95:3",
      "text": "For the Lord is a great God, and a great King above all gods.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.95.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 4,
      "referenceLabel": "Psalms 95:4",
      "text": "In his hand are the deep places of the earth: the strength of the hills is his also.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.95.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 5,
      "referenceLabel": "Psalms 95:5",
      "text": "The sea is his, and he made it: and his hands formed the dry land.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.95.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 6,
      "referenceLabel": "Psalms 95:6",
      "text": "O come, let us worship and bow down: let us kneel before the Lord our maker.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.95.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 7,
      "referenceLabel": "Psalms 95:7",
      "text": "For he is our God; and we are the people of his pasture, and the sheep of his hand. To day if ye will hear his voice,",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.95.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 8,
      "referenceLabel": "Psalms 95:8",
      "text": "Harden not your heart, as in the provocation, and as in the day of temptation in the wilderness:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.95.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 9,
      "referenceLabel": "Psalms 95:9",
      "text": "When your fathers tempted me, proved me, and saw my work.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.95.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 10,
      "referenceLabel": "Psalms 95:10",
      "text": "Forty years long was I grieved with this generation, and said, It is a people that do err in their heart, and they have not known my ways:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.95.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 11,
      "referenceLabel": "Psalms 95:11",
      "text": "Unto whom I sware in my wrath that they should not enter into my rest.",
      "paragraphStart": false
    }
  ]
}
