{
  "chapter": {
    "id": "kjva:psalms.8",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 8,
    "referenceLabel": "Psalms 8",
    "summary": "Source text for Psalms 8 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.8.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Psalms 8:1",
      "text": "O Lord our Lord, how excellent is thy name in all the earth! who hast set thy glory above the heavens.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.8.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Psalms 8:2",
      "text": "Out of the mouth of babes and sucklings hast thou ordained strength because of thine enemies, that thou mightest still the enemy and the avenger.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.8.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Psalms 8:3",
      "text": "When I consider thy heavens, the work of thy fingers, the moon and the stars, which thou hast ordained;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.8.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Psalms 8:4",
      "text": "What is man, that thou art mindful of him? and the son of man, that thou visitest him?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.8.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Psalms 8:5",
      "text": "For thou hast made him a little lower than the angels, and hast crowned him with glory and honour.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.8.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Psalms 8:6",
      "text": "Thou madest him to have dominion over the works of thy hands; thou hast put all things under his feet:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.8.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Psalms 8:7",
      "text": "All sheep and oxen, yea, and the beasts of the field;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.8.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Psalms 8:8",
      "text": "The fowl of the air, and the fish of the sea, and whatsoever passeth through the paths of the seas.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.8.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Psalms 8:9",
      "text": "O Lord our Lord, how excellent is thy name in all the earth!",
      "paragraphStart": false
    }
  ]
}
