{
  "chapter": {
    "id": "kjva:psalms.94",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 94,
    "referenceLabel": "Psalms 94",
    "summary": "Source text for Psalms 94 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.94.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 1,
      "referenceLabel": "Psalms 94:1",
      "text": "O Lord God, to whom vengeance belongeth; O God, to whom vengeance belongeth, shew thyself.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.94.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 2,
      "referenceLabel": "Psalms 94:2",
      "text": "Lift up thyself, thou judge of the earth: render a reward to the proud.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 3,
      "referenceLabel": "Psalms 94:3",
      "text": "Lord, how long shall the wicked, how long shall the wicked triumph?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 4,
      "referenceLabel": "Psalms 94:4",
      "text": "How long shall they utter and speak hard things? and all the workers of iniquity boast themselves?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 5,
      "referenceLabel": "Psalms 94:5",
      "text": "They break in pieces thy people, O Lord, and afflict thine heritage.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 6,
      "referenceLabel": "Psalms 94:6",
      "text": "They slay the widow and the stranger, and murder the fatherless.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 7,
      "referenceLabel": "Psalms 94:7",
      "text": "Yet they say, The Lord shall not see, neither shall the God of Jacob regard it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 8,
      "referenceLabel": "Psalms 94:8",
      "text": "Understand, ye brutish among the people: and ye fools, when will ye be wise?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 9,
      "referenceLabel": "Psalms 94:9",
      "text": "He that planted the ear, shall he not hear? he that formed the eye, shall he not see?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 10,
      "referenceLabel": "Psalms 94:10",
      "text": "He that chastiseth the heathen, shall not he correct? he that teacheth man knowledge, shall not he know?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 11,
      "referenceLabel": "Psalms 94:11",
      "text": "The Lord knoweth the thoughts of man, that they are vanity.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 12,
      "referenceLabel": "Psalms 94:12",
      "text": "Blessed is the man whom thou chastenest, O Lord, and teachest him out of thy law;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 13,
      "referenceLabel": "Psalms 94:13",
      "text": "That thou mayest give him rest from the days of adversity, until the pit be digged for the wicked.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 14,
      "referenceLabel": "Psalms 94:14",
      "text": "For the Lord will not cast off his people, neither will he forsake his inheritance.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 15,
      "referenceLabel": "Psalms 94:15",
      "text": "But judgment shall return unto righteousness: and all the upright in heart shall follow it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 16,
      "referenceLabel": "Psalms 94:16",
      "text": "Who will rise up for me against the evildoers? or who will stand up for me against the workers of iniquity?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 17,
      "referenceLabel": "Psalms 94:17",
      "text": "Unless the Lord had been my help, my soul had almost dwelt in silence.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 18,
      "referenceLabel": "Psalms 94:18",
      "text": "When I said, My foot slippeth; thy mercy, O Lord, held me up.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 19,
      "referenceLabel": "Psalms 94:19",
      "text": "In the multitude of my thoughts within me thy comforts delight my soul.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 20,
      "referenceLabel": "Psalms 94:20",
      "text": "Shall the throne of iniquity have fellowship with thee, which frameth mischief by a law?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 21,
      "referenceLabel": "Psalms 94:21",
      "text": "They gather themselves together against the soul of the righteous, and condemn the innocent blood.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 22,
      "referenceLabel": "Psalms 94:22",
      "text": "But the Lord is my defence; and my God is the rock of my refuge.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.94.23",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 23,
      "referenceLabel": "Psalms 94:23",
      "text": "And he shall bring upon them their own iniquity, and shall cut them off in their own wickedness; yea, the Lord our God shall cut them off.",
      "paragraphStart": false
    }
  ]
}
