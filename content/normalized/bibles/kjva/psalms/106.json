{
  "chapter": {
    "id": "kjva:psalms.106",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 106,
    "referenceLabel": "Psalms 106",
    "summary": "Source text for Psalms 106 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.106.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 1,
      "referenceLabel": "Psalms 106:1",
      "text": "Praise ye the Lord. O give thanks unto the Lord; for he is good: for his mercy endureth for ever.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.106.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 2,
      "referenceLabel": "Psalms 106:2",
      "text": "Who can utter the mighty acts of the Lord? who can shew forth all his praise?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 3,
      "referenceLabel": "Psalms 106:3",
      "text": "Blessed are they that keep judgment, and he that doeth righteousness at all times.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 4,
      "referenceLabel": "Psalms 106:4",
      "text": "Remember me, O Lord, with the favour that thou bearest unto thy people: O visit me with thy salvation;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 5,
      "referenceLabel": "Psalms 106:5",
      "text": "That I may see the good of thy chosen, that I may rejoice in the gladness of thy nation, that I may glory with thine inheritance.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 6,
      "referenceLabel": "Psalms 106:6",
      "text": "We have sinned with our fathers, we have committed iniquity, we have done wickedly.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 7,
      "referenceLabel": "Psalms 106:7",
      "text": "Our fathers understood not thy wonders in Egypt; they remembered not the multitude of thy mercies; but provoked him at the sea, even at the Red sea.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 8,
      "referenceLabel": "Psalms 106:8",
      "text": "Nevertheless he saved them for his name’s sake, that he might make his mighty power to be known.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 9,
      "referenceLabel": "Psalms 106:9",
      "text": "He rebuked the Red sea also, and it was dried up: so he led them through the depths, as through the wilderness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 10,
      "referenceLabel": "Psalms 106:10",
      "text": "And he saved them from the hand of him that hated them, and redeemed them from the hand of the enemy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 11,
      "referenceLabel": "Psalms 106:11",
      "text": "And the waters covered their enemies: there was not one of them left.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 12,
      "referenceLabel": "Psalms 106:12",
      "text": "Then believed they his words; they sang his praise.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 13,
      "referenceLabel": "Psalms 106:13",
      "text": "They soon forgat his works; they waited not for his counsel:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 14,
      "referenceLabel": "Psalms 106:14",
      "text": "But lusted exceedingly in the wilderness, and tempted God in the desert.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 15,
      "referenceLabel": "Psalms 106:15",
      "text": "And he gave them their request; but sent leanness into their soul.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 16,
      "referenceLabel": "Psalms 106:16",
      "text": "They envied Moses also in the camp, and Aaron the saint of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 17,
      "referenceLabel": "Psalms 106:17",
      "text": "The earth opened and swallowed up Dathan, and covered the company of Abiram.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 18,
      "referenceLabel": "Psalms 106:18",
      "text": "And a fire was kindled in their company; the flame burned up the wicked.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 19,
      "referenceLabel": "Psalms 106:19",
      "text": "They made a calf in Horeb, and worshipped the molten image.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 20,
      "referenceLabel": "Psalms 106:20",
      "text": "Thus they changed their glory into the similitude of an ox that eateth grass.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 21,
      "referenceLabel": "Psalms 106:21",
      "text": "They forgat God their saviour, which had done great things in Egypt;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 22,
      "referenceLabel": "Psalms 106:22",
      "text": "Wondrous works in the land of Ham, and terrible things by the Red sea.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.23",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 23,
      "referenceLabel": "Psalms 106:23",
      "text": "Therefore he said that he would destroy them, had not Moses his chosen stood before him in the breach, to turn away his wrath, lest he should destroy them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.24",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 24,
      "referenceLabel": "Psalms 106:24",
      "text": "Yea, they despised the pleasant land, they believed not his word:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.25",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 25,
      "referenceLabel": "Psalms 106:25",
      "text": "But murmured in their tents, and hearkened not unto the voice of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.26",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 26,
      "referenceLabel": "Psalms 106:26",
      "text": "Therefore he lifted up his hand against them, to overthrow them in the wilderness:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.27",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 27,
      "referenceLabel": "Psalms 106:27",
      "text": "To overthrow their seed also among the nations, and to scatter them in the lands.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.28",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 28,
      "referenceLabel": "Psalms 106:28",
      "text": "They joined themselves also unto Baal–peor, and ate the sacrifices of the dead.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.29",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 29,
      "referenceLabel": "Psalms 106:29",
      "text": "Thus they provoked him to anger with their inventions: and the plague brake in upon them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.30",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 30,
      "referenceLabel": "Psalms 106:30",
      "text": "Then stood up Phinehas, and executed judgment: and so the plague was stayed.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.31",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 31,
      "referenceLabel": "Psalms 106:31",
      "text": "And that was counted unto him for righteousness unto all generations for evermore.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.32",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 32,
      "referenceLabel": "Psalms 106:32",
      "text": "They angered him also at the waters of strife, so that it went ill with Moses for their sakes:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.33",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 33,
      "referenceLabel": "Psalms 106:33",
      "text": "Because they provoked his spirit, so that he spake unadvisedly with his lips.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.34",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 34,
      "referenceLabel": "Psalms 106:34",
      "text": "They did not destroy the nations, concerning whom the Lord commanded them:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.35",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 35,
      "referenceLabel": "Psalms 106:35",
      "text": "But were mingled among the heathen, and learned their works.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.36",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 36,
      "referenceLabel": "Psalms 106:36",
      "text": "And they served their idols: which were a snare unto them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.37",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 37,
      "referenceLabel": "Psalms 106:37",
      "text": "Yea, they sacrificed their sons and their daughters unto devils,",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.38",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 38,
      "referenceLabel": "Psalms 106:38",
      "text": "And shed innocent blood, even the blood of their sons and of their daughters, whom they sacrificed unto the idols of Canaan: and the land was polluted with blood.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.39",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 39,
      "referenceLabel": "Psalms 106:39",
      "text": "Thus were they defiled with their own works, and went a whoring with their own inventions.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.40",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 40,
      "referenceLabel": "Psalms 106:40",
      "text": "Therefore was the wrath of the Lord kindled against his people, insomuch that he abhorred his own inheritance.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.41",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 41,
      "referenceLabel": "Psalms 106:41",
      "text": "And he gave them into the hand of the heathen; and they that hated them ruled over them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.42",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 42,
      "referenceLabel": "Psalms 106:42",
      "text": "Their enemies also oppressed them, and they were brought into subjection under their hand.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.43",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 43,
      "referenceLabel": "Psalms 106:43",
      "text": "Many times did he deliver them; but they provoked him with their counsel, and were brought low for their iniquity.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.44",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 44,
      "referenceLabel": "Psalms 106:44",
      "text": "Nevertheless he regarded their affliction, when he heard their cry:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.45",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 45,
      "referenceLabel": "Psalms 106:45",
      "text": "And he remembered for them his covenant, and repented according to the multitude of his mercies.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.46",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 46,
      "referenceLabel": "Psalms 106:46",
      "text": "He made them also to be pitied of all those that carried them captives.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.47",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 47,
      "referenceLabel": "Psalms 106:47",
      "text": "Save us, O Lord our God, and gather us from among the heathen, to give thanks unto thy holy name, and to triumph in thy praise.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.106.48",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 48,
      "referenceLabel": "Psalms 106:48",
      "text": "Blessed be the Lord God of Israel from everlasting to everlasting: and let all the people say, Amen. Praise ye the Lord.",
      "paragraphStart": false
    }
  ]
}
