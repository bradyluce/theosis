{
  "chapter": {
    "id": "kjva:psalms.11",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 11,
    "referenceLabel": "Psalms 11",
    "summary": "Source text for Psalms 11 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.11.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Psalms 11:1",
      "text": "In the Lord put I my trust: how say ye to my soul, Flee as a bird to your mountain?",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.11.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Psalms 11:2",
      "text": "For, lo, the wicked bend their bow, they make ready their arrow upon the string, that they may privily shoot at the upright in heart.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.11.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Psalms 11:3",
      "text": "If the foundations be destroyed, what can the righteous do?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.11.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Psalms 11:4",
      "text": "The Lord is in his holy temple, the Lord’s throne is in heaven: his eyes behold, his eyelids try, the children of men.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.11.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Psalms 11:5",
      "text": "The Lord trieth the righteous: but the wicked and him that loveth violence his soul hateth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.11.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Psalms 11:6",
      "text": "Upon the wicked he shall rain snares, fire and brimstone, and an horrible tempest: this shall be the portion of their cup.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.11.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Psalms 11:7",
      "text": "For the righteous Lord loveth righteousness; his countenance doth behold the upright.",
      "paragraphStart": false
    }
  ]
}
