{
  "chapter": {
    "id": "kjva:psalms.24",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 24,
    "referenceLabel": "Psalms 24",
    "summary": "Source text for Psalms 24 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.24.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Psalms 24:1",
      "text": "The earth is the Lord’s, and the fulness thereof; the world, and they that dwell therein.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.24.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Psalms 24:2",
      "text": "For he hath founded it upon the seas, and established it upon the floods.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.24.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Psalms 24:3",
      "text": "Who shall ascend into the hill of the Lord? or who shall stand in his holy place?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.24.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Psalms 24:4",
      "text": "He that hath clean hands, and a pure heart; who hath not lifted up his soul unto vanity, nor sworn deceitfully.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.24.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Psalms 24:5",
      "text": "He shall receive the blessing from the Lord, and righteousness from the God of his salvation.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.24.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Psalms 24:6",
      "text": "This is the generation of them that seek him, that seek thy face, O Jacob. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.24.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Psalms 24:7",
      "text": "Lift up your heads, O ye gates; and be ye lift up, ye everlasting doors; and the King of glory shall come in.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.24.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Psalms 24:8",
      "text": "Who is this King of glory? The Lord strong and mighty, the Lord mighty in battle.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.24.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Psalms 24:9",
      "text": "Lift up your heads, O ye gates; even lift them up, ye everlasting doors; and the King of glory shall come in.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.24.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Psalms 24:10",
      "text": "Who is this King of glory? The Lord of hosts, he is the King of glory. Selah.",
      "paragraphStart": false
    }
  ]
}
