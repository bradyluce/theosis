{
  "chapter": {
    "id": "kjva:psalms.64",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 64,
    "referenceLabel": "Psalms 64",
    "summary": "Source text for Psalms 64 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.64.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 1,
      "referenceLabel": "Psalms 64:1",
      "text": "Hear my voice, O God, in my prayer: preserve my life from fear of the enemy.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.64.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 2,
      "referenceLabel": "Psalms 64:2",
      "text": "Hide me from the secret counsel of the wicked; from the insurrection of the workers of iniquity:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.64.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 3,
      "referenceLabel": "Psalms 64:3",
      "text": "Who whet their tongue like a sword, and bend their bows to shoot their arrows, even bitter words:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.64.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 4,
      "referenceLabel": "Psalms 64:4",
      "text": "That they may shoot in secret at the perfect: suddenly do they shoot at him, and fear not.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.64.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 5,
      "referenceLabel": "Psalms 64:5",
      "text": "They encourage themselves in an evil matter: they commune of laying snares privily; they say, Who shall see them?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.64.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 6,
      "referenceLabel": "Psalms 64:6",
      "text": "They search out iniquities; they accomplish a diligent search: both the inward thought of every one of them, and the heart, is deep.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.64.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 7,
      "referenceLabel": "Psalms 64:7",
      "text": "But God shall shoot at them with an arrow; suddenly shall they be wounded.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.64.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 8,
      "referenceLabel": "Psalms 64:8",
      "text": "So they shall make their own tongue to fall upon themselves: all that see them shall flee away.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.64.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 9,
      "referenceLabel": "Psalms 64:9",
      "text": "And all men shall fear, and shall declare the work of God; for they shall wisely consider of his doing.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.64.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 10,
      "referenceLabel": "Psalms 64:10",
      "text": "The righteous shall be glad in the Lord, and shall trust in him; and all the upright in heart shall glory.",
      "paragraphStart": false
    }
  ]
}
