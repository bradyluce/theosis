{
  "chapter": {
    "id": "kjva:psalms.118",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 118,
    "referenceLabel": "Psalms 118",
    "summary": "Source text for Psalms 118 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.118.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 1,
      "referenceLabel": "Psalms 118:1",
      "text": "O give thanks unto the Lord; for he is good: because his mercy endureth for ever.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.118.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 2,
      "referenceLabel": "Psalms 118:2",
      "text": "Let Israel now say, that his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 3,
      "referenceLabel": "Psalms 118:3",
      "text": "Let the house of Aaron now say, that his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 4,
      "referenceLabel": "Psalms 118:4",
      "text": "Let them now that fear the Lord say, that his mercy endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 5,
      "referenceLabel": "Psalms 118:5",
      "text": "I called upon the Lord in distress: the Lord answered me, and set me in a large place.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 6,
      "referenceLabel": "Psalms 118:6",
      "text": "The Lord is on my side; I will not fear: what can man do unto me?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 7,
      "referenceLabel": "Psalms 118:7",
      "text": "The Lord taketh my part with them that help me: therefore shall I see my desire upon them that hate me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 8,
      "referenceLabel": "Psalms 118:8",
      "text": "It is better to trust in the Lord than to put confidence in man.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 9,
      "referenceLabel": "Psalms 118:9",
      "text": "It is better to trust in the Lord than to put confidence in princes.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 10,
      "referenceLabel": "Psalms 118:10",
      "text": "All nations compassed me about: but in the name of the Lord will I destroy them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 11,
      "referenceLabel": "Psalms 118:11",
      "text": "They compassed me about; yea, they compassed me about: but in the name of the Lord I will destroy them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 12,
      "referenceLabel": "Psalms 118:12",
      "text": "They compassed me about like bees; they are quenched as the fire of thorns: for in the name of the Lord I will destroy them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 13,
      "referenceLabel": "Psalms 118:13",
      "text": "Thou hast thrust sore at me that I might fall: but the Lord helped me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 14,
      "referenceLabel": "Psalms 118:14",
      "text": "The Lord is my strength and song, and is become my salvation.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 15,
      "referenceLabel": "Psalms 118:15",
      "text": "The voice of rejoicing and salvation is in the tabernacles of the righteous: the right hand of the Lord doeth valiantly.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 16,
      "referenceLabel": "Psalms 118:16",
      "text": "The right hand of the Lord is exalted: the right hand of the Lord doeth valiantly.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 17,
      "referenceLabel": "Psalms 118:17",
      "text": "I shall not die, but live, and declare the works of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 18,
      "referenceLabel": "Psalms 118:18",
      "text": "The Lord hath chastened me sore: but he hath not given me over unto death.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 19,
      "referenceLabel": "Psalms 118:19",
      "text": "Open to me the gates of righteousness: I will go into them, and I will praise the Lord:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 20,
      "referenceLabel": "Psalms 118:20",
      "text": "This gate of the Lord, into which the righteous shall enter.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 21,
      "referenceLabel": "Psalms 118:21",
      "text": "I will praise thee: for thou hast heard me, and art become my salvation.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 22,
      "referenceLabel": "Psalms 118:22",
      "text": "The stone which the builders refused is become the head stone of the corner.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.23",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 23,
      "referenceLabel": "Psalms 118:23",
      "text": "This is the Lord’s doing; it is marvellous in our eyes.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.24",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 24,
      "referenceLabel": "Psalms 118:24",
      "text": "This is the day which the Lord hath made; we will rejoice and be glad in it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.25",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 25,
      "referenceLabel": "Psalms 118:25",
      "text": "Save now, I beseech thee, O Lord: O Lord, I beseech thee, send now prosperity.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.26",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 26,
      "referenceLabel": "Psalms 118:26",
      "text": "Blessed be he that cometh in the name of the Lord: we have blessed you out of the house of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.27",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 27,
      "referenceLabel": "Psalms 118:27",
      "text": "God is the Lord, which hath shewed us light: bind the sacrifice with cords, even unto the horns of the altar.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.28",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 28,
      "referenceLabel": "Psalms 118:28",
      "text": "Thou art my God, and I will praise thee: thou art my God, I will exalt thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.118.29",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 29,
      "referenceLabel": "Psalms 118:29",
      "text": "O give thanks unto the Lord; for he is good: for his mercy endureth for ever.",
      "paragraphStart": false
    }
  ]
}
