{
  "chapter": {
    "id": "kjva:psalms.91",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 91,
    "referenceLabel": "Psalms 91",
    "summary": "Source text for Psalms 91 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.91.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 1,
      "referenceLabel": "Psalms 91:1",
      "text": "He that dwelleth in the secret place of the most High shall abide under the shadow of the Almighty.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.91.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 2,
      "referenceLabel": "Psalms 91:2",
      "text": "I will say of the Lord, He is my refuge and my fortress: my God; in him will I trust.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.91.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 3,
      "referenceLabel": "Psalms 91:3",
      "text": "Surely he shall deliver thee from the snare of the fowler, and from the noisome pestilence.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.91.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 4,
      "referenceLabel": "Psalms 91:4",
      "text": "He shall cover thee with his feathers, and under his wings shalt thou trust: his truth shall be thy shield and buckler.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.91.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 5,
      "referenceLabel": "Psalms 91:5",
      "text": "Thou shalt not be afraid for the terror by night; nor for the arrow that flieth by day;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.91.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 6,
      "referenceLabel": "Psalms 91:6",
      "text": "Nor for the pestilence that walketh in darkness; nor for the destruction that wasteth at noonday.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.91.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 7,
      "referenceLabel": "Psalms 91:7",
      "text": "A thousand shall fall at thy side, and ten thousand at thy right hand; but it shall not come nigh thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.91.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 8,
      "referenceLabel": "Psalms 91:8",
      "text": "Only with thine eyes shalt thou behold and see the reward of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.91.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 9,
      "referenceLabel": "Psalms 91:9",
      "text": "Because thou hast made the Lord, which is my refuge, even the most High, thy habitation;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.91.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 10,
      "referenceLabel": "Psalms 91:10",
      "text": "There shall no evil befall thee, neither shall any plague come nigh thy dwelling.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.91.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 11,
      "referenceLabel": "Psalms 91:11",
      "text": "For he shall give his angels charge over thee, to keep thee in all thy ways.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.91.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 12,
      "referenceLabel": "Psalms 91:12",
      "text": "They shall bear thee up in their hands, lest thou dash thy foot against a stone.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.91.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 13,
      "referenceLabel": "Psalms 91:13",
      "text": "Thou shalt tread upon the lion and adder: the young lion and the dragon shalt thou trample under feet.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.91.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 14,
      "referenceLabel": "Psalms 91:14",
      "text": "Because he hath set his love upon me, therefore will I deliver him: I will set him on high, because he hath known my name.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.91.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 15,
      "referenceLabel": "Psalms 91:15",
      "text": "He shall call upon me, and I will answer him: I will be with him in trouble; I will deliver him, and honour him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.91.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 16,
      "referenceLabel": "Psalms 91:16",
      "text": "With long life will I satisfy him, and shew him my salvation.",
      "paragraphStart": false
    }
  ]
}
