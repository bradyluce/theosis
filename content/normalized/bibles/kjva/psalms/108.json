{
  "chapter": {
    "id": "kjva:psalms.108",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 108,
    "referenceLabel": "Psalms 108",
    "summary": "Source text for Psalms 108 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.108.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 1,
      "referenceLabel": "Psalms 108:1",
      "text": "O God, my heart is fixed; I will sing and give praise, even with my glory.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.108.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 2,
      "referenceLabel": "Psalms 108:2",
      "text": "Awake, psaltery and harp: I myself will awake early.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.108.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 3,
      "referenceLabel": "Psalms 108:3",
      "text": "I will praise thee, O Lord, among the people: and I will sing praises unto thee among the nations.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.108.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 4,
      "referenceLabel": "Psalms 108:4",
      "text": "For thy mercy is great above the heavens: and thy truth reacheth unto the clouds.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.108.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 5,
      "referenceLabel": "Psalms 108:5",
      "text": "Be thou exalted, O God, above the heavens: and thy glory above all the earth;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.108.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 6,
      "referenceLabel": "Psalms 108:6",
      "text": "That thy beloved may be delivered: save with thy right hand, and answer me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.108.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 7,
      "referenceLabel": "Psalms 108:7",
      "text": "God hath spoken in his holiness; I will rejoice, I will divide Shechem, and mete out the valley of Succoth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.108.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 8,
      "referenceLabel": "Psalms 108:8",
      "text": "Gilead is mine; Manasseh is mine; Ephraim also is the strength of mine head; Judah is my lawgiver;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.108.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 9,
      "referenceLabel": "Psalms 108:9",
      "text": "Moab is my washpot; over Edom will I cast out my shoe; over Philistia will I triumph.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.108.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 10,
      "referenceLabel": "Psalms 108:10",
      "text": "Who will bring me into the strong city? who will lead me into Edom?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.108.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 11,
      "referenceLabel": "Psalms 108:11",
      "text": "Wilt not thou, O God, who hast cast us off? and wilt not thou, O God, go forth with our hosts?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.108.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 12,
      "referenceLabel": "Psalms 108:12",
      "text": "Give us help from trouble: for vain is the help of man.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.108.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 13,
      "referenceLabel": "Psalms 108:13",
      "text": "Through God we shall do valiantly: for he it is that shall tread down our enemies.",
      "paragraphStart": false
    }
  ]
}
