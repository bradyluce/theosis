{
  "chapter": {
    "id": "kjva:psalms.149",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 149,
    "referenceLabel": "Psalms 149",
    "summary": "Source text for Psalms 149 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.149.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 1,
      "referenceLabel": "Psalms 149:1",
      "text": "Praise ye the Lord. Sing unto the Lord a new song, and his praise in the congregation of saints.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.149.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 2,
      "referenceLabel": "Psalms 149:2",
      "text": "Let Israel rejoice in him that made him: let the children of Zion be joyful in their King.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.149.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 3,
      "referenceLabel": "Psalms 149:3",
      "text": "Let them praise his name in the dance: let them sing praises unto him with the timbrel and harp.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.149.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 4,
      "referenceLabel": "Psalms 149:4",
      "text": "For the Lord taketh pleasure in his people: he will beautify the meek with salvation.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.149.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 5,
      "referenceLabel": "Psalms 149:5",
      "text": "Let the saints be joyful in glory: let them sing aloud upon their beds.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.149.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 6,
      "referenceLabel": "Psalms 149:6",
      "text": "Let the high praises of God be in their mouth, and a twoedged sword in their hand;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.149.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 7,
      "referenceLabel": "Psalms 149:7",
      "text": "To execute vengeance upon the heathen, and punishments upon the people;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.149.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 8,
      "referenceLabel": "Psalms 149:8",
      "text": "To bind their kings with chains, and their nobles with fetters of iron;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.149.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 9,
      "referenceLabel": "Psalms 149:9",
      "text": "To execute upon them the judgment written: this honour have all his saints. Praise ye the Lord.",
      "paragraphStart": false
    }
  ]
}
