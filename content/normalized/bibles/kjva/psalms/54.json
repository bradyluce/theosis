{
  "chapter": {
    "id": "kjva:psalms.54",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 54,
    "referenceLabel": "Psalms 54",
    "summary": "Source text for Psalms 54 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.54.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 1,
      "referenceLabel": "Psalms 54:1",
      "text": "Save me, O God, by thy name, and judge me by thy strength.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.54.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 2,
      "referenceLabel": "Psalms 54:2",
      "text": "Hear my prayer, O God; give ear to the words of my mouth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.54.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 3,
      "referenceLabel": "Psalms 54:3",
      "text": "For strangers are risen up against me, and oppressors seek after my soul: they have not set God before them. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.54.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 4,
      "referenceLabel": "Psalms 54:4",
      "text": "Behold, God is mine helper: the Lord is with them that uphold my soul.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.54.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 5,
      "referenceLabel": "Psalms 54:5",
      "text": "He shall reward evil unto mine enemies: cut them off in thy truth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.54.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 6,
      "referenceLabel": "Psalms 54:6",
      "text": "I will freely sacrifice unto thee: I will praise thy name, O Lord; for it is good.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.54.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 7,
      "referenceLabel": "Psalms 54:7",
      "text": "For he hath delivered me out of all trouble: and mine eye hath seen his desire upon mine enemies.",
      "paragraphStart": false
    }
  ]
}
