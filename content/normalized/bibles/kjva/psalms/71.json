{
  "chapter": {
    "id": "kjva:psalms.71",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 71,
    "referenceLabel": "Psalms 71",
    "summary": "Source text for Psalms 71 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.71.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 1,
      "referenceLabel": "Psalms 71:1",
      "text": "In thee, O Lord, do I put my trust: let me never be put to confusion.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.71.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 2,
      "referenceLabel": "Psalms 71:2",
      "text": "Deliver me in thy righteousness, and cause me to escape: incline thine ear unto me, and save me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 3,
      "referenceLabel": "Psalms 71:3",
      "text": "Be thou my strong habitation, whereunto I may continually resort: thou hast given commandment to save me; for thou art my rock and my fortress.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 4,
      "referenceLabel": "Psalms 71:4",
      "text": "Deliver me, O my God, out of the hand of the wicked, out of the hand of the unrighteous and cruel man.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 5,
      "referenceLabel": "Psalms 71:5",
      "text": "For thou art my hope, O Lord God: thou art my trust from my youth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 6,
      "referenceLabel": "Psalms 71:6",
      "text": "By thee have I been holden up from the womb: thou art he that took me out of my mother’s bowels: my praise shall be continually of thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 7,
      "referenceLabel": "Psalms 71:7",
      "text": "I am as a wonder unto many; but thou art my strong refuge.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 8,
      "referenceLabel": "Psalms 71:8",
      "text": "Let my mouth be filled with thy praise and with thy honour all the day.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 9,
      "referenceLabel": "Psalms 71:9",
      "text": "Cast me not off in the time of old age; forsake me not when my strength faileth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 10,
      "referenceLabel": "Psalms 71:10",
      "text": "For mine enemies speak against me; and they that lay wait for my soul take counsel together,",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 11,
      "referenceLabel": "Psalms 71:11",
      "text": "Saying, God hath forsaken him: persecute and take him; for there is none to deliver him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 12,
      "referenceLabel": "Psalms 71:12",
      "text": "O God, be not far from me: O my God, make haste for my help.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 13,
      "referenceLabel": "Psalms 71:13",
      "text": "Let them be confounded and consumed that are adversaries to my soul; let them be covered with reproach and dishonour that seek my hurt.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 14,
      "referenceLabel": "Psalms 71:14",
      "text": "But I will hope continually, and will yet praise thee more and more.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 15,
      "referenceLabel": "Psalms 71:15",
      "text": "My mouth shall shew forth thy righteousness and thy salvation all the day; for I know not the numbers thereof.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 16,
      "referenceLabel": "Psalms 71:16",
      "text": "I will go in the strength of the Lord God: I will make mention of thy righteousness, even of thine only.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 17,
      "referenceLabel": "Psalms 71:17",
      "text": "O God, thou hast taught me from my youth: and hitherto have I declared thy wondrous works.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 18,
      "referenceLabel": "Psalms 71:18",
      "text": "Now also when I am old and grayheaded, O God, forsake me not; until I have shewed thy strength unto this generation, and thy power to every one that is to come.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 19,
      "referenceLabel": "Psalms 71:19",
      "text": "Thy righteousness also, O God, is very high, who hast done great things: O God, who is like unto thee!",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 20,
      "referenceLabel": "Psalms 71:20",
      "text": "Thou, which hast shewed me great and sore troubles, shalt quicken me again, and shalt bring me up again from the depths of the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 21,
      "referenceLabel": "Psalms 71:21",
      "text": "Thou shalt increase my greatness, and comfort me on every side.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 22,
      "referenceLabel": "Psalms 71:22",
      "text": "I will also praise thee with the psaltery, even thy truth, O my God: unto thee will I sing with the harp, O thou Holy One of Israel.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.23",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 23,
      "referenceLabel": "Psalms 71:23",
      "text": "My lips shall greatly rejoice when I sing unto thee; and my soul, which thou hast redeemed.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.71.24",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 24,
      "referenceLabel": "Psalms 71:24",
      "text": "My tongue also shall talk of thy righteousness all the day long: for they are confounded, for they are brought unto shame, that seek my hurt.",
      "paragraphStart": false
    }
  ]
}
