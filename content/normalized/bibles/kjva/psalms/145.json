{
  "chapter": {
    "id": "kjva:psalms.145",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 145,
    "referenceLabel": "Psalms 145",
    "summary": "Source text for Psalms 145 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.145.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 1,
      "referenceLabel": "Psalms 145:1",
      "text": "I will extol thee, my God, O king; and I will bless thy name for ever and ever.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.145.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 2,
      "referenceLabel": "Psalms 145:2",
      "text": "Every day will I bless thee; and I will praise thy name for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.145.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 3,
      "referenceLabel": "Psalms 145:3",
      "text": "Great is the Lord, and greatly to be praised; and his greatness is unsearchable.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.145.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 4,
      "referenceLabel": "Psalms 145:4",
      "text": "One generation shall praise thy works to another, and shall declare thy mighty acts.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.145.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 5,
      "referenceLabel": "Psalms 145:5",
      "text": "I will speak of the glorious honour of thy majesty, and of thy wondrous works.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.145.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 6,
      "referenceLabel": "Psalms 145:6",
      "text": "And men shall speak of the might of thy terrible acts: and I will declare thy greatness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.145.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 7,
      "referenceLabel": "Psalms 145:7",
      "text": "They shall abundantly utter the memory of thy great goodness, and shall sing of thy righteousness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.145.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 8,
      "referenceLabel": "Psalms 145:8",
      "text": "The Lord is gracious, and full of compassion; slow to anger, and of great mercy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.145.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 9,
      "referenceLabel": "Psalms 145:9",
      "text": "The Lord is good to all: and his tender mercies are over all his works.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.145.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 10,
      "referenceLabel": "Psalms 145:10",
      "text": "All thy works shall praise thee, O Lord; and thy saints shall bless thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.145.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 11,
      "referenceLabel": "Psalms 145:11",
      "text": "They shall speak of the glory of thy kingdom, and talk of thy power;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.145.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 12,
      "referenceLabel": "Psalms 145:12",
      "text": "To make known to the sons of men his mighty acts, and the glorious majesty of his kingdom.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.145.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 13,
      "referenceLabel": "Psalms 145:13",
      "text": "Thy kingdom is an everlasting kingdom, and thy dominion endureth throughout all generations.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.145.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 14,
      "referenceLabel": "Psalms 145:14",
      "text": "The Lord upholdeth all that fall, and raiseth up all those that be bowed down.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.145.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 15,
      "referenceLabel": "Psalms 145:15",
      "text": "The eyes of all wait upon thee; and thou givest them their meat in due season.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.145.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 16,
      "referenceLabel": "Psalms 145:16",
      "text": "Thou openest thine hand, and satisfiest the desire of every living thing.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.145.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 17,
      "referenceLabel": "Psalms 145:17",
      "text": "The Lord is righteous in all his ways, and holy in all his works.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.145.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 18,
      "referenceLabel": "Psalms 145:18",
      "text": "The Lord is nigh unto all them that call upon him, to all that call upon him in truth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.145.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 19,
      "referenceLabel": "Psalms 145:19",
      "text": "He will fulfil the desire of them that fear him: he also will hear their cry, and will save them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.145.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 20,
      "referenceLabel": "Psalms 145:20",
      "text": "The Lord preserveth all them that love him: but all the wicked will he destroy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.145.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 21,
      "referenceLabel": "Psalms 145:21",
      "text": "My mouth shall speak the praise of the Lord: and let all flesh bless his holy name for ever and ever.",
      "paragraphStart": false
    }
  ]
}
