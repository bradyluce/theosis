{
  "chapter": {
    "id": "kjva:psalms.37",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 37,
    "referenceLabel": "Psalms 37",
    "summary": "Source text for Psalms 37 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.37.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 1,
      "referenceLabel": "Psalms 37:1",
      "text": "Fret not thyself because of evildoers, neither be thou envious against the workers of iniquity.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.37.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 2,
      "referenceLabel": "Psalms 37:2",
      "text": "For they shall soon be cut down like the grass, and wither as the green herb.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 3,
      "referenceLabel": "Psalms 37:3",
      "text": "Trust in the Lord, and do good; so shalt thou dwell in the land, and verily thou shalt be fed.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 4,
      "referenceLabel": "Psalms 37:4",
      "text": "Delight thyself also in the Lord; and he shall give thee the desires of thine heart.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 5,
      "referenceLabel": "Psalms 37:5",
      "text": "Commit thy way unto the Lord; trust also in him; and he shall bring it to pass.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 6,
      "referenceLabel": "Psalms 37:6",
      "text": "And he shall bring forth thy righteousness as the light, and thy judgment as the noonday.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 7,
      "referenceLabel": "Psalms 37:7",
      "text": "Rest in the Lord, and wait patiently for him: fret not thyself because of him who prospereth in his way, because of the man who bringeth wicked devices to pass.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 8,
      "referenceLabel": "Psalms 37:8",
      "text": "Cease from anger, and forsake wrath: fret not thyself in any wise to do evil.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 9,
      "referenceLabel": "Psalms 37:9",
      "text": "For evildoers shall be cut off: but those that wait upon the Lord, they shall inherit the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 10,
      "referenceLabel": "Psalms 37:10",
      "text": "For yet a little while, and the wicked shall not be: yea, thou shalt diligently consider his place, and it shall not be.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 11,
      "referenceLabel": "Psalms 37:11",
      "text": "But the meek shall inherit the earth; and shall delight themselves in the abundance of peace.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 12,
      "referenceLabel": "Psalms 37:12",
      "text": "The wicked plotteth against the just, and gnasheth upon him with his teeth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 13,
      "referenceLabel": "Psalms 37:13",
      "text": "The Lord shall laugh at him: for he seeth that his day is coming.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 14,
      "referenceLabel": "Psalms 37:14",
      "text": "The wicked have drawn out the sword, and have bent their bow, to cast down the poor and needy, and to slay such as be of upright conversation.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 15,
      "referenceLabel": "Psalms 37:15",
      "text": "Their sword shall enter into their own heart, and their bows shall be broken.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 16,
      "referenceLabel": "Psalms 37:16",
      "text": "A little that a righteous man hath is better than the riches of many wicked.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 17,
      "referenceLabel": "Psalms 37:17",
      "text": "For the arms of the wicked shall be broken: but the Lord upholdeth the righteous.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 18,
      "referenceLabel": "Psalms 37:18",
      "text": "The Lord knoweth the days of the upright: and their inheritance shall be for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 19,
      "referenceLabel": "Psalms 37:19",
      "text": "They shall not be ashamed in the evil time: and in the days of famine they shall be satisfied.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 20,
      "referenceLabel": "Psalms 37:20",
      "text": "But the wicked shall perish, and the enemies of the Lord shall be as the fat of lambs: they shall consume; into smoke shall they consume away.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 21,
      "referenceLabel": "Psalms 37:21",
      "text": "The wicked borroweth, and payeth not again: but the righteous sheweth mercy, and giveth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 22,
      "referenceLabel": "Psalms 37:22",
      "text": "For such as be blessed of him shall inherit the earth; and they that be cursed of him shall be cut off.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.23",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 23,
      "referenceLabel": "Psalms 37:23",
      "text": "The steps of a good man are ordered by the Lord: and he delighteth in his way.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.24",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 24,
      "referenceLabel": "Psalms 37:24",
      "text": "Though he fall, he shall not be utterly cast down: for the Lord upholdeth him with his hand.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.25",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 25,
      "referenceLabel": "Psalms 37:25",
      "text": "I have been young, and now am old; yet have I not seen the righteous forsaken, nor his seed begging bread.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.26",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 26,
      "referenceLabel": "Psalms 37:26",
      "text": "He is ever merciful, and lendeth; and his seed is blessed.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.27",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 27,
      "referenceLabel": "Psalms 37:27",
      "text": "Depart from evil, and do good; and dwell for evermore.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.28",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 28,
      "referenceLabel": "Psalms 37:28",
      "text": "For the Lord loveth judgment, and forsaketh not his saints; they are preserved for ever: but the seed of the wicked shall be cut off.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.29",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 29,
      "referenceLabel": "Psalms 37:29",
      "text": "The righteous shall inherit the land, and dwell therein for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.30",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 30,
      "referenceLabel": "Psalms 37:30",
      "text": "The mouth of the righteous speaketh wisdom, and his tongue talketh of judgment.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.31",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 31,
      "referenceLabel": "Psalms 37:31",
      "text": "The law of his God is in his heart; none of his steps shall slide.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.32",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 32,
      "referenceLabel": "Psalms 37:32",
      "text": "The wicked watcheth the righteous, and seeketh to slay him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.33",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 33,
      "referenceLabel": "Psalms 37:33",
      "text": "The Lord will not leave him in his hand, nor condemn him when he is judged.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.34",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 34,
      "referenceLabel": "Psalms 37:34",
      "text": "Wait on the Lord, and keep his way, and he shall exalt thee to inherit the land: when the wicked are cut off, thou shalt see it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.35",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 35,
      "referenceLabel": "Psalms 37:35",
      "text": "I have seen the wicked in great power, and spreading himself like a green bay tree.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.36",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 36,
      "referenceLabel": "Psalms 37:36",
      "text": "Yet he passed away, and, lo, he was not: yea, I sought him, but he could not be found.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.37",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 37,
      "referenceLabel": "Psalms 37:37",
      "text": "Mark the perfect man, and behold the upright: for the end of that man is peace.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.38",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 38,
      "referenceLabel": "Psalms 37:38",
      "text": "But the transgressors shall be destroyed together: the end of the wicked shall be cut off.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.39",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 39,
      "referenceLabel": "Psalms 37:39",
      "text": "But the salvation of the righteous is of the Lord: he is their strength in the time of trouble.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.37.40",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 40,
      "referenceLabel": "Psalms 37:40",
      "text": "And the Lord shall help them, and deliver them: he shall deliver them from the wicked, and save them, because they trust in him.",
      "paragraphStart": false
    }
  ]
}
