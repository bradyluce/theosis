{
  "chapter": {
    "id": "kjva:psalms.46",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 46,
    "referenceLabel": "Psalms 46",
    "summary": "Source text for Psalms 46 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.46.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 1,
      "referenceLabel": "Psalms 46:1",
      "text": "God is our refuge and strength, a very present help in trouble.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.46.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 2,
      "referenceLabel": "Psalms 46:2",
      "text": "Therefore will not we fear, though the earth be removed, and though the mountains be carried into the midst of the sea;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.46.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 3,
      "referenceLabel": "Psalms 46:3",
      "text": "Though the waters thereof roar and be troubled, though the mountains shake with the swelling thereof. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.46.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 4,
      "referenceLabel": "Psalms 46:4",
      "text": "There is a river, the streams whereof shall make glad the city of God, the holy place of the tabernacles of the most High.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.46.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 5,
      "referenceLabel": "Psalms 46:5",
      "text": "God is in the midst of her; she shall not be moved: God shall help her, and that right early.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.46.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 6,
      "referenceLabel": "Psalms 46:6",
      "text": "The heathen raged, the kingdoms were moved: he uttered his voice, the earth melted.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.46.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 7,
      "referenceLabel": "Psalms 46:7",
      "text": "The Lord of hosts is with us; the God of Jacob is our refuge. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.46.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 8,
      "referenceLabel": "Psalms 46:8",
      "text": "Come, behold the works of the Lord, what desolations he hath made in the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.46.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 9,
      "referenceLabel": "Psalms 46:9",
      "text": "He maketh wars to cease unto the end of the earth; he breaketh the bow, and cutteth the spear in sunder; he burneth the chariot in the fire.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.46.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 10,
      "referenceLabel": "Psalms 46:10",
      "text": "Be still, and know that I am God: I will be exalted among the heathen, I will be exalted in the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.46.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 11,
      "referenceLabel": "Psalms 46:11",
      "text": "The Lord of hosts is with us; the God of Jacob is our refuge. Selah.",
      "paragraphStart": false
    }
  ]
}
