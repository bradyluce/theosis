{
  "chapter": {
    "id": "kjva:psalms.129",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 129,
    "referenceLabel": "Psalms 129",
    "summary": "Source text for Psalms 129 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.129.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 1,
      "referenceLabel": "Psalms 129:1",
      "text": "Many a time have they afflicted me from my youth, may Israel now say:",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.129.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 2,
      "referenceLabel": "Psalms 129:2",
      "text": "Many a time have they afflicted me from my youth: yet they have not prevailed against me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.129.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 3,
      "referenceLabel": "Psalms 129:3",
      "text": "The plowers plowed upon my back: they made long their furrows.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.129.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 4,
      "referenceLabel": "Psalms 129:4",
      "text": "The Lord is righteous: he hath cut asunder the cords of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.129.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 5,
      "referenceLabel": "Psalms 129:5",
      "text": "Let them all be confounded and turned back that hate Zion.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.129.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 6,
      "referenceLabel": "Psalms 129:6",
      "text": "Let them be as the grass upon the housetops, which withereth afore it groweth up:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.129.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 7,
      "referenceLabel": "Psalms 129:7",
      "text": "Wherewith the mower filleth not his hand; nor he that bindeth sheaves his bosom.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.129.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 8,
      "referenceLabel": "Psalms 129:8",
      "text": "Neither do they which go by say, The blessing of the Lord be upon you: we bless you in the name of the Lord.",
      "paragraphStart": false
    }
  ]
}
