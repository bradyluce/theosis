{
  "chapter": {
    "id": "kjva:psalms.85",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 85,
    "referenceLabel": "Psalms 85",
    "summary": "Source text for Psalms 85 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.85.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 1,
      "referenceLabel": "Psalms 85:1",
      "text": "Lord, thou hast been favourable unto thy land: thou hast brought back the captivity of Jacob.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.85.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 2,
      "referenceLabel": "Psalms 85:2",
      "text": "Thou hast forgiven the iniquity of thy people, thou hast covered all their sin. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.85.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 3,
      "referenceLabel": "Psalms 85:3",
      "text": "Thou hast taken away all thy wrath: thou hast turned thyself from the fierceness of thine anger.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.85.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 4,
      "referenceLabel": "Psalms 85:4",
      "text": "Turn us, O God of our salvation, and cause thine anger toward us to cease.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.85.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 5,
      "referenceLabel": "Psalms 85:5",
      "text": "Wilt thou be angry with us for ever? wilt thou draw out thine anger to all generations?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.85.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 6,
      "referenceLabel": "Psalms 85:6",
      "text": "Wilt thou not revive us again: that thy people may rejoice in thee?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.85.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 7,
      "referenceLabel": "Psalms 85:7",
      "text": "Shew us thy mercy, O Lord, and grant us thy salvation.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.85.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 8,
      "referenceLabel": "Psalms 85:8",
      "text": "I will hear what God the Lord will speak: for he will speak peace unto his people, and to his saints: but let them not turn again to folly.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.85.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 9,
      "referenceLabel": "Psalms 85:9",
      "text": "Surely his salvation is nigh them that fear him; that glory may dwell in our land.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.85.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 10,
      "referenceLabel": "Psalms 85:10",
      "text": "Mercy and truth are met together; righteousness and peace have kissed each other.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.85.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 11,
      "referenceLabel": "Psalms 85:11",
      "text": "Truth shall spring out of the earth; and righteousness shall look down from heaven.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.85.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 12,
      "referenceLabel": "Psalms 85:12",
      "text": "Yea, the Lord shall give that which is good; and our land shall yield her increase.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.85.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 13,
      "referenceLabel": "Psalms 85:13",
      "text": "Righteousness shall go before him; and shall set us in the way of his steps.",
      "paragraphStart": false
    }
  ]
}
