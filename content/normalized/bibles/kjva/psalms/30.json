{
  "chapter": {
    "id": "kjva:psalms.30",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 30,
    "referenceLabel": "Psalms 30",
    "summary": "Source text for Psalms 30 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.30.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 1,
      "referenceLabel": "Psalms 30:1",
      "text": "I will extol thee, O Lord; for thou hast lifted me up, and hast not made my foes to rejoice over me.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.30.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 2,
      "referenceLabel": "Psalms 30:2",
      "text": "O Lord my God, I cried unto thee, and thou hast healed me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.30.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 3,
      "referenceLabel": "Psalms 30:3",
      "text": "O Lord, thou hast brought up my soul from the grave: thou hast kept me alive, that I should not go down to the pit.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.30.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 4,
      "referenceLabel": "Psalms 30:4",
      "text": "Sing unto the Lord, O ye saints of his, and give thanks at the remembrance of his holiness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.30.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 5,
      "referenceLabel": "Psalms 30:5",
      "text": "For his anger endureth but a moment; in his favour is life: weeping may endure for a night, but joy cometh in the morning.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.30.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 6,
      "referenceLabel": "Psalms 30:6",
      "text": "And in my prosperity I said, I shall never be moved.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.30.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 7,
      "referenceLabel": "Psalms 30:7",
      "text": "Lord, by thy favour thou hast made my mountain to stand strong: thou didst hide thy face, and I was troubled.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.30.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 8,
      "referenceLabel": "Psalms 30:8",
      "text": "I cried to thee, O Lord; and unto the Lord I made supplication.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.30.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 9,
      "referenceLabel": "Psalms 30:9",
      "text": "What profit is there in my blood, when I go down to the pit? Shall the dust praise thee? shall it declare thy truth?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.30.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 10,
      "referenceLabel": "Psalms 30:10",
      "text": "Hear, O Lord, and have mercy upon me: Lord, be thou my helper.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.30.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 11,
      "referenceLabel": "Psalms 30:11",
      "text": "Thou hast turned for me my mourning into dancing: thou hast put off my sackcloth, and girded me with gladness;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.30.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 12,
      "referenceLabel": "Psalms 30:12",
      "text": "To the end that my glory may sing praise to thee, and not be silent. O Lord my God, I will give thanks unto thee for ever.",
      "paragraphStart": false
    }
  ]
}
