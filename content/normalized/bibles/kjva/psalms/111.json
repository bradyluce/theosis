{
  "chapter": {
    "id": "kjva:psalms.111",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 111,
    "referenceLabel": "Psalms 111",
    "summary": "Source text for Psalms 111 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.111.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 1,
      "referenceLabel": "Psalms 111:1",
      "text": "Praise ye the Lord. I will praise the Lord with my whole heart, in the assembly of the upright, and in the congregation.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.111.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 2,
      "referenceLabel": "Psalms 111:2",
      "text": "The works of the Lord are great, sought out of all them that have pleasure therein.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.111.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 3,
      "referenceLabel": "Psalms 111:3",
      "text": "His work is honourable and glorious: and his righteousness endureth for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.111.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 4,
      "referenceLabel": "Psalms 111:4",
      "text": "He hath made his wonderful works to be remembered: the Lord is gracious and full of compassion.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.111.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 5,
      "referenceLabel": "Psalms 111:5",
      "text": "He hath given meat unto them that fear him: he will ever be mindful of his covenant.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.111.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 6,
      "referenceLabel": "Psalms 111:6",
      "text": "He hath shewed his people the power of his works, that he may give them the heritage of the heathen.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.111.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 7,
      "referenceLabel": "Psalms 111:7",
      "text": "The works of his hands are verity and judgment; all his commandments are sure.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.111.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 8,
      "referenceLabel": "Psalms 111:8",
      "text": "They stand fast for ever and ever, and are done in truth and uprightness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.111.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 9,
      "referenceLabel": "Psalms 111:9",
      "text": "He sent redemption unto his people: he hath commanded his covenant for ever: holy and reverend is his name.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.111.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 10,
      "referenceLabel": "Psalms 111:10",
      "text": "The fear of the Lord is the beginning of wisdom: a good understanding have all they that do his commandments: his praise endureth for ever.",
      "paragraphStart": false
    }
  ]
}
