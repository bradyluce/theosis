{
  "chapter": {
    "id": "kjva:psalms.104",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 104,
    "referenceLabel": "Psalms 104",
    "summary": "Source text for Psalms 104 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.104.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 1,
      "referenceLabel": "Psalms 104:1",
      "text": "Bless the Lord, O my soul. O Lord my God, thou art very great; thou art clothed with honour and majesty.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.104.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 2,
      "referenceLabel": "Psalms 104:2",
      "text": "Who coverest thyself with light as with a garment: who stretchest out the heavens like a curtain:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 3,
      "referenceLabel": "Psalms 104:3",
      "text": "Who layeth the beams of his chambers in the waters: who maketh the clouds his chariot: who walketh upon the wings of the wind:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 4,
      "referenceLabel": "Psalms 104:4",
      "text": "Who maketh his angels spirits; his ministers a flaming fire:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 5,
      "referenceLabel": "Psalms 104:5",
      "text": "Who laid the foundations of the earth, that it should not be removed for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 6,
      "referenceLabel": "Psalms 104:6",
      "text": "Thou coveredst it with the deep as with a garment: the waters stood above the mountains.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 7,
      "referenceLabel": "Psalms 104:7",
      "text": "At thy rebuke they fled; at the voice of thy thunder they hasted away.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 8,
      "referenceLabel": "Psalms 104:8",
      "text": "They go up by the mountains; they go down by the valleys unto the place which thou hast founded for them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 9,
      "referenceLabel": "Psalms 104:9",
      "text": "Thou hast set a bound that they may not pass over; that they turn not again to cover the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 10,
      "referenceLabel": "Psalms 104:10",
      "text": "He sendeth the springs into the valleys, which run among the hills.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 11,
      "referenceLabel": "Psalms 104:11",
      "text": "They give drink to every beast of the field: the wild asses quench their thirst.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 12,
      "referenceLabel": "Psalms 104:12",
      "text": "By them shall the fowls of the heaven have their habitation, which sing among the branches.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 13,
      "referenceLabel": "Psalms 104:13",
      "text": "He watereth the hills from his chambers: the earth is satisfied with the fruit of thy works.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 14,
      "referenceLabel": "Psalms 104:14",
      "text": "He causeth the grass to grow for the cattle, and herb for the service of man: that he may bring forth food out of the earth;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 15,
      "referenceLabel": "Psalms 104:15",
      "text": "And wine that maketh glad the heart of man, and oil to make his face to shine, and bread which strengtheneth man’s heart.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 16,
      "referenceLabel": "Psalms 104:16",
      "text": "The trees of the Lord are full of sap; the cedars of Lebanon, which he hath planted;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 17,
      "referenceLabel": "Psalms 104:17",
      "text": "Where the birds make their nests: as for the stork, the fir trees are her house.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 18,
      "referenceLabel": "Psalms 104:18",
      "text": "The high hills are a refuge for the wild goats; and the rocks for the conies.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 19,
      "referenceLabel": "Psalms 104:19",
      "text": "He appointed the moon for seasons: the sun knoweth his going down.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 20,
      "referenceLabel": "Psalms 104:20",
      "text": "Thou makest darkness, and it is night: wherein all the beasts of the forest do creep forth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 21,
      "referenceLabel": "Psalms 104:21",
      "text": "The young lions roar after their prey, and seek their meat from God.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 22,
      "referenceLabel": "Psalms 104:22",
      "text": "The sun ariseth, they gather themselves together, and lay them down in their dens.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.23",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 23,
      "referenceLabel": "Psalms 104:23",
      "text": "Man goeth forth unto his work and to his labour until the evening.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.24",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 24,
      "referenceLabel": "Psalms 104:24",
      "text": "O Lord, how manifold are thy works! in wisdom hast thou made them all: the earth is full of thy riches.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.25",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 25,
      "referenceLabel": "Psalms 104:25",
      "text": "So is this great and wide sea, wherein are things creeping innumerable, both small and great beasts.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.26",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 26,
      "referenceLabel": "Psalms 104:26",
      "text": "There go the ships: there is that leviathan, whom thou hast made to play therein.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.27",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 27,
      "referenceLabel": "Psalms 104:27",
      "text": "These wait all upon thee; that thou mayest give them their meat in due season.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.28",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 28,
      "referenceLabel": "Psalms 104:28",
      "text": "That thou givest them they gather: thou openest thine hand, they are filled with good.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.29",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 29,
      "referenceLabel": "Psalms 104:29",
      "text": "Thou hidest thy face, they are troubled: thou takest away their breath, they die, and return to their dust.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.30",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 30,
      "referenceLabel": "Psalms 104:30",
      "text": "Thou sendest forth thy spirit, they are created: and thou renewest the face of the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.31",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 31,
      "referenceLabel": "Psalms 104:31",
      "text": "The glory of the Lord shall endure for ever: the Lord shall rejoice in his works.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.32",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 32,
      "referenceLabel": "Psalms 104:32",
      "text": "He looketh on the earth, and it trembleth: he toucheth the hills, and they smoke.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.33",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 33,
      "referenceLabel": "Psalms 104:33",
      "text": "I will sing unto the Lord as long as I live: I will sing praise to my God while I have my being.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.34",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 34,
      "referenceLabel": "Psalms 104:34",
      "text": "My meditation of him shall be sweet: I will be glad in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.104.35",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 35,
      "referenceLabel": "Psalms 104:35",
      "text": "Let the sinners be consumed out of the earth, and let the wicked be no more. Bless thou the Lord, O my soul. Praise ye the Lord.",
      "paragraphStart": false
    }
  ]
}
