{
  "chapter": {
    "id": "kjva:psalms.77",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 77,
    "referenceLabel": "Psalms 77",
    "summary": "Source text for Psalms 77 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.77.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 1,
      "referenceLabel": "Psalms 77:1",
      "text": "I cried unto God with my voice, even unto God with my voice; and he gave ear unto me.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.77.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 2,
      "referenceLabel": "Psalms 77:2",
      "text": "In the day of my trouble I sought the Lord: my sore ran in the night, and ceased not: my soul refused to be comforted.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.77.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 3,
      "referenceLabel": "Psalms 77:3",
      "text": "I remembered God, and was troubled: I complained, and my spirit was overwhelmed. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.77.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 4,
      "referenceLabel": "Psalms 77:4",
      "text": "Thou holdest mine eyes waking: I am so troubled that I cannot speak.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.77.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 5,
      "referenceLabel": "Psalms 77:5",
      "text": "I have considered the days of old, the years of ancient times.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.77.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 6,
      "referenceLabel": "Psalms 77:6",
      "text": "I call to remembrance my song in the night: I commune with mine own heart: and my spirit made diligent search.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.77.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 7,
      "referenceLabel": "Psalms 77:7",
      "text": "Will the Lord cast off for ever? and will he be favourable no more?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.77.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 8,
      "referenceLabel": "Psalms 77:8",
      "text": "Is his mercy clean gone for ever? doth his promise fail for evermore?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.77.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 9,
      "referenceLabel": "Psalms 77:9",
      "text": "Hath God forgotten to be gracious? hath he in anger shut up his tender mercies? Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.77.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 10,
      "referenceLabel": "Psalms 77:10",
      "text": "And I said, This is my infirmity: but I will remember the years of the right hand of the most High.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.77.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 11,
      "referenceLabel": "Psalms 77:11",
      "text": "I will remember the works of the Lord: surely I will remember thy wonders of old.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.77.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 12,
      "referenceLabel": "Psalms 77:12",
      "text": "I will meditate also of all thy work, and talk of thy doings.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.77.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 13,
      "referenceLabel": "Psalms 77:13",
      "text": "Thy way, O God, is in the sanctuary: who is so great a God as our God?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.77.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 14,
      "referenceLabel": "Psalms 77:14",
      "text": "Thou art the God that doest wonders: thou hast declared thy strength among the people.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.77.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 15,
      "referenceLabel": "Psalms 77:15",
      "text": "Thou hast with thine arm redeemed thy people, the sons of Jacob and Joseph. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.77.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 16,
      "referenceLabel": "Psalms 77:16",
      "text": "The waters saw thee, O God, the waters saw thee; they were afraid: the depths also were troubled.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.77.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 17,
      "referenceLabel": "Psalms 77:17",
      "text": "The clouds poured out water: the skies sent out a sound: thine arrows also went abroad.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.77.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 18,
      "referenceLabel": "Psalms 77:18",
      "text": "The voice of thy thunder was in the heaven: the lightnings lightened the world: the earth trembled and shook.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.77.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 19,
      "referenceLabel": "Psalms 77:19",
      "text": "Thy way is in the sea, and thy path in the great waters, and thy footsteps are not known.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.77.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 20,
      "referenceLabel": "Psalms 77:20",
      "text": "Thou leddest thy people like a flock by the hand of Moses and Aaron.",
      "paragraphStart": false
    }
  ]
}
