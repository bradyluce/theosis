{
  "chapter": {
    "id": "kjva:psalms.7",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 7,
    "referenceLabel": "Psalms 7",
    "summary": "Source text for Psalms 7 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.7.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Psalms 7:1",
      "text": "O Lord my God, in thee do I put my trust: save me from all them that persecute me, and deliver me:",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.7.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Psalms 7:2",
      "text": "Lest he tear my soul like a lion, rending it in pieces, while there is none to deliver.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.7.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Psalms 7:3",
      "text": "O Lord my God, if I have done this; if there be iniquity in my hands;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.7.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Psalms 7:4",
      "text": "If I have rewarded evil unto him that was at peace with me; (yea, I have delivered him that without cause is mine enemy:)",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.7.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Psalms 7:5",
      "text": "Let the enemy persecute my soul, and take it; yea, let him tread down my life upon the earth, and lay mine honour in the dust. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.7.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Psalms 7:6",
      "text": "Arise, O Lord, in thine anger, lift up thyself because of the rage of mine enemies: and awake for me to the judgment that thou hast commanded.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.7.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Psalms 7:7",
      "text": "So shall the congregation of the people compass thee about: for their sakes therefore return thou on high.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.7.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Psalms 7:8",
      "text": "The Lord shall judge the people: judge me, O Lord, according to my righteousness, and according to mine integrity that is in me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.7.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Psalms 7:9",
      "text": "Oh let the wickedness of the wicked come to an end; but establish the just: for the righteous God trieth the hearts and reins.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.7.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Psalms 7:10",
      "text": "My defence is of God, which saveth the upright in heart.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.7.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Psalms 7:11",
      "text": "God judgeth the righteous, and God is angry with the wicked every day.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.7.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Psalms 7:12",
      "text": "If he turn not, he will whet his sword; he hath bent his bow, and made it ready.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.7.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Psalms 7:13",
      "text": "He hath also prepared for him the instruments of death; he ordaineth his arrows against the persecutors.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.7.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Psalms 7:14",
      "text": "Behold, he travaileth with iniquity, and hath conceived mischief, and brought forth falsehood.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.7.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Psalms 7:15",
      "text": "He made a pit, and digged it, and is fallen into the ditch which he made.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.7.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Psalms 7:16",
      "text": "His mischief shall return upon his own head, and his violent dealing shall come down upon his own pate.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.7.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Psalms 7:17",
      "text": "I will praise the Lord according to his righteousness: and will sing praise to the name of the Lord most high.",
      "paragraphStart": false
    }
  ]
}
