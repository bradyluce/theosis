    "referenceLabel": "Psalms 13",
    "summary": "Source text for Psalms 13 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.13.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Psalms 13:1",
      "text": "How long wilt thou forget me, O Lord? for ever? how long wilt thou hide thy face from me?",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.13.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Psalms 13:2",
      "text": "How long shall I take counsel in my soul, having sorrow in my heart daily? how long shall mine enemy be exalted over me?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.13.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Psalms 13:3",
      "text": "Consider and hear me, O Lord my God: lighten mine eyes, lest I sleep the sleep of death;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.13.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Psalms 13:4",
      "text": "Lest mine enemy say, I have prevailed against him; and those that trouble me rejoice when I am moved.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.13.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Psalms 13:5",
      "text": "But I have trusted in thy mercy; my heart shall rejoice in thy salvation.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.13.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Psalms 13:6",
      "text": "I will sing unto the Lord, because he hath dealt bountifully with me.",
      "paragraphStart": false
    }
  ]
}
