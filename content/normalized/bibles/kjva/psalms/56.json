{
  "chapter": {
    "id": "kjva:psalms.56",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 56,
    "referenceLabel": "Psalms 56",
    "summary": "Source text for Psalms 56 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.56.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 1,
      "referenceLabel": "Psalms 56:1",
      "text": "Be merciful unto me, O God: for man would swallow me up; he fighting daily oppresseth me.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.56.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 2,
      "referenceLabel": "Psalms 56:2",
      "text": "Mine enemies would daily swallow me up: for they be many that fight against me, O thou most High.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.56.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 3,
      "referenceLabel": "Psalms 56:3",
      "text": "What time I am afraid, I will trust in thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.56.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 4,
      "referenceLabel": "Psalms 56:4",
      "text": "In God I will praise his word, in God I have put my trust; I will not fear what flesh can do unto me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.56.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 5,
      "referenceLabel": "Psalms 56:5",
      "text": "Every day they wrest my words: all their thoughts are against me for evil.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.56.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 6,
      "referenceLabel": "Psalms 56:6",
      "text": "They gather themselves together, they hide themselves, they mark my steps, when they wait for my soul.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.56.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 7,
      "referenceLabel": "Psalms 56:7",
      "text": "Shall they escape by iniquity? in thine anger cast down the people, O God.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.56.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 8,
      "referenceLabel": "Psalms 56:8",
      "text": "Thou tellest my wanderings: put thou my tears into thy bottle: are they not in thy book?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.56.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 9,
      "referenceLabel": "Psalms 56:9",
      "text": "When I cry unto thee, then shall mine enemies turn back: this I know; for God is for me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.56.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 10,
      "referenceLabel": "Psalms 56:10",
      "text": "In God will I praise his word: in the Lord will I praise his word.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.56.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 11,
      "referenceLabel": "Psalms 56:11",
      "text": "In God have I put my trust: I will not be afraid what man can do unto me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.56.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 12,
      "referenceLabel": "Psalms 56:12",
      "text": "Thy vows are upon me, O God: I will render praises unto thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.56.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 13,
      "referenceLabel": "Psalms 56:13",
      "text": "For thou hast delivered my soul from death: wilt not thou deliver my feet from falling, that I may walk before God in the light of the living?",
      "paragraphStart": false
    }
  ]
}
