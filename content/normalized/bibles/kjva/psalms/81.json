{
  "chapter": {
    "id": "kjva:psalms.81",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 81,
    "referenceLabel": "Psalms 81",
    "summary": "Source text for Psalms 81 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.81.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 1,
      "referenceLabel": "Psalms 81:1",
      "text": "Sing aloud unto God our strength: make a joyful noise unto the God of Jacob.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.81.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 2,
      "referenceLabel": "Psalms 81:2",
      "text": "Take a psalm, and bring hither the timbrel, the pleasant harp with the psaltery.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.81.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 3,
      "referenceLabel": "Psalms 81:3",
      "text": "Blow up the trumpet in the new moon, in the time appointed, on our solemn feast day.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.81.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 4,
      "referenceLabel": "Psalms 81:4",
      "text": "For this was a statute for Israel, and a law of the God of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.81.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 5,
      "referenceLabel": "Psalms 81:5",
      "text": "This he ordained in Joseph for a testimony, when he went out through the land of Egypt: where I heard a language that I understood not.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.81.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 6,
      "referenceLabel": "Psalms 81:6",
      "text": "I removed his shoulder from the burden: his hands were delivered from the pots.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.81.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 7,
      "referenceLabel": "Psalms 81:7",
      "text": "Thou calledst in trouble, and I delivered thee; I answered thee in the secret place of thunder: I proved thee at the waters of Meribah. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.81.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 8,
      "referenceLabel": "Psalms 81:8",
      "text": "Hear, O my people, and I will testify unto thee: O Israel, if thou wilt hearken unto me;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.81.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 9,
      "referenceLabel": "Psalms 81:9",
      "text": "There shall no strange god be in thee; neither shalt thou worship any strange god.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.81.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 10,
      "referenceLabel": "Psalms 81:10",
      "text": "I am the Lord thy God, which brought thee out of the land of Egypt: open thy mouth wide, and I will fill it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.81.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 11,
      "referenceLabel": "Psalms 81:11",
      "text": "But my people would not hearken to my voice; and Israel would none of me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.81.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 12,
      "referenceLabel": "Psalms 81:12",
      "text": "So I gave them up unto their own hearts’ lust: and they walked in their own counsels.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.81.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 13,
      "referenceLabel": "Psalms 81:13",
      "text": "Oh that my people had hearkened unto me, and Israel had walked in my ways!",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.81.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 14,
      "referenceLabel": "Psalms 81:14",
      "text": "I should soon have subdued their enemies, and turned my hand against their adversaries.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.81.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 15,
      "referenceLabel": "Psalms 81:15",
      "text": "The haters of the Lord should have submitted themselves unto him: but their time should have endured for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.81.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 16,
      "referenceLabel": "Psalms 81:16",
      "text": "He should have fed them also with the finest of the wheat: and with honey out of the rock should I have satisfied thee.",
      "paragraphStart": false
    }
  ]
}
