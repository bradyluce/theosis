{
  "chapter": {
    "id": "kjva:psalms.105",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 105,
    "referenceLabel": "Psalms 105",
    "summary": "Source text for Psalms 105 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.105.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 1,
      "referenceLabel": "Psalms 105:1",
      "text": "O give thanks unto the Lord; call upon his name: make known his deeds among the people.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.105.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 2,
      "referenceLabel": "Psalms 105:2",
      "text": "Sing unto him, sing psalms unto him: talk ye of all his wondrous works.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 3,
      "referenceLabel": "Psalms 105:3",
      "text": "Glory ye in his holy name: let the heart of them rejoice that seek the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 4,
      "referenceLabel": "Psalms 105:4",
      "text": "Seek the Lord, and his strength: seek his face evermore.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 5,
      "referenceLabel": "Psalms 105:5",
      "text": "Remember his marvellous works that he hath done; his wonders, and the judgments of his mouth;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 6,
      "referenceLabel": "Psalms 105:6",
      "text": "O ye seed of Abraham his servant, ye children of Jacob his chosen.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 7,
      "referenceLabel": "Psalms 105:7",
      "text": "He is the Lord our God: his judgments are in all the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 8,
      "referenceLabel": "Psalms 105:8",
      "text": "He hath remembered his covenant for ever, the word which he commanded to a thousand generations.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 9,
      "referenceLabel": "Psalms 105:9",
      "text": "Which covenant he made with Abraham, and his oath unto Isaac;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 10,
      "referenceLabel": "Psalms 105:10",
      "text": "And confirmed the same unto Jacob for a law, and to Israel for an everlasting covenant:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 11,
      "referenceLabel": "Psalms 105:11",
      "text": "Saying, Unto thee will I give the land of Canaan, the lot of your inheritance:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 12,
      "referenceLabel": "Psalms 105:12",
      "text": "When they were but a few men in number; yea, very few, and strangers in it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 13,
      "referenceLabel": "Psalms 105:13",
      "text": "When they went from one nation to another, from one kingdom to another people;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 14,
      "referenceLabel": "Psalms 105:14",
      "text": "He suffered no man to do them wrong: yea, he reproved kings for their sakes;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 15,
      "referenceLabel": "Psalms 105:15",
      "text": "Saying, Touch not mine anointed, and do my prophets no harm.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 16,
      "referenceLabel": "Psalms 105:16",
      "text": "Moreover he called for a famine upon the land: he brake the whole staff of bread.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 17,
      "referenceLabel": "Psalms 105:17",
      "text": "He sent a man before them, even Joseph, who was sold for a servant:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 18,
      "referenceLabel": "Psalms 105:18",
      "text": "Whose feet they hurt with fetters: he was laid in iron:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 19,
      "referenceLabel": "Psalms 105:19",
      "text": "Until the time that his word came: the word of the Lord tried him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 20,
      "referenceLabel": "Psalms 105:20",
      "text": "The king sent and loosed him; even the ruler of the people, and let him go free.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 21,
      "referenceLabel": "Psalms 105:21",
      "text": "He made him lord of his house, and ruler of all his substance:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 22,
      "referenceLabel": "Psalms 105:22",
      "text": "To bind his princes at his pleasure; and teach his senators wisdom.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.23",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 23,
      "referenceLabel": "Psalms 105:23",
      "text": "Israel also came into Egypt; and Jacob sojourned in the land of Ham.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.24",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 24,
      "referenceLabel": "Psalms 105:24",
      "text": "And he increased his people greatly; and made them stronger than their enemies.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.25",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 25,
      "referenceLabel": "Psalms 105:25",
      "text": "He turned their heart to hate his people, to deal subtilly with his servants.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.26",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 26,
      "referenceLabel": "Psalms 105:26",
      "text": "He sent Moses his servant; and Aaron whom he had chosen.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.27",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 27,
      "referenceLabel": "Psalms 105:27",
      "text": "They shewed his signs among them, and wonders in the land of Ham.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.28",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 28,
      "referenceLabel": "Psalms 105:28",
      "text": "He sent darkness, and made it dark; and they rebelled not against his word.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.29",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 29,
      "referenceLabel": "Psalms 105:29",
      "text": "He turned their waters into blood, and slew their fish.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.30",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 30,
      "referenceLabel": "Psalms 105:30",
      "text": "Their land brought forth frogs in abundance, in the chambers of their kings.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.31",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 31,
      "referenceLabel": "Psalms 105:31",
      "text": "He spake, and there came divers sorts of flies, and lice in all their coasts.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.32",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 32,
      "referenceLabel": "Psalms 105:32",
      "text": "He gave them hail for rain, and flaming fire in their land.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.33",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 33,
      "referenceLabel": "Psalms 105:33",
      "text": "He smote their vines also and their fig trees; and brake the trees of their coasts.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.34",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 34,
      "referenceLabel": "Psalms 105:34",
      "text": "He spake, and the locusts came, and caterpillers, and that without number,",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.35",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 35,
      "referenceLabel": "Psalms 105:35",
      "text": "And did eat up all the herbs in their land, and devoured the fruit of their ground.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.36",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 36,
      "referenceLabel": "Psalms 105:36",
      "text": "He smote also all the firstborn in their land, the chief of all their strength.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.37",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 37,
      "referenceLabel": "Psalms 105:37",
      "text": "He brought them forth also with silver and gold: and there was not one feeble person among their tribes.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.38",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 38,
      "referenceLabel": "Psalms 105:38",
      "text": "Egypt was glad when they departed: for the fear of them fell upon them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.39",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 39,
      "referenceLabel": "Psalms 105:39",
      "text": "He spread a cloud for a covering; and fire to give light in the night.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.40",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 40,
      "referenceLabel": "Psalms 105:40",
      "text": "The people asked, and he brought quails, and satisfied them with the bread of heaven.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.41",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 41,
      "referenceLabel": "Psalms 105:41",
      "text": "He opened the rock, and the waters gushed out; they ran in the dry places like a river.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.42",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 42,
      "referenceLabel": "Psalms 105:42",
      "text": "For he remembered his holy promise, and Abraham his servant.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.43",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 43,
      "referenceLabel": "Psalms 105:43",
      "text": "And he brought forth his people with joy, and his chosen with gladness:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.44",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 44,
      "referenceLabel": "Psalms 105:44",
      "text": "And gave them the lands of the heathen: and they inherited the labour of the people;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.105.45",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 45,
      "referenceLabel": "Psalms 105:45",
      "text": "That they might observe his statutes, and keep his laws. Praise ye the Lord.",
      "paragraphStart": false
    }
  ]
}
