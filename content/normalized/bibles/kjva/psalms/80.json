{
  "chapter": {
    "id": "kjva:psalms.80",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 80,
    "referenceLabel": "Psalms 80",
    "summary": "Source text for Psalms 80 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.80.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 1,
      "referenceLabel": "Psalms 80:1",
      "text": "Give ear, O Shepherd of Israel, thou that leadest Joseph like a flock; thou that dwellest between the cherubims, shine forth.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.80.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 2,
      "referenceLabel": "Psalms 80:2",
      "text": "Before Ephraim and Benjamin and Manasseh stir up thy strength, and come and save us.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.80.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 3,
      "referenceLabel": "Psalms 80:3",
      "text": "Turn us again, O God, and cause thy face to shine; and we shall be saved.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.80.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 4,
      "referenceLabel": "Psalms 80:4",
      "text": "O Lord God of hosts, how long wilt thou be angry against the prayer of thy people?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.80.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 5,
      "referenceLabel": "Psalms 80:5",
      "text": "Thou feedest them with the bread of tears; and givest them tears to drink in great measure.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.80.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 6,
      "referenceLabel": "Psalms 80:6",
      "text": "Thou makest us a strife unto our neighbours: and our enemies laugh among themselves.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.80.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 7,
      "referenceLabel": "Psalms 80:7",
      "text": "Turn us again, O God of hosts, and cause thy face to shine; and we shall be saved.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.80.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 8,
      "referenceLabel": "Psalms 80:8",
      "text": "Thou hast brought a vine out of Egypt: thou hast cast out the heathen, and planted it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.80.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 9,
      "referenceLabel": "Psalms 80:9",
      "text": "Thou preparedst room before it, and didst cause it to take deep root, and it filled the land.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.80.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 10,
      "referenceLabel": "Psalms 80:10",
      "text": "The hills were covered with the shadow of it, and the boughs thereof were like the goodly cedars.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.80.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 11,
      "referenceLabel": "Psalms 80:11",
      "text": "She sent out her boughs unto the sea, and her branches unto the river.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.80.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 12,
      "referenceLabel": "Psalms 80:12",
      "text": "Why hast thou then broken down her hedges, so that all they which pass by the way do pluck her?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.80.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 13,
      "referenceLabel": "Psalms 80:13",
      "text": "The boar out of the wood doth waste it, and the wild beast of the field doth devour it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.80.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 14,
      "referenceLabel": "Psalms 80:14",
      "text": "Return, we beseech thee, O God of hosts: look down from heaven, and behold, and visit this vine;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.80.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 15,
      "referenceLabel": "Psalms 80:15",
      "text": "And the vineyard which thy right hand hath planted, and the branch that thou madest strong for thyself.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.80.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 16,
      "referenceLabel": "Psalms 80:16",
      "text": "It is burned with fire, it is cut down: they perish at the rebuke of thy countenance.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.80.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 17,
      "referenceLabel": "Psalms 80:17",
      "text": "Let thy hand be upon the man of thy right hand, upon the son of man whom thou madest strong for thyself.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.80.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 18,
      "referenceLabel": "Psalms 80:18",
      "text": "So will not we go back from thee: quicken us, and we will call upon thy name.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.80.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 19,
      "referenceLabel": "Psalms 80:19",
      "text": "Turn us again, O Lord God of hosts, cause thy face to shine; and we shall be saved.",
      "paragraphStart": false
    }
  ]
}
