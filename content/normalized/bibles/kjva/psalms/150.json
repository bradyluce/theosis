{
  "chapter": {
    "id": "kjva:psalms.150",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 150,
    "referenceLabel": "Psalms 150",
    "summary": "Source text for Psalms 150 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.150.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 1,
      "referenceLabel": "Psalms 150:1",
      "text": "Praise ye the Lord. Praise God in his sanctuary: praise him in the firmament of his power.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.150.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 2,
      "referenceLabel": "Psalms 150:2",
      "text": "Praise him for his mighty acts: praise him according to his excellent greatness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.150.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 3,
      "referenceLabel": "Psalms 150:3",
      "text": "Praise him with the sound of the trumpet: praise him with the psaltery and harp.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.150.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 4,
      "referenceLabel": "Psalms 150:4",
      "text": "Praise him with the timbrel and dance: praise him with stringed instruments and organs.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.150.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 5,
      "referenceLabel": "Psalms 150:5",
      "text": "Praise him upon the loud cymbals: praise him upon the high sounding cymbals.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.150.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 6,
      "referenceLabel": "Psalms 150:6",
      "text": "Let every thing that hath breath praise the Lord. Praise ye the Lord.",
      "paragraphStart": false
    }
  ]
}
