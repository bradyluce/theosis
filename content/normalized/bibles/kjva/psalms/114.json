{
  "chapter": {
    "id": "kjva:psalms.114",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 114,
    "referenceLabel": "Psalms 114",
    "summary": "Source text for Psalms 114 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.114.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 1,
      "referenceLabel": "Psalms 114:1",
      "text": "When Israel went out of Egypt, the house of Jacob from a people of strange language;",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.114.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 2,
      "referenceLabel": "Psalms 114:2",
      "text": "Judah was his sanctuary, and Israel his dominion.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.114.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 3,
      "referenceLabel": "Psalms 114:3",
      "text": "The sea saw it, and fled: Jordan was driven back.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.114.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 4,
      "referenceLabel": "Psalms 114:4",
      "text": "The mountains skipped like rams, and the little hills like lambs.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.114.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 5,
      "referenceLabel": "Psalms 114:5",
      "text": "What ailed thee, O thou sea, that thou fleddest? thou Jordan, that thou wast driven back?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.114.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 6,
      "referenceLabel": "Psalms 114:6",
      "text": "Ye mountains, that ye skipped like rams; and ye little hills, like lambs?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.114.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 7,
      "referenceLabel": "Psalms 114:7",
      "text": "Tremble, thou earth, at the presence of the Lord, at the presence of the God of Jacob;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.114.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 8,
      "referenceLabel": "Psalms 114:8",
      "text": "Which turned the rock into a standing water, the flint into a fountain of waters.",
      "paragraphStart": false
    }
  ]
}
