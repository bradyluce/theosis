{
  "chapter": {
    "id": "kjva:psalms.82",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 82,
    "referenceLabel": "Psalms 82",
    "summary": "Source text for Psalms 82 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.82.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 1,
      "referenceLabel": "Psalms 82:1",
      "text": "God standeth in the congregation of the mighty; he judgeth among the gods.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.82.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 2,
      "referenceLabel": "Psalms 82:2",
      "text": "How long will ye judge unjustly, and accept the persons of the wicked? Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.82.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 3,
      "referenceLabel": "Psalms 82:3",
      "text": "Defend the poor and fatherless: do justice to the afflicted and needy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.82.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 4,
      "referenceLabel": "Psalms 82:4",
      "text": "Deliver the poor and needy: rid them out of the hand of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.82.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 5,
      "referenceLabel": "Psalms 82:5",
      "text": "They know not, neither will they understand; they walk on in darkness: all the foundations of the earth are out of course.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.82.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 6,
      "referenceLabel": "Psalms 82:6",
      "text": "I have said, Ye are gods; and all of you are children of the most High.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.82.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 7,
      "referenceLabel": "Psalms 82:7",
      "text": "But ye shall die like men, and fall like one of the princes.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.82.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 8,
      "referenceLabel": "Psalms 82:8",
      "text": "Arise, O God, judge the earth: for thou shalt inherit all nations.",
      "paragraphStart": false
    }
  ]
}
