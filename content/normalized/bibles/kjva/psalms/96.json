{
  "chapter": {
    "id": "kjva:psalms.96",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 96,
    "referenceLabel": "Psalms 96",
    "summary": "Source text for Psalms 96 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.96.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 1,
      "referenceLabel": "Psalms 96:1",
      "text": "O sing unto the Lord a new song: sing unto the Lord, all the earth.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.96.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 2,
      "referenceLabel": "Psalms 96:2",
      "text": "Sing unto the Lord, bless his name; shew forth his salvation from day to day.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.96.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 3,
      "referenceLabel": "Psalms 96:3",
      "text": "Declare his glory among the heathen, his wonders among all people.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.96.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 4,
      "referenceLabel": "Psalms 96:4",
      "text": "For the Lord is great, and greatly to be praised: he is to be feared above all gods.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.96.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 5,
      "referenceLabel": "Psalms 96:5",
      "text": "For all the gods of the nations are idols: but the Lord made the heavens.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.96.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 6,
      "referenceLabel": "Psalms 96:6",
      "text": "Honour and majesty are before him: strength and beauty are in his sanctuary.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.96.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 7,
      "referenceLabel": "Psalms 96:7",
      "text": "Give unto the Lord, O ye kindreds of the people, give unto the Lord glory and strength.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.96.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 8,
      "referenceLabel": "Psalms 96:8",
      "text": "Give unto the Lord the glory due unto his name: bring an offering, and come into his courts.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.96.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 9,
      "referenceLabel": "Psalms 96:9",
      "text": "O worship the Lord in the beauty of holiness: fear before him, all the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.96.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 10,
      "referenceLabel": "Psalms 96:10",
      "text": "Say among the heathen that the Lord reigneth: the world also shall be established that it shall not be moved: he shall judge the people righteously.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.96.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 11,
      "referenceLabel": "Psalms 96:11",
      "text": "Let the heavens rejoice, and let the earth be glad; let the sea roar, and the fulness thereof.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.96.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 12,
      "referenceLabel": "Psalms 96:12",
      "text": "Let the field be joyful, and all that is therein: then shall all the trees of the wood rejoice",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.96.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 13,
      "referenceLabel": "Psalms 96:13",
      "text": "Before the Lord: for he cometh, for he cometh to judge the earth: he shall judge the world with righteousness, and the people with his truth.",
      "paragraphStart": false
    }
  ]
}
