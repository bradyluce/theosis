{
  "chapter": {
    "id": "kjva:psalms.86",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 86,
    "referenceLabel": "Psalms 86",
    "summary": "Source text for Psalms 86 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.86.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 1,
      "referenceLabel": "Psalms 86:1",
      "text": "Bow down thine ear, O Lord, hear me: for I am poor and needy.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.86.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 2,
      "referenceLabel": "Psalms 86:2",
      "text": "Preserve my soul; for I am holy: O thou my God, save thy servant that trusteth in thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.86.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 3,
      "referenceLabel": "Psalms 86:3",
      "text": "Be merciful unto me, O Lord: for I cry unto thee daily.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.86.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 4,
      "referenceLabel": "Psalms 86:4",
      "text": "Rejoice the soul of thy servant: for unto thee, O Lord, do I lift up my soul.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.86.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 5,
      "referenceLabel": "Psalms 86:5",
      "text": "For thou, Lord, art good, and ready to forgive; and plenteous in mercy unto all them that call upon thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.86.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 6,
      "referenceLabel": "Psalms 86:6",
      "text": "Give ear, O Lord, unto my prayer; and attend to the voice of my supplications.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.86.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 7,
      "referenceLabel": "Psalms 86:7",
      "text": "In the day of my trouble I will call upon thee: for thou wilt answer me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.86.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 8,
      "referenceLabel": "Psalms 86:8",
      "text": "Among the gods there is none like unto thee, O Lord; neither are there any works like unto thy works.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.86.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 9,
      "referenceLabel": "Psalms 86:9",
      "text": "All nations whom thou hast made shall come and worship before thee, O Lord; and shall glorify thy name.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.86.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 10,
      "referenceLabel": "Psalms 86:10",
      "text": "For thou art great, and doest wondrous things: thou art God alone.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.86.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 11,
      "referenceLabel": "Psalms 86:11",
      "text": "Teach me thy way, O Lord; I will walk in thy truth: unite my heart to fear thy name.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.86.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 12,
      "referenceLabel": "Psalms 86:12",
      "text": "I will praise thee, O Lord my God, with all my heart: and I will glorify thy name for evermore.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.86.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 13,
      "referenceLabel": "Psalms 86:13",
      "text": "For great is thy mercy toward me: and thou hast delivered my soul from the lowest hell.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.86.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 14,
      "referenceLabel": "Psalms 86:14",
      "text": "O God, the proud are risen against me, and the assemblies of violent men have sought after my soul; and have not set thee before them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.86.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 15,
      "referenceLabel": "Psalms 86:15",
      "text": "But thou, O Lord, art a God full of compassion, and gracious, longsuffering, and plenteous in mercy and truth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.86.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 16,
      "referenceLabel": "Psalms 86:16",
      "text": "O turn unto me, and have mercy upon me; give thy strength unto thy servant, and save the son of thine handmaid.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.86.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 17,
      "referenceLabel": "Psalms 86:17",
      "text": "Shew me a token for good; that they which hate me may see it, and be ashamed: because thou, Lord, hast holpen me, and comforted me.",
      "paragraphStart": false
    }
  ]
}
