{
  "chapter": {
    "id": "kjva:psalms.41",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 41,
    "referenceLabel": "Psalms 41",
    "summary": "Source text for Psalms 41 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.41.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 1,
      "referenceLabel": "Psalms 41:1",
      "text": "Blessed is he that considereth the poor: the Lord will deliver him in time of trouble.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.41.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 2,
      "referenceLabel": "Psalms 41:2",
      "text": "The Lord will preserve him, and keep him alive; and he shall be blessed upon the earth: and thou wilt not deliver him unto the will of his enemies.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.41.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 3,
      "referenceLabel": "Psalms 41:3",
      "text": "The Lord will strengthen him upon the bed of languishing: thou wilt make all his bed in his sickness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.41.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 4,
      "referenceLabel": "Psalms 41:4",
      "text": "I said, Lord, be merciful unto me: heal my soul; for I have sinned against thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.41.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 5,
      "referenceLabel": "Psalms 41:5",
      "text": "Mine enemies speak evil of me, When shall he die, and his name perish?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.41.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 6,
      "referenceLabel": "Psalms 41:6",
      "text": "And if he come to see me, he speaketh vanity: his heart gathereth iniquity to itself; when he goeth abroad, he telleth it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.41.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 7,
      "referenceLabel": "Psalms 41:7",
      "text": "All that hate me whisper together against me: against me do they devise my hurt.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.41.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 8,
      "referenceLabel": "Psalms 41:8",
      "text": "An evil disease, say they, cleaveth fast unto him: and now that he lieth he shall rise up no more.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.41.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 9,
      "referenceLabel": "Psalms 41:9",
      "text": "Yea, mine own familiar friend, in whom I trusted, which did eat of my bread, hath lifted up his heel against me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.41.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 10,
      "referenceLabel": "Psalms 41:10",
      "text": "But thou, O Lord, be merciful unto me, and raise me up, that I may requite them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.41.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 11,
      "referenceLabel": "Psalms 41:11",
      "text": "By this I know that thou favourest me, because mine enemy doth not triumph over me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.41.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 12,
      "referenceLabel": "Psalms 41:12",
      "text": "And as for me, thou upholdest me in mine integrity, and settest me before thy face for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.41.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 13,
      "referenceLabel": "Psalms 41:13",
      "text": "Blessed be the Lord God of Israel from everlasting, and to everlasting. Amen, and Amen.",
      "paragraphStart": false
    }
  ]
}
