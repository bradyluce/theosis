{
  "chapter": {
    "id": "kjva:psalms.73",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 73,
    "referenceLabel": "Psalms 73",
    "summary": "Source text for Psalms 73 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.73.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 1,
      "referenceLabel": "Psalms 73:1",
      "text": "Truly God is good to Israel, even to such as are of a clean heart.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.73.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 2,
      "referenceLabel": "Psalms 73:2",
      "text": "But as for me, my feet were almost gone; my steps had well nigh slipped.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 3,
      "referenceLabel": "Psalms 73:3",
      "text": "For I was envious at the foolish, when I saw the prosperity of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 4,
      "referenceLabel": "Psalms 73:4",
      "text": "For there are no bands in their death: but their strength is firm.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 5,
      "referenceLabel": "Psalms 73:5",
      "text": "They are not in trouble as other men; neither are they plagued like other men.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 6,
      "referenceLabel": "Psalms 73:6",
      "text": "Therefore pride compasseth them about as a chain; violence covereth them as a garment.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 7,
      "referenceLabel": "Psalms 73:7",
      "text": "Their eyes stand out with fatness: they have more than heart could wish.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 8,
      "referenceLabel": "Psalms 73:8",
      "text": "They are corrupt, and speak wickedly concerning oppression: they speak loftily.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 9,
      "referenceLabel": "Psalms 73:9",
      "text": "They set their mouth against the heavens, and their tongue walketh through the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 10,
      "referenceLabel": "Psalms 73:10",
      "text": "Therefore his people return hither: and waters of a full cup are wrung out to them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 11,
      "referenceLabel": "Psalms 73:11",
      "text": "And they say, How doth God know? and is there knowledge in the most High?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 12,
      "referenceLabel": "Psalms 73:12",
      "text": "Behold, these are the ungodly, who prosper in the world; they increase in riches.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 13,
      "referenceLabel": "Psalms 73:13",
      "text": "Verily I have cleansed my heart in vain, and washed my hands in innocency.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 14,
      "referenceLabel": "Psalms 73:14",
      "text": "For all the day long have I been plagued, and chastened every morning.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 15,
      "referenceLabel": "Psalms 73:15",
      "text": "If I say, I will speak thus; behold, I should offend against the generation of thy children.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 16,
      "referenceLabel": "Psalms 73:16",
      "text": "When I thought to know this, it was too painful for me;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 17,
      "referenceLabel": "Psalms 73:17",
      "text": "Until I went into the sanctuary of God; then understood I their end.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 18,
      "referenceLabel": "Psalms 73:18",
      "text": "Surely thou didst set them in slippery places: thou castedst them down into destruction.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 19,
      "referenceLabel": "Psalms 73:19",
      "text": "How are they brought into desolation, as in a moment! they are utterly consumed with terrors.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 20,
      "referenceLabel": "Psalms 73:20",
      "text": "As a dream when one awaketh; so, O Lord, when thou awakest, thou shalt despise their image.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 21,
      "referenceLabel": "Psalms 73:21",
      "text": "Thus my heart was grieved, and I was pricked in my reins.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 22,
      "referenceLabel": "Psalms 73:22",
      "text": "So foolish was I, and ignorant: I was as a beast before thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.23",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 23,
      "referenceLabel": "Psalms 73:23",
      "text": "Nevertheless I am continually with thee: thou hast holden me by my right hand.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.24",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 24,
      "referenceLabel": "Psalms 73:24",
      "text": "Thou shalt guide me with thy counsel, and afterward receive me to glory.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.25",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 25,
      "referenceLabel": "Psalms 73:25",
      "text": "Whom have I in heaven but thee? and there is none upon earth that I desire beside thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.26",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 26,
      "referenceLabel": "Psalms 73:26",
      "text": "My flesh and my heart faileth: but God is the strength of my heart, and my portion for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.27",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 27,
      "referenceLabel": "Psalms 73:27",
      "text": "For, lo, they that are far from thee shall perish: thou hast destroyed all them that go a whoring from thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.73.28",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 28,
      "referenceLabel": "Psalms 73:28",
      "text": "But it is good for me to draw near to God: I have put my trust in the Lord God, that I may declare all thy works.",
      "paragraphStart": false
    }
  ]
}
