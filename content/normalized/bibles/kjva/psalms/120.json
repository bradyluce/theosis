  "verses": [
    {
      "id": "kjva:psalms.120.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 1,
      "referenceLabel": "Psalms 120:1",
      "text": "In my distress I cried unto the Lord, and he heard me.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.120.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 2,
      "referenceLabel": "Psalms 120:2",
      "text": "Deliver my soul, O Lord, from lying lips, and from a deceitful tongue.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.120.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 3,
      "referenceLabel": "Psalms 120:3",
      "text": "What shall be given unto thee? or what shall be done unto thee, thou false tongue?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.120.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 4,
      "referenceLabel": "Psalms 120:4",
      "text": "Sharp arrows of the mighty, with coals of juniper.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.120.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 5,
      "referenceLabel": "Psalms 120:5",
      "text": "Woe is me, that I sojourn in Mesech, that I dwell in the tents of Kedar!",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.120.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 6,
      "referenceLabel": "Psalms 120:6",
      "text": "My soul hath long dwelt with him that hateth peace.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.120.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 7,
      "referenceLabel": "Psalms 120:7",
      "text": "I am for peace: but when I speak, they are for war.",
      "paragraphStart": false
    }
  ]
}
