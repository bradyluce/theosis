{
  "chapter": {
    "id": "kjva:psalms.89",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 89,
    "referenceLabel": "Psalms 89",
    "summary": "Source text for Psalms 89 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.89.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 1,
      "referenceLabel": "Psalms 89:1",
      "text": "I will sing of the mercies of the Lord for ever: with my mouth will I make known thy faithfulness to all generations.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.89.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 2,
      "referenceLabel": "Psalms 89:2",
      "text": "For I have said, Mercy shall be built up for ever: thy faithfulness shalt thou establish in the very heavens.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 3,
      "referenceLabel": "Psalms 89:3",
      "text": "I have made a covenant with my chosen, I have sworn unto David my servant,",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 4,
      "referenceLabel": "Psalms 89:4",
      "text": "Thy seed will I establish for ever, and build up thy throne to all generations. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 5,
      "referenceLabel": "Psalms 89:5",
      "text": "And the heavens shall praise thy wonders, O Lord: thy faithfulness also in the congregation of the saints.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 6,
      "referenceLabel": "Psalms 89:6",
      "text": "For who in the heaven can be compared unto the Lord? who among the sons of the mighty can be likened unto the Lord?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 7,
      "referenceLabel": "Psalms 89:7",
      "text": "God is greatly to be feared in the assembly of the saints, and to be had in reverence of all them that are about him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 8,
      "referenceLabel": "Psalms 89:8",
      "text": "O Lord God of hosts, who is a strong Lord like unto thee? or to thy faithfulness round about thee?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 9,
      "referenceLabel": "Psalms 89:9",
      "text": "Thou rulest the raging of the sea: when the waves thereof arise, thou stillest them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 10,
      "referenceLabel": "Psalms 89:10",
      "text": "Thou hast broken Rahab in pieces, as one that is slain; thou hast scattered thine enemies with thy strong arm.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 11,
      "referenceLabel": "Psalms 89:11",
      "text": "The heavens are thine, the earth also is thine: as for the world and the fulness thereof, thou hast founded them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 12,
      "referenceLabel": "Psalms 89:12",
      "text": "The north and the south thou hast created them: Tabor and Hermon shall rejoice in thy name.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 13,
      "referenceLabel": "Psalms 89:13",
      "text": "Thou hast a mighty arm: strong is thy hand, and high is thy right hand.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 14,
      "referenceLabel": "Psalms 89:14",
      "text": "Justice and judgment are the habitation of thy throne: mercy and truth shall go before thy face.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 15,
      "referenceLabel": "Psalms 89:15",
      "text": "Blessed is the people that know the joyful sound: they shall walk, O Lord, in the light of thy countenance.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 16,
      "referenceLabel": "Psalms 89:16",
      "text": "In thy name shall they rejoice all the day: and in thy righteousness shall they be exalted.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 17,
      "referenceLabel": "Psalms 89:17",
      "text": "For thou art the glory of their strength: and in thy favour our horn shall be exalted.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 18,
      "referenceLabel": "Psalms 89:18",
      "text": "For the Lord is our defence; and the Holy One of Israel is our king.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 19,
      "referenceLabel": "Psalms 89:19",
      "text": "Then thou spakest in vision to thy holy one, and saidst, I have laid help upon one that is mighty; I have exalted one chosen out of the people.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 20,
      "referenceLabel": "Psalms 89:20",
      "text": "I have found David my servant; with my holy oil have I anointed him:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 21,
      "referenceLabel": "Psalms 89:21",
      "text": "With whom my hand shall be established: mine arm also shall strengthen him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 22,
      "referenceLabel": "Psalms 89:22",
      "text": "The enemy shall not exact upon him; nor the son of wickedness afflict him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.23",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 23,
      "referenceLabel": "Psalms 89:23",
      "text": "And I will beat down his foes before his face, and plague them that hate him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.24",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 24,
      "referenceLabel": "Psalms 89:24",
      "text": "But my faithfulness and my mercy shall be with him: and in my name shall his horn be exalted.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.25",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 25,
      "referenceLabel": "Psalms 89:25",
      "text": "I will set his hand also in the sea, and his right hand in the rivers.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.26",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 26,
      "referenceLabel": "Psalms 89:26",
      "text": "He shall cry unto me, Thou art my father, my God, and the rock of my salvation.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.27",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 27,
      "referenceLabel": "Psalms 89:27",
      "text": "Also I will make him my firstborn, higher than the kings of the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.28",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 28,
      "referenceLabel": "Psalms 89:28",
      "text": "My mercy will I keep for him for evermore, and my covenant shall stand fast with him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.29",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 29,
      "referenceLabel": "Psalms 89:29",
      "text": "His seed also will I make to endure for ever, and his throne as the days of heaven.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.30",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 30,
      "referenceLabel": "Psalms 89:30",
      "text": "If his children forsake my law, and walk not in my judgments;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.31",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 31,
      "referenceLabel": "Psalms 89:31",
      "text": "If they break my statutes, and keep not my commandments;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.32",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 32,
      "referenceLabel": "Psalms 89:32",
      "text": "Then will I visit their transgression with the rod, and their iniquity with stripes.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.33",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 33,
      "referenceLabel": "Psalms 89:33",
      "text": "Nevertheless my lovingkindness will I not utterly take from him, nor suffer my faithfulness to fail.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.34",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 34,
      "referenceLabel": "Psalms 89:34",
      "text": "My covenant will I not break, nor alter the thing that is gone out of my lips.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.35",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 35,
      "referenceLabel": "Psalms 89:35",
      "text": "Once have I sworn by my holiness that I will not lie unto David.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.36",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 36,
      "referenceLabel": "Psalms 89:36",
      "text": "His seed shall endure for ever, and his throne as the sun before me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.37",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 37,
      "referenceLabel": "Psalms 89:37",
      "text": "It shall be established for ever as the moon, and as a faithful witness in heaven. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.38",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 38,
      "referenceLabel": "Psalms 89:38",
      "text": "But thou hast cast off and abhorred, thou hast been wroth with thine anointed.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.39",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 39,
      "referenceLabel": "Psalms 89:39",
      "text": "Thou hast made void the covenant of thy servant: thou hast profaned his crown by casting it to the ground.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.40",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 40,
      "referenceLabel": "Psalms 89:40",
      "text": "Thou hast broken down all his hedges; thou hast brought his strong holds to ruin.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.41",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 41,
      "referenceLabel": "Psalms 89:41",
      "text": "All that pass by the way spoil him: he is a reproach to his neighbours.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.42",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 42,
      "referenceLabel": "Psalms 89:42",
      "text": "Thou hast set up the right hand of his adversaries; thou hast made all his enemies to rejoice.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.43",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 43,
      "referenceLabel": "Psalms 89:43",
      "text": "Thou hast also turned the edge of his sword, and hast not made him to stand in the battle.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.44",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 44,
      "referenceLabel": "Psalms 89:44",
      "text": "Thou hast made his glory to cease, and cast his throne down to the ground.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.45",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 45,
      "referenceLabel": "Psalms 89:45",
      "text": "The days of his youth hast thou shortened: thou hast covered him with shame. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.46",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 46,
      "referenceLabel": "Psalms 89:46",
      "text": "How long, Lord? wilt thou hide thyself for ever? shall thy wrath burn like fire?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.47",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 47,
      "referenceLabel": "Psalms 89:47",
      "text": "Remember how short my time is: wherefore hast thou made all men in vain?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.48",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 48,
      "referenceLabel": "Psalms 89:48",
      "text": "What man is he that liveth, and shall not see death? shall he deliver his soul from the hand of the grave? Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.49",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 49,
      "referenceLabel": "Psalms 89:49",
      "text": "Lord, where are thy former lovingkindnesses, which thou swarest unto David in thy truth?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.50",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 50,
      "referenceLabel": "Psalms 89:50",
      "text": "Remember, Lord, the reproach of thy servants; how I do bear in my bosom the reproach of all the mighty people;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.51",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 51,
      "referenceLabel": "Psalms 89:51",
      "text": "Wherewith thine enemies have reproached, O Lord; wherewith they have reproached the footsteps of thine anointed.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.89.52",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 52,
      "referenceLabel": "Psalms 89:52",
      "text": "Blessed be the Lord for evermore. Amen, and Amen.",
      "paragraphStart": false
    }
  ]
}
