{
  "chapter": {
    "id": "kjva:psalms.124",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 124,
    "referenceLabel": "Psalms 124",
    "summary": "Source text for Psalms 124 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.124.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 1,
      "referenceLabel": "Psalms 124:1",
      "text": "If it had not been the Lord who was on our side, now may Israel say;",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.124.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 2,
      "referenceLabel": "Psalms 124:2",
      "text": "If it had not been the Lord who was on our side, when men rose up against us:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.124.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 3,
      "referenceLabel": "Psalms 124:3",
      "text": "Then they had swallowed us up quick, when their wrath was kindled against us:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.124.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 4,
      "referenceLabel": "Psalms 124:4",
      "text": "Then the waters had overwhelmed us, the stream had gone over our soul:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.124.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 5,
      "referenceLabel": "Psalms 124:5",
      "text": "Then the proud waters had gone over our soul.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.124.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 6,
      "referenceLabel": "Psalms 124:6",
      "text": "Blessed be the Lord, who hath not given us as a prey to their teeth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.124.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 7,
      "referenceLabel": "Psalms 124:7",
      "text": "Our soul is escaped as a bird out of the snare of the fowlers: the snare is broken, and we are escaped.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.124.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 8,
      "referenceLabel": "Psalms 124:8",
      "text": "Our help is in the name of the Lord, who made heaven and earth.",
      "paragraphStart": false
    }
  ]
}
