{
  "chapter": {
    "id": "kjva:psalms.66",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 66,
    "referenceLabel": "Psalms 66",
    "summary": "Source text for Psalms 66 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.66.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 1,
      "referenceLabel": "Psalms 66:1",
      "text": "Make a joyful noise unto God, all ye lands:",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.66.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 2,
      "referenceLabel": "Psalms 66:2",
      "text": "Sing forth the honour of his name: make his praise glorious.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.66.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 3,
      "referenceLabel": "Psalms 66:3",
      "text": "Say unto God, How terrible art thou in thy works! through the greatness of thy power shall thine enemies submit themselves unto thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.66.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 4,
      "referenceLabel": "Psalms 66:4",
      "text": "All the earth shall worship thee, and shall sing unto thee; they shall sing to thy name. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.66.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 5,
      "referenceLabel": "Psalms 66:5",
      "text": "Come and see the works of God: he is terrible in his doing toward the children of men.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.66.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 6,
      "referenceLabel": "Psalms 66:6",
      "text": "He turned the sea into dry land: they went through the flood on foot: there did we rejoice in him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.66.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 7,
      "referenceLabel": "Psalms 66:7",
      "text": "He ruleth by his power for ever; his eyes behold the nations: let not the rebellious exalt themselves. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.66.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 8,
      "referenceLabel": "Psalms 66:8",
      "text": "O bless our God, ye people, and make the voice of his praise to be heard:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.66.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 9,
      "referenceLabel": "Psalms 66:9",
      "text": "Which holdeth our soul in life, and suffereth not our feet to be moved.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.66.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 10,
      "referenceLabel": "Psalms 66:10",
      "text": "For thou, O God, hast proved us: thou hast tried us, as silver is tried.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.66.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 11,
      "referenceLabel": "Psalms 66:11",
      "text": "Thou broughtest us into the net; thou laidst affliction upon our loins.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.66.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 12,
      "referenceLabel": "Psalms 66:12",
      "text": "Thou hast caused men to ride over our heads; we went through fire and through water: but thou broughtest us out into a wealthy place.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.66.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 13,
      "referenceLabel": "Psalms 66:13",
      "text": "I will go into thy house with burnt offerings: I will pay thee my vows,",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.66.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 14,
      "referenceLabel": "Psalms 66:14",
      "text": "Which my lips have uttered, and my mouth hath spoken, when I was in trouble.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.66.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 15,
      "referenceLabel": "Psalms 66:15",
      "text": "I will offer unto thee burnt sacrifices of fatlings, with the incense of rams; I will offer bullocks with goats. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.66.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 16,
      "referenceLabel": "Psalms 66:16",
      "text": "Come and hear, all ye that fear God, and I will declare what he hath done for my soul.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.66.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 17,
      "referenceLabel": "Psalms 66:17",
      "text": "I cried unto him with my mouth, and he was extolled with my tongue.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.66.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 18,
      "referenceLabel": "Psalms 66:18",
      "text": "If I regard iniquity in my heart, the Lord will not hear me:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.66.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 19,
      "referenceLabel": "Psalms 66:19",
      "text": "But verily God hath heard me; he hath attended to the voice of my prayer.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.66.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 20,
      "referenceLabel": "Psalms 66:20",
      "text": "Blessed be God, which hath not turned away my prayer, nor his mercy from me.",
      "paragraphStart": false
    }
  ]
}
