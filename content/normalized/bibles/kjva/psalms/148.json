{
  "chapter": {
    "id": "kjva:psalms.148",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 148,
    "referenceLabel": "Psalms 148",
    "summary": "Source text for Psalms 148 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.148.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 1,
      "referenceLabel": "Psalms 148:1",
      "text": "Praise ye the Lord. Praise ye the Lord from the heavens: praise him in the heights.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.148.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 2,
      "referenceLabel": "Psalms 148:2",
      "text": "Praise ye him, all his angels: praise ye him, all his hosts.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.148.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 3,
      "referenceLabel": "Psalms 148:3",
      "text": "Praise ye him, sun and moon: praise him, all ye stars of light.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.148.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 4,
      "referenceLabel": "Psalms 148:4",
      "text": "Praise him, ye heavens of heavens, and ye waters that be above the heavens.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.148.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 5,
      "referenceLabel": "Psalms 148:5",
      "text": "Let them praise the name of the Lord: for he commanded, and they were created.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.148.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 6,
      "referenceLabel": "Psalms 148:6",
      "text": "He hath also stablished them for ever and ever: he hath made a decree which shall not pass.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.148.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 7,
      "referenceLabel": "Psalms 148:7",
      "text": "Praise the Lord from the earth, ye dragons, and all deeps:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.148.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 8,
      "referenceLabel": "Psalms 148:8",
      "text": "Fire, and hail; snow, and vapour; stormy wind fulfilling his word:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.148.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 9,
      "referenceLabel": "Psalms 148:9",
      "text": "Mountains, and all hills; fruitful trees, and all cedars:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.148.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 10,
      "referenceLabel": "Psalms 148:10",
      "text": "Beasts, and all cattle; creeping things, and flying fowl:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.148.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 11,
      "referenceLabel": "Psalms 148:11",
      "text": "Kings of the earth, and all people; princes, and all judges of the earth:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.148.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 12,
      "referenceLabel": "Psalms 148:12",
      "text": "Both young men, and maidens; old men, and children:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.148.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 13,
      "referenceLabel": "Psalms 148:13",
      "text": "Let them praise the name of the Lord: for his name alone is excellent; his glory is above the earth and heaven.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.148.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 14,
      "referenceLabel": "Psalms 148:14",
      "text": "He also exalteth the horn of his people, the praise of all his saints; even of the children of Israel, a people near unto him. Praise ye the Lord.",
      "paragraphStart": false
    }
  ]
}
