{
  "chapter": {
    "id": "kjva:psalms.10",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 10,
    "referenceLabel": "Psalms 10",
    "summary": "Source text for Psalms 10 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.10.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Psalms 10:1",
      "text": "Why standest thou afar off, O Lord? why hidest thou thyself in times of trouble?",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.10.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Psalms 10:2",
      "text": "The wicked in his pride doth persecute the poor: let them be taken in the devices that they have imagined.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.10.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Psalms 10:3",
      "text": "For the wicked boasteth of his heart’s desire, and blesseth the covetous, whom the Lord abhorreth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.10.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Psalms 10:4",
      "text": "The wicked, through the pride of his countenance, will not seek after God: God is not in all his thoughts.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.10.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Psalms 10:5",
      "text": "His ways are always grievous; thy judgments are far above out of his sight: as for all his enemies, he puffeth at them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.10.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Psalms 10:6",
      "text": "He hath said in his heart, I shall not be moved: for I shall never be in adversity.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.10.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Psalms 10:7",
      "text": "His mouth is full of cursing and deceit and fraud: under his tongue is mischief and vanity.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.10.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Psalms 10:8",
      "text": "He sitteth in the lurking places of the villages: in the secret places doth he murder the innocent: his eyes are privily set against the poor.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.10.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Psalms 10:9",
      "text": "He lieth in wait secretly as a lion in his den: he lieth in wait to catch the poor: he doth catch the poor, when he draweth him into his net.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.10.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Psalms 10:10",
      "text": "He croucheth, and humbleth himself, that the poor may fall by his strong ones.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.10.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Psalms 10:11",
      "text": "He hath said in his heart, God hath forgotten: he hideth his face; he will never see it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.10.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Psalms 10:12",
      "text": "Arise, O Lord; O God, lift up thine hand: forget not the humble.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.10.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Psalms 10:13",
      "text": "Wherefore doth the wicked contemn God? he hath said in his heart, Thou wilt not require it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.10.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Psalms 10:14",
      "text": "Thou hast seen it; for thou beholdest mischief and spite, to requite it with thy hand: the poor committeth himself unto thee; thou art the helper of the fatherless.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.10.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Psalms 10:15",
      "text": "Break thou the arm of the wicked and the evil man: seek out his wickedness till thou find none.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.10.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Psalms 10:16",
      "text": "The Lord is King for ever and ever: the heathen are perished out of his land.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.10.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Psalms 10:17",
      "text": "Lord, thou hast heard the desire of the humble: thou wilt prepare their heart, thou wilt cause thine ear to hear:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.10.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Psalms 10:18",
      "text": "To judge the fatherless and the oppressed, that the man of the earth may no more oppress.",
      "paragraphStart": false
    }
  ]
}
