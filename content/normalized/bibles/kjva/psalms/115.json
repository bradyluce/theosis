{
  "chapter": {
    "id": "kjva:psalms.115",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 115,
    "referenceLabel": "Psalms 115",
    "summary": "Source text for Psalms 115 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.115.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 1,
      "referenceLabel": "Psalms 115:1",
      "text": "Not unto us, O Lord, not unto us, but unto thy name give glory, for thy mercy, and for thy truth’s sake.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.115.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 2,
      "referenceLabel": "Psalms 115:2",
      "text": "Wherefore should the heathen say, Where is now their God?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.115.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 3,
      "referenceLabel": "Psalms 115:3",
      "text": "But our God is in the heavens: he hath done whatsoever he hath pleased.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.115.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 4,
      "referenceLabel": "Psalms 115:4",
      "text": "Their idols are silver and gold, the work of men’s hands.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.115.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 5,
      "referenceLabel": "Psalms 115:5",
      "text": "They have mouths, but they speak not: eyes have they, but they see not:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.115.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 6,
      "referenceLabel": "Psalms 115:6",
      "text": "They have ears, but they hear not: noses have they, but they smell not:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.115.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 7,
      "referenceLabel": "Psalms 115:7",
      "text": "They have hands, but they handle not: feet have they, but they walk not: neither speak they through their throat.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.115.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 8,
      "referenceLabel": "Psalms 115:8",
      "text": "They that make them are like unto them; so is every one that trusteth in them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.115.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 9,
      "referenceLabel": "Psalms 115:9",
      "text": "O Israel, trust thou in the Lord: he is their help and their shield.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.115.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 10,
      "referenceLabel": "Psalms 115:10",
      "text": "O house of Aaron, trust in the Lord: he is their help and their shield.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.115.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 11,
      "referenceLabel": "Psalms 115:11",
      "text": "Ye that fear the Lord, trust in the Lord: he is their help and their shield.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.115.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 12,
      "referenceLabel": "Psalms 115:12",
      "text": "The Lord hath been mindful of us: he will bless us; he will bless the house of Israel; he will bless the house of Aaron.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.115.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 13,
      "referenceLabel": "Psalms 115:13",
      "text": "He will bless them that fear the Lord, both small and great.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.115.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 14,
      "referenceLabel": "Psalms 115:14",
      "text": "The Lord shall increase you more and more, you and your children.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.115.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 15,
      "referenceLabel": "Psalms 115:15",
      "text": "Ye are blessed of the Lord which made heaven and earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.115.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 16,
      "referenceLabel": "Psalms 115:16",
      "text": "The heaven, even the heavens, are the Lord’s: but the earth hath he given to the children of men.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.115.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 17,
      "referenceLabel": "Psalms 115:17",
      "text": "The dead praise not the Lord, neither any that go down into silence.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.115.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 18,
      "referenceLabel": "Psalms 115:18",
      "text": "But we will bless the Lord from this time forth and for evermore. Praise the Lord.",
      "paragraphStart": false
    }
  ]
}
