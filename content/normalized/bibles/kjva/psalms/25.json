{
  "chapter": {
    "id": "kjva:psalms.25",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 25,
    "referenceLabel": "Psalms 25",
    "summary": "Source text for Psalms 25 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.25.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Psalms 25:1",
      "text": "Unto thee, O Lord, do I lift up my soul.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.25.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Psalms 25:2",
      "text": "O my God, I trust in thee: let me not be ashamed, let not mine enemies triumph over me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Psalms 25:3",
      "text": "Yea, let none that wait on thee be ashamed: let them be ashamed which transgress without cause.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Psalms 25:4",
      "text": "Shew me thy ways, O Lord; teach me thy paths.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Psalms 25:5",
      "text": "Lead me in thy truth, and teach me: for thou art the God of my salvation; on thee do I wait all the day.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Psalms 25:6",
      "text": "Remember, O Lord, thy tender mercies and thy lovingkindnesses; for they have been ever of old.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Psalms 25:7",
      "text": "Remember not the sins of my youth, nor my transgressions: according to thy mercy remember thou me for thy goodness’ sake, O Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Psalms 25:8",
      "text": "Good and upright is the Lord: therefore will he teach sinners in the way.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Psalms 25:9",
      "text": "The meek will he guide in judgment: and the meek will he teach his way.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Psalms 25:10",
      "text": "All the paths of the Lord are mercy and truth unto such as keep his covenant and his testimonies.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Psalms 25:11",
      "text": "For thy name’s sake, O Lord, pardon mine iniquity; for it is great.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Psalms 25:12",
      "text": "What man is he that feareth the Lord? him shall he teach in the way that he shall choose.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "Psalms 25:13",
      "text": "His soul shall dwell at ease; and his seed shall inherit the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "Psalms 25:14",
      "text": "The secret of the Lord is with them that fear him; and he will shew them his covenant.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 15,
      "referenceLabel": "Psalms 25:15",
      "text": "Mine eyes are ever toward the Lord; for he shall pluck my feet out of the net.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 16,
      "referenceLabel": "Psalms 25:16",
      "text": "Turn thee unto me, and have mercy upon me; for I am desolate and afflicted.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 17,
      "referenceLabel": "Psalms 25:17",
      "text": "The troubles of my heart are enlarged: O bring thou me out of my distresses.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 18,
      "referenceLabel": "Psalms 25:18",
      "text": "Look upon mine affliction and my pain; and forgive all my sins.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 19,
      "referenceLabel": "Psalms 25:19",
      "text": "Consider mine enemies; for they are many; and they hate me with cruel hatred.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 20,
      "referenceLabel": "Psalms 25:20",
      "text": "O keep my soul, and deliver me: let me not be ashamed; for I put my trust in thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 21,
      "referenceLabel": "Psalms 25:21",
      "text": "Let integrity and uprightness preserve me; for I wait on thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.25.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 22,
      "referenceLabel": "Psalms 25:22",
      "text": "Redeem Israel, O God, out of all his troubles.",
      "paragraphStart": false
    }
  ]
}
