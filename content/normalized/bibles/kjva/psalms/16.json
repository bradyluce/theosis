{
  "chapter": {
    "id": "kjva:psalms.16",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 16,
    "referenceLabel": "Psalms 16",
    "summary": "Source text for Psalms 16 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.16.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Psalms 16:1",
      "text": "Preserve me, O God: for in thee do I put my trust.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.16.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Psalms 16:2",
      "text": "O my soul, thou hast said unto the Lord, Thou art my Lord: my goodness extendeth not to thee;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.16.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Psalms 16:3",
      "text": "But to the saints that are in the earth, and to the excellent, in whom is all my delight.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.16.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Psalms 16:4",
      "text": "Their sorrows shall be multiplied that hasten after another god: their drink offerings of blood will I not offer, nor take up their names into my lips.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.16.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Psalms 16:5",
      "text": "The Lord is the portion of mine inheritance and of my cup: thou maintainest my lot.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.16.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Psalms 16:6",
      "text": "The lines are fallen unto me in pleasant places; yea, I have a goodly heritage.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.16.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Psalms 16:7",
      "text": "I will bless the Lord, who hath given me counsel: my reins also instruct me in the night seasons.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.16.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Psalms 16:8",
      "text": "I have set the Lord always before me: because he is at my right hand, I shall not be moved.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.16.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Psalms 16:9",
      "text": "Therefore my heart is glad, and my glory rejoiceth: my flesh also shall rest in hope.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.16.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Psalms 16:10",
      "text": "For thou wilt not leave my soul in hell; neither wilt thou suffer thine Holy One to see corruption.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.16.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Psalms 16:11",
      "text": "Thou wilt shew me the path of life: in thy presence is fulness of joy; at thy right hand there are pleasures for evermore.",
      "paragraphStart": false
    }
  ]
}
