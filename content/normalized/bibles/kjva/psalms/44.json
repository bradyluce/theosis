{
  "chapter": {
    "id": "kjva:psalms.44",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 44,
    "referenceLabel": "Psalms 44",
    "summary": "Source text for Psalms 44 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.44.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 1,
      "referenceLabel": "Psalms 44:1",
      "text": "We have heard with our ears, O God, our fathers have told us, what work thou didst in their days, in the times of old.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.44.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 2,
      "referenceLabel": "Psalms 44:2",
      "text": "How thou didst drive out the heathen with thy hand, and plantedst them; how thou didst afflict the people, and cast them out.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 3,
      "referenceLabel": "Psalms 44:3",
      "text": "For they got not the land in possession by their own sword, neither did their own arm save them: but thy right hand, and thine arm, and the light of thy countenance, because thou hadst a favour unto them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 4,
      "referenceLabel": "Psalms 44:4",
      "text": "Thou art my King, O God: command deliverances for Jacob.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 5,
      "referenceLabel": "Psalms 44:5",
      "text": "Through thee will we push down our enemies: through thy name will we tread them under that rise up against us.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 6,
      "referenceLabel": "Psalms 44:6",
      "text": "For I will not trust in my bow, neither shall my sword save me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 7,
      "referenceLabel": "Psalms 44:7",
      "text": "But thou hast saved us from our enemies, and hast put them to shame that hated us.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 8,
      "referenceLabel": "Psalms 44:8",
      "text": "In God we boast all the day long, and praise thy name for ever. Selah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 9,
      "referenceLabel": "Psalms 44:9",
      "text": "But thou hast cast off, and put us to shame; and goest not forth with our armies.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 10,
      "referenceLabel": "Psalms 44:10",
      "text": "Thou makest us to turn back from the enemy: and they which hate us spoil for themselves.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 11,
      "referenceLabel": "Psalms 44:11",
      "text": "Thou hast given us like sheep appointed for meat; and hast scattered us among the heathen.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 12,
      "referenceLabel": "Psalms 44:12",
      "text": "Thou sellest thy people for nought, and dost not increase thy wealth by their price.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 13,
      "referenceLabel": "Psalms 44:13",
      "text": "Thou makest us a reproach to our neighbours, a scorn and a derision to them that are round about us.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 14,
      "referenceLabel": "Psalms 44:14",
      "text": "Thou makest us a byword among the heathen, a shaking of the head among the people.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 15,
      "referenceLabel": "Psalms 44:15",
      "text": "My confusion is continually before me, and the shame of my face hath covered me,",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 16,
      "referenceLabel": "Psalms 44:16",
      "text": "For the voice of him that reproacheth and blasphemeth; by reason of the enemy and avenger.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 17,
      "referenceLabel": "Psalms 44:17",
      "text": "All this is come upon us; yet have we not forgotten thee, neither have we dealt falsely in thy covenant.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 18,
      "referenceLabel": "Psalms 44:18",
      "text": "Our heart is not turned back, neither have our steps declined from thy way;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 19,
      "referenceLabel": "Psalms 44:19",
      "text": "Though thou hast sore broken us in the place of dragons, and covered us with the shadow of death.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 20,
      "referenceLabel": "Psalms 44:20",
      "text": "If we have forgotten the name of our God, or stretched out our hands to a strange god;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 21,
      "referenceLabel": "Psalms 44:21",
      "text": "Shall not God search this out? for he knoweth the secrets of the heart.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 22,
      "referenceLabel": "Psalms 44:22",
      "text": "Yea, for thy sake are we killed all the day long; we are counted as sheep for the slaughter.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.23",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 23,
      "referenceLabel": "Psalms 44:23",
      "text": "Awake, why sleepest thou, O Lord? arise, cast us not off for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.24",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 24,
      "referenceLabel": "Psalms 44:24",
      "text": "Wherefore hidest thou thy face, and forgettest our affliction and our oppression?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.25",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 25,
      "referenceLabel": "Psalms 44:25",
      "text": "For our soul is bowed down to the dust: our belly cleaveth unto the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.44.26",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 26,
      "referenceLabel": "Psalms 44:26",
      "text": "Arise for our help, and redeem us for thy mercies’ sake.",
      "paragraphStart": false
    }
  ]
}
