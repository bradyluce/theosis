{
  "chapter": {
    "id": "kjva:psalms.51",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 51,
    "referenceLabel": "Psalms 51",
    "summary": "Source text for Psalms 51 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.51.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 1,
      "referenceLabel": "Psalms 51:1",
      "text": "Have mercy upon me, O God, according to thy lovingkindness: according unto the multitude of thy tender mercies blot out my transgressions.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.51.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 2,
      "referenceLabel": "Psalms 51:2",
      "text": "Wash me throughly from mine iniquity, and cleanse me from my sin.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.51.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 3,
      "referenceLabel": "Psalms 51:3",
      "text": "For I acknowledge my transgressions: and my sin is ever before me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.51.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 4,
      "referenceLabel": "Psalms 51:4",
      "text": "Against thee, thee only, have I sinned, and done this evil in thy sight: that thou mightest be justified when thou speakest, and be clear when thou judgest.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.51.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 5,
      "referenceLabel": "Psalms 51:5",
      "text": "Behold, I was shapen in iniquity; and in sin did my mother conceive me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.51.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 6,
      "referenceLabel": "Psalms 51:6",
      "text": "Behold, thou desirest truth in the inward parts: and in the hidden part thou shalt make me to know wisdom.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.51.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 7,
      "referenceLabel": "Psalms 51:7",
      "text": "Purge me with hyssop, and I shall be clean: wash me, and I shall be whiter than snow.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.51.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 8,
      "referenceLabel": "Psalms 51:8",
      "text": "Make me to hear joy and gladness; that the bones which thou hast broken may rejoice.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.51.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 9,
      "referenceLabel": "Psalms 51:9",
      "text": "Hide thy face from my sins, and blot out all mine iniquities.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.51.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 10,
      "referenceLabel": "Psalms 51:10",
      "text": "Create in me a clean heart, O God; and renew a right spirit within me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.51.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 11,
      "referenceLabel": "Psalms 51:11",
      "text": "Cast me not away from thy presence; and take not thy holy spirit from me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.51.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 12,
      "referenceLabel": "Psalms 51:12",
      "text": "Restore unto me the joy of thy salvation; and uphold me with thy free spirit.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.51.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 13,
      "referenceLabel": "Psalms 51:13",
      "text": "Then will I teach transgressors thy ways; and sinners shall be converted unto thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.51.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 14,
      "referenceLabel": "Psalms 51:14",
      "text": "Deliver me from bloodguiltiness, O God, thou God of my salvation: and my tongue shall sing aloud of thy righteousness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.51.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 15,
      "referenceLabel": "Psalms 51:15",
      "text": "O Lord, open thou my lips; and my mouth shall shew forth thy praise.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.51.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 16,
      "referenceLabel": "Psalms 51:16",
      "text": "For thou desirest not sacrifice; else would I give it: thou delightest not in burnt offering.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.51.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 17,
      "referenceLabel": "Psalms 51:17",
      "text": "The sacrifices of God are a broken spirit: a broken and a contrite heart, O God, thou wilt not despise.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.51.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 18,
      "referenceLabel": "Psalms 51:18",
      "text": "Do good in thy good pleasure unto Zion: build thou the walls of Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.51.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 19,
      "referenceLabel": "Psalms 51:19",
      "text": "Then shalt thou be pleased with the sacrifices of righteousness, with burnt offering and whole burnt offering: then shall they offer bullocks upon thine altar.",
      "paragraphStart": false
    }
  ]
}
