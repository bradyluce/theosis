{
  "chapter": {
    "id": "kjva:psalms.72",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 72,
    "referenceLabel": "Psalms 72",
    "summary": "Source text for Psalms 72 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.72.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 1,
      "referenceLabel": "Psalms 72:1",
      "text": "Give the king thy judgments, O God, and thy righteousness unto the king’s son.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.72.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 2,
      "referenceLabel": "Psalms 72:2",
      "text": "He shall judge thy people with righteousness, and thy poor with judgment.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.72.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 3,
      "referenceLabel": "Psalms 72:3",
      "text": "The mountains shall bring peace to the people, and the little hills, by righteousness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.72.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 4,
      "referenceLabel": "Psalms 72:4",
      "text": "He shall judge the poor of the people, he shall save the children of the needy, and shall break in pieces the oppressor.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.72.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 5,
      "referenceLabel": "Psalms 72:5",
      "text": "They shall fear thee as long as the sun and moon endure, throughout all generations.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.72.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 6,
      "referenceLabel": "Psalms 72:6",
      "text": "He shall come down like rain upon the mown grass: as showers that water the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.72.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 7,
      "referenceLabel": "Psalms 72:7",
      "text": "In his days shall the righteous flourish; and abundance of peace so long as the moon endureth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.72.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 8,
      "referenceLabel": "Psalms 72:8",
      "text": "He shall have dominion also from sea to sea, and from the river unto the ends of the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.72.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 9,
      "referenceLabel": "Psalms 72:9",
      "text": "They that dwell in the wilderness shall bow before him; and his enemies shall lick the dust.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.72.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 10,
      "referenceLabel": "Psalms 72:10",
      "text": "The kings of Tarshish and of the isles shall bring presents: the kings of Sheba and Seba shall offer gifts.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.72.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 11,
      "referenceLabel": "Psalms 72:11",
      "text": "Yea, all kings shall fall down before him: all nations shall serve him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.72.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 12,
      "referenceLabel": "Psalms 72:12",
      "text": "For he shall deliver the needy when he crieth; the poor also, and him that hath no helper.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.72.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 13,
      "referenceLabel": "Psalms 72:13",
      "text": "He shall spare the poor and needy, and shall save the souls of the needy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.72.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 14,
      "referenceLabel": "Psalms 72:14",
      "text": "He shall redeem their soul from deceit and violence: and precious shall their blood be in his sight.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.72.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 15,
      "referenceLabel": "Psalms 72:15",
      "text": "And he shall live, and to him shall be given of the gold of Sheba: prayer also shall be made for him continually; and daily shall he be praised.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.72.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 16,
      "referenceLabel": "Psalms 72:16",
      "text": "There shall be an handful of corn in the earth upon the top of the mountains; the fruit thereof shall shake like Lebanon: and they of the city shall flourish like grass of the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.72.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 17,
      "referenceLabel": "Psalms 72:17",
      "text": "His name shall endure for ever: his name shall be continued as long as the sun: and men shall be blessed in him: all nations shall call him blessed.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.72.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 18,
      "referenceLabel": "Psalms 72:18",
      "text": "Blessed be the Lord God, the God of Israel, who only doeth wondrous things.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.72.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 19,
      "referenceLabel": "Psalms 72:19",
      "text": "And blessed be his glorious name for ever: and let the whole earth be filled with his glory; Amen, and Amen.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.72.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 20,
      "referenceLabel": "Psalms 72:20",
      "text": "The prayers of David the son of Jesse are ended.",
      "paragraphStart": false
    }
  ]
}
