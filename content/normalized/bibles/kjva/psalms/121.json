{
  "chapter": {
    "id": "kjva:psalms.121",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 121,
    "referenceLabel": "Psalms 121",
    "summary": "Source text for Psalms 121 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.121.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 1,
      "referenceLabel": "Psalms 121:1",
      "text": "I will lift up mine eyes unto the hills, from whence cometh my help.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.121.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 2,
      "referenceLabel": "Psalms 121:2",
      "text": "My help cometh from the Lord, which made heaven and earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.121.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 3,
      "referenceLabel": "Psalms 121:3",
      "text": "He will not suffer thy foot to be moved: he that keepeth thee will not slumber.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.121.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 4,
      "referenceLabel": "Psalms 121:4",
      "text": "Behold, he that keepeth Israel shall neither slumber nor sleep.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.121.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 5,
      "referenceLabel": "Psalms 121:5",
      "text": "The Lord is thy keeper: the Lord is thy shade upon thy right hand.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.121.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 6,
      "referenceLabel": "Psalms 121:6",
      "text": "The sun shall not smite thee by day, nor the moon by night.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.121.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 7,
      "referenceLabel": "Psalms 121:7",
      "text": "The Lord shall preserve thee from all evil: he shall preserve thy soul.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.121.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 8,
      "referenceLabel": "Psalms 121:8",
      "text": "The Lord shall preserve thy going out and thy coming in from this time forth, and even for evermore.",
      "paragraphStart": false
    }
  ]
}
