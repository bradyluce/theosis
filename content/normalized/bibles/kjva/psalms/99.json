{
  "chapter": {
    "id": "kjva:psalms.99",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 99,
    "referenceLabel": "Psalms 99",
    "summary": "Source text for Psalms 99 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.99.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 1,
      "referenceLabel": "Psalms 99:1",
      "text": "The Lord reigneth; let the people tremble: he sitteth between the cherubims; let the earth be moved.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.99.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 2,
      "referenceLabel": "Psalms 99:2",
      "text": "The Lord is great in Zion; and he is high above all the people.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.99.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 3,
      "referenceLabel": "Psalms 99:3",
      "text": "Let them praise thy great and terrible name; for it is holy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.99.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 4,
      "referenceLabel": "Psalms 99:4",
      "text": "The king’s strength also loveth judgment; thou dost establish equity, thou executest judgment and righteousness in Jacob.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.99.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 5,
      "referenceLabel": "Psalms 99:5",
      "text": "Exalt ye the Lord our God, and worship at his footstool; for he is holy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.99.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 6,
      "referenceLabel": "Psalms 99:6",
      "text": "Moses and Aaron among his priests, and Samuel among them that call upon his name; they called upon the Lord, and he answered them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.99.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 7,
      "referenceLabel": "Psalms 99:7",
      "text": "He spake unto them in the cloudy pillar: they kept his testimonies, and the ordinance that he gave them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.99.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 8,
      "referenceLabel": "Psalms 99:8",
      "text": "Thou answeredst them, O Lord our God: thou wast a God that forgavest them, though thou tookest vengeance of their inventions.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.99.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 9,
      "referenceLabel": "Psalms 99:9",
      "text": "Exalt the Lord our God, and worship at his holy hill; for the Lord our God is holy.",
      "paragraphStart": false
    }
  ]
}
