{
  "chapter": {
    "id": "kjva:psalms.34",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 34,
    "referenceLabel": "Psalms 34",
    "summary": "Source text for Psalms 34 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.34.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 1,
      "referenceLabel": "Psalms 34:1",
      "text": "I will bless the Lord at all times: his praise shall continually be in my mouth.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.34.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 2,
      "referenceLabel": "Psalms 34:2",
      "text": "My soul shall make her boast in the Lord: the humble shall hear thereof, and be glad.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 3,
      "referenceLabel": "Psalms 34:3",
      "text": "O magnify the Lord with me, and let us exalt his name together.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 4,
      "referenceLabel": "Psalms 34:4",
      "text": "I sought the Lord, and he heard me, and delivered me from all my fears.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 5,
      "referenceLabel": "Psalms 34:5",
      "text": "They looked unto him, and were lightened: and their faces were not ashamed.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 6,
      "referenceLabel": "Psalms 34:6",
      "text": "This poor man cried, and the Lord heard him, and saved him out of all his troubles.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 7,
      "referenceLabel": "Psalms 34:7",
      "text": "The angel of the Lord encampeth round about them that fear him, and delivereth them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 8,
      "referenceLabel": "Psalms 34:8",
      "text": "O taste and see that the Lord is good: blessed is the man that trusteth in him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 9,
      "referenceLabel": "Psalms 34:9",
      "text": "O fear the Lord, ye his saints: for there is no want to them that fear him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 10,
      "referenceLabel": "Psalms 34:10",
      "text": "The young lions do lack, and suffer hunger: but they that seek the Lord shall not want any good thing.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 11,
      "referenceLabel": "Psalms 34:11",
      "text": "Come, ye children, hearken unto me: I will teach you the fear of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 12,
      "referenceLabel": "Psalms 34:12",
      "text": "What man is he that desireth life, and loveth many days, that he may see good?",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 13,
      "referenceLabel": "Psalms 34:13",
      "text": "Keep thy tongue from evil, and thy lips from speaking guile.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 14,
      "referenceLabel": "Psalms 34:14",
      "text": "Depart from evil, and do good; seek peace, and pursue it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 15,
      "referenceLabel": "Psalms 34:15",
      "text": "The eyes of the Lord are upon the righteous, and his ears are open unto their cry.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 16,
      "referenceLabel": "Psalms 34:16",
      "text": "The face of the Lord is against them that do evil, to cut off the remembrance of them from the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 17,
      "referenceLabel": "Psalms 34:17",
      "text": "The righteous cry, and the Lord heareth, and delivereth them out of all their troubles.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 18,
      "referenceLabel": "Psalms 34:18",
      "text": "The Lord is nigh unto them that are of a broken heart; and saveth such as be of a contrite spirit.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 19,
      "referenceLabel": "Psalms 34:19",
      "text": "Many are the afflictions of the righteous: but the Lord delivereth him out of them all.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 20,
      "referenceLabel": "Psalms 34:20",
      "text": "He keepeth all his bones: not one of them is broken.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 21,
      "referenceLabel": "Psalms 34:21",
      "text": "Evil shall slay the wicked: and they that hate the righteous shall be desolate.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.34.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 22,
      "referenceLabel": "Psalms 34:22",
      "text": "The Lord redeemeth the soul of his servants: and none of them that trust in him shall be desolate.",
      "paragraphStart": false
    }
  ]
}
