{
  "chapter": {
    "id": "kjva:psalms.102",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 102,
    "referenceLabel": "Psalms 102",
    "summary": "Source text for Psalms 102 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.102.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 1,
      "referenceLabel": "Psalms 102:1",
      "text": "Hear my prayer, O Lord, and let my cry come unto thee.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.102.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 2,
      "referenceLabel": "Psalms 102:2",
      "text": "Hide not thy face from me in the day when I am in trouble; incline thine ear unto me: in the day when I call answer me speedily.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 3,
      "referenceLabel": "Psalms 102:3",
      "text": "For my days are consumed like smoke, and my bones are burned as an hearth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 4,
      "referenceLabel": "Psalms 102:4",
      "text": "My heart is smitten, and withered like grass; so that I forget to eat my bread.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 5,
      "referenceLabel": "Psalms 102:5",
      "text": "By reason of the voice of my groaning my bones cleave to my skin.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 6,
      "referenceLabel": "Psalms 102:6",
      "text": "I am like a pelican of the wilderness: I am like an owl of the desert.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 7,
      "referenceLabel": "Psalms 102:7",
      "text": "I watch, and am as a sparrow alone upon the house top.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 8,
      "referenceLabel": "Psalms 102:8",
      "text": "Mine enemies reproach me all the day; and they that are mad against me are sworn against me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 9,
      "referenceLabel": "Psalms 102:9",
      "text": "For I have eaten ashes like bread, and mingled my drink with weeping,",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 10,
      "referenceLabel": "Psalms 102:10",
      "text": "Because of thine indignation and thy wrath: for thou hast lifted me up, and cast me down.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 11,
      "referenceLabel": "Psalms 102:11",
      "text": "My days are like a shadow that declineth; and I am withered like grass.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 12,
      "referenceLabel": "Psalms 102:12",
      "text": "But thou, O Lord, shalt endure for ever; and thy remembrance unto all generations.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 13,
      "referenceLabel": "Psalms 102:13",
      "text": "Thou shalt arise, and have mercy upon Zion: for the time to favour her, yea, the set time, is come.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 14,
      "referenceLabel": "Psalms 102:14",
      "text": "For thy servants take pleasure in her stones, and favour the dust thereof.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 15,
      "referenceLabel": "Psalms 102:15",
      "text": "So the heathen shall fear the name of the Lord, and all the kings of the earth thy glory.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 16,
      "referenceLabel": "Psalms 102:16",
      "text": "When the Lord shall build up Zion, he shall appear in his glory.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 17,
      "referenceLabel": "Psalms 102:17",
      "text": "He will regard the prayer of the destitute, and not despise their prayer.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 18,
      "referenceLabel": "Psalms 102:18",
      "text": "This shall be written for the generation to come: and the people which shall be created shall praise the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 19,
      "referenceLabel": "Psalms 102:19",
      "text": "For he hath looked down from the height of his sanctuary; from heaven did the Lord behold the earth;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 20,
      "referenceLabel": "Psalms 102:20",
      "text": "To hear the groaning of the prisoner; to loose those that are appointed to death;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 21,
      "referenceLabel": "Psalms 102:21",
      "text": "To declare the name of the Lord in Zion, and his praise in Jerusalem;",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 22,
      "referenceLabel": "Psalms 102:22",
      "text": "When the people are gathered together, and the kingdoms, to serve the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.23",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 23,
      "referenceLabel": "Psalms 102:23",
      "text": "He weakened my strength in the way; he shortened my days.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.24",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 24,
      "referenceLabel": "Psalms 102:24",
      "text": "I said, O my God, take me not away in the midst of my days: thy years are throughout all generations.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.25",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 25,
      "referenceLabel": "Psalms 102:25",
      "text": "Of old hast thou laid the foundation of the earth: and the heavens are the work of thy hands.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.26",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 26,
      "referenceLabel": "Psalms 102:26",
      "text": "They shall perish, but thou shalt endure: yea, all of them shall wax old like a garment; as a vesture shalt thou change them, and they shall be changed:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.27",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 27,
      "referenceLabel": "Psalms 102:27",
      "text": "But thou art the same, and thy years shall have no end.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.102.28",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 28,
      "referenceLabel": "Psalms 102:28",
      "text": "The children of thy servants shall continue, and their seed shall be established before thee.",
      "paragraphStart": false
    }
  ]
}
