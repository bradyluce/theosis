{
  "chapter": {
    "id": "kjva:psalms.146",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 146,
    "referenceLabel": "Psalms 146",
    "summary": "Source text for Psalms 146 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.146.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 1,
      "referenceLabel": "Psalms 146:1",
      "text": "Praise ye the Lord. Praise the Lord, O my soul.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.146.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 2,
      "referenceLabel": "Psalms 146:2",
      "text": "While I live will I praise the Lord: I will sing praises unto my God while I have any being.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.146.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 3,
      "referenceLabel": "Psalms 146:3",
      "text": "Put not your trust in princes, nor in the son of man, in whom there is no help.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.146.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 4,
      "referenceLabel": "Psalms 146:4",
      "text": "His breath goeth forth, he returneth to his earth; in that very day his thoughts perish.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.146.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 5,
      "referenceLabel": "Psalms 146:5",
      "text": "Happy is he that hath the God of Jacob for his help, whose hope is in the Lord his God:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.146.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 6,
      "referenceLabel": "Psalms 146:6",
      "text": "Which made heaven, and earth, the sea, and all that therein is: which keepeth truth for ever:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.146.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 7,
      "referenceLabel": "Psalms 146:7",
      "text": "Which executeth judgment for the oppressed: which giveth food to the hungry. The Lord looseth the prisoners:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.146.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 8,
      "referenceLabel": "Psalms 146:8",
      "text": "The Lord openeth the eyes of the blind: the Lord raiseth them that are bowed down: the Lord loveth the righteous:",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.146.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 9,
      "referenceLabel": "Psalms 146:9",
      "text": "The Lord preserveth the strangers; he relieveth the fatherless and widow: but the way of the wicked he turneth upside down.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.146.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 10,
      "referenceLabel": "Psalms 146:10",
      "text": "The Lord shall reign for ever, even thy God, O Zion, unto all generations. Praise ye the Lord.",
      "paragraphStart": false
    }
  ]
}
