{
  "chapter": {
    "id": "kjva:psalms.69",
    "translationId": "kjva",
    "bookSlug": "psalms",
    "chapterNumber": 69,
    "referenceLabel": "Psalms 69",
    "summary": "Source text for Psalms 69 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:psalms.69.1",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 1,
      "referenceLabel": "Psalms 69:1",
      "text": "Save me, O God; for the waters are come in unto my soul.",
      "paragraphStart": true
    },
    {
      "id": "kjva:psalms.69.2",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 2,
      "referenceLabel": "Psalms 69:2",
      "text": "I sink in deep mire, where there is no standing: I am come into deep waters, where the floods overflow me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.3",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 3,
      "referenceLabel": "Psalms 69:3",
      "text": "I am weary of my crying: my throat is dried: mine eyes fail while I wait for my God.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.4",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 4,
      "referenceLabel": "Psalms 69:4",
      "text": "They that hate me without a cause are more than the hairs of mine head: they that would destroy me, being mine enemies wrongfully, are mighty: then I restored that which I took not away.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.5",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 5,
      "referenceLabel": "Psalms 69:5",
      "text": "O God, thou knowest my foolishness; and my sins are not hid from thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.6",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 6,
      "referenceLabel": "Psalms 69:6",
      "text": "Let not them that wait on thee, O Lord God of hosts, be ashamed for my sake: let not those that seek thee be confounded for my sake, O God of Israel.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.7",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 7,
      "referenceLabel": "Psalms 69:7",
      "text": "Because for thy sake I have borne reproach; shame hath covered my face.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.8",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 8,
      "referenceLabel": "Psalms 69:8",
      "text": "I am become a stranger unto my brethren, and an alien unto my mother’s children.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.9",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 9,
      "referenceLabel": "Psalms 69:9",
      "text": "For the zeal of thine house hath eaten me up; and the reproaches of them that reproached thee are fallen upon me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.10",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 10,
      "referenceLabel": "Psalms 69:10",
      "text": "When I wept, and chastened my soul with fasting, that was to my reproach.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.11",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 11,
      "referenceLabel": "Psalms 69:11",
      "text": "I made sackcloth also my garment; and I became a proverb to them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.12",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 12,
      "referenceLabel": "Psalms 69:12",
      "text": "They that sit in the gate speak against me; and I was the song of the drunkards.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.13",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 13,
      "referenceLabel": "Psalms 69:13",
      "text": "But as for me, my prayer is unto thee, O Lord, in an acceptable time: O God, in the multitude of thy mercy hear me, in the truth of thy salvation.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.14",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 14,
      "referenceLabel": "Psalms 69:14",
      "text": "Deliver me out of the mire, and let me not sink: let me be delivered from them that hate me, and out of the deep waters.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.15",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 15,
      "referenceLabel": "Psalms 69:15",
      "text": "Let not the waterflood overflow me, neither let the deep swallow me up, and let not the pit shut her mouth upon me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.16",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 16,
      "referenceLabel": "Psalms 69:16",
      "text": "Hear me, O Lord; for thy lovingkindness is good: turn unto me according to the multitude of thy tender mercies.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.17",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 17,
      "referenceLabel": "Psalms 69:17",
      "text": "And hide not thy face from thy servant; for I am in trouble: hear me speedily.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.18",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 18,
      "referenceLabel": "Psalms 69:18",
      "text": "Draw nigh unto my soul, and redeem it: deliver me because of mine enemies.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.19",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 19,
      "referenceLabel": "Psalms 69:19",
      "text": "Thou hast known my reproach, and my shame, and my dishonour: mine adversaries are all before thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.20",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 20,
      "referenceLabel": "Psalms 69:20",
      "text": "Reproach hath broken my heart; and I am full of heaviness: and I looked for some to take pity, but there was none; and for comforters, but I found none.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.21",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 21,
      "referenceLabel": "Psalms 69:21",
      "text": "They gave me also gall for my meat; and in my thirst they gave me vinegar to drink.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.22",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 22,
      "referenceLabel": "Psalms 69:22",
      "text": "Let their table become a snare before them: and that which should have been for their welfare, let it become a trap.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.23",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 23,
      "referenceLabel": "Psalms 69:23",
      "text": "Let their eyes be darkened, that they see not; and make their loins continually to shake.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.24",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 24,
      "referenceLabel": "Psalms 69:24",
      "text": "Pour out thine indignation upon them, and let thy wrathful anger take hold of them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.25",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 25,
      "referenceLabel": "Psalms 69:25",
      "text": "Let their habitation be desolate; and let none dwell in their tents.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.26",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 26,
      "referenceLabel": "Psalms 69:26",
      "text": "For they persecute him whom thou hast smitten; and they talk to the grief of those whom thou hast wounded.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.27",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 27,
      "referenceLabel": "Psalms 69:27",
      "text": "Add iniquity unto their iniquity: and let them not come into thy righteousness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.28",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 28,
      "referenceLabel": "Psalms 69:28",
      "text": "Let them be blotted out of the book of the living, and not be written with the righteous.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.29",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 29,
      "referenceLabel": "Psalms 69:29",
      "text": "But I am poor and sorrowful: let thy salvation, O God, set me up on high.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.30",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 30,
      "referenceLabel": "Psalms 69:30",
      "text": "I will praise the name of God with a song, and will magnify him with thanksgiving.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.31",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 31,
      "referenceLabel": "Psalms 69:31",
      "text": "This also shall please the Lord better than an ox or bullock that hath horns and hoofs.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.32",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 32,
      "referenceLabel": "Psalms 69:32",
      "text": "The humble shall see this, and be glad: and your heart shall live that seek God.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.33",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 33,
      "referenceLabel": "Psalms 69:33",
      "text": "For the Lord heareth the poor, and despiseth not his prisoners.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.34",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 34,
      "referenceLabel": "Psalms 69:34",
      "text": "Let the heaven and earth praise him, the seas, and every thing that moveth therein.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.35",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 35,
      "referenceLabel": "Psalms 69:35",
      "text": "For God will save Zion, and will build the cities of Judah: that they may dwell there, and have it in possession.",
      "paragraphStart": false
    },
    {
      "id": "kjva:psalms.69.36",
      "translationId": "kjva",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 36,
      "referenceLabel": "Psalms 69:36",
      "text": "The seed also of his servants shall inherit it: and they that love his name shall dwell therein.",
      "paragraphStart": false
    }
  ]
}
