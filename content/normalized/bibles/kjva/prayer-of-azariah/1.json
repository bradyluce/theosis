{
  "chapter": {
    "id": "kjva:prayer-of-azariah.1",
    "translationId": "kjva",
    "bookSlug": "prayer-of-azariah",
    "chapterNumber": 1,
    "referenceLabel": "Prayer of Azariah 1",
    "summary": "Source text for Prayer of Azariah 1 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:prayer-of-azariah.1.1",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Prayer of Azariah 1:1",
      "text": "And they walked in the midst of the fire, praising God, and blessing the Lord.",
      "paragraphStart": true
    },
    {
      "id": "kjva:prayer-of-azariah.1.2",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Prayer of Azariah 1:2",
      "text": "Then Azarias stood up, and prayed on this manner; and opening his mouth in the midst of the fire said,",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.3",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Prayer of Azariah 1:3",
      "text": "Blessed art thou, O Lord God of our fathers: thy name is worthy to be praised and glorified for evermore:",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.4",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Prayer of Azariah 1:4",
      "text": "For thou art righteous in all the things that thou hast done to us: yea, true are all thy works, thy ways are right, and all thy judgments truth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.5",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Prayer of Azariah 1:5",
      "text": "In all the things that thou hast brought upon us, and upon the holy city of our fathers, even Jerusalem, thou hast executed true judgment: for according to truth and judgment didst thou bring all these things upon us because of our sins.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.6",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Prayer of Azariah 1:6",
      "text": "For we have sinned and committed iniquity, departing from thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.7",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Prayer of Azariah 1:7",
      "text": "In all things have we trespassed, and not obeyed thy commandments, nor kept them, neither done as thou hast commanded us, that it might go well with us.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.8",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Prayer of Azariah 1:8",
      "text": "Wherefore all that thou hast brought upon us, and every thing that thou hast done to us, thou hast done in true judgment.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.9",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Prayer of Azariah 1:9",
      "text": "And thou didst deliver us into the hands of lawless enemies, most hateful forsakers of God, and to an unjust king, and the most wicked in all the world.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.10",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Prayer of Azariah 1:10",
      "text": "And now we cannot open our mouths, we are become a shame and reproach to thy servants; and to them that worship thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.11",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Prayer of Azariah 1:11",
      "text": "Yet deliver us not up wholly, for thy name’s sake, neither disannul thou thy covenant:",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.12",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Prayer of Azariah 1:12",
      "text": "And cause not thy mercy to depart from us, for thy beloved Abraham’s sake, for thy servant Issac’s sake, and for thy holy Israel’s sake;",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.13",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Prayer of Azariah 1:13",
      "text": "To whom thou hast spoken and promised, that thou wouldest multiply their seed as the stars of heaven, and as the sand that lieth upon the seashore.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.14",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Prayer of Azariah 1:14",
      "text": "For we, O Lord, are become less than any nation, and be kept under this day in all the world because of our sins.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.15",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Prayer of Azariah 1:15",
      "text": "Neither is there at this time prince, or prophet, or leader, or burnt offering, or sacrifice, or oblation, or incense, or place to sacrifice before thee, and to find mercy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.16",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Prayer of Azariah 1:16",
      "text": "Nevertheless in a contrite heart and an humble spirit let us be accepted.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.17",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Prayer of Azariah 1:17",
      "text": "Like as in the burnt offerings of rams and bullocks, and like as in ten thousands of fat lambs: so let our sacrifice be in thy sight this day, and grant that we may wholly go after thee: for they shall not be confounded that put their trust in thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.18",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Prayer of Azariah 1:18",
      "text": "And now we follow thee with all our heart, we fear thee, and seek thy face.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.19",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Prayer of Azariah 1:19",
      "text": "Put us not to shame: but deal with us after thy lovingkindness, and according to the multitude of thy mercies.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.20",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Prayer of Azariah 1:20",
      "text": "Deliver us also according to thy marvellous works, and give glory to thy name, O Lord: and let all them that do thy servants hurt be ashamed;",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.21",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Prayer of Azariah 1:21",
      "text": "And let them be confounded in all their power and might, and let their strength be broken;",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.22",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Prayer of Azariah 1:22",
      "text": "And let them know that thou art God, the only God, and glorious over the whole world.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.23",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Prayer of Azariah 1:23",
      "text": "And the king’s servants, that put them in, ceased not to make the oven hot with rosin, pitch, tow, and small wood;",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.24",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Prayer of Azariah 1:24",
      "text": "So that the flame streamed forth above the furnace forty and nine cubits.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.25",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Prayer of Azariah 1:25",
      "text": "And it passed through, and burned those Chaldeans it found about the furnace.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.26",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "Prayer of Azariah 1:26",
      "text": "But the angel of the Lord came down into the oven together with Azarias and his fellows, and smote the flame of the fire out of the oven;",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.27",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "Prayer of Azariah 1:27",
      "text": "And made the midst of the furnace as it had been a moist whistling wind, so that the fire touched them not at all, neither hurt nor troubled them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.28",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "Prayer of Azariah 1:28",
      "text": "Then the three, as out of one mouth, praised, glorified, and blessed, God in the furnace, saying,",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.29",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "Prayer of Azariah 1:29",
      "text": "Blessed art thou, O Lord God of our fathers: and to be praised and exalted above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.30",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "Prayer of Azariah 1:30",
      "text": "And blessed is thy glorious and holy name: and to be praised and exalted above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.31",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "Prayer of Azariah 1:31",
      "text": "Blessed art thou in the temple of thine holy glory: and to be praised and glorified above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.32",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "Prayer of Azariah 1:32",
      "text": "Blessed art thou that beholdest the depths, and sittest upon the cherubims: and to be praised and exalted above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.33",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "Prayer of Azariah 1:33",
      "text": "Blessed art thou on the glorious throne of thy kingdom: and to be praised and glorified above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.34",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "Prayer of Azariah 1:34",
      "text": "Blessed art thou in the firmament of heaven: and above all to be praised and glorified for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.35",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "Prayer of Azariah 1:35",
      "text": "O all ye works of the Lord, bless ye the Lord: praise and exalt him above all for ever,",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.36",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "Prayer of Azariah 1:36",
      "text": "O ye heavens, bless ye the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.37",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "Prayer of Azariah 1:37",
      "text": "O ye angels of the Lord, bless ye the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.38",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "Prayer of Azariah 1:38",
      "text": "O all ye waters that be above the heaven, bless ye the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.39",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "Prayer of Azariah 1:39",
      "text": "O all ye powers of the Lord, bless ye the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.40",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "Prayer of Azariah 1:40",
      "text": "O ye sun and moon, bless ye the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.41",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 41,
      "referenceLabel": "Prayer of Azariah 1:41",
      "text": "O ye stars of heaven, bless ye the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.42",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 42,
      "referenceLabel": "Prayer of Azariah 1:42",
      "text": "O every shower and dew, bless ye the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.43",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 43,
      "referenceLabel": "Prayer of Azariah 1:43",
      "text": "O all ye winds, bless ye the Lord: praise and exalt him above all for ever,",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.44",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 44,
      "referenceLabel": "Prayer of Azariah 1:44",
      "text": "O ye fire and heat, bless ye the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.45",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 45,
      "referenceLabel": "Prayer of Azariah 1:45",
      "text": "O ye winter and summer, bless ye the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.46",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 46,
      "referenceLabel": "Prayer of Azariah 1:46",
      "text": "O ye dews and storms of snow, bless ye the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.47",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 47,
      "referenceLabel": "Prayer of Azariah 1:47",
      "text": "O ye nights and days, bless ye the Lord: bless and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.48",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 48,
      "referenceLabel": "Prayer of Azariah 1:48",
      "text": "O ye light and darkness, bless ye the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.49",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 49,
      "referenceLabel": "Prayer of Azariah 1:49",
      "text": "O ye ice and cold, bless ye the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.50",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 50,
      "referenceLabel": "Prayer of Azariah 1:50",
      "text": "O ye frost and snow, bless ye the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.51",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 51,
      "referenceLabel": "Prayer of Azariah 1:51",
      "text": "O ye lightnings and clouds, bless ye the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.52",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 52,
      "referenceLabel": "Prayer of Azariah 1:52",
      "text": "O let the earth bless the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.53",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 53,
      "referenceLabel": "Prayer of Azariah 1:53",
      "text": "O ye mountains and little hills, bless ye the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.54",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 54,
      "referenceLabel": "Prayer of Azariah 1:54",
      "text": "O all ye things that grow in the earth, bless ye the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.55",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 55,
      "referenceLabel": "Prayer of Azariah 1:55",
      "text": "O ye mountains, bless ye the Lord: Praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.56",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 56,
      "referenceLabel": "Prayer of Azariah 1:56",
      "text": "O ye seas and rivers, bless ye the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.57",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 57,
      "referenceLabel": "Prayer of Azariah 1:57",
      "text": "O ye whales, and all that move in the waters, bless ye the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.58",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 58,
      "referenceLabel": "Prayer of Azariah 1:58",
      "text": "O all ye fowls of the air, bless ye the Lord: praise and exalt him above all for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:prayer-of-azariah.1.59",
      "translationId": "kjva",
      "bookSlug": "prayer-of-azariah",
      "chapterNumber": 1,
      "verseNumber": 59,
