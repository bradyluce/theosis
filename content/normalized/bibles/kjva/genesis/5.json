{
  "chapter": {
    "id": "kjva:genesis.5",
    "translationId": "kjva",
    "bookSlug": "genesis",
    "chapterNumber": 5,
    "referenceLabel": "Genesis 5",
    "summary": "Source text for Genesis 5 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:genesis.5.1",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Genesis 5:1",
      "text": "This is the book of the generations of Adam. In the day that God created man, in the likeness of God made he him;",
      "paragraphStart": true
    },
    {
      "id": "kjva:genesis.5.2",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Genesis 5:2",
      "text": "Male and female created he them; and blessed them, and called their name Adam, in the day when they were created.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.3",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Genesis 5:3",
      "text": "And Adam lived an hundred and thirty years, and begat a son in his own likeness, after his image; and called his name Seth:",
      "paragraphStart": true
    },
    {
      "id": "kjva:genesis.5.4",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Genesis 5:4",
      "text": "And the days of Adam after he had begotten Seth were eight hundred years: and he begat sons and daughters:",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.5",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Genesis 5:5",
      "text": "And all the days that Adam lived were nine hundred and thirty years: and he died.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.6",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Genesis 5:6",
      "text": "And Seth lived an hundred and five years, and begat Enos:",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.7",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Genesis 5:7",
      "text": "And Seth lived after he begat Enos eight hundred and seven years, and begat sons and daughters:",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.8",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Genesis 5:8",
      "text": "And all the days of Seth were nine hundred and twelve years: and he died.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.9",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Genesis 5:9",
      "text": "And Enos lived ninety years, and begat Cainan:",
      "paragraphStart": true
    },
    {
      "id": "kjva:genesis.5.10",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Genesis 5:10",
      "text": "And Enos lived after he begat Cainan eight hundred and fifteen years, and begat sons and daughters:",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.11",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Genesis 5:11",
      "text": "And all the days of Enos were nine hundred and five years: and he died.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.12",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Genesis 5:12",
      "text": "And Cainan lived seventy years, and begat Mahalaleel:",
      "paragraphStart": true
    },
    {
      "id": "kjva:genesis.5.13",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Genesis 5:13",
      "text": "And Cainan lived after he begat Mahalaleel eight hundred and forty years, and begat sons and daughters:",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.14",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Genesis 5:14",
      "text": "And all the days of Cainan were nine hundred and ten years: and he died.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.15",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Genesis 5:15",
      "text": "And Mahalaleel lived sixty and five years, and begat Jared:",
      "paragraphStart": true
    },
    {
      "id": "kjva:genesis.5.16",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Genesis 5:16",
      "text": "And Mahalaleel lived after he begat Jared eight hundred and thirty years, and begat sons and daughters:",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.17",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Genesis 5:17",
      "text": "And all the days of Mahalaleel were eight hundred ninety and five years: and he died.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.18",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Genesis 5:18",
      "text": "And Jared lived an hundred sixty and two years, and he begat Enoch:",
      "paragraphStart": true
    },
    {
      "id": "kjva:genesis.5.19",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Genesis 5:19",
      "text": "And Jared lived after he begat Enoch eight hundred years, and begat sons and daughters:",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.20",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Genesis 5:20",
      "text": "And all the days of Jared were nine hundred sixty and two years: and he died.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.21",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Genesis 5:21",
      "text": "And Enoch lived sixty and five years, and begat Methuselah:",
      "paragraphStart": true
    },
    {
      "id": "kjva:genesis.5.22",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Genesis 5:22",
      "text": "And Enoch walked with God after he begat Methuselah three hundred years, and begat sons and daughters:",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.23",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Genesis 5:23",
      "text": "And all the days of Enoch were three hundred sixty and five years:",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.24",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Genesis 5:24",
      "text": "And Enoch walked with God: and he was not; for God took him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.25",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Genesis 5:25",
      "text": "And Methuselah lived an hundred eighty and seven years, and begat Lamech:",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.26",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Genesis 5:26",
      "text": "And Methuselah lived after he begat Lamech seven hundred eighty and two years, and begat sons and daughters:",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.27",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Genesis 5:27",
      "text": "And all the days of Methuselah were nine hundred sixty and nine years: and he died.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.28",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "Genesis 5:28",
      "text": "And Lamech lived an hundred eighty and two years, and begat a son:",
      "paragraphStart": true
    },
    {
      "id": "kjva:genesis.5.29",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "Genesis 5:29",
      "text": "And he called his name Noah, saying, This same shall comfort us concerning our work and toil of our hands, because of the ground which the Lord hath cursed.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.30",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "Genesis 5:30",
      "text": "And Lamech lived after he begat Noah five hundred ninety and five years, and begat sons and daughters:",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.31",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "Genesis 5:31",
      "text": "And all the days of Lamech were seven hundred seventy and seven years: and he died.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.5.32",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 32,
      "referenceLabel": "Genesis 5:32",
      "text": "And Noah was five hundred years old: and Noah begat Shem, Ham, and Japheth.",
      "paragraphStart": false
    }
  ]
}
