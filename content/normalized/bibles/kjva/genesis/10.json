{
  "chapter": {
    "id": "kjva:genesis.10",
    "translationId": "kjva",
    "bookSlug": "genesis",
    "chapterNumber": 10,
    "referenceLabel": "Genesis 10",
    "summary": "Source text for Genesis 10 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:genesis.10.1",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Genesis 10:1",
      "text": "Now these are the generations of the sons of Noah, Shem, Ham, and Japheth: and unto them were sons born after the flood.",
      "paragraphStart": true
    },
    {
      "id": "kjva:genesis.10.2",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Genesis 10:2",
      "text": "The sons of Japheth; Gomer, and Magog, and Madai, and Javan, and Tubal, and Meshech, and Tiras.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.3",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Genesis 10:3",
      "text": "And the sons of Gomer; Ashkenaz, and Riphath, and Togarmah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.4",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Genesis 10:4",
      "text": "And the sons of Javan; Elishah, and Tarshish, Kittim, and Dodanim.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.5",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Genesis 10:5",
      "text": "By these were the isles of the Gentiles divided in their lands; every one after his tongue, after their families, in their nations.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.6",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Genesis 10:6",
      "text": "And the sons of Ham; Cush, and Mizraim, and Phut, and Canaan.",
      "paragraphStart": true
    },
    {
      "id": "kjva:genesis.10.7",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Genesis 10:7",
      "text": "And the sons of Cush; Seba, and Havilah, and Sabtah, and Raamah, and Sabtecha: and the sons of Raamah; Sheba, and Dedan.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.8",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Genesis 10:8",
      "text": "And Cush begat Nimrod: he began to be a mighty one in the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.9",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Genesis 10:9",
      "text": "He was a mighty hunter before the Lord: wherefore it is said, Even as Nimrod the mighty hunter before the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.10",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Genesis 10:10",
      "text": "And the beginning of his kingdom was Babel, and Erech, and Accad, and Calneh, in the land of Shinar.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.11",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Genesis 10:11",
      "text": "Out of that land went forth Asshur, and builded Nineveh, and the city Rehoboth, and Calah,",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.12",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Genesis 10:12",
      "text": "And Resen between Nineveh and Calah: the same is a great city.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.13",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Genesis 10:13",
      "text": "And Mizraim begat Ludim, and Anamim, and Lehabim, and Naphtuhim,",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.14",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Genesis 10:14",
      "text": "And Pathrusim, and Casluhim, (out of whom came Philistim,) and Caphtorim.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.15",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Genesis 10:15",
      "text": "And Canaan begat Sidon his firstborn, and Heth,",
      "paragraphStart": true
    },
    {
      "id": "kjva:genesis.10.16",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Genesis 10:16",
      "text": "And the Jebusite, and the Amorite, and the Girgasite,",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.17",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Genesis 10:17",
      "text": "And the Hivite, and the Arkite, and the Sinite,",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.18",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Genesis 10:18",
      "text": "And the Arvadite, and the Zemarite, and the Hamathite: and afterward were the families of the Canaanites spread abroad.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.19",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Genesis 10:19",
      "text": "And the border of the Canaanites was from Sidon, as thou comest to Gerar, unto Gaza; as thou goest, unto Sodom, and Gomorrah, and Admah, and Zeboim, even unto Lasha.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.20",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Genesis 10:20",
      "text": "These are the sons of Ham, after their families, after their tongues, in their countries, and in their nations.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.21",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Genesis 10:21",
      "text": "Unto Shem also, the father of all the children of Eber, the brother of Japheth the elder, even to him were children born.",
      "paragraphStart": true
    },
    {
      "id": "kjva:genesis.10.22",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Genesis 10:22",
      "text": "The children of Shem; Elam, and Asshur, and Arphaxad, and Lud, and Aram.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.23",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Genesis 10:23",
      "text": "And the children of Aram; Uz, and Hul, and Gether, and Mash.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.24",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Genesis 10:24",
      "text": "And Arphaxad begat Salah; and Salah begat Eber.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.25",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Genesis 10:25",
      "text": "And unto Eber were born two sons: the name of one was Peleg; for in his days was the earth divided; and his brother’s name was Joktan.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.26",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Genesis 10:26",
      "text": "And Joktan begat Almodad, and Sheleph, and Hazarmaveth, and Jerah,",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.27",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Genesis 10:27",
      "text": "And Hadoram, and Uzal, and Diklah,",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.28",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Genesis 10:28",
      "text": "And Obal, and Abimael, and Sheba,",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.29",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Genesis 10:29",
      "text": "And Ophir, and Havilah, and Jobab: all these were the sons of Joktan.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.30",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Genesis 10:30",
      "text": "And their dwelling was from Mesha, as thou goest unto Sephar a mount of the east.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.31",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Genesis 10:31",
      "text": "These are the sons of Shem, after their families, after their tongues, in their lands, after their nations.",
      "paragraphStart": false
    },
    {
      "id": "kjva:genesis.10.32",
      "translationId": "kjva",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Genesis 10:32",
      "text": "These are the families of the sons of Noah, after their generations, in their nations: and by these were the nations divided in the earth after the flood.",
      "paragraphStart": false
    }
  ]
}
