{
  "chapter": {
    "id": "kjva:first-chronicles.1",
    "translationId": "kjva",
    "bookSlug": "first-chronicles",
    "chapterNumber": 1,
    "referenceLabel": "1 Chronicles 1",
    "summary": "Source text for 1 Chronicles 1 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:first-chronicles.1.1",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 1:1",
      "text": "Adam, Sheth, Enosh,",
      "paragraphStart": true
    },
    {
      "id": "kjva:first-chronicles.1.2",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 1:2",
      "text": "Kenan, Mahalaleel, Jered,",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.3",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 1:3",
      "text": "Henoch, Methuselah, Lamech,",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.4",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 1:4",
      "text": "Noah, Shem, Ham, and Japheth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.5",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 1:5",
      "text": "The sons of Japheth; Gomer, and Magog, and Madai, and Javan, and Tubal, and Meshech, and Tiras.",
      "paragraphStart": true
    },
    {
      "id": "kjva:first-chronicles.1.6",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 1:6",
      "text": "And the sons of Gomer; Ashchenaz, and Riphath, and Togarmah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.7",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 1:7",
      "text": "And the sons of Javan; Elishah, and Tarshish, Kittim, and Dodanim.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.8",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 1:8",
      "text": "The sons of Ham; Cush, and Mizraim, Put, and Canaan.",
      "paragraphStart": true
    },
    {
      "id": "kjva:first-chronicles.1.9",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 1:9",
      "text": "And the sons of Cush; Seba, and Havilah, and Sabta, and Raamah, and Sabtecha. And the sons of Raamah; Sheba, and Dedan.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.10",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 1:10",
      "text": "And Cush begat Nimrod: he began to be mighty upon the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.11",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 1:11",
      "text": "And Mizraim begat Ludim, and Anamim, and Lehabim, and Naphtuhim,",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.12",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 1:12",
      "text": "And Pathrusim, and Casluhim, (of whom came the Philistines,) and Caphthorim.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.13",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 1:13",
      "text": "And Canaan begat Zidon his firstborn, and Heth,",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.14",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 1:14",
      "text": "The Jebusite also, and the Amorite, and the Girgashite,",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.15",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 1:15",
      "text": "And the Hivite, and the Arkite, and the Sinite,",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.16",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 1:16",
      "text": "And the Arvadite, and the Zemarite, and the Hamathite.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.17",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 1:17",
      "text": "The sons of Shem; Elam, and Asshur, and Arphaxad, and Lud, and Aram, and Uz, and Hul, and Gether, and Meshech.",
      "paragraphStart": true
    },
    {
      "id": "kjva:first-chronicles.1.18",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 1:18",
      "text": "And Arphaxad begat Shelah, and Shelah begat Eber.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.19",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 1:19",
      "text": "And unto Eber were born two sons: the name of the one was Peleg; because in his days the earth was divided: and his brother’s name was Joktan.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.20",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 1:20",
      "text": "And Joktan begat Almodad, and Sheleph, and Hazarmaveth, and Jerah,",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.21",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 1:21",
      "text": "Hadoram also, and Uzal, and Diklah,",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.22",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 1:22",
      "text": "And Ebal, and Abimael, and Sheba,",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.23",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 1:23",
      "text": "And Ophir, and Havilah, and Jobab. All these were the sons of Joktan.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.24",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 1:24",
      "text": "Shem, Arphaxad, Shelah,",
      "paragraphStart": true
    },
    {
      "id": "kjva:first-chronicles.1.25",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 1:25",
      "text": "Eber, Peleg, Reu,",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.26",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 1:26",
      "text": "Serug, Nahor, Terah,",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.27",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 1:27",
      "text": "Abram; the same is Abraham.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.28",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 1:28",
      "text": "The sons of Abraham; Isaac, and Ishmael.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.29",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 1:29",
      "text": "These are their generations: The firstborn of Ishmael, Nebaioth; then Kedar, and Adbeel, and Mibsam,",
      "paragraphStart": true
    },
    {
      "id": "kjva:first-chronicles.1.30",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 1:30",
      "text": "Mishma, and Dumah, Massa, Hadad, and Tema,",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.31",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 1:31",
      "text": "Jetur, Naphish, and Kedemah. These are the sons of Ishmael.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.32",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 1:32",
      "text": "Now the sons of Keturah, Abraham’s concubine: she bare Zimran, and Jokshan, and Medan, and Midian, and Ishbak, and Shuah. And the sons of Jokshan; Sheba, and Dedan.",
      "paragraphStart": true
    },
    {
      "id": "kjva:first-chronicles.1.33",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 1:33",
      "text": "And the sons of Midian; Ephah, and Epher, and Henoch, and Abida, and Eldaah. All these are the sons of Keturah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.34",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 1:34",
      "text": "And Abraham begat Isaac. The sons of Isaac; Esau and Israel.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.35",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 1:35",
      "text": "The sons of Esau; Eliphaz, Reuel, and Jeush, and Jaalam, and Korah.",
      "paragraphStart": true
    },
    {
      "id": "kjva:first-chronicles.1.36",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 1:36",
      "text": "The sons of Eliphaz; Teman, and Omar, Zephi, and Gatam, Kenaz, and Timna, and Amalek.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.37",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 1:37",
      "text": "The sons of Reuel; Nahath, Zerah, Shammah, and Mizzah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.38",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 1:38",
      "text": "And the sons of Seir; Lotan, and Shobal, and Zibeon, and Anah, and Dishon, and Ezer, and Dishan.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.39",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 1:39",
      "text": "And the sons of Lotan; Hori, and Homam: and Timna was Lotan’s sister.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.40",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 1:40",
      "text": "The sons of Shobal; Alian, and Manahath, and Ebal, Shephi, and Onam. And the sons of Zibeon; Aiah, and Anah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.41",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 41,
      "referenceLabel": "1 Chronicles 1:41",
      "text": "The sons of Anah; Dishon. And the sons of Dishon; Amram, and Eshban, and Ithran, and Cheran.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.42",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 42,
      "referenceLabel": "1 Chronicles 1:42",
      "text": "The sons of Ezer; Bilhan, and Zavan, and Jakan. The sons of Dishan; Uz, and Aran.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.43",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 43,
      "referenceLabel": "1 Chronicles 1:43",
      "text": "Now these are the kings that reigned in the land of Edom before any king reigned over the children of Israel; Bela the son of Beor: and the name of his city was Dinhabah.",
      "paragraphStart": true
    },
    {
      "id": "kjva:first-chronicles.1.44",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 44,
      "referenceLabel": "1 Chronicles 1:44",
      "text": "And when Bela was dead, Jobab the son of Zerah of Bozrah reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.45",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 45,
      "referenceLabel": "1 Chronicles 1:45",
      "text": "And when Jobab was dead, Husham of the land of the Temanites reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.46",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 46,
      "referenceLabel": "1 Chronicles 1:46",
      "text": "And when Husham was dead, Hadad the son of Bedad, which smote Midian in the field of Moab, reigned in his stead: and the name of his city was Avith.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.47",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 47,
      "referenceLabel": "1 Chronicles 1:47",
      "text": "And when Hadad was dead, Samlah of Masrekah reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.48",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 48,
      "referenceLabel": "1 Chronicles 1:48",
      "text": "And when Samlah was dead, Shaul of Rehoboth by the river reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.49",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 49,
      "referenceLabel": "1 Chronicles 1:49",
      "text": "And when Shaul was dead, Baal–hanan the son of Achbor reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.50",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 50,
      "referenceLabel": "1 Chronicles 1:50",
      "text": "And when Baal–hanan was dead, Hadad reigned in his stead: and the name of his city was Pai; and his wife’s name was Mehetabel, the daughter of Matred, the daughter of Mezahab.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.51",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 51,
      "referenceLabel": "1 Chronicles 1:51",
      "text": "Hadad died also. And the dukes of Edom were; duke Timnah, duke Aliah, duke Jetheth,",
      "paragraphStart": true
    },
    {
      "id": "kjva:first-chronicles.1.52",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 52,
      "referenceLabel": "1 Chronicles 1:52",
      "text": "Duke Aholibamah, duke Elah, duke Pinon,",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.53",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 53,
      "referenceLabel": "1 Chronicles 1:53",
      "text": "Duke Kenaz, duke Teman, duke Mibzar,",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-chronicles.1.54",
      "translationId": "kjva",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 54,
      "referenceLabel": "1 Chronicles 1:54",
      "text": "Duke Magdiel, duke Iram. These are the dukes of Edom.",
      "paragraphStart": false
    }
  ]
}
