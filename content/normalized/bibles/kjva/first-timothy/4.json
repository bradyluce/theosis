{
  "chapter": {
    "id": "kjva:first-timothy.4",
    "translationId": "kjva",
    "bookSlug": "first-timothy",
    "chapterNumber": 4,
    "referenceLabel": "1 Timothy 4",
    "summary": "Source text for 1 Timothy 4 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:first-timothy.4.1",
      "translationId": "kjva",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "1 Timothy 4:1",
      "text": "Now the Spirit speaketh expressly, that in the latter times some shall depart from the faith, giving heed to seducing spirits, and doctrines of devils;",
      "paragraphStart": true
    },
    {
      "id": "kjva:first-timothy.4.2",
      "translationId": "kjva",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "1 Timothy 4:2",
      "text": "Speaking lies in hypocrisy; having their conscience seared with a hot iron;",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-timothy.4.3",
      "translationId": "kjva",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "1 Timothy 4:3",
      "text": "Forbidding to marry, and commanding to abstain from meats, which God hath created to be received with thanksgiving of them which believe and know the truth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-timothy.4.4",
      "translationId": "kjva",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "1 Timothy 4:4",
      "text": "For every creature of God is good, and nothing to be refused, if it be received with thanksgiving:",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-timothy.4.5",
      "translationId": "kjva",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "1 Timothy 4:5",
      "text": "For it is sanctified by the word of God and prayer.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-timothy.4.6",
      "translationId": "kjva",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "1 Timothy 4:6",
      "text": "If thou put the brethren in remembrance of these things, thou shalt be a good minister of Jesus Christ, nourished up in the words of faith and of good doctrine, whereunto thou hast attained.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-timothy.4.7",
      "translationId": "kjva",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "1 Timothy 4:7",
      "text": "But refuse profane and old wives’ fables, and exercise thyself rather unto godliness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-timothy.4.8",
      "translationId": "kjva",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "1 Timothy 4:8",
      "text": "For bodily exercise profiteth little: but godliness is profitable unto all things, having promise of the life that now is, and of that which is to come.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-timothy.4.9",
      "translationId": "kjva",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "1 Timothy 4:9",
      "text": "This is a faithful saying and worthy of all acceptation.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-timothy.4.10",
      "translationId": "kjva",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "1 Timothy 4:10",
      "text": "For therefore we both labour and suffer reproach, because we trust in the living God, who is the Saviour of all men, specially of those that believe.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-timothy.4.11",
      "translationId": "kjva",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "1 Timothy 4:11",
      "text": "These things command and teach.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-timothy.4.12",
      "translationId": "kjva",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "1 Timothy 4:12",
      "text": "Let no man despise thy youth; but be thou an example of the believers, in word, in conversation, in charity, in spirit, in faith, in purity.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-timothy.4.13",
      "translationId": "kjva",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "1 Timothy 4:13",
      "text": "Till I come, give attendance to reading, to exhortation, to doctrine.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-timothy.4.14",
      "translationId": "kjva",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "1 Timothy 4:14",
      "text": "Neglect not the gift that is in thee, which was given thee by prophecy, with the laying on of the hands of the presbytery.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-timothy.4.15",
      "translationId": "kjva",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "1 Timothy 4:15",
      "text": "Meditate upon these things; give thyself wholly to them; that thy profiting may appear to all.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-timothy.4.16",
      "translationId": "kjva",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "1 Timothy 4:16",
      "text": "Take heed unto thyself, and unto the doctrine; continue in them: for in doing this thou shalt both save thyself, and them that hear thee.",
      "paragraphStart": false
    }
  ]
}
