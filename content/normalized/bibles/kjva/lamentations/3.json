{
  "chapter": {
    "id": "kjva:lamentations.3",
    "translationId": "kjva",
    "bookSlug": "lamentations",
    "chapterNumber": 3,
    "referenceLabel": "Lamentations 3",
    "summary": "Source text for Lamentations 3 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:lamentations.3.1",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Lamentations 3:1",
      "text": "I am the man that hath seen affliction by the rod of his wrath.",
      "paragraphStart": true
    },
    {
      "id": "kjva:lamentations.3.2",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Lamentations 3:2",
      "text": "He hath led me, and brought me into darkness, but not into light.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.3",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Lamentations 3:3",
      "text": "Surely against me is he turned; he turneth his hand against me all the day.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.4",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Lamentations 3:4",
      "text": "My flesh and my skin hath he made old; he hath broken my bones.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.5",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Lamentations 3:5",
      "text": "He hath builded against me, and compassed me with gall and travail.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.6",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Lamentations 3:6",
      "text": "He hath set me in dark places, as they that be dead of old.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.7",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Lamentations 3:7",
      "text": "He hath hedged me about, that I cannot get out: he hath made my chain heavy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.8",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Lamentations 3:8",
      "text": "Also when I cry and shout, he shutteth out my prayer.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.9",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Lamentations 3:9",
      "text": "He hath inclosed my ways with hewn stone, he hath made my paths crooked.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.10",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Lamentations 3:10",
      "text": "He was unto me as a bear lying in wait, and as a lion in secret places.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.11",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Lamentations 3:11",
      "text": "He hath turned aside my ways, and pulled me in pieces: he hath made me desolate.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.12",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Lamentations 3:12",
      "text": "He hath bent his bow, and set me as a mark for the arrow.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.13",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Lamentations 3:13",
      "text": "He hath caused the arrows of his quiver to enter into my reins.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.14",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Lamentations 3:14",
      "text": "I was a derision to all my people; and their song all the day.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.15",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Lamentations 3:15",
      "text": "He hath filled me with bitterness, he hath made me drunken with wormwood.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.16",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Lamentations 3:16",
      "text": "He hath also broken my teeth with gravel stones, he hath covered me with ashes.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.17",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Lamentations 3:17",
      "text": "And thou hast removed my soul far off from peace: I forgat prosperity.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.18",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Lamentations 3:18",
      "text": "And I said, My strength and my hope is perished from the Lord:",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.19",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Lamentations 3:19",
      "text": "Remembering mine affliction and my misery, the wormwood and the gall.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.20",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Lamentations 3:20",
      "text": "My soul hath them still in remembrance, and is humbled in me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.21",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Lamentations 3:21",
      "text": "This I recall to my mind, therefore have I hope.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.22",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Lamentations 3:22",
      "text": "It is of the Lord’s mercies that we are not consumed, because his compassions fail not.",
      "paragraphStart": true
    },
    {
      "id": "kjva:lamentations.3.23",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Lamentations 3:23",
      "text": "They are new every morning: great is thy faithfulness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.24",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Lamentations 3:24",
      "text": "The Lord is my portion, saith my soul; therefore will I hope in him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.25",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Lamentations 3:25",
      "text": "The Lord is good unto them that wait for him, to the soul that seeketh him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.26",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Lamentations 3:26",
      "text": "It is good that a man should both hope and quietly wait for the salvation of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.27",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Lamentations 3:27",
      "text": "It is good for a man that he bear the yoke in his youth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.28",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Lamentations 3:28",
      "text": "He sitteth alone and keepeth silence, because he hath borne it upon him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.29",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Lamentations 3:29",
      "text": "He putteth his mouth in the dust; if so be there may be hope.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.30",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Lamentations 3:30",
      "text": "He giveth his cheek to him that smiteth him: he is filled full with reproach.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.31",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Lamentations 3:31",
      "text": "For the Lord will not cast off for ever:",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.32",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "Lamentations 3:32",
      "text": "But though he cause grief, yet will he have compassion according to the multitude of his mercies.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.33",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "Lamentations 3:33",
      "text": "For he doth not afflict willingly nor grieve the children of men.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.34",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "Lamentations 3:34",
      "text": "To crush under his feet all the prisoners of the earth,",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.35",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "Lamentations 3:35",
      "text": "To turn aside the right of a man before the face of the most High,",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.36",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 36,
      "referenceLabel": "Lamentations 3:36",
      "text": "To subvert a man in his cause, the Lord approveth not.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.37",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 37,
      "referenceLabel": "Lamentations 3:37",
      "text": "Who is he that saith, and it cometh to pass, when the Lord commandeth it not?",
      "paragraphStart": true
    },
    {
      "id": "kjva:lamentations.3.38",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 38,
      "referenceLabel": "Lamentations 3:38",
      "text": "Out of the mouth of the most High proceedeth not evil and good?",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.39",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 39,
      "referenceLabel": "Lamentations 3:39",
      "text": "Wherefore doth a living man complain, a man for the punishment of his sins?",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.40",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 40,
      "referenceLabel": "Lamentations 3:40",
      "text": "Let us search and try our ways, and turn again to the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.41",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 41,
      "referenceLabel": "Lamentations 3:41",
      "text": "Let us lift up our heart with our hands unto God in the heavens.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.42",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 42,
      "referenceLabel": "Lamentations 3:42",
      "text": "We have transgressed and have rebelled: thou hast not pardoned.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.43",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 43,
      "referenceLabel": "Lamentations 3:43",
      "text": "Thou hast covered with anger, and persecuted us: thou hast slain, thou hast not pitied.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.44",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 44,
      "referenceLabel": "Lamentations 3:44",
      "text": "Thou hast covered thyself with a cloud, that our prayer should not pass through.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.45",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 45,
      "referenceLabel": "Lamentations 3:45",
      "text": "Thou hast made us as the offscouring and refuse in the midst of the people.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.46",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 46,
      "referenceLabel": "Lamentations 3:46",
      "text": "All our enemies have opened their mouths against us.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.47",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 47,
      "referenceLabel": "Lamentations 3:47",
      "text": "Fear and a snare is come upon us, desolation and destruction.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.48",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 48,
      "referenceLabel": "Lamentations 3:48",
      "text": "Mine eye runneth down with rivers of water for the destruction of the daughter of my people.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.49",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 49,
      "referenceLabel": "Lamentations 3:49",
      "text": "Mine eye trickleth down, and ceaseth not, without any intermission,",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.50",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 50,
      "referenceLabel": "Lamentations 3:50",
      "text": "Till the Lord look down, and behold from heaven.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.51",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 51,
      "referenceLabel": "Lamentations 3:51",
      "text": "Mine eye affecteth mine heart because of all the daughters of my city.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.52",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 52,
      "referenceLabel": "Lamentations 3:52",
      "text": "Mine enemies chased me sore, like a bird, without cause.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.53",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 53,
      "referenceLabel": "Lamentations 3:53",
      "text": "They have cut off my life in the dungeon, and cast a stone upon me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.54",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 54,
      "referenceLabel": "Lamentations 3:54",
      "text": "Waters flowed over mine head; then I said, I am cut off.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.55",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 55,
      "referenceLabel": "Lamentations 3:55",
      "text": "I called upon thy name, O Lord, out of the low dungeon.",
      "paragraphStart": true
    },
    {
      "id": "kjva:lamentations.3.56",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 56,
      "referenceLabel": "Lamentations 3:56",
      "text": "Thou hast heard my voice: hide not thine ear at my breathing, at my cry.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.57",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 57,
      "referenceLabel": "Lamentations 3:57",
      "text": "Thou drewest near in the day that I called upon thee: thou saidst, Fear not.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.58",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 58,
      "referenceLabel": "Lamentations 3:58",
      "text": "O Lord, thou hast pleaded the causes of my soul; thou hast redeemed my life.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.59",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 59,
      "referenceLabel": "Lamentations 3:59",
      "text": "O Lord, thou hast seen my wrong: judge thou my cause.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.60",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 60,
      "referenceLabel": "Lamentations 3:60",
      "text": "Thou hast seen all their vengeance and all their imaginations against me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.61",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 61,
      "referenceLabel": "Lamentations 3:61",
      "text": "Thou hast heard their reproach, O Lord, and all their imaginations against me;",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.62",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 62,
      "referenceLabel": "Lamentations 3:62",
      "text": "The lips of those that rose up against me, and their device against me all the day.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.63",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 63,
      "referenceLabel": "Lamentations 3:63",
      "text": "Behold their sitting down, and their rising up; I am their musick.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.64",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 64,
      "referenceLabel": "Lamentations 3:64",
      "text": "Render unto them a recompence, O Lord, according to the work of their hands.",
      "paragraphStart": true
    },
    {
      "id": "kjva:lamentations.3.65",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 65,
      "referenceLabel": "Lamentations 3:65",
      "text": "Give them sorrow of heart, thy curse unto them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.3.66",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 66,
      "referenceLabel": "Lamentations 3:66",
      "text": "Persecute and destroy them in anger from under the heavens of the Lord.",
      "paragraphStart": false
    }
  ]
}
