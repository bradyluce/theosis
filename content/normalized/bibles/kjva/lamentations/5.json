{
  "chapter": {
    "id": "kjva:lamentations.5",
    "translationId": "kjva",
    "bookSlug": "lamentations",
    "chapterNumber": 5,
    "referenceLabel": "Lamentations 5",
    "summary": "Source text for Lamentations 5 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:lamentations.5.1",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Lamentations 5:1",
      "text": "Remember, O Lord, what is come upon us: consider, and behold our reproach.",
      "paragraphStart": true
    },
    {
      "id": "kjva:lamentations.5.2",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Lamentations 5:2",
      "text": "Our inheritance is turned to strangers, our houses to aliens.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.3",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Lamentations 5:3",
      "text": "We are orphans and fatherless, our mothers are as widows.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.4",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Lamentations 5:4",
      "text": "We have drunken our water for money; our wood is sold unto us.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.5",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Lamentations 5:5",
      "text": "Our necks are under persecution: we labour, and have no rest.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.6",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Lamentations 5:6",
      "text": "We have given the hand to the Egyptians, and to the Assyrians, to be satisfied with bread.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.7",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Lamentations 5:7",
      "text": "Our fathers have sinned, and are not; and we have borne their iniquities.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.8",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Lamentations 5:8",
      "text": "Servants have ruled over us: there is none that doth deliver us out of their hand.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.9",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Lamentations 5:9",
      "text": "We gat our bread with the peril of our lives because of the sword of the wilderness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.10",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Lamentations 5:10",
      "text": "Our skin was black like an oven because of the terrible famine.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.11",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Lamentations 5:11",
      "text": "They ravished the women in Zion, and the maids in the cities of Judah.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.12",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Lamentations 5:12",
      "text": "Princes are hanged up by their hand: the faces of elders were not honoured.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.13",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Lamentations 5:13",
      "text": "They took the young men to grind, and the children fell under the wood.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.14",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Lamentations 5:14",
      "text": "The elders have ceased from the gate, the young men from their musick.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.15",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Lamentations 5:15",
      "text": "The joy of our heart is ceased; our dance is turned into mourning.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.16",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Lamentations 5:16",
      "text": "The crown is fallen from our head: woe unto us, that we have sinned!",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.17",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Lamentations 5:17",
      "text": "For this our heart is faint; for these things our eyes are dim.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.18",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Lamentations 5:18",
      "text": "Because of the mountain of Zion, which is desolate, the foxes walk upon it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.19",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Lamentations 5:19",
      "text": "Thou, O Lord, remainest for ever; thy throne from generation to generation.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.20",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Lamentations 5:20",
      "text": "Wherefore dost thou forget us for ever, and forsake us so long time?",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.21",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Lamentations 5:21",
      "text": "Turn thou us unto thee, O Lord, and we shall be turned; renew our days as of old.",
      "paragraphStart": false
    },
    {
      "id": "kjva:lamentations.5.22",
      "translationId": "kjva",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Lamentations 5:22",
      "text": "But thou hast utterly rejected us; thou art very wroth against us.",
      "paragraphStart": false
    }
  ]
}
