{
  "chapter": {
    "id": "kjva:first-corinthians.13",
    "translationId": "kjva",
    "bookSlug": "first-corinthians",
    "chapterNumber": 13,
    "referenceLabel": "1 Corinthians 13",
    "summary": "Source text for 1 Corinthians 13 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:first-corinthians.13.1",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 13:1",
      "text": "Though I speak with the tongues of men and of angels, and have not charity, I am become as sounding brass, or a tinkling cymbal.",
      "paragraphStart": true
    },
    {
      "id": "kjva:first-corinthians.13.2",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 13:2",
      "text": "And though I have the gift of prophecy, and understand all mysteries, and all knowledge; and though I have all faith, so that I could remove mountains, and have not charity, I am nothing.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.13.3",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 13:3",
      "text": "And though I bestow all my goods to feed the poor, and though I give my body to be burned, and have not charity, it profiteth me nothing.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.13.4",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 13:4",
      "text": "Charity suffereth long, and is kind; charity envieth not; charity vaunteth not itself, is not puffed up,",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.13.5",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 13:5",
      "text": "Doth not behave itself unseemly, seeketh not her own, is not easily provoked, thinketh no evil;",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.13.6",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 13:6",
      "text": "Rejoiceth not in iniquity, but rejoiceth in the truth;",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.13.7",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 13:7",
      "text": "Beareth all things, believeth all things, hopeth all things, endureth all things.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.13.8",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 13:8",
      "text": "Charity never faileth: but whether there be prophecies, they shall fail; whether there be tongues, they shall cease; whether there be knowledge, it shall vanish away.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.13.9",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 13:9",
      "text": "For we know in part, and we prophesy in part.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.13.10",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 13:10",
      "text": "But when that which is perfect is come, then that which is in part shall be done away.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.13.11",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 13:11",
      "text": "When I was a child, I spake as a child, I understood as a child, I thought as a child: but when I became a man, I put away childish things.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.13.12",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 13:12",
      "text": "For now we see through a glass, darkly; but then face to face: now I know in part; but then shall I know even as also I am known.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.13.13",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 13:13",
      "text": "And now abideth faith, hope, charity, these three; but the greatest of these is charity.",
      "paragraphStart": false
    }
  ]
}
