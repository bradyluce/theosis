{
  "chapter": {
    "id": "kjva:first-corinthians.16",
    "translationId": "kjva",
    "bookSlug": "first-corinthians",
    "chapterNumber": 16,
    "referenceLabel": "1 Corinthians 16",
    "summary": "Source text for 1 Corinthians 16 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:first-corinthians.16.1",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 16:1",
      "text": "Now concerning the collection for the saints, as I have given order to the churches of Galatia, even so do ye.",
      "paragraphStart": true
    },
    {
      "id": "kjva:first-corinthians.16.2",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 16:2",
      "text": "Upon the first day of the week let every one of you lay by him in store, as God hath prospered him, that there be no gatherings when I come.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.3",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 16:3",
      "text": "And when I come, whomsoever ye shall approve by your letters, them will I send to bring your liberality unto Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.4",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 16:4",
      "text": "And if it be meet that I go also, they shall go with me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.5",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 16:5",
      "text": "Now I will come unto you, when I shall pass through Macedonia: for I do pass through Macedonia.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.6",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 16:6",
      "text": "And it may be that I will abide, yea, and winter with you, that ye may bring me on my journey whithersoever I go.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.7",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 16:7",
      "text": "For I will not see you now by the way; but I trust to tarry a while with you, if the Lord permit.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.8",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 16:8",
      "text": "But I will tarry at Ephesus until Pentecost.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.9",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 16:9",
      "text": "For a great door and effectual is opened unto me, and there are many adversaries.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.10",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 16:10",
      "text": "Now if Timotheus come, see that he may be with you without fear: for he worketh the work of the Lord, as I also do.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.11",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 16:11",
      "text": "Let no man therefore despise him: but conduct him forth in peace, that he may come unto me: for I look for him with the brethren.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.12",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 16:12",
      "text": "As touching our brother Apollos, I greatly desired him to come unto you with the brethren: but his will was not at all to come at this time; but he will come when he shall have convenient time.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.13",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 16:13",
      "text": "Watch ye, stand fast in the faith, quit you like men, be strong.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.14",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 16:14",
      "text": "Let all your things be done with charity.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.15",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 16:15",
      "text": "I beseech you, brethren, (ye know the house of Stephanas, that it is the firstfruits of Achaia, and that they have addicted themselves to the ministry of the saints,)",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.16",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 16:16",
      "text": "That ye submit yourselves unto such, and to every one that helpeth with us, and laboureth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.17",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 16:17",
      "text": "I am glad of the coming of Stephanas and Fortunatus and Achaicus: for that which was lacking on your part they have supplied.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.18",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 16:18",
      "text": "For they have refreshed my spirit and yours: therefore acknowledge ye them that are such.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.19",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 16:19",
      "text": "The churches of Asia salute you. Aquila and Priscilla salute you much in the Lord, with the church that is in their house.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.20",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 16:20",
      "text": "All the brethren greet you. Greet ye one another with an holy kiss.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.21",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 16:21",
      "text": "The salutation of me Paul with mine own hand.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.22",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 16:22",
      "text": "If any man love not the Lord Jesus Christ, let him be Anathema Maran-atha.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.23",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 16:23",
      "text": "The grace of our Lord Jesus Christ be with you.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-corinthians.16.24",
      "translationId": "kjva",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 16:24",
      "text": "My love be with you all in Christ Jesus. Amen.",
      "paragraphStart": false
    }
  ]
}
