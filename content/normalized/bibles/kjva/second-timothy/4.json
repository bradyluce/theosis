{
  "chapter": {
    "id": "kjva:second-timothy.4",
    "translationId": "kjva",
    "bookSlug": "second-timothy",
    "chapterNumber": 4,
    "referenceLabel": "2 Timothy 4",
    "summary": "Source text for 2 Timothy 4 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:second-timothy.4.1",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "2 Timothy 4:1",
      "text": "I charge thee therefore before God, and the Lord Jesus Christ, who shall judge the quick and the dead at his appearing and his kingdom;",
      "paragraphStart": true
    },
    {
      "id": "kjva:second-timothy.4.2",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "2 Timothy 4:2",
      "text": "Preach the word; be instant in season, out of season; reprove, rebuke, exhort with all longsuffering and doctrine.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.3",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "2 Timothy 4:3",
      "text": "For the time will come when they will not endure sound doctrine; but after their own lusts shall they heap to themselves teachers, having itching ears;",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.4",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "2 Timothy 4:4",
      "text": "And they shall turn away their ears from the truth, and shall be turned unto fables.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.5",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "2 Timothy 4:5",
      "text": "But watch thou in all things, endure afflictions, do the work of an evangelist, make full proof of thy ministry.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.6",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "2 Timothy 4:6",
      "text": "For I am now ready to be offered, and the time of my departure is at hand.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.7",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "2 Timothy 4:7",
      "text": "I have fought a good fight, I have finished my course, I have kept the faith:",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.8",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "2 Timothy 4:8",
      "text": "Henceforth there is laid up for me a crown of righteousness, which the Lord, the righteous judge, shall give me at that day: and not to me only, but unto all them also that love his appearing.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.9",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "2 Timothy 4:9",
      "text": "Do thy diligence to come shortly unto me:",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.10",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "2 Timothy 4:10",
      "text": "For Demas hath forsaken me, having loved this present world, and is departed unto Thessalonica; Crescens to Galatia, Titus unto Dalmatia.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.11",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "2 Timothy 4:11",
      "text": "Only Luke is with me. Take Mark, and bring him with thee: for he is profitable to me for the ministry.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.12",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "2 Timothy 4:12",
      "text": "And Tychicus have I sent to Ephesus.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.13",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "2 Timothy 4:13",
      "text": "The cloke that I left at Troas with Carpus, when thou comest, bring with thee, and the books, but especially the parchments.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.14",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "2 Timothy 4:14",
      "text": "Alexander the coppersmith did me much evil: the Lord reward him according to his works:",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.15",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "2 Timothy 4:15",
      "text": "Of whom be thou ware also; for he hath greatly withstood our words.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.16",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "2 Timothy 4:16",
      "text": "At my first answer no man stood with me, but all men forsook me: I pray God that it may not be laid to their charge.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.17",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "2 Timothy 4:17",
      "text": "Notwithstanding the Lord stood with me, and strengthened me; that by me the preaching might be fully known, and that all the Gentiles might hear: and I was delivered out of the mouth of the lion.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.18",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "2 Timothy 4:18",
      "text": "And the Lord shall deliver me from every evil work, and will preserve me unto his heavenly kingdom: to whom be glory for ever and ever. Amen.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.19",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "2 Timothy 4:19",
      "text": "Salute Prisca and Aquila, and the household of Onesiphorus.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.20",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "2 Timothy 4:20",
      "text": "Erastus abode at Corinth: but Trophimus have I left at Miletum sick.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.21",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "2 Timothy 4:21",
      "text": "Do thy diligence to come before winter. Eubulus greeteth thee, and Pudens, and Linus, and Claudia, and all the brethren.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.4.22",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "2 Timothy 4:22",
      "text": "The Lord Jesus Christ be with thy spirit. Grace be with you. Amen.",
      "paragraphStart": false
    }
  ]
}
