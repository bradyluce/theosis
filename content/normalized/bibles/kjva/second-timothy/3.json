{
  "chapter": {
    "id": "kjva:second-timothy.3",
    "translationId": "kjva",
    "bookSlug": "second-timothy",
    "chapterNumber": 3,
    "referenceLabel": "2 Timothy 3",
    "summary": "Source text for 2 Timothy 3 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:second-timothy.3.1",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "2 Timothy 3:1",
      "text": "This know also, that in the last days perilous times shall come.",
      "paragraphStart": true
    },
    {
      "id": "kjva:second-timothy.3.2",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "2 Timothy 3:2",
      "text": "For men shall be lovers of their own selves, covetous, boasters, proud, blasphemers, disobedient to parents, unthankful, unholy,",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.3.3",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "2 Timothy 3:3",
      "text": "Without natural affection, trucebreakers, false accusers, incontinent, fierce, despisers of those that are good,",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.3.4",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "2 Timothy 3:4",
      "text": "Traitors, heady, highminded, lovers of pleasures more than lovers of God;",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.3.5",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "2 Timothy 3:5",
      "text": "Having a form of godliness, but denying the power thereof: from such turn away.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.3.6",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "2 Timothy 3:6",
      "text": "For of this sort are they which creep into houses, and lead captive silly women laden with sins, led away with divers lusts,",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.3.7",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "2 Timothy 3:7",
      "text": "Ever learning, and never able to come to the knowledge of the truth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.3.8",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "2 Timothy 3:8",
      "text": "Now as Jannes and Jambres withstood Moses, so do these also resist the truth: men of corrupt minds, reprobate concerning the faith.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.3.9",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "2 Timothy 3:9",
      "text": "But they shall proceed no further: for their folly shall be manifest unto all men, as theirs also was.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.3.10",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "2 Timothy 3:10",
      "text": "But thou hast fully known my doctrine, manner of life, purpose, faith, longsuffering, charity, patience,",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.3.11",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "2 Timothy 3:11",
      "text": "Persecutions, afflictions, which came unto me at Antioch, at Iconium, at Lystra; what persecutions I endured: but out of them all the Lord delivered me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.3.12",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "2 Timothy 3:12",
      "text": "Yea, and all that will live godly in Christ Jesus shall suffer persecution.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.3.13",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "2 Timothy 3:13",
      "text": "But evil men and seducers shall wax worse and worse, deceiving, and being deceived.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.3.14",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "2 Timothy 3:14",
      "text": "But continue thou in the things which thou hast learned and hast been assured of, knowing of whom thou hast learned them;",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.3.15",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "2 Timothy 3:15",
      "text": "And that from a child thou hast known the holy scriptures, which are able to make thee wise unto salvation through faith which is in Christ Jesus.",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.3.16",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "2 Timothy 3:16",
      "text": "All scripture is given by inspiration of God, and is profitable for doctrine, for reproof, for correction, for instruction in righteousness:",
      "paragraphStart": false
    },
    {
      "id": "kjva:second-timothy.3.17",
      "translationId": "kjva",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "2 Timothy 3:17",
      "text": "That the man of God may be perfect, throughly furnished unto all good works.",
      "paragraphStart": false
    }
  ]
}
