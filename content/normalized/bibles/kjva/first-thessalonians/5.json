{
  "chapter": {
    "id": "kjva:first-thessalonians.5",
    "translationId": "kjva",
    "bookSlug": "first-thessalonians",
    "chapterNumber": 5,
    "referenceLabel": "1 Thessalonians 5",
    "summary": "Source text for 1 Thessalonians 5 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:first-thessalonians.5.1",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "1 Thessalonians 5:1",
      "text": "But of the times and the seasons, brethren, ye have no need that I write unto you.",
      "paragraphStart": true
    },
    {
      "id": "kjva:first-thessalonians.5.2",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "1 Thessalonians 5:2",
      "text": "For yourselves know perfectly that the day of the Lord so cometh as a thief in the night.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.3",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "1 Thessalonians 5:3",
      "text": "For when they shall say, Peace and safety; then sudden destruction cometh upon them, as travail upon a woman with child; and they shall not escape.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.4",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "1 Thessalonians 5:4",
      "text": "But ye, brethren, are not in darkness, that that day should overtake you as a thief.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.5",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "1 Thessalonians 5:5",
      "text": "Ye are all the children of light, and the children of the day: we are not of the night, nor of darkness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.6",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "1 Thessalonians 5:6",
      "text": "Therefore let us not sleep, as do others; but let us watch and be sober.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.7",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "1 Thessalonians 5:7",
      "text": "For they that sleep sleep in the night; and they that be drunken are drunken in the night.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.8",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "1 Thessalonians 5:8",
      "text": "But let us, who are of the day, be sober, putting on the breastplate of faith and love; and for an helmet, the hope of salvation.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.9",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "1 Thessalonians 5:9",
      "text": "For God hath not appointed us to wrath, but to obtain salvation by our Lord Jesus Christ,",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.10",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "1 Thessalonians 5:10",
      "text": "Who died for us, that, whether we wake or sleep, we should live together with him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.11",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "1 Thessalonians 5:11",
      "text": "Wherefore comfort yourselves together, and edify one another, even as also ye do.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.12",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "1 Thessalonians 5:12",
      "text": "And we beseech you, brethren, to know them which labour among you, and are over you in the Lord, and admonish you;",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.13",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "1 Thessalonians 5:13",
      "text": "And to esteem them very highly in love for their work’s sake. And be at peace among yourselves.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.14",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "1 Thessalonians 5:14",
      "text": "Now we exhort you, brethren, warn them that are unruly, comfort the feebleminded, support the weak, be patient toward all men.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.15",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "1 Thessalonians 5:15",
      "text": "See that none render evil for evil unto any man; but ever follow that which is good, both among yourselves, and to all men.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.16",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "1 Thessalonians 5:16",
      "text": "Rejoice evermore.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.17",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "1 Thessalonians 5:17",
      "text": "Pray without ceasing.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.18",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "1 Thessalonians 5:18",
      "text": "In every thing give thanks: for this is the will of God in Christ Jesus concerning you.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.19",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "1 Thessalonians 5:19",
      "text": "Quench not the Spirit.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.20",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "1 Thessalonians 5:20",
      "text": "Despise not prophesyings.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.21",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "1 Thessalonians 5:21",
      "text": "Prove all things; hold fast that which is good.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.22",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "1 Thessalonians 5:22",
      "text": "Abstain from all appearance of evil.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.23",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "1 Thessalonians 5:23",
      "text": "And the very God of peace sanctify you wholly; and I pray God your whole spirit and soul and body be preserved blameless unto the coming of our Lord Jesus Christ.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.24",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "1 Thessalonians 5:24",
      "text": "Faithful is he that calleth you, who also will do it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.25",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "1 Thessalonians 5:25",
      "text": "Brethren, pray for us.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.26",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "1 Thessalonians 5:26",
      "text": "Greet all the brethren with an holy kiss.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.27",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "1 Thessalonians 5:27",
      "text": "I charge you by the Lord that this epistle be read unto all the holy brethren.",
      "paragraphStart": false
    },
    {
      "id": "kjva:first-thessalonians.5.28",
      "translationId": "kjva",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "1 Thessalonians 5:28",
      "text": "The grace of our Lord Jesus Christ be with you. Amen.",
      "paragraphStart": false
    }
  ]
}
