{
  "chapter": {
    "id": "kjva:colossians.3",
    "translationId": "kjva",
    "bookSlug": "colossians",
    "chapterNumber": 3,
    "referenceLabel": "Colossians 3",
    "summary": "Source text for Colossians 3 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:colossians.3.1",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Colossians 3:1",
      "text": "If ye then be risen with Christ, seek those things which are above, where Christ sitteth on the right hand of God.",
      "paragraphStart": true
    },
    {
      "id": "kjva:colossians.3.2",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Colossians 3:2",
      "text": "Set your affection on things above, not on things on the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.3",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Colossians 3:3",
      "text": "For ye are dead, and your life is hid with Christ in God.",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.4",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Colossians 3:4",
      "text": "When Christ, who is our life, shall appear, then shall ye also appear with him in glory.",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.5",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Colossians 3:5",
      "text": "Mortify therefore your members which are upon the earth; fornication, uncleanness, inordinate affection, evil concupiscence, and covetousness, which is idolatry:",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.6",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Colossians 3:6",
      "text": "For which things’ sake the wrath of God cometh on the children of disobedience:",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.7",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Colossians 3:7",
      "text": "In the which ye also walked some time, when ye lived in them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.8",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Colossians 3:8",
      "text": "But now ye also put off all these; anger, wrath, malice, blasphemy, filthy communication out of your mouth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.9",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Colossians 3:9",
      "text": "Lie not one to another, seeing that ye have put off the old man with his deeds;",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.10",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Colossians 3:10",
      "text": "And have put on the new man, which is renewed in knowledge after the image of him that created him:",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.11",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Colossians 3:11",
      "text": "Where there is neither Greek nor Jew, circumcision nor uncircumcision, Barbarian, Scythian, bond nor free: but Christ is all, and in all.",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.12",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Colossians 3:12",
      "text": "Put on therefore, as the elect of God, holy and beloved, bowels of mercies, kindness, humbleness of mind, meekness, longsuffering;",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.13",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Colossians 3:13",
      "text": "Forbearing one another, and forgiving one another, if any man have a quarrel against any: even as Christ forgave you, so also do ye.",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.14",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Colossians 3:14",
      "text": "And above all these things put on charity, which is the bond of perfectness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.15",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Colossians 3:15",
      "text": "And let the peace of God rule in your hearts, to the which also ye are called in one body; and be ye thankful.",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.16",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Colossians 3:16",
      "text": "Let the word of Christ dwell in you richly in all wisdom; teaching and admonishing one another in psalms and hymns and spiritual songs, singing with grace in your hearts to the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.17",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Colossians 3:17",
      "text": "And whatsoever ye do in word or deed, do all in the name of the Lord Jesus, giving thanks to God and the Father by him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.18",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Colossians 3:18",
      "text": "Wives, submit yourselves unto your own husbands, as it is fit in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.19",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Colossians 3:19",
      "text": "Husbands, love your wives, and be not bitter against them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.20",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Colossians 3:20",
      "text": "Children, obey your parents in all things: for this is well pleasing unto the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.21",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Colossians 3:21",
      "text": "Fathers, provoke not your children to anger, lest they be discouraged.",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.22",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Colossians 3:22",
      "text": "Servants, obey in all things your masters according to the flesh; not with eyeservice, as menpleasers; but in singleness of heart, fearing God:",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.23",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Colossians 3:23",
      "text": "And whatsoever ye do, do it heartily, as to the Lord, and not unto men;",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.24",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Colossians 3:24",
      "text": "Knowing that of the Lord ye shall receive the reward of the inheritance: for ye serve the Lord Christ.",
      "paragraphStart": false
    },
    {
      "id": "kjva:colossians.3.25",
      "translationId": "kjva",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Colossians 3:25",
      "text": "But he that doeth wrong shall receive for the wrong which he hath done: and there is no respect of persons.",
      "paragraphStart": false
    }
  ]
}
