{
  "chapter": {
    "id": "kjva:song-of-solomon.2",
    "translationId": "kjva",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 2,
    "referenceLabel": "Song of Solomon 2",
    "summary": "Source text for Song of Solomon 2 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:song-of-solomon.2.1",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 2:1",
      "text": "I am the rose of Sharon, and the lily of the valleys.",
      "paragraphStart": true
    },
    {
      "id": "kjva:song-of-solomon.2.2",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 2:2",
      "text": "As the lily among thorns, so is my love among the daughters.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.2.3",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 2:3",
      "text": "As the apple tree among the trees of the wood, so is my beloved among the sons. I sat down under his shadow with great delight, and his fruit was sweet to my taste.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.2.4",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 2:4",
      "text": "He brought me to the banqueting house, and his banner over me was love.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.2.5",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 2:5",
      "text": "Stay me with flagons, comfort me with apples: for I am sick of love.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.2.6",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 2:6",
      "text": "His left hand is under my head, and his right hand doth embrace me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.2.7",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 2:7",
      "text": "I charge you, O ye daughters of Jerusalem, by the roes, and by the hinds of the field, that ye stir not up, nor awake my love, till he please.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.2.8",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 2:8",
      "text": "The voice of my beloved! behold, he cometh leaping upon the mountains, skipping upon the hills.",
      "paragraphStart": true
    },
    {
      "id": "kjva:song-of-solomon.2.9",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 2:9",
      "text": "My beloved is like a roe or a young hart: behold, he standeth behind our wall, he looketh forth at the windows, shewing himself through the lattice.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.2.10",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 2:10",
      "text": "My beloved spake, and said unto me, Rise up, my love, my fair one, and come away.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.2.11",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 2:11",
      "text": "For, lo, the winter is past, the rain is over and gone;",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.2.12",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 2:12",
      "text": "The flowers appear on the earth; the time of the singing of birds is come, and the voice of the turtle is heard in our land;",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.2.13",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 2:13",
      "text": "The fig tree putteth forth her green figs, and the vines with the tender grape give a good smell. Arise, my love, my fair one, and come away.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.2.14",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Song of Solomon 2:14",
      "text": "O my dove, that art in the clefts of the rock, in the secret places of the stairs, let me see thy countenance, let me hear thy voice; for sweet is thy voice, and thy countenance is comely.",
      "paragraphStart": true
    },
    {
      "id": "kjva:song-of-solomon.2.15",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Song of Solomon 2:15",
      "text": "Take us the foxes, the little foxes, that spoil the vines: for our vines have tender grapes.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.2.16",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Song of Solomon 2:16",
      "text": "My beloved is mine, and I am his: he feedeth among the lilies.",
      "paragraphStart": true
    },
    {
      "id": "kjva:song-of-solomon.2.17",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Song of Solomon 2:17",
      "text": "Until the day break, and the shadows flee away, turn, my beloved, and be thou like a roe or a young hart upon the mountains of Bether.",
      "paragraphStart": false
    }
  ]
}
