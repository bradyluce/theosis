{
  "chapter": {
    "id": "kjva:song-of-solomon.1",
    "translationId": "kjva",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 1,
    "referenceLabel": "Song of Solomon 1",
    "summary": "Source text for Song of Solomon 1 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:song-of-solomon.1.1",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 1:1",
      "text": "The song of songs, which is Solomon’s.",
      "paragraphStart": true
    },
    {
      "id": "kjva:song-of-solomon.1.2",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 1:2",
      "text": "Let him kiss me with the kisses of his mouth: for thy love is better than wine.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.1.3",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 1:3",
      "text": "Because of the savour of thy good ointments thy name is as ointment poured forth, therefore do the virgins love thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.1.4",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 1:4",
      "text": "Draw me, we will run after thee: the king hath brought me into his chambers: we will be glad and rejoice in thee, we will remember thy love more than wine: the upright love thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.1.5",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 1:5",
      "text": "I am black, but comely, O ye daughters of Jerusalem, as the tents of Kedar, as the curtains of Solomon.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.1.6",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 1:6",
      "text": "Look not upon me, because I am black, because the sun hath looked upon me: my mother’s children were angry with me; they made me the keeper of the vineyards; but mine own vineyard have I not kept.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.1.7",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 1:7",
      "text": "Tell me, O thou whom my soul loveth, where thou feedest, where thou makest thy flock to rest at noon: for why should I be as one that turneth aside by the flocks of thy companions?",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.1.8",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 1:8",
      "text": "If thou know not, O thou fairest among women, go thy way forth by the footsteps of the flock, and feed thy kids beside the shepherds’ tents.",
      "paragraphStart": true
    },
    {
      "id": "kjva:song-of-solomon.1.9",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 1:9",
      "text": "I have compared thee, O my love, to a company of horses in Pharaoh’s chariots.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.1.10",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 1:10",
      "text": "Thy cheeks are comely with rows of jewels, thy neck with chains of gold.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.1.11",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 1:11",
      "text": "We will make thee borders of gold with studs of silver.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.1.12",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 1:12",
      "text": "While the king sitteth at his table, my spikenard sendeth forth the smell thereof.",
      "paragraphStart": true
    },
    {
      "id": "kjva:song-of-solomon.1.13",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 1:13",
      "text": "A bundle of myrrh is my wellbeloved unto me; he shall lie all night betwixt my breasts.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.1.14",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Song of Solomon 1:14",
      "text": "My beloved is unto me as a cluster of camphire in the vineyards of En–gedi.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.1.15",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Song of Solomon 1:15",
      "text": "Behold, thou art fair, my love; behold, thou art fair; thou hast doves’ eyes.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.1.16",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Song of Solomon 1:16",
      "text": "Behold, thou art fair, my beloved, yea, pleasant: also our bed is green.",
      "paragraphStart": false
    },
    {
      "id": "kjva:song-of-solomon.1.17",
      "translationId": "kjva",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Song of Solomon 1:17",
      "text": "The beams of our house are cedar, and our rafters of fir.",
      "paragraphStart": false
    }
  ]
}
