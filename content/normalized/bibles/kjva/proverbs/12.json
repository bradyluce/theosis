{
  "chapter": {
    "id": "kjva:proverbs.12",
    "translationId": "kjva",
    "bookSlug": "proverbs",
    "chapterNumber": 12,
    "referenceLabel": "Proverbs 12",
    "summary": "Source text for Proverbs 12 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:proverbs.12.1",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 12:1",
      "text": "Whoso loveth instruction loveth knowledge: but he that hateth reproof is brutish.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.12.2",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 12:2",
      "text": "A good man obtaineth favour of the Lord: but a man of wicked devices will he condemn.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.3",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 12:3",
      "text": "A man shall not be established by wickedness: but the root of the righteous shall not be moved.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.4",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 12:4",
      "text": "A virtuous woman is a crown to her husband: but she that maketh ashamed is as rottenness in his bones.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.5",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 12:5",
      "text": "The thoughts of the righteous are right: but the counsels of the wicked are deceit.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.6",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 12:6",
      "text": "The words of the wicked are to lie in wait for blood: but the mouth of the upright shall deliver them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.7",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 12:7",
      "text": "The wicked are overthrown, and are not: but the house of the righteous shall stand.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.8",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 12:8",
      "text": "A man shall be commended according to his wisdom: but he that is of a perverse heart shall be despised.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.9",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 12:9",
      "text": "He that is despised, and hath a servant, is better than he that honoureth himself, and lacketh bread.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.10",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 12:10",
      "text": "A righteous man regardeth the life of his beast: but the tender mercies of the wicked are cruel.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.11",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 12:11",
      "text": "He that tilleth his land shall be satisfied with bread: but he that followeth vain persons is void of understanding.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.12",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 12:12",
      "text": "The wicked desireth the net of evil men: but the root of the righteous yieldeth fruit.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.13",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 12:13",
      "text": "The wicked is snared by the transgression of his lips: but the just shall come out of trouble.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.14",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 12:14",
      "text": "A man shall be satisfied with good by the fruit of his mouth: and the recompence of a man’s hands shall be rendered unto him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.15",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 12:15",
      "text": "The way of a fool is right in his own eyes: but he that hearkeneth unto counsel is wise.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.16",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 12:16",
      "text": "A fool’s wrath is presently known: but a prudent man covereth shame.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.17",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 12:17",
      "text": "He that speaketh truth sheweth forth righteousness: but a false witness deceit.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.18",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 12:18",
      "text": "There is that speaketh like the piercings of a sword: but the tongue of the wise is health.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.19",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 12:19",
      "text": "The lip of truth shall be established for ever: but a lying tongue is but for a moment.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.20",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 12:20",
      "text": "Deceit is in the heart of them that imagine evil: but to the counsellors of peace is joy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.21",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 12:21",
      "text": "There shall no evil happen to the just: but the wicked shall be filled with mischief.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.22",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 12:22",
      "text": "Lying lips are abomination to the Lord: but they that deal truly are his delight.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.23",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 12:23",
      "text": "A prudent man concealeth knowledge: but the heart of fools proclaimeth foolishness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.24",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 12:24",
      "text": "The hand of the diligent shall bear rule: but the slothful shall be under tribute.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.25",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 12:25",
      "text": "Heaviness in the heart of man maketh it stoop: but a good word maketh it glad.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.26",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 12:26",
      "text": "The righteous is more excellent than his neighbour: but the way of the wicked seduceth them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.27",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 12:27",
      "text": "The slothful man roasteth not that which he took in hunting: but the substance of a diligent man is precious.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.12.28",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 12:28",
      "text": "In the way of righteousness is life; and in the pathway thereof there is no death.",
      "paragraphStart": false
    }
  ]
}
