{
  "chapter": {
    "id": "kjva:proverbs.4",
    "translationId": "kjva",
    "bookSlug": "proverbs",
    "chapterNumber": 4,
    "referenceLabel": "Proverbs 4",
    "summary": "Source text for Proverbs 4 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:proverbs.4.1",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 4:1",
      "text": "Hear, ye children, the instruction of a father, and attend to know understanding.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.4.2",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 4:2",
      "text": "For I give you good doctrine, forsake ye not my law.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.3",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 4:3",
      "text": "For I was my father’s son, tender and only beloved in the sight of my mother.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.4",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 4:4",
      "text": "He taught me also, and said unto me, Let thine heart retain my words: keep my commandments, and live.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.5",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 4:5",
      "text": "Get wisdom, get understanding: forget it not; neither decline from the words of my mouth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.6",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 4:6",
      "text": "Forsake her not, and she shall preserve thee: love her, and she shall keep thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.7",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 4:7",
      "text": "Wisdom is the principal thing; therefore get wisdom: and with all thy getting get understanding.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.8",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 4:8",
      "text": "Exalt her, and she shall promote thee: she shall bring thee to honour, when thou dost embrace her.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.9",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 4:9",
      "text": "She shall give to thine head an ornament of grace: a crown of glory shall she deliver to thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.10",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 4:10",
      "text": "Hear, O my son, and receive my sayings; and the years of thy life shall be many.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.11",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 4:11",
      "text": "I have taught thee in the way of wisdom; I have led thee in right paths.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.12",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 4:12",
      "text": "When thou goest, thy steps shall not be straitened; and when thou runnest, thou shalt not stumble.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.13",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 4:13",
      "text": "Take fast hold of instruction; let her not go: keep her; for she is thy life.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.14",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 4:14",
      "text": "Enter not into the path of the wicked, and go not in the way of evil men.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.4.15",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 4:15",
      "text": "Avoid it, pass not by it, turn from it, and pass away.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.16",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 4:16",
      "text": "For they sleep not, except they have done mischief; and their sleep is taken away, unless they cause some to fall.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.17",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 4:17",
      "text": "For they eat the bread of wickedness, and drink the wine of violence.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.18",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 4:18",
      "text": "But the path of the just is as the shining light, that shineth more and more unto the perfect day.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.19",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 4:19",
      "text": "The way of the wicked is as darkness: they know not at what they stumble.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.20",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 4:20",
      "text": "My son, attend to my words; incline thine ear unto my sayings.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.4.21",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 4:21",
      "text": "Let them not depart from thine eyes; keep them in the midst of thine heart.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.22",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 4:22",
      "text": "For they are life unto those that find them, and health to all their flesh.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.23",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 4:23",
      "text": "Keep thy heart with all diligence; for out of it are the issues of life.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.4.24",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 4:24",
      "text": "Put away from thee a froward mouth, and perverse lips put far from thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.25",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 4:25",
      "text": "Let thine eyes look right on, and let thine eyelids look straight before thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.26",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 4:26",
      "text": "Ponder the path of thy feet, and let all thy ways be established.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.4.27",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 4:27",
      "text": "Turn not to the right hand nor to the left: remove thy foot from evil.",
      "paragraphStart": false
    }
  ]
}
