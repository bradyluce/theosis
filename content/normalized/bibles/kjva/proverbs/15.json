{
  "chapter": {
    "id": "kjva:proverbs.15",
    "translationId": "kjva",
    "bookSlug": "proverbs",
    "chapterNumber": 15,
    "referenceLabel": "Proverbs 15",
    "summary": "Source text for Proverbs 15 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:proverbs.15.1",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 15:1",
      "text": "A soft answer turneth away wrath: but grievous words stir up anger.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.15.2",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 15:2",
      "text": "The tongue of the wise useth knowledge aright: but the mouth of fools poureth out foolishness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.3",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 15:3",
      "text": "The eyes of the Lord are in every place, beholding the evil and the good.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.4",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 15:4",
      "text": "A wholesome tongue is a tree of life: but perverseness therein is a breach in the spirit.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.5",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 15:5",
      "text": "A fool despiseth his father’s instruction: but he that regardeth reproof is prudent.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.6",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 15:6",
      "text": "In the house of the righteous is much treasure: but in the revenues of the wicked is trouble.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.7",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 15:7",
      "text": "The lips of the wise disperse knowledge: but the heart of the foolish doeth not so.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.8",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 15:8",
      "text": "The sacrifice of the wicked is an abomination to the Lord: but the prayer of the upright is his delight.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.9",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 15:9",
      "text": "The way of the wicked is an abomination unto the Lord: but he loveth him that followeth after righteousness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.10",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 15:10",
      "text": "Correction is grievous unto him that forsaketh the way: and he that hateth reproof shall die.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.11",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 15:11",
      "text": "Hell and destruction are before the Lord: how much more then the hearts of the children of men?",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.12",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 15:12",
      "text": "A scorner loveth not one that reproveth him: neither will he go unto the wise.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.13",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 15:13",
      "text": "A merry heart maketh a cheerful countenance: but by sorrow of the heart the spirit is broken.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.14",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 15:14",
      "text": "The heart of him that hath understanding seeketh knowledge: but the mouth of fools feedeth on foolishness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.15",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 15:15",
      "text": "All the days of the afflicted are evil: but he that is of a merry heart hath a continual feast.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.16",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 15:16",
      "text": "Better is little with the fear of the Lord than great treasure and trouble therewith.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.17",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 15:17",
      "text": "Better is a dinner of herbs where love is, than a stalled ox and hatred therewith.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.18",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 15:18",
      "text": "A wrathful man stirreth up strife: but he that is slow to anger appeaseth strife.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.19",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 15:19",
      "text": "The way of the slothful man is as an hedge of thorns: but the way of the righteous is made plain.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.20",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 15:20",
      "text": "A wise son maketh a glad father: but a foolish man despiseth his mother.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.21",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 15:21",
      "text": "Folly is joy to him that is destitute of wisdom: but a man of understanding walketh uprightly.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.22",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 15:22",
      "text": "Without counsel purposes are disappointed: but in the multitude of counsellors they are established.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.23",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 15:23",
      "text": "A man hath joy by the answer of his mouth: and a word spoken in due season, how good is it!",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.24",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 15:24",
      "text": "The way of life is above to the wise, that he may depart from hell beneath.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.25",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 15:25",
      "text": "The Lord will destroy the house of the proud: but he will establish the border of the widow.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.26",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 15:26",
      "text": "The thoughts of the wicked are an abomination to the Lord: but the words of the pure are pleasant words.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.27",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 15:27",
      "text": "He that is greedy of gain troubleth his own house; but he that hateth gifts shall live.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.28",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 15:28",
      "text": "The heart of the righteous studieth to answer: but the mouth of the wicked poureth out evil things.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.29",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 15:29",
      "text": "The Lord is far from the wicked: but he heareth the prayer of the righteous.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.30",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 15:30",
      "text": "The light of the eyes rejoiceth the heart: and a good report maketh the bones fat.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.31",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 15:31",
      "text": "The ear that heareth the reproof of life abideth among the wise.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.32",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 15:32",
      "text": "He that refuseth instruction despiseth his own soul: but he that heareth reproof getteth understanding.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.15.33",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 15:33",
      "text": "The fear of the Lord is the instruction of wisdom; and before honour is humility.",
      "paragraphStart": false
    }
  ]
}
