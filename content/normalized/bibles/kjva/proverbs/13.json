{
  "chapter": {
    "id": "kjva:proverbs.13",
    "translationId": "kjva",
    "bookSlug": "proverbs",
    "chapterNumber": 13,
    "referenceLabel": "Proverbs 13",
    "summary": "Source text for Proverbs 13 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:proverbs.13.1",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 13:1",
      "text": "A wise son heareth his father’s instruction: but a scorner heareth not rebuke.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.13.2",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 13:2",
      "text": "A man shall eat good by the fruit of his mouth: but the soul of the transgressors shall eat violence.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.3",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 13:3",
      "text": "He that keepeth his mouth keepeth his life: but he that openeth wide his lips shall have destruction.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.4",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 13:4",
      "text": "The soul of the sluggard desireth, and hath nothing: but the soul of the diligent shall be made fat.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.5",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 13:5",
      "text": "A righteous man hateth lying: but a wicked man is loathsome, and cometh to shame.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.6",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 13:6",
      "text": "Righteousness keepeth him that is upright in the way: but wickedness overthroweth the sinner.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.7",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 13:7",
      "text": "There is that maketh himself rich, yet hath nothing: there is that maketh himself poor, yet hath great riches.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.8",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 13:8",
      "text": "The ransom of a man’s life are his riches: but the poor heareth not rebuke.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.9",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 13:9",
      "text": "The light of the righteous rejoiceth: but the lamp of the wicked shall be put out.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.10",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 13:10",
      "text": "Only by pride cometh contention: but with the well advised is wisdom.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.11",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 13:11",
      "text": "Wealth gotten by vanity shall be diminished: but he that gathereth by labour shall increase.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.12",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 13:12",
      "text": "Hope deferred maketh the heart sick: but when the desire cometh, it is a tree of life.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.13",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 13:13",
      "text": "Whoso despiseth the word shall be destroyed: but he that feareth the commandment shall be rewarded.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.14",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 13:14",
      "text": "The law of the wise is a fountain of life, to depart from the snares of death.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.15",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 13:15",
      "text": "Good understanding giveth favour: but the way of transgressors is hard.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.16",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 13:16",
      "text": "Every prudent man dealeth with knowledge: but a fool layeth open his folly.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.17",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 13:17",
      "text": "A wicked messenger falleth into mischief: but a faithful ambassador is health.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.18",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 13:18",
      "text": "Poverty and shame shall be to him that refuseth instruction: but he that regardeth reproof shall be honoured.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.19",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 13:19",
      "text": "The desire accomplished is sweet to the soul: but it is abomination to fools to depart from evil.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.20",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 13:20",
      "text": "He that walketh with wise men shall be wise: but a companion of fools shall be destroyed.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.21",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 13:21",
      "text": "Evil pursueth sinners: but to the righteous good shall be repayed.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.22",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 13:22",
      "text": "A good man leaveth an inheritance to his children’s children: and the wealth of the sinner is laid up for the just.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.23",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 13:23",
      "text": "Much food is in the tillage of the poor: but there is that is destroyed for want of judgment.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.24",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 13:24",
      "text": "He that spareth his rod hateth his son: but he that loveth him chasteneth him betimes.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.13.25",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 13:25",
      "text": "The righteous eateth to the satisfying of his soul: but the belly of the wicked shall want.",
      "paragraphStart": false
    }
  ]
}
