{
  "chapter": {
    "id": "kjva:proverbs.27",
    "translationId": "kjva",
    "bookSlug": "proverbs",
    "chapterNumber": 27,
    "referenceLabel": "Proverbs 27",
    "summary": "Source text for Proverbs 27 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:proverbs.27.1",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 27:1",
      "text": "Boast not thyself of to morrow; for thou knowest not what a day may bring forth.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.27.2",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 27:2",
      "text": "Let another man praise thee, and not thine own mouth; a stranger, and not thine own lips.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.3",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 27:3",
      "text": "A stone is heavy, and the sand weighty; but a fool’s wrath is heavier than them both.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.4",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 27:4",
      "text": "Wrath is cruel, and anger is outrageous; but who is able to stand before envy?",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.5",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 27:5",
      "text": "Open rebuke is better than secret love.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.6",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 27:6",
      "text": "Faithful are the wounds of a friend; but the kisses of an enemy are deceitful.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.7",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 27:7",
      "text": "The full soul loatheth an honeycomb; but to the hungry soul every bitter thing is sweet.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.8",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 27:8",
      "text": "As a bird that wandereth from her nest, so is a man that wandereth from his place.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.9",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 27:9",
      "text": "Ointment and perfume rejoice the heart: so doth the sweetness of a man’s friend by hearty counsel.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.10",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 27:10",
      "text": "Thine own friend, and thy father’s friend, forsake not; neither go into thy brother’s house in the day of thy calamity: for better is a neighbour that is near than a brother far off.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.11",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 27:11",
      "text": "My son, be wise, and make my heart glad, that I may answer him that reproacheth me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.12",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 27:12",
      "text": "A prudent man foreseeth the evil, and hideth himself; but the simple pass on, and are punished.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.13",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 27:13",
      "text": "Take his garment that is surety for a stranger, and take a pledge of him for a strange woman.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.14",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 27:14",
      "text": "He that blesseth his friend with a loud voice, rising early in the morning, it shall be counted a curse to him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.15",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 27:15",
      "text": "A continual dropping in a very rainy day and a contentious woman are alike.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.16",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 27:16",
      "text": "Whosoever hideth her hideth the wind, and the ointment of his right hand, which bewrayeth itself.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.17",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 27:17",
      "text": "Iron sharpeneth iron; so a man sharpeneth the countenance of his friend.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.18",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 27:18",
      "text": "Whoso keepeth the fig tree shall eat the fruit thereof: so he that waiteth on his master shall be honoured.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.19",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 27:19",
      "text": "As in water face answereth to face, so the heart of man to man.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.20",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 27:20",
      "text": "Hell and destruction are never full; so the eyes of man are never satisfied.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.21",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 27:21",
      "text": "As the fining pot for silver, and the furnace for gold; so is a man to his praise.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.22",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 27:22",
      "text": "Though thou shouldest bray a fool in a mortar among wheat with a pestle, yet will not his foolishness depart from him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.23",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 27:23",
      "text": "Be thou diligent to know the state of thy flocks, and look well to thy herds.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.24",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 27:24",
      "text": "For riches are not for ever: and doth the crown endure to every generation?",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.25",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 27:25",
      "text": "The hay appeareth, and the tender grass sheweth itself, and herbs of the mountains are gathered.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.26",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 27:26",
      "text": "The lambs are for thy clothing, and the goats are the price of the field.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.27.27",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 27:27",
      "text": "And thou shalt have goats’ milk enough for thy food, for the food of thy household, and for the maintenance for thy maidens.",
      "paragraphStart": false
    }
  ]
}
