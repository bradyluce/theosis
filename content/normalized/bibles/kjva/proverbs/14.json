{
  "chapter": {
    "id": "kjva:proverbs.14",
    "translationId": "kjva",
    "bookSlug": "proverbs",
    "chapterNumber": 14,
    "referenceLabel": "Proverbs 14",
    "summary": "Source text for Proverbs 14 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:proverbs.14.1",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 14:1",
      "text": "Every wise woman buildeth her house: but the foolish plucketh it down with her hands.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.14.2",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 14:2",
      "text": "He that walketh in his uprightness feareth the Lord: but he that is perverse in his ways despiseth him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.3",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 14:3",
      "text": "In the mouth of the foolish is a rod of pride: but the lips of the wise shall preserve them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.4",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 14:4",
      "text": "Where no oxen are, the crib is clean: but much increase is by the strength of the ox.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.5",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 14:5",
      "text": "A faithful witness will not lie: but a false witness will utter lies.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.6",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 14:6",
      "text": "A scorner seeketh wisdom, and findeth it not: but knowledge is easy unto him that understandeth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.7",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 14:7",
      "text": "Go from the presence of a foolish man, when thou perceivest not in him the lips of knowledge.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.8",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 14:8",
      "text": "The wisdom of the prudent is to understand his way: but the folly of fools is deceit.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.9",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 14:9",
      "text": "Fools make a mock at sin: but among the righteous there is favour.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.10",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 14:10",
      "text": "The heart knoweth his own bitterness; and a stranger doth not intermeddle with his joy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.11",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 14:11",
      "text": "The house of the wicked shall be overthrown: but the tabernacle of the upright shall flourish.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.12",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 14:12",
      "text": "There is a way which seemeth right unto a man, but the end thereof are the ways of death.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.13",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 14:13",
      "text": "Even in laughter the heart is sorrowful; and the end of that mirth is heaviness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.14",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 14:14",
      "text": "The backslider in heart shall be filled with his own ways: and a good man shall be satisfied from himself.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.15",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 14:15",
      "text": "The simple believeth every word: but the prudent man looketh well to his going.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.16",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 14:16",
      "text": "A wise man feareth, and departeth from evil: but the fool rageth, and is confident.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.17",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 14:17",
      "text": "He that is soon angry dealeth foolishly: and a man of wicked devices is hated.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.18",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 14:18",
      "text": "The simple inherit folly: but the prudent are crowned with knowledge.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.19",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 14:19",
      "text": "The evil bow before the good; and the wicked at the gates of the righteous.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.20",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 14:20",
      "text": "The poor is hated even of his own neighbour: but the rich hath many friends.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.21",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 14:21",
      "text": "He that despiseth his neighbour sinneth: but he that hath mercy on the poor, happy is he.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.22",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 14:22",
      "text": "Do they not err that devise evil? but mercy and truth shall be to them that devise good.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.23",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 14:23",
      "text": "In all labour there is profit: but the talk of the lips tendeth only to penury.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.24",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 14:24",
      "text": "The crown of the wise is their riches: but the foolishness of fools is folly.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.25",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 14:25",
      "text": "A true witness delivereth souls: but a deceitful witness speaketh lies.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.26",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 14:26",
      "text": "In the fear of the Lord is strong confidence: and his children shall have a place of refuge.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.27",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 14:27",
      "text": "The fear of the Lord is a fountain of life, to depart from the snares of death.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.28",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 14:28",
      "text": "In the multitude of people is the king’s honour: but in the want of people is the destruction of the prince.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.29",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 14:29",
      "text": "He that is slow to wrath is of great understanding: but he that is hasty of spirit exalteth folly.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.30",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 14:30",
      "text": "A sound heart is the life of the flesh: but envy the rottenness of the bones.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.31",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 14:31",
      "text": "He that oppresseth the poor reproacheth his Maker: but he that honoureth him hath mercy on the poor.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.32",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 14:32",
      "text": "The wicked is driven away in his wickedness: but the righteous hath hope in his death.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.33",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 14:33",
      "text": "Wisdom resteth in the heart of him that hath understanding: but that which is in the midst of fools is made known.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.34",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 14:34",
      "text": "Righteousness exalteth a nation: but sin is a reproach to any people.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.14.35",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 14:35",
      "text": "The king’s favour is toward a wise servant: but his wrath is against him that causeth shame.",
      "paragraphStart": false
    }
  ]
}
