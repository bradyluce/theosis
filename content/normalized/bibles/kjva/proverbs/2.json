{
  "chapter": {
    "id": "kjva:proverbs.2",
    "translationId": "kjva",
    "bookSlug": "proverbs",
    "chapterNumber": 2,
    "referenceLabel": "Proverbs 2",
    "summary": "Source text for Proverbs 2 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:proverbs.2.1",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 2:1",
      "text": "My son, if thou wilt receive my words, and hide my commandments with thee;",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.2.2",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 2:2",
      "text": "So that thou incline thine ear unto wisdom, and apply thine heart to understanding;",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.2.3",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 2:3",
      "text": "Yea, if thou criest after knowledge, and liftest up thy voice for understanding;",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.2.4",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 2:4",
      "text": "If thou seekest her as silver, and searchest for her as for hid treasures;",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.2.5",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 2:5",
      "text": "Then shalt thou understand the fear of the Lord, and find the knowledge of God.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.2.6",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 2:6",
      "text": "For the Lord giveth wisdom: out of his mouth cometh knowledge and understanding.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.2.7",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 2:7",
      "text": "He layeth up sound wisdom for the righteous: he is a buckler to them that walk uprightly.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.2.8",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 2:8",
      "text": "He keepeth the paths of judgment, and preserveth the way of his saints.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.2.9",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 2:9",
      "text": "Then shalt thou understand righteousness, and judgment, and equity; yea, every good path.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.2.10",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 2:10",
      "text": "When wisdom entereth into thine heart, and knowledge is pleasant unto thy soul;",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.2.11",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 2:11",
      "text": "Discretion shall preserve thee, understanding shall keep thee:",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.2.12",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 2:12",
      "text": "To deliver thee from the way of the evil man, from the man that speaketh froward things;",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.2.13",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 2:13",
      "text": "Who leave the paths of uprightness, to walk in the ways of darkness;",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.2.14",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 2:14",
      "text": "Who rejoice to do evil, and delight in the frowardness of the wicked;",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.2.15",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 2:15",
      "text": "Whose ways are crooked, and they froward in their paths:",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.2.16",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 2:16",
      "text": "To deliver thee from the strange woman, even from the stranger which flattereth with her words;",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.2.17",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 2:17",
      "text": "Which forsaketh the guide of her youth, and forgetteth the covenant of her God.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.2.18",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 2:18",
      "text": "For her house inclineth unto death, and her paths unto the dead.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.2.19",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 2:19",
      "text": "None that go unto her return again, neither take they hold of the paths of life.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.2.20",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 2:20",
      "text": "That thou mayest walk in the way of good men, and keep the paths of the righteous.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.2.21",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 2:21",
      "text": "For the upright shall dwell in the land, and the perfect shall remain in it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.2.22",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 2:22",
      "text": "But the wicked shall be cut off from the earth, and the transgressors shall be rooted out of it.",
      "paragraphStart": false
    }
  ]
}
