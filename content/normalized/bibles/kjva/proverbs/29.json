{
  "chapter": {
    "id": "kjva:proverbs.29",
    "translationId": "kjva",
    "bookSlug": "proverbs",
    "chapterNumber": 29,
    "referenceLabel": "Proverbs 29",
    "summary": "Source text for Proverbs 29 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:proverbs.29.1",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 29:1",
      "text": "He, that being often reproved hardeneth his neck, shall suddenly be destroyed, and that without remedy.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.29.2",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 29:2",
      "text": "When the righteous are in authority, the people rejoice: but when the wicked beareth rule, the people mourn.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.3",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 29:3",
      "text": "Whoso loveth wisdom rejoiceth his father: but he that keepeth company with harlots spendeth his substance.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.4",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 29:4",
      "text": "The king by judgment establisheth the land: but he that receiveth gifts overthroweth it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.5",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 29:5",
      "text": "A man that flattereth his neighbour spreadeth a net for his feet.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.6",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 29:6",
      "text": "In the transgression of an evil man there is a snare: but the righteous doth sing and rejoice.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.7",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 29:7",
      "text": "The righteous considereth the cause of the poor: but the wicked regardeth not to know it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.8",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 29:8",
      "text": "Scornful men bring a city into a snare: but wise men turn away wrath.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.9",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 29:9",
      "text": "If a wise man contendeth with a foolish man, whether he rage or laugh, there is no rest.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.10",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 29:10",
      "text": "The bloodthirsty hate the upright: but the just seek his soul.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.11",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 29:11",
      "text": "A fool uttereth all his mind: but a wise man keepeth it in till afterwards.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.12",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 29:12",
      "text": "If a ruler hearken to lies, all his servants are wicked.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.13",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 29:13",
      "text": "The poor and the deceitful man meet together: the Lord lighteneth both their eyes.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.14",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 29:14",
      "text": "The king that faithfully judgeth the poor, his throne shall be established for ever.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.15",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 29:15",
      "text": "The rod and reproof give wisdom: but a child left to himself bringeth his mother to shame.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.16",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 29:16",
      "text": "When the wicked are multiplied, transgression increaseth: but the righteous shall see their fall.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.17",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 29:17",
      "text": "Correct thy son, and he shall give thee rest; yea, he shall give delight unto thy soul.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.18",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 29:18",
      "text": "Where there is no vision, the people perish: but he that keepeth the law, happy is he.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.19",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 29:19",
      "text": "A servant will not be corrected by words: for though he understand he will not answer.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.20",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 29:20",
      "text": "Seest thou a man that is hasty in his words? there is more hope of a fool than of him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.21",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 29:21",
      "text": "He that delicately bringeth up his servant from a child shall have him become his son at the length.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.22",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 29:22",
      "text": "An angry man stirreth up strife, and a furious man aboundeth in transgression.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.23",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 29:23",
      "text": "A man’s pride shall bring him low: but honour shall uphold the humble in spirit.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.24",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 29:24",
      "text": "Whoso is partner with a thief hateth his own soul: he heareth cursing, and bewrayeth it not.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.25",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 29:25",
      "text": "The fear of man bringeth a snare: but whoso putteth his trust in the Lord shall be safe.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.26",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 29:26",
      "text": "Many seek the ruler’s favour; but every man’s judgment cometh from the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.29.27",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 29:27",
      "text": "An unjust man is an abomination to the just: and he that is upright in the way is abomination to the wicked.",
      "paragraphStart": false
    }
  ]
}
