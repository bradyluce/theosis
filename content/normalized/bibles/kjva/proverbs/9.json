{
  "chapter": {
    "id": "kjva:proverbs.9",
    "translationId": "kjva",
    "bookSlug": "proverbs",
    "chapterNumber": 9,
    "referenceLabel": "Proverbs 9",
    "summary": "Source text for Proverbs 9 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:proverbs.9.1",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 9:1",
      "text": "Wisdom hath builded her house, she hath hewn out her seven pillars:",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.9.2",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 9:2",
      "text": "She hath killed her beasts; she hath mingled her wine; she hath also furnished her table.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.9.3",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 9:3",
      "text": "She hath sent forth her maidens: she crieth upon the highest places of the city,",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.9.4",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 9:4",
      "text": "Whoso is simple, let him turn in hither: as for him that wanteth understanding, she saith to him,",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.9.5",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 9:5",
      "text": "Come, eat of my bread, and drink of the wine which I have mingled.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.9.6",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 9:6",
      "text": "Forsake the foolish, and live; and go in the way of understanding.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.9.7",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 9:7",
      "text": "He that reproveth a scorner getteth to himself shame: and he that rebuketh a wicked man getteth himself a blot.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.9.8",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 9:8",
      "text": "Reprove not a scorner, lest he hate thee: rebuke a wise man, and he will love thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.9.9",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 9:9",
      "text": "Give instruction to a wise man, and he will be yet wiser: teach a just man, and he will increase in learning.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.9.10",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 9:10",
      "text": "The fear of the Lord is the beginning of wisdom: and the knowledge of the holy is understanding.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.9.11",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 9:11",
      "text": "For by me thy days shall be multiplied, and the years of thy life shall be increased.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.9.12",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 9:12",
      "text": "If thou be wise, thou shalt be wise for thyself: but if thou scornest, thou alone shalt bear it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.9.13",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 9:13",
      "text": "A foolish woman is clamorous: she is simple, and knoweth nothing.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.9.14",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 9:14",
      "text": "For she sitteth at the door of her house, on a seat in the high places of the city,",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.9.15",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 9:15",
      "text": "To call passengers who go right on their ways:",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.9.16",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 9:16",
      "text": "Whoso is simple, let him turn in hither: and as for him that wanteth understanding, she saith to him,",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.9.17",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 9:17",
      "text": "Stolen waters are sweet, and bread eaten in secret is pleasant.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.9.18",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 9:18",
      "text": "But he knoweth not that the dead are there; and that her guests are in the depths of hell.",
      "paragraphStart": false
    }
  ]
}
