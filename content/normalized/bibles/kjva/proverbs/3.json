{
  "chapter": {
    "id": "kjva:proverbs.3",
    "translationId": "kjva",
    "bookSlug": "proverbs",
    "chapterNumber": 3,
    "referenceLabel": "Proverbs 3",
    "summary": "Source text for Proverbs 3 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:proverbs.3.1",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 3:1",
      "text": "My son, forget not my law; but let thine heart keep my commandments:",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.3.2",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 3:2",
      "text": "For length of days, and long life, and peace, shall they add to thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.3",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 3:3",
      "text": "Let not mercy and truth forsake thee: bind them about thy neck; write them upon the table of thine heart:",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.4",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 3:4",
      "text": "So shalt thou find favour and good understanding in the sight of God and man.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.5",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 3:5",
      "text": "Trust in the Lord with all thine heart; and lean not unto thine own understanding.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.3.6",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 3:6",
      "text": "In all thy ways acknowledge him, and he shall direct thy paths.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.7",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 3:7",
      "text": "Be not wise in thine own eyes: fear the Lord, and depart from evil.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.3.8",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 3:8",
      "text": "It shall be health to thy navel, and marrow to thy bones.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.9",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 3:9",
      "text": "Honour the Lord with thy substance, and with the firstfruits of all thine increase:",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.10",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 3:10",
      "text": "So shall thy barns be filled with plenty, and thy presses shall burst out with new wine.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.11",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 3:11",
      "text": "My son, despise not the chastening of the Lord; neither be weary of his correction:",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.3.12",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 3:12",
      "text": "For whom the Lord loveth he correcteth; even as a father the son in whom he delighteth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.13",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 3:13",
      "text": "Happy is the man that findeth wisdom, and the man that getteth understanding.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.3.14",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 3:14",
      "text": "For the merchandise of it is better than the merchandise of silver, and the gain thereof than fine gold.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.15",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 3:15",
      "text": "She is more precious than rubies: and all the things thou canst desire are not to be compared unto her.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.16",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 3:16",
      "text": "Length of days is in her right hand; and in her left hand riches and honour.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.17",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 3:17",
      "text": "Her ways are ways of pleasantness, and all her paths are peace.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.18",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 3:18",
      "text": "She is a tree of life to them that lay hold upon her: and happy is every one that retaineth her.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.19",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 3:19",
      "text": "The Lord by wisdom hath founded the earth; by understanding hath he established the heavens.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.20",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 3:20",
      "text": "By his knowledge the depths are broken up, and the clouds drop down the dew.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.21",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 3:21",
      "text": "My son, let not them depart from thine eyes: keep sound wisdom and discretion:",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.3.22",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 3:22",
      "text": "So shall they be life unto thy soul, and grace to thy neck.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.23",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 3:23",
      "text": "Then shalt thou walk in thy way safely, and thy foot shall not stumble.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.24",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 3:24",
      "text": "When thou liest down, thou shalt not be afraid: yea, thou shalt lie down, and thy sleep shall be sweet.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.25",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 3:25",
      "text": "Be not afraid of sudden fear, neither of the desolation of the wicked, when it cometh.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.26",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 3:26",
      "text": "For the Lord shall be thy confidence, and shall keep thy foot from being taken.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.27",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 3:27",
      "text": "Withhold not good from them to whom it is due, when it is in the power of thine hand to do it.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.3.28",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 3:28",
      "text": "Say not unto thy neighbour, Go, and come again, and to morrow I will give; when thou hast it by thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.29",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 3:29",
      "text": "Devise not evil against thy neighbour, seeing he dwelleth securely by thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.30",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 3:30",
      "text": "Strive not with a man without cause, if he have done thee no harm.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.3.31",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 3:31",
      "text": "Envy thou not the oppressor, and choose none of his ways.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.3.32",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 3:32",
      "text": "For the froward is abomination to the Lord: but his secret is with the righteous.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.33",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 3:33",
      "text": "The curse of the Lord is in the house of the wicked: but he blesseth the habitation of the just.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.3.34",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 3:34",
      "text": "Surely he scorneth the scorners: but he giveth grace unto the lowly.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.3.35",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 3:35",
      "text": "The wise shall inherit glory: but shame shall be the promotion of fools.",
      "paragraphStart": false
    }
  ]
}
