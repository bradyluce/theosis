{
  "chapter": {
    "id": "kjva:proverbs.26",
    "translationId": "kjva",
    "bookSlug": "proverbs",
    "chapterNumber": 26,
    "referenceLabel": "Proverbs 26",
    "summary": "Source text for Proverbs 26 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:proverbs.26.1",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 26:1",
      "text": "As snow in summer, and as rain in harvest, so honour is not seemly for a fool.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.26.2",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 26:2",
      "text": "As the bird by wandering, as the swallow by flying, so the curse causeless shall not come.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.3",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 26:3",
      "text": "A whip for the horse, a bridle for the ass, and a rod for the fool’s back.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.4",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 26:4",
      "text": "Answer not a fool according to his folly, lest thou also be like unto him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.5",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 26:5",
      "text": "Answer a fool according to his folly, lest he be wise in his own conceit.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.6",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 26:6",
      "text": "He that sendeth a message by the hand of a fool cutteth off the feet, and drinketh damage.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.7",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 26:7",
      "text": "The legs of the lame are not equal: so is a parable in the mouth of fools.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.8",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 26:8",
      "text": "As he that bindeth a stone in a sling, so is he that giveth honour to a fool.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.9",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 26:9",
      "text": "As a thorn goeth up into the hand of a drunkard, so is a parable in the mouth of fools.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.10",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 26:10",
      "text": "The great God that formed all things both rewardeth the fool, and rewardeth transgressors.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.11",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 26:11",
      "text": "As a dog returneth to his vomit, so a fool returneth to his folly.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.12",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 26:12",
      "text": "Seest thou a man wise in his own conceit? there is more hope of a fool than of him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.13",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 26:13",
      "text": "The slothful man saith, There is a lion in the way; a lion is in the streets.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.14",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 26:14",
      "text": "As the door turneth upon his hinges, so doth the slothful upon his bed.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.15",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 26:15",
      "text": "The slothful hideth his hand in his bosom; it grieveth him to bring it again to his mouth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.16",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 26:16",
      "text": "The sluggard is wiser in his own conceit than seven men that can render a reason.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.17",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 26:17",
      "text": "He that passeth by, and meddleth with strife belonging not to him, is like one that taketh a dog by the ears.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.18",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 26:18",
      "text": "As a mad man who casteth firebrands, arrows, and death,",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.19",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 26:19",
      "text": "So is the man that deceiveth his neighbour, and saith, Am not I in sport?",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.20",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 26:20",
      "text": "Where no wood is, there the fire goeth out: so where there is no talebearer, the strife ceaseth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.21",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 26:21",
      "text": "As coals are to burning coals, and wood to fire; so is a contentious man to kindle strife.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.22",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 26:22",
      "text": "The words of a talebearer are as wounds, and they go down into the innermost parts of the belly.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.23",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 26:23",
      "text": "Burning lips and a wicked heart are like a potsherd covered with silver dross.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.24",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 26:24",
      "text": "He that hateth dissembleth with his lips, and layeth up deceit within him;",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.25",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 26:25",
      "text": "When he speaketh fair, believe him not: for there are seven abominations in his heart.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.26",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 26:26",
      "text": "Whose hatred is covered by deceit, his wickedness shall be shewed before the whole congregation.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.27",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 26:27",
      "text": "Whoso diggeth a pit shall fall therein: and he that rolleth a stone, it will return upon him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.26.28",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 26:28",
      "text": "A lying tongue hateth those that are afflicted by it; and a flattering mouth worketh ruin.",
      "paragraphStart": false
    }
  ]
}
