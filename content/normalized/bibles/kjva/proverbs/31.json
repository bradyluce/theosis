{
  "chapter": {
    "id": "kjva:proverbs.31",
    "translationId": "kjva",
    "bookSlug": "proverbs",
    "chapterNumber": 31,
    "referenceLabel": "Proverbs 31",
    "summary": "Source text for Proverbs 31 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:proverbs.31.1",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 31:1",
      "text": "The words of king Lemuel, the prophecy that his mother taught him.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.31.2",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 31:2",
      "text": "What, my son? and what, the son of my womb? and what, the son of my vows?",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.3",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 31:3",
      "text": "Give not thy strength unto women, nor thy ways to that which destroyeth kings.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.4",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 31:4",
      "text": "It is not for kings, O Lemuel, it is not for kings to drink wine; nor for princes strong drink:",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.5",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 31:5",
      "text": "Lest they drink, and forget the law, and pervert the judgment of any of the afflicted.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.6",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 31:6",
      "text": "Give strong drink unto him that is ready to perish, and wine unto those that be of heavy hearts.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.7",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 31:7",
      "text": "Let him drink, and forget his poverty, and remember his misery no more.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.8",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 31:8",
      "text": "Open thy mouth for the dumb in the cause of all such as are appointed to destruction.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.9",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 31:9",
      "text": "Open thy mouth, judge righteously, and plead the cause of the poor and needy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.10",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 31:10",
      "text": "Who can find a virtuous woman? for her price is far above rubies.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.31.11",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 31:11",
      "text": "The heart of her husband doth safely trust in her, so that he shall have no need of spoil.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.12",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 31:12",
      "text": "She will do him good and not evil all the days of her life.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.13",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 31:13",
      "text": "She seeketh wool, and flax, and worketh willingly with her hands.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.14",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 31:14",
      "text": "She is like the merchants’ ships; she bringeth her food from afar.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.15",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 31:15",
      "text": "She riseth also while it is yet night, and giveth meat to her household, and a portion to her maidens.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.16",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 31:16",
      "text": "She considereth a field, and buyeth it: with the fruit of her hands she planteth a vineyard.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.17",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 31:17",
      "text": "She girdeth her loins with strength, and strengtheneth her arms.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.18",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 31:18",
      "text": "She perceiveth that her merchandise is good: her candle goeth not out by night.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.19",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 31:19",
      "text": "She layeth her hands to the spindle, and her hands hold the distaff.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.20",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 31:20",
      "text": "She stretcheth out her hand to the poor; yea, she reacheth forth her hands to the needy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.21",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 31:21",
      "text": "She is not afraid of the snow for her household: for all her household are clothed with scarlet.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.22",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 31:22",
      "text": "She maketh herself coverings of tapestry; her clothing is silk and purple.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.23",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 31:23",
      "text": "Her husband is known in the gates, when he sitteth among the elders of the land.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.24",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 31:24",
      "text": "She maketh fine linen, and selleth it; and delivereth girdles unto the merchant.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.25",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 31:25",
      "text": "Strength and honour are her clothing; and she shall rejoice in time to come.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.26",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 31:26",
      "text": "She openeth her mouth with wisdom; and in her tongue is the law of kindness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.27",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 31:27",
      "text": "She looketh well to the ways of her household, and eateth not the bread of idleness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.28",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 31:28",
      "text": "Her children arise up, and call her blessed; her husband also, and he praiseth her.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.29",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 31:29",
      "text": "Many daughters have done virtuously, but thou excellest them all.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.30",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 31:30",
      "text": "Favour is deceitful, and beauty is vain: but a woman that feareth the Lord, she shall be praised.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.31.31",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 31:31",
      "text": "Give her of the fruit of her hands; and let her own works praise her in the gates.",
      "paragraphStart": false
    }
  ]
}
