{
  "chapter": {
    "id": "kjva:proverbs.23",
    "translationId": "kjva",
    "bookSlug": "proverbs",
    "chapterNumber": 23,
    "referenceLabel": "Proverbs 23",
    "summary": "Source text for Proverbs 23 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:proverbs.23.1",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 23:1",
      "text": "When thou sittest to eat with a ruler, consider diligently what is before thee:",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.23.2",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 23:2",
      "text": "And put a knife to thy throat, if thou be a man given to appetite.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.3",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 23:3",
      "text": "Be not desirous of his dainties: for they are deceitful meat.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.4",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 23:4",
      "text": "Labour not to be rich: cease from thine own wisdom.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.5",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 23:5",
      "text": "Wilt thou set thine eyes upon that which is not? for riches certainly make themselves wings; they fly away as an eagle toward heaven.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.6",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 23:6",
      "text": "Eat thou not the bread of him that hath an evil eye, neither desire thou his dainty meats:",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.7",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 23:7",
      "text": "For as he thinketh in his heart, so is he: Eat and drink, saith he to thee; but his heart is not with thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.8",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 23:8",
      "text": "The morsel which thou hast eaten shalt thou vomit up, and lose thy sweet words.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.9",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 23:9",
      "text": "Speak not in the ears of a fool: for he will despise the wisdom of thy words.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.10",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 23:10",
      "text": "Remove not the old landmark; and enter not into the fields of the fatherless:",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.11",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 23:11",
      "text": "For their redeemer is mighty; he shall plead their cause with thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.12",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 23:12",
      "text": "Apply thine heart unto instruction, and thine ears to the words of knowledge.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.13",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 23:13",
      "text": "Withhold not correction from the child: for if thou beatest him with the rod, he shall not die.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.14",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 23:14",
      "text": "Thou shalt beat him with the rod, and shalt deliver his soul from hell.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.15",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 23:15",
      "text": "My son, if thine heart be wise, my heart shall rejoice, even mine.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.16",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 23:16",
      "text": "Yea, my reins shall rejoice, when thy lips speak right things.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.17",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 23:17",
      "text": "Let not thine heart envy sinners: but be thou in the fear of the Lord all the day long.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.18",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 23:18",
      "text": "For surely there is an end; and thine expectation shall not be cut off.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.19",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 23:19",
      "text": "Hear thou, my son, and be wise, and guide thine heart in the way.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.20",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 23:20",
      "text": "Be not among winebibbers; among riotous eaters of flesh:",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.21",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 23:21",
      "text": "For the drunkard and the glutton shall come to poverty: and drowsiness shall clothe a man with rags.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.22",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 23:22",
      "text": "Hearken unto thy father that begat thee, and despise not thy mother when she is old.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.23",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 23:23",
      "text": "Buy the truth, and sell it not; also wisdom, and instruction, and understanding.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.24",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 23:24",
      "text": "The father of the righteous shall greatly rejoice: and he that begetteth a wise child shall have joy of him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.25",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 23:25",
      "text": "Thy father and thy mother shall be glad, and she that bare thee shall rejoice.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.26",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 23:26",
      "text": "My son, give me thine heart, and let thine eyes observe my ways.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.27",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 23:27",
      "text": "For a whore is a deep ditch; and a strange woman is a narrow pit.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.28",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 23:28",
      "text": "She also lieth in wait as for a prey, and increaseth the transgressors among men.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.29",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 23:29",
      "text": "Who hath woe? who hath sorrow? who hath contentions? who hath babbling? who hath wounds without cause? who hath redness of eyes?",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.30",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 23:30",
      "text": "They that tarry long at the wine; they that go to seek mixed wine.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.31",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 23:31",
      "text": "Look not thou upon the wine when it is red, when it giveth his colour in the cup, when it moveth itself aright.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.32",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 23:32",
      "text": "At the last it biteth like a serpent, and stingeth like an adder.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.33",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 23:33",
      "text": "Thine eyes shall behold strange women, and thine heart shall utter perverse things.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.34",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 23:34",
      "text": "Yea, thou shalt be as he that lieth down in the midst of the sea, or as he that lieth upon the top of a mast.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.23.35",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 23:35",
      "text": "They have stricken me, shalt thou say, and I was not sick; they have beaten me, and I felt it not: when shall I awake? I will seek it yet again.",
      "paragraphStart": false
    }
  ]
}
