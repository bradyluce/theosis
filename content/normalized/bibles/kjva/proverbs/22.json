{
  "chapter": {
    "id": "kjva:proverbs.22",
    "translationId": "kjva",
    "bookSlug": "proverbs",
    "chapterNumber": 22,
    "referenceLabel": "Proverbs 22",
    "summary": "Source text for Proverbs 22 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:proverbs.22.1",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 22:1",
      "text": "A good name is rather to be chosen than great riches, and loving favour rather than silver and gold.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.22.2",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 22:2",
      "text": "The rich and poor meet together: the Lord is the maker of them all.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.3",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 22:3",
      "text": "A prudent man foreseeth the evil, and hideth himself: but the simple pass on, and are punished.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.4",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 22:4",
      "text": "By humility and the fear of the Lord are riches, and honour, and life.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.5",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 22:5",
      "text": "Thorns and snares are in the way of the froward: he that doth keep his soul shall be far from them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.6",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 22:6",
      "text": "Train up a child in the way he should go: and when he is old, he will not depart from it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.7",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 22:7",
      "text": "The rich ruleth over the poor, and the borrower is servant to the lender.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.8",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 22:8",
      "text": "He that soweth iniquity shall reap vanity: and the rod of his anger shall fail.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.9",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 22:9",
      "text": "He that hath a bountiful eye shall be blessed; for he giveth of his bread to the poor.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.10",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 22:10",
      "text": "Cast out the scorner, and contention shall go out; yea, strife and reproach shall cease.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.11",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 22:11",
      "text": "He that loveth pureness of heart, for the grace of his lips the king shall be his friend.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.12",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 22:12",
      "text": "The eyes of the Lord preserve knowledge, and he overthroweth the words of the transgressor.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.13",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 22:13",
      "text": "The slothful man saith, There is a lion without, I shall be slain in the streets.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.14",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 22:14",
      "text": "The mouth of strange women is a deep pit: he that is abhorred of the Lord shall fall therein.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.15",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 22:15",
      "text": "Foolishness is bound in the heart of a child; but the rod of correction shall drive it far from him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.16",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 22:16",
      "text": "He that oppresseth the poor to increase his riches, and he that giveth to the rich, shall surely come to want.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.17",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 22:17",
      "text": "Bow down thine ear, and hear the words of the wise, and apply thine heart unto my knowledge.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.18",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 22:18",
      "text": "For it is a pleasant thing if thou keep them within thee; they shall withal be fitted in thy lips.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.19",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 22:19",
      "text": "That thy trust may be in the Lord, I have made known to thee this day, even to thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.20",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 22:20",
      "text": "Have not I written to thee excellent things in counsels and knowledge,",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.21",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 22:21",
      "text": "That I might make thee know the certainty of the words of truth; that thou mightest answer the words of truth to them that send unto thee?",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.22",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 22:22",
      "text": "Rob not the poor, because he is poor: neither oppress the afflicted in the gate:",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.23",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 22:23",
      "text": "For the Lord will plead their cause, and spoil the soul of those that spoiled them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.24",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 22:24",
      "text": "Make no friendship with an angry man; and with a furious man thou shalt not go:",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.25",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 22:25",
      "text": "Lest thou learn his ways, and get a snare to thy soul.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.26",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 22:26",
      "text": "Be not thou one of them that strike hands, or of them that are sureties for debts.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.27",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 22:27",
      "text": "If thou hast nothing to pay, why should he take away thy bed from under thee?",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.28",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 22:28",
      "text": "Remove not the ancient landmark, which thy fathers have set.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.22.29",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 22:29",
      "text": "Seest thou a man diligent in his business? he shall stand before kings; he shall not stand before mean men.",
      "paragraphStart": false
    }
  ]
}
