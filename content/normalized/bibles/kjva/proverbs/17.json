{
  "chapter": {
    "id": "kjva:proverbs.17",
    "translationId": "kjva",
    "bookSlug": "proverbs",
    "chapterNumber": 17,
    "referenceLabel": "Proverbs 17",
    "summary": "Source text for Proverbs 17 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:proverbs.17.1",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 17:1",
      "text": "Better is a dry morsel, and quietness therewith, than an house full of sacrifices with strife.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.17.2",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 17:2",
      "text": "A wise servant shall have rule over a son that causeth shame, and shall have part of the inheritance among the brethren.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.3",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 17:3",
      "text": "The fining pot is for silver, and the furnace for gold: but the Lord trieth the hearts.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.4",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 17:4",
      "text": "A wicked doer giveth heed to false lips; and a liar giveth ear to a naughty tongue.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.5",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 17:5",
      "text": "Whoso mocketh the poor reproacheth his Maker: and he that is glad at calamities shall not be unpunished.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.6",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 17:6",
      "text": "Children’s children are the crown of old men; and the glory of children are their fathers.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.7",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 17:7",
      "text": "Excellent speech becometh not a fool: much less do lying lips a prince.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.8",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 17:8",
      "text": "A gift is as a precious stone in the eyes of him that hath it: whithersoever it turneth, it prospereth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.9",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 17:9",
      "text": "He that covereth a transgression seeketh love; but he that repeateth a matter separateth very friends.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.10",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 17:10",
      "text": "A reproof entereth more into a wise man than an hundred stripes into a fool.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.11",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 17:11",
      "text": "An evil man seeketh only rebellion: therefore a cruel messenger shall be sent against him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.12",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 17:12",
      "text": "Let a bear robbed of her whelps meet a man, rather than a fool in his folly.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.13",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 17:13",
      "text": "Whoso rewardeth evil for good, evil shall not depart from his house.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.14",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 17:14",
      "text": "The beginning of strife is as when one letteth out water: therefore leave off contention, before it be meddled with.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.15",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 17:15",
      "text": "He that justifieth the wicked, and he that condemneth the just, even they both are abomination to the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.16",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 17:16",
      "text": "Wherefore is there a price in the hand of a fool to get wisdom, seeing he hath no heart to it?",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.17",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 17:17",
      "text": "A friend loveth at all times, and a brother is born for adversity.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.18",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 17:18",
      "text": "A man void of understanding striketh hands, and becometh surety in the presence of his friend.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.19",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 17:19",
      "text": "He loveth transgression that loveth strife: and he that exalteth his gate seeketh destruction.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.20",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 17:20",
      "text": "He that hath a froward heart findeth no good: and he that hath a perverse tongue falleth into mischief.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.21",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 17:21",
      "text": "He that begetteth a fool doeth it to his sorrow: and the father of a fool hath no joy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.22",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 17:22",
      "text": "A merry heart doeth good like a medicine: but a broken spirit drieth the bones.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.23",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 17:23",
      "text": "A wicked man taketh a gift out of the bosom to pervert the ways of judgment.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.24",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 17:24",
      "text": "Wisdom is before him that hath understanding; but the eyes of a fool are in the ends of the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.25",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 17:25",
      "text": "A foolish son is a grief to his father, and bitterness to her that bare him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.26",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 17:26",
      "text": "Also to punish the just is not good, nor to strike princes for equity.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.27",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 17:27",
      "text": "He that hath knowledge spareth his words: and a man of understanding is of an excellent spirit.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.17.28",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 17:28",
      "text": "Even a fool, when he holdeth his peace, is counted wise: and he that shutteth his lips is esteemed a man of understanding.",
      "paragraphStart": false
    }
  ]
}
