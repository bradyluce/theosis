{
  "chapter": {
    "id": "kjva:proverbs.10",
    "translationId": "kjva",
    "bookSlug": "proverbs",
    "chapterNumber": 10,
    "referenceLabel": "Proverbs 10",
    "summary": "Source text for Proverbs 10 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:proverbs.10.1",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 10:1",
      "text": "The proverbs of Solomon. A wise son maketh a glad father: but a foolish son is the heaviness of his mother.",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.10.2",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 10:2",
      "text": "Treasures of wickedness profit nothing: but righteousness delivereth from death.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.3",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 10:3",
      "text": "The Lord will not suffer the soul of the righteous to famish: but he casteth away the substance of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.4",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 10:4",
      "text": "He becometh poor that dealeth with a slack hand: but the hand of the diligent maketh rich.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.5",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 10:5",
      "text": "He that gathereth in summer is a wise son: but he that sleepeth in harvest is a son that causeth shame.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.6",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 10:6",
      "text": "Blessings are upon the head of the just: but violence covereth the mouth of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.7",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 10:7",
      "text": "The memory of the just is blessed: but the name of the wicked shall rot.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.8",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 10:8",
      "text": "The wise in heart will receive commandments: but a prating fool shall fall.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.9",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 10:9",
      "text": "He that walketh uprightly walketh surely: but he that perverteth his ways shall be known.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.10",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 10:10",
      "text": "He that winketh with the eye causeth sorrow: but a prating fool shall fall.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.11",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 10:11",
      "text": "The mouth of a righteous man is a well of life: but violence covereth the mouth of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.12",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 10:12",
      "text": "Hatred stirreth up strifes: but love covereth all sins.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.13",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 10:13",
      "text": "In the lips of him that hath understanding wisdom is found: but a rod is for the back of him that is void of understanding.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.14",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 10:14",
      "text": "Wise men lay up knowledge: but the mouth of the foolish is near destruction.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.15",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 10:15",
      "text": "The rich man’s wealth is his strong city: the destruction of the poor is their poverty.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.16",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 10:16",
      "text": "The labour of the righteous tendeth to life: the fruit of the wicked to sin.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.17",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 10:17",
      "text": "He is in the way of life that keepeth instruction: but he that refuseth reproof erreth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.18",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 10:18",
      "text": "He that hideth hatred with lying lips, and he that uttereth a slander, is a fool.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.19",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 10:19",
      "text": "In the multitude of words there wanteth not sin: but he that refraineth his lips is wise.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.20",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 10:20",
      "text": "The tongue of the just is as choice silver: the heart of the wicked is little worth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.21",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 10:21",
      "text": "The lips of the righteous feed many: but fools die for want of wisdom.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.22",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 10:22",
      "text": "The blessing of the Lord, it maketh rich, and he addeth no sorrow with it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.23",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 10:23",
      "text": "It is as sport to a fool to do mischief: but a man of understanding hath wisdom.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.24",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 10:24",
      "text": "The fear of the wicked, it shall come upon him: but the desire of the righteous shall be granted.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.25",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 10:25",
      "text": "As the whirlwind passeth, so is the wicked no more: but the righteous is an everlasting foundation.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.26",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 10:26",
      "text": "As vinegar to the teeth, and as smoke to the eyes, so is the sluggard to them that send him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.27",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 10:27",
      "text": "The fear of the Lord prolongeth days: but the years of the wicked shall be shortened.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.28",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 10:28",
      "text": "The hope of the righteous shall be gladness: but the expectation of the wicked shall perish.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.29",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 10:29",
      "text": "The way of the Lord is strength to the upright: but destruction shall be to the workers of iniquity.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.30",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 10:30",
      "text": "The righteous shall never be removed: but the wicked shall not inhabit the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.31",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 10:31",
      "text": "The mouth of the just bringeth forth wisdom: but the froward tongue shall be cut out.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.10.32",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 10:32",
      "text": "The lips of the righteous know what is acceptable: but the mouth of the wicked speaketh frowardness.",
      "paragraphStart": false
    }
  ]
}
