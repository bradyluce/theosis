{
  "chapter": {
    "id": "kjva:proverbs.8",
    "translationId": "kjva",
    "bookSlug": "proverbs",
    "chapterNumber": 8,
    "referenceLabel": "Proverbs 8",
    "summary": "Source text for Proverbs 8 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:proverbs.8.1",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 8:1",
      "text": "Doth not wisdom cry? and understanding put forth her voice?",
      "paragraphStart": true
    },
    {
      "id": "kjva:proverbs.8.2",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 8:2",
      "text": "She standeth in the top of high places, by the way in the places of the paths.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.3",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 8:3",
      "text": "She crieth at the gates, at the entry of the city, at the coming in at the doors.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.4",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 8:4",
      "text": "Unto you, O men, I call; and my voice is to the sons of man.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.5",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 8:5",
      "text": "O ye simple, understand wisdom: and, ye fools, be ye of an understanding heart.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.6",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 8:6",
      "text": "Hear; for I will speak of excellent things; and the opening of my lips shall be right things.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.7",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 8:7",
      "text": "For my mouth shall speak truth; and wickedness is an abomination to my lips.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.8",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 8:8",
      "text": "All the words of my mouth are in righteousness; there is nothing froward or perverse in them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.9",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 8:9",
      "text": "They are all plain to him that understandeth, and right to them that find knowledge.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.10",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 8:10",
      "text": "Receive my instruction, and not silver; and knowledge rather than choice gold.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.11",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 8:11",
      "text": "For wisdom is better than rubies; and all the things that may be desired are not to be compared to it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.12",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 8:12",
      "text": "I wisdom dwell with prudence, and find out knowledge of witty inventions.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.13",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 8:13",
      "text": "The fear of the Lord is to hate evil: pride, and arrogancy, and the evil way, and the froward mouth, do I hate.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.14",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 8:14",
      "text": "Counsel is mine, and sound wisdom: I am understanding; I have strength.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.15",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 8:15",
      "text": "By me kings reign, and princes decree justice.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.16",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 8:16",
      "text": "By me princes rule, and nobles, even all the judges of the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.17",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 8:17",
      "text": "I love them that love me; and those that seek me early shall find me.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.18",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 8:18",
      "text": "Riches and honour are with me; yea, durable riches and righteousness.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.19",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 8:19",
      "text": "My fruit is better than gold, yea, than fine gold; and my revenue than choice silver.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.20",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 8:20",
      "text": "I lead in the way of righteousness, in the midst of the paths of judgment:",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.21",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 8:21",
      "text": "That I may cause those that love me to inherit substance; and I will fill their treasures.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.22",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 8:22",
      "text": "The Lord possessed me in the beginning of his way, before his works of old.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.23",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 8:23",
      "text": "I was set up from everlasting, from the beginning, or ever the earth was.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.24",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 8:24",
      "text": "When there were no depths, I was brought forth; when there were no fountains abounding with water.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.25",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 8:25",
      "text": "Before the mountains were settled, before the hills was I brought forth:",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.26",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 8:26",
      "text": "While as yet he had not made the earth, nor the fields, nor the highest part of the dust of the world.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.27",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 8:27",
      "text": "When he prepared the heavens, I was there: when he set a compass upon the face of the depth:",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.28",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 8:28",
      "text": "When he established the clouds above: when he strengthened the fountains of the deep:",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.29",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 8:29",
      "text": "When he gave to the sea his decree, that the waters should not pass his commandment: when he appointed the foundations of the earth:",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.30",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 8:30",
      "text": "Then I was by him, as one brought up with him: and I was daily his delight, rejoicing always before him;",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.31",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 8:31",
      "text": "Rejoicing in the habitable part of his earth; and my delights were with the sons of men.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.32",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 8:32",
      "text": "Now therefore hearken unto me, O ye children: for blessed are they that keep my ways.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.33",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 8:33",
      "text": "Hear instruction, and be wise, and refuse it not.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.34",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 8:34",
      "text": "Blessed is the man that heareth me, watching daily at my gates, waiting at the posts of my doors.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.35",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 8:35",
      "text": "For whoso findeth me findeth life, and shall obtain favour of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "kjva:proverbs.8.36",
      "translationId": "kjva",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 36,
      "referenceLabel": "Proverbs 8:36",
      "text": "But he that sinneth against me wrongeth his own soul: all they that hate me love death.",
      "paragraphStart": false
    }
  ]
}
