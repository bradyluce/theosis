  "verses": [
    {
      "id": "kjva:job.25.1",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Job 25:1",
      "text": "Then answered Bildad the Shuhite, and said,",
      "paragraphStart": true
    },
    {
      "id": "kjva:job.25.2",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Job 25:2",
      "text": "Dominion and fear are with him, he maketh peace in his high places.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.25.3",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Job 25:3",
      "text": "Is there any number of his armies? and upon whom doth not his light arise?",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.25.4",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Job 25:4",
      "text": "How then can man be justified with God? or how can he be clean that is born of a woman?",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.25.5",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Job 25:5",
      "text": "Behold even to the moon, and it shineth not; yea, the stars are not pure in his sight.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.25.6",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Job 25:6",
      "text": "How much less man, that is a worm? and the son of man, which is a worm?",
      "paragraphStart": false
    }
  ]
}
