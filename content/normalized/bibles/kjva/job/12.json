{
  "chapter": {
    "id": "kjva:job.12",
    "translationId": "kjva",
    "bookSlug": "job",
    "chapterNumber": 12,
    "referenceLabel": "Job 12",
    "summary": "Source text for Job 12 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:job.12.1",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Job 12:1",
      "text": "And Job answered and said,",
      "paragraphStart": true
    },
    {
      "id": "kjva:job.12.2",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Job 12:2",
      "text": "No doubt but ye are the people, and wisdom shall die with you.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.3",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Job 12:3",
      "text": "But I have understanding as well as you; I am not inferior to you: yea, who knoweth not such things as these?",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.4",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Job 12:4",
      "text": "I am as one mocked of his neighbour, who calleth upon God, and he answereth him: the just upright man is laughed to scorn.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.5",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Job 12:5",
      "text": "He that is ready to slip with his feet is as a lamp despised in the thought of him that is at ease.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.6",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Job 12:6",
      "text": "The tabernacles of robbers prosper, and they that provoke God are secure; into whose hand God bringeth abundantly.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.7",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Job 12:7",
      "text": "But ask now the beasts, and they shall teach thee; and the fowls of the air, and they shall tell thee:",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.8",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Job 12:8",
      "text": "Or speak to the earth, and it shall teach thee: and the fishes of the sea shall declare unto thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.9",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Job 12:9",
      "text": "Who knoweth not in all these that the hand of the Lord hath wrought this?",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.10",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Job 12:10",
      "text": "In whose hand is the soul of every living thing, and the breath of all mankind.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.11",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Job 12:11",
      "text": "Doth not the ear try words? and the mouth taste his meat?",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.12",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Job 12:12",
      "text": "With the ancient is wisdom; and in length of days understanding.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.13",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Job 12:13",
      "text": "With him is wisdom and strength, he hath counsel and understanding.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.14",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Job 12:14",
      "text": "Behold, he breaketh down, and it cannot be built again: he shutteth up a man, and there can be no opening.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.15",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Job 12:15",
      "text": "Behold, he withholdeth the waters, and they dry up: also he sendeth them out, and they overturn the earth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.16",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Job 12:16",
      "text": "With him is strength and wisdom: the deceived and the deceiver are his.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.17",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Job 12:17",
      "text": "He leadeth counsellors away spoiled, and maketh the judges fools.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.18",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Job 12:18",
      "text": "He looseth the bond of kings, and girdeth their loins with a girdle.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.19",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Job 12:19",
      "text": "He leadeth princes away spoiled, and overthroweth the mighty.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.20",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Job 12:20",
      "text": "He removeth away the speech of the trusty, and taketh away the understanding of the aged.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.21",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Job 12:21",
      "text": "He poureth contempt upon princes, and weakeneth the strength of the mighty.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.22",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Job 12:22",
      "text": "He discovereth deep things out of darkness, and bringeth out to light the shadow of death.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.23",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Job 12:23",
      "text": "He increaseth the nations, and destroyeth them: he enlargeth the nations, and straiteneth them again.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.24",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Job 12:24",
      "text": "He taketh away the heart of the chief of the people of the earth, and causeth them to wander in a wilderness where there is no way.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.12.25",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Job 12:25",
      "text": "They grope in the dark without light, and he maketh them to stagger like a drunken man.",
      "paragraphStart": false
    }
  ]
}
