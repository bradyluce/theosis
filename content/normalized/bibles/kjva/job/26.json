{
  "chapter": {
    "id": "kjva:job.26",
    "translationId": "kjva",
    "bookSlug": "job",
    "chapterNumber": 26,
    "referenceLabel": "Job 26",
    "summary": "Source text for Job 26 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:job.26.1",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Job 26:1",
      "text": "But Job answered and said,",
      "paragraphStart": true
    },
    {
      "id": "kjva:job.26.2",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Job 26:2",
      "text": "How hast thou helped him that is without power? how savest thou the arm that hath no strength?",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.26.3",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Job 26:3",
      "text": "How hast thou counselled him that hath no wisdom? and how hast thou plentifully declared the thing as it is?",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.26.4",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Job 26:4",
      "text": "To whom hast thou uttered words? and whose spirit came from thee?",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.26.5",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Job 26:5",
      "text": "Dead things are formed from under the waters, and the inhabitants thereof.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.26.6",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Job 26:6",
      "text": "Hell is naked before him, and destruction hath no covering.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.26.7",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Job 26:7",
      "text": "He stretcheth out the north over the empty place, and hangeth the earth upon nothing.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.26.8",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Job 26:8",
      "text": "He bindeth up the waters in his thick clouds; and the cloud is not rent under them.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.26.9",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Job 26:9",
      "text": "He holdeth back the face of his throne, and spreadeth his cloud upon it.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.26.10",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Job 26:10",
      "text": "He hath compassed the waters with bounds, until the day and night come to an end.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.26.11",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Job 26:11",
      "text": "The pillars of heaven tremble and are astonished at his reproof.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.26.12",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Job 26:12",
      "text": "He divideth the sea with his power, and by his understanding he smiteth through the proud.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.26.13",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 13,
      "referenceLabel": "Job 26:13",
      "text": "By his spirit he hath garnished the heavens; his hand hath formed the crooked serpent.",
      "paragraphStart": false
    },
    {
      "id": "kjva:job.26.14",
      "translationId": "kjva",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 14,
      "referenceLabel": "Job 26:14",
      "text": "Lo, these are parts of his ways: but how little a portion is heard of him? but the thunder of his power who can understand?",
      "paragraphStart": false
    }
  ]
}
