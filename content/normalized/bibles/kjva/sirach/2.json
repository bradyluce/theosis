{
  "chapter": {
    "id": "kjva:sirach.2",
    "translationId": "kjva",
    "bookSlug": "sirach",
    "chapterNumber": 2,
    "referenceLabel": "Sirach 2",
    "summary": "Source text for Sirach 2 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:sirach.2.1",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Sirach 2:1",
      "text": "My son, if thou come to serve the Lord, prepare thy soul for temptation.",
      "paragraphStart": true
    },
    {
      "id": "kjva:sirach.2.2",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Sirach 2:2",
      "text": "Set thy heart aright, and constantly endure, and make not haste in time of trouble.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.2.3",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Sirach 2:3",
      "text": "Cleave unto him, and depart not away, that thou mayest be increased at thy last end.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.2.4",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Sirach 2:4",
      "text": "Whatsoever is brought upon thee take cheerfully, and be patient when thou art changed to a low estate.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.2.5",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Sirach 2:5",
      "text": "For gold is tried in the fire, and acceptable men in the furnace of adversity.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.2.6",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Sirach 2:6",
      "text": "Believe in him, and he will help thee; order thy way aright, and trust in him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.2.7",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Sirach 2:7",
      "text": "Ye that fear the Lord, wait for his mercy; and go not aside, lest ye fall.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.2.8",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Sirach 2:8",
      "text": "Ye that fear the Lord, believe him; and your reward shall not fail.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.2.9",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Sirach 2:9",
      "text": "Ye that fear the Lord, hope for good, and for everlasting joy and mercy.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.2.10",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Sirach 2:10",
      "text": "Look at the generations of old, and see; did ever any trust in the Lord, and was confounded? or did any abide in his fear, and was forsaken? or whom did he ever despise, that called upon him?",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.2.11",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Sirach 2:11",
      "text": "For the Lord is full of compassion and mercy, longsuffering, and very pitiful, and forgiveth sins, and saveth in time of affliction.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.2.12",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Sirach 2:12",
      "text": "Woe be to fearful hearts, and faint hands, and the sinner that goeth two ways!",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.2.13",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Sirach 2:13",
      "text": "Woe unto him that is fainthearted! for he believeth not; therefore shall he not be defended.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.2.14",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Sirach 2:14",
      "text": "Woe unto you that have lost patience! and what will ye do when the Lord shall visit you?",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.2.15",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Sirach 2:15",
      "text": "They that fear the Lord will not disobey his Word; and they that love him will keep his ways.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.2.16",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Sirach 2:16",
      "text": "They that fear the Lord will seek that which is well, pleasing unto him; and they that love him shall be filled with the law.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.2.17",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Sirach 2:17",
      "text": "They that fear the Lord will prepare their hearts, and humble their souls in his sight,",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.2.18",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Sirach 2:18",
      "text": "Saying, We will fall into the hands of the Lord, and not into the hands of men: for as his majesty is, so is his mercy.",
      "paragraphStart": false
    }
  ]
}
