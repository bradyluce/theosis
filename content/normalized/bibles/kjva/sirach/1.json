{
  "chapter": {
    "id": "kjva:sirach.1",
    "translationId": "kjva",
    "bookSlug": "sirach",
    "chapterNumber": 1,
    "referenceLabel": "Sirach 1",
    "summary": "Source text for Sirach 1 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:sirach.1.1",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Sirach 1:1",
      "text": "All wisdom cometh from the Lord, and is with him for ever.",
      "paragraphStart": true
    },
    {
      "id": "kjva:sirach.1.2",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Sirach 1:2",
      "text": "Who can number the sand of the sea, and the drops of rain, and the days of eternity?",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.3",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Sirach 1:3",
      "text": "Who can find out the height of heaven, and the breadth of the earth, and the deep, and wisdom?",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.4",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Sirach 1:4",
      "text": "Wisdom hath been created before all things, and the understanding of prudence from everlasting.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.5",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Sirach 1:5",
      "text": "The word of God most high is the fountain of wisdom; and her ways are everlasting commandments.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.6",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Sirach 1:6",
      "text": "To whom hath the root of wisdom been revealed? or who hath known her wise counsels?",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.8",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Sirach 1:8",
      "text": "There is one wise and greatly to be feared, the Lord sitting upon his throne.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.9",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Sirach 1:9",
      "text": "He created her, and saw her, and numbered her, and poured her out upon all his works.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.10",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Sirach 1:10",
      "text": "She is with all flesh according to his gift, and he hath given her to them that love him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.11",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Sirach 1:11",
      "text": "The fear of the Lord is honour, and glory, and gladness, and a crown of rejoicing.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.12",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Sirach 1:12",
      "text": "The fear of the Lord maketh a merry heart, and giveth joy, and gladness, and a long life.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.13",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Sirach 1:13",
      "text": "Whoso feareth the Lord, it shall go well with him at the last, and he shall find favour in the day of his death.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.14",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Sirach 1:14",
      "text": "To fear the Lord is the beginning of wisdom: and it was created with the faithful in the womb.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.15",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Sirach 1:15",
      "text": "She hath built an everlasting foundation with men, and she shall continue with their seed.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.16",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Sirach 1:16",
      "text": "To fear the Lord is fulness of wisdom, and filleth men with her fruits.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.17",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Sirach 1:17",
      "text": "She filleth all their house with things desirable, and the garners with her increase.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.18",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Sirach 1:18",
      "text": "The fear of the Lord is a crown of wisdom, making peace and perfect health to flourish; both which are the gifts of God: and it enlargeth their rejoicing that love him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.19",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Sirach 1:19",
      "text": "Wisdom raineth down skill and knowledge of understanding standing, and exalteth them to honour that hold her fast.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.20",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Sirach 1:20",
      "text": "The root of wisdom is to fear the Lord, and the branches thereof are long life.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.21",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Sirach 1:21",
      "text": "The fear of the Lord driveth away sins: and where it is present, it turneth away wrath.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.22",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Sirach 1:22",
      "text": "A furious man cannot be justified; for the sway of his fury shall be his destruction.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.23",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Sirach 1:23",
      "text": "A patient man will tear for a time, and afterward joy shall spring up unto him.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.24",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Sirach 1:24",
      "text": "He will hide his words for a time, and the lips of many shall declare his wisdom.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.25",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Sirach 1:25",
      "text": "The parables of knowledge are in the treasures of wisdom: but godliness is an abomination to a sinner.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.26",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "Sirach 1:26",
      "text": "If thou desire wisdom, keep the commandments, and the Lord shall give her unto thee.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.27",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "Sirach 1:27",
      "text": "For the fear of the Lord is wisdom and instruction: and faith and meekness are his delight.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.28",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "Sirach 1:28",
      "text": "Distrust not the fear of the Lord when thou art poor: and come not unto him with a double heart.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.29",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "Sirach 1:29",
      "text": "Be not an hypocrite in the sight of men, and take good heed what thou speakest.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.1.30",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "Sirach 1:30",
      "text": "Exalt not thyself, lest thou fall, and bring dishonour upon thy soul, and so God discover thy secrets, and cast thee down in the midst of the congregation, because thou camest not in truth to the fear of the Lord, but thy heart is full of deceit.",
      "paragraphStart": false
    }
  ]
}
