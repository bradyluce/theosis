{
  "chapter": {
    "id": "kjva:sirach.5",
    "translationId": "kjva",
    "bookSlug": "sirach",
    "chapterNumber": 5,
    "referenceLabel": "Sirach 5",
    "summary": "Source text for Sirach 5 in King James Version with Apocrypha."
  },
  "verses": [
    {
      "id": "kjva:sirach.5.1",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Sirach 5:1",
      "text": "Set thy heart upon thy goods; and say not, I have enough for my life.",
      "paragraphStart": true
    },
    {
      "id": "kjva:sirach.5.2",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Sirach 5:2",
      "text": "Follow not thine own mind and thy strength, to walk in the ways of thy heart:",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.5.3",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Sirach 5:3",
      "text": "And say not, Who shall controul me for my works? for the Lord will surely revenge thy pride.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.5.4",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Sirach 5:4",
      "text": "Say not, I have sinned, and what harm hath happened unto me? for the Lord is longsuffering, he will in no wise let thee go.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.5.5",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Sirach 5:5",
      "text": "Concerning propitiation, be not without fear to add sin unto sin:",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.5.6",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Sirach 5:6",
      "text": "And say not His mercy is great; he will be pacified for the multitude of my sins: for mercy and wrath come from him, and his indignation resteth upon sinners.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.5.7",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Sirach 5:7",
      "text": "Make no tarrying to turn to the Lord, and put not off from day to day: for suddenly shall the wrath of the Lord come forth, and in thy security thou shalt be destroyed, and perish in the day of vengeance.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.5.8",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Sirach 5:8",
      "text": "Set not thine heart upon goods unjustly gotten, for they shall not profit thee in the day of calamity.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.5.9",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Sirach 5:9",
      "text": "Winnow not with every wind, and go not into every way: for so doth the sinner that hath a double tongue.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.5.10",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Sirach 5:10",
      "text": "Be stedfast in thy understanding; and let thy word be the same.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.5.11",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Sirach 5:11",
      "text": "Be swift to hear; and let thy life be sincere; and with patience give answer.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.5.12",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Sirach 5:12",
      "text": "If thou hast understanding, answer thy neighbour; if not, lay thy hand upon thy mouth.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.5.13",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Sirach 5:13",
      "text": "Honour and shame is in talk: and the tongue of man is his fall.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.5.14",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Sirach 5:14",
      "text": "Be not called a whisperer, and lie not in wait with thy tongue: for a foul shame is upon the thief, and an evil condemnation upon the double tongue.",
      "paragraphStart": false
    },
    {
      "id": "kjva:sirach.5.15",
      "translationId": "kjva",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Sirach 5:15",
      "text": "Be not ignorant of any thing in a great matter or a small.",
      "paragraphStart": false
    }
  ]
}
