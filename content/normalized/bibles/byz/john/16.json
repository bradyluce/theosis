{
  "chapter": {
    "id": "byz:john.16",
    "translationId": "byz",
    "bookSlug": "john",
    "chapterNumber": 16,
    "referenceLabel": "John 16",
    "summary": "Source text for John 16 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:john.16.1",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "John 16:1",
      "text": "ταυτα λελαληκα υμιν ινα μη σκανδαλισθητε",
      "paragraphStart": true
    },
    {
      "id": "byz:john.16.2",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "John 16:2",
      "text": "αποσυναγωγους ποιησουσιν υμας αλλ ερχεται ωρα ινα πας ο αποκτεινας υμας δοξη λατρειαν προσφερειν τω θεω",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.3",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "John 16:3",
      "text": "και ταυτα ποιησουσιν οτι ουκ εγνωσαν τον πατερα ουδε εμε",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.4",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "John 16:4",
      "text": "αλλα ταυτα λελαληκα υμιν ινα οταν ελθη η ωρα μνημονευητε αυτων οτι εγω ειπον υμιν ταυτα δε υμιν εξ αρχης ουκ ειπον οτι μεθ υμων ημην",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.5",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "John 16:5",
      "text": "νυν δε υπαγω προς τον πεμψαντα με και ουδεις εξ υμων ερωτα με που υπαγεις",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.6",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "John 16:6",
      "text": "αλλ οτι ταυτα λελαληκα υμιν η λυπη πεπληρωκεν υμων την καρδιαν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.7",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "John 16:7",
      "text": "αλλ εγω την αληθειαν λεγω υμιν συμφερει υμιν ινα εγω απελθω εαν γαρ εγω μη απελθω ο παρακλητος ουκ ελευσεται προς υμας εαν δε πορευθω πεμψω αυτον προς υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.8",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "John 16:8",
      "text": "και ελθων εκεινος ελεγξει τον κοσμον περι αμαρτιας και περι δικαιοσυνης και περι κρισεως",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.9",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "John 16:9",
      "text": "περι αμαρτιας μεν οτι ου πιστευουσιν εις εμε",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.10",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "John 16:10",
      "text": "περι δικαιοσυνης δε οτι προς τον πατερα μου υπαγω και ουκετι θεωρειτε με",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.11",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "John 16:11",
      "text": "περι δε κρισεως οτι ο αρχων του κοσμου τουτου κεκριται",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.12",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "John 16:12",
      "text": "ετι πολλα εχω λεγειν υμιν αλλ ου δυνασθε βασταζειν αρτι",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.13",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "John 16:13",
      "text": "οταν δε ελθη εκεινος το πνευμα της αληθειας οδηγησει υμας εις πασαν την αληθειαν ου γαρ λαλησει αφ εαυτου αλλ οσα αν ακουση λαλησει και τα ερχομενα αναγγελει υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.14",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "John 16:14",
      "text": "εκεινος εμε δοξασει οτι εκ του εμου ληψεται και αναγγελει υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.15",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "John 16:15",
      "text": "παντα οσα εχει ο πατηρ εμα εστιν δια τουτο ειπον οτι εκ του εμου λαμβανει και αναγγελει υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.16",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "John 16:16",
      "text": "μικρον και ου θεωρειτε με και παλιν μικρον και οψεσθε με οτι υπαγω προς τον πατερα",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.17",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "John 16:17",
      "text": "ειπον ουν εκ των μαθητων αυτου προς αλληλους τι εστιν τουτο ο λεγει ημιν μικρον και ου θεωρειτε με και παλιν μικρον και οψεσθε με και οτι εγω υπαγω προς τον πατερα",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.18",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "John 16:18",
      "text": "ελεγον ουν τουτο τι εστιν ο λεγει το μικρον ουκ οιδαμεν τι λαλει",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.19",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "John 16:19",
      "text": "εγνω ουν ο ιησους οτι ηθελον αυτον ερωταν και ειπεν αυτοις περι τουτου ζητειτε μετ αλληλων οτι ειπον μικρον και ου θεωρειτε με και παλιν μικρον και οψεσθε με",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.20",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "John 16:20",
      "text": "αμην αμην λεγω υμιν οτι κλαυσετε και θρηνησετε υμεις ο δε κοσμος χαρησεται υμεις δε λυπηθησεσθε αλλ η λυπη υμων εις χαραν γενησεται",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.21",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "John 16:21",
      "text": "η γυνη οταν τικτη λυπην εχει οτι ηλθεν η ωρα αυτης οταν δε γεννηση το παιδιον ουκετι μνημονευει της θλιψεως δια την χαραν οτι εγεννηθη ανθρωπος εις τον κοσμον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.22",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "John 16:22",
      "text": "και υμεις ουν λυπην μεν νυν εχετε παλιν δε οψομαι υμας και χαρησεται υμων η καρδια και την χαραν υμων ουδεις αιρει αφ υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.23",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "John 16:23",
      "text": "και εν εκεινη τη ημερα εμε ουκ ερωτησετε ουδεν αμην αμην λεγω υμιν οτι οσα αν αιτησητε τον πατερα εν τω ονοματι μου δωσει υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.24",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "John 16:24",
      "text": "εως αρτι ουκ ητησατε ουδεν εν τω ονοματι μου αιτειτε και ληψεσθε ινα η χαρα υμων η πεπληρωμενη",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.25",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 25,
      "referenceLabel": "John 16:25",
      "text": "ταυτα εν παροιμιαις λελαληκα υμιν αλλ ερχεται ωρα οτε ουκετι εν παροιμιαις λαλησω υμιν αλλα παρρησια περι του πατρος αναγγελω υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.26",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 26,
      "referenceLabel": "John 16:26",
      "text": "εν εκεινη τη ημερα εν τω ονοματι μου αιτησεσθε και ου λεγω υμιν οτι εγω ερωτησω τον πατερα περι υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.27",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 27,
      "referenceLabel": "John 16:27",
      "text": "αυτος γαρ ο πατηρ φιλει υμας οτι υμεις εμε πεφιληκατε και πεπιστευκατε οτι εγω παρα του θεου εξηλθον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.28",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 28,
      "referenceLabel": "John 16:28",
      "text": "εξηλθον παρα του πατρος και εληλυθα εις τον κοσμον παλιν αφιημι τον κοσμον και πορευομαι προς τον πατερα",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.29",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 29,
      "referenceLabel": "John 16:29",
      "text": "λεγουσιν αυτω οι μαθηται αυτου ιδε νυν παρρησια λαλεις και παροιμιαν ουδεμιαν λεγεις",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.30",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 30,
      "referenceLabel": "John 16:30",
      "text": "νυν οιδαμεν οτι οιδας παντα και ου χρειαν εχεις ινα τις σε ερωτα εν τουτω πιστευομεν οτι απο θεου εξηλθες",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.31",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 31,
      "referenceLabel": "John 16:31",
      "text": "απεκριθη αυτοις ο ιησους αρτι πιστευετε",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.32",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 32,
      "referenceLabel": "John 16:32",
      "text": "ιδου ερχεται ωρα και νυν εληλυθεν ινα σκορπισθητε εκαστος εις τα ιδια και εμε μονον αφητε και ουκ ειμι μονος οτι ο πατηρ μετ εμου εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.16.33",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 33,
      "referenceLabel": "John 16:33",
      "text": "ταυτα λελαληκα υμιν ινα εν εμοι ειρηνην εχητε εν τω κοσμω θλιψιν εχετε αλλα θαρσειτε εγω νενικηκα τον κοσμον",
      "paragraphStart": false
    }
  ]
}
