{
  "chapter": {
    "id": "byz:john.2",
    "translationId": "byz",
    "bookSlug": "john",
    "chapterNumber": 2,
    "referenceLabel": "John 2",
    "summary": "Source text for John 2 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:john.2.1",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "John 2:1",
      "text": "και τη ημερα τη τριτη γαμος εγενετο εν κανα της γαλιλαιας και ην η μητηρ του ιησου εκει",
      "paragraphStart": true
    },
    {
      "id": "byz:john.2.2",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "John 2:2",
      "text": "εκληθη δε και ο ιησους και οι μαθηται αυτου εις τον γαμον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.3",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "John 2:3",
      "text": "και υστερησαντος οινου λεγει η μητηρ του ιησου προς αυτον οινον ουκ εχουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.4",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "John 2:4",
      "text": "λεγει αυτη ο ιησους τι εμοι και σοι γυναι ουπω ηκει η ωρα μου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.5",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "John 2:5",
      "text": "λεγει η μητηρ αυτου τοις διακονοις ο τι αν λεγη υμιν ποιησατε",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.6",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "John 2:6",
      "text": "ησαν δε εκει υδριαι λιθιναι εξ κειμεναι κατα τον καθαρισμον των ιουδαιων χωρουσαι ανα μετρητας δυο η τρεις",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.7",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "John 2:7",
      "text": "λεγει αυτοις ο ιησους γεμισατε τας υδριας υδατος και εγεμισαν αυτας εως ανω",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.8",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "John 2:8",
      "text": "και λεγει αυτοις αντλησατε νυν και φερετε τω αρχιτρικλινω και ηνεγκαν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.9",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "John 2:9",
      "text": "ως δε εγευσατο ο αρχιτρικλινος το υδωρ οινον γεγενημενον και ουκ ηδει ποθεν εστιν οι δε διακονοι ηδεισαν οι ηντληκοτες το υδωρ φωνει τον νυμφιον ο αρχιτρικλινος",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.10",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "John 2:10",
      "text": "και λεγει αυτω πας ανθρωπος πρωτον τον καλον οινον τιθησιν και οταν μεθυσθωσιν τοτε τον ελασσω συ τετηρηκας τον καλον οινον εως αρτι",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.11",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "John 2:11",
      "text": "ταυτην εποιησεν την αρχην των σημειων ο ιησους εν κανα της γαλιλαιας και εφανερωσεν την δοξαν αυτου και επιστευσαν εις αυτον οι μαθηται αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.12",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "John 2:12",
      "text": "μετα τουτο κατεβη εις καπερναουμ αυτος και η μητηρ αυτου και οι αδελφοι αυτου και οι μαθηται αυτου και εκει εμειναν ου πολλας ημερας",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.13",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "John 2:13",
      "text": "και εγγυς ην το πασχα των ιουδαιων και ανεβη εις ιεροσολυμα ο ιησους",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.14",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "John 2:14",
      "text": "και ευρεν εν τω ιερω τους πωλουντας βοας και προβατα και περιστερας και τους κερματιστας καθημενους",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.15",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "John 2:15",
      "text": "και ποιησας φραγελλιον εκ σχοινιων παντας εξεβαλεν εκ του ιερου τα τε προβατα και τους βοας και των κολλυβιστων εξεχεεν το κερμα και τας τραπεζας ανεστρεψεν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.16",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "John 2:16",
      "text": "και τοις τας περιστερας πωλουσιν ειπεν αρατε ταυτα εντευθεν μη ποιειτε τον οικον του πατρος μου οικον εμποριου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.17",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "John 2:17",
      "text": "εμνησθησαν δε οι μαθηται αυτου οτι γεγραμμενον εστιν ο ζηλος του οικου σου καταφαγεται με",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.18",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "John 2:18",
      "text": "απεκριθησαν ουν οι ιουδαιοι και ειπον αυτω τι σημειον δεικνυεις ημιν οτι ταυτα ποιεις",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.19",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "John 2:19",
      "text": "απεκριθη ιησους και ειπεν αυτοις λυσατε τον ναον τουτον και εν τρισιν ημεραις εγερω αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.20",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "John 2:20",
      "text": "ειπον ουν οι ιουδαιοι τεσσαρακοντα και εξ ετεσιν ωκοδομηθη ο ναος ουτος και συ εν τρισιν ημεραις εγερεις αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.21",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "John 2:21",
      "text": "εκεινος δε ελεγεν περι του ναου του σωματος αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.22",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "John 2:22",
      "text": "οτε ουν ηγερθη εκ νεκρων εμνησθησαν οι μαθηται αυτου οτι τουτο ελεγεν και επιστευσαν τη γραφη και τω λογω ω ειπεν ο ιησους",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.23",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "John 2:23",
      "text": "ως δε ην εν τοις ιεροσολυμοις εν τω πασχα εν τη εορτη πολλοι επιστευσαν εις το ονομα αυτου θεωρουντες αυτου τα σημεια α εποιει",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.24",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "John 2:24",
      "text": "αυτος δε ο ιησους ουκ επιστευεν εαυτον αυτοις δια το αυτον γινωσκειν παντας",
      "paragraphStart": false
    },
    {
      "id": "byz:john.2.25",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "John 2:25",
      "text": "και οτι ου χρειαν ειχεν ινα τις μαρτυρηση περι του ανθρωπου αυτος γαρ εγινωσκεν τι ην εν τω ανθρωπω",
      "paragraphStart": false
    }
  ]
}
