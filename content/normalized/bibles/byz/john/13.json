{
  "chapter": {
    "id": "byz:john.13",
    "translationId": "byz",
    "bookSlug": "john",
    "chapterNumber": 13,
    "referenceLabel": "John 13",
    "summary": "Source text for John 13 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:john.13.1",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "John 13:1",
      "text": "προ δε της εορτης του πασχα ειδως ο ιησους οτι εληλυθεν αυτου η ωρα ινα μεταβη εκ του κοσμου τουτου προς τον πατερα αγαπησας τους ιδιους τους εν τω κοσμω εις τελος ηγαπησεν αυτους",
      "paragraphStart": true
    },
    {
      "id": "byz:john.13.2",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "John 13:2",
      "text": "και δειπνου γενομενου του διαβολου ηδη βεβληκοτος εις την καρδιαν ιουδα σιμωνος ισκαριωτου ινα αυτον παραδω",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.3",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "John 13:3",
      "text": "ειδως ο ιησους οτι παντα δεδωκεν αυτω ο πατηρ εις τας χειρας και οτι απο θεου εξηλθεν και προς τον θεον υπαγει",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.4",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "John 13:4",
      "text": "εγειρεται εκ του δειπνου και τιθησιν τα ιματια και λαβων λεντιον διεζωσεν εαυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.5",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "John 13:5",
      "text": "ειτα βαλλει υδωρ εις τον νιπτηρα και ηρξατο νιπτειν τους ποδας των μαθητων και εκμασσειν τω λεντιω ω ην διεζωσμενος",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.6",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "John 13:6",
      "text": "ερχεται ουν προς σιμωνα πετρον και λεγει αυτω εκεινος κυριε συ μου νιπτεις τους ποδας",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.7",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "John 13:7",
      "text": "απεκριθη ιησους και ειπεν αυτω ο εγω ποιω συ ουκ οιδας αρτι γνωση δε μετα ταυτα",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.8",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "John 13:8",
      "text": "λεγει αυτω πετρος ου μη νιψης τους ποδας μου εις τον αιωνα απεκριθη αυτω ο ιησους εαν μη νιψω σε ουκ εχεις μερος μετ εμου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.9",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "John 13:9",
      "text": "λεγει αυτω σιμων πετρος κυριε μη τους ποδας μου μονον αλλα και τας χειρας και την κεφαλην",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.10",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "John 13:10",
      "text": "λεγει αυτω ο ιησους ο λελουμενος ου χρειαν εχει η τους ποδας νιψασθαι αλλ εστιν καθαρος ολος και υμεις καθαροι εστε αλλ ουχι παντες",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.11",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "John 13:11",
      "text": "ηδει γαρ τον παραδιδοντα αυτον δια τουτο ειπεν ουχι παντες καθαροι εστε",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.12",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "John 13:12",
      "text": "οτε ουν ενιψεν τους ποδας αυτων και ελαβεν τα ιματια αυτου αναπεσων παλιν ειπεν αυτοις γινωσκετε τι πεποιηκα υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.13",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "John 13:13",
      "text": "υμεις φωνειτε με ο διδασκαλος και ο κυριος και καλως λεγετε ειμι γαρ",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.14",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "John 13:14",
      "text": "ει ουν εγω ενιψα υμων τους ποδας ο κυριος και ο διδασκαλος και υμεις οφειλετε αλληλων νιπτειν τους ποδας",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.15",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "John 13:15",
      "text": "υποδειγμα γαρ εδωκα υμιν ινα καθως εγω εποιησα υμιν και υμεις ποιητε",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.16",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "John 13:16",
      "text": "αμην αμην λεγω υμιν ουκ εστιν δουλος μειζων του κυριου αυτου ουδε αποστολος μειζων του πεμψαντος αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.17",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "John 13:17",
      "text": "ει ταυτα οιδατε μακαριοι εστε εαν ποιητε αυτα",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.18",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "John 13:18",
      "text": "ου περι παντων υμων λεγω εγω οιδα ους εξελεξαμην αλλ ινα η γραφη πληρωθη ο τρωγων μετ εμου τον αρτον επηρεν επ εμε την πτερναν αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.19",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "John 13:19",
      "text": "απ αρτι λεγω υμιν προ του γενεσθαι ινα οταν γενηται πιστευσητε οτι εγω ειμι",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.20",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "John 13:20",
      "text": "αμην αμην λεγω υμιν ο λαμβανων εαν τινα πεμψω εμε λαμβανει ο δε εμε λαμβανων λαμβανει τον πεμψαντα με",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.21",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "John 13:21",
      "text": "ταυτα ειπων ο ιησους εταραχθη τω πνευματι και εμαρτυρησεν και ειπεν αμην αμην λεγω υμιν οτι εις εξ υμων παραδωσει με",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.22",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "John 13:22",
      "text": "εβλεπον ουν εις αλληλους οι μαθηται απορουμενοι περι τινος λεγει",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.23",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "John 13:23",
      "text": "ην δε ανακειμενος εις των μαθητων αυτου εν τω κολπω του ιησου ον ηγαπα ο ιησους",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.24",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "John 13:24",
      "text": "νευει ουν τουτω σιμων πετρος πυθεσθαι τις αν ειη περι ου λεγει",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.25",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "John 13:25",
      "text": "επιπεσων δε εκεινος ουτως επι το στηθος του ιησου λεγει αυτω κυριε τις εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.26",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 26,
      "referenceLabel": "John 13:26",
      "text": "αποκρινεται ο ιησους εκεινος εστιν ω εγω βαψας το ψωμιον επιδωσω και εμβαψας το ψωμιον διδωσιν ιουδα σιμωνος ισκαριωτη",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.27",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 27,
      "referenceLabel": "John 13:27",
      "text": "και μετα το ψωμιον τοτε εισηλθεν εις εκεινον ο σατανας λεγει ουν αυτω ο ιησους ο ποιεις ποιησον ταχιον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.28",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 28,
      "referenceLabel": "John 13:28",
      "text": "τουτο δε ουδεις εγνω των ανακειμενων προς τι ειπεν αυτω",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.29",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 29,
      "referenceLabel": "John 13:29",
      "text": "τινες γαρ εδοκουν επει το γλωσσοκομον ειχεν ο ιουδας οτι λεγει αυτω ο ιησους αγορασον ων χρειαν εχομεν εις την εορτην η τοις πτωχοις ινα τι δω",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.30",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 30,
      "referenceLabel": "John 13:30",
      "text": "λαβων ουν το ψωμιον εκεινος ευθεως εξηλθεν ην δε νυξ",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.31",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 31,
      "referenceLabel": "John 13:31",
      "text": "οτε εξηλθεν λεγει ο ιησους νυν εδοξασθη ο υιος του ανθρωπου και ο θεος εδοξασθη εν αυτω",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.32",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 32,
      "referenceLabel": "John 13:32",
      "text": "ει ο θεος εδοξασθη εν αυτω και ο θεος δοξασει αυτον εν εαυτω και ευθυς δοξασει αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.33",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 33,
      "referenceLabel": "John 13:33",
      "text": "τεκνια ετι μικρον μεθ υμων ειμι ζητησετε με και καθως ειπον τοις ιουδαιοις οτι οπου υπαγω εγω υμεις ου δυνασθε ελθειν και υμιν λεγω αρτι",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.34",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 34,
      "referenceLabel": "John 13:34",
      "text": "εντολην καινην διδωμι υμιν ινα αγαπατε αλληλους καθως ηγαπησα υμας ινα και υμεις αγαπατε αλληλους",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.35",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 35,
      "referenceLabel": "John 13:35",
      "text": "εν τουτω γνωσονται παντες οτι εμοι μαθηται εστε εαν αγαπην εχητε εν αλληλοις",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.36",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 36,
      "referenceLabel": "John 13:36",
      "text": "λεγει αυτω σιμων πετρος κυριε που υπαγεις απεκριθη αυτω ο ιησους οπου υπαγω ου δυνασαι μοι νυν ακολουθησαι υστερον δε ακολουθησεις μοι",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.37",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 37,
      "referenceLabel": "John 13:37",
      "text": "λεγει αυτω πετρος κυριε δια τι ου δυναμαι σοι ακολουθησαι αρτι την ψυχην μου υπερ σου θησω",
      "paragraphStart": false
    },
    {
      "id": "byz:john.13.38",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 38,
      "referenceLabel": "John 13:38",
      "text": "απεκριθη αυτω ο ιησους την ψυχην σου υπερ εμου θησεις αμην αμην λεγω σοι ου μη αλεκτωρ φωνηση εως ου απαρνηση με τρις",
      "paragraphStart": false
    }
  ]
}
