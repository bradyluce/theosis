{
  "chapter": {
    "id": "byz:john.15",
    "translationId": "byz",
    "bookSlug": "john",
    "chapterNumber": 15,
    "referenceLabel": "John 15",
    "summary": "Source text for John 15 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:john.15.1",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "John 15:1",
      "text": "εγω ειμι η αμπελος η αληθινη και ο πατηρ μου ο γεωργος εστιν",
      "paragraphStart": true
    },
    {
      "id": "byz:john.15.2",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "John 15:2",
      "text": "παν κλημα εν εμοι μη φερον καρπον αιρει αυτο και παν το καρπον φερον καθαιρει αυτο ινα πλειονα καρπον φερη",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.3",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "John 15:3",
      "text": "ηδη υμεις καθαροι εστε δια τον λογον ον λελαληκα υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.4",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "John 15:4",
      "text": "μεινατε εν εμοι καγω εν υμιν καθως το κλημα ου δυναται καρπον φερειν αφ εαυτου εαν μη μεινη εν τη αμπελω ουτως ουδε υμεις εαν μη εν εμοι μεινητε",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.5",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "John 15:5",
      "text": "εγω ειμι η αμπελος υμεις τα κληματα ο μενων εν εμοι καγω εν αυτω ουτος φερει καρπον πολυν οτι χωρις εμου ου δυνασθε ποιειν ουδεν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.6",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "John 15:6",
      "text": "εαν μη τις μεινη εν εμοι εβληθη εξω ως το κλημα και εξηρανθη και συναγουσιν αυτα και εις το πυρ βαλλουσιν και καιεται",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.7",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "John 15:7",
      "text": "εαν μεινητε εν εμοι και τα ρηματα μου εν υμιν μεινη ο εαν θελητε αιτησεσθε και γενησεται υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.8",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "John 15:8",
      "text": "εν τουτω εδοξασθη ο πατηρ μου ινα καρπον πολυν φερητε και γενησεσθε εμοι μαθηται",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.9",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "John 15:9",
      "text": "καθως ηγαπησεν με ο πατηρ καγω ηγαπησα υμας μεινατε εν τη αγαπη τη εμη",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.10",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "John 15:10",
      "text": "εαν τας εντολας μου τηρησητε μενειτε εν τη αγαπη μου καθως εγω τας εντολας του πατρος μου τετηρηκα και μενω αυτου εν τη αγαπη",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.11",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "John 15:11",
      "text": "ταυτα λελαληκα υμιν ινα η χαρα η εμη εν υμιν μεινη και η χαρα υμων πληρωθη",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.12",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "John 15:12",
      "text": "αυτη εστιν η εντολη η εμη ινα αγαπατε αλληλους καθως ηγαπησα υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.13",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "John 15:13",
      "text": "μειζονα ταυτης αγαπην ουδεις εχει ινα τις την ψυχην αυτου θη υπερ των φιλων αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.14",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "John 15:14",
      "text": "υμεις φιλοι μου εστε εαν ποιητε οσα εγω εντελλομαι υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.15",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "John 15:15",
      "text": "ουκετι υμας λεγω δουλους οτι ο δουλος ουκ οιδεν τι ποιει αυτου ο κυριος υμας δε ειρηκα φιλους οτι παντα α ηκουσα παρα του πατρος μου εγνωρισα υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.16",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "John 15:16",
      "text": "ουχ υμεις με εξελεξασθε αλλ εγω εξελεξαμην υμας και εθηκα υμας ινα υμεις υπαγητε και καρπον φερητε και ο καρπος υμων μενη ινα ο τι αν αιτησητε τον πατερα εν τω ονοματι μου δω υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.17",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "John 15:17",
      "text": "ταυτα εντελλομαι υμιν ινα αγαπατε αλληλους",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.18",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "John 15:18",
      "text": "ει ο κοσμος υμας μισει γινωσκετε οτι εμε πρωτον υμων μεμισηκεν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.19",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "John 15:19",
      "text": "ει εκ του κοσμου ητε ο κοσμος αν το ιδιον εφιλει οτι δε εκ του κοσμου ουκ εστε αλλ εγω εξελεξαμην υμας εκ του κοσμου δια τουτο μισει υμας ο κοσμος",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.20",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "John 15:20",
      "text": "μνημονευετε του λογου ου εγω ειπον υμιν ουκ εστιν δουλος μειζων του κυριου αυτου ει εμε εδιωξαν και υμας διωξουσιν ει τον λογον μου ετηρησαν και τον υμετερον τηρησουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.21",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "John 15:21",
      "text": "αλλα ταυτα παντα ποιησουσιν υμιν δια το ονομα μου οτι ουκ οιδασιν τον πεμψαντα με",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.22",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "John 15:22",
      "text": "ει μη ηλθον και ελαλησα αυτοις αμαρτιαν ουκ ειχον νυν δε προφασιν ουκ εχουσιν περι της αμαρτιας αυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.23",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "John 15:23",
      "text": "ο εμε μισων και τον πατερα μου μισει",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.24",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "John 15:24",
      "text": "ει τα εργα μη εποιησα εν αυτοις α ουδεις αλλος πεποιηκεν αμαρτιαν ουκ ειχον νυν δε και εωρακασιν και μεμισηκασιν και εμε και τον πατερα μου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.25",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "John 15:25",
      "text": "αλλ ινα πληρωθη ο λογος ο γεγραμμενος εν τω νομω αυτων οτι εμισησαν με δωρεαν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.26",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "John 15:26",
      "text": "οταν δε ελθη ο παρακλητος ον εγω πεμψω υμιν παρα του πατρος το πνευμα της αληθειας ο παρα του πατρος εκπορευεται εκεινος μαρτυρησει περι εμου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.15.27",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "John 15:27",
      "text": "και υμεις δε μαρτυρειτε οτι απ αρχης μετ εμου εστε",
      "paragraphStart": false
    }
  ]
}
