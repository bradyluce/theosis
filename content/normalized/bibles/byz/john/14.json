{
  "chapter": {
    "id": "byz:john.14",
    "translationId": "byz",
    "bookSlug": "john",
    "chapterNumber": 14,
    "referenceLabel": "John 14",
    "summary": "Source text for John 14 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:john.14.1",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "John 14:1",
      "text": "μη ταρασσεσθω υμων η καρδια πιστευετε εις τον θεον και εις εμε πιστευετε",
      "paragraphStart": true
    },
    {
      "id": "byz:john.14.2",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "John 14:2",
      "text": "εν τη οικια του πατρος μου μοναι πολλαι εισιν ει δε μη ειπον αν υμιν πορευομαι ετοιμασαι τοπον υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.3",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "John 14:3",
      "text": "και εαν πορευθω ετοιμασω υμιν τοπον παλιν ερχομαι και παραληψομαι υμας προς εμαυτον ινα οπου ειμι εγω και υμεις ητε",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.4",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "John 14:4",
      "text": "και οπου εγω υπαγω οιδατε και την οδον οιδατε",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.5",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "John 14:5",
      "text": "λεγει αυτω θωμας κυριε ουκ οιδαμεν που υπαγεις και πως δυναμεθα την οδον ειδεναι",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.6",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "John 14:6",
      "text": "λεγει αυτω ο ιησους εγω ειμι η οδος και η αληθεια και η ζωη ουδεις ερχεται προς τον πατερα ει μη δι εμου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.7",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "John 14:7",
      "text": "ει εγνωκειτε με και τον πατερα μου εγνωκειτε αν και απ αρτι γινωσκετε αυτον και εωρακατε αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.8",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "John 14:8",
      "text": "λεγει αυτω φιλιππος κυριε δειξον ημιν τον πατερα και αρκει ημιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.9",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "John 14:9",
      "text": "λεγει αυτω ο ιησους τοσουτον χρονον μεθ υμων ειμι και ουκ εγνωκας με φιλιππε ο εωρακως εμε εωρακεν τον πατερα και πως συ λεγεις δειξον ημιν τον πατερα",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.10",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "John 14:10",
      "text": "ου πιστευεις οτι εγω εν τω πατρι και ο πατηρ εν εμοι εστιν τα ρηματα α εγω λαλω υμιν απ εμαυτου ου λαλω ο δε πατηρ ο εν εμοι μενων αυτος ποιει τα εργα",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.11",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "John 14:11",
      "text": "πιστευετε μοι οτι εγω εν τω πατρι και ο πατηρ εν εμοι ει δε μη δια τα εργα αυτα πιστευετε μοι",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.12",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "John 14:12",
      "text": "αμην αμην λεγω υμιν ο πιστευων εις εμε τα εργα α εγω ποιω κακεινος ποιησει και μειζονα τουτων ποιησει οτι εγω προς τον πατερα μου πορευομαι",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.13",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "John 14:13",
      "text": "και ο τι αν αιτησητε εν τω ονοματι μου τουτο ποιησω ινα δοξασθη ο πατηρ εν τω υιω",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.14",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "John 14:14",
      "text": "εαν τι αιτησητε με εν τω ονοματι μου εγω ποιησω",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.15",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "John 14:15",
      "text": "εαν αγαπατε με τας εντολας τας εμας τηρησατε",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.16",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "John 14:16",
      "text": "και εγω ερωτησω τον πατερα και αλλον παρακλητον δωσει υμιν ινα μενη μεθ υμων εις τον αιωνα",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.17",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "John 14:17",
      "text": "το πνευμα της αληθειας ο ο κοσμος ου δυναται λαβειν οτι ου θεωρει αυτο ουδε γινωσκει αυτο υμεις δε γινωσκετε αυτο οτι παρ υμιν μενει και εν υμιν εσται",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.18",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "John 14:18",
      "text": "ουκ αφησω υμας ορφανους ερχομαι προς υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.19",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "John 14:19",
      "text": "ετι μικρον και ο κοσμος με ουκετι θεωρει υμεις δε θεωρειτε με οτι εγω ζω και υμεις ζησεσθε",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.20",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "John 14:20",
      "text": "εν εκεινη τη ημερα γνωσεσθε υμεις οτι εγω εν τω πατρι μου και υμεις εν εμοι και εγω εν υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.21",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "John 14:21",
      "text": "ο εχων τας εντολας μου και τηρων αυτας εκεινος εστιν ο αγαπων με ο δε αγαπων με αγαπηθησεται υπο του πατρος μου και εγω αγαπησω αυτον και εμφανισω αυτω εμαυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.22",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "John 14:22",
      "text": "λεγει αυτω ιουδας ουχ ο ισκαριωτης κυριε και τι γεγονεν οτι ημιν μελλεις εμφανιζειν σεαυτον και ουχι τω κοσμω",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.23",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "John 14:23",
      "text": "απεκριθη ιησους και ειπεν αυτω εαν τις αγαπα με τον λογον μου τηρησει και ο πατηρ μου αγαπησει αυτον και προς αυτον ελευσομεθα και μονην παρ αυτω ποιησομεν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.24",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "John 14:24",
      "text": "ο μη αγαπων με τους λογους μου ου τηρει και ο λογος ον ακουετε ουκ εστιν εμος αλλα του πεμψαντος με πατρος",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.25",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "John 14:25",
      "text": "ταυτα λελαληκα υμιν παρ υμιν μενων",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.26",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "John 14:26",
      "text": "ο δε παρακλητος το πνευμα το αγιον ο πεμψει ο πατηρ εν τω ονοματι μου εκεινος υμας διδαξει παντα και υπομνησει υμας παντα α ειπον υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.27",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "John 14:27",
      "text": "ειρηνην αφιημι υμιν ειρηνην την εμην διδωμι υμιν ου καθως ο κοσμος διδωσιν εγω διδωμι υμιν μη ταρασσεσθω υμων η καρδια μηδε δειλιατω",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.28",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "John 14:28",
      "text": "ηκουσατε οτι εγω ειπον υμιν υπαγω και ερχομαι προς υμας ει ηγαπατε με εχαρητε αν οτι ειπον πορευομαι προς τον πατερα οτι ο πατηρ μου μειζων μου εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.29",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "John 14:29",
      "text": "και νυν ειρηκα υμιν πριν γενεσθαι ινα οταν γενηται πιστευσητε",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.30",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "John 14:30",
      "text": "ουκετι πολλα λαλησω μεθ υμων ερχεται γαρ ο του κοσμου αρχων και εν εμοι ουκ εχει ουδεν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.14.31",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "John 14:31",
      "text": "αλλ ινα γνω ο κοσμος οτι αγαπω τον πατερα και καθως ενετειλατο μοι ο πατηρ ουτως ποιω εγειρεσθε αγωμεν εντευθεν",
      "paragraphStart": false
    }
  ]
}
