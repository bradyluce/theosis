{
  "chapter": {
    "id": "byz:john.4",
    "translationId": "byz",
    "bookSlug": "john",
    "chapterNumber": 4,
    "referenceLabel": "John 4",
    "summary": "Source text for John 4 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:john.4.1",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "John 4:1",
      "text": "ως ουν εγνω ο κυριος οτι ηκουσαν οι φαρισαιοι οτι ιησους πλειονας μαθητας ποιει και βαπτιζει η ιωαννης",
      "paragraphStart": true
    },
    {
      "id": "byz:john.4.2",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "John 4:2",
      "text": "καιτοιγε ιησους αυτος ουκ εβαπτιζεν αλλ οι μαθηται αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.3",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "John 4:3",
      "text": "αφηκεν την ιουδαιαν και απηλθεν εις την γαλιλαιαν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.4",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "John 4:4",
      "text": "εδει δε αυτον διερχεσθαι δια της σαμαρειας",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.5",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "John 4:5",
      "text": "ερχεται ουν εις πολιν της σαμαρειας λεγομενην συχαρ πλησιον του χωριου ο εδωκεν ιακωβ ιωσηφ τω υιω αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.6",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "John 4:6",
      "text": "ην δε εκει πηγη του ιακωβ ο ουν ιησους κεκοπιακως εκ της οδοιποριας εκαθεζετο ουτως επι τη πηγη ωρα ην ωσει εκτη",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.7",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "John 4:7",
      "text": "ερχεται γυνη εκ της σαμαρειας αντλησαι υδωρ λεγει αυτη ο ιησους δος μοι πιειν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.8",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "John 4:8",
      "text": "οι γαρ μαθηται αυτου απεληλυθεισαν εις την πολιν ινα τροφας αγορασωσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.9",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "John 4:9",
      "text": "λεγει ουν αυτω η γυνη η σαμαρειτις πως συ ιουδαιος ων παρ εμου πιειν αιτεις ουσης γυναικος σαμαρειτιδος ου γαρ συγχρωνται ιουδαιοι σαμαρειταις",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.10",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "John 4:10",
      "text": "απεκριθη ιησους και ειπεν αυτη ει ηδεις την δωρεαν του θεου και τις εστιν ο λεγων σοι δος μοι πιειν συ αν ητησας αυτον και εδωκεν αν σοι υδωρ ζων",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.11",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "John 4:11",
      "text": "λεγει αυτω η γυνη κυριε ουτε αντλημα εχεις και το φρεαρ εστιν βαθυ ποθεν ουν εχεις το υδωρ το ζων",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.12",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "John 4:12",
      "text": "μη συ μειζων ει του πατρος ημων ιακωβ ος εδωκεν ημιν το φρεαρ και αυτος εξ αυτου επιεν και οι υιοι αυτου και τα θρεμματα αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.13",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "John 4:13",
      "text": "απεκριθη ιησους και ειπεν αυτη πας ο πινων εκ του υδατος τουτου διψησει παλιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.14",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "John 4:14",
      "text": "ος δ αν πιη εκ του υδατος ου εγω δωσω αυτω ου μη διψηση εις τον αιωνα αλλα το υδωρ ο δωσω αυτω γενησεται εν αυτω πηγη υδατος αλλομενου εις ζωην αιωνιον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.15",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "John 4:15",
      "text": "λεγει προς αυτον η γυνη κυριε δος μοι τουτο το υδωρ ινα μη διψω μηδε ερχομαι ενθαδε αντλειν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.16",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "John 4:16",
      "text": "λεγει αυτη ο ιησους υπαγε φωνησον τον ανδρα σου και ελθε ενθαδε",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.17",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "John 4:17",
      "text": "απεκριθη η γυνη και ειπεν ουκ εχω ανδρα λεγει αυτη ο ιησους καλως ειπας οτι ανδρα ουκ εχω",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.18",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "John 4:18",
      "text": "πεντε γαρ ανδρας εσχες και νυν ον εχεις ουκ εστιν σου ανηρ τουτο αληθες ειρηκας",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.19",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "John 4:19",
      "text": "λεγει αυτω η γυνη κυριε θεωρω οτι προφητης ει συ",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.20",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "John 4:20",
      "text": "οι πατερες ημων εν τω ορει τουτω προσεκυνησαν και υμεις λεγετε οτι εν ιεροσολυμοις εστιν ο τοπος οπου δει προσκυνειν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.21",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "John 4:21",
      "text": "λεγει αυτη ο ιησους γυναι πιστευσον μοι οτι ερχεται ωρα οτε ουτε εν τω ορει τουτω ουτε εν ιεροσολυμοις προσκυνησετε τω πατρι",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.22",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "John 4:22",
      "text": "υμεις προσκυνειτε ο ουκ οιδατε ημεις προσκυνουμεν ο οιδαμεν οτι η σωτηρια εκ των ιουδαιων εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.23",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "John 4:23",
      "text": "αλλ ερχεται ωρα και νυν εστιν οτε οι αληθινοι προσκυνηται προσκυνησουσιν τω πατρι εν πνευματι και αληθεια και γαρ ο πατηρ τοιουτους ζητει τους προσκυνουντας αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.24",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "John 4:24",
      "text": "πνευμα ο θεος και τους προσκυνουντας αυτον εν πνευματι και αληθεια δει προσκυνειν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.25",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "John 4:25",
      "text": "λεγει αυτω η γυνη οιδα οτι μεσιας ερχεται ο λεγομενος χριστος οταν ελθη εκεινος αναγγελει ημιν παντα",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.26",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "John 4:26",
      "text": "λεγει αυτη ο ιησους εγω ειμι ο λαλων σοι",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.27",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "John 4:27",
      "text": "και επι τουτω ηλθον οι μαθηται αυτου και εθαυμασαν οτι μετα γυναικος ελαλει ουδεις μεντοι ειπεν τι ζητεις η τι λαλεις μετ αυτης",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.28",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "John 4:28",
      "text": "αφηκεν ουν την υδριαν αυτης η γυνη και απηλθεν εις την πολιν και λεγει τοις ανθρωποις",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.29",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "John 4:29",
      "text": "δευτε ιδετε ανθρωπον ος ειπεν μοι παντα οσα εποιησα μητι ουτος εστιν ο χριστος",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.30",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "John 4:30",
      "text": "εξηλθον εκ της πολεως και ηρχοντο προς αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.31",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "John 4:31",
      "text": "εν δε τω μεταξυ ηρωτων αυτον οι μαθηται λεγοντες ραββι φαγε",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.32",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 32,
      "referenceLabel": "John 4:32",
      "text": "ο δε ειπεν αυτοις εγω βρωσιν εχω φαγειν ην υμεις ουκ οιδατε",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.33",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 33,
      "referenceLabel": "John 4:33",
      "text": "ελεγον ουν οι μαθηται προς αλληλους μη τις ηνεγκεν αυτω φαγειν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.34",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 34,
      "referenceLabel": "John 4:34",
      "text": "λεγει αυτοις ο ιησους εμον βρωμα εστιν ινα ποιω το θελημα του πεμψαντος με και τελειωσω αυτου το εργον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.35",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 35,
      "referenceLabel": "John 4:35",
      "text": "ουχ υμεις λεγετε οτι ετι τετραμηνος εστιν και ο θερισμος ερχεται ιδου λεγω υμιν επαρατε τους οφθαλμους υμων και θεασασθε τας χωρας οτι λευκαι εισιν προς θερισμον ηδη",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.36",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 36,
      "referenceLabel": "John 4:36",
      "text": "και ο θεριζων μισθον λαμβανει και συναγει καρπον εις ζωην αιωνιον ινα και ο σπειρων ομου χαιρη και ο θεριζων",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.37",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 37,
      "referenceLabel": "John 4:37",
      "text": "εν γαρ τουτω ο λογος εστιν ο αληθινος οτι αλλος εστιν ο σπειρων και αλλος ο θεριζων",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.38",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 38,
      "referenceLabel": "John 4:38",
      "text": "εγω απεστειλα υμας θεριζειν ο ουχ υμεις κεκοπιακατε αλλοι κεκοπιακασιν και υμεις εις τον κοπον αυτων εισεληλυθατε",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.39",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 39,
      "referenceLabel": "John 4:39",
      "text": "εκ δε της πολεως εκεινης πολλοι επιστευσαν εις αυτον των σαμαρειτων δια τον λογον της γυναικος μαρτυρουσης οτι ειπεν μοι παντα οσα εποιησα",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.40",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 40,
      "referenceLabel": "John 4:40",
      "text": "ως ουν ηλθον προς αυτον οι σαμαρειται ηρωτων αυτον μειναι παρ αυτοις και εμεινεν εκει δυο ημερας",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.41",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 41,
      "referenceLabel": "John 4:41",
      "text": "και πολλω πλειους επιστευσαν δια τον λογον αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.42",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 42,
      "referenceLabel": "John 4:42",
      "text": "τη τε γυναικι ελεγον οτι ουκετι δια την σην λαλιαν πιστευομεν αυτοι γαρ ακηκοαμεν και οιδαμεν οτι ουτος εστιν αληθως ο σωτηρ του κοσμου ο χριστος",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.43",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 43,
      "referenceLabel": "John 4:43",
      "text": "μετα δε τας δυο ημερας εξηλθεν εκειθεν και απηλθεν εις την γαλιλαιαν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.44",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 44,
      "referenceLabel": "John 4:44",
      "text": "αυτος γαρ ο ιησους εμαρτυρησεν οτι προφητης εν τη ιδια πατριδι τιμην ουκ εχει",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.45",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 45,
      "referenceLabel": "John 4:45",
      "text": "οτε ουν ηλθεν εις την γαλιλαιαν εδεξαντο αυτον οι γαλιλαιοι παντα εωρακοτες α εποιησεν εν ιεροσολυμοις εν τη εορτη και αυτοι γαρ ηλθον εις την εορτην",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.46",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 46,
      "referenceLabel": "John 4:46",
      "text": "ηλθεν ουν παλιν ο ιησους εις την κανα της γαλιλαιας οπου εποιησεν το υδωρ οινον και ην τις βασιλικος ου ο υιος ησθενει εν καπερναουμ",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.47",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 47,
      "referenceLabel": "John 4:47",
      "text": "ουτος ακουσας οτι ιησους ηκει εκ της ιουδαιας εις την γαλιλαιαν απηλθεν προς αυτον και ηρωτα αυτον ινα καταβη και ιασηται αυτου τον υιον εμελλεν γαρ αποθνησκειν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.48",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 48,
      "referenceLabel": "John 4:48",
      "text": "ειπεν ουν ο ιησους προς αυτον εαν μη σημεια και τερατα ιδητε ου μη πιστευσητε",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.49",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 49,
      "referenceLabel": "John 4:49",
      "text": "λεγει προς αυτον ο βασιλικος κυριε καταβηθι πριν αποθανειν το παιδιον μου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.50",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 50,
      "referenceLabel": "John 4:50",
      "text": "λεγει αυτω ο ιησους πορευου ο υιος σου ζη και επιστευσεν ο ανθρωπος τω λογω ω ειπεν αυτω ο ιησους και επορευετο",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.51",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 51,
      "referenceLabel": "John 4:51",
      "text": "ηδη δε αυτου καταβαινοντος οι δουλοι αυτου απηντησαν αυτω και απηγγειλαν λεγοντες οτι ο παις σου ζη",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.52",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 52,
      "referenceLabel": "John 4:52",
      "text": "επυθετο ουν παρ αυτων την ωραν εν η κομψοτερον εσχεν και ειπον αυτω οτι χθες ωραν εβδομην αφηκεν αυτον ο πυρετος",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.53",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 53,
      "referenceLabel": "John 4:53",
      "text": "εγνω ουν ο πατηρ οτι εν εκεινη τη ωρα εν η ειπεν αυτω ο ιησους οτι ο υιος σου ζη και επιστευσεν αυτος και η οικια αυτου ολη",
      "paragraphStart": false
    },
    {
      "id": "byz:john.4.54",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 54,
      "referenceLabel": "John 4:54",
