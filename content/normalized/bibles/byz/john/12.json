{
  "chapter": {
    "id": "byz:john.12",
    "translationId": "byz",
    "bookSlug": "john",
    "chapterNumber": 12,
    "referenceLabel": "John 12",
    "summary": "Source text for John 12 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:john.12.1",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "John 12:1",
      "text": "ο ουν ιησους προ εξ ημερων του πασχα ηλθεν εις βηθανιαν οπου ην λαζαρος ο τεθνηκως ον ηγειρεν εκ νεκρων",
      "paragraphStart": true
    },
    {
      "id": "byz:john.12.2",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "John 12:2",
      "text": "εποιησαν ουν αυτω δειπνον εκει και η μαρθα διηκονει ο δε λαζαρος εις ην των ανακειμενων συν αυτω",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.3",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "John 12:3",
      "text": "η ουν μαρια λαβουσα λιτραν μυρου ναρδου πιστικης πολυτιμου ηλειψεν τους ποδας του ιησου και εξεμαξεν ταις θριξιν αυτης τους ποδας αυτου η δε οικια επληρωθη εκ της οσμης του μυρου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.4",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "John 12:4",
      "text": "λεγει ουν εις εκ των μαθητων αυτου ιουδας σιμωνος ισκαριωτης ο μελλων αυτον παραδιδοναι",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.5",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "John 12:5",
      "text": "δια τι τουτο το μυρον ουκ επραθη τριακοσιων δηναριων και εδοθη πτωχοις",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.6",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "John 12:6",
      "text": "ειπεν δε τουτο ουχ οτι περι των πτωχων εμελεν αυτω αλλ οτι κλεπτης ην και το γλωσσοκομον ειχεν και τα βαλλομενα εβασταζεν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.7",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "John 12:7",
      "text": "ειπεν ουν ο ιησους αφες αυτην εις την ημεραν του ενταφιασμου μου τετηρηκεν αυτο",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.8",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "John 12:8",
      "text": "τους πτωχους γαρ παντοτε εχετε μεθ εαυτων εμε δε ου παντοτε εχετε",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.9",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "John 12:9",
      "text": "εγνω ουν οχλος πολυς εκ των ιουδαιων οτι εκει εστιν και ηλθον ου δια τον ιησουν μονον αλλ ινα και τον λαζαρον ιδωσιν ον ηγειρεν εκ νεκρων",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.10",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "John 12:10",
      "text": "εβουλευσαντο δε οι αρχιερεις ινα και τον λαζαρον αποκτεινωσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.11",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "John 12:11",
      "text": "οτι πολλοι δι αυτον υπηγον των ιουδαιων και επιστευον εις τον ιησουν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.12",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "John 12:12",
      "text": "τη επαυριον οχλος πολυς ο ελθων εις την εορτην ακουσαντες οτι ερχεται ιησους εις ιεροσολυμα",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.13",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "John 12:13",
      "text": "ελαβον τα βαια των φοινικων και εξηλθον εις υπαντησιν αυτω και εκραζον ωσαννα ευλογημενος ο ερχομενος εν ονοματι κυριου βασιλευς του ισραηλ",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.14",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "John 12:14",
      "text": "ευρων δε ο ιησους οναριον εκαθισεν επ αυτο καθως εστιν γεγραμμενον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.15",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "John 12:15",
      "text": "μη φοβου θυγατερ σιων ιδου ο βασιλευς σου ερχεται καθημενος επι πωλον ονου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.16",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "John 12:16",
      "text": "ταυτα δε ουκ εγνωσαν οι μαθηται αυτου το πρωτον αλλ οτε εδοξασθη ιησους τοτε εμνησθησαν οτι ταυτα ην επ αυτω γεγραμμενα και ταυτα εποιησαν αυτω",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.17",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "John 12:17",
      "text": "εμαρτυρει ουν ο οχλος ο ων μετ αυτου οτε τον λαζαρον εφωνησεν εκ του μνημειου και ηγειρεν αυτον εκ νεκρων",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.18",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "John 12:18",
      "text": "δια τουτο και υπηντησεν αυτω ο οχλος οτι ηκουσεν τουτο αυτον πεποιηκεναι το σημειον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.19",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "John 12:19",
      "text": "οι ουν φαρισαιοι ειπον προς εαυτους θεωρειτε οτι ουκ ωφελειτε ουδεν ιδε ο κοσμος οπισω αυτου απηλθεν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.20",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "John 12:20",
      "text": "ησαν δε τινες ελληνες εκ των αναβαινοντων ινα προσκυνησωσιν εν τη εορτη",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.21",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "John 12:21",
      "text": "ουτοι ουν προσηλθον φιλιππω τω απο βηθσαιδα της γαλιλαιας και ηρωτων αυτον λεγοντες κυριε θελομεν τον ιησουν ιδειν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.22",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "John 12:22",
      "text": "ερχεται φιλιππος και λεγει τω ανδρεα και παλιν ανδρεας και φιλιππος λεγουσιν τω ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.23",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "John 12:23",
      "text": "ο δε ιησους απεκρινατο αυτοις λεγων εληλυθεν η ωρα ινα δοξασθη ο υιος του ανθρωπου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.24",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "John 12:24",
      "text": "αμην αμην λεγω υμιν εαν μη ο κοκκος του σιτου πεσων εις την γην αποθανη αυτος μονος μενει εαν δε αποθανη πολυν καρπον φερει",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.25",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "John 12:25",
      "text": "ο φιλων την ψυχην αυτου απολεσει αυτην και ο μισων την ψυχην αυτου εν τω κοσμω τουτω εις ζωην αιωνιον φυλαξει αυτην",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.26",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "John 12:26",
      "text": "εαν εμοι διακονη τις εμοι ακολουθειτω και οπου ειμι εγω εκει και ο διακονος ο εμος εσται και εαν τις εμοι διακονη τιμησει αυτον ο πατηρ",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.27",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "John 12:27",
      "text": "νυν η ψυχη μου τεταρακται και τι ειπω πατερ σωσον με εκ της ωρας ταυτης αλλα δια τουτο ηλθον εις την ωραν ταυτην",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.28",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "John 12:28",
      "text": "πατερ δοξασον σου το ονομα ηλθεν ουν φωνη εκ του ουρανου και εδοξασα και παλιν δοξασω",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.29",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 29,
      "referenceLabel": "John 12:29",
      "text": "ο ουν οχλος ο εστως και ακουσας ελεγεν βροντην γεγονεναι αλλοι ελεγον αγγελος αυτω λελαληκεν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.30",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 30,
      "referenceLabel": "John 12:30",
      "text": "απεκριθη ιησους και ειπεν ου δι εμε αυτη η φωνη γεγονεν αλλα δι υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.31",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 31,
      "referenceLabel": "John 12:31",
      "text": "νυν κρισις εστιν του κοσμου τουτου νυν ο αρχων του κοσμου τουτου εκβληθησεται εξω",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.32",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 32,
      "referenceLabel": "John 12:32",
      "text": "καγω εαν υψωθω εκ της γης παντας ελκυσω προς εμαυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.33",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 33,
      "referenceLabel": "John 12:33",
      "text": "τουτο δε ελεγεν σημαινων ποιω θανατω εμελλεν αποθνησκειν",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.34",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 34,
      "referenceLabel": "John 12:34",
      "text": "απεκριθη αυτω ο οχλος ημεις ηκουσαμεν εκ του νομου οτι ο χριστος μενει εις τον αιωνα και πως συ λεγεις δει υψωθηναι τον υιον του ανθρωπου τις εστιν ουτος ο υιος του ανθρωπου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.35",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 35,
      "referenceLabel": "John 12:35",
      "text": "ειπεν ουν αυτοις ο ιησους ετι μικρον χρονον το φως μεθ υμων εστιν περιπατειτε εως το φως εχετε ινα μη σκοτια υμας καταλαβη και ο περιπατων εν τη σκοτια ουκ οιδεν που υπαγει",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.36",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 36,
      "referenceLabel": "John 12:36",
      "text": "εως το φως εχετε πιστευετε εις το φως ινα υιοι φωτος γενησθε ταυτα ελαλησεν ο ιησους και απελθων εκρυβη απ αυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.37",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 37,
      "referenceLabel": "John 12:37",
      "text": "τοσαυτα δε αυτου σημεια πεποιηκοτος εμπροσθεν αυτων ουκ επιστευον εις αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.38",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 38,
      "referenceLabel": "John 12:38",
      "text": "ινα ο λογος ησαιου του προφητου πληρωθη ον ειπεν κυριε τις επιστευσεν τη ακοη ημων και ο βραχιων κυριου τινι απεκαλυφθη",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.39",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 39,
      "referenceLabel": "John 12:39",
      "text": "δια τουτο ουκ ηδυναντο πιστευειν οτι παλιν ειπεν ησαιας",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.40",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 40,
      "referenceLabel": "John 12:40",
      "text": "τετυφλωκεν αυτων τους οφθαλμους και πεπωρωκεν αυτων την καρδιαν ινα μη ιδωσιν τοις οφθαλμοις και νοησωσιν τη καρδια και επιστραφωσιν και ιασωμαι αυτους",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.41",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 41,
      "referenceLabel": "John 12:41",
      "text": "ταυτα ειπεν ησαιας οτε ειδεν την δοξαν αυτου και ελαλησεν περι αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.42",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 42,
      "referenceLabel": "John 12:42",
      "text": "ομως μεντοι και εκ των αρχοντων πολλοι επιστευσαν εις αυτον αλλα δια τους φαρισαιους ουχ ωμολογουν ινα μη αποσυναγωγοι γενωνται",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.43",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 43,
      "referenceLabel": "John 12:43",
      "text": "ηγαπησαν γαρ την δοξαν των ανθρωπων μαλλον ηπερ την δοξαν του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.44",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 44,
      "referenceLabel": "John 12:44",
      "text": "ιησους δε εκραξεν και ειπεν ο πιστευων εις εμε ου πιστευει εις εμε αλλ εις τον πεμψαντα με",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.45",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 45,
      "referenceLabel": "John 12:45",
      "text": "και ο θεωρων εμε θεωρει τον πεμψαντα με",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.46",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 46,
      "referenceLabel": "John 12:46",
      "text": "εγω φως εις τον κοσμον εληλυθα ινα πας ο πιστευων εις εμε εν τη σκοτια μη μεινη",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.47",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 47,
      "referenceLabel": "John 12:47",
      "text": "και εαν τις μου ακουση των ρηματων και μη πιστευση εγω ου κρινω αυτον ου γαρ ηλθον ινα κρινω τον κοσμον αλλ ινα σωσω τον κοσμον",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.48",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 48,
      "referenceLabel": "John 12:48",
      "text": "ο αθετων εμε και μη λαμβανων τα ρηματα μου εχει τον κρινοντα αυτον ο λογος ον ελαλησα εκεινος κρινει αυτον εν τη εσχατη ημερα",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.49",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 49,
      "referenceLabel": "John 12:49",
      "text": "οτι εγω εξ εμαυτου ουκ ελαλησα αλλ ο πεμψας με πατηρ αυτος μοι εντολην εδωκεν τι ειπω και τι λαλησω",
      "paragraphStart": false
    },
    {
      "id": "byz:john.12.50",
      "translationId": "byz",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 50,
      "referenceLabel": "John 12:50",
      "text": "και οιδα οτι η εντολη αυτου ζωη αιωνιος εστιν α ουν λαλω εγω καθως ειρηκεν μοι ο πατηρ ουτως λαλω",
      "paragraphStart": false
    }
  ]
}
