{
  "chapter": {
    "id": "byz:colossians.3",
    "translationId": "byz",
    "bookSlug": "colossians",
    "chapterNumber": 3,
    "referenceLabel": "Colossians 3",
    "summary": "Source text for Colossians 3 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:colossians.3.1",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Colossians 3:1",
      "text": "ει ουν συνηγερθητε τω χριστω τα ανω ζητειτε ου ο χριστος εστιν εν δεξια του θεου καθημενος",
      "paragraphStart": true
    },
    {
      "id": "byz:colossians.3.2",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Colossians 3:2",
      "text": "τα ανω φρονειτε μη τα επι της γης",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.3",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Colossians 3:3",
      "text": "απεθανετε γαρ και η ζωη υμων κεκρυπται συν τω χριστω εν τω θεω",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.4",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Colossians 3:4",
      "text": "οταν ο χριστος φανερωθη η ζωη ημων τοτε και υμεις συν αυτω φανερωθησεσθε εν δοξη",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.5",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Colossians 3:5",
      "text": "νεκρωσατε ουν τα μελη υμων τα επι της γης πορνειαν ακαθαρσιαν παθος επιθυμιαν κακην και την πλεονεξιαν ητις εστιν ειδωλολατρεια",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.6",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Colossians 3:6",
      "text": "δι α ερχεται η οργη του θεου επι τους υιους της απειθειας",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.7",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Colossians 3:7",
      "text": "εν οις και υμεις περιεπατησατε ποτε οτε εζητε εν αυτοις",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.8",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Colossians 3:8",
      "text": "νυνι δε αποθεσθε και υμεις τα παντα οργην θυμον κακιαν βλασφημιαν αισχρολογιαν εκ του στοματος υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.9",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Colossians 3:9",
      "text": "μη ψευδεσθε εις αλληλους απεκδυσαμενοι τον παλαιον ανθρωπον συν ταις πραξεσιν αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.10",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Colossians 3:10",
      "text": "και ενδυσαμενοι τον νεον τον ανακαινουμενον εις επιγνωσιν κατ εικονα του κτισαντος αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.11",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Colossians 3:11",
      "text": "οπου ουκ ενι ελλην και ιουδαιος περιτομη και ακροβυστια βαρβαρος σκυθης δουλος ελευθερος αλλα τα παντα και εν πασιν χριστος",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.12",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Colossians 3:12",
      "text": "ενδυσασθε ουν ως εκλεκτοι του θεου αγιοι και ηγαπημενοι σπλαγχνα οικτιρμου χρηστοτητα ταπεινοφροσυνην πραοτητα μακροθυμιαν",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.13",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Colossians 3:13",
      "text": "ανεχομενοι αλληλων και χαριζομενοι εαυτοις εαν τις προς τινα εχη μομφην καθως και ο χριστος εχαρισατο υμιν ουτως και υμεις",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.14",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Colossians 3:14",
      "text": "επι πασιν δε τουτοις την αγαπην ητις εστιν συνδεσμος της τελειοτητος",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.15",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Colossians 3:15",
      "text": "και η ειρηνη του θεου βραβευετω εν ταις καρδιαις υμων εις ην και εκληθητε εν ενι σωματι και ευχαριστοι γινεσθε",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.16",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Colossians 3:16",
      "text": "ο λογος του χριστου ενοικειτω εν υμιν πλουσιως εν παση σοφια διδασκοντες και νουθετουντες εαυτους ψαλμοις και υμνοις και ωδαις πνευματικαις εν χαριτι αδοντες εν τη καρδια υμων τω κυριω",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.17",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Colossians 3:17",
      "text": "και παν ο τι αν ποιητε εν λογω η εν εργω παντα εν ονοματι κυριου ιησου ευχαριστουντες τω θεω και πατρι δι αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.18",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Colossians 3:18",
      "text": "αι γυναικες υποτασσεσθε τοις ιδιοις ανδρασιν ως ανηκεν εν κυριω",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.19",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Colossians 3:19",
      "text": "οι ανδρες αγαπατε τας γυναικας και μη πικραινεσθε προς αυτας",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.20",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Colossians 3:20",
      "text": "τα τεκνα υπακουετε τοις γονευσιν κατα παντα τουτο γαρ εστιν ευαρεστον εν κυριω",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.21",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Colossians 3:21",
      "text": "οι πατερες μη ερεθιζετε τα τεκνα υμων ινα μη αθυμωσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.22",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Colossians 3:22",
      "text": "οι δουλοι υπακουετε κατα παντα τοις κατα σαρκα κυριοις μη εν οφθαλμοδουλειαις ως ανθρωπαρεσκοι αλλ εν απλοτητι καρδιας φοβουμενοι τον θεον",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.23",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Colossians 3:23",
      "text": "και παν ο τι εαν ποιητε εκ ψυχης εργαζεσθε ως τω κυριω και ουκ ανθρωποις",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.24",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Colossians 3:24",
      "text": "ειδοτες οτι απο κυριου ληψεσθε την ανταποδοσιν της κληρονομιας τω γαρ κυριω χριστω δουλευετε",
      "paragraphStart": false
    },
    {
      "id": "byz:colossians.3.25",
      "translationId": "byz",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Colossians 3:25",
      "text": "ο δε αδικων κομιειται ο ηδικησεν και ουκ εστιν προσωποληψια",
      "paragraphStart": false
    }
  ]
}
