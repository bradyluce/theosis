{
  "chapter": {
    "id": "byz:philippians.3",
    "translationId": "byz",
    "bookSlug": "philippians",
    "chapterNumber": 3,
    "referenceLabel": "Philippians 3",
    "summary": "Source text for Philippians 3 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:philippians.3.1",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Philippians 3:1",
      "text": "το λοιπον αδελφοι μου χαιρετε εν κυριω τα αυτα γραφειν υμιν εμοι μεν ουκ οκνηρον υμιν δε ασφαλες",
      "paragraphStart": true
    },
    {
      "id": "byz:philippians.3.2",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Philippians 3:2",
      "text": "βλεπετε τους κυνας βλεπετε τους κακους εργατας βλεπετε την κατατομην",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.3.3",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Philippians 3:3",
      "text": "ημεις γαρ εσμεν η περιτομη οι πνευματι θεου λατρευοντες και καυχωμενοι εν χριστω ιησου και ουκ εν σαρκι πεποιθοτες",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.3.4",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Philippians 3:4",
      "text": "καιπερ εγω εχων πεποιθησιν και εν σαρκι ει τις δοκει αλλος πεποιθεναι εν σαρκι εγω μαλλον",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.3.5",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Philippians 3:5",
      "text": "περιτομη οκταημερος εκ γενους ισραηλ φυλης βενιαμιν εβραιος εξ εβραιων κατα νομον φαρισαιος",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.3.6",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Philippians 3:6",
      "text": "κατα ζηλον διωκων την εκκλησιαν κατα δικαιοσυνην την εν νομω γενομενος αμεμπτος",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.3.7",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Philippians 3:7",
      "text": "αλλ ατινα ην μοι κερδη ταυτα ηγημαι δια τον χριστον ζημιαν",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.3.8",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Philippians 3:8",
      "text": "αλλα μεν ουν και ηγουμαι παντα ζημιαν ειναι δια το υπερεχον της γνωσεως χριστου ιησου του κυριου μου δι ον τα παντα εζημιωθην και ηγουμαι σκυβαλα ειναι ινα χριστον κερδησω",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.3.9",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Philippians 3:9",
      "text": "και ευρεθω εν αυτω μη εχων εμην δικαιοσυνην την εκ νομου αλλα την δια πιστεως χριστου την εκ θεου δικαιοσυνην επι τη πιστει",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.3.10",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Philippians 3:10",
      "text": "του γνωναι αυτον και την δυναμιν της αναστασεως αυτου και την κοινωνιαν των παθηματων αυτου συμμορφουμενος τω θανατω αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.3.11",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Philippians 3:11",
      "text": "ει πως καταντησω εις την εξαναστασιν των νεκρων",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.3.12",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Philippians 3:12",
      "text": "ουχ οτι ηδη ελαβον η ηδη τετελειωμαι διωκω δε ει και καταλαβω εφ ω και κατεληφθην υπο του χριστου ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.3.13",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Philippians 3:13",
      "text": "αδελφοι εγω εμαυτον ου λογιζομαι κατειληφεναι εν δε τα μεν οπισω επιλανθανομενος τοις δε εμπροσθεν επεκτεινομενος",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.3.14",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Philippians 3:14",
      "text": "κατα σκοπον διωκω επι το βραβειον της ανω κλησεως του θεου εν χριστω ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.3.15",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Philippians 3:15",
      "text": "οσοι ουν τελειοι τουτο φρονωμεν και ει τι ετερως φρονειτε και τουτο ο θεος υμιν αποκαλυψει",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.3.16",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Philippians 3:16",
      "text": "πλην εις ο εφθασαμεν τω αυτω στοιχειν κανονι το αυτο φρονειν",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.3.17",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Philippians 3:17",
      "text": "συμμιμηται μου γινεσθε αδελφοι και σκοπειτε τους ουτως περιπατουντας καθως εχετε τυπον ημας",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.3.18",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Philippians 3:18",
      "text": "πολλοι γαρ περιπατουσιν ους πολλακις ελεγον υμιν νυν δε και κλαιων λεγω τους εχθρους του σταυρου του χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.3.19",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Philippians 3:19",
      "text": "ων το τελος απωλεια ων ο θεος η κοιλια και η δοξα εν τη αισχυνη αυτων οι τα επιγεια φρονουντες",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.3.20",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Philippians 3:20",
      "text": "ημων γαρ το πολιτευμα εν ουρανοις υπαρχει εξ ου και σωτηρα απεκδεχομεθα κυριον ιησουν χριστον",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.3.21",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Philippians 3:21",
      "text": "ος μετασχηματισει το σωμα της ταπεινωσεως ημων εις το γενεσθαι αυτο συμμορφον τω σωματι της δοξης αυτου κατα την ενεργειαν του δυνασθαι αυτον και υποταξαι εαυτω τα παντα",
      "paragraphStart": false
    }
  ]
}
