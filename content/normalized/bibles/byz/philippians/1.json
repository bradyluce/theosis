{
  "chapter": {
    "id": "byz:philippians.1",
    "translationId": "byz",
    "bookSlug": "philippians",
    "chapterNumber": 1,
    "referenceLabel": "Philippians 1",
    "summary": "Source text for Philippians 1 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:philippians.1.1",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Philippians 1:1",
      "text": "παυλος και τιμοθεος δουλοι ιησου χριστου πασιν τοις αγιοις εν χριστω ιησου τοις ουσιν εν φιλιπποις συν επισκοποις και διακονοις",
      "paragraphStart": true
    },
    {
      "id": "byz:philippians.1.2",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Philippians 1:2",
      "text": "χαρις υμιν και ειρηνη απο θεου πατρος ημων και κυριου ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.3",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Philippians 1:3",
      "text": "ευχαριστω τω θεω μου επι παση τη μνεια υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.4",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Philippians 1:4",
      "text": "παντοτε εν παση δεησει μου υπερ παντων υμων μετα χαρας την δεησιν ποιουμενος",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.5",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Philippians 1:5",
      "text": "επι τη κοινωνια υμων εις το ευαγγελιον απο πρωτης ημερας αχρι του νυν",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.6",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Philippians 1:6",
      "text": "πεποιθως αυτο τουτο οτι ο εναρξαμενος εν υμιν εργον αγαθον επιτελεσει αχρι ημερας χριστου ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.7",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Philippians 1:7",
      "text": "καθως εστιν δικαιον εμοι τουτο φρονειν υπερ παντων υμων δια το εχειν με εν τη καρδια υμας εν τε τοις δεσμοις μου και εν τη απολογια και βεβαιωσει του ευαγγελιου συγκοινωνους μου της χαριτος παντας υμας οντας",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.8",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Philippians 1:8",
      "text": "μαρτυς γαρ μου εστιν ο θεος ως επιποθω παντας υμας εν σπλαγχνοις ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.9",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Philippians 1:9",
      "text": "και τουτο προσευχομαι ινα η αγαπη υμων ετι μαλλον και μαλλον περισσευη εν επιγνωσει και παση αισθησει",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.10",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Philippians 1:10",
      "text": "εις το δοκιμαζειν υμας τα διαφεροντα ινα ητε ειλικρινεις και απροσκοποι εις ημεραν χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.11",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Philippians 1:11",
      "text": "πεπληρωμενοι καρπων δικαιοσυνης των δια ιησου χριστου εις δοξαν και επαινον θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.12",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Philippians 1:12",
      "text": "γινωσκειν δε υμας βουλομαι αδελφοι οτι τα κατ εμε μαλλον εις προκοπην του ευαγγελιου εληλυθεν",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.13",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Philippians 1:13",
      "text": "ωστε τους δεσμους μου φανερους εν χριστω γενεσθαι εν ολω τω πραιτωριω και τοις λοιποις πασιν",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.14",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Philippians 1:14",
      "text": "και τους πλειονας των αδελφων εν κυριω πεποιθοτας τοις δεσμοις μου περισσοτερως τολμαν αφοβως τον λογον λαλειν",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.15",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Philippians 1:15",
      "text": "τινες μεν και δια φθονον και εριν τινες δε και δι ευδοκιαν τον χριστον κηρυσσουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.16",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Philippians 1:16",
      "text": "οι μεν εξ εριθειας τον χριστον καταγγελλουσιν ουχ αγνως οιομενοι θλιψιν επιφερειν τοις δεσμοις μου",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.17",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Philippians 1:17",
      "text": "οι δε εξ αγαπης ειδοτες οτι εις απολογιαν του ευαγγελιου κειμαι",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.18",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Philippians 1:18",
      "text": "τι γαρ πλην παντι τροπω ειτε προφασει ειτε αληθεια χριστος καταγγελλεται και εν τουτω χαιρω αλλα και χαρησομαι",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.19",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Philippians 1:19",
      "text": "οιδα γαρ οτι τουτο μοι αποβησεται εις σωτηριαν δια της υμων δεησεως και επιχορηγιας του πνευματος ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.20",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Philippians 1:20",
      "text": "κατα την αποκαραδοκιαν και ελπιδα μου οτι εν ουδενι αισχυνθησομαι αλλ εν παση παρρησια ως παντοτε και νυν μεγαλυνθησεται χριστος εν τω σωματι μου ειτε δια ζωης ειτε δια θανατου",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.21",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Philippians 1:21",
      "text": "εμοι γαρ το ζην χριστος και το αποθανειν κερδος",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.22",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Philippians 1:22",
      "text": "ει δε το ζην εν σαρκι τουτο μοι καρπος εργου και τι αιρησομαι ου γνωριζω",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.23",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Philippians 1:23",
      "text": "συνεχομαι δε εκ των δυο την επιθυμιαν εχων εις το αναλυσαι και συν χριστω ειναι πολλω μαλλον κρεισσον",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.24",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Philippians 1:24",
      "text": "το δε επιμενειν εν τη σαρκι αναγκαιοτερον δι υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.25",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Philippians 1:25",
      "text": "και τουτο πεποιθως οιδα οτι μενω και συμπαραμενω πασιν υμιν εις την υμων προκοπην και χαραν της πιστεως",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.26",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "Philippians 1:26",
      "text": "ινα το καυχημα υμων περισσευη εν χριστω ιησου εν εμοι δια της εμης παρουσιας παλιν προς υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.27",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "Philippians 1:27",
      "text": "μονον αξιως του ευαγγελιου του χριστου πολιτευεσθε ινα ειτε ελθων και ιδων υμας ειτε απων ακουσω τα περι υμων οτι στηκετε εν ενι πνευματι μια ψυχη συναθλουντες τη πιστει του ευαγγελιου",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.28",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "Philippians 1:28",
      "text": "και μη πτυρομενοι εν μηδενι υπο των αντικειμενων ητις αυτοις μεν εστιν ενδειξις απωλειας υμιν δε σωτηριας και τουτο απο θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.29",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "Philippians 1:29",
      "text": "οτι υμιν εχαρισθη το υπερ χριστου ου μονον το εις αυτον πιστευειν αλλα και το υπερ αυτου πασχειν",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.1.30",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "Philippians 1:30",
      "text": "τον αυτον αγωνα εχοντες οιον ειδετε εν εμοι και νυν ακουετε εν εμοι",
      "paragraphStart": false
    }
  ]
}
