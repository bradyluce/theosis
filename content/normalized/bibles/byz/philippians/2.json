{
  "chapter": {
    "id": "byz:philippians.2",
    "translationId": "byz",
    "bookSlug": "philippians",
    "chapterNumber": 2,
    "referenceLabel": "Philippians 2",
    "summary": "Source text for Philippians 2 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:philippians.2.1",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Philippians 2:1",
      "text": "ει τις ουν παρακλησις εν χριστω ει τι παραμυθιον αγαπης ει τις κοινωνια πνευματος ει τις σπλαγχνα και οικτιρμοι",
      "paragraphStart": true
    },
    {
      "id": "byz:philippians.2.2",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Philippians 2:2",
      "text": "πληρωσατε μου την χαραν ινα το αυτο φρονητε την αυτην αγαπην εχοντες συμψυχοι το εν φρονουντες",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.3",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Philippians 2:3",
      "text": "μηδεν κατα εριθειαν η κενοδοξιαν αλλα τη ταπεινοφροσυνη αλληλους ηγουμενοι υπερεχοντας εαυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.4",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Philippians 2:4",
      "text": "μη τα εαυτων εκαστος σκοπειτε αλλα και τα ετερων εκαστος",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.5",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Philippians 2:5",
      "text": "τουτο γαρ φρονεισθω εν υμιν ο και εν χριστω ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.6",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Philippians 2:6",
      "text": "ος εν μορφη θεου υπαρχων ουχ αρπαγμον ηγησατο το ειναι ισα θεω",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.7",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Philippians 2:7",
      "text": "αλλ εαυτον εκενωσεν μορφην δουλου λαβων εν ομοιωματι ανθρωπων γενομενος",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.8",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Philippians 2:8",
      "text": "και σχηματι ευρεθεις ως ανθρωπος εταπεινωσεν εαυτον γενομενος υπηκοος μεχρι θανατου θανατου δε σταυρου",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.9",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Philippians 2:9",
      "text": "διο και ο θεος αυτον υπερυψωσεν και εχαρισατο αυτω ονομα το υπερ παν ονομα",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.10",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Philippians 2:10",
      "text": "ινα εν τω ονοματι ιησου παν γονυ καμψη επουρανιων και επιγειων και καταχθονιων",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.11",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Philippians 2:11",
      "text": "και πασα γλωσσα εξομολογησηται οτι κυριος ιησους χριστος εις δοξαν θεου πατρος",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.12",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Philippians 2:12",
      "text": "ωστε αγαπητοι μου καθως παντοτε υπηκουσατε μη ως εν τη παρουσια μου μονον αλλα νυν πολλω μαλλον εν τη απουσια μου μετα φοβου και τρομου την εαυτων σωτηριαν κατεργαζεσθε",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.13",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Philippians 2:13",
      "text": "ο θεος γαρ εστιν ο ενεργων εν υμιν και το θελειν και το ενεργειν υπερ της ευδοκιας",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.14",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Philippians 2:14",
      "text": "παντα ποιειτε χωρις γογγυσμων και διαλογισμων",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.15",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Philippians 2:15",
      "text": "ινα γενησθε αμεμπτοι και ακεραιοι τεκνα θεου αμωμητα εν μεσω γενεας σκολιας και διεστραμμενης εν οις φαινεσθε ως φωστηρες εν κοσμω",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.16",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Philippians 2:16",
      "text": "λογον ζωης επεχοντες εις καυχημα εμοι εις ημεραν χριστου οτι ουκ εις κενον εδραμον ουδε εις κενον εκοπιασα",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.17",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Philippians 2:17",
      "text": "αλλ ει και σπενδομαι επι τη θυσια και λειτουργια της πιστεως υμων χαιρω και συγχαιρω πασιν υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.18",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Philippians 2:18",
      "text": "το δ αυτο και υμεις χαιρετε και συγχαιρετε μοι",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.19",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Philippians 2:19",
      "text": "ελπιζω δε εν κυριω ιησου τιμοθεον ταχεως πεμψαι υμιν ινα καγω ευψυχω γνους τα περι υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.20",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Philippians 2:20",
      "text": "ουδενα γαρ εχω ισοψυχον οστις γνησιως τα περι υμων μεριμνησει",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.21",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Philippians 2:21",
      "text": "οι παντες γαρ τα εαυτων ζητουσιν ου τα χριστου ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.22",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Philippians 2:22",
      "text": "την δε δοκιμην αυτου γινωσκετε οτι ως πατρι τεκνον συν εμοι εδουλευσεν εις το ευαγγελιον",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.23",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Philippians 2:23",
      "text": "τουτον μεν ουν ελπιζω πεμψαι ως αν απιδω τα περι εμε εξαυτης",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.24",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "Philippians 2:24",
      "text": "πεποιθα δε εν κυριω οτι και αυτος ταχεως ελευσομαι",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.25",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "Philippians 2:25",
      "text": "αναγκαιον δε ηγησαμην επαφροδιτον τον αδελφον και συνεργον και συστρατιωτην μου υμων δε αποστολον και λειτουργον της χρειας μου πεμψαι προς υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.26",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "Philippians 2:26",
      "text": "επειδη επιποθων ην παντας υμας και αδημονων διοτι ηκουσατε οτι ησθενησεν",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.27",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "Philippians 2:27",
      "text": "και γαρ ησθενησεν παραπλησιον θανατω αλλα ο θεος αυτον ηλεησεν ουκ αυτον δε μονον αλλα και εμε ινα μη λυπην επι λυπην σχω",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.28",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "Philippians 2:28",
      "text": "σπουδαιοτερως ουν επεμψα αυτον ινα ιδοντες αυτον παλιν χαρητε καγω αλυποτερος ω",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.29",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 29,
      "referenceLabel": "Philippians 2:29",
      "text": "προσδεχεσθε ουν αυτον εν κυριω μετα πασης χαρας και τους τοιουτους εντιμους εχετε",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.2.30",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 2,
      "verseNumber": 30,
      "referenceLabel": "Philippians 2:30",
      "text": "οτι δια το εργον του χριστου μεχρι θανατου ηγγισεν παραβουλευσαμενος τη ψυχη ινα αναπληρωση το υμων υστερημα της προς με λειτουργιας",
      "paragraphStart": false
    }
  ]
}
