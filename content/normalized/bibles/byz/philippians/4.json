{
  "chapter": {
    "id": "byz:philippians.4",
    "translationId": "byz",
    "bookSlug": "philippians",
    "chapterNumber": 4,
    "referenceLabel": "Philippians 4",
    "summary": "Source text for Philippians 4 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:philippians.4.1",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Philippians 4:1",
      "text": "ωστε αδελφοι μου αγαπητοι και επιποθητοι χαρα και στεφανος μου ουτως στηκετε εν κυριω αγαπητοι",
      "paragraphStart": true
    },
    {
      "id": "byz:philippians.4.2",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Philippians 4:2",
      "text": "ευοδιαν παρακαλω και συντυχην παρακαλω το αυτο φρονειν εν κυριω",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.3",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Philippians 4:3",
      "text": "ναι ερωτω και σε συζυγε γνησιε συλλαμβανου αυταις αιτινες εν τω ευαγγελιω συνηθλησαν μοι μετα και κλημεντος και των λοιπων συνεργων μου ων τα ονοματα εν βιβλω ζωης",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.4",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Philippians 4:4",
      "text": "χαιρετε εν κυριω παντοτε παλιν ερω χαιρετε",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.5",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Philippians 4:5",
      "text": "το επιεικες υμων γνωσθητω πασιν ανθρωποις ο κυριος εγγυς",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.6",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Philippians 4:6",
      "text": "μηδεν μεριμνατε αλλ εν παντι τη προσευχη και τη δεησει μετα ευχαριστιας τα αιτηματα υμων γνωριζεσθω προς τον θεον",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.7",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Philippians 4:7",
      "text": "και η ειρηνη του θεου η υπερεχουσα παντα νουν φρουρησει τας καρδιας υμων και τα νοηματα υμων εν χριστω ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.8",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Philippians 4:8",
      "text": "το λοιπον αδελφοι οσα εστιν αληθη οσα σεμνα οσα δικαια οσα αγνα οσα προσφιλη οσα ευφημα ει τις αρετη και ει τις επαινος ταυτα λογιζεσθε",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.9",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Philippians 4:9",
      "text": "α και εμαθετε και παρελαβετε και ηκουσατε και ειδετε εν εμοι ταυτα πρασσετε και ο θεος της ειρηνης εσται μεθ υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.10",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Philippians 4:10",
      "text": "εχαρην δε εν κυριω μεγαλως οτι ηδη ποτε ανεθαλετε το υπερ εμου φρονειν εφ ω και εφρονειτε ηκαιρεισθε δε",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.11",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Philippians 4:11",
      "text": "ουχ οτι καθ υστερησιν λεγω εγω γαρ εμαθον εν οις ειμι αυταρκης ειναι",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.12",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Philippians 4:12",
      "text": "οιδα και ταπεινουσθαι οιδα και περισσευειν εν παντι και εν πασιν μεμυημαι και χορταζεσθαι και πειναν και περισσευειν και υστερεισθαι",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.13",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Philippians 4:13",
      "text": "παντα ισχυω εν τω ενδυναμουντι με χριστω",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.14",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Philippians 4:14",
      "text": "πλην καλως εποιησατε συγκοινωνησαντες μου τη θλιψει",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.15",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Philippians 4:15",
      "text": "οιδατε δε και υμεις φιλιππησιοι οτι εν αρχη του ευαγγελιου οτε εξηλθον απο μακεδονιας ουδεμια μοι εκκλησια εκοινωνησεν εις λογον δοσεως και ληψεως ει μη υμεις μονοι",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.16",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Philippians 4:16",
      "text": "οτι και εν θεσσαλονικη και απαξ και δις εις την χρειαν μοι επεμψατε",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.17",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Philippians 4:17",
      "text": "ουχ οτι επιζητω το δομα αλλ επιζητω τον καρπον τον πλεοναζοντα εις λογον υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.18",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Philippians 4:18",
      "text": "απεχω δε παντα και περισσευω πεπληρωμαι δεξαμενος παρα επαφροδιτου τα παρ υμων οσμην ευωδιας θυσιαν δεκτην ευαρεστον τω θεω",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.19",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Philippians 4:19",
      "text": "ο δε θεος μου πληρωσει πασαν χρειαν υμων κατα τον πλουτον αυτου εν δοξη εν χριστω ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.20",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Philippians 4:20",
      "text": "τω δε θεω και πατρι ημων η δοξα εις τους αιωνας των αιωνων αμην",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.21",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Philippians 4:21",
      "text": "ασπασασθε παντα αγιον εν χριστω ιησου ασπαζονται υμας οι συν εμοι αδελφοι",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.22",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Philippians 4:22",
      "text": "ασπαζονται υμας παντες οι αγιοι μαλιστα δε οι εκ της καισαρος οικιας",
      "paragraphStart": false
    },
    {
      "id": "byz:philippians.4.23",
      "translationId": "byz",
      "bookSlug": "philippians",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Philippians 4:23",
      "text": "η χαρις του κυριου ιησου χριστου μετα παντων υμων αμην",
      "paragraphStart": false
    }
  ]
}
