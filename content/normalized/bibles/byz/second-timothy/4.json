{
  "chapter": {
    "id": "byz:second-timothy.4",
    "translationId": "byz",
    "bookSlug": "second-timothy",
    "chapterNumber": 4,
    "referenceLabel": "2 Timothy 4",
    "summary": "Source text for 2 Timothy 4 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:second-timothy.4.1",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "2 Timothy 4:1",
      "text": "διαμαρτυρομαι ουν εγω ενωπιον του θεου και του κυριου ιησου χριστου του μελλοντος κρινειν ζωντας και νεκρους κατα την επιφανειαν αυτου και την βασιλειαν αυτου",
      "paragraphStart": true
    },
    {
      "id": "byz:second-timothy.4.2",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "2 Timothy 4:2",
      "text": "κηρυξον τον λογον επιστηθι ευκαιρως ακαιρως ελεγξον επιτιμησον παρακαλεσον εν παση μακροθυμια και διδαχη",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.3",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "2 Timothy 4:3",
      "text": "εσται γαρ καιρος οτε της υγιαινουσης διδασκαλιας ουκ ανεξονται αλλα κατα τας επιθυμιας τας ιδιας εαυτοις επισωρευσουσιν διδασκαλους κνηθομενοι την ακοην",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.4",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "2 Timothy 4:4",
      "text": "και απο μεν της αληθειας την ακοην αποστρεψουσιν επι δε τους μυθους εκτραπησονται",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.5",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "2 Timothy 4:5",
      "text": "συ δε νηφε εν πασιν κακοπαθησον εργον ποιησον ευαγγελιστου την διακονιαν σου πληροφορησον",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.6",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "2 Timothy 4:6",
      "text": "εγω γαρ ηδη σπενδομαι και ο καιρος της εμης αναλυσεως εφεστηκεν",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.7",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "2 Timothy 4:7",
      "text": "τον αγωνα τον καλον ηγωνισμαι τον δρομον τετελεκα την πιστιν τετηρηκα",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.8",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "2 Timothy 4:8",
      "text": "λοιπον αποκειται μοι ο της δικαιοσυνης στεφανος ον αποδωσει μοι ο κυριος εν εκεινη τη ημερα ο δικαιος κριτης ου μονον δε εμοι αλλα και πασιν τοις ηγαπηκοσιν την επιφανειαν αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.9",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "2 Timothy 4:9",
      "text": "σπουδασον ελθειν προς με ταχεως",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.10",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "2 Timothy 4:10",
      "text": "δημας γαρ με εγκατελιπεν αγαπησας τον νυν αιωνα και επορευθη εις θεσσαλονικην κρησκης εις γαλατιαν τιτος εις δαλματιαν",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.11",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "2 Timothy 4:11",
      "text": "λουκας εστιν μονος μετ εμου μαρκον αναλαβων αγε μετα σεαυτου εστιν γαρ μοι ευχρηστος εις διακονιαν",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.12",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "2 Timothy 4:12",
      "text": "τυχικον δε απεστειλα εις εφεσον",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.13",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "2 Timothy 4:13",
      "text": "τον φελονην ον απελιπον εν τρωαδι παρα καρπω ερχομενος φερε και τα βιβλια μαλιστα τας μεμβρανας",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.14",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "2 Timothy 4:14",
      "text": "αλεξανδρος ο χαλκευς πολλα μοι κακα ενεδειξατο αποδωη αυτω ο κυριος κατα τα εργα αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.15",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "2 Timothy 4:15",
      "text": "ον και συ φυλασσου λιαν γαρ ανθεστηκεν τοις ημετεροις λογοις",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.16",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "2 Timothy 4:16",
      "text": "εν τη πρωτη μου απολογια ουδεις μοι συμπαρεγενετο αλλα παντες με εγκατελιπον μη αυτοις λογισθειη",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.17",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "2 Timothy 4:17",
      "text": "ο δε κυριος μοι παρεστη και ενεδυναμωσεν με ινα δι εμου το κηρυγμα πληροφορηθη και ακουση παντα τα εθνη και ερρυσθην εκ στοματος λεοντος",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.18",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "2 Timothy 4:18",
      "text": "και ρυσεται με ο κυριος απο παντος εργου πονηρου και σωσει εις την βασιλειαν αυτου την επουρανιον ω η δοξα εις τους αιωνας των αιωνων αμην",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.19",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "2 Timothy 4:19",
      "text": "ασπασαι πρισκαν και ακυλαν και τον ονησιφορου οικον",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.20",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "2 Timothy 4:20",
      "text": "εραστος εμεινεν εν κορινθω τροφιμον δε απελιπον εν μιλητω ασθενουντα",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.21",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "2 Timothy 4:21",
      "text": "σπουδασον προ χειμωνος ελθειν ασπαζεται σε ευβουλος και πουδης και λινος και κλαυδια και οι αδελφοι παντες",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.4.22",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "2 Timothy 4:22",
      "text": "ο κυριος ιησους χριστος μετα του πνευματος σου η χαρις μεθ υμων αμην",
      "paragraphStart": false
    }
  ]
}
