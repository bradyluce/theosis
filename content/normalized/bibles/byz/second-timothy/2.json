{
  "chapter": {
    "id": "byz:second-timothy.2",
    "translationId": "byz",
    "bookSlug": "second-timothy",
    "chapterNumber": 2,
    "referenceLabel": "2 Timothy 2",
    "summary": "Source text for 2 Timothy 2 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:second-timothy.2.1",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "2 Timothy 2:1",
      "text": "συ ουν τεκνον μου ενδυναμου εν τη χαριτι τη εν χριστω ιησου",
      "paragraphStart": true
    },
    {
      "id": "byz:second-timothy.2.2",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "2 Timothy 2:2",
      "text": "και α ηκουσας παρ εμου δια πολλων μαρτυρων ταυτα παραθου πιστοις ανθρωποις οιτινες ικανοι εσονται και ετερους διδαξαι",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.3",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "2 Timothy 2:3",
      "text": "συ ουν κακοπαθησον ως καλος στρατιωτης ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.4",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "2 Timothy 2:4",
      "text": "ουδεις στρατευομενος εμπλεκεται ταις του βιου πραγματειαις ινα τω στρατολογησαντι αρεση",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.5",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "2 Timothy 2:5",
      "text": "εαν δε και αθλη τις ου στεφανουται εαν μη νομιμως αθληση",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.6",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "2 Timothy 2:6",
      "text": "τον κοπιωντα γεωργον δει πρωτον των καρπων μεταλαμβανειν",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.7",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "2 Timothy 2:7",
      "text": "νοει α λεγω δωη γαρ σοι ο κυριος συνεσιν εν πασιν",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.8",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "2 Timothy 2:8",
      "text": "μνημονευε ιησουν χριστον εγηγερμενον εκ νεκρων εκ σπερματος δαυιδ κατα το ευαγγελιον μου",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.9",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "2 Timothy 2:9",
      "text": "εν ω κακοπαθω μεχρι δεσμων ως κακουργος αλλ ο λογος του θεου ου δεδεται",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.10",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "2 Timothy 2:10",
      "text": "δια τουτο παντα υπομενω δια τους εκλεκτους ινα και αυτοι σωτηριας τυχωσιν της εν χριστω ιησου μετα δοξης αιωνιου",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.11",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "2 Timothy 2:11",
      "text": "πιστος ο λογος ει γαρ συναπεθανομεν και συζησομεν",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.12",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "2 Timothy 2:12",
      "text": "ει υπομενομεν και συμβασιλευσομεν ει αρνουμεθα κακεινος αρνησεται ημας",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.13",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "2 Timothy 2:13",
      "text": "ει απιστουμεν εκεινος πιστος μενει αρνησασθαι εαυτον ου δυναται",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.14",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "2 Timothy 2:14",
      "text": "ταυτα υπομιμνησκε διαμαρτυρομενος ενωπιον του κυριου μη λογομαχειν εις ουδεν χρησιμον επι καταστροφη των ακουοντων",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.15",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "2 Timothy 2:15",
      "text": "σπουδασον σεαυτον δοκιμον παραστησαι τω θεω εργατην ανεπαισχυντον ορθοτομουντα τον λογον της αληθειας",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.16",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "2 Timothy 2:16",
      "text": "τας δε βεβηλους κενοφωνιας περιιστασο επι πλειον γαρ προκοψουσιν ασεβειας",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.17",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "2 Timothy 2:17",
      "text": "και ο λογος αυτων ως γαγγραινα νομην εξει ων εστιν υμεναιος και φιλητος",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.18",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "2 Timothy 2:18",
      "text": "οιτινες περι την αληθειαν ηστοχησαν λεγοντες την αναστασιν ηδη γεγονεναι και ανατρεπουσιν την τινων πιστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.19",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "2 Timothy 2:19",
      "text": "ο μεντοι στερεος θεμελιος του θεου εστηκεν εχων την σφραγιδα ταυτην εγνω κυριος τους οντας αυτου και αποστητω απο αδικιας πας ο ονομαζων το ονομα κυριου",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.20",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "2 Timothy 2:20",
      "text": "εν μεγαλη δε οικια ουκ εστιν μονον σκευη χρυσα και αργυρα αλλα και ξυλινα και οστρακινα και α μεν εις τιμην α δε εις ατιμιαν",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.21",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "2 Timothy 2:21",
      "text": "εαν ουν τις εκκαθαρη εαυτον απο τουτων εσται σκευος εις τιμην ηγιασμενον και ευχρηστον τω δεσποτη εις παν εργον αγαθον ητοιμασμενον",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.22",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "2 Timothy 2:22",
      "text": "τας δε νεωτερικας επιθυμιας φευγε διωκε δε δικαιοσυνην πιστιν αγαπην ειρηνην μετα των επικαλουμενων τον κυριον εκ καθαρας καρδιας",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.23",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "2 Timothy 2:23",
      "text": "τας δε μωρας και απαιδευτους ζητησεις παραιτου ειδως οτι γεννωσιν μαχας",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.24",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "2 Timothy 2:24",
      "text": "δουλον δε κυριου ου δει μαχεσθαι αλλ ηπιον ειναι προς παντας διδακτικον ανεξικακον",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.25",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "2 Timothy 2:25",
      "text": "εν πραοτητι παιδευοντα τους αντιδιατιθεμενους μηποτε δω αυτοις ο θεος μετανοιαν εις επιγνωσιν αληθειας",
      "paragraphStart": false
    },
    {
      "id": "byz:second-timothy.2.26",
      "translationId": "byz",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "2 Timothy 2:26",
      "text": "και ανανηψωσιν εκ της του διαβολου παγιδος εζωγρημενοι υπ αυτου εις το εκεινου θελημα",
      "paragraphStart": false
    }
  ]
}
