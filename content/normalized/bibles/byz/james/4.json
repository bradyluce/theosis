{
  "chapter": {
    "id": "byz:james.4",
    "translationId": "byz",
    "bookSlug": "james",
    "chapterNumber": 4,
    "referenceLabel": "James 4",
    "summary": "Source text for James 4 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:james.4.1",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "James 4:1",
      "text": "ποθεν πολεμοι και μαχαι εν υμιν ουκ εντευθεν εκ των ηδονων υμων των στρατευομενων εν τοις μελεσιν υμων",
      "paragraphStart": true
    },
    {
      "id": "byz:james.4.2",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "James 4:2",
      "text": "επιθυμειτε και ουκ εχετε φονευετε και ζηλουτε και ου δυνασθε επιτυχειν μαχεσθε και πολεμειτε ουκ εχετε δια το μη αιτεισθαι υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:james.4.3",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "James 4:3",
      "text": "αιτειτε και ου λαμβανετε διοτι κακως αιτεισθε ινα εν ταις ηδοναις υμων δαπανησητε",
      "paragraphStart": false
    },
    {
      "id": "byz:james.4.4",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "James 4:4",
      "text": "μοιχοι και μοιχαλιδες ουκ οιδατε οτι η φιλια του κοσμου εχθρα του θεου εστιν ος αν ουν βουληθη φιλος ειναι του κοσμου εχθρος του θεου καθισταται",
      "paragraphStart": false
    },
    {
      "id": "byz:james.4.5",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "James 4:5",
      "text": "η δοκειτε οτι κενως η γραφη λεγει προς φθονον επιποθει το πνευμα ο κατωκησεν εν ημιν",
      "paragraphStart": false
    },
    {
      "id": "byz:james.4.6",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "James 4:6",
      "text": "μειζονα δε διδωσιν χαριν διο λεγει ο θεος υπερηφανοις αντιτασσεται ταπεινοις δε διδωσιν χαριν",
      "paragraphStart": false
    },
    {
      "id": "byz:james.4.7",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "James 4:7",
      "text": "υποταγητε ουν τω θεω αντιστητε δε τω διαβολω και φευξεται αφ υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:james.4.8",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "James 4:8",
      "text": "εγγισατε τω θεω και εγγιει υμιν καθαρισατε χειρας αμαρτωλοι και αγνισατε καρδιας διψυχοι",
      "paragraphStart": false
    },
    {
      "id": "byz:james.4.9",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "James 4:9",
      "text": "ταλαιπωρησατε και πενθησατε και κλαυσατε ο γελως υμων εις πενθος μεταστραφητω και η χαρα εις κατηφειαν",
      "paragraphStart": false
    },
    {
      "id": "byz:james.4.10",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "James 4:10",
      "text": "ταπεινωθητε ενωπιον του κυριου και υψωσει υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:james.4.11",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "James 4:11",
      "text": "μη καταλαλειτε αλληλων αδελφοι ο καταλαλων αδελφου και κρινων τον αδελφον αυτου καταλαλει νομου και κρινει νομον ει δε νομον κρινεις ουκ ει ποιητης νομου αλλα κριτης",
      "paragraphStart": false
    },
    {
      "id": "byz:james.4.12",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "James 4:12",
      "text": "εις εστιν ο νομοθετης ο δυναμενος σωσαι και απολεσαι συ δε τις ει ος κρινεις τον ετερον",
      "paragraphStart": false
    },
    {
      "id": "byz:james.4.13",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "James 4:13",
      "text": "αγε νυν οι λεγοντες σημερον και αυριον πορευσωμεθα εις τηνδε την πολιν και ποιησωμεν εκει ενιαυτον ενα και εμπορευσωμεθα και κερδησωμεν",
      "paragraphStart": false
    },
    {
      "id": "byz:james.4.14",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "James 4:14",
      "text": "οιτινες ουκ επιστασθε το της αυριον ποια γαρ η ζωη υμων ατμις γαρ εσται η προς ολιγον φαινομενη επειτα δε και αφανιζομενη",
      "paragraphStart": false
    },
    {
      "id": "byz:james.4.15",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "James 4:15",
      "text": "αντι του λεγειν υμας εαν ο κυριος θεληση και ζησωμεν και ποιησωμεν τουτο η εκεινο",
      "paragraphStart": false
    },
    {
      "id": "byz:james.4.16",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "James 4:16",
      "text": "νυν δε καυχασθε εν ταις αλαζονειαις υμων πασα καυχησις τοιαυτη πονηρα εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:james.4.17",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "James 4:17",
      "text": "ειδοτι ουν καλον ποιειν και μη ποιουντι αμαρτια αυτω εστιν",
      "paragraphStart": false
    }
  ]
}
