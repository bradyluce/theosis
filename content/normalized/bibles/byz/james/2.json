{
  "chapter": {
    "id": "byz:james.2",
    "translationId": "byz",
    "bookSlug": "james",
    "chapterNumber": 2,
    "referenceLabel": "James 2",
    "summary": "Source text for James 2 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:james.2.1",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "James 2:1",
      "text": "αδελφοι μου μη εν προσωποληψιαις εχετε την πιστιν του κυριου ημων ιησου χριστου της δοξης",
      "paragraphStart": true
    },
    {
      "id": "byz:james.2.2",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "James 2:2",
      "text": "εαν γαρ εισελθη εις την συναγωγην υμων ανηρ χρυσοδακτυλιος εν εσθητι λαμπρα εισελθη δε και πτωχος εν ρυπαρα εσθητι",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.3",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "James 2:3",
      "text": "και επιβλεψητε επι τον φορουντα την εσθητα την λαμπραν και ειπητε αυτω συ καθου ωδε καλως και τω πτωχω ειπητε συ στηθι εκει η καθου ωδε υπο το υποποδιον μου",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.4",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "James 2:4",
      "text": "και ου διεκριθητε εν εαυτοις και εγενεσθε κριται διαλογισμων πονηρων",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.5",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "James 2:5",
      "text": "ακουσατε αδελφοι μου αγαπητοι ουχ ο θεος εξελεξατο τους πτωχους του κοσμου πλουσιους εν πιστει και κληρονομους της βασιλειας ης επηγγειλατο τοις αγαπωσιν αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.6",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "James 2:6",
      "text": "υμεις δε ητιμασατε τον πτωχον ουχ οι πλουσιοι καταδυναστευουσιν υμων και αυτοι ελκουσιν υμας εις κριτηρια",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.7",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "James 2:7",
      "text": "ουκ αυτοι βλασφημουσιν το καλον ονομα το επικληθεν εφ υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.8",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "James 2:8",
      "text": "ει μεντοι νομον τελειτε βασιλικον κατα την γραφην αγαπησεις τον πλησιον σου ως σεαυτον καλως ποιειτε",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.9",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "James 2:9",
      "text": "ει δε προσωποληπτειτε αμαρτιαν εργαζεσθε ελεγχομενοι υπο του νομου ως παραβαται",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.10",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "James 2:10",
      "text": "οστις γαρ ολον τον νομον τηρησει πταισει δε εν ενι γεγονεν παντων ενοχος",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.11",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "James 2:11",
      "text": "ο γαρ ειπων μη μοιχευσεις ειπεν και μη φονευσεις ει δε ου μοιχευσεις φονευσεις δε γεγονας παραβατης νομου",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.12",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "James 2:12",
      "text": "ουτως λαλειτε και ουτως ποιειτε ως δια νομου ελευθεριας μελλοντες κρινεσθαι",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.13",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "James 2:13",
      "text": "η γαρ κρισις ανελεος τω μη ποιησαντι ελεος κατακαυχαται ελεον κρισεως",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.14",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "James 2:14",
      "text": "τι το οφελος αδελφοι μου εαν πιστιν λεγη τις εχειν εργα δε μη εχη μη δυναται η πιστις σωσαι αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.15",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "James 2:15",
      "text": "εαν δε αδελφος η αδελφη γυμνοι υπαρχωσιν και λειπομενοι ωσιν της εφημερου τροφης",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.16",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "James 2:16",
      "text": "ειπη δε τις αυτοις εξ υμων υπαγετε εν ειρηνη θερμαινεσθε και χορταζεσθε μη δωτε δε αυτοις τα επιτηδεια του σωματος τι το οφελος",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.17",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "James 2:17",
      "text": "ουτως και η πιστις εαν μη εργα εχη νεκρα εστιν καθ εαυτην",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.18",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "James 2:18",
      "text": "αλλ ερει τις συ πιστιν εχεις καγω εργα εχω δειξον μοι την πιστιν σου εκ των εργων σου καγω δειξω σοι εκ των εργων μου την πιστιν μου",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.19",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "James 2:19",
      "text": "συ πιστευεις οτι ο θεος εις εστιν καλως ποιεις και τα δαιμονια πιστευουσιν και φρισσουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.20",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "James 2:20",
      "text": "θελεις δε γνωναι ω ανθρωπε κενε οτι η πιστις χωρις των εργων νεκρα εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.21",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "James 2:21",
      "text": "αβρααμ ο πατηρ ημων ουκ εξ εργων εδικαιωθη ανενεγκας ισαακ τον υιον αυτου επι το θυσιαστηριον",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.22",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "James 2:22",
      "text": "βλεπεις οτι η πιστις συνηργει τοις εργοις αυτου και εκ των εργων η πιστις ετελειωθη",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.23",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "James 2:23",
      "text": "και επληρωθη η γραφη η λεγουσα επιστευσεν δε αβρααμ τω θεω και ελογισθη αυτω εις δικαιοσυνην και φιλος θεου εκληθη",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.24",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "James 2:24",
      "text": "ορατε τοινυν οτι εξ εργων δικαιουται ανθρωπος και ουκ εκ πιστεως μονον",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.25",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "James 2:25",
      "text": "ομοιως δε και ρααβ η πορνη ουκ εξ εργων εδικαιωθη υποδεξαμενη τους αγγελους και ετερα οδω εκβαλουσα",
      "paragraphStart": false
    },
    {
      "id": "byz:james.2.26",
      "translationId": "byz",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "James 2:26",
      "text": "ωσπερ γαρ το σωμα χωρις πνευματος νεκρον εστιν ουτως και η πιστις χωρις των εργων νεκρα εστιν",
      "paragraphStart": false
    }
  ]
}
