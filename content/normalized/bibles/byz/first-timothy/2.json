{
  "chapter": {
    "id": "byz:first-timothy.2",
    "translationId": "byz",
    "bookSlug": "first-timothy",
    "chapterNumber": 2,
    "referenceLabel": "1 Timothy 2",
    "summary": "Source text for 1 Timothy 2 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:first-timothy.2.1",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "1 Timothy 2:1",
      "text": "παρακαλω ουν πρωτον παντων ποιεισθαι δεησεις προσευχας εντευξεις ευχαριστιας υπερ παντων ανθρωπων",
      "paragraphStart": true
    },
    {
      "id": "byz:first-timothy.2.2",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "1 Timothy 2:2",
      "text": "υπερ βασιλεων και παντων των εν υπεροχη οντων ινα ηρεμον και ησυχιον βιον διαγωμεν εν παση ευσεβεια και σεμνοτητι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.2.3",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "1 Timothy 2:3",
      "text": "τουτο γαρ καλον και αποδεκτον ενωπιον του σωτηρος ημων θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.2.4",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "1 Timothy 2:4",
      "text": "ος παντας ανθρωπους θελει σωθηναι και εις επιγνωσιν αληθειας ελθειν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.2.5",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "1 Timothy 2:5",
      "text": "εις γαρ θεος εις και μεσιτης θεου και ανθρωπων ανθρωπος χριστος ιησους",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.2.6",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "1 Timothy 2:6",
      "text": "ο δους εαυτον αντιλυτρον υπερ παντων το μαρτυριον καιροις ιδιοις",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.2.7",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "1 Timothy 2:7",
      "text": "εις ο ετεθην εγω κηρυξ και αποστολος αληθειαν λεγω εν χριστω ου ψευδομαι διδασκαλος εθνων εν πιστει και αληθεια",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.2.8",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "1 Timothy 2:8",
      "text": "βουλομαι ουν προσευχεσθαι τους ανδρας εν παντι τοπω επαιροντας οσιους χειρας χωρις οργης και διαλογισμου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.2.9",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "1 Timothy 2:9",
      "text": "ωσαυτως και τας γυναικας εν καταστολη κοσμιω μετα αιδους και σωφροσυνης κοσμειν εαυτας μη εν πλεγμασιν η χρυσω η μαργαριταις η ιματισμω πολυτελει",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.2.10",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "1 Timothy 2:10",
      "text": "αλλ ο πρεπει γυναιξιν επαγγελλομεναις θεοσεβειαν δι εργων αγαθων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.2.11",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "1 Timothy 2:11",
      "text": "γυνη εν ησυχια μανθανετω εν παση υποταγη",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.2.12",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "1 Timothy 2:12",
      "text": "γυναικι δε διδασκειν ουκ επιτρεπω ουδε αυθεντειν ανδρος αλλ ειναι εν ησυχια",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.2.13",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "1 Timothy 2:13",
      "text": "αδαμ γαρ πρωτος επλασθη ειτα ευα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.2.14",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "1 Timothy 2:14",
      "text": "και αδαμ ουκ ηπατηθη η δε γυνη απατηθεισα εν παραβασει γεγονεν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.2.15",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "1 Timothy 2:15",
      "text": "σωθησεται δε δια της τεκνογονιας εαν μεινωσιν εν πιστει και αγαπη και αγιασμω μετα σωφροσυνης",
      "paragraphStart": false
    }
  ]
}
