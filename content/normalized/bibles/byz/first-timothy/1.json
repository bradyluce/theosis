{
  "chapter": {
    "id": "byz:first-timothy.1",
    "translationId": "byz",
    "bookSlug": "first-timothy",
    "chapterNumber": 1,
    "referenceLabel": "1 Timothy 1",
    "summary": "Source text for 1 Timothy 1 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:first-timothy.1.1",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "1 Timothy 1:1",
      "text": "παυλος αποστολος ιησου χριστου κατ επιταγην θεου σωτηρος ημων και κυριου ιησου χριστου της ελπιδος ημων",
      "paragraphStart": true
    },
    {
      "id": "byz:first-timothy.1.2",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "1 Timothy 1:2",
      "text": "τιμοθεω γνησιω τεκνω εν πιστει χαρις ελεος ειρηνη απο θεου πατρος ημων και χριστου ιησου του κυριου ημων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.1.3",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "1 Timothy 1:3",
      "text": "καθως παρεκαλεσα σε προσμειναι εν εφεσω πορευομενος εις μακεδονιαν ινα παραγγειλης τισιν μη ετεροδιδασκαλειν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.1.4",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "1 Timothy 1:4",
      "text": "μηδε προσεχειν μυθοις και γενεαλογιαις απεραντοις αιτινες ζητησεις παρεχουσιν μαλλον η οικονομιαν θεου την εν πιστει",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.1.5",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "1 Timothy 1:5",
      "text": "το δε τελος της παραγγελιας εστιν αγαπη εκ καθαρας καρδιας και συνειδησεως αγαθης και πιστεως ανυποκριτου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.1.6",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "1 Timothy 1:6",
      "text": "ων τινες αστοχησαντες εξετραπησαν εις ματαιολογιαν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.1.7",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "1 Timothy 1:7",
      "text": "θελοντες ειναι νομοδιδασκαλοι μη νοουντες μητε α λεγουσιν μητε περι τινων διαβεβαιουνται",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.1.8",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "1 Timothy 1:8",
      "text": "οιδαμεν δε οτι καλος ο νομος εαν τις αυτω νομιμως χρηται",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.1.9",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "1 Timothy 1:9",
      "text": "ειδως τουτο οτι δικαιω νομος ου κειται ανομοις δε και ανυποτακτοις ασεβεσιν και αμαρτωλοις ανοσιοις και βεβηλοις πατρολωαις και μητρολωαις ανδροφονοις",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.1.10",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "1 Timothy 1:10",
      "text": "πορνοις αρσενοκοιταις ανδραποδισταις ψευσταις επιορκοις και ει τι ετερον τη υγιαινουση διδασκαλια αντικειται",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.1.11",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "1 Timothy 1:11",
      "text": "κατα το ευαγγελιον της δοξης του μακαριου θεου ο επιστευθην εγω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.1.12",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "1 Timothy 1:12",
      "text": "και χαριν εχω τω ενδυναμωσαντι με χριστω ιησου τω κυριω ημων οτι πιστον με ηγησατο θεμενος εις διακονιαν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.1.13",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "1 Timothy 1:13",
      "text": "τον προτερον οντα βλασφημον και διωκτην και υβριστην αλλα ηλεηθην οτι αγνοων εποιησα εν απιστια",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.1.14",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "1 Timothy 1:14",
      "text": "υπερεπλεονασεν δε η χαρις του κυριου ημων μετα πιστεως και αγαπης της εν χριστω ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.1.15",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "1 Timothy 1:15",
      "text": "πιστος ο λογος και πασης αποδοχης αξιος οτι χριστος ιησους ηλθεν εις τον κοσμον αμαρτωλους σωσαι ων πρωτος ειμι εγω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.1.16",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "1 Timothy 1:16",
      "text": "αλλα δια τουτο ηλεηθην ινα εν εμοι πρωτω ενδειξηται ιησους χριστος την πασαν μακροθυμιαν προς υποτυπωσιν των μελλοντων πιστευειν επ αυτω εις ζωην αιωνιον",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.1.17",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "1 Timothy 1:17",
      "text": "τω δε βασιλει των αιωνων αφθαρτω αορατω μονω σοφω θεω τιμη και δοξα εις τους αιωνας των αιωνων αμην",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.1.18",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "1 Timothy 1:18",
      "text": "ταυτην την παραγγελιαν παρατιθεμαι σοι τεκνον τιμοθεε κατα τας προαγουσας επι σε προφητειας ινα στρατευη εν αυταις την καλην στρατειαν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.1.19",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "1 Timothy 1:19",
      "text": "εχων πιστιν και αγαθην συνειδησιν ην τινες απωσαμενοι περι την πιστιν εναυαγησαν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.1.20",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "1 Timothy 1:20",
      "text": "ων εστιν υμεναιος και αλεξανδρος ους παρεδωκα τω σατανα ινα παιδευθωσιν μη βλασφημειν",
      "paragraphStart": false
    }
  ]
}
