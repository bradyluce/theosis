{
  "chapter": {
    "id": "byz:first-timothy.5",
    "translationId": "byz",
    "bookSlug": "first-timothy",
    "chapterNumber": 5,
    "referenceLabel": "1 Timothy 5",
    "summary": "Source text for 1 Timothy 5 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:first-timothy.5.1",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "1 Timothy 5:1",
      "text": "πρεσβυτερω μη επιπληξης αλλα παρακαλει ως πατερα νεωτερους ως αδελφους",
      "paragraphStart": true
    },
    {
      "id": "byz:first-timothy.5.2",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "1 Timothy 5:2",
      "text": "πρεσβυτερας ως μητερας νεωτερας ως αδελφας εν παση αγνεια",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.3",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "1 Timothy 5:3",
      "text": "χηρας τιμα τας οντως χηρας",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.4",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "1 Timothy 5:4",
      "text": "ει δε τις χηρα τεκνα η εκγονα εχει μανθανετωσαν πρωτον τον ιδιον οικον ευσεβειν και αμοιβας αποδιδοναι τοις προγονοις τουτο γαρ εστιν αποδεκτον ενωπιον του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.5",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "1 Timothy 5:5",
      "text": "η δε οντως χηρα και μεμονωμενη ηλπικεν επι τον θεον και προσμενει ταις δεησεσιν και ταις προσευχαις νυκτος και ημερας",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.6",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "1 Timothy 5:6",
      "text": "η δε σπαταλωσα ζωσα τεθνηκεν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.7",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "1 Timothy 5:7",
      "text": "και ταυτα παραγγελλε ινα ανεπιληπτοι ωσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.8",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "1 Timothy 5:8",
      "text": "ει δε τις των ιδιων και μαλιστα των οικειων ου προνοει την πιστιν ηρνηται και εστιν απιστου χειρων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.9",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "1 Timothy 5:9",
      "text": "χηρα καταλεγεσθω μη ελαττον ετων εξηκοντα γεγονυια ενος ανδρος γυνη",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.10",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "1 Timothy 5:10",
      "text": "εν εργοις καλοις μαρτυρουμενη ει ετεκνοτροφησεν ει εξενοδοχησεν ει αγιων ποδας ενιψεν ει θλιβομενοις επηρκεσεν ει παντι εργω αγαθω επηκολουθησεν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.11",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "1 Timothy 5:11",
      "text": "νεωτερας δε χηρας παραιτου οταν γαρ καταστρηνιασωσιν του χριστου γαμειν θελουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.12",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "1 Timothy 5:12",
      "text": "εχουσαι κριμα οτι την πρωτην πιστιν ηθετησαν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.13",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "1 Timothy 5:13",
      "text": "αμα δε και αργαι μανθανουσιν περιερχομεναι τας οικιας ου μονον δε αργαι αλλα και φλυαροι και περιεργοι λαλουσαι τα μη δεοντα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.14",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "1 Timothy 5:14",
      "text": "βουλομαι ουν νεωτερας γαμειν τεκνογονειν οικοδεσποτειν μηδεμιαν αφορμην διδοναι τω αντικειμενω λοιδοριας χαριν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.15",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "1 Timothy 5:15",
      "text": "ηδη γαρ τινες εξετραπησαν οπισω του σατανα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.16",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "1 Timothy 5:16",
      "text": "ει τις πιστος η πιστη εχει χηρας επαρκειτω αυταις και μη βαρεισθω η εκκλησια ινα ταις οντως χηραις επαρκεση",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.17",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "1 Timothy 5:17",
      "text": "οι καλως προεστωτες πρεσβυτεροι διπλης τιμης αξιουσθωσαν μαλιστα οι κοπιωντες εν λογω και διδασκαλια",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.18",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "1 Timothy 5:18",
      "text": "λεγει γαρ η γραφη βουν αλοωντα ου φιμωσεις και αξιος ο εργατης του μισθου αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.19",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "1 Timothy 5:19",
      "text": "κατα πρεσβυτερου κατηγοριαν μη παραδεχου εκτος ει μη επι δυο η τριων μαρτυρων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.20",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "1 Timothy 5:20",
      "text": "τους αμαρτανοντας ενωπιον παντων ελεγχε ινα και οι λοιποι φοβον εχωσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.21",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "1 Timothy 5:21",
      "text": "διαμαρτυρομαι ενωπιον του θεου και κυριου ιησου χριστου και των εκλεκτων αγγελων ινα ταυτα φυλαξης χωρις προκριματος μηδεν ποιων κατα προσκλησιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.22",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "1 Timothy 5:22",
      "text": "χειρας ταχεως μηδενι επιτιθει μηδε κοινωνει αμαρτιαις αλλοτριαις σεαυτον αγνον τηρει",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.23",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "1 Timothy 5:23",
      "text": "μηκετι υδροποτει αλλ οινω ολιγω χρω δια τον στομαχον σου και τας πυκνας σου ασθενειας",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.24",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "1 Timothy 5:24",
      "text": "τινων ανθρωπων αι αμαρτιαι προδηλοι εισιν προαγουσαι εις κρισιν τισιν δε και επακολουθουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-timothy.5.25",
      "translationId": "byz",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "1 Timothy 5:25",
      "text": "ωσαυτως και τα καλα εργα προδηλα εστιν και τα αλλως εχοντα κρυβηναι ου δυνανται",
      "paragraphStart": false
    }
  ]
}
