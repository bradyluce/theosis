{
  "chapter": {
    "id": "byz:luke.18",
    "translationId": "byz",
    "bookSlug": "luke",
    "chapterNumber": 18,
    "referenceLabel": "Luke 18",
    "summary": "Source text for Luke 18 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:luke.18.1",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Luke 18:1",
      "text": "ελεγεν δε και παραβολην αυτοις προς το δειν παντοτε προσευχεσθαι και μη εκκακειν",
      "paragraphStart": true
    },
    {
      "id": "byz:luke.18.2",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Luke 18:2",
      "text": "λεγων κριτης τις ην εν τινι πολει τον θεον μη φοβουμενος και ανθρωπον μη εντρεπομενος",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.3",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Luke 18:3",
      "text": "χηρα δε ην εν τη πολει εκεινη και ηρχετο προς αυτον λεγουσα εκδικησον με απο του αντιδικου μου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.4",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Luke 18:4",
      "text": "και ουκ ηθελησεν επι χρονον μετα δε ταυτα ειπεν εν εαυτω ει και τον θεον ου φοβουμαι και ανθρωπον ουκ εντρεπομαι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.5",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Luke 18:5",
      "text": "δια γε το παρεχειν μοι κοπον την χηραν ταυτην εκδικησω αυτην ινα μη εις τελος ερχομενη υποπιαζη με",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.6",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Luke 18:6",
      "text": "ειπεν δε ο κυριος ακουσατε τι ο κριτης της αδικιας λεγει",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.7",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Luke 18:7",
      "text": "ο δε θεος ου μη ποιηση την εκδικησιν των εκλεκτων αυτου των βοωντων προς αυτον ημερας και νυκτος και μακροθυμων επ αυτοις",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.8",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Luke 18:8",
      "text": "λεγω υμιν οτι ποιησει την εκδικησιν αυτων εν ταχει πλην ο υιος του ανθρωπου ελθων αρα ευρησει την πιστιν επι της γης",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.9",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Luke 18:9",
      "text": "ειπεν δε προς τινας τους πεποιθοτας εφ εαυτοις οτι εισιν δικαιοι και εξουθενουντας τους λοιπους την παραβολην ταυτην",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.10",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Luke 18:10",
      "text": "ανθρωποι δυο ανεβησαν εις το ιερον προσευξασθαι ο εις φαρισαιος και ο ετερος τελωνης",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.11",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Luke 18:11",
      "text": "ο φαρισαιος σταθεις προς εαυτον ταυτα προσηυχετο ο θεος ευχαριστω σοι οτι ουκ ειμι ωσπερ οι λοιποι των ανθρωπων αρπαγες αδικοι μοιχοι η και ως ουτος ο τελωνης",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.12",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Luke 18:12",
      "text": "νηστευω δις του σαββατου αποδεκατω παντα οσα κτωμαι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.13",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "Luke 18:13",
      "text": "και ο τελωνης μακροθεν εστως ουκ ηθελεν ουδε τους οφθαλμους εις τον ουρανον επαραι αλλ ετυπτεν εις το στηθος αυτου λεγων ο θεος ιλασθητι μοι τω αμαρτωλω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.14",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "Luke 18:14",
      "text": "λεγω υμιν κατεβη ουτος δεδικαιωμενος εις τον οικον αυτου η γαρ εκεινος οτι πας ο υψων εαυτον ταπεινωθησεται ο δε ταπεινων εαυτον υψωθησεται",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.15",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "Luke 18:15",
      "text": "προσεφερον δε αυτω και τα βρεφη ινα αυτων απτηται ιδοντες δε οι μαθηται επετιμησαν αυτοις",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.16",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 16,
      "referenceLabel": "Luke 18:16",
      "text": "ο δε ιησους προσκαλεσαμενος αυτα ειπεν αφετε τα παιδια ερχεσθαι προς με και μη κωλυετε αυτα των γαρ τοιουτων εστιν η βασιλεια του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.17",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 17,
      "referenceLabel": "Luke 18:17",
      "text": "αμην λεγω υμιν ος εαν μη δεξηται την βασιλειαν του θεου ως παιδιον ου μη εισελθη εις αυτην",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.18",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 18,
      "referenceLabel": "Luke 18:18",
      "text": "και επηρωτησεν τις αυτον αρχων λεγων διδασκαλε αγαθε τι ποιησας ζωην αιωνιον κληρονομησω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.19",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 19,
      "referenceLabel": "Luke 18:19",
      "text": "ειπεν δε αυτω ο ιησους τι με λεγεις αγαθον ουδεις αγαθος ει μη εις ο θεος",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.20",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 20,
      "referenceLabel": "Luke 18:20",
      "text": "τας εντολας οιδας μη μοιχευσης μη φονευσης μη κλεψης μη ψευδομαρτυρησης τιμα τον πατερα σου και την μητερα σου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.21",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 21,
      "referenceLabel": "Luke 18:21",
      "text": "ο δε ειπεν ταυτα παντα εφυλαξαμην εκ νεοτητος μου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.22",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 22,
      "referenceLabel": "Luke 18:22",
      "text": "ακουσας δε ταυτα ο ιησους ειπεν αυτω ετι εν σοι λειπει παντα οσα εχεις πωλησον και διαδος πτωχοις και εξεις θησαυρον εν ουρανω και δευρο ακολουθει μοι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.23",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 23,
      "referenceLabel": "Luke 18:23",
      "text": "ο δε ακουσας ταυτα περιλυπος εγενετο ην γαρ πλουσιος σφοδρα",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.24",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 24,
      "referenceLabel": "Luke 18:24",
      "text": "ιδων δε αυτον ο ιησους περιλυπον γενομενον ειπεν πως δυσκολως οι τα χρηματα εχοντες εισελευσονται εις την βασιλειαν του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.25",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 25,
      "referenceLabel": "Luke 18:25",
      "text": "ευκοπωτερον γαρ εστιν καμηλον δια τρυμαλιας ραφιδος εισελθειν η πλουσιον εις την βασιλειαν του θεου εισελθειν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.26",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 26,
      "referenceLabel": "Luke 18:26",
      "text": "ειπον δε οι ακουσαντες και τις δυναται σωθηναι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.27",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 27,
      "referenceLabel": "Luke 18:27",
      "text": "ο δε ειπεν τα αδυνατα παρα ανθρωποις δυνατα εστιν παρα τω θεω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.28",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 28,
      "referenceLabel": "Luke 18:28",
      "text": "ειπεν δε πετρος ιδου ημεις αφηκαμεν παντα και ηκολουθησαμεν σοι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.29",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 29,
      "referenceLabel": "Luke 18:29",
      "text": "ο δε ειπεν αυτοις αμην λεγω υμιν οτι ουδεις εστιν ος αφηκεν οικιαν η γονεις η αδελφους η γυναικα η τεκνα ενεκεν της βασιλειας του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.30",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 30,
      "referenceLabel": "Luke 18:30",
      "text": "ος ου μη απολαβη πολλαπλασιονα εν τω καιρω τουτω και εν τω αιωνι τω ερχομενω ζωην αιωνιον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.31",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 31,
      "referenceLabel": "Luke 18:31",
      "text": "παραλαβων δε τους δωδεκα ειπεν προς αυτους ιδου αναβαινομεν εις ιεροσολυμα και τελεσθησεται παντα τα γεγραμμενα δια των προφητων τω υιω του ανθρωπου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.32",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 32,
      "referenceLabel": "Luke 18:32",
      "text": "παραδοθησεται γαρ τοις εθνεσιν και εμπαιχθησεται και υβρισθησεται και εμπτυσθησεται",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.33",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 33,
      "referenceLabel": "Luke 18:33",
      "text": "και μαστιγωσαντες αποκτενουσιν αυτον και τη ημερα τη τριτη αναστησεται",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.34",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 34,
      "referenceLabel": "Luke 18:34",
      "text": "και αυτοι ουδεν τουτων συνηκαν και ην το ρημα τουτο κεκρυμμενον απ αυτων και ουκ εγινωσκον τα λεγομενα",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.35",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 35,
      "referenceLabel": "Luke 18:35",
      "text": "εγενετο δε εν τω εγγιζειν αυτον εις ιεριχω τυφλος τις εκαθητο παρα την οδον προσαιτων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.36",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 36,
      "referenceLabel": "Luke 18:36",
      "text": "ακουσας δε οχλου διαπορευομενου επυνθανετο τι ειη τουτο",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.37",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 37,
      "referenceLabel": "Luke 18:37",
      "text": "απηγγειλαν δε αυτω οτι ιησους ο ναζωραιος παρερχεται",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.38",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 38,
      "referenceLabel": "Luke 18:38",
      "text": "και εβοησεν λεγων ιησου υιε δαυιδ ελεησον με",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.39",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 39,
      "referenceLabel": "Luke 18:39",
      "text": "και οι προαγοντες επετιμων αυτω ινα σιωπηση αυτος δε πολλω μαλλον εκραζεν υιε δαυιδ ελεησον με",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.40",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 40,
      "referenceLabel": "Luke 18:40",
      "text": "σταθεις δε ο ιησους εκελευσεν αυτον αχθηναι προς αυτον εγγισαντος δε αυτου επηρωτησεν αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.41",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 41,
      "referenceLabel": "Luke 18:41",
      "text": "λεγων τι σοι θελεις ποιησω ο δε ειπεν κυριε ινα αναβλεψω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.42",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 42,
      "referenceLabel": "Luke 18:42",
      "text": "και ο ιησους ειπεν αυτω αναβλεψον η πιστις σου σεσωκεν σε",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.18.43",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 43,
      "referenceLabel": "Luke 18:43",
      "text": "και παραχρημα ανεβλεψεν και ηκολουθει αυτω δοξαζων τον θεον και πας ο λαος ιδων εδωκεν αινον τω θεω",
      "paragraphStart": false
    }
  ]
}
