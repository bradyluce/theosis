{
  "chapter": {
    "id": "byz:luke.22",
    "translationId": "byz",
    "bookSlug": "luke",
    "chapterNumber": 22,
    "referenceLabel": "Luke 22",
    "summary": "Source text for Luke 22 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:luke.22.1",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Luke 22:1",
      "text": "ηγγιζεν δε η εορτη των αζυμων η λεγομενη πασχα",
      "paragraphStart": true
    },
    {
      "id": "byz:luke.22.2",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Luke 22:2",
      "text": "και εζητουν οι αρχιερεις και οι γραμματεις το πως ανελωσιν αυτον εφοβουντο γαρ τον λαον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.3",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Luke 22:3",
      "text": "εισηλθεν δε σατανας εις ιουδαν τον επικαλουμενον ισκαριωτην οντα εκ του αριθμου των δωδεκα",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.4",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Luke 22:4",
      "text": "και απελθων συνελαλησεν τοις αρχιερευσιν και στρατηγοις το πως αυτον παραδω αυτοις",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.5",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Luke 22:5",
      "text": "και εχαρησαν και συνεθεντο αυτω αργυριον δουναι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.6",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Luke 22:6",
      "text": "και εξωμολογησεν και εζητει ευκαιριαν του παραδουναι αυτον αυτοις ατερ οχλου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.7",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Luke 22:7",
      "text": "ηλθεν δε η ημερα των αζυμων εν η εδει θυεσθαι το πασχα",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.8",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Luke 22:8",
      "text": "και απεστειλεν πετρον και ιωαννην ειπων πορευθεντες ετοιμασατε ημιν το πασχα ινα φαγωμεν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.9",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Luke 22:9",
      "text": "οι δε ειπον αυτω που θελεις ετοιμασομεν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.10",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Luke 22:10",
      "text": "ο δε ειπεν αυτοις ιδου εισελθοντων υμων εις την πολιν συναντησει υμιν ανθρωπος κεραμιον υδατος βασταζων ακολουθησατε αυτω εις την οικιαν ου εισπορευεται",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.11",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Luke 22:11",
      "text": "και ερειτε τω οικοδεσποτη της οικιας λεγει σοι ο διδασκαλος που εστιν το καταλυμα οπου το πασχα μετα των μαθητων μου φαγω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.12",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Luke 22:12",
      "text": "κακεινος υμιν δειξει ανωγεον μεγα εστρωμενον εκει ετοιμασατε",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.13",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Luke 22:13",
      "text": "απελθοντες δε ευρον καθως ειρηκεν αυτοις και ητοιμασαν το πασχα",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.14",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Luke 22:14",
      "text": "και οτε εγενετο η ωρα ανεπεσεν και οι δωδεκα αποστολοι συν αυτω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.15",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Luke 22:15",
      "text": "και ειπεν προς αυτους επιθυμια επεθυμησα τουτο το πασχα φαγειν μεθ υμων προ του με παθειν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.16",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Luke 22:16",
      "text": "λεγω γαρ υμιν οτι ουκετι ου μη φαγω εξ αυτου εως οτου πληρωθη εν τη βασιλεια του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.17",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Luke 22:17",
      "text": "και δεξαμενος ποτηριον ευχαριστησας ειπεν λαβετε τουτο και διαμερισατε εαυτοις",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.18",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Luke 22:18",
      "text": "λεγω γαρ υμιν οτι ου μη πιω απο του γενηματος της αμπελου εως οτου η βασιλεια του θεου ελθη",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.19",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Luke 22:19",
      "text": "και λαβων αρτον ευχαριστησας εκλασεν και εδωκεν αυτοις λεγων τουτο εστιν το σωμα μου το υπερ υμων διδομενον τουτο ποιειτε εις την εμην αναμνησιν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.20",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Luke 22:20",
      "text": "ωσαυτως και το ποτηριον μετα το δειπνησαι λεγων τουτο το ποτηριον η καινη διαθηκη εν τω αιματι μου το υπερ υμων εκχυνομενον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.21",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Luke 22:21",
      "text": "πλην ιδου η χειρ του παραδιδοντος με μετ εμου επι της τραπεζης",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.22",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Luke 22:22",
      "text": "και ο μεν υιος του ανθρωπου πορευεται κατα το ωρισμενον πλην ουαι τω ανθρωπω εκεινω δι ου παραδιδοται",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.23",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Luke 22:23",
      "text": "και αυτοι ηρξαντο συζητειν προς εαυτους το τις αρα ειη εξ αυτων ο τουτο μελλων πρασσειν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.24",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Luke 22:24",
      "text": "εγενετο δε και φιλονεικια εν αυτοις το τις αυτων δοκει ειναι μειζων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.25",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Luke 22:25",
      "text": "ο δε ειπεν αυτοις οι βασιλεις των εθνων κυριευουσιν αυτων και οι εξουσιαζοντες αυτων ευεργεται καλουνται",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.26",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Luke 22:26",
      "text": "υμεις δε ουχ ουτως αλλ ο μειζων εν υμιν γενεσθω ως ο νεωτερος και ο ηγουμενος ως ο διακονων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.27",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Luke 22:27",
      "text": "τις γαρ μειζων ο ανακειμενος η ο διακονων ουχι ο ανακειμενος εγω δε ειμι εν μεσω υμων ως ο διακονων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.28",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Luke 22:28",
      "text": "υμεις δε εστε οι διαμεμενηκοτες μετ εμου εν τοις πειρασμοις μου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.29",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Luke 22:29",
      "text": "καγω διατιθεμαι υμιν καθως διεθετο μοι ο πατηρ μου βασιλειαν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.30",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "Luke 22:30",
      "text": "ινα εσθιητε και πινητε επι της τραπεζης μου και καθισεσθε επι θρονων κρινοντες τας δωδεκα φυλας του ισραηλ",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.31",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 31,
      "referenceLabel": "Luke 22:31",
      "text": "ειπεν δε ο κυριος σιμων σιμων ιδου ο σατανας εξητησατο υμας του σινιασαι ως τον σιτον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.32",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 32,
      "referenceLabel": "Luke 22:32",
      "text": "εγω δε εδεηθην περι σου ινα μη εκλιπη η πιστις σου και συ ποτε επιστρεψας στηριξον τους αδελφους σου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.33",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 33,
      "referenceLabel": "Luke 22:33",
      "text": "ο δε ειπεν αυτω κυριε μετα σου ετοιμος ειμι και εις φυλακην και εις θανατον πορευεσθαι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.34",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 34,
      "referenceLabel": "Luke 22:34",
      "text": "ο δε ειπεν λεγω σοι πετρε ου μη φωνηση σημερον αλεκτωρ πριν η τρις απαρνηση μη ειδεναι με",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.35",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 35,
      "referenceLabel": "Luke 22:35",
      "text": "και ειπεν αυτοις οτε απεστειλα υμας ατερ βαλαντιου και πηρας και υποδηματων μη τινος υστερησατε οι δε ειπον ουθενος",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.36",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 36,
      "referenceLabel": "Luke 22:36",
      "text": "ειπεν ουν αυτοις αλλα νυν ο εχων βαλαντιον αρατω ομοιως και πηραν και ο μη εχων πωλησει το ιματιον αυτου και αγορασει μαχαιραν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.37",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 37,
      "referenceLabel": "Luke 22:37",
      "text": "λεγω γαρ υμιν οτι ετι τουτο το γεγραμμενον δει τελεσθηναι εν εμοι το και μετα ανομων ελογισθη και γαρ τα περι εμου τελος εχει",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.38",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 38,
      "referenceLabel": "Luke 22:38",
      "text": "οι δε ειπον κυριε ιδου μαχαιραι ωδε δυο ο δε ειπεν αυτοις ικανον εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.39",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 39,
      "referenceLabel": "Luke 22:39",
      "text": "και εξελθων επορευθη κατα το εθος εις το ορος των ελαιων ηκολουθησαν δε αυτω και οι μαθηται αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.40",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 40,
      "referenceLabel": "Luke 22:40",
      "text": "γενομενος δε επι του τοπου ειπεν αυτοις προσευχεσθε μη εισελθειν εις πειρασμον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.41",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 41,
      "referenceLabel": "Luke 22:41",
      "text": "και αυτος απεσπασθη απ αυτων ωσει λιθου βολην και θεις τα γονατα προσηυχετο",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.42",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 42,
      "referenceLabel": "Luke 22:42",
      "text": "λεγων πατερ ει βουλει παρενεγκειν το ποτηριον τουτο απ εμου πλην μη το θελημα μου αλλα το σον γενεσθω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.43",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 43,
      "referenceLabel": "Luke 22:43",
      "text": "ωφθη δε αυτω αγγελος απ ουρανου ενισχυων αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.44",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 44,
      "referenceLabel": "Luke 22:44",
      "text": "και γενομενος εν αγωνια εκτενεστερον προσηυχετο εγενετο δε ο ιδρως αυτου ωσει θρομβοι αιματος καταβαινοντες επι την γην",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.45",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 45,
      "referenceLabel": "Luke 22:45",
      "text": "και αναστας απο της προσευχης ελθων προς τους μαθητας ευρεν αυτους κοιμωμενους απο της λυπης",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.46",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 46,
      "referenceLabel": "Luke 22:46",
      "text": "και ειπεν αυτοις τι καθευδετε ανασταντες προσευχεσθε ινα μη εισελθητε εις πειρασμον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.47",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 47,
      "referenceLabel": "Luke 22:47",
      "text": "ετι δε αυτου λαλουντος ιδου οχλος και ο λεγομενος ιουδας εις των δωδεκα προηρχετο αυτους και ηγγισεν τω ιησου φιλησαι αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.48",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 48,
      "referenceLabel": "Luke 22:48",
      "text": "ο δε ιησους ειπεν αυτω ιουδα φιληματι τον υιον του ανθρωπου παραδιδως",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.49",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 49,
      "referenceLabel": "Luke 22:49",
      "text": "ιδοντες δε οι περι αυτον το εσομενον ειπον αυτω κυριε ει παταξομεν εν μαχαιρα",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.50",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 50,
      "referenceLabel": "Luke 22:50",
      "text": "και επαταξεν εις τις εξ αυτων τον δουλον του αρχιερεως και αφειλεν αυτου το ους το δεξιον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.51",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 51,
      "referenceLabel": "Luke 22:51",
      "text": "αποκριθεις δε ο ιησους ειπεν εατε εως τουτου και αψαμενος του ωτιου αυτου ιασατο αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.52",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 52,
      "referenceLabel": "Luke 22:52",
      "text": "ειπεν δε ο ιησους προς τους παραγενομενους επ αυτον αρχιερεις και στρατηγους του ιερου και πρεσβυτερους ως επι ληστην εξεληλυθατε μετα μαχαιρων και ξυλων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.53",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 53,
      "referenceLabel": "Luke 22:53",
      "text": "καθ ημεραν οντος μου μεθ υμων εν τω ιερω ουκ εξετεινατε τας χειρας επ εμε αλλ αυτη υμων εστιν η ωρα και η εξουσια του σκοτους",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.54",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 54,
      "referenceLabel": "Luke 22:54",
      "text": "συλλαβοντες δε αυτον ηγαγον και εισηγαγον αυτον εις τον οικον του αρχιερεως ο δε πετρος ηκολουθει μακροθεν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.55",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 55,
      "referenceLabel": "Luke 22:55",
      "text": "αψαντων δε πυρ εν μεσω της αυλης και συγκαθισαντων αυτων εκαθητο ο πετρος εν μεσω αυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.22.56",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 56,
