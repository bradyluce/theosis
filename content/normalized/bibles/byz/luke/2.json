{
  "chapter": {
    "id": "byz:luke.2",
    "translationId": "byz",
    "bookSlug": "luke",
    "chapterNumber": 2,
    "referenceLabel": "Luke 2",
    "summary": "Source text for Luke 2 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:luke.2.1",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Luke 2:1",
      "text": "εγενετο δε εν ταις ημεραις εκειναις εξηλθεν δογμα παρα καισαρος αυγουστου απογραφεσθαι πασαν την οικουμενην",
      "paragraphStart": true
    },
    {
      "id": "byz:luke.2.2",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Luke 2:2",
      "text": "αυτη η απογραφη πρωτη εγενετο ηγεμονευοντος της συριας κυρηνιου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.3",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Luke 2:3",
      "text": "και επορευοντο παντες απογραφεσθαι εκαστος εις την ιδιαν πολιν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.4",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Luke 2:4",
      "text": "ανεβη δε και ιωσηφ απο της γαλιλαιας εκ πολεως ναζαρετ εις την ιουδαιαν εις πολιν δαυιδ ητις καλειται βηθλεεμ δια το ειναι αυτον εξ οικου και πατριας δαυιδ",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.5",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Luke 2:5",
      "text": "απογραψασθαι συν μαριαμ τη μεμνηστευμενη αυτω γυναικι ουση εγκυω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.6",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Luke 2:6",
      "text": "εγενετο δε εν τω ειναι αυτους εκει επλησθησαν αι ημεραι του τεκειν αυτην",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.7",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Luke 2:7",
      "text": "και ετεκεν τον υιον αυτης τον πρωτοτοκον και εσπαργανωσεν αυτον και ανεκλινεν αυτον εν τη φατνη διοτι ουκ ην αυτοις τοπος εν τω καταλυματι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.8",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Luke 2:8",
      "text": "και ποιμενες ησαν εν τη χωρα τη αυτη αγραυλουντες και φυλασσοντες φυλακας της νυκτος επι την ποιμνην αυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.9",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Luke 2:9",
      "text": "και ιδου αγγελος κυριου επεστη αυτοις και δοξα κυριου περιελαμψεν αυτους και εφοβηθησαν φοβον μεγαν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.10",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Luke 2:10",
      "text": "και ειπεν αυτοις ο αγγελος μη φοβεισθε ιδου γαρ ευαγγελιζομαι υμιν χαραν μεγαλην ητις εσται παντι τω λαω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.11",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Luke 2:11",
      "text": "οτι ετεχθη υμιν σημερον σωτηρ ος εστιν χριστος κυριος εν πολει δαυιδ",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.12",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Luke 2:12",
      "text": "και τουτο υμιν το σημειον ευρησετε βρεφος εσπαργανωμενον κειμενον εν φατνη",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.13",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Luke 2:13",
      "text": "και εξαιφνης εγενετο συν τω αγγελω πληθος στρατιας ουρανιου αινουντων τον θεον και λεγοντων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.14",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Luke 2:14",
      "text": "δοξα εν υψιστοις θεω και επι γης ειρηνη εν ανθρωποις ευδοκια",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.15",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Luke 2:15",
      "text": "και εγενετο ως απηλθον απ αυτων εις τον ουρανον οι αγγελοι και οι ανθρωποι οι ποιμενες ειπον προς αλληλους διελθωμεν δη εως βηθλεεμ και ιδωμεν το ρημα τουτο το γεγονος ο ο κυριος εγνωρισεν ημιν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.16",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Luke 2:16",
      "text": "και ηλθον σπευσαντες και ανευρον την τε μαριαμ και τον ιωσηφ και το βρεφος κειμενον εν τη φατνη",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.17",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Luke 2:17",
      "text": "ιδοντες δε διεγνωρισαν περι του ρηματος του λαληθεντος αυτοις περι του παιδιου τουτου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.18",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Luke 2:18",
      "text": "και παντες οι ακουσαντες εθαυμασαν περι των λαληθεντων υπο των ποιμενων προς αυτους",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.19",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Luke 2:19",
      "text": "η δε μαριαμ παντα συνετηρει τα ρηματα ταυτα συμβαλλουσα εν τη καρδια αυτης",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.20",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Luke 2:20",
      "text": "και υπεστρεψαν οι ποιμενες δοξαζοντες και αινουντες τον θεον επι πασιν οις ηκουσαν και ειδον καθως ελαληθη προς αυτους",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.21",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Luke 2:21",
      "text": "και οτε επλησθησαν ημεραι οκτω του περιτεμειν αυτον και εκληθη το ονομα αυτου ιησους το κληθεν υπο του αγγελου προ του συλληφθηναι αυτον εν τη κοιλια",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.22",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Luke 2:22",
      "text": "και οτε επλησθησαν αι ημεραι του καθαρισμου αυτων κατα τον νομον μωσεως ανηγαγον αυτον εις ιεροσολυμα παραστησαι τω κυριω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.23",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Luke 2:23",
      "text": "καθως γεγραπται εν νομω κυριου οτι παν αρσεν διανοιγον μητραν αγιον τω κυριω κληθησεται",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.24",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "Luke 2:24",
      "text": "και του δουναι θυσιαν κατα το ειρημενον εν νομω κυριου ζευγος τρυγονων η δυο νεοσσους περιστερων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.25",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "Luke 2:25",
      "text": "και ιδου ην ανθρωπος εν ιερουσαλημ ω ονομα συμεων και ο ανθρωπος ουτος δικαιος και ευλαβης προσδεχομενος παρακλησιν του ισραηλ και πνευμα ην αγιον επ αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.26",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "Luke 2:26",
      "text": "και ην αυτω κεχρηματισμενον υπο του πνευματος του αγιου μη ιδειν θανατον πριν η ιδη τον χριστον κυριου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.27",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "Luke 2:27",
      "text": "και ηλθεν εν τω πνευματι εις το ιερον και εν τω εισαγαγειν τους γονεις το παιδιον ιησουν του ποιησαι αυτους κατα το ειθισμενον του νομου περι αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.28",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "Luke 2:28",
      "text": "και αυτος εδεξατο αυτο εις τας αγκαλας αυτου και ευλογησεν τον θεον και ειπεν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.29",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 29,
      "referenceLabel": "Luke 2:29",
      "text": "νυν απολυεις τον δουλον σου δεσποτα κατα το ρημα σου εν ειρηνη",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.30",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 30,
      "referenceLabel": "Luke 2:30",
      "text": "οτι ειδον οι οφθαλμοι μου το σωτηριον σου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.31",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 31,
      "referenceLabel": "Luke 2:31",
      "text": "ο ητοιμασας κατα προσωπον παντων των λαων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.32",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 32,
      "referenceLabel": "Luke 2:32",
      "text": "φως εις αποκαλυψιν εθνων και δοξαν λαου σου ισραηλ",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.33",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 33,
      "referenceLabel": "Luke 2:33",
      "text": "και ην ιωσηφ και η μητηρ αυτου θαυμαζοντες επι τοις λαλουμενοις περι αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.34",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 34,
      "referenceLabel": "Luke 2:34",
      "text": "και ευλογησεν αυτους συμεων και ειπεν προς μαριαμ την μητερα αυτου ιδου ουτος κειται εις πτωσιν και αναστασιν πολλων εν τω ισραηλ και εις σημειον αντιλεγομενον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.35",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 35,
      "referenceLabel": "Luke 2:35",
      "text": "και σου δε αυτης την ψυχην διελευσεται ρομφαια οπως αν αποκαλυφθωσιν εκ πολλων καρδιων διαλογισμοι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.36",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 36,
      "referenceLabel": "Luke 2:36",
      "text": "και ην αννα προφητις θυγατηρ φανουηλ εκ φυλης ασηρ αυτη προβεβηκυια εν ημεραις πολλαις ζησασα ετη μετα ανδρος επτα απο της παρθενιας αυτης",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.37",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 37,
      "referenceLabel": "Luke 2:37",
      "text": "και αυτη χηρα ως ετων ογδοηκοντα τεσσαρων η ουκ αφιστατο απο του ιερου νηστειαις και δεησεσιν λατρευουσα νυκτα και ημεραν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.38",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 38,
      "referenceLabel": "Luke 2:38",
      "text": "και αυτη αυτη τη ωρα επιστασα ανθωμολογειτο τω κυριω και ελαλει περι αυτου πασιν τοις προσδεχομενοις λυτρωσιν εν ιερουσαλημ",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.39",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 39,
      "referenceLabel": "Luke 2:39",
      "text": "και ως ετελεσαν απαντα τα κατα τον νομον κυριου υπεστρεψαν εις την γαλιλαιαν εις την πολιν εαυτων ναζαρετ",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.40",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 40,
      "referenceLabel": "Luke 2:40",
      "text": "το δε παιδιον ηυξανεν και εκραταιουτο πνευματι πληρουμενον σοφιας και χαρις θεου ην επ αυτο",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.41",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 41,
      "referenceLabel": "Luke 2:41",
      "text": "και επορευοντο οι γονεις αυτου κατ ετος εις ιερουσαλημ τη εορτη του πασχα",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.42",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 42,
      "referenceLabel": "Luke 2:42",
      "text": "και οτε εγενετο ετων δωδεκα αναβαντων αυτων εις ιεροσολυμα κατα το εθος της εορτης",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.43",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 43,
      "referenceLabel": "Luke 2:43",
      "text": "και τελειωσαντων τας ημερας εν τω υποστρεφειν αυτους υπεμεινεν ιησους ο παις εν ιερουσαλημ και ουκ εγνω ιωσηφ και η μητηρ αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.44",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 44,
      "referenceLabel": "Luke 2:44",
      "text": "νομισαντες δε αυτον εν τη συνοδια ειναι ηλθον ημερας οδον και ανεζητουν αυτον εν τοις συγγενεσιν και εν τοις γνωστοις",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.45",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 45,
      "referenceLabel": "Luke 2:45",
      "text": "και μη ευροντες αυτον υπεστρεψαν εις ιερουσαλημ ζητουντες αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.46",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 46,
      "referenceLabel": "Luke 2:46",
      "text": "και εγενετο μεθ ημερας τρεις ευρον αυτον εν τω ιερω καθεζομενον εν μεσω των διδασκαλων και ακουοντα αυτων και επερωτωντα αυτους",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.47",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 47,
      "referenceLabel": "Luke 2:47",
      "text": "εξισταντο δε παντες οι ακουοντες αυτου επι τη συνεσει και ταις αποκρισεσιν αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.48",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 48,
      "referenceLabel": "Luke 2:48",
      "text": "και ιδοντες αυτον εξεπλαγησαν και προς αυτον η μητηρ αυτου ειπεν τεκνον τι εποιησας ημιν ουτως ιδου ο πατηρ σου καγω οδυνωμενοι εζητουμεν σε",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.49",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 49,
      "referenceLabel": "Luke 2:49",
      "text": "και ειπεν προς αυτους τι οτι εζητειτε με ουκ ηδειτε οτι εν τοις του πατρος μου δει ειναι με",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.50",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 50,
      "referenceLabel": "Luke 2:50",
      "text": "και αυτοι ου συνηκαν το ρημα ο ελαλησεν αυτοις",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.51",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 51,
      "referenceLabel": "Luke 2:51",
      "text": "και κατεβη μετ αυτων και ηλθεν εις ναζαρετ και ην υποτασσομενος αυτοις και η μητηρ αυτου διετηρει παντα τα ρηματα ταυτα εν τη καρδια αυτης",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.2.52",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 52,
      "referenceLabel": "Luke 2:52",
      "text": "και ιησους προεκοπτεν σοφια και ηλικια και χαριτι παρα θεω και ανθρωποις",
      "paragraphStart": false
    }
  ]
}
