{
  "chapter": {
    "id": "byz:luke.23",
    "translationId": "byz",
    "bookSlug": "luke",
    "chapterNumber": 23,
    "referenceLabel": "Luke 23",
    "summary": "Source text for Luke 23 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:luke.23.1",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Luke 23:1",
      "text": "και ανασταν απαν το πληθος αυτων ηγαγον αυτον επι τον πιλατον",
      "paragraphStart": true
    },
    {
      "id": "byz:luke.23.2",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Luke 23:2",
      "text": "ηρξαντο δε κατηγορειν αυτου λεγοντες τουτον ευρομεν διαστρεφοντα το εθνος και κωλυοντα καισαρι φορους διδοναι λεγοντα εαυτον χριστον βασιλεα ειναι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.3",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Luke 23:3",
      "text": "ο δε πιλατος επηρωτησεν αυτον λεγων συ ει ο βασιλευς των ιουδαιων ο δε αποκριθεις αυτω εφη συ λεγεις",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.4",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Luke 23:4",
      "text": "ο δε πιλατος ειπεν προς τους αρχιερεις και τους οχλους ουδεν ευρισκω αιτιον εν τω ανθρωπω τουτω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.5",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Luke 23:5",
      "text": "οι δε επισχυον λεγοντες οτι ανασειει τον λαον διδασκων καθ ολης της ιουδαιας αρξαμενος απο της γαλιλαιας εως ωδε",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.6",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Luke 23:6",
      "text": "πιλατος δε ακουσας γαλιλαιαν επηρωτησεν ει ο ανθρωπος γαλιλαιος εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.7",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Luke 23:7",
      "text": "και επιγνους οτι εκ της εξουσιας ηρωδου εστιν ανεπεμψεν αυτον προς ηρωδην οντα και αυτον εν ιεροσολυμοις εν ταυταις ταις ημεραις",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.8",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Luke 23:8",
      "text": "ο δε ηρωδης ιδων τον ιησουν εχαρη λιαν ην γαρ θελων εξ ικανου ιδειν αυτον δια το ακουειν πολλα περι αυτου και ηλπιζεν τι σημειον ιδειν υπ αυτου γινομενον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.9",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Luke 23:9",
      "text": "επηρωτα δε αυτον εν λογοις ικανοις αυτος δε ουδεν απεκρινατο αυτω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.10",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Luke 23:10",
      "text": "ειστηκεισαν δε οι αρχιερεις και οι γραμματεις ευτονως κατηγορουντες αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.11",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "Luke 23:11",
      "text": "εξουθενησας δε αυτον ο ηρωδης συν τοις στρατευμασιν αυτου και εμπαιξας περιβαλων αυτον εσθητα λαμπραν ανεπεμψεν αυτον τω πιλατω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.12",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "Luke 23:12",
      "text": "εγενοντο δε φιλοι ο τε πιλατος και ο ηρωδης εν αυτη τη ημερα μετ αλληλων προυπηρχον γαρ εν εχθρα οντες προς εαυτους",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.13",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "Luke 23:13",
      "text": "πιλατος δε συγκαλεσαμενος τους αρχιερεις και τους αρχοντας και τον λαον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.14",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "Luke 23:14",
      "text": "ειπεν προς αυτους προσηνεγκατε μοι τον ανθρωπον τουτον ως αποστρεφοντα τον λαον και ιδου εγω ενωπιον υμων ανακρινας ουδεν ευρον εν τω ανθρωπω τουτω αιτιον ων κατηγορειτε κατ αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.15",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "Luke 23:15",
      "text": "αλλ ουδε ηρωδης ανεπεμψα γαρ υμας προς αυτον και ιδου ουδεν αξιον θανατου εστιν πεπραγμενον αυτω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.16",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "Luke 23:16",
      "text": "παιδευσας ουν αυτον απολυσω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.17",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "Luke 23:17",
      "text": "αναγκην δε ειχεν απολυειν αυτοις κατα εορτην ενα",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.18",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 18,
      "referenceLabel": "Luke 23:18",
      "text": "ανεκραξαν δε παμπληθει λεγοντες αιρε τουτον απολυσον δε ημιν βαραββαν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.19",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 19,
      "referenceLabel": "Luke 23:19",
      "text": "οστις ην δια στασιν τινα γενομενην εν τη πολει και φονον βεβλημενος εις φυλακην",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.20",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 20,
      "referenceLabel": "Luke 23:20",
      "text": "παλιν ουν ο πιλατος προσεφωνησεν θελων απολυσαι τον ιησουν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.21",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 21,
      "referenceLabel": "Luke 23:21",
      "text": "οι δε επεφωνουν λεγοντες σταυρωσον σταυρωσον αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.22",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 22,
      "referenceLabel": "Luke 23:22",
      "text": "ο δε τριτον ειπεν προς αυτους τι γαρ κακον εποιησεν ουτος ουδεν αιτιον θανατου ευρον εν αυτω παιδευσας ουν αυτον απολυσω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.23",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 23,
      "referenceLabel": "Luke 23:23",
      "text": "οι δε επεκειντο φωναις μεγαλαις αιτουμενοι αυτον σταυρωθηναι και κατισχυον αι φωναι αυτων και των αρχιερεων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.24",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 24,
      "referenceLabel": "Luke 23:24",
      "text": "ο δε πιλατος επεκρινεν γενεσθαι το αιτημα αυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.25",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 25,
      "referenceLabel": "Luke 23:25",
      "text": "απελυσεν δε τον δια στασιν και φονον βεβλημενον εις την φυλακην ον ητουντο τον δε ιησουν παρεδωκεν τω θεληματι αυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.26",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 26,
      "referenceLabel": "Luke 23:26",
      "text": "και ως απηγαγον αυτον επιλαβομενοι σιμωνος τινος κυρηναιου ερχομενου απ αγρου επεθηκαν αυτω τον σταυρον φερειν οπισθεν του ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.27",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 27,
      "referenceLabel": "Luke 23:27",
      "text": "ηκολουθει δε αυτω πολυ πληθος του λαου και γυναικων αι και εκοπτοντο και εθρηνουν αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.28",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 28,
      "referenceLabel": "Luke 23:28",
      "text": "στραφεις δε προς αυτας ο ιησους ειπεν θυγατερες ιερουσαλημ μη κλαιετε επ εμε πλην εφ εαυτας κλαιετε και επι τα τεκνα υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.29",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 29,
      "referenceLabel": "Luke 23:29",
      "text": "οτι ιδου ερχονται ημεραι εν αις ερουσιν μακαριαι αι στειραι και κοιλιαι αι ουκ εγεννησαν και μαστοι οι ουκ εθηλασαν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.30",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 30,
      "referenceLabel": "Luke 23:30",
      "text": "τοτε αρξονται λεγειν τοις ορεσιν πεσετε εφ ημας και τοις βουνοις καλυψατε ημας",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.31",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 31,
      "referenceLabel": "Luke 23:31",
      "text": "οτι ει εν τω υγρω ξυλω ταυτα ποιουσιν εν τω ξηρω τι γενηται",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.32",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 32,
      "referenceLabel": "Luke 23:32",
      "text": "ηγοντο δε και ετεροι δυο κακουργοι συν αυτω αναιρεθηναι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.33",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 33,
      "referenceLabel": "Luke 23:33",
      "text": "και οτε απηλθον επι τον τοπον τον καλουμενον κρανιον εκει εσταυρωσαν αυτον και τους κακουργους ον μεν εκ δεξιων ον δε εξ αριστερων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.34",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 34,
      "referenceLabel": "Luke 23:34",
      "text": "ο δε ιησους ελεγεν πατερ αφες αυτοις ου γαρ οιδασιν τι ποιουσιν διαμεριζομενοι δε τα ιματια αυτου εβαλον κληρον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.35",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 35,
      "referenceLabel": "Luke 23:35",
      "text": "και ειστηκει ο λαος θεωρων εξεμυκτηριζον δε και οι αρχοντες συν αυτοις λεγοντες αλλους εσωσεν σωσατω εαυτον ει ουτος εστιν ο χριστος ο του θεου εκλεκτος",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.36",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 36,
      "referenceLabel": "Luke 23:36",
      "text": "ενεπαιζον δε αυτω και οι στρατιωται προσερχομενοι και οξος προσφεροντες αυτω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.37",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 37,
      "referenceLabel": "Luke 23:37",
      "text": "και λεγοντες ει συ ει ο βασιλευς των ιουδαιων σωσον σεαυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.38",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 38,
      "referenceLabel": "Luke 23:38",
      "text": "ην δε και επιγραφη γεγραμμενη επ αυτω γραμμασιν ελληνικοις και ρωμαικοις και εβραικοις ουτος εστιν ο βασιλευς των ιουδαιων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.39",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 39,
      "referenceLabel": "Luke 23:39",
      "text": "εις δε των κρεμασθεντων κακουργων εβλασφημει αυτον λεγων ει συ ει ο χριστος σωσον σεαυτον και ημας",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.40",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 40,
      "referenceLabel": "Luke 23:40",
      "text": "αποκριθεις δε ο ετερος επετιμα αυτω λεγων ουδε φοβη συ τον θεον οτι εν τω αυτω κριματι ει",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.41",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 41,
      "referenceLabel": "Luke 23:41",
      "text": "και ημεις μεν δικαιως αξια γαρ ων επραξαμεν απολαμβανομεν ουτος δε ουδεν ατοπον επραξεν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.42",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 42,
      "referenceLabel": "Luke 23:42",
      "text": "και ελεγεν τω ιησου μνησθητι μου κυριε οταν ελθης εν τη βασιλεια σου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.43",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 43,
      "referenceLabel": "Luke 23:43",
      "text": "και ειπεν αυτω ο ιησους αμην λεγω σοι σημερον μετ εμου εση εν τω παραδεισω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.44",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 44,
      "referenceLabel": "Luke 23:44",
      "text": "ην δε ωσει ωρα εκτη και σκοτος εγενετο εφ ολην την γην εως ωρας ενατης",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.45",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 45,
      "referenceLabel": "Luke 23:45",
      "text": "και εσκοτισθη ο ηλιος και εσχισθη το καταπετασμα του ναου μεσον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.46",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 46,
      "referenceLabel": "Luke 23:46",
      "text": "και φωνησας φωνη μεγαλη ο ιησους ειπεν πατερ εις χειρας σου παραθησομαι το πνευμα μου και ταυτα ειπων εξεπνευσεν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.47",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 47,
      "referenceLabel": "Luke 23:47",
      "text": "ιδων δε ο εκατονταρχος το γενομενον εδοξασεν τον θεον λεγων οντως ο ανθρωπος ουτος δικαιος ην",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.48",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 48,
      "referenceLabel": "Luke 23:48",
      "text": "και παντες οι συμπαραγενομενοι οχλοι επι την θεωριαν ταυτην θεωρουντες τα γενομενα τυπτοντες εαυτων τα στηθη υπεστρεφον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.49",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 49,
      "referenceLabel": "Luke 23:49",
      "text": "ειστηκεισαν δε παντες οι γνωστοι αυτου μακροθεν και γυναικες αι συνακολουθησασαι αυτω απο της γαλιλαιας ορωσαι ταυτα",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.50",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 50,
      "referenceLabel": "Luke 23:50",
      "text": "και ιδου ανηρ ονοματι ιωσηφ βουλευτης υπαρχων ανηρ αγαθος και δικαιος",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.51",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 51,
      "referenceLabel": "Luke 23:51",
      "text": "ουτος ουκ ην συγκατατεθειμενος τη βουλη και τη πραξει αυτων απο αριμαθαιας πολεως των ιουδαιων ος και προσεδεχετο και αυτος την βασιλειαν του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.52",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 52,
      "referenceLabel": "Luke 23:52",
      "text": "ουτος προσελθων τω πιλατω ητησατο το σωμα του ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.53",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 53,
      "referenceLabel": "Luke 23:53",
      "text": "και καθελων αυτο ενετυλιξεν αυτο σινδονι και εθηκεν αυτο εν μνηματι λαξευτω ου ουκ ην ουδεπω ουδεις κειμενος",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.54",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 54,
      "referenceLabel": "Luke 23:54",
      "text": "και ημερα ην παρασκευη σαββατον επεφωσκεν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.23.55",
