{
  "chapter": {
    "id": "byz:luke.19",
    "translationId": "byz",
    "bookSlug": "luke",
    "chapterNumber": 19,
    "referenceLabel": "Luke 19",
    "summary": "Source text for Luke 19 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:luke.19.1",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Luke 19:1",
      "text": "και εισελθων διηρχετο την ιεριχω",
      "paragraphStart": true
    },
    {
      "id": "byz:luke.19.2",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Luke 19:2",
      "text": "και ιδου ανηρ ονοματι καλουμενος ζακχαιος και αυτος ην αρχιτελωνης και ουτος ην πλουσιος",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.3",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Luke 19:3",
      "text": "και εζητει ιδειν τον ιησουν τις εστιν και ουκ ηδυνατο απο του οχλου οτι τη ηλικια μικρος ην",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.4",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Luke 19:4",
      "text": "και προδραμων εμπροσθεν ανεβη επι συκομωραιαν ινα ιδη αυτον οτι εκεινης εμελλεν διερχεσθαι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.5",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Luke 19:5",
      "text": "και ως ηλθεν επι τον τοπον αναβλεψας ο ιησους ειδεν αυτον και ειπεν προς αυτον ζακχαιε σπευσας καταβηθι σημερον γαρ εν τω οικω σου δει με μειναι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.6",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Luke 19:6",
      "text": "και σπευσας κατεβη και υπεδεξατο αυτον χαιρων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.7",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Luke 19:7",
      "text": "και ιδοντες παντες διεγογγυζον λεγοντες οτι παρα αμαρτωλω ανδρι εισηλθεν καταλυσαι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.8",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Luke 19:8",
      "text": "σταθεις δε ζακχαιος ειπεν προς τον κυριον ιδου τα ημιση των υπαρχοντων μου κυριε διδωμι τοις πτωχοις και ει τινος τι εσυκοφαντησα αποδιδωμι τετραπλουν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.9",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Luke 19:9",
      "text": "ειπεν δε προς αυτον ο ιησους οτι σημερον σωτηρια τω οικω τουτω εγενετο καθοτι και αυτος υιος αβρααμ εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.10",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Luke 19:10",
      "text": "ηλθεν γαρ ο υιος του ανθρωπου ζητησαι και σωσαι το απολωλος",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.11",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Luke 19:11",
      "text": "ακουοντων δε αυτων ταυτα προσθεις ειπεν παραβολην δια το εγγυς αυτον ειναι ιερουσαλημ και δοκειν αυτους οτι παραχρημα μελλει η βασιλεια του θεου αναφαινεσθαι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.12",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Luke 19:12",
      "text": "ειπεν ουν ανθρωπος τις ευγενης επορευθη εις χωραν μακραν λαβειν εαυτω βασιλειαν και υποστρεψαι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.13",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Luke 19:13",
      "text": "καλεσας δε δεκα δουλους εαυτου εδωκεν αυτοις δεκα μνας και ειπεν προς αυτους πραγματευσασθε εως ερχομαι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.14",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Luke 19:14",
      "text": "οι δε πολιται αυτου εμισουν αυτον και απεστειλαν πρεσβειαν οπισω αυτου λεγοντες ου θελομεν τουτον βασιλευσαι εφ ημας",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.15",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Luke 19:15",
      "text": "και εγενετο εν τω επανελθειν αυτον λαβοντα την βασιλειαν και ειπεν φωνηθηναι αυτω τους δουλους τουτους οις εδωκεν το αργυριον ινα γνω τις τι διεπραγματευσατο",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.16",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "Luke 19:16",
      "text": "παρεγενετο δε ο πρωτος λεγων κυριε η μνα σου προσειργασατο δεκα μνας",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.17",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "Luke 19:17",
      "text": "και ειπεν αυτω ευ αγαθε δουλε οτι εν ελαχιστω πιστος εγενου ισθι εξουσιαν εχων επανω δεκα πολεων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.18",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "Luke 19:18",
      "text": "και ηλθεν ο δευτερος λεγων κυριε η μνα σου εποιησεν πεντε μνας",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.19",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "Luke 19:19",
      "text": "ειπεν δε και τουτω και συ γινου επανω πεντε πολεων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.20",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "Luke 19:20",
      "text": "και ετερος ηλθεν λεγων κυριε ιδου η μνα σου ην ειχον αποκειμενην εν σουδαριω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.21",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "Luke 19:21",
      "text": "εφοβουμην γαρ σε οτι ανθρωπος αυστηρος ει αιρεις ο ουκ εθηκας και θεριζεις ο ουκ εσπειρας",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.22",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 22,
      "referenceLabel": "Luke 19:22",
      "text": "λεγει δε αυτω εκ του στοματος σου κρινω σε πονηρε δουλε ηδεις οτι εγω ανθρωπος αυστηρος ειμι αιρων ο ουκ εθηκα και θεριζων ο ουκ εσπειρα",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.23",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 23,
      "referenceLabel": "Luke 19:23",
      "text": "και δια τι ουκ εδωκας το αργυριον μου επι τραπεζαν και εγω ελθων συν τοκω αν επραξα αυτο",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.24",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 24,
      "referenceLabel": "Luke 19:24",
      "text": "και τοις παρεστωσιν ειπεν αρατε απ αυτου την μναν και δοτε τω τας δεκα μνας εχοντι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.25",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 25,
      "referenceLabel": "Luke 19:25",
      "text": "και ειπον αυτω κυριε εχει δεκα μνας",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.26",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 26,
      "referenceLabel": "Luke 19:26",
      "text": "λεγω γαρ υμιν οτι παντι τω εχοντι δοθησεται απο δε του μη εχοντος και ο εχει αρθησεται απ αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.27",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 27,
      "referenceLabel": "Luke 19:27",
      "text": "πλην τους εχθρους μου εκεινους τους μη θελησαντας με βασιλευσαι επ αυτους αγαγετε ωδε και κατασφαξατε εμπροσθεν μου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.28",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 28,
      "referenceLabel": "Luke 19:28",
      "text": "και ειπων ταυτα επορευετο εμπροσθεν αναβαινων εις ιεροσολυμα",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.29",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 29,
      "referenceLabel": "Luke 19:29",
      "text": "και εγενετο ως ηγγισεν εις βηθσφαγη και βηθανιαν προς το ορος το καλουμενον ελαιων απεστειλεν δυο των μαθητων αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.30",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 30,
      "referenceLabel": "Luke 19:30",
      "text": "ειπων υπαγετε εις την κατεναντι κωμην εν η εισπορευομενοι ευρησετε πωλον δεδεμενον εφ ον ουδεις πωποτε ανθρωπων εκαθισεν λυσαντες αυτον αγαγετε",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.31",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 31,
      "referenceLabel": "Luke 19:31",
      "text": "και εαν τις υμας ερωτα δια τι λυετε ουτως ερειτε αυτω οτι ο κυριος αυτου χρειαν εχει",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.32",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 32,
      "referenceLabel": "Luke 19:32",
      "text": "απελθοντες δε οι απεσταλμενοι ευρον καθως ειπεν αυτοις",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.33",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 33,
      "referenceLabel": "Luke 19:33",
      "text": "λυοντων δε αυτων τον πωλον ειπον οι κυριοι αυτου προς αυτους τι λυετε τον πωλον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.34",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 34,
      "referenceLabel": "Luke 19:34",
      "text": "οι δε ειπον ο κυριος αυτου χρειαν εχει",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.35",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 35,
      "referenceLabel": "Luke 19:35",
      "text": "και ηγαγον αυτον προς τον ιησουν και επιρριψαντες εαυτων τα ιματια επι τον πωλον επεβιβασαν τον ιησουν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.36",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 36,
      "referenceLabel": "Luke 19:36",
      "text": "πορευομενου δε αυτου υπεστρωννυον τα ιματια αυτων εν τη οδω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.37",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 37,
      "referenceLabel": "Luke 19:37",
      "text": "εγγιζοντος δε αυτου ηδη προς τη καταβασει του ορους των ελαιων ηρξαντο απαν το πληθος των μαθητων χαιροντες αινειν τον θεον φωνη μεγαλη περι πασων ων ειδον δυναμεων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.38",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 38,
      "referenceLabel": "Luke 19:38",
      "text": "λεγοντες ευλογημενος ο ερχομενος βασιλευς εν ονοματι κυριου ειρηνη εν ουρανω και δοξα εν υψιστοις",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.39",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 39,
      "referenceLabel": "Luke 19:39",
      "text": "και τινες των φαρισαιων απο του οχλου ειπον προς αυτον διδασκαλε επιτιμησον τοις μαθηταις σου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.40",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 40,
      "referenceLabel": "Luke 19:40",
      "text": "και αποκριθεις ειπεν αυτοις λεγω υμιν οτι εαν ουτοι σιωπησωσιν οι λιθοι κεκραξονται",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.41",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 41,
      "referenceLabel": "Luke 19:41",
      "text": "και ως ηγγισεν ιδων την πολιν εκλαυσεν επ αυτη",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.42",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 42,
      "referenceLabel": "Luke 19:42",
      "text": "λεγων οτι ει εγνως και συ και γε εν τη ημερα σου ταυτη τα προς ειρηνην σου νυν δε εκρυβη απο οφθαλμων σου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.43",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 43,
      "referenceLabel": "Luke 19:43",
      "text": "οτι ηξουσιν ημεραι επι σε και περιβαλουσιν οι εχθροι σου χαρακα σοι και περικυκλωσουσιν σε και συνεξουσιν σε παντοθεν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.44",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 44,
      "referenceLabel": "Luke 19:44",
      "text": "και εδαφιουσιν σε και τα τεκνα σου εν σοι και ουκ αφησουσιν εν σοι λιθον επι λιθω ανθ ων ουκ εγνως τον καιρον της επισκοπης σου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.45",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 45,
      "referenceLabel": "Luke 19:45",
      "text": "και εισελθων εις το ιερον ηρξατο εκβαλλειν τους πωλουντας εν αυτω και αγοραζοντας",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.46",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 46,
      "referenceLabel": "Luke 19:46",
      "text": "λεγων αυτοις γεγραπται ο οικος μου οικος προσευχης εστιν υμεις δε αυτον εποιησατε σπηλαιον ληστων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.47",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 47,
      "referenceLabel": "Luke 19:47",
      "text": "και ην διδασκων το καθ ημεραν εν τω ιερω οι δε αρχιερεις και οι γραμματεις εζητουν αυτον απολεσαι και οι πρωτοι του λαου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.19.48",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 48,
      "referenceLabel": "Luke 19:48",
      "text": "και ουχ ευρισκον το τι ποιησωσιν ο λαος γαρ απας εξεκρεματο αυτου ακουων",
      "paragraphStart": false
    }
  ]
}
