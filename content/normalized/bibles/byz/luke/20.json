{
  "chapter": {
    "id": "byz:luke.20",
    "translationId": "byz",
    "bookSlug": "luke",
    "chapterNumber": 20,
    "referenceLabel": "Luke 20",
    "summary": "Source text for Luke 20 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:luke.20.1",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Luke 20:1",
      "text": "και εγενετο εν μια των ημερων εκεινων διδασκοντος αυτου τον λαον εν τω ιερω και ευαγγελιζομενου επεστησαν οι ιερεις και οι γραμματεις συν τοις πρεσβυτεροις",
      "paragraphStart": true
    },
    {
      "id": "byz:luke.20.2",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Luke 20:2",
      "text": "και ειπον προς αυτον λεγοντες ειπε ημιν εν ποια εξουσια ταυτα ποιεις η τις εστιν ο δους σοι την εξουσιαν ταυτην",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.3",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Luke 20:3",
      "text": "αποκριθεις δε ειπεν προς αυτους ερωτησω υμας καγω ενα λογον και ειπατε μοι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.4",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Luke 20:4",
      "text": "το βαπτισμα ιωαννου εξ ουρανου ην η εξ ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.5",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Luke 20:5",
      "text": "οι δε συνελογισαντο προς εαυτους λεγοντες οτι εαν ειπωμεν εξ ουρανου ερει δια τι ουκ επιστευσατε αυτω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.6",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Luke 20:6",
      "text": "εαν δε ειπωμεν εξ ανθρωπων πας ο λαος καταλιθασει ημας πεπεισμενος γαρ εστιν ιωαννην προφητην ειναι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.7",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Luke 20:7",
      "text": "και απεκριθησαν μη ειδεναι ποθεν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.8",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Luke 20:8",
      "text": "και ο ιησους ειπεν αυτοις ουδε εγω λεγω υμιν εν ποια εξουσια ταυτα ποιω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.9",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Luke 20:9",
      "text": "ηρξατο δε προς τον λαον λεγειν την παραβολην ταυτην ανθρωπος εφυτευσεν αμπελωνα και εξεδοτο αυτον γεωργοις και απεδημησεν χρονους ικανους",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.10",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Luke 20:10",
      "text": "και εν καιρω απεστειλεν προς τους γεωργους δουλον ινα απο του καρπου του αμπελωνος δωσιν αυτω οι δε γεωργοι δειραντες αυτον εξαπεστειλαν κενον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.11",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Luke 20:11",
      "text": "και προσεθετο πεμψαι ετερον δουλον οι δε κακεινον δειραντες και ατιμασαντες εξαπεστειλαν κενον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.12",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Luke 20:12",
      "text": "και προσεθετο πεμψαι τριτον οι δε και τουτον τραυματισαντες εξεβαλον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.13",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "Luke 20:13",
      "text": "ειπεν δε ο κυριος του αμπελωνος τι ποιησω πεμψω τον υιον μου τον αγαπητον ισως τουτον ιδοντες εντραπησονται",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.14",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 14,
      "referenceLabel": "Luke 20:14",
      "text": "ιδοντες δε αυτον οι γεωργοι διελογιζοντο προς εαυτους λεγοντες ουτος εστιν ο κληρονομος δευτε αποκτεινωμεν αυτον ινα ημων γενηται η κληρονομια",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.15",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 15,
      "referenceLabel": "Luke 20:15",
      "text": "και εκβαλοντες αυτον εξω του αμπελωνος απεκτειναν τι ουν ποιησει αυτοις ο κυριος του αμπελωνος",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.16",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 16,
      "referenceLabel": "Luke 20:16",
      "text": "ελευσεται και απολεσει τους γεωργους τουτους και δωσει τον αμπελωνα αλλοις ακουσαντες δε ειπον μη γενοιτο",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.17",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 17,
      "referenceLabel": "Luke 20:17",
      "text": "ο δε εμβλεψας αυτοις ειπεν τι ουν εστιν το γεγραμμενον τουτο λιθον ον απεδοκιμασαν οι οικοδομουντες ουτος εγενηθη εις κεφαλην γωνιας",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.18",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 18,
      "referenceLabel": "Luke 20:18",
      "text": "πας ο πεσων επ εκεινον τον λιθον συνθλασθησεται εφ ον δ αν πεση λικμησει αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.19",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 19,
      "referenceLabel": "Luke 20:19",
      "text": "και εζητησαν οι αρχιερεις και οι γραμματεις επιβαλειν επ αυτον τας χειρας εν αυτη τη ωρα και εφοβηθησαν εγνωσαν γαρ οτι προς αυτους την παραβολην ταυτην ειπεν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.20",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 20,
      "referenceLabel": "Luke 20:20",
      "text": "και παρατηρησαντες απεστειλαν εγκαθετους υποκρινομενους εαυτους δικαιους ειναι ινα επιλαβωνται αυτου λογου εις το παραδουναι αυτον τη αρχη και τη εξουσια του ηγεμονος",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.21",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 21,
      "referenceLabel": "Luke 20:21",
      "text": "και επηρωτησαν αυτον λεγοντες διδασκαλε οιδαμεν οτι ορθως λεγεις και διδασκεις και ου λαμβανεις προσωπον αλλ επ αληθειας την οδον του θεου διδασκεις",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.22",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 22,
      "referenceLabel": "Luke 20:22",
      "text": "εξεστιν ημιν καισαρι φορον δουναι η ου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.23",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 23,
      "referenceLabel": "Luke 20:23",
      "text": "κατανοησας δε αυτων την πανουργιαν ειπεν προς αυτους τι με πειραζετε",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.24",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 24,
      "referenceLabel": "Luke 20:24",
      "text": "επιδειξατε μοι δηναριον τινος εχει εικονα και επιγραφην αποκριθεντες δε ειπον καισαρος",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.25",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 25,
      "referenceLabel": "Luke 20:25",
      "text": "ο δε ειπεν αυτοις αποδοτε τοινυν τα καισαρος καισαρι και τα του θεου τω θεω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.26",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 26,
      "referenceLabel": "Luke 20:26",
      "text": "και ουκ ισχυσαν επιλαβεσθαι αυτου ρηματος εναντιον του λαου και θαυμασαντες επι τη αποκρισει αυτου εσιγησαν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.27",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 27,
      "referenceLabel": "Luke 20:27",
      "text": "προσελθοντες δε τινες των σαδδουκαιων οι αντιλεγοντες αναστασιν μη ειναι επηρωτησαν αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.28",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 28,
      "referenceLabel": "Luke 20:28",
      "text": "λεγοντες διδασκαλε μωσης εγραψεν ημιν εαν τινος αδελφος αποθανη εχων γυναικα και ουτος ατεκνος αποθανη ινα λαβη ο αδελφος αυτου την γυναικα και εξαναστηση σπερμα τω αδελφω αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.29",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 29,
      "referenceLabel": "Luke 20:29",
      "text": "επτα ουν αδελφοι ησαν και ο πρωτος λαβων γυναικα απεθανεν ατεκνος",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.30",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 30,
      "referenceLabel": "Luke 20:30",
      "text": "και ελαβεν ο δευτερος την γυναικα και ουτος απεθανεν ατεκνος",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.31",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 31,
      "referenceLabel": "Luke 20:31",
      "text": "και ο τριτος ελαβεν αυτην ωσαυτως ωσαυτως δε και οι επτα ου κατελιπον τεκνα και απεθανον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.32",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 32,
      "referenceLabel": "Luke 20:32",
      "text": "υστερον δε παντων απεθανεν και η γυνη",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.33",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 33,
      "referenceLabel": "Luke 20:33",
      "text": "εν τη ουν αναστασει τινος αυτων γινεται γυνη οι γαρ επτα εσχον αυτην γυναικα",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.34",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 34,
      "referenceLabel": "Luke 20:34",
      "text": "και αποκριθεις ειπεν αυτοις ο ιησους οι υιοι του αιωνος τουτου γαμουσιν και εκγαμισκονται",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.35",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 35,
      "referenceLabel": "Luke 20:35",
      "text": "οι δε καταξιωθεντες του αιωνος εκεινου τυχειν και της αναστασεως της εκ νεκρων ουτε γαμουσιν ουτε εκγαμιζονται",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.36",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 36,
      "referenceLabel": "Luke 20:36",
      "text": "ουτε γαρ αποθανειν ετι δυνανται ισαγγελοι γαρ εισιν και υιοι εισιν του θεου της αναστασεως υιοι οντες",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.37",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 37,
      "referenceLabel": "Luke 20:37",
      "text": "οτι δε εγειρονται οι νεκροι και μωσης εμηνυσεν επι της βατου ως λεγει κυριον τον θεον αβρααμ και τον θεον ισαακ και τον θεον ιακωβ",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.38",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 38,
      "referenceLabel": "Luke 20:38",
      "text": "θεος δε ουκ εστιν νεκρων αλλα ζωντων παντες γαρ αυτω ζωσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.39",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 39,
      "referenceLabel": "Luke 20:39",
      "text": "αποκριθεντες δε τινες των γραμματεων ειπον διδασκαλε καλως ειπας",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.40",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 40,
      "referenceLabel": "Luke 20:40",
      "text": "ουκετι δε ετολμων επερωταν αυτον ουδεν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.41",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 41,
      "referenceLabel": "Luke 20:41",
      "text": "ειπεν δε προς αυτους πως λεγουσιν τον χριστον υιον δαυιδ ειναι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.42",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 42,
      "referenceLabel": "Luke 20:42",
      "text": "και αυτος δαυιδ λεγει εν βιβλω ψαλμων ειπεν ο κυριος τω κυριω μου καθου εκ δεξιων μου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.43",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 43,
      "referenceLabel": "Luke 20:43",
      "text": "εως αν θω τους εχθρους σου υποποδιον των ποδων σου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.44",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 44,
      "referenceLabel": "Luke 20:44",
      "text": "δαυιδ ουν κυριον αυτον καλει και πως υιος αυτου εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.45",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 45,
      "referenceLabel": "Luke 20:45",
      "text": "ακουοντος δε παντος του λαου ειπεν τοις μαθηταις αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.46",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 46,
      "referenceLabel": "Luke 20:46",
      "text": "προσεχετε απο των γραμματεων των θελοντων περιπατειν εν στολαις και φιλουντων ασπασμους εν ταις αγοραις και πρωτοκαθεδριας εν ταις συναγωγαις και πρωτοκλισιας εν τοις δειπνοις",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.20.47",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 47,
      "referenceLabel": "Luke 20:47",
      "text": "οι κατεσθιουσιν τας οικιας των χηρων και προφασει μακρα προσευχονται ουτοι ληψονται περισσοτερον κριμα",
      "paragraphStart": false
    }
  ]
}
