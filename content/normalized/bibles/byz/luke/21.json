{
  "chapter": {
    "id": "byz:luke.21",
    "translationId": "byz",
    "bookSlug": "luke",
    "chapterNumber": 21,
    "referenceLabel": "Luke 21",
    "summary": "Source text for Luke 21 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:luke.21.1",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Luke 21:1",
      "text": "αναβλεψας δε ειδεν τους βαλλοντας τα δωρα αυτων εις το γαζοφυλακιον πλουσιους",
      "paragraphStart": true
    },
    {
      "id": "byz:luke.21.2",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Luke 21:2",
      "text": "ειδεν δε τινα και χηραν πενιχραν βαλλουσαν εκει δυο λεπτα",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.3",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Luke 21:3",
      "text": "και ειπεν αληθως λεγω υμιν οτι η χηρα η πτωχη αυτη πλειον παντων εβαλεν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.4",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Luke 21:4",
      "text": "απαντες γαρ ουτοι εκ του περισσευοντος αυτοις εβαλον εις τα δωρα του θεου αυτη δε εκ του υστερηματος αυτης απαντα τον βιον ον ειχεν εβαλεν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.5",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Luke 21:5",
      "text": "και τινων λεγοντων περι του ιερου οτι λιθοις καλοις και αναθημασιν κεκοσμηται ειπεν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.6",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Luke 21:6",
      "text": "ταυτα α θεωρειτε ελευσονται ημεραι εν αις ουκ αφεθησεται λιθος επι λιθω ος ου καταλυθησεται",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.7",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Luke 21:7",
      "text": "επηρωτησαν δε αυτον λεγοντες διδασκαλε ποτε ουν ταυτα εσται και τι το σημειον οταν μελλη ταυτα γινεσθαι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.8",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Luke 21:8",
      "text": "ο δε ειπεν βλεπετε μη πλανηθητε πολλοι γαρ ελευσονται επι τω ονοματι μου λεγοντες οτι εγω ειμι και ο καιρος ηγγικεν μη ουν πορευθητε οπισω αυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.9",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Luke 21:9",
      "text": "οταν δε ακουσητε πολεμους και ακαταστασιας μη πτοηθητε δει γαρ ταυτα γενεσθαι πρωτον αλλ ουκ ευθεως το τελος",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.10",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Luke 21:10",
      "text": "τοτε ελεγεν αυτοις εγερθησεται εθνος επι εθνος και βασιλεια επι βασιλειαν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.11",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Luke 21:11",
      "text": "σεισμοι τε μεγαλοι κατα τοπους και λιμοι και λοιμοι εσονται φοβητρα τε και σημεια απ ουρανου μεγαλα εσται",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.12",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Luke 21:12",
      "text": "προ δε τουτων παντων επιβαλουσιν εφ υμας τας χειρας αυτων και διωξουσιν παραδιδοντες εις συναγωγας και φυλακας αγομενους επι βασιλεις και ηγεμονας ενεκεν του ονοματος μου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.13",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Luke 21:13",
      "text": "αποβησεται δε υμιν εις μαρτυριον",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.14",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Luke 21:14",
      "text": "θεσθε ουν εις τας καρδιας υμων μη προμελεταν απολογηθηναι",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.15",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Luke 21:15",
      "text": "εγω γαρ δωσω υμιν στομα και σοφιαν η ου δυνησονται αντειπειν ουδε αντιστηναι παντες οι αντικειμενοι υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.16",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Luke 21:16",
      "text": "παραδοθησεσθε δε και υπο γονεων και συγγενων και φιλων και αδελφων και θανατωσουσιν εξ υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.17",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Luke 21:17",
      "text": "και εσεσθε μισουμενοι υπο παντων δια το ονομα μου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.18",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Luke 21:18",
      "text": "και θριξ εκ της κεφαλης υμων ου μη αποληται",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.19",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Luke 21:19",
      "text": "εν τη υπομονη υμων κτησασθε τας ψυχας υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.20",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Luke 21:20",
      "text": "οταν δε ιδητε κυκλουμενην υπο στρατοπεδων την ιερουσαλημ τοτε γνωτε οτι ηγγικεν η ερημωσις αυτης",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.21",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Luke 21:21",
      "text": "τοτε οι εν τη ιουδαια φευγετωσαν εις τα ορη και οι εν μεσω αυτης εκχωρειτωσαν και οι εν ταις χωραις μη εισερχεσθωσαν εις αυτην",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.22",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Luke 21:22",
      "text": "οτι ημεραι εκδικησεως αυται εισιν του πλησθηναι παντα τα γεγραμμενα",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.23",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Luke 21:23",
      "text": "ουαι δε ταις εν γαστρι εχουσαις και ταις θηλαζουσαις εν εκειναις ταις ημεραις εσται γαρ αναγκη μεγαλη επι της γης και οργη εν τω λαω τουτω",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.24",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Luke 21:24",
      "text": "και πεσουνται στοματι μαχαιρας και αιχμαλωτισθησονται εις παντα τα εθνη και ιερουσαλημ εσται πατουμενη υπο εθνων αχρι πληρωθωσιν καιροι εθνων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.25",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Luke 21:25",
      "text": "και εσται σημεια εν ηλιω και σεληνη και αστροις και επι της γης συνοχη εθνων εν απορια ηχουσης θαλασσης και σαλου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.26",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Luke 21:26",
      "text": "αποψυχοντων ανθρωπων απο φοβου και προσδοκιας των επερχομενων τη οικουμενη αι γαρ δυναμεις των ουρανων σαλευθησονται",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.27",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Luke 21:27",
      "text": "και τοτε οψονται τον υιον του ανθρωπου ερχομενον εν νεφελη μετα δυναμεως και δοξης πολλης",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.28",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Luke 21:28",
      "text": "αρχομενων δε τουτων γινεσθαι ανακυψατε και επαρατε τας κεφαλας υμων διοτι εγγιζει η απολυτρωσις υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.29",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Luke 21:29",
      "text": "και ειπεν παραβολην αυτοις ιδετε την συκην και παντα τα δενδρα",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.30",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Luke 21:30",
      "text": "οταν προβαλωσιν ηδη βλεποντες αφ εαυτων γινωσκετε οτι ηδη εγγυς το θερος εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.31",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Luke 21:31",
      "text": "ουτως και υμεις οταν ιδητε ταυτα γινομενα γινωσκετε οτι εγγυς εστιν η βασιλεια του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.32",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 32,
      "referenceLabel": "Luke 21:32",
      "text": "αμην λεγω υμιν οτι ου μη παρελθη η γενεα αυτη εως αν παντα γενηται",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.33",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 33,
      "referenceLabel": "Luke 21:33",
      "text": "ο ουρανος και η γη παρελευσονται οι δε λογοι μου ου μη παρελθωσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.34",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 34,
      "referenceLabel": "Luke 21:34",
      "text": "προσεχετε δε εαυτοις μηποτε βαρηθωσιν υμων αι καρδιαι εν κραιπαλη και μεθη και μεριμναις βιωτικαις και αιφνιδιος εφ υμας επιστη η ημερα εκεινη",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.35",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 35,
      "referenceLabel": "Luke 21:35",
      "text": "ως παγις γαρ επελευσεται επι παντας τους καθημενους επι προσωπον πασης της γης",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.36",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 36,
      "referenceLabel": "Luke 21:36",
      "text": "αγρυπνειτε ουν εν παντι καιρω δεομενοι ινα καταξιωθητε εκφυγειν παντα τα μελλοντα γινεσθαι και σταθηναι εμπροσθεν του υιου του ανθρωπου",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.37",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 37,
      "referenceLabel": "Luke 21:37",
      "text": "ην δε τας ημερας εν τω ιερω διδασκων τας δε νυκτας εξερχομενος ηυλιζετο εις το ορος το καλουμενον ελαιων",
      "paragraphStart": false
    },
    {
      "id": "byz:luke.21.38",
      "translationId": "byz",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 38,
      "referenceLabel": "Luke 21:38",
      "text": "και πας ο λαος ωρθριζεν προς αυτον εν τω ιερω ακουειν αυτου",
      "paragraphStart": false
    }
  ]
}
