{
  "chapter": {
    "id": "byz:matthew.10",
    "translationId": "byz",
    "bookSlug": "matthew",
    "chapterNumber": 10,
    "referenceLabel": "Matthew 10",
    "summary": "Source text for Matthew 10 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:matthew.10.1",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Matthew 10:1",
      "text": "και προσκαλεσαμενος τους δωδεκα μαθητας αυτου εδωκεν αυτοις εξουσιαν πνευματων ακαθαρτων ωστε εκβαλλειν αυτα και θεραπευειν πασαν νοσον και πασαν μαλακιαν",
      "paragraphStart": true
    },
    {
      "id": "byz:matthew.10.2",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Matthew 10:2",
      "text": "των δε δωδεκα αποστολων τα ονοματα εστιν ταυτα πρωτος σιμων ο λεγομενος πετρος και ανδρεας ο αδελφος αυτου ιακωβος ο του ζεβεδαιου και ιωαννης ο αδελφος αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.3",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Matthew 10:3",
      "text": "φιλιππος και βαρθολομαιος θωμας και ματθαιος ο τελωνης ιακωβος ο του αλφαιου και λεββαιος ο επικληθεις θαδδαιος",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.4",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Matthew 10:4",
      "text": "σιμων ο κανανιτης και ιουδας ισκαριωτης ο και παραδους αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.5",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Matthew 10:5",
      "text": "τουτους τους δωδεκα απεστειλεν ο ιησους παραγγειλας αυτοις λεγων εις οδον εθνων μη απελθητε και εις πολιν σαμαρειτων μη εισελθητε",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.6",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Matthew 10:6",
      "text": "πορευεσθε δε μαλλον προς τα προβατα τα απολωλοτα οικου ισραηλ",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.7",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Matthew 10:7",
      "text": "πορευομενοι δε κηρυσσετε λεγοντες οτι ηγγικεν η βασιλεια των ουρανων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.8",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Matthew 10:8",
      "text": "ασθενουντας θεραπευετε λεπρους καθαριζετε δαιμονια εκβαλλετε δωρεαν ελαβετε δωρεαν δοτε",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.9",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Matthew 10:9",
      "text": "μη κτησησθε χρυσον μηδε αργυρον μηδε χαλκον εις τας ζωνας υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.10",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Matthew 10:10",
      "text": "μη πηραν εις οδον μηδε δυο χιτωνας μηδε υποδηματα μηδε ραβδους αξιος γαρ ο εργατης της τροφης αυτου εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.11",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Matthew 10:11",
      "text": "εις ην δ αν πολιν η κωμην εισελθητε εξετασατε τις εν αυτη αξιος εστιν κακει μεινατε εως αν εξελθητε",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.12",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Matthew 10:12",
      "text": "εισερχομενοι δε εις την οικιαν ασπασασθε αυτην",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.13",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Matthew 10:13",
      "text": "και εαν μεν η η οικια αξια ελθετω η ειρηνη υμων επ αυτην εαν δε μη η αξια η ειρηνη υμων προς υμας επιστραφητω",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.14",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Matthew 10:14",
      "text": "και ος εαν μη δεξηται υμας μηδε ακουση τους λογους υμων εξερχομενοι της οικιας η της πολεως εκεινης εκτιναξατε τον κονιορτον των ποδων υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.15",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Matthew 10:15",
      "text": "αμην λεγω υμιν ανεκτοτερον εσται γη σοδομων και γομορρων εν ημερα κρισεως η τη πολει εκεινη",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.16",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Matthew 10:16",
      "text": "ιδου εγω αποστελλω υμας ως προβατα εν μεσω λυκων γινεσθε ουν φρονιμοι ως οι οφεις και ακεραιοι ως αι περιστεραι",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.17",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Matthew 10:17",
      "text": "προσεχετε δε απο των ανθρωπων παραδωσουσιν γαρ υμας εις συνεδρια και εν ταις συναγωγαις αυτων μαστιγωσουσιν υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.18",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Matthew 10:18",
      "text": "και επι ηγεμονας δε και βασιλεις αχθησεσθε ενεκεν εμου εις μαρτυριον αυτοις και τοις εθνεσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.19",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Matthew 10:19",
      "text": "οταν δε παραδιδωσιν υμας μη μεριμνησητε πως η τι λαλησητε δοθησεται γαρ υμιν εν εκεινη τη ωρα τι λαλησετε",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.20",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Matthew 10:20",
      "text": "ου γαρ υμεις εστε οι λαλουντες αλλα το πνευμα του πατρος υμων το λαλουν εν υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.21",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Matthew 10:21",
      "text": "παραδωσει δε αδελφος αδελφον εις θανατον και πατηρ τεκνον και επαναστησονται τεκνα επι γονεις και θανατωσουσιν αυτους",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.22",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Matthew 10:22",
      "text": "και εσεσθε μισουμενοι υπο παντων δια το ονομα μου ο δε υπομεινας εις τελος ουτος σωθησεται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.23",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Matthew 10:23",
      "text": "οταν δε διωκωσιν υμας εν τη πολει ταυτη φευγετε εις την αλλην αμην γαρ λεγω υμιν ου μη τελεσητε τας πολεις του ισραηλ εως αν ελθη ο υιος του ανθρωπου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.24",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Matthew 10:24",
      "text": "ουκ εστιν μαθητης υπερ τον διδασκαλον ουδε δουλος υπερ τον κυριον αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.25",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Matthew 10:25",
      "text": "αρκετον τω μαθητη ινα γενηται ως ο διδασκαλος αυτου και ο δουλος ως ο κυριος αυτου ει τον οικοδεσποτην βεελζεβουλ εκαλεσαν ποσω μαλλον τους οικειακους αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.26",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Matthew 10:26",
      "text": "μη ουν φοβηθητε αυτους ουδεν γαρ εστιν κεκαλυμμενον ο ουκ αποκαλυφθησεται και κρυπτον ο ου γνωσθησεται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.27",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Matthew 10:27",
      "text": "ο λεγω υμιν εν τη σκοτια ειπατε εν τω φωτι και ο εις το ους ακουετε κηρυξατε επι των δωματων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.28",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Matthew 10:28",
      "text": "και μη φοβεισθε απο των αποκτενοντων το σωμα την δε ψυχην μη δυναμενων αποκτειναι φοβηθητε δε μαλλον τον δυναμενον και την ψυχην και το σωμα απολεσαι εν γεεννη",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.29",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Matthew 10:29",
      "text": "ουχι δυο στρουθια ασσαριου πωλειται και εν εξ αυτων ου πεσειται επι την γην ανευ του πατρος υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.30",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Matthew 10:30",
      "text": "υμων δε και αι τριχες της κεφαλης πασαι ηριθμημεναι εισιν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.31",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Matthew 10:31",
      "text": "μη ουν φοβηθητε πολλων στρουθιων διαφερετε υμεις",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.32",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Matthew 10:32",
      "text": "πας ουν οστις ομολογησει εν εμοι εμπροσθεν των ανθρωπων ομολογησω καγω εν αυτω εμπροσθεν του πατρος μου του εν ουρανοις",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.33",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "Matthew 10:33",
      "text": "οστις δ αν αρνησηται με εμπροσθεν των ανθρωπων αρνησομαι αυτον καγω εμπροσθεν του πατρος μου του εν ουρανοις",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.34",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 34,
      "referenceLabel": "Matthew 10:34",
      "text": "μη νομισητε οτι ηλθον βαλειν ειρηνην επι την γην ουκ ηλθον βαλειν ειρηνην αλλα μαχαιραν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.35",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 35,
      "referenceLabel": "Matthew 10:35",
      "text": "ηλθον γαρ διχασαι ανθρωπον κατα του πατρος αυτου και θυγατερα κατα της μητρος αυτης και νυμφην κατα της πενθερας αυτης",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.36",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 36,
      "referenceLabel": "Matthew 10:36",
      "text": "και εχθροι του ανθρωπου οι οικειακοι αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.37",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 37,
      "referenceLabel": "Matthew 10:37",
      "text": "ο φιλων πατερα η μητερα υπερ εμε ουκ εστιν μου αξιος και ο φιλων υιον η θυγατερα υπερ εμε ουκ εστιν μου αξιος",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.38",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 38,
      "referenceLabel": "Matthew 10:38",
      "text": "και ος ου λαμβανει τον σταυρον αυτου και ακολουθει οπισω μου ουκ εστιν μου αξιος",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.39",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 39,
      "referenceLabel": "Matthew 10:39",
      "text": "ο ευρων την ψυχην αυτου απολεσει αυτην και ο απολεσας την ψυχην αυτου ενεκεν εμου ευρησει αυτην",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.40",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 40,
      "referenceLabel": "Matthew 10:40",
      "text": "ο δεχομενος υμας εμε δεχεται και ο εμε δεχομενος δεχεται τον αποστειλαντα με",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.41",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 41,
      "referenceLabel": "Matthew 10:41",
      "text": "ο δεχομενος προφητην εις ονομα προφητου μισθον προφητου ληψεται και ο δεχομενος δικαιον εις ονομα δικαιου μισθον δικαιου ληψεται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.10.42",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 42,
      "referenceLabel": "Matthew 10:42",
      "text": "και ος εαν ποτιση ενα των μικρων τουτων ποτηριον ψυχρου μονον εις ονομα μαθητου αμην λεγω υμιν ου μη απολεση τον μισθον αυτου",
      "paragraphStart": false
    }
  ]
}
