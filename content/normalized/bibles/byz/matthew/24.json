{
  "chapter": {
    "id": "byz:matthew.24",
    "translationId": "byz",
    "bookSlug": "matthew",
    "chapterNumber": 24,
    "referenceLabel": "Matthew 24",
    "summary": "Source text for Matthew 24 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:matthew.24.1",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Matthew 24:1",
      "text": "και εξελθων ο ιησους επορευετο απο του ιερου και προσηλθον οι μαθηται αυτου επιδειξαι αυτω τας οικοδομας του ιερου",
      "paragraphStart": true
    },
    {
      "id": "byz:matthew.24.2",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Matthew 24:2",
      "text": "ο δε ιησους ειπεν αυτοις ου βλεπετε παντα ταυτα αμην λεγω υμιν ου μη αφεθη ωδε λιθος επι λιθον ος ου καταλυθησεται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.3",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Matthew 24:3",
      "text": "καθημενου δε αυτου επι του ορους των ελαιων προσηλθον αυτω οι μαθηται κατ ιδιαν λεγοντες ειπε ημιν ποτε ταυτα εσται και τι το σημειον της σης παρουσιας και της συντελειας του αιωνος",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.4",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Matthew 24:4",
      "text": "και αποκριθεις ο ιησους ειπεν αυτοις βλεπετε μη τις υμας πλανηση",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.5",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Matthew 24:5",
      "text": "πολλοι γαρ ελευσονται επι τω ονοματι μου λεγοντες εγω ειμι ο χριστος και πολλους πλανησουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.6",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Matthew 24:6",
      "text": "μελλησετε δε ακουειν πολεμους και ακοας πολεμων ορατε μη θροεισθε δει γαρ παντα γενεσθαι αλλ ουπω εστιν το τελος",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.7",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Matthew 24:7",
      "text": "εγερθησεται γαρ εθνος επι εθνος και βασιλεια επι βασιλειαν και εσονται λιμοι και λοιμοι και σεισμοι κατα τοπους",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.8",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Matthew 24:8",
      "text": "παντα δε ταυτα αρχη ωδινων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.9",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Matthew 24:9",
      "text": "τοτε παραδωσουσιν υμας εις θλιψιν και αποκτενουσιν υμας και εσεσθε μισουμενοι υπο παντων των εθνων δια το ονομα μου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.10",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Matthew 24:10",
      "text": "και τοτε σκανδαλισθησονται πολλοι και αλληλους παραδωσουσιν και μισησουσιν αλληλους",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.11",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 11,
      "referenceLabel": "Matthew 24:11",
      "text": "και πολλοι ψευδοπροφηται εγερθησονται και πλανησουσιν πολλους",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.12",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 12,
      "referenceLabel": "Matthew 24:12",
      "text": "και δια το πληθυνθηναι την ανομιαν ψυγησεται η αγαπη των πολλων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.13",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 13,
      "referenceLabel": "Matthew 24:13",
      "text": "ο δε υπομεινας εις τελος ουτος σωθησεται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.14",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 14,
      "referenceLabel": "Matthew 24:14",
      "text": "και κηρυχθησεται τουτο το ευαγγελιον της βασιλειας εν ολη τη οικουμενη εις μαρτυριον πασιν τοις εθνεσιν και τοτε ηξει το τελος",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.15",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 15,
      "referenceLabel": "Matthew 24:15",
      "text": "οταν ουν ιδητε το βδελυγμα της ερημωσεως το ρηθεν δια δανιηλ του προφητου εστως εν τοπω αγιω ο αναγινωσκων νοειτω",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.16",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 16,
      "referenceLabel": "Matthew 24:16",
      "text": "τοτε οι εν τη ιουδαια φευγετωσαν επι τα ορη",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.17",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 17,
      "referenceLabel": "Matthew 24:17",
      "text": "ο επι του δωματος μη καταβαινετω αραι τα εκ της οικιας αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.18",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 18,
      "referenceLabel": "Matthew 24:18",
      "text": "και ο εν τω αγρω μη επιστρεψατω οπισω αραι τα ιματια αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.19",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 19,
      "referenceLabel": "Matthew 24:19",
      "text": "ουαι δε ταις εν γαστρι εχουσαις και ταις θηλαζουσαις εν εκειναις ταις ημεραις",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.20",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 20,
      "referenceLabel": "Matthew 24:20",
      "text": "προσευχεσθε δε ινα μη γενηται η φυγη υμων χειμωνος μηδε σαββατω",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.21",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 21,
      "referenceLabel": "Matthew 24:21",
      "text": "εσται γαρ τοτε θλιψις μεγαλη οια ου γεγονεν απ αρχης κοσμου εως του νυν ουδ ου μη γενηται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.22",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 22,
      "referenceLabel": "Matthew 24:22",
      "text": "και ει μη εκολοβωθησαν αι ημεραι εκειναι ουκ αν εσωθη πασα σαρξ δια δε τους εκλεκτους κολοβωθησονται αι ημεραι εκειναι",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.23",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 23,
      "referenceLabel": "Matthew 24:23",
      "text": "τοτε εαν τις υμιν ειπη ιδου ωδε ο χριστος η ωδε μη πιστευσητε",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.24",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 24,
      "referenceLabel": "Matthew 24:24",
      "text": "εγερθησονται γαρ ψευδοχριστοι και ψευδοπροφηται και δωσουσιν σημεια μεγαλα και τερατα ωστε πλανησαι ει δυνατον και τους εκλεκτους",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.25",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 25,
      "referenceLabel": "Matthew 24:25",
      "text": "ιδου προειρηκα υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.26",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 26,
      "referenceLabel": "Matthew 24:26",
      "text": "εαν ουν ειπωσιν υμιν ιδου εν τη ερημω εστιν μη εξελθητε ιδου εν τοις ταμειοις μη πιστευσητε",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.27",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 27,
      "referenceLabel": "Matthew 24:27",
      "text": "ωσπερ γαρ η αστραπη εξερχεται απο ανατολων και φαινεται εως δυσμων ουτως εσται και η παρουσια του υιου του ανθρωπου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.28",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 28,
      "referenceLabel": "Matthew 24:28",
      "text": "οπου γαρ εαν η το πτωμα εκει συναχθησονται οι αετοι",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.29",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 29,
      "referenceLabel": "Matthew 24:29",
      "text": "ευθεως δε μετα την θλιψιν των ημερων εκεινων ο ηλιος σκοτισθησεται και η σεληνη ου δωσει το φεγγος αυτης και οι αστερες πεσουνται απο του ουρανου και αι δυναμεις των ουρανων σαλευθησονται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.30",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 30,
      "referenceLabel": "Matthew 24:30",
      "text": "και τοτε φανησεται το σημειον του υιου του ανθρωπου εν τω ουρανω και τοτε κοψονται πασαι αι φυλαι της γης και οψονται τον υιον του ανθρωπου ερχομενον επι των νεφελων του ουρανου μετα δυναμεως και δοξης πολλης",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.31",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 31,
      "referenceLabel": "Matthew 24:31",
      "text": "και αποστελει τους αγγελους αυτου μετα σαλπιγγος φωνης μεγαλης και επισυναξουσιν τους εκλεκτους αυτου εκ των τεσσαρων ανεμων απ ακρων ουρανων εως ακρων αυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.32",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 32,
      "referenceLabel": "Matthew 24:32",
      "text": "απο δε της συκης μαθετε την παραβολην οταν ηδη ο κλαδος αυτης γενηται απαλος και τα φυλλα εκφυη γινωσκετε οτι εγγυς το θερος",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.33",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 33,
      "referenceLabel": "Matthew 24:33",
      "text": "ουτως και υμεις οταν ιδητε ταυτα παντα γινωσκετε οτι εγγυς εστιν επι θυραις",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.34",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 34,
      "referenceLabel": "Matthew 24:34",
      "text": "αμην λεγω υμιν ου μη παρελθη η γενεα αυτη εως αν παντα ταυτα γενηται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.35",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 35,
      "referenceLabel": "Matthew 24:35",
      "text": "ο ουρανος και η γη παρελευσονται οι δε λογοι μου ου μη παρελθωσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.36",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 36,
      "referenceLabel": "Matthew 24:36",
      "text": "περι δε της ημερας εκεινης και ωρας ουδεις οιδεν ουδε οι αγγελοι των ουρανων ει μη ο πατηρ μου μονος",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.37",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 37,
      "referenceLabel": "Matthew 24:37",
      "text": "ωσπερ δε αι ημεραι του νωε ουτως εσται και η παρουσια του υιου του ανθρωπου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.38",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 38,
      "referenceLabel": "Matthew 24:38",
      "text": "ωσπερ γαρ ησαν εν ταις ημεραις ταις προ του κατακλυσμου τρωγοντες και πινοντες γαμουντες και εκγαμιζοντες αχρι ης ημερας εισηλθεν νωε εις την κιβωτον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.39",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 39,
      "referenceLabel": "Matthew 24:39",
      "text": "και ουκ εγνωσαν εως ηλθεν ο κατακλυσμος και ηρεν απαντας ουτως εσται και η παρουσια του υιου του ανθρωπου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.40",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 40,
      "referenceLabel": "Matthew 24:40",
      "text": "τοτε δυο εσονται εν τω αγρω ο εις παραλαμβανεται και ο εις αφιεται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.41",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 41,
      "referenceLabel": "Matthew 24:41",
      "text": "δυο αληθουσαι εν τω μυλωνι μια παραλαμβανεται και μια αφιεται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.42",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 42,
      "referenceLabel": "Matthew 24:42",
      "text": "γρηγορειτε ουν οτι ουκ οιδατε ποια ωρα ο κυριος υμων ερχεται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.43",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 43,
      "referenceLabel": "Matthew 24:43",
      "text": "εκεινο δε γινωσκετε οτι ει ηδει ο οικοδεσποτης ποια φυλακη ο κλεπτης ερχεται εγρηγορησεν αν και ουκ αν ειασεν διορυγηναι την οικιαν αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.44",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 44,
      "referenceLabel": "Matthew 24:44",
      "text": "δια τουτο και υμεις γινεσθε ετοιμοι οτι η ωρα ου δοκειτε ο υιος του ανθρωπου ερχεται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.45",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 45,
      "referenceLabel": "Matthew 24:45",
      "text": "τις αρα εστιν ο πιστος δουλος και φρονιμος ον κατεστησεν ο κυριος αυτου επι της θεραπειας αυτου του διδοναι αυτοις την τροφην εν καιρω",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.46",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 46,
      "referenceLabel": "Matthew 24:46",
      "text": "μακαριος ο δουλος εκεινος ον ελθων ο κυριος αυτου ευρησει ποιουντα ουτως",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.47",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 47,
      "referenceLabel": "Matthew 24:47",
      "text": "αμην λεγω υμιν οτι επι πασιν τοις υπαρχουσιν αυτου καταστησει αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.48",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 48,
      "referenceLabel": "Matthew 24:48",
      "text": "εαν δε ειπη ο κακος δουλος εκεινος εν τη καρδια αυτου χρονιζει ο κυριος μου ελθειν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.49",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 49,
      "referenceLabel": "Matthew 24:49",
      "text": "και αρξηται τυπτειν τους συνδουλους εσθιειν δε και πινειν μετα των μεθυοντων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.50",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 50,
      "referenceLabel": "Matthew 24:50",
      "text": "ηξει ο κυριος του δουλου εκεινου εν ημερα η ου προσδοκα και εν ωρα η ου γινωσκει",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.24.51",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 51,
      "referenceLabel": "Matthew 24:51",
      "text": "και διχοτομησει αυτον και το μερος αυτου μετα των υποκριτων θησει εκει εσται ο κλαυθμος και ο βρυγμος των οδοντων",
      "paragraphStart": false
    }
  ]
}
