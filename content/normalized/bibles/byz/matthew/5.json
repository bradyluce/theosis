{
  "chapter": {
    "id": "byz:matthew.5",
    "translationId": "byz",
    "bookSlug": "matthew",
    "chapterNumber": 5,
    "referenceLabel": "Matthew 5",
    "summary": "Source text for Matthew 5 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:matthew.5.1",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Matthew 5:1",
      "text": "ιδων δε τους οχλους ανεβη εις το ορος και καθισαντος αυτου προσηλθον αυτω οι μαθηται αυτου",
      "paragraphStart": true
    },
    {
      "id": "byz:matthew.5.2",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Matthew 5:2",
      "text": "και ανοιξας το στομα αυτου εδιδασκεν αυτους λεγων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.3",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Matthew 5:3",
      "text": "μακαριοι οι πτωχοι τω πνευματι οτι αυτων εστιν η βασιλεια των ουρανων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.4",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Matthew 5:4",
      "text": "μακαριοι οι πενθουντες οτι αυτοι παρακληθησονται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.5",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Matthew 5:5",
      "text": "μακαριοι οι πραεις οτι αυτοι κληρονομησουσιν την γην",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.6",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Matthew 5:6",
      "text": "μακαριοι οι πεινωντες και διψωντες την δικαιοσυνην οτι αυτοι χορτασθησονται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.7",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Matthew 5:7",
      "text": "μακαριοι οι ελεημονες οτι αυτοι ελεηθησονται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.8",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Matthew 5:8",
      "text": "μακαριοι οι καθαροι τη καρδια οτι αυτοι τον θεον οψονται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.9",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Matthew 5:9",
      "text": "μακαριοι οι ειρηνοποιοι οτι αυτοι υιοι θεου κληθησονται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.10",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Matthew 5:10",
      "text": "μακαριοι οι δεδιωγμενοι ενεκεν δικαιοσυνης οτι αυτων εστιν η βασιλεια των ουρανων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.11",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Matthew 5:11",
      "text": "μακαριοι εστε οταν ονειδισωσιν υμας και διωξωσιν και ειπωσιν παν πονηρον ρημα καθ υμων ψευδομενοι ενεκεν εμου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.12",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Matthew 5:12",
      "text": "χαιρετε και αγαλλιασθε οτι ο μισθος υμων πολυς εν τοις ουρανοις ουτως γαρ εδιωξαν τους προφητας τους προ υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.13",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Matthew 5:13",
      "text": "υμεις εστε το αλας της γης εαν δε το αλας μωρανθη εν τινι αλισθησεται εις ουδεν ισχυει ετι ει μη βληθηναι εξω και καταπατεισθαι υπο των ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.14",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Matthew 5:14",
      "text": "υμεις εστε το φως του κοσμου ου δυναται πολις κρυβηναι επανω ορους κειμενη",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.15",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Matthew 5:15",
      "text": "ουδε καιουσιν λυχνον και τιθεασιν αυτον υπο τον μοδιον αλλ επι την λυχνιαν και λαμπει πασιν τοις εν τη οικια",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.16",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Matthew 5:16",
      "text": "ουτως λαμψατω το φως υμων εμπροσθεν των ανθρωπων οπως ιδωσιν υμων τα καλα εργα και δοξασωσιν τον πατερα υμων τον εν τοις ουρανοις",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.17",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Matthew 5:17",
      "text": "μη νομισητε οτι ηλθον καταλυσαι τον νομον η τους προφητας ουκ ηλθον καταλυσαι αλλα πληρωσαι",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.18",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Matthew 5:18",
      "text": "αμην γαρ λεγω υμιν εως αν παρελθη ο ουρανος και η γη ιωτα εν η μια κεραια ου μη παρελθη απο του νομου εως αν παντα γενηται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.19",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Matthew 5:19",
      "text": "ος εαν ουν λυση μιαν των εντολων τουτων των ελαχιστων και διδαξη ουτως τους ανθρωπους ελαχιστος κληθησεται εν τη βασιλεια των ουρανων ος δ αν ποιηση και διδαξη ουτος μεγας κληθησεται εν τη βασιλεια των ουρανων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.20",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Matthew 5:20",
      "text": "λεγω γαρ υμιν οτι εαν μη περισσευση η δικαιοσυνη υμων πλειον των γραμματεων και φαρισαιων ου μη εισελθητε εις την βασιλειαν των ουρανων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.21",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Matthew 5:21",
      "text": "ηκουσατε οτι ερρεθη τοις αρχαιοις ου φονευσεις ος δ αν φονευση ενοχος εσται τη κρισει",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.22",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Matthew 5:22",
      "text": "εγω δε λεγω υμιν οτι πας ο οργιζομενος τω αδελφω αυτου εικη ενοχος εσται τη κρισει ος δ αν ειπη τω αδελφω αυτου ρακα ενοχος εσται τω συνεδριω ος δ αν ειπη μωρε ενοχος εσται εις την γεενναν του πυρος",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.23",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Matthew 5:23",
      "text": "εαν ουν προσφερης το δωρον σου επι το θυσιαστηριον και εκει μνησθης οτι ο αδελφος σου εχει τι κατα σου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.24",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Matthew 5:24",
      "text": "αφες εκει το δωρον σου εμπροσθεν του θυσιαστηριου και υπαγε πρωτον διαλλαγηθι τω αδελφω σου και τοτε ελθων προσφερε το δωρον σου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.25",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Matthew 5:25",
      "text": "ισθι ευνοων τω αντιδικω σου ταχυ εως οτου ει εν τη οδω μετ αυτου μηποτε σε παραδω ο αντιδικος τω κριτη και ο κριτης σε παραδω τω υπηρετη και εις φυλακην βληθηση",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.26",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Matthew 5:26",
      "text": "αμην λεγω σοι ου μη εξελθης εκειθεν εως αν αποδως τον εσχατον κοδραντην",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.27",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Matthew 5:27",
      "text": "ηκουσατε οτι ερρεθη ου μοιχευσεις",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.28",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "Matthew 5:28",
      "text": "εγω δε λεγω υμιν οτι πας ο βλεπων γυναικα προς το επιθυμησαι αυτην ηδη εμοιχευσεν αυτην εν τη καρδια αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.29",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "Matthew 5:29",
      "text": "ει δε ο οφθαλμος σου ο δεξιος σκανδαλιζει σε εξελε αυτον και βαλε απο σου συμφερει γαρ σοι ινα αποληται εν των μελων σου και μη ολον το σωμα σου βληθη εις γεενναν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.30",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "Matthew 5:30",
      "text": "και ει η δεξια σου χειρ σκανδαλιζει σε εκκοψον αυτην και βαλε απο σου συμφερει γαρ σοι ινα αποληται εν των μελων σου και μη ολον το σωμα σου βληθη εις γεενναν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.31",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "Matthew 5:31",
      "text": "ερρεθη δε οτι ος αν απολυση την γυναικα αυτου δοτω αυτη αποστασιον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.32",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 32,
      "referenceLabel": "Matthew 5:32",
      "text": "εγω δε λεγω υμιν οτι ος αν απολυση την γυναικα αυτου παρεκτος λογου πορνειας ποιει αυτην μοιχασθαι και ος εαν απολελυμενην γαμηση μοιχαται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.33",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 33,
      "referenceLabel": "Matthew 5:33",
      "text": "παλιν ηκουσατε οτι ερρεθη τοις αρχαιοις ουκ επιορκησεις αποδωσεις δε τω κυριω τους ορκους σου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.34",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 34,
      "referenceLabel": "Matthew 5:34",
      "text": "εγω δε λεγω υμιν μη ομοσαι ολως μητε εν τω ουρανω οτι θρονος εστιν του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.35",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 35,
      "referenceLabel": "Matthew 5:35",
      "text": "μητε εν τη γη οτι υποποδιον εστιν των ποδων αυτου μητε εις ιεροσολυμα οτι πολις εστιν του μεγαλου βασιλεως",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.36",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 36,
      "referenceLabel": "Matthew 5:36",
      "text": "μητε εν τη κεφαλη σου ομοσης οτι ου δυνασαι μιαν τριχα λευκην η μελαιναν ποιησαι",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.37",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 37,
      "referenceLabel": "Matthew 5:37",
      "text": "εστω δε ο λογος υμων ναι ναι ου ου το δε περισσον τουτων εκ του πονηρου εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.38",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 38,
      "referenceLabel": "Matthew 5:38",
      "text": "ηκουσατε οτι ερρεθη οφθαλμον αντι οφθαλμου και οδοντα αντι οδοντος",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.39",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 39,
      "referenceLabel": "Matthew 5:39",
      "text": "εγω δε λεγω υμιν μη αντιστηναι τω πονηρω αλλ οστις σε ραπισει επι την δεξιαν σιαγονα στρεψον αυτω και την αλλην",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.40",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 40,
      "referenceLabel": "Matthew 5:40",
      "text": "και τω θελοντι σοι κριθηναι και τον χιτωνα σου λαβειν αφες αυτω και το ιματιον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.41",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 41,
      "referenceLabel": "Matthew 5:41",
      "text": "και οστις σε αγγαρευσει μιλιον εν υπαγε μετ αυτου δυο",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.42",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 42,
      "referenceLabel": "Matthew 5:42",
      "text": "τω αιτουντι σε διδου και τον θελοντα απο σου δανεισασθαι μη αποστραφης",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.43",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 43,
      "referenceLabel": "Matthew 5:43",
      "text": "ηκουσατε οτι ερρεθη αγαπησεις τον πλησιον σου και μισησεις τον εχθρον σου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.44",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 44,
      "referenceLabel": "Matthew 5:44",
      "text": "εγω δε λεγω υμιν αγαπατε τους εχθρους υμων ευλογειτε τους καταρωμενους υμας καλως ποιειτε τοις μισουσιν υμας και προσευχεσθε υπερ των επηρεαζοντων υμας και διωκοντων υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.45",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 45,
      "referenceLabel": "Matthew 5:45",
      "text": "οπως γενησθε υιοι του πατρος υμων του εν τοις ουρανοις οτι τον ηλιον αυτου ανατελλει επι πονηρους και αγαθους και βρεχει επι δικαιους και αδικους",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.46",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 46,
      "referenceLabel": "Matthew 5:46",
      "text": "εαν γαρ αγαπησητε τους αγαπωντας υμας τινα μισθον εχετε ουχι και οι τελωναι το αυτο ποιουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.47",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 47,
      "referenceLabel": "Matthew 5:47",
      "text": "και εαν ασπασησθε τους φιλους υμων μονον τι περισσον ποιειτε ουχι και οι τελωναι ουτως ποιουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.5.48",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 48,
      "referenceLabel": "Matthew 5:48",
      "text": "εσεσθε ουν υμεις τελειοι ωσπερ ο πατηρ υμων ο εν τοις ουρανοις τελειος εστιν",
      "paragraphStart": false
    }
  ]
}
