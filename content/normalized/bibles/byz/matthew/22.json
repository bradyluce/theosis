{
  "chapter": {
    "id": "byz:matthew.22",
    "translationId": "byz",
    "bookSlug": "matthew",
    "chapterNumber": 22,
    "referenceLabel": "Matthew 22",
    "summary": "Source text for Matthew 22 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:matthew.22.1",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Matthew 22:1",
      "text": "και αποκριθεις ο ιησους παλιν ειπεν αυτοις εν παραβολαις λεγων",
      "paragraphStart": true
    },
    {
      "id": "byz:matthew.22.2",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Matthew 22:2",
      "text": "ωμοιωθη η βασιλεια των ουρανων ανθρωπω βασιλει οστις εποιησεν γαμους τω υιω αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.3",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Matthew 22:3",
      "text": "και απεστειλεν τους δουλους αυτου καλεσαι τους κεκλημενους εις τους γαμους και ουκ ηθελον ελθειν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.4",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Matthew 22:4",
      "text": "παλιν απεστειλεν αλλους δουλους λεγων ειπατε τοις κεκλημενοις ιδου το αριστον μου ητοιμασα οι ταυροι μου και τα σιτιστα τεθυμενα και παντα ετοιμα δευτε εις τους γαμους",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.5",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Matthew 22:5",
      "text": "οι δε αμελησαντες απηλθον ο μεν εις τον ιδιον αγρον ο δε εις την εμποριαν αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.6",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Matthew 22:6",
      "text": "οι δε λοιποι κρατησαντες τους δουλους αυτου υβρισαν και απεκτειναν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.7",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Matthew 22:7",
      "text": "και ακουσας ο βασιλευς εκεινος ωργισθη και πεμψας τα στρατευματα αυτου απωλεσεν τους φονεις εκεινους και την πολιν αυτων ενεπρησεν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.8",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Matthew 22:8",
      "text": "τοτε λεγει τοις δουλοις αυτου ο μεν γαμος ετοιμος εστιν οι δε κεκλημενοι ουκ ησαν αξιοι",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.9",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Matthew 22:9",
      "text": "πορευεσθε ουν επι τας διεξοδους των οδων και οσους αν ευρητε καλεσατε εις τους γαμους",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.10",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Matthew 22:10",
      "text": "και εξελθοντες οι δουλοι εκεινοι εις τας οδους συνηγαγον παντας οσους ευρον πονηρους τε και αγαθους και επλησθη ο γαμος ανακειμενων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.11",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Matthew 22:11",
      "text": "εισελθων δε ο βασιλευς θεασασθαι τους ανακειμενους ειδεν εκει ανθρωπον ουκ ενδεδυμενον ενδυμα γαμου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.12",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Matthew 22:12",
      "text": "και λεγει αυτω εταιρε πως εισηλθες ωδε μη εχων ενδυμα γαμου ο δε εφιμωθη",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.13",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Matthew 22:13",
      "text": "τοτε ειπεν ο βασιλευς τοις διακονοις δησαντες αυτου ποδας και χειρας αρατε αυτον και εκβαλετε εις το σκοτος το εξωτερον εκει εσται ο κλαυθμος και ο βρυγμος των οδοντων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.14",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Matthew 22:14",
      "text": "πολλοι γαρ εισιν κλητοι ολιγοι δε εκλεκτοι",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.15",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Matthew 22:15",
      "text": "τοτε πορευθεντες οι φαρισαιοι συμβουλιον ελαβον οπως αυτον παγιδευσωσιν εν λογω",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.16",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Matthew 22:16",
      "text": "και αποστελλουσιν αυτω τους μαθητας αυτων μετα των ηρωδιανων λεγοντες διδασκαλε οιδαμεν οτι αληθης ει και την οδον του θεου εν αληθεια διδασκεις και ου μελει σοι περι ουδενος ου γαρ βλεπεις εις προσωπον ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.17",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Matthew 22:17",
      "text": "ειπε ουν ημιν τι σοι δοκει εξεστιν δουναι κηνσον καισαρι η ου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.18",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Matthew 22:18",
      "text": "γνους δε ο ιησους την πονηριαν αυτων ειπεν τι με πειραζετε υποκριται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.19",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Matthew 22:19",
      "text": "επιδειξατε μοι το νομισμα του κηνσου οι δε προσηνεγκαν αυτω δηναριον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.20",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Matthew 22:20",
      "text": "και λεγει αυτοις τινος η εικων αυτη και η επιγραφη",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.21",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Matthew 22:21",
      "text": "λεγουσιν αυτω καισαρος τοτε λεγει αυτοις αποδοτε ουν τα καισαρος καισαρι και τα του θεου τω θεω",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.22",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Matthew 22:22",
      "text": "και ακουσαντες εθαυμασαν και αφεντες αυτον απηλθον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.23",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Matthew 22:23",
      "text": "εν εκεινη τη ημερα προσηλθον αυτω σαδδουκαιοι οι λεγοντες μη ειναι αναστασιν και επηρωτησαν αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.24",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Matthew 22:24",
      "text": "λεγοντες διδασκαλε μωσης ειπεν εαν τις αποθανη μη εχων τεκνα επιγαμβρευσει ο αδελφος αυτου την γυναικα αυτου και αναστησει σπερμα τω αδελφω αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.25",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Matthew 22:25",
      "text": "ησαν δε παρ ημιν επτα αδελφοι και ο πρωτος γαμησας ετελευτησεν και μη εχων σπερμα αφηκεν την γυναικα αυτου τω αδελφω αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.26",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Matthew 22:26",
      "text": "ομοιως και ο δευτερος και ο τριτος εως των επτα",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.27",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Matthew 22:27",
      "text": "υστερον δε παντων απεθανεν και η γυνη",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.28",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Matthew 22:28",
      "text": "εν τη ουν αναστασει τινος των επτα εσται γυνη παντες γαρ εσχον αυτην",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.29",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Matthew 22:29",
      "text": "αποκριθεις δε ο ιησους ειπεν αυτοις πλανασθε μη ειδοτες τας γραφας μηδε την δυναμιν του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.30",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "Matthew 22:30",
      "text": "εν γαρ τη αναστασει ουτε γαμουσιν ουτε εκγαμιζονται αλλ ως αγγελοι του θεου εν ουρανω εισιν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.31",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 31,
      "referenceLabel": "Matthew 22:31",
      "text": "περι δε της αναστασεως των νεκρων ουκ ανεγνωτε το ρηθεν υμιν υπο του θεου λεγοντος",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.32",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 32,
      "referenceLabel": "Matthew 22:32",
      "text": "εγω ειμι ο θεος αβρααμ και ο θεος ισαακ και ο θεος ιακωβ ουκ εστιν ο θεος θεος νεκρων αλλα ζωντων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.33",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 33,
      "referenceLabel": "Matthew 22:33",
      "text": "και ακουσαντες οι οχλοι εξεπλησσοντο επι τη διδαχη αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.34",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 34,
      "referenceLabel": "Matthew 22:34",
      "text": "οι δε φαρισαιοι ακουσαντες οτι εφιμωσεν τους σαδδουκαιους συνηχθησαν επι το αυτο",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.35",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 35,
      "referenceLabel": "Matthew 22:35",
      "text": "και επηρωτησεν εις εξ αυτων νομικος πειραζων αυτον και λεγων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.36",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 36,
      "referenceLabel": "Matthew 22:36",
      "text": "διδασκαλε ποια εντολη μεγαλη εν τω νομω",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.37",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 37,
      "referenceLabel": "Matthew 22:37",
      "text": "ο δε ιησους εφη αυτω αγαπησεις κυριον τον θεον σου εν ολη καρδια σου και εν ολη ψυχη σου και εν ολη τη διανοια σου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.38",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 38,
      "referenceLabel": "Matthew 22:38",
      "text": "αυτη εστιν πρωτη και μεγαλη εντολη",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.39",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 39,
      "referenceLabel": "Matthew 22:39",
      "text": "δευτερα δε ομοια αυτη αγαπησεις τον πλησιον σου ως σεαυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.40",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 40,
      "referenceLabel": "Matthew 22:40",
      "text": "εν ταυταις ταις δυσιν εντολαις ολος ο νομος και οι προφηται κρεμανται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.41",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 41,
      "referenceLabel": "Matthew 22:41",
      "text": "συνηγμενων δε των φαρισαιων επηρωτησεν αυτους ο ιησους",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.42",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 42,
      "referenceLabel": "Matthew 22:42",
      "text": "λεγων τι υμιν δοκει περι του χριστου τινος υιος εστιν λεγουσιν αυτω του δαυιδ",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.43",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 43,
      "referenceLabel": "Matthew 22:43",
      "text": "λεγει αυτοις πως ουν δαυιδ εν πνευματι κυριον αυτον καλει λεγων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.44",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 44,
      "referenceLabel": "Matthew 22:44",
      "text": "ειπεν ο κυριος τω κυριω μου καθου εκ δεξιων μου εως αν θω τους εχθρους σου υποποδιον των ποδων σου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.45",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 45,
      "referenceLabel": "Matthew 22:45",
      "text": "ει ουν δαυιδ καλει αυτον κυριον πως υιος αυτου εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.22.46",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 46,
      "referenceLabel": "Matthew 22:46",
      "text": "και ουδεις εδυνατο αυτω αποκριθηναι λογον ουδε ετολμησεν τις απ εκεινης της ημερας επερωτησαι αυτον ουκετι",
      "paragraphStart": false
    }
  ]
}
