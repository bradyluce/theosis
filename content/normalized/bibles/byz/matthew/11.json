{
  "chapter": {
    "id": "byz:matthew.11",
    "translationId": "byz",
    "bookSlug": "matthew",
    "chapterNumber": 11,
    "referenceLabel": "Matthew 11",
    "summary": "Source text for Matthew 11 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:matthew.11.1",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Matthew 11:1",
      "text": "και εγενετο οτε ετελεσεν ο ιησους διατασσων τοις δωδεκα μαθηταις αυτου μετεβη εκειθεν του διδασκειν και κηρυσσειν εν ταις πολεσιν αυτων",
      "paragraphStart": true
    },
    {
      "id": "byz:matthew.11.2",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Matthew 11:2",
      "text": "ο δε ιωαννης ακουσας εν τω δεσμωτηριω τα εργα του χριστου πεμψας δυο των μαθητων αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.3",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Matthew 11:3",
      "text": "ειπεν αυτω συ ει ο ερχομενος η ετερον προσδοκωμεν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.4",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Matthew 11:4",
      "text": "και αποκριθεις ο ιησους ειπεν αυτοις πορευθεντες απαγγειλατε ιωαννη α ακουετε και βλεπετε",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.5",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Matthew 11:5",
      "text": "τυφλοι αναβλεπουσιν και χωλοι περιπατουσιν λεπροι καθαριζονται και κωφοι ακουουσιν νεκροι εγειρονται και πτωχοι ευαγγελιζονται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.6",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Matthew 11:6",
      "text": "και μακαριος εστιν ος εαν μη σκανδαλισθη εν εμοι",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.7",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Matthew 11:7",
      "text": "τουτων δε πορευομενων ηρξατο ο ιησους λεγειν τοις οχλοις περι ιωαννου τι εξηλθετε εις την ερημον θεασασθαι καλαμον υπο ανεμου σαλευομενον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.8",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Matthew 11:8",
      "text": "αλλα τι εξηλθετε ιδειν ανθρωπον εν μαλακοις ιματιοις ημφιεσμενον ιδου οι τα μαλακα φορουντες εν τοις οικοις των βασιλειων εισιν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.9",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Matthew 11:9",
      "text": "αλλα τι εξηλθετε ιδειν προφητην ναι λεγω υμιν και περισσοτερον προφητου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.10",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Matthew 11:10",
      "text": "ουτος γαρ εστιν περι ου γεγραπται ιδου εγω αποστελλω τον αγγελον μου προ προσωπου σου ος κατασκευασει την οδον σου εμπροσθεν σου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.11",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Matthew 11:11",
      "text": "αμην λεγω υμιν ουκ εγηγερται εν γεννητοις γυναικων μειζων ιωαννου του βαπτιστου ο δε μικροτερος εν τη βασιλεια των ουρανων μειζων αυτου εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.12",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Matthew 11:12",
      "text": "απο δε των ημερων ιωαννου του βαπτιστου εως αρτι η βασιλεια των ουρανων βιαζεται και βιασται αρπαζουσιν αυτην",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.13",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Matthew 11:13",
      "text": "παντες γαρ οι προφηται και ο νομος εως ιωαννου προεφητευσαν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.14",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Matthew 11:14",
      "text": "και ει θελετε δεξασθαι αυτος εστιν ηλιας ο μελλων ερχεσθαι",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.15",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Matthew 11:15",
      "text": "ο εχων ωτα ακουειν ακουετω",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.16",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Matthew 11:16",
      "text": "τινι δε ομοιωσω την γενεαν ταυτην ομοια εστιν παιδιοις εν αγοραις καθημενοις και προσφωνουσιν τοις εταιροις αυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.17",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Matthew 11:17",
      "text": "και λεγουσιν ηυλησαμεν υμιν και ουκ ωρχησασθε εθρηνησαμεν υμιν και ουκ εκοψασθε",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.18",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Matthew 11:18",
      "text": "ηλθεν γαρ ιωαννης μητε εσθιων μητε πινων και λεγουσιν δαιμονιον εχει",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.19",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Matthew 11:19",
      "text": "ηλθεν ο υιος του ανθρωπου εσθιων και πινων και λεγουσιν ιδου ανθρωπος φαγος και οινοποτης τελωνων φιλος και αμαρτωλων και εδικαιωθη η σοφια απο των τεκνων αυτης",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.20",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Matthew 11:20",
      "text": "τοτε ηρξατο ονειδιζειν τας πολεις εν αις εγενοντο αι πλεισται δυναμεις αυτου οτι ου μετενοησαν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.21",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Matthew 11:21",
      "text": "ουαι σοι χοραζιν ουαι σοι βηθσαιδα οτι ει εν τυρω και σιδωνι εγενοντο αι δυναμεις αι γενομεναι εν υμιν παλαι αν εν σακκω και σποδω μετενοησαν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.22",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Matthew 11:22",
      "text": "πλην λεγω υμιν τυρω και σιδωνι ανεκτοτερον εσται εν ημερα κρισεως η υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.23",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Matthew 11:23",
      "text": "και συ καπερναουμ η εως του ουρανου υψωθεισα εως αδου καταβιβασθηση οτι ει εν σοδομοις εγενοντο αι δυναμεις αι γενομεναι εν σοι εμειναν αν μεχρι της σημερον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.24",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Matthew 11:24",
      "text": "πλην λεγω υμιν οτι γη σοδομων ανεκτοτερον εσται εν ημερα κρισεως η σοι",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.25",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Matthew 11:25",
      "text": "εν εκεινω τω καιρω αποκριθεις ο ιησους ειπεν εξομολογουμαι σοι πατερ κυριε του ουρανου και της γης οτι απεκρυψας ταυτα απο σοφων και συνετων και απεκαλυψας αυτα νηπιοις",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.26",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Matthew 11:26",
      "text": "ναι ο πατηρ οτι ουτως εγενετο ευδοκια εμπροσθεν σου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.27",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Matthew 11:27",
      "text": "παντα μοι παρεδοθη υπο του πατρος μου και ουδεις επιγινωσκει τον υιον ει μη ο πατηρ ουδε τον πατερα τις επιγινωσκει ει μη ο υιος και ω εαν βουληται ο υιος αποκαλυψαι",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.28",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "Matthew 11:28",
      "text": "δευτε προς με παντες οι κοπιωντες και πεφορτισμενοι καγω αναπαυσω υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.29",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "Matthew 11:29",
      "text": "αρατε τον ζυγον μου εφ υμας και μαθετε απ εμου οτι πραος ειμι και ταπεινος τη καρδια και ευρησετε αναπαυσιν ταις ψυχαις υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.11.30",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "Matthew 11:30",
      "text": "ο γαρ ζυγος μου χρηστος και το φορτιον μου ελαφρον εστιν",
      "paragraphStart": false
    }
  ]
}
