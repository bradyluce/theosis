{
  "chapter": {
    "id": "byz:matthew.27",
    "translationId": "byz",
    "bookSlug": "matthew",
    "chapterNumber": 27,
    "referenceLabel": "Matthew 27",
    "summary": "Source text for Matthew 27 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:matthew.27.1",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 1,
      "referenceLabel": "Matthew 27:1",
      "text": "πρωιας δε γενομενης συμβουλιον ελαβον παντες οι αρχιερεις και οι πρεσβυτεροι του λαου κατα του ιησου ωστε θανατωσαι αυτον",
      "paragraphStart": true
    },
    {
      "id": "byz:matthew.27.2",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 2,
      "referenceLabel": "Matthew 27:2",
      "text": "και δησαντες αυτον απηγαγον και παρεδωκαν αυτον ποντιω πιλατω τω ηγεμονι",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.3",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 3,
      "referenceLabel": "Matthew 27:3",
      "text": "τοτε ιδων ιουδας ο παραδιδους αυτον οτι κατεκριθη μεταμεληθεις απεστρεψεν τα τριακοντα αργυρια τοις αρχιερευσιν και τοις πρεσβυτεροις",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.4",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 4,
      "referenceLabel": "Matthew 27:4",
      "text": "λεγων ημαρτον παραδους αιμα αθωον οι δε ειπον τι προς ημας συ οψει",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.5",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 5,
      "referenceLabel": "Matthew 27:5",
      "text": "και ριψας τα αργυρια εν τω ναω ανεχωρησεν και απελθων απηγξατο",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.6",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 6,
      "referenceLabel": "Matthew 27:6",
      "text": "οι δε αρχιερεις λαβοντες τα αργυρια ειπον ουκ εξεστιν βαλειν αυτα εις τον κορβαναν επει τιμη αιματος εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.7",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 7,
      "referenceLabel": "Matthew 27:7",
      "text": "συμβουλιον δε λαβοντες ηγορασαν εξ αυτων τον αγρον του κεραμεως εις ταφην τοις ξενοις",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.8",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 8,
      "referenceLabel": "Matthew 27:8",
      "text": "διο εκληθη ο αγρος εκεινος αγρος αιματος εως της σημερον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.9",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 9,
      "referenceLabel": "Matthew 27:9",
      "text": "τοτε επληρωθη το ρηθεν δια ιερεμιου του προφητου λεγοντος και ελαβον τα τριακοντα αργυρια την τιμην του τετιμημενου ον ετιμησαντο απο υιων ισραηλ",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.10",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 10,
      "referenceLabel": "Matthew 27:10",
      "text": "και εδωκαν αυτα εις τον αγρον του κεραμεως καθα συνεταξεν μοι κυριος",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.11",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 11,
      "referenceLabel": "Matthew 27:11",
      "text": "ο δε ιησους εστη εμπροσθεν του ηγεμονος και επηρωτησεν αυτον ο ηγεμων λεγων συ ει ο βασιλευς των ιουδαιων ο δε ιησους εφη αυτω συ λεγεις",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.12",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 12,
      "referenceLabel": "Matthew 27:12",
      "text": "και εν τω κατηγορεισθαι αυτον υπο των αρχιερεων και των πρεσβυτερων ουδεν απεκρινατο",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.13",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 13,
      "referenceLabel": "Matthew 27:13",
      "text": "τοτε λεγει αυτω ο πιλατος ουκ ακουεις ποσα σου καταμαρτυρουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.14",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 14,
      "referenceLabel": "Matthew 27:14",
      "text": "και ουκ απεκριθη αυτω προς ουδε εν ρημα ωστε θαυμαζειν τον ηγεμονα λιαν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.15",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 15,
      "referenceLabel": "Matthew 27:15",
      "text": "κατα δε εορτην ειωθει ο ηγεμων απολυειν ενα τω οχλω δεσμιον ον ηθελον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.16",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 16,
      "referenceLabel": "Matthew 27:16",
      "text": "ειχον δε τοτε δεσμιον επισημον λεγομενον βαραββαν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.17",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 17,
      "referenceLabel": "Matthew 27:17",
      "text": "συνηγμενων ουν αυτων ειπεν αυτοις ο πιλατος τινα θελετε απολυσω υμιν βαραββαν η ιησουν τον λεγομενον χριστον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.18",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 18,
      "referenceLabel": "Matthew 27:18",
      "text": "ηδει γαρ οτι δια φθονον παρεδωκαν αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.19",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 19,
      "referenceLabel": "Matthew 27:19",
      "text": "καθημενου δε αυτου επι του βηματος απεστειλεν προς αυτον η γυνη αυτου λεγουσα μηδεν σοι και τω δικαιω εκεινω πολλα γαρ επαθον σημερον κατ οναρ δι αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.20",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 20,
      "referenceLabel": "Matthew 27:20",
      "text": "οι δε αρχιερεις και οι πρεσβυτεροι επεισαν τους οχλους ινα αιτησωνται τον βαραββαν τον δε ιησουν απολεσωσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.21",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 21,
      "referenceLabel": "Matthew 27:21",
      "text": "αποκριθεις δε ο ηγεμων ειπεν αυτοις τινα θελετε απο των δυο απολυσω υμιν οι δε ειπον βαραββαν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.22",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 22,
      "referenceLabel": "Matthew 27:22",
      "text": "λεγει αυτοις ο πιλατος τι ουν ποιησω ιησουν τον λεγομενον χριστον λεγουσιν αυτω παντες σταυρωθητω",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.23",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 23,
      "referenceLabel": "Matthew 27:23",
      "text": "ο δε ηγεμων εφη τι γαρ κακον εποιησεν οι δε περισσως εκραζον λεγοντες σταυρωθητω",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.24",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 24,
      "referenceLabel": "Matthew 27:24",
      "text": "ιδων δε ο πιλατος οτι ουδεν ωφελει αλλα μαλλον θορυβος γινεται λαβων υδωρ απενιψατο τας χειρας απεναντι του οχλου λεγων αθωος ειμι απο του αιματος του δικαιου τουτου υμεις οψεσθε",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.25",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 25,
      "referenceLabel": "Matthew 27:25",
      "text": "και αποκριθεις πας ο λαος ειπεν το αιμα αυτου εφ ημας και επι τα τεκνα ημων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.26",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 26,
      "referenceLabel": "Matthew 27:26",
      "text": "τοτε απελυσεν αυτοις τον βαραββαν τον δε ιησουν φραγελλωσας παρεδωκεν ινα σταυρωθη",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.27",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 27,
      "referenceLabel": "Matthew 27:27",
      "text": "τοτε οι στρατιωται του ηγεμονος παραλαβοντες τον ιησουν εις το πραιτωριον συνηγαγον επ αυτον ολην την σπειραν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.28",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 28,
      "referenceLabel": "Matthew 27:28",
      "text": "και εκδυσαντες αυτον περιεθηκαν αυτω χλαμυδα κοκκινην",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.29",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 29,
      "referenceLabel": "Matthew 27:29",
      "text": "και πλεξαντες στεφανον εξ ακανθων επεθηκαν επι την κεφαλην αυτου και καλαμον επι την δεξιαν αυτου και γονυπετησαντες εμπροσθεν αυτου ενεπαιζον αυτω λεγοντες χαιρε ο βασιλευς των ιουδαιων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.30",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 30,
      "referenceLabel": "Matthew 27:30",
      "text": "και εμπτυσαντες εις αυτον ελαβον τον καλαμον και ετυπτον εις την κεφαλην αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.31",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 31,
      "referenceLabel": "Matthew 27:31",
      "text": "και οτε ενεπαιξαν αυτω εξεδυσαν αυτον την χλαμυδα και ενεδυσαν αυτον τα ιματια αυτου και απηγαγον αυτον εις το σταυρωσαι",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.32",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 32,
      "referenceLabel": "Matthew 27:32",
      "text": "εξερχομενοι δε ευρον ανθρωπον κυρηναιον ονοματι σιμωνα τουτον ηγγαρευσαν ινα αρη τον σταυρον αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.33",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 33,
      "referenceLabel": "Matthew 27:33",
      "text": "και ελθοντες εις τοπον λεγομενον γολγοθα ο εστιν λεγομενος κρανιου τοπος",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.34",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 34,
      "referenceLabel": "Matthew 27:34",
      "text": "εδωκαν αυτω πιειν οξος μετα χολης μεμιγμενον και γευσαμενος ουκ ηθελεν πιειν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.35",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 35,
      "referenceLabel": "Matthew 27:35",
      "text": "σταυρωσαντες δε αυτον διεμερισαντο τα ιματια αυτου βαλλοντες κληρον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.36",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 36,
      "referenceLabel": "Matthew 27:36",
      "text": "και καθημενοι ετηρουν αυτον εκει",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.37",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 37,
      "referenceLabel": "Matthew 27:37",
      "text": "και επεθηκαν επανω της κεφαλης αυτου την αιτιαν αυτου γεγραμμενην ουτος εστιν ιησους ο βασιλευς των ιουδαιων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.38",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 38,
      "referenceLabel": "Matthew 27:38",
      "text": "τοτε σταυρουνται συν αυτω δυο λησται εις εκ δεξιων και εις εξ ευωνυμων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.39",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 39,
      "referenceLabel": "Matthew 27:39",
      "text": "οι δε παραπορευομενοι εβλασφημουν αυτον κινουντες τας κεφαλας αυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.40",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 40,
      "referenceLabel": "Matthew 27:40",
      "text": "και λεγοντες ο καταλυων τον ναον και εν τρισιν ημεραις οικοδομων σωσον σεαυτον ει υιος ει του θεου καταβηθι απο του σταυρου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.41",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 41,
      "referenceLabel": "Matthew 27:41",
      "text": "ομοιως δε και οι αρχιερεις εμπαιζοντες μετα των γραμματεων και πρεσβυτερων και φαρισαιων ελεγον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.42",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 42,
      "referenceLabel": "Matthew 27:42",
      "text": "αλλους εσωσεν εαυτον ου δυναται σωσαι ει βασιλευς ισραηλ εστιν καταβατω νυν απο του σταυρου και πιστευσομεν επ αυτω",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.43",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 43,
      "referenceLabel": "Matthew 27:43",
      "text": "πεποιθεν επι τον θεον ρυσασθω νυν αυτον ει θελει αυτον ειπεν γαρ οτι θεου ειμι υιος",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.44",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 44,
      "referenceLabel": "Matthew 27:44",
      "text": "το δ αυτο και οι λησται οι συσταυρωθεντες αυτω ωνειδιζον αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.45",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 45,
      "referenceLabel": "Matthew 27:45",
      "text": "απο δε εκτης ωρας σκοτος εγενετο επι πασαν την γην εως ωρας ενατης",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.46",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 46,
      "referenceLabel": "Matthew 27:46",
      "text": "περι δε την ενατην ωραν ανεβοησεν ο ιησους φωνη μεγαλη λεγων ηλι ηλι λιμα σαβαχθανι τουτ εστιν θεε μου θεε μου ινα τι με εγκατελιπες",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.47",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 47,
      "referenceLabel": "Matthew 27:47",
      "text": "τινες δε των εκει εστωτων ακουσαντες ελεγον οτι ηλιαν φωνει ουτος",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.48",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 48,
      "referenceLabel": "Matthew 27:48",
      "text": "και ευθεως δραμων εις εξ αυτων και λαβων σπογγον πλησας τε οξους και περιθεις καλαμω εποτιζεν αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.49",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 49,
      "referenceLabel": "Matthew 27:49",
      "text": "οι δε λοιποι ελεγον αφες ιδωμεν ει ερχεται ηλιας σωσων αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.50",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 50,
      "referenceLabel": "Matthew 27:50",
      "text": "ο δε ιησους παλιν κραξας φωνη μεγαλη αφηκεν το πνευμα",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.51",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 51,
      "referenceLabel": "Matthew 27:51",
      "text": "και ιδου το καταπετασμα του ναου εσχισθη εις δυο απο ανωθεν εως κατω και η γη εσεισθη και αι πετραι εσχισθησαν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.52",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 52,
      "referenceLabel": "Matthew 27:52",
      "text": "και τα μνημεια ανεωχθησαν και πολλα σωματα των κεκοιμημενων αγιων ηγερθη",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.53",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 53,
      "referenceLabel": "Matthew 27:53",
      "text": "και εξελθοντες εκ των μνημειων μετα την εγερσιν αυτου εισηλθον εις την αγιαν πολιν και ενεφανισθησαν πολλοις",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.27.54",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 54,
      "referenceLabel": "Matthew 27:54",
