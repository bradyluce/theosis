{
  "chapter": {
    "id": "byz:matthew.25",
    "translationId": "byz",
    "bookSlug": "matthew",
    "chapterNumber": 25,
    "referenceLabel": "Matthew 25",
    "summary": "Source text for Matthew 25 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:matthew.25.1",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Matthew 25:1",
      "text": "τοτε ομοιωθησεται η βασιλεια των ουρανων δεκα παρθενοις αιτινες λαβουσαι τας λαμπαδας αυτων εξηλθον εις απαντησιν του νυμφιου",
      "paragraphStart": true
    },
    {
      "id": "byz:matthew.25.2",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Matthew 25:2",
      "text": "πεντε δε ησαν εξ αυτων φρονιμοι και αι πεντε μωραι",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.3",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Matthew 25:3",
      "text": "αιτινες μωραι λαβουσαι τας λαμπαδας αυτων ουκ ελαβον μεθ εαυτων ελαιον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.4",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Matthew 25:4",
      "text": "αι δε φρονιμοι ελαβον ελαιον εν τοις αγγειοις αυτων μετα των λαμπαδων αυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.5",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Matthew 25:5",
      "text": "χρονιζοντος δε του νυμφιου ενυσταξαν πασαι και εκαθευδον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.6",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Matthew 25:6",
      "text": "μεσης δε νυκτος κραυγη γεγονεν ιδου ο νυμφιος ερχεται εξερχεσθε εις απαντησιν αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.7",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Matthew 25:7",
      "text": "τοτε ηγερθησαν πασαι αι παρθενοι εκειναι και εκοσμησαν τας λαμπαδας αυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.8",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Matthew 25:8",
      "text": "αι δε μωραι ταις φρονιμοις ειπον δοτε ημιν εκ του ελαιου υμων οτι αι λαμπαδες ημων σβεννυνται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.9",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Matthew 25:9",
      "text": "απεκριθησαν δε αι φρονιμοι λεγουσαι μηποτε ουκ αρκεση ημιν και υμιν πορευεσθε δε μαλλον προς τους πωλουντας και αγορασατε εαυταις",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.10",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Matthew 25:10",
      "text": "απερχομενων δε αυτων αγορασαι ηλθεν ο νυμφιος και αι ετοιμοι εισηλθον μετ αυτου εις τους γαμους και εκλεισθη η θυρα",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.11",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Matthew 25:11",
      "text": "υστερον δε ερχονται και αι λοιπαι παρθενοι λεγουσαι κυριε κυριε ανοιξον ημιν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.12",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Matthew 25:12",
      "text": "ο δε αποκριθεις ειπεν αμην λεγω υμιν ουκ οιδα υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.13",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "Matthew 25:13",
      "text": "γρηγορειτε ουν οτι ουκ οιδατε την ημεραν ουδε την ωραν εν η ο υιος του ανθρωπου ερχεται",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.14",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "Matthew 25:14",
      "text": "ωσπερ γαρ ανθρωπος αποδημων εκαλεσεν τους ιδιους δουλους και παρεδωκεν αυτοις τα υπαρχοντα αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.15",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 15,
      "referenceLabel": "Matthew 25:15",
      "text": "και ω μεν εδωκεν πεντε ταλαντα ω δε δυο ω δε εν εκαστω κατα την ιδιαν δυναμιν και απεδημησεν ευθεως",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.16",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 16,
      "referenceLabel": "Matthew 25:16",
      "text": "πορευθεις δε ο τα πεντε ταλαντα λαβων ειργασατο εν αυτοις και εποιησεν αλλα πεντε ταλαντα",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.17",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 17,
      "referenceLabel": "Matthew 25:17",
      "text": "ωσαυτως και ο τα δυο εκερδησεν και αυτος αλλα δυο",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.18",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 18,
      "referenceLabel": "Matthew 25:18",
      "text": "ο δε το εν λαβων απελθων ωρυξεν εν τη γη και απεκρυψεν το αργυριον του κυριου αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.19",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 19,
      "referenceLabel": "Matthew 25:19",
      "text": "μετα δε χρονον πολυν ερχεται ο κυριος των δουλων εκεινων και συναιρει μετ αυτων λογον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.20",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 20,
      "referenceLabel": "Matthew 25:20",
      "text": "και προσελθων ο τα πεντε ταλαντα λαβων προσηνεγκεν αλλα πεντε ταλαντα λεγων κυριε πεντε ταλαντα μοι παρεδωκας ιδε αλλα πεντε ταλαντα εκερδησα επ αυτοις",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.21",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 21,
      "referenceLabel": "Matthew 25:21",
      "text": "εφη δε αυτω ο κυριος αυτου ευ δουλε αγαθε και πιστε επι ολιγα ης πιστος επι πολλων σε καταστησω εισελθε εις την χαραν του κυριου σου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.22",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 22,
      "referenceLabel": "Matthew 25:22",
      "text": "προσελθων δε και ο τα δυο ταλαντα λαβων ειπεν κυριε δυο ταλαντα μοι παρεδωκας ιδε αλλα δυο ταλαντα εκερδησα επ αυτοις",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.23",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 23,
      "referenceLabel": "Matthew 25:23",
      "text": "εφη αυτω ο κυριος αυτου ευ δουλε αγαθε και πιστε επι ολιγα ης πιστος επι πολλων σε καταστησω εισελθε εις την χαραν του κυριου σου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.24",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 24,
      "referenceLabel": "Matthew 25:24",
      "text": "προσελθων δε και ο το εν ταλαντον ειληφως ειπεν κυριε εγνων σε οτι σκληρος ει ανθρωπος θεριζων οπου ουκ εσπειρας και συναγων οθεν ου διεσκορπισας",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.25",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 25,
      "referenceLabel": "Matthew 25:25",
      "text": "και φοβηθεις απελθων εκρυψα το ταλαντον σου εν τη γη ιδε εχεις το σον",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.26",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 26,
      "referenceLabel": "Matthew 25:26",
      "text": "αποκριθεις δε ο κυριος αυτου ειπεν αυτω πονηρε δουλε και οκνηρε ηδεις οτι θεριζω οπου ουκ εσπειρα και συναγω οθεν ου διεσκορπισα",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.27",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 27,
      "referenceLabel": "Matthew 25:27",
      "text": "εδει ουν σε βαλειν το αργυριον μου τοις τραπεζιταις και ελθων εγω εκομισαμην αν το εμον συν τοκω",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.28",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 28,
      "referenceLabel": "Matthew 25:28",
      "text": "αρατε ουν απ αυτου το ταλαντον και δοτε τω εχοντι τα δεκα ταλαντα",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.29",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 29,
      "referenceLabel": "Matthew 25:29",
      "text": "τω γαρ εχοντι παντι δοθησεται και περισσευθησεται απο δε του μη εχοντος και ο εχει αρθησεται απ αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.30",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 30,
      "referenceLabel": "Matthew 25:30",
      "text": "και τον αχρειον δουλον εκβαλετε εις το σκοτος το εξωτερον εκει εσται ο κλαυθμος και ο βρυγμος των οδοντων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.31",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 31,
      "referenceLabel": "Matthew 25:31",
      "text": "οταν δε ελθη ο υιος του ανθρωπου εν τη δοξη αυτου και παντες οι αγιοι αγγελοι μετ αυτου τοτε καθισει επι θρονου δοξης αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.32",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 32,
      "referenceLabel": "Matthew 25:32",
      "text": "και συναχθησεται εμπροσθεν αυτου παντα τα εθνη και αφοριει αυτους απ αλληλων ωσπερ ο ποιμην αφοριζει τα προβατα απο των εριφων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.33",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 33,
      "referenceLabel": "Matthew 25:33",
      "text": "και στησει τα μεν προβατα εκ δεξιων αυτου τα δε εριφια εξ ευωνυμων",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.34",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 34,
      "referenceLabel": "Matthew 25:34",
      "text": "τοτε ερει ο βασιλευς τοις εκ δεξιων αυτου δευτε οι ευλογημενοι του πατρος μου κληρονομησατε την ητοιμασμενην υμιν βασιλειαν απο καταβολης κοσμου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.35",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 35,
      "referenceLabel": "Matthew 25:35",
      "text": "επεινασα γαρ και εδωκατε μοι φαγειν εδιψησα και εποτισατε με ξενος ημην και συνηγαγετε με",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.36",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 36,
      "referenceLabel": "Matthew 25:36",
      "text": "γυμνος και περιεβαλετε με ησθενησα και επεσκεψασθε με εν φυλακη ημην και ηλθετε προς με",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.37",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 37,
      "referenceLabel": "Matthew 25:37",
      "text": "τοτε αποκριθησονται αυτω οι δικαιοι λεγοντες κυριε ποτε σε ειδομεν πεινωντα και εθρεψαμεν η διψωντα και εποτισαμεν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.38",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 38,
      "referenceLabel": "Matthew 25:38",
      "text": "ποτε δε σε ειδομεν ξενον και συνηγαγομεν η γυμνον και περιεβαλομεν",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.39",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 39,
      "referenceLabel": "Matthew 25:39",
      "text": "ποτε δε σε ειδομεν ασθενη η εν φυλακη και ηλθομεν προς σε",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.40",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 40,
      "referenceLabel": "Matthew 25:40",
      "text": "και αποκριθεις ο βασιλευς ερει αυτοις αμην λεγω υμιν εφ οσον εποιησατε ενι τουτων των αδελφων μου των ελαχιστων εμοι εποιησατε",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.41",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 41,
      "referenceLabel": "Matthew 25:41",
      "text": "τοτε ερει και τοις εξ ευωνυμων πορευεσθε απ εμου οι κατηραμενοι εις το πυρ το αιωνιον το ητοιμασμενον τω διαβολω και τοις αγγελοις αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.42",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 42,
      "referenceLabel": "Matthew 25:42",
      "text": "επεινασα γαρ και ουκ εδωκατε μοι φαγειν εδιψησα και ουκ εποτισατε με",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.43",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 43,
      "referenceLabel": "Matthew 25:43",
      "text": "ξενος ημην και ου συνηγαγετε με γυμνος και ου περιεβαλετε με ασθενης και εν φυλακη και ουκ επεσκεψασθε με",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.44",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 44,
      "referenceLabel": "Matthew 25:44",
      "text": "τοτε αποκριθησονται και αυτοι λεγοντες κυριε ποτε σε ειδομεν πεινωντα η διψωντα η ξενον η γυμνον η ασθενη η εν φυλακη και ου διηκονησαμεν σοι",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.45",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 45,
      "referenceLabel": "Matthew 25:45",
      "text": "τοτε αποκριθησεται αυτοις λεγων αμην λεγω υμιν εφ οσον ουκ εποιησατε ενι τουτων των ελαχιστων ουδε εμοι εποιησατε",
      "paragraphStart": false
    },
    {
      "id": "byz:matthew.25.46",
      "translationId": "byz",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 46,
      "referenceLabel": "Matthew 25:46",
      "text": "και απελευσονται ουτοι εις κολασιν αιωνιον οι δε δικαιοι εις ζωην αιωνιον",
      "paragraphStart": false
    }
  ]
}
