{
  "chapter": {
    "id": "byz:galatians.4",
    "translationId": "byz",
    "bookSlug": "galatians",
    "chapterNumber": 4,
    "referenceLabel": "Galatians 4",
    "summary": "Source text for Galatians 4 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:galatians.4.1",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Galatians 4:1",
      "text": "λεγω δε εφ οσον χρονον ο κληρονομος νηπιος εστιν ουδεν διαφερει δουλου κυριος παντων ων",
      "paragraphStart": true
    },
    {
      "id": "byz:galatians.4.2",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Galatians 4:2",
      "text": "αλλα υπο επιτροπους εστιν και οικονομους αχρι της προθεσμιας του πατρος",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.3",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Galatians 4:3",
      "text": "ουτως και ημεις οτε ημεν νηπιοι υπο τα στοιχεια του κοσμου ημεν δεδουλωμενοι",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.4",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Galatians 4:4",
      "text": "οτε δε ηλθεν το πληρωμα του χρονου εξαπεστειλεν ο θεος τον υιον αυτου γενομενον εκ γυναικος γενομενον υπο νομον",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.5",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Galatians 4:5",
      "text": "ινα τους υπο νομον εξαγοραση ινα την υιοθεσιαν απολαβωμεν",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.6",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Galatians 4:6",
      "text": "οτι δε εστε υιοι εξαπεστειλεν ο θεος το πνευμα του υιου αυτου εις τας καρδιας υμων κραζον αββα ο πατηρ",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.7",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Galatians 4:7",
      "text": "ωστε ουκετι ει δουλος αλλ υιος ει δε υιος και κληρονομος θεου δια χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.8",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Galatians 4:8",
      "text": "αλλα τοτε μεν ουκ ειδοτες θεον εδουλευσατε τοις μη φυσει ουσιν θεοις",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.9",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Galatians 4:9",
      "text": "νυν δε γνοντες θεον μαλλον δε γνωσθεντες υπο θεου πως επιστρεφετε παλιν επι τα ασθενη και πτωχα στοιχεια οις παλιν ανωθεν δουλευειν θελετε",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.10",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Galatians 4:10",
      "text": "ημερας παρατηρεισθε και μηνας και καιρους και ενιαυτους",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.11",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Galatians 4:11",
      "text": "φοβουμαι υμας μηπως εικη κεκοπιακα εις υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.12",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Galatians 4:12",
      "text": "γινεσθε ως εγω οτι καγω ως υμεις αδελφοι δεομαι υμων ουδεν με ηδικησατε",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.13",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Galatians 4:13",
      "text": "οιδατε δε οτι δι ασθενειαν της σαρκος ευηγγελισαμην υμιν το προτερον",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.14",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Galatians 4:14",
      "text": "και τον πειρασμον μου τον εν τη σαρκι μου ουκ εξουθενησατε ουδε εξεπτυσατε αλλ ως αγγελον θεου εδεξασθε με ως χριστον ιησουν",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.15",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Galatians 4:15",
      "text": "τις ουν ην ο μακαρισμος υμων μαρτυρω γαρ υμιν οτι ει δυνατον τους οφθαλμους υμων εξορυξαντες αν εδωκατε μοι",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.16",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Galatians 4:16",
      "text": "ωστε εχθρος υμων γεγονα αληθευων υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.17",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Galatians 4:17",
      "text": "ζηλουσιν υμας ου καλως αλλα εκκλεισαι υμας θελουσιν ινα αυτους ζηλουτε",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.18",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Galatians 4:18",
      "text": "καλον δε το ζηλουσθαι εν καλω παντοτε και μη μονον εν τω παρειναι με προς υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.19",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Galatians 4:19",
      "text": "τεκνια μου ους παλιν ωδινω αχρι ου μορφωθη χριστος εν υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.20",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Galatians 4:20",
      "text": "ηθελον δε παρειναι προς υμας αρτι και αλλαξαι την φωνην μου οτι απορουμαι εν υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.21",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Galatians 4:21",
      "text": "λεγετε μοι οι υπο νομον θελοντες ειναι τον νομον ουκ ακουετε",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.22",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Galatians 4:22",
      "text": "γεγραπται γαρ οτι αβρααμ δυο υιους εσχεν ενα εκ της παιδισκης και ενα εκ της ελευθερας",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.23",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Galatians 4:23",
      "text": "αλλ ο μεν εκ της παιδισκης κατα σαρκα γεγεννηται ο δε εκ της ελευθερας δια της επαγγελιας",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.24",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Galatians 4:24",
      "text": "ατινα εστιν αλληγορουμενα αυται γαρ εισιν δυο διαθηκαι μια μεν απο ορους σινα εις δουλειαν γεννωσα ητις εστιν αγαρ",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.25",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Galatians 4:25",
      "text": "το γαρ αγαρ σινα ορος εστιν εν τη αραβια συστοιχει δε τη νυν ιερουσαλημ δουλευει δε μετα των τεκνων αυτης",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.26",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Galatians 4:26",
      "text": "η δε ανω ιερουσαλημ ελευθερα εστιν ητις εστιν μητηρ παντων ημων",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.27",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Galatians 4:27",
      "text": "γεγραπται γαρ ευφρανθητι στειρα η ου τικτουσα ρηξον και βοησον η ουκ ωδινουσα οτι πολλα τα τεκνα της ερημου μαλλον η της εχουσης τον ανδρα",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.28",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "Galatians 4:28",
      "text": "ημεις δε αδελφοι κατα ισαακ επαγγελιας τεκνα εσμεν",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.29",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "Galatians 4:29",
      "text": "αλλ ωσπερ τοτε ο κατα σαρκα γεννηθεις εδιωκεν τον κατα πνευμα ουτως και νυν",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.30",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "Galatians 4:30",
      "text": "αλλα τι λεγει η γραφη εκβαλε την παιδισκην και τον υιον αυτης ου γαρ μη κληρονομηση ο υιος της παιδισκης μετα του υιου της ελευθερας",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.4.31",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "Galatians 4:31",
      "text": "αρα αδελφοι ουκ εσμεν παιδισκης τεκνα αλλα της ελευθερας",
      "paragraphStart": false
    }
  ]
}
