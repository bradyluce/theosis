{
  "chapter": {
    "id": "byz:galatians.3",
    "translationId": "byz",
    "bookSlug": "galatians",
    "chapterNumber": 3,
    "referenceLabel": "Galatians 3",
    "summary": "Source text for Galatians 3 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:galatians.3.1",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Galatians 3:1",
      "text": "ω ανοητοι γαλαται τις υμας εβασκανεν τη αληθεια μη πειθεσθαι οις κατ οφθαλμους ιησους χριστος προεγραφη εν υμιν εσταυρωμενος",
      "paragraphStart": true
    },
    {
      "id": "byz:galatians.3.2",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Galatians 3:2",
      "text": "τουτο μονον θελω μαθειν αφ υμων εξ εργων νομου το πνευμα ελαβετε η εξ ακοης πιστεως",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.3",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Galatians 3:3",
      "text": "ουτως ανοητοι εστε εναρξαμενοι πνευματι νυν σαρκι επιτελεισθε",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.4",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Galatians 3:4",
      "text": "τοσαυτα επαθετε εικη ειγε και εικη",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.5",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Galatians 3:5",
      "text": "ο ουν επιχορηγων υμιν το πνευμα και ενεργων δυναμεις εν υμιν εξ εργων νομου η εξ ακοης πιστεως",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.6",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Galatians 3:6",
      "text": "καθως αβρααμ επιστευσεν τω θεω και ελογισθη αυτω εις δικαιοσυνην",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.7",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Galatians 3:7",
      "text": "γινωσκετε αρα οτι οι εκ πιστεως ουτοι εισιν υιοι αβρααμ",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.8",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Galatians 3:8",
      "text": "προιδουσα δε η γραφη οτι εκ πιστεως δικαιοι τα εθνη ο θεος προευηγγελισατο τω αβρααμ οτι ενευλογηθησονται εν σοι παντα τα εθνη",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.9",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Galatians 3:9",
      "text": "ωστε οι εκ πιστεως ευλογουνται συν τω πιστω αβρααμ",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.10",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Galatians 3:10",
      "text": "οσοι γαρ εξ εργων νομου εισιν υπο καταραν εισιν γεγραπται γαρ επικαταρατος πας ος ουκ εμμενει εν πασιν τοις γεγραμμενοις εν τω βιβλιω του νομου του ποιησαι αυτα",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.11",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Galatians 3:11",
      "text": "οτι δε εν νομω ουδεις δικαιουται παρα τω θεω δηλον οτι ο δικαιος εκ πιστεως ζησεται",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.12",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Galatians 3:12",
      "text": "ο δε νομος ουκ εστιν εκ πιστεως αλλ ο ποιησας αυτα ανθρωπος ζησεται εν αυτοις",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.13",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Galatians 3:13",
      "text": "χριστος ημας εξηγορασεν εκ της καταρας του νομου γενομενος υπερ ημων καταρα γεγραπται γαρ επικαταρατος πας ο κρεμαμενος επι ξυλου",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.14",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Galatians 3:14",
      "text": "ινα εις τα εθνη η ευλογια του αβρααμ γενηται εν χριστω ιησου ινα την επαγγελιαν του πνευματος λαβωμεν δια της πιστεως",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.15",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Galatians 3:15",
      "text": "αδελφοι κατα ανθρωπον λεγω ομως ανθρωπου κεκυρωμενην διαθηκην ουδεις αθετει η επιδιατασσεται",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.16",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Galatians 3:16",
      "text": "τω δε αβρααμ ερρηθησαν αι επαγγελιαι και τω σπερματι αυτου ου λεγει και τοις σπερμασιν ως επι πολλων αλλ ως εφ ενος και τω σπερματι σου ος εστιν χριστος",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.17",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Galatians 3:17",
      "text": "τουτο δε λεγω διαθηκην προκεκυρωμενην υπο του θεου εις χριστον ο μετα ετη τετρακοσια και τριακοντα γεγονως νομος ουκ ακυροι εις το καταργησαι την επαγγελιαν",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.18",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Galatians 3:18",
      "text": "ει γαρ εκ νομου η κληρονομια ουκετι εξ επαγγελιας τω δε αβρααμ δι επαγγελιας κεχαρισται ο θεος",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.19",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Galatians 3:19",
      "text": "τι ουν ο νομος των παραβασεων χαριν προσετεθη αχρι ου ελθη το σπερμα ω επηγγελται διαταγεις δι αγγελων εν χειρι μεσιτου",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.20",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Galatians 3:20",
      "text": "ο δε μεσιτης ενος ουκ εστιν ο δε θεος εις εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.21",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Galatians 3:21",
      "text": "ο ουν νομος κατα των επαγγελιων του θεου μη γενοιτο ει γαρ εδοθη νομος ο δυναμενος ζωοποιησαι οντως αν εκ νομου ην η δικαιοσυνη",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.22",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Galatians 3:22",
      "text": "αλλα συνεκλεισεν η γραφη τα παντα υπο αμαρτιαν ινα η επαγγελια εκ πιστεως ιησου χριστου δοθη τοις πιστευουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.23",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Galatians 3:23",
      "text": "προ του δε ελθειν την πιστιν υπο νομον εφρουρουμεθα συγκεκλεισμενοι εις την μελλουσαν πιστιν αποκαλυφθηναι",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.24",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Galatians 3:24",
      "text": "ωστε ο νομος παιδαγωγος ημων γεγονεν εις χριστον ινα εκ πιστεως δικαιωθωμεν",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.25",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Galatians 3:25",
      "text": "ελθουσης δε της πιστεως ουκετι υπο παιδαγωγον εσμεν",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.26",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Galatians 3:26",
      "text": "παντες γαρ υιοι θεου εστε δια της πιστεως εν χριστω ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.27",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Galatians 3:27",
      "text": "οσοι γαρ εις χριστον εβαπτισθητε χριστον ενεδυσασθε",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.28",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Galatians 3:28",
      "text": "ουκ ενι ιουδαιος ουδε ελλην ουκ ενι δουλος ουδε ελευθερος ουκ ενι αρσεν και θηλυ παντες γαρ υμεις εις εστε εν χριστω ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:galatians.3.29",
      "translationId": "byz",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Galatians 3:29",
      "text": "ει δε υμεις χριστου αρα του αβρααμ σπερμα εστε και κατ επαγγελιαν κληρονομοι",
      "paragraphStart": false
    }
  ]
}
