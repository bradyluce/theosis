{
  "chapter": {
    "id": "byz:first-peter.4",
    "translationId": "byz",
    "bookSlug": "first-peter",
    "chapterNumber": 4,
    "referenceLabel": "1 Peter 4",
    "summary": "Source text for 1 Peter 4 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:first-peter.4.1",
      "translationId": "byz",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "1 Peter 4:1",
      "text": "χριστου ουν παθοντος υπερ ημων σαρκι και υμεις την αυτην εννοιαν οπλισασθε οτι ο παθων εν σαρκι πεπαυται αμαρτιας",
      "paragraphStart": true
    },
    {
      "id": "byz:first-peter.4.2",
      "translationId": "byz",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "1 Peter 4:2",
      "text": "εις το μηκετι ανθρωπων επιθυμιαις αλλα θεληματι θεου τον επιλοιπον εν σαρκι βιωσαι χρονον",
      "paragraphStart": false
    },
    {
      "id": "byz:first-peter.4.3",
      "translationId": "byz",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "1 Peter 4:3",
      "text": "αρκετος γαρ ημιν ο παρεληλυθως χρονος του βιου το θελημα των εθνων κατεργασασθαι πεπορευμενους εν ασελγειαις επιθυμιαις οινοφλυγιαις κωμοις ποτοις και αθεμιτοις ειδωλολατρειαις",
      "paragraphStart": false
    },
    {
      "id": "byz:first-peter.4.4",
      "translationId": "byz",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "1 Peter 4:4",
      "text": "εν ω ξενιζονται μη συντρεχοντων υμων εις την αυτην της ασωτιας αναχυσιν βλασφημουντες",
      "paragraphStart": false
    },
    {
      "id": "byz:first-peter.4.5",
      "translationId": "byz",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "1 Peter 4:5",
      "text": "οι αποδωσουσιν λογον τω ετοιμως εχοντι κριναι ζωντας και νεκρους",
      "paragraphStart": false
    },
    {
      "id": "byz:first-peter.4.6",
      "translationId": "byz",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "1 Peter 4:6",
      "text": "εις τουτο γαρ και νεκροις ευηγγελισθη ινα κριθωσιν μεν κατα ανθρωπους σαρκι ζωσιν δε κατα θεον πνευματι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-peter.4.7",
      "translationId": "byz",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "1 Peter 4:7",
      "text": "παντων δε το τελος ηγγικεν σωφρονησατε ουν και νηψατε εις τας προσευχας",
      "paragraphStart": false
    },
    {
      "id": "byz:first-peter.4.8",
      "translationId": "byz",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "1 Peter 4:8",
      "text": "προ παντων δε την εις εαυτους αγαπην εκτενη εχοντες οτι αγαπη καλυψει πληθος αμαρτιων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-peter.4.9",
      "translationId": "byz",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "1 Peter 4:9",
      "text": "φιλοξενοι εις αλληλους ανευ γογγυσμων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-peter.4.10",
      "translationId": "byz",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "1 Peter 4:10",
      "text": "εκαστος καθως ελαβεν χαρισμα εις εαυτους αυτο διακονουντες ως καλοι οικονομοι ποικιλης χαριτος θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-peter.4.11",
      "translationId": "byz",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "1 Peter 4:11",
      "text": "ει τις λαλει ως λογια θεου ει τις διακονει ως εξ ισχυος ως χορηγει ο θεος ινα εν πασιν δοξαζηται ο θεος δια ιησου χριστου ω εστιν η δοξα και το κρατος εις τους αιωνας των αιωνων αμην",
      "paragraphStart": false
    },
    {
      "id": "byz:first-peter.4.12",
      "translationId": "byz",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "1 Peter 4:12",
      "text": "αγαπητοι μη ξενιζεσθε τη εν υμιν πυρωσει προς πειρασμον υμιν γινομενη ως ξενου υμιν συμβαινοντος",
      "paragraphStart": false
    },
    {
      "id": "byz:first-peter.4.13",
      "translationId": "byz",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "1 Peter 4:13",
      "text": "αλλα καθο κοινωνειτε τοις του χριστου παθημασιν χαιρετε ινα και εν τη αποκαλυψει της δοξης αυτου χαρητε αγαλλιωμενοι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-peter.4.14",
      "translationId": "byz",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "1 Peter 4:14",
      "text": "ει ονειδιζεσθε εν ονοματι χριστου μακαριοι οτι το της δοξης και το του θεου πνευμα εφ υμας αναπαυεται κατα μεν αυτους βλασφημειται κατα δε υμας δοξαζεται",
      "paragraphStart": false
    },
    {
      "id": "byz:first-peter.4.15",
      "translationId": "byz",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "1 Peter 4:15",
      "text": "μη γαρ τις υμων πασχετω ως φονευς η κλεπτης η κακοποιος η ως αλλοτριοεπισκοπος",
      "paragraphStart": false
    },
    {
      "id": "byz:first-peter.4.16",
      "translationId": "byz",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "1 Peter 4:16",
      "text": "ει δε ως χριστιανος μη αισχυνεσθω δοξαζετω δε τον θεον εν τω μερει τουτω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-peter.4.17",
      "translationId": "byz",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "1 Peter 4:17",
      "text": "οτι ο καιρος του αρξασθαι το κριμα απο του οικου του θεου ει δε πρωτον αφ ημων τι το τελος των απειθουντων τω του θεου ευαγγελιω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-peter.4.18",
      "translationId": "byz",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "1 Peter 4:18",
      "text": "και ει ο δικαιος μολις σωζεται ο ασεβης και αμαρτωλος που φανειται",
      "paragraphStart": false
    },
    {
      "id": "byz:first-peter.4.19",
      "translationId": "byz",
      "bookSlug": "first-peter",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "1 Peter 4:19",
      "text": "ωστε και οι πασχοντες κατα το θελημα του θεου ως πιστω κτιστη παρατιθεσθωσαν τας ψυχας αυτων εν αγαθοποιια",
      "paragraphStart": false
    }
  ]
}
