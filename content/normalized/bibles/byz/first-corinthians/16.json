{
  "chapter": {
    "id": "byz:first-corinthians.16",
    "translationId": "byz",
    "bookSlug": "first-corinthians",
    "chapterNumber": 16,
    "referenceLabel": "1 Corinthians 16",
    "summary": "Source text for 1 Corinthians 16 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:first-corinthians.16.1",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 16:1",
      "text": "περι δε της λογιας της εις τους αγιους ωσπερ διεταξα ταις εκκλησιαις της γαλατιας ουτως και υμεις ποιησατε",
      "paragraphStart": true
    },
    {
      "id": "byz:first-corinthians.16.2",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 16:2",
      "text": "κατα μιαν σαββατων εκαστος υμων παρ εαυτω τιθετω θησαυριζων ο τι αν ευοδωται ινα μη οταν ελθω τοτε λογιαι γινωνται",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.3",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 16:3",
      "text": "οταν δε παραγενωμαι ους εαν δοκιμασητε δι επιστολων τουτους πεμψω απενεγκειν την χαριν υμων εις ιερουσαλημ",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.4",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 16:4",
      "text": "εαν δε η αξιον του καμε πορευεσθαι συν εμοι πορευσονται",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.5",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 16:5",
      "text": "ελευσομαι δε προς υμας οταν μακεδονιαν διελθω μακεδονιαν γαρ διερχομαι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.6",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 16:6",
      "text": "προς υμας δε τυχον παραμενω η και παραχειμασω ινα υμεις με προπεμψητε ου εαν πορευωμαι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.7",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 16:7",
      "text": "ου θελω γαρ υμας αρτι εν παροδω ιδειν ελπιζω δε χρονον τινα επιμειναι προς υμας εαν ο κυριος επιτρεπη",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.8",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 16:8",
      "text": "επιμενω δε εν εφεσω εως της πεντηκοστης",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.9",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 16:9",
      "text": "θυρα γαρ μοι ανεωγεν μεγαλη και ενεργης και αντικειμενοι πολλοι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.10",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 16:10",
      "text": "εαν δε ελθη τιμοθεος βλεπετε ινα αφοβως γενηται προς υμας το γαρ εργον κυριου εργαζεται ως και εγω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.11",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 16:11",
      "text": "μη τις ουν αυτον εξουθενηση προπεμψατε δε αυτον εν ειρηνη ινα ελθη προς με εκδεχομαι γαρ αυτον μετα των αδελφων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.12",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 16:12",
      "text": "περι δε απολλω του αδελφου πολλα παρεκαλεσα αυτον ινα ελθη προς υμας μετα των αδελφων και παντως ουκ ην θελημα ινα νυν ελθη ελευσεται δε οταν ευκαιρηση",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.13",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 16:13",
      "text": "γρηγορειτε στηκετε εν τη πιστει ανδριζεσθε κραταιουσθε",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.14",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 16:14",
      "text": "παντα υμων εν αγαπη γινεσθω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.15",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 16:15",
      "text": "παρακαλω δε υμας αδελφοι οιδατε την οικιαν στεφανα οτι εστιν απαρχη της αχαιας και εις διακονιαν τοις αγιοις εταξαν εαυτους",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.16",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 16:16",
      "text": "ινα και υμεις υποτασσησθε τοις τοιουτοις και παντι τω συνεργουντι και κοπιωντι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.17",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 16:17",
      "text": "χαιρω δε επι τη παρουσια στεφανα και φουρτουνατου και αχαικου οτι το υμων υστερημα ουτοι ανεπληρωσαν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.18",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 16:18",
      "text": "ανεπαυσαν γαρ το εμον πνευμα και το υμων επιγινωσκετε ουν τους τοιουτους",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.19",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 16:19",
      "text": "ασπαζονται υμας αι εκκλησιαι της ασιας ασπαζονται υμας εν κυριω πολλα ακυλας και πρισκιλλα συν τη κατ οικον αυτων εκκλησια",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.20",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 16:20",
      "text": "ασπαζονται υμας οι αδελφοι παντες ασπασασθε αλληλους εν φιληματι αγιω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.21",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 16:21",
      "text": "ο ασπασμος τη εμη χειρι παυλου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.22",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 16:22",
      "text": "ει τις ου φιλει τον κυριον ιησουν χριστον ητω αναθεμα μαραν αθα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.23",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 16:23",
      "text": "η χαρις του κυριου ιησου χριστου μεθ υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.16.24",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 16:24",
      "text": "η αγαπη μου μετα παντων υμων εν χριστω ιησου αμην",
      "paragraphStart": false
    }
  ]
}
