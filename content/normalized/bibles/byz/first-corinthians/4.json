{
  "chapter": {
    "id": "byz:first-corinthians.4",
    "translationId": "byz",
    "bookSlug": "first-corinthians",
    "chapterNumber": 4,
    "referenceLabel": "1 Corinthians 4",
    "summary": "Source text for 1 Corinthians 4 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:first-corinthians.4.1",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 4:1",
      "text": "ουτως ημας λογιζεσθω ανθρωπος ως υπηρετας χριστου και οικονομους μυστηριων θεου",
      "paragraphStart": true
    },
    {
      "id": "byz:first-corinthians.4.2",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 4:2",
      "text": "ο δε λοιπον ζητειται εν τοις οικονομοις ινα πιστος τις ευρεθη",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.4.3",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 4:3",
      "text": "εμοι δε εις ελαχιστον εστιν ινα υφ υμων ανακριθω η υπο ανθρωπινης ημερας αλλ ουδε εμαυτον ανακρινω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.4.4",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 4:4",
      "text": "ουδεν γαρ εμαυτω συνοιδα αλλ ουκ εν τουτω δεδικαιωμαι ο δε ανακρινων με κυριος εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.4.5",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 4:5",
      "text": "ωστε μη προ καιρου τι κρινετε εως αν ελθη ο κυριος ος και φωτισει τα κρυπτα του σκοτους και φανερωσει τας βουλας των καρδιων και τοτε ο επαινος γενησεται εκαστω απο του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.4.6",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 4:6",
      "text": "ταυτα δε αδελφοι μετεσχηματισα εις εμαυτον και απολλω δι υμας ινα εν ημιν μαθητε το μη υπερ ο γεγραπται φρονειν ινα μη εις υπερ του ενος φυσιουσθε κατα του ετερου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.4.7",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 4:7",
      "text": "τις γαρ σε διακρινει τι δε εχεις ο ουκ ελαβες ει δε και ελαβες τι καυχασαι ως μη λαβων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.4.8",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 4:8",
      "text": "ηδη κεκορεσμενοι εστε ηδη επλουτησατε χωρις ημων εβασιλευσατε και οφελον γε εβασιλευσατε ινα και ημεις υμιν συμβασιλευσωμεν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.4.9",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 4:9",
      "text": "δοκω γαρ οτι ο θεος ημας τους αποστολους εσχατους απεδειξεν ως επιθανατιους οτι θεατρον εγενηθημεν τω κοσμω και αγγελοις και ανθρωποις",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.4.10",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 4:10",
      "text": "ημεις μωροι δια χριστον υμεις δε φρονιμοι εν χριστω ημεις ασθενεις υμεις δε ισχυροι υμεις ενδοξοι ημεις δε ατιμοι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.4.11",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 4:11",
      "text": "αχρι της αρτι ωρας και πεινωμεν και διψωμεν και γυμνητευομεν και κολαφιζομεθα και αστατουμεν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.4.12",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 4:12",
      "text": "και κοπιωμεν εργαζομενοι ταις ιδιαις χερσιν λοιδορουμενοι ευλογουμεν διωκομενοι ανεχομεθα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.4.13",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 4:13",
      "text": "βλασφημουμενοι παρακαλουμεν ως περικαθαρματα του κοσμου εγενηθημεν παντων περιψημα εως αρτι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.4.14",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 4:14",
      "text": "ουκ εντρεπων υμας γραφω ταυτα αλλ ως τεκνα μου αγαπητα νουθετω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.4.15",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 4:15",
      "text": "εαν γαρ μυριους παιδαγωγους εχητε εν χριστω αλλ ου πολλους πατερας εν γαρ χριστω ιησου δια του ευαγγελιου εγω υμας εγεννησα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.4.16",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 4:16",
      "text": "παρακαλω ουν υμας μιμηται μου γινεσθε",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.4.17",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 4:17",
      "text": "δια τουτο επεμψα υμιν τιμοθεον ος εστιν τεκνον μου αγαπητον και πιστον εν κυριω ος υμας αναμνησει τας οδους μου τας εν χριστω καθως πανταχου εν παση εκκλησια διδασκω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.4.18",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 4:18",
      "text": "ως μη ερχομενου δε μου προς υμας εφυσιωθησαν τινες",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.4.19",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 4:19",
      "text": "ελευσομαι δε ταχεως προς υμας εαν ο κυριος θεληση και γνωσομαι ου τον λογον των πεφυσιωμενων αλλα την δυναμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.4.20",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 4:20",
      "text": "ου γαρ εν λογω η βασιλεια του θεου αλλ εν δυναμει",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.4.21",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 4:21",
      "text": "τι θελετε εν ραβδω ελθω προς υμας η εν αγαπη πνευματι τε πραοτητος",
      "paragraphStart": false
    }
  ]
}
