{
  "chapter": {
    "id": "byz:first-corinthians.11",
    "translationId": "byz",
    "bookSlug": "first-corinthians",
    "chapterNumber": 11,
    "referenceLabel": "1 Corinthians 11",
    "summary": "Source text for 1 Corinthians 11 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:first-corinthians.11.1",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 11:1",
      "text": "μιμηται μου γινεσθε καθως καγω χριστου",
      "paragraphStart": true
    },
    {
      "id": "byz:first-corinthians.11.2",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 11:2",
      "text": "επαινω δε υμας αδελφοι οτι παντα μου μεμνησθε και καθως παρεδωκα υμιν τας παραδοσεις κατεχετε",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.3",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 11:3",
      "text": "θελω δε υμας ειδεναι οτι παντος ανδρος η κεφαλη ο χριστος εστιν κεφαλη δε γυναικος ο ανηρ κεφαλη δε χριστου ο θεος",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.4",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 11:4",
      "text": "πας ανηρ προσευχομενος η προφητευων κατα κεφαλης εχων καταισχυνει την κεφαλην αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.5",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 11:5",
      "text": "πασα δε γυνη προσευχομενη η προφητευουσα ακατακαλυπτω τη κεφαλη καταισχυνει την κεφαλην εαυτης εν γαρ εστιν και το αυτο τη εξυρημενη",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.6",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 11:6",
      "text": "ει γαρ ου κατακαλυπτεται γυνη και κειρασθω ει δε αισχρον γυναικι το κειρασθαι η ξυρασθαι κατακαλυπτεσθω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.7",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 11:7",
      "text": "ανηρ μεν γαρ ουκ οφειλει κατακαλυπτεσθαι την κεφαλην εικων και δοξα θεου υπαρχων γυνη δε δοξα ανδρος εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.8",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 11:8",
      "text": "ου γαρ εστιν ανηρ εκ γυναικος αλλα γυνη εξ ανδρος",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.9",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 11:9",
      "text": "και γαρ ουκ εκτισθη ανηρ δια την γυναικα αλλα γυνη δια τον ανδρα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.10",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 11:10",
      "text": "δια τουτο οφειλει η γυνη εξουσιαν εχειν επι της κεφαλης δια τους αγγελους",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.11",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 11:11",
      "text": "πλην ουτε ανηρ χωρις γυναικος ουτε γυνη χωρις ανδρος εν κυριω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.12",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 11:12",
      "text": "ωσπερ γαρ η γυνη εκ του ανδρος ουτως και ο ανηρ δια της γυναικος τα δε παντα εκ του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.13",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 11:13",
      "text": "εν υμιν αυτοις κρινατε πρεπον εστιν γυναικα ακατακαλυπτον τω θεω προσευχεσθαι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.14",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 11:14",
      "text": "η ουδε αυτη η φυσις διδασκει υμας οτι ανηρ μεν εαν κομα ατιμια αυτω εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.15",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 11:15",
      "text": "γυνη δε εαν κομα δοξα αυτη εστιν οτι η κομη αντι περιβολαιου δεδοται",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.16",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 11:16",
      "text": "ει δε τις δοκει φιλονεικος ειναι ημεις τοιαυτην συνηθειαν ουκ εχομεν ουδε αι εκκλησιαι του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.17",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 11:17",
      "text": "τουτο δε παραγγελλων ουκ επαινω οτι ουκ εις το κρειττον αλλ εις το ηττον συνερχεσθε",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.18",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 11:18",
      "text": "πρωτον μεν γαρ συνερχομενων υμων εν εκκλησια ακουω σχισματα εν υμιν υπαρχειν και μερος τι πιστευω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.19",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 11:19",
      "text": "δει γαρ και αιρεσεις εν υμιν ειναι ινα οι δοκιμοι φανεροι γενωνται εν υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.20",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 11:20",
      "text": "συνερχομενων ουν υμων επι το αυτο ουκ εστιν κυριακον δειπνον φαγειν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.21",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 11:21",
      "text": "εκαστος γαρ το ιδιον δειπνον προλαμβανει εν τω φαγειν και ος μεν πεινα ος δε μεθυει",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.22",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 11:22",
      "text": "μη γαρ οικιας ουκ εχετε εις το εσθιειν και πινειν η της εκκλησιας του θεου καταφρονειτε και καταισχυνετε τους μη εχοντας τι υμιν ειπω επαινεσω υμας εν τουτω ουκ επαινω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.23",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 11:23",
      "text": "εγω γαρ παρελαβον απο του κυριου ο και παρεδωκα υμιν οτι ο κυριος ιησους εν τη νυκτι η παρεδιδοτο ελαβεν αρτον",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.24",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 11:24",
      "text": "και ευχαριστησας εκλασεν και ειπεν λαβετε φαγετε τουτο μου εστιν το σωμα το υπερ υμων κλωμενον τουτο ποιειτε εις την εμην αναμνησιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.25",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "1 Corinthians 11:25",
      "text": "ωσαυτως και το ποτηριον μετα το δειπνησαι λεγων τουτο το ποτηριον η καινη διαθηκη εστιν εν τω εμω αιματι τουτο ποιειτε οσακις αν πινητε εις την εμην αναμνησιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.26",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 11:26",
      "text": "οσακις γαρ αν εσθιητε τον αρτον τουτον και το ποτηριον τουτο πινητε τον θανατον του κυριου καταγγελλετε αχρι ου αν ελθη",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.27",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "1 Corinthians 11:27",
      "text": "ωστε ος αν εσθιη τον αρτον τουτον η πινη το ποτηριον του κυριου αναξιως του κυριου ενοχος εσται του σωματος και του αιματος του κυριου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.28",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "1 Corinthians 11:28",
      "text": "δοκιμαζετω δε ανθρωπος εαυτον και ουτως εκ του αρτου εσθιετω και εκ του ποτηριου πινετω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.29",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "1 Corinthians 11:29",
      "text": "ο γαρ εσθιων και πινων αναξιως κριμα εαυτω εσθιει και πινει μη διακρινων το σωμα του κυριου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.30",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "1 Corinthians 11:30",
      "text": "δια τουτο εν υμιν πολλοι ασθενεις και αρρωστοι και κοιμωνται ικανοι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.31",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "1 Corinthians 11:31",
      "text": "ει γαρ εαυτους διεκρινομεν ουκ αν εκρινομεθα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.32",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 32,
      "referenceLabel": "1 Corinthians 11:32",
      "text": "κρινομενοι δε υπο κυριου παιδευομεθα ινα μη συν τω κοσμω κατακριθωμεν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.33",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 33,
      "referenceLabel": "1 Corinthians 11:33",
      "text": "ωστε αδελφοι μου συνερχομενοι εις το φαγειν αλληλους εκδεχεσθε",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.11.34",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 34,
      "referenceLabel": "1 Corinthians 11:34",
      "text": "ει δε τις πεινα εν οικω εσθιετω ινα μη εις κριμα συνερχησθε τα δε λοιπα ως αν ελθω διαταξομαι",
      "paragraphStart": false
    }
  ]
}
