{
  "chapter": {
    "id": "byz:first-corinthians.13",
    "translationId": "byz",
    "bookSlug": "first-corinthians",
    "chapterNumber": 13,
    "referenceLabel": "1 Corinthians 13",
    "summary": "Source text for 1 Corinthians 13 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:first-corinthians.13.1",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 13:1",
      "text": "εαν ταις γλωσσαις των ανθρωπων λαλω και των αγγελων αγαπην δε μη εχω γεγονα χαλκος ηχων η κυμβαλον αλαλαζον",
      "paragraphStart": true
    },
    {
      "id": "byz:first-corinthians.13.2",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 13:2",
      "text": "και εαν εχω προφητειαν και ειδω τα μυστηρια παντα και πασαν την γνωσιν και εαν εχω πασαν την πιστιν ωστε ορη μεθιστανειν αγαπην δε μη εχω ουθεν ειμι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.13.3",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 13:3",
      "text": "και εαν ψωμισω παντα τα υπαρχοντα μου και εαν παραδω το σωμα μου ινα καυθησωμαι αγαπην δε μη εχω ουδεν ωφελουμαι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.13.4",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 13:4",
      "text": "η αγαπη μακροθυμει χρηστευεται η αγαπη ου ζηλοι η αγαπη ου περπερευεται ου φυσιουται",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.13.5",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 13:5",
      "text": "ουκ ασχημονει ου ζητει τα εαυτης ου παροξυνεται ου λογιζεται το κακον",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.13.6",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 13:6",
      "text": "ου χαιρει επι τη αδικια συγχαιρει δε τη αληθεια",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.13.7",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 13:7",
      "text": "παντα στεγει παντα πιστευει παντα ελπιζει παντα υπομενει",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.13.8",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 13:8",
      "text": "η αγαπη ουδεποτε εκπιπτει ειτε δε προφητειαι καταργηθησονται ειτε γλωσσαι παυσονται ειτε γνωσις καταργηθησεται",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.13.9",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 13:9",
      "text": "εκ μερους δε γινωσκομεν και εκ μερους προφητευομεν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.13.10",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 13:10",
      "text": "οταν δε ελθη το τελειον τοτε το εκ μερους καταργηθησεται",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.13.11",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 13:11",
      "text": "οτε ημην νηπιος ως νηπιος ελαλουν ως νηπιος εφρονουν ως νηπιος ελογιζομην οτε δε γεγονα ανηρ κατηργηκα τα του νηπιου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.13.12",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 13:12",
      "text": "βλεπομεν γαρ αρτι δι εσοπτρου εν αινιγματι τοτε δε προσωπον προς προσωπον αρτι γινωσκω εκ μερους τοτε δε επιγνωσομαι καθως και επεγνωσθην",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.13.13",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 13:13",
      "text": "νυνι δε μενει πιστις ελπις αγαπη τα τρια ταυτα μειζων δε τουτων η αγαπη",
      "paragraphStart": false
    }
  ]
}
