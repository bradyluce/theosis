{
  "chapter": {
    "id": "byz:first-corinthians.3",
    "translationId": "byz",
    "bookSlug": "first-corinthians",
    "chapterNumber": 3,
    "referenceLabel": "1 Corinthians 3",
    "summary": "Source text for 1 Corinthians 3 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:first-corinthians.3.1",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 3:1",
      "text": "και εγω αδελφοι ουκ ηδυνηθην υμιν λαλησαι ως πνευματικοις αλλ ως σαρκικοις ως νηπιοις εν χριστω",
      "paragraphStart": true
    },
    {
      "id": "byz:first-corinthians.3.2",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 3:2",
      "text": "γαλα υμας εποτισα και ου βρωμα ουπω γαρ εδυνασθε αλλ ουτε ετι νυν δυνασθε",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.3",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 3:3",
      "text": "ετι γαρ σαρκικοι εστε οπου γαρ εν υμιν ζηλος και ερις και διχοστασιαι ουχι σαρκικοι εστε και κατα ανθρωπον περιπατειτε",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.4",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 3:4",
      "text": "οταν γαρ λεγη τις εγω μεν ειμι παυλου ετερος δε εγω απολλω ουχι σαρκικοι εστε",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.5",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 3:5",
      "text": "τις ουν εστιν παυλος τις δε απολλως αλλ η διακονοι δι ων επιστευσατε και εκαστω ως ο κυριος εδωκεν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.6",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 3:6",
      "text": "εγω εφυτευσα απολλως εποτισεν αλλ ο θεος ηυξανεν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.7",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 3:7",
      "text": "ωστε ουτε ο φυτευων εστιν τι ουτε ο ποτιζων αλλ ο αυξανων θεος",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.8",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 3:8",
      "text": "ο φυτευων δε και ο ποτιζων εν εισιν εκαστος δε τον ιδιον μισθον ληψεται κατα τον ιδιον κοπον",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.9",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 3:9",
      "text": "θεου γαρ εσμεν συνεργοι θεου γεωργιον θεου οικοδομη εστε",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.10",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 3:10",
      "text": "κατα την χαριν του θεου την δοθεισαν μοι ως σοφος αρχιτεκτων θεμελιον τεθεικα αλλος δε εποικοδομει εκαστος δε βλεπετω πως εποικοδομει",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.11",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 3:11",
      "text": "θεμελιον γαρ αλλον ουδεις δυναται θειναι παρα τον κειμενον ος εστιν ιησους χριστος",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.12",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 3:12",
      "text": "ει δε τις εποικοδομει επι τον θεμελιον τουτον χρυσον αργυρον λιθους τιμιους ξυλα χορτον καλαμην",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.13",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 3:13",
      "text": "εκαστου το εργον φανερον γενησεται η γαρ ημερα δηλωσει οτι εν πυρι αποκαλυπτεται και εκαστου το εργον οποιον εστιν το πυρ δοκιμασει",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.14",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 3:14",
      "text": "ει τινος το εργον μενει ο εποικοδομησεν μισθον ληψεται",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.15",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 3:15",
      "text": "ει τινος το εργον κατακαησεται ζημιωθησεται αυτος δε σωθησεται ουτως δε ως δια πυρος",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.16",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 3:16",
      "text": "ουκ οιδατε οτι ναος θεου εστε και το πνευμα του θεου οικει εν υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.17",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 3:17",
      "text": "ει τις τον ναον του θεου φθειρει φθερει τουτον ο θεος ο γαρ ναος του θεου αγιος εστιν οιτινες εστε υμεις",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.18",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 3:18",
      "text": "μηδεις εαυτον εξαπατατω ει τις δοκει σοφος ειναι εν υμιν εν τω αιωνι τουτω μωρος γενεσθω ινα γενηται σοφος",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.19",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 3:19",
      "text": "η γαρ σοφια του κοσμου τουτου μωρια παρα τω θεω εστιν γεγραπται γαρ ο δρασσομενος τους σοφους εν τη πανουργια αυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.20",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 3:20",
      "text": "και παλιν κυριος γινωσκει τους διαλογισμους των σοφων οτι εισιν ματαιοι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.21",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 3:21",
      "text": "ωστε μηδεις καυχασθω εν ανθρωποις παντα γαρ υμων εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.22",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 3:22",
      "text": "ειτε παυλος ειτε απολλως ειτε κηφας ειτε κοσμος ειτε ζωη ειτε θανατος ειτε ενεστωτα ειτε μελλοντα παντα υμων εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.3.23",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 3:23",
      "text": "υμεις δε χριστου χριστος δε θεου",
      "paragraphStart": false
    }
  ]
}
