{
  "chapter": {
    "id": "byz:first-corinthians.12",
    "translationId": "byz",
    "bookSlug": "first-corinthians",
    "chapterNumber": 12,
    "referenceLabel": "1 Corinthians 12",
    "summary": "Source text for 1 Corinthians 12 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:first-corinthians.12.1",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 12:1",
      "text": "περι δε των πνευματικων αδελφοι ου θελω υμας αγνοειν",
      "paragraphStart": true
    },
    {
      "id": "byz:first-corinthians.12.2",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 12:2",
      "text": "οιδατε οτι οτε εθνη ητε προς τα ειδωλα τα αφωνα ως αν ηγεσθε απαγομενοι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.3",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 12:3",
      "text": "διο γνωριζω υμιν οτι ουδεις εν πνευματι θεου λαλων λεγει αναθεμα ιησουν και ουδεις δυναται ειπειν κυριον ιησουν ει μη εν πνευματι αγιω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.4",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 12:4",
      "text": "διαιρεσεις δε χαρισματων εισιν το δε αυτο πνευμα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.5",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 12:5",
      "text": "και διαιρεσεις διακονιων εισιν και ο αυτος κυριος",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.6",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 12:6",
      "text": "και διαιρεσεις ενεργηματων εισιν ο δε αυτος εστιν θεος ο ενεργων τα παντα εν πασιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.7",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 12:7",
      "text": "εκαστω δε διδοται η φανερωσις του πνευματος προς το συμφερον",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.8",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 12:8",
      "text": "ω μεν γαρ δια του πνευματος διδοται λογος σοφιας αλλω δε λογος γνωσεως κατα το αυτο πνευμα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.9",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 12:9",
      "text": "ετερω δε πιστις εν τω αυτω πνευματι αλλω δε χαρισματα ιαματων εν τω αυτω πνευματι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.10",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 12:10",
      "text": "αλλω δε ενεργηματα δυναμεων αλλω δε προφητεια αλλω δε διακρισεις πνευματων ετερω δε γενη γλωσσων αλλω δε ερμηνεια γλωσσων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.11",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 12:11",
      "text": "παντα δε ταυτα ενεργει το εν και το αυτο πνευμα διαιρουν ιδια εκαστω καθως βουλεται",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.12",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 12:12",
      "text": "καθαπερ γαρ το σωμα εν εστιν και μελη εχει πολλα παντα δε τα μελη του σωματος του ενος πολλα οντα εν εστιν σωμα ουτως και ο χριστος",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.13",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 12:13",
      "text": "και γαρ εν ενι πνευματι ημεις παντες εις εν σωμα εβαπτισθημεν ειτε ιουδαιοι ειτε ελληνες ειτε δουλοι ειτε ελευθεροι και παντες εις εν πνευμα εποτισθημεν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.14",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 12:14",
      "text": "και γαρ το σωμα ουκ εστιν εν μελος αλλα πολλα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.15",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 12:15",
      "text": "εαν ειπη ο πους οτι ουκ ειμι χειρ ουκ ειμι εκ του σωματος ου παρα τουτο ουκ εστιν εκ του σωματος",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.16",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 12:16",
      "text": "και εαν ειπη το ους οτι ουκ ειμι οφθαλμος ουκ ειμι εκ του σωματος ου παρα τουτο ουκ εστιν εκ του σωματος",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.17",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 12:17",
      "text": "ει ολον το σωμα οφθαλμος που η ακοη ει ολον ακοη που η οσφρησις",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.18",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 12:18",
      "text": "νυνι δε ο θεος εθετο τα μελη εν εκαστον αυτων εν τω σωματι καθως ηθελησεν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.19",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 12:19",
      "text": "ει δε ην τα παντα εν μελος που το σωμα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.20",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 12:20",
      "text": "νυν δε πολλα μεν μελη εν δε σωμα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.21",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 12:21",
      "text": "ου δυναται δε ο οφθαλμος ειπειν τη χειρι χρειαν σου ουκ εχω η παλιν η κεφαλη τοις ποσιν χρειαν υμων ουκ εχω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.22",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 12:22",
      "text": "αλλα πολλω μαλλον τα δοκουντα μελη του σωματος ασθενεστερα υπαρχειν αναγκαια εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.23",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 12:23",
      "text": "και α δοκουμεν ατιμοτερα ειναι του σωματος τουτοις τιμην περισσοτεραν περιτιθεμεν και τα ασχημονα ημων ευσχημοσυνην περισσοτεραν εχει",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.24",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 12:24",
      "text": "τα δε ευσχημονα ημων ου χρειαν εχει αλλ ο θεος συνεκερασεν το σωμα τω υστερουντι περισσοτεραν δους τιμην",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.25",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "1 Corinthians 12:25",
      "text": "ινα μη η σχισματα εν τω σωματι αλλα το αυτο υπερ αλληλων μεριμνωσιν τα μελη",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.26",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 12:26",
      "text": "και ειτε πασχει εν μελος συμπασχει παντα τα μελη ειτε δοξαζεται εν μελος συγχαιρει παντα τα μελη",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.27",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "1 Corinthians 12:27",
      "text": "υμεις δε εστε σωμα χριστου και μελη εκ μερους",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.28",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "1 Corinthians 12:28",
      "text": "και ους μεν εθετο ο θεος εν τη εκκλησια πρωτον αποστολους δευτερον προφητας τριτον διδασκαλους επειτα δυναμεις ειτα χαρισματα ιαματων αντιληψεις κυβερνησεις γενη γλωσσων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.29",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 29,
      "referenceLabel": "1 Corinthians 12:29",
      "text": "μη παντες αποστολοι μη παντες προφηται μη παντες διδασκαλοι μη παντες δυναμεις",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.30",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 30,
      "referenceLabel": "1 Corinthians 12:30",
      "text": "μη παντες χαρισματα εχουσιν ιαματων μη παντες γλωσσαις λαλουσιν μη παντες διερμηνευουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.12.31",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 31,
      "referenceLabel": "1 Corinthians 12:31",
      "text": "ζηλουτε δε τα χαρισματα τα κρειττονα και ετι καθ υπερβολην οδον υμιν δεικνυμι",
      "paragraphStart": false
    }
  ]
}
