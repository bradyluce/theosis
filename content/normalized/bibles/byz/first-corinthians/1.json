{
  "chapter": {
    "id": "byz:first-corinthians.1",
    "translationId": "byz",
    "bookSlug": "first-corinthians",
    "chapterNumber": 1,
    "referenceLabel": "1 Corinthians 1",
    "summary": "Source text for 1 Corinthians 1 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:first-corinthians.1.1",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 1:1",
      "text": "παυλος κλητος αποστολος ιησου χριστου δια θεληματος θεου και σωσθενης ο αδελφος",
      "paragraphStart": true
    },
    {
      "id": "byz:first-corinthians.1.2",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 1:2",
      "text": "τη εκκλησια του θεου τη ουση εν κορινθω ηγιασμενοις εν χριστω ιησου κλητοις αγιοις συν πασιν τοις επικαλουμενοις το ονομα του κυριου ημων ιησου χριστου εν παντι τοπω αυτων τε και ημων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.3",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 1:3",
      "text": "χαρις υμιν και ειρηνη απο θεου πατρος ημων και κυριου ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.4",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 1:4",
      "text": "ευχαριστω τω θεω μου παντοτε περι υμων επι τη χαριτι του θεου τη δοθειση υμιν εν χριστω ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.5",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 1:5",
      "text": "οτι εν παντι επλουτισθητε εν αυτω εν παντι λογω και παση γνωσει",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.6",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 1:6",
      "text": "καθως το μαρτυριον του χριστου εβεβαιωθη εν υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.7",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 1:7",
      "text": "ωστε υμας μη υστερεισθαι εν μηδενι χαρισματι απεκδεχομενους την αποκαλυψιν του κυριου ημων ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.8",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 1:8",
      "text": "ος και βεβαιωσει υμας εως τελους ανεγκλητους εν τη ημερα του κυριου ημων ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.9",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 1:9",
      "text": "πιστος ο θεος δι ου εκληθητε εις κοινωνιαν του υιου αυτου ιησου χριστου του κυριου ημων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.10",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 1:10",
      "text": "παρακαλω δε υμας αδελφοι δια του ονοματος του κυριου ημων ιησου χριστου ινα το αυτο λεγητε παντες και μη η εν υμιν σχισματα ητε δε κατηρτισμενοι εν τω αυτω νοι και εν τη αυτη γνωμη",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.11",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 1:11",
      "text": "εδηλωθη γαρ μοι περι υμων αδελφοι μου υπο των χλοης οτι εριδες εν υμιν εισιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.12",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 1:12",
      "text": "λεγω δε τουτο οτι εκαστος υμων λεγει εγω μεν ειμι παυλου εγω δε απολλω εγω δε κηφα εγω δε χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.13",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 1:13",
      "text": "μεμερισται ο χριστος μη παυλος εσταυρωθη υπερ υμων η εις το ονομα παυλου εβαπτισθητε",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.14",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 1:14",
      "text": "ευχαριστω τω θεω οτι ουδενα υμων εβαπτισα ει μη κρισπον και γαιον",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.15",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 1:15",
      "text": "ινα μη τις ειπη οτι εις το εμον ονομα εβαπτισα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.16",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 1:16",
      "text": "εβαπτισα δε και τον στεφανα οικον λοιπον ουκ οιδα ει τινα αλλον εβαπτισα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.17",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 1:17",
      "text": "ου γαρ απεστειλεν με χριστος βαπτιζειν αλλ ευαγγελιζεσθαι ουκ εν σοφια λογου ινα μη κενωθη ο σταυρος του χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.18",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 1:18",
      "text": "ο λογος γαρ ο του σταυρου τοις μεν απολλυμενοις μωρια εστιν τοις δε σωζομενοις ημιν δυναμις θεου εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.19",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 1:19",
      "text": "γεγραπται γαρ απολω την σοφιαν των σοφων και την συνεσιν των συνετων αθετησω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.20",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 1:20",
      "text": "που σοφος που γραμματευς που συζητητης του αιωνος τουτου ουχι εμωρανεν ο θεος την σοφιαν του κοσμου τουτου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.21",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 1:21",
      "text": "επειδη γαρ εν τη σοφια του θεου ουκ εγνω ο κοσμος δια της σοφιας τον θεον ευδοκησεν ο θεος δια της μωριας του κηρυγματος σωσαι τους πιστευοντας",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.22",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 1:22",
      "text": "επειδη και ιουδαιοι σημειον αιτουσιν και ελληνες σοφιαν ζητουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.23",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 1:23",
      "text": "ημεις δε κηρυσσομεν χριστον εσταυρωμενον ιουδαιοις μεν σκανδαλον ελλησιν δε μωριαν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.24",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 1:24",
      "text": "αυτοις δε τοις κλητοις ιουδαιοις τε και ελλησιν χριστον θεου δυναμιν και θεου σοφιαν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.25",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "1 Corinthians 1:25",
      "text": "οτι το μωρον του θεου σοφωτερον των ανθρωπων εστιν και το ασθενες του θεου ισχυροτερον των ανθρωπων εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.26",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 1:26",
      "text": "βλεπετε γαρ την κλησιν υμων αδελφοι οτι ου πολλοι σοφοι κατα σαρκα ου πολλοι δυνατοι ου πολλοι ευγενεις",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.27",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "1 Corinthians 1:27",
      "text": "αλλα τα μωρα του κοσμου εξελεξατο ο θεος ινα τους σοφους καταισχυνη και τα ασθενη του κοσμου εξελεξατο ο θεος ινα καταισχυνη τα ισχυρα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.28",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "1 Corinthians 1:28",
      "text": "και τα αγενη του κοσμου και τα εξουθενημενα εξελεξατο ο θεος και τα μη οντα ινα τα οντα καταργηση",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.29",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "1 Corinthians 1:29",
      "text": "οπως μη καυχησηται πασα σαρξ ενωπιον του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.30",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "1 Corinthians 1:30",
      "text": "εξ αυτου δε υμεις εστε εν χριστω ιησου ος εγενηθη ημιν σοφια απο θεου δικαιοσυνη τε και αγιασμος και απολυτρωσις",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.1.31",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "1 Corinthians 1:31",
      "text": "ινα καθως γεγραπται ο καυχωμενος εν κυριω καυχασθω",
      "paragraphStart": false
    }
  ]
}
