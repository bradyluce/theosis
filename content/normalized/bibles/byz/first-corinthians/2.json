{
  "chapter": {
    "id": "byz:first-corinthians.2",
    "translationId": "byz",
    "bookSlug": "first-corinthians",
    "chapterNumber": 2,
    "referenceLabel": "1 Corinthians 2",
    "summary": "Source text for 1 Corinthians 2 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:first-corinthians.2.1",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 2:1",
      "text": "καγω ελθων προς υμας αδελφοι ηλθον ου καθ υπεροχην λογου η σοφιας καταγγελλων υμιν το μαρτυριον του θεου",
      "paragraphStart": true
    },
    {
      "id": "byz:first-corinthians.2.2",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 2:2",
      "text": "ου γαρ εκρινα του ειδεναι τι εν υμιν ει μη ιησουν χριστον και τουτον εσταυρωμενον",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.2.3",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 2:3",
      "text": "και εγω εν ασθενεια και εν φοβω και εν τρομω πολλω εγενομην προς υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.2.4",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 2:4",
      "text": "και ο λογος μου και το κηρυγμα μου ουκ εν πειθοις ανθρωπινης σοφιας λογοις αλλ εν αποδειξει πνευματος και δυναμεως",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.2.5",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 2:5",
      "text": "ινα η πιστις υμων μη η εν σοφια ανθρωπων αλλ εν δυναμει θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.2.6",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 2:6",
      "text": "σοφιαν δε λαλουμεν εν τοις τελειοις σοφιαν δε ου του αιωνος τουτου ουδε των αρχοντων του αιωνος τουτου των καταργουμενων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.2.7",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 2:7",
      "text": "αλλα λαλουμεν σοφιαν θεου εν μυστηριω την αποκεκρυμμενην ην προωρισεν ο θεος προ των αιωνων εις δοξαν ημων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.2.8",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 2:8",
      "text": "ην ουδεις των αρχοντων του αιωνος τουτου εγνωκεν ει γαρ εγνωσαν ουκ αν τον κυριον της δοξης εσταυρωσαν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.2.9",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 2:9",
      "text": "αλλα καθως γεγραπται α οφθαλμος ουκ ειδεν και ους ουκ ηκουσεν και επι καρδιαν ανθρωπου ουκ ανεβη α ητοιμασεν ο θεος τοις αγαπωσιν αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.2.10",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 2:10",
      "text": "ημιν δε ο θεος απεκαλυψεν δια του πνευματος αυτου το γαρ πνευμα παντα ερευνα και τα βαθη του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.2.11",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 2:11",
      "text": "τις γαρ οιδεν ανθρωπων τα του ανθρωπου ει μη το πνευμα του ανθρωπου το εν αυτω ουτως και τα του θεου ουδεις οιδεν ει μη το πνευμα του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.2.12",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 2:12",
      "text": "ημεις δε ου το πνευμα του κοσμου ελαβομεν αλλα το πνευμα το εκ του θεου ινα ειδωμεν τα υπο του θεου χαρισθεντα ημιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.2.13",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 2:13",
      "text": "α και λαλουμεν ουκ εν διδακτοις ανθρωπινης σοφιας λογοις αλλ εν διδακτοις πνευματος αγιου πνευματικοις πνευματικα συγκρινοντες",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.2.14",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 2:14",
      "text": "ψυχικος δε ανθρωπος ου δεχεται τα του πνευματος του θεου μωρια γαρ αυτω εστιν και ου δυναται γνωναι οτι πνευματικως ανακρινεται",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.2.15",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 2:15",
      "text": "ο δε πνευματικος ανακρινει μεν παντα αυτος δε υπ ουδενος ανακρινεται",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.2.16",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 2:16",
      "text": "τις γαρ εγνω νουν κυριου ος συμβιβασει αυτον ημεις δε νουν χριστου εχομεν",
      "paragraphStart": false
    }
  ]
}
