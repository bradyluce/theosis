{
  "chapter": {
    "id": "byz:first-corinthians.9",
    "translationId": "byz",
    "bookSlug": "first-corinthians",
    "chapterNumber": 9,
    "referenceLabel": "1 Corinthians 9",
    "summary": "Source text for 1 Corinthians 9 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:first-corinthians.9.1",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 9:1",
      "text": "ουκ ειμι αποστολος ουκ ειμι ελευθερος ουχι ιησουν χριστον τον κυριον ημων εωρακα ου το εργον μου υμεις εστε εν κυριω",
      "paragraphStart": true
    },
    {
      "id": "byz:first-corinthians.9.2",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 9:2",
      "text": "ει αλλοις ουκ ειμι αποστολος αλλα γε υμιν ειμι η γαρ σφραγις της εμης αποστολης υμεις εστε εν κυριω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.3",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 9:3",
      "text": "η εμη απολογια τοις εμε ανακρινουσιν αυτη εστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.4",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 9:4",
      "text": "μη ουκ εχομεν εξουσιαν φαγειν και πιειν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.5",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 9:5",
      "text": "μη ουκ εχομεν εξουσιαν αδελφην γυναικα περιαγειν ως και οι λοιποι αποστολοι και οι αδελφοι του κυριου και κηφας",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.6",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 9:6",
      "text": "η μονος εγω και βαρναβας ουκ εχομεν εξουσιαν του μη εργαζεσθαι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.7",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 9:7",
      "text": "τις στρατευεται ιδιοις οψωνιοις ποτε τις φυτευει αμπελωνα και εκ του καρπου αυτου ουκ εσθιει η τις ποιμαινει ποιμνην και εκ του γαλακτος της ποιμνης ουκ εσθιει",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.8",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 9:8",
      "text": "μη κατα ανθρωπον ταυτα λαλω η ουχι και ο νομος ταυτα λεγει",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.9",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 9:9",
      "text": "εν γαρ τω μωυσεως νομω γεγραπται ου φιμωσεις βουν αλοωντα μη των βοων μελει τω θεω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.10",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 9:10",
      "text": "η δι ημας παντως λεγει δι ημας γαρ εγραφη οτι επ ελπιδι οφειλει ο αροτριων αροτριαν και ο αλοων της ελπιδος αυτου μετεχειν επ ελπιδι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.11",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 9:11",
      "text": "ει ημεις υμιν τα πνευματικα εσπειραμεν μεγα ει ημεις υμων τα σαρκικα θερισομεν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.12",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 9:12",
      "text": "ει αλλοι της εξουσιας υμων μετεχουσιν ου μαλλον ημεις αλλ ουκ εχρησαμεθα τη εξουσια ταυτη αλλα παντα στεγομεν ινα μη εγκοπην τινα δωμεν τω ευαγγελιω του χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.13",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 9:13",
      "text": "ουκ οιδατε οτι οι τα ιερα εργαζομενοι εκ του ιερου εσθιουσιν οι τω θυσιαστηριω προσεδρευοντες τω θυσιαστηριω συμμεριζονται",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.14",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 9:14",
      "text": "ουτως και ο κυριος διεταξεν τοις το ευαγγελιον καταγγελλουσιν εκ του ευαγγελιου ζην",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.15",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 9:15",
      "text": "εγω δε ουδενι εχρησαμην τουτων ουκ εγραψα δε ταυτα ινα ουτως γενηται εν εμοι καλον γαρ μοι μαλλον αποθανειν η το καυχημα μου ινα τις κενωση",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.16",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 9:16",
      "text": "εαν γαρ ευαγγελιζωμαι ουκ εστιν μοι καυχημα αναγκη γαρ μοι επικειται ουαι δε μοι εστιν εαν μη ευαγγελιζωμαι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.17",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 9:17",
      "text": "ει γαρ εκων τουτο πρασσω μισθον εχω ει δε ακων οικονομιαν πεπιστευμαι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.18",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 9:18",
      "text": "τις ουν μοι εστιν ο μισθος ινα ευαγγελιζομενος αδαπανον θησω το ευαγγελιον του χριστου εις το μη καταχρησασθαι τη εξουσια μου εν τω ευαγγελιω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.19",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 9:19",
      "text": "ελευθερος γαρ ων εκ παντων πασιν εμαυτον εδουλωσα ινα τους πλειονας κερδησω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.20",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 9:20",
      "text": "και εγενομην τοις ιουδαιοις ως ιουδαιος ινα ιουδαιους κερδησω τοις υπο νομον ως υπο νομον ινα τους υπο νομον κερδησω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.21",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 9:21",
      "text": "τοις ανομοις ως ανομος μη ων ανομος θεω αλλ εννομος χριστω ινα κερδησω ανομους",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.22",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 9:22",
      "text": "εγενομην τοις ασθενεσιν ως ασθενης ινα τους ασθενεις κερδησω τοις πασιν γεγονα τα παντα ινα παντως τινας σωσω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.23",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 9:23",
      "text": "τουτο δε ποιω δια το ευαγγελιον ινα συγκοινωνος αυτου γενωμαι",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.24",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 9:24",
      "text": "ουκ οιδατε οτι οι εν σταδιω τρεχοντες παντες μεν τρεχουσιν εις δε λαμβανει το βραβειον ουτως τρεχετε ινα καταλαβητε",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.25",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "1 Corinthians 9:25",
      "text": "πας δε ο αγωνιζομενος παντα εγκρατευεται εκεινοι μεν ουν ινα φθαρτον στεφανον λαβωσιν ημεις δε αφθαρτον",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.26",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 9:26",
      "text": "εγω τοινυν ουτως τρεχω ως ουκ αδηλως ουτως πυκτευω ως ουκ αερα δερων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-corinthians.9.27",
      "translationId": "byz",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "1 Corinthians 9:27",
      "text": "αλλ υπωπιαζω μου το σωμα και δουλαγωγω μηπως αλλοις κηρυξας αυτος αδοκιμος γενωμαι",
      "paragraphStart": false
    }
  ]
}
