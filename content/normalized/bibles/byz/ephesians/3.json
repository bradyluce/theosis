{
  "chapter": {
    "id": "byz:ephesians.3",
    "translationId": "byz",
    "bookSlug": "ephesians",
    "chapterNumber": 3,
    "referenceLabel": "Ephesians 3",
    "summary": "Source text for Ephesians 3 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:ephesians.3.1",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 3:1",
      "text": "τουτου χαριν εγω παυλος ο δεσμιος του χριστου ιησου υπερ υμων των εθνων",
      "paragraphStart": true
    },
    {
      "id": "byz:ephesians.3.2",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 3:2",
      "text": "ειγε ηκουσατε την οικονομιαν της χαριτος του θεου της δοθεισης μοι εις υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.3.3",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 3:3",
      "text": "οτι κατα αποκαλυψιν εγνωρισεν μοι το μυστηριον καθως προεγραψα εν ολιγω",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.3.4",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 3:4",
      "text": "προς ο δυνασθε αναγινωσκοντες νοησαι την συνεσιν μου εν τω μυστηριω του χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.3.5",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 3:5",
      "text": "ο ετεραις γενεαις ουκ εγνωρισθη τοις υιοις των ανθρωπων ως νυν απεκαλυφθη τοις αγιοις αποστολοις αυτου και προφηταις εν πνευματι",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.3.6",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 3:6",
      "text": "ειναι τα εθνη συγκληρονομα και συσσωμα και συμμετοχα της επαγγελιας αυτου εν τω χριστω δια του ευαγγελιου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.3.7",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 3:7",
      "text": "ου εγενομην διακονος κατα την δωρεαν της χαριτος του θεου την δοθεισαν μοι κατα την ενεργειαν της δυναμεως αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.3.8",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 3:8",
      "text": "εμοι τω ελαχιστοτερω παντων αγιων εδοθη η χαρις αυτη εν τοις εθνεσιν ευαγγελισασθαι τον ανεξιχνιαστον πλουτον του χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.3.9",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 3:9",
      "text": "και φωτισαι παντας τις η οικονομια του μυστηριου του αποκεκρυμμενου απο των αιωνων εν τω θεω τω τα παντα κτισαντι δια ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.3.10",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 3:10",
      "text": "ινα γνωρισθη νυν ταις αρχαις και ταις εξουσιαις εν τοις επουρανιοις δια της εκκλησιας η πολυποικιλος σοφια του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.3.11",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 3:11",
      "text": "κατα προθεσιν των αιωνων ην εποιησεν εν χριστω ιησου τω κυριω ημων",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.3.12",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 3:12",
      "text": "εν ω εχομεν την παρρησιαν και την προσαγωγην εν πεποιθησει δια της πιστεως αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.3.13",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 3:13",
      "text": "διο αιτουμαι μη εκκακειν εν ταις θλιψεσιν μου υπερ υμων ητις εστιν δοξα υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.3.14",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 3:14",
      "text": "τουτου χαριν καμπτω τα γονατα μου προς τον πατερα του κυριου ημων ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.3.15",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 3:15",
      "text": "εξ ου πασα πατρια εν ουρανοις και επι γης ονομαζεται",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.3.16",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 3:16",
      "text": "ινα δωη υμιν κατα τον πλουτον της δοξης αυτου δυναμει κραταιωθηναι δια του πνευματος αυτου εις τον εσω ανθρωπον",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.3.17",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 3:17",
      "text": "κατοικησαι τον χριστον δια της πιστεως εν ταις καρδιαις υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.3.18",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 3:18",
      "text": "εν αγαπη ερριζωμενοι και τεθεμελιωμενοι ινα εξισχυσητε καταλαβεσθαι συν πασιν τοις αγιοις τι το πλατος και μηκος και βαθος και υψος",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.3.19",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 3:19",
      "text": "γνωναι τε την υπερβαλλουσαν της γνωσεως αγαπην του χριστου ινα πληρωθητε εις παν το πληρωμα του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.3.20",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 3:20",
      "text": "τω δε δυναμενω υπερ παντα ποιησαι υπερ εκπερισσου ων αιτουμεθα η νοουμεν κατα την δυναμιν την ενεργουμενην εν ημιν",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.3.21",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 3:21",
      "text": "αυτω η δοξα εν τη εκκλησια εν χριστω ιησου εις πασας τας γενεας του αιωνος των αιωνων αμην",
      "paragraphStart": false
    }
  ]
}
