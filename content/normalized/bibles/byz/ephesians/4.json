{
  "chapter": {
    "id": "byz:ephesians.4",
    "translationId": "byz",
    "bookSlug": "ephesians",
    "chapterNumber": 4,
    "referenceLabel": "Ephesians 4",
    "summary": "Source text for Ephesians 4 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:ephesians.4.1",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 4:1",
      "text": "παρακαλω ουν υμας εγω ο δεσμιος εν κυριω αξιως περιπατησαι της κλησεως ης εκληθητε",
      "paragraphStart": true
    },
    {
      "id": "byz:ephesians.4.2",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 4:2",
      "text": "μετα πασης ταπεινοφροσυνης και πραοτητος μετα μακροθυμιας ανεχομενοι αλληλων εν αγαπη",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.3",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 4:3",
      "text": "σπουδαζοντες τηρειν την ενοτητα του πνευματος εν τω συνδεσμω της ειρηνης",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.4",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 4:4",
      "text": "εν σωμα και εν πνευμα καθως και εκληθητε εν μια ελπιδι της κλησεως υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.5",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 4:5",
      "text": "εις κυριος μια πιστις εν βαπτισμα",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.6",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 4:6",
      "text": "εις θεος και πατηρ παντων ο επι παντων και δια παντων και εν πασιν ημιν",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.7",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 4:7",
      "text": "ενι δε εκαστω ημων εδοθη η χαρις κατα το μετρον της δωρεας του χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.8",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 4:8",
      "text": "διο λεγει αναβας εις υψος ηχμαλωτευσεν αιχμαλωσιαν και εδωκεν δοματα τοις ανθρωποις",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.9",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 4:9",
      "text": "το δε ανεβη τι εστιν ει μη οτι και κατεβη πρωτον εις τα κατωτερα μερη της γης",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.10",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 4:10",
      "text": "ο καταβας αυτος εστιν και ο αναβας υπερανω παντων των ουρανων ινα πληρωση τα παντα",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.11",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 4:11",
      "text": "και αυτος εδωκεν τους μεν αποστολους τους δε προφητας τους δε ευαγγελιστας τους δε ποιμενας και διδασκαλους",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.12",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 4:12",
      "text": "προς τον καταρτισμον των αγιων εις εργον διακονιας εις οικοδομην του σωματος του χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.13",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 4:13",
      "text": "μεχρι καταντησωμεν οι παντες εις την ενοτητα της πιστεως και της επιγνωσεως του υιου του θεου εις ανδρα τελειον εις μετρον ηλικιας του πληρωματος του χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.14",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 4:14",
      "text": "ινα μηκετι ωμεν νηπιοι κλυδωνιζομενοι και περιφερομενοι παντι ανεμω της διδασκαλιας εν τη κυβεια των ανθρωπων εν πανουργια προς την μεθοδειαν της πλανης",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.15",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 4:15",
      "text": "αληθευοντες δε εν αγαπη αυξησωμεν εις αυτον τα παντα ος εστιν η κεφαλη ο χριστος",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.16",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 4:16",
      "text": "εξ ου παν το σωμα συναρμολογουμενον και συμβιβαζομενον δια πασης αφης της επιχορηγιας κατ ενεργειαν εν μετρω ενος εκαστου μερους την αυξησιν του σωματος ποιειται εις οικοδομην εαυτου εν αγαπη",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.17",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 4:17",
      "text": "τουτο ουν λεγω και μαρτυρομαι εν κυριω μηκετι υμας περιπατειν καθως και τα λοιπα εθνη περιπατει εν ματαιοτητι του νοος αυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.18",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 4:18",
      "text": "εσκοτισμενοι τη διανοια οντες απηλλοτριωμενοι της ζωης του θεου δια την αγνοιαν την ουσαν εν αυτοις δια την πωρωσιν της καρδιας αυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.19",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 4:19",
      "text": "οιτινες απηλγηκοτες εαυτους παρεδωκαν τη ασελγεια εις εργασιαν ακαθαρσιας πασης εν πλεονεξια",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.20",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 4:20",
      "text": "υμεις δε ουχ ουτως εμαθετε τον χριστον",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.21",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 4:21",
      "text": "ειγε αυτον ηκουσατε και εν αυτω εδιδαχθητε καθως εστιν αληθεια εν τω ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.22",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Ephesians 4:22",
      "text": "αποθεσθαι υμας κατα την προτεραν αναστροφην τον παλαιον ανθρωπον τον φθειρομενον κατα τας επιθυμιας της απατης",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.23",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Ephesians 4:23",
      "text": "ανανεουσθαι δε τω πνευματι του νοος υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.24",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Ephesians 4:24",
      "text": "και ενδυσασθαι τον καινον ανθρωπον τον κατα θεον κτισθεντα εν δικαιοσυνη και οσιοτητι της αληθειας",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.25",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Ephesians 4:25",
      "text": "διο αποθεμενοι το ψευδος λαλειτε αληθειαν εκαστος μετα του πλησιον αυτου οτι εσμεν αλληλων μελη",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.26",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Ephesians 4:26",
      "text": "οργιζεσθε και μη αμαρτανετε ο ηλιος μη επιδυετω επι τω παροργισμω υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.27",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Ephesians 4:27",
      "text": "μηδε διδοτε τοπον τω διαβολω",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.28",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "Ephesians 4:28",
      "text": "ο κλεπτων μηκετι κλεπτετω μαλλον δε κοπιατω εργαζομενος το αγαθον ταις χερσιν ινα εχη μεταδιδοναι τω χρειαν εχοντι",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.29",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "Ephesians 4:29",
      "text": "πας λογος σαπρος εκ του στοματος υμων μη εκπορευεσθω αλλ ει τις αγαθος προς οικοδομην της χρειας ινα δω χαριν τοις ακουουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.30",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "Ephesians 4:30",
      "text": "και μη λυπειτε το πνευμα το αγιον του θεου εν ω εσφραγισθητε εις ημεραν απολυτρωσεως",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.31",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "Ephesians 4:31",
      "text": "πασα πικρια και θυμος και οργη και κραυγη και βλασφημια αρθητω αφ υμων συν παση κακια",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.4.32",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 32,
      "referenceLabel": "Ephesians 4:32",
      "text": "γινεσθε δε εις αλληλους χρηστοι ευσπλαγχνοι χαριζομενοι εαυτοις καθως και ο θεος εν χριστω εχαρισατο ημιν",
      "paragraphStart": false
    }
  ]
}
