{
  "chapter": {
    "id": "byz:ephesians.2",
    "translationId": "byz",
    "bookSlug": "ephesians",
    "chapterNumber": 2,
    "referenceLabel": "Ephesians 2",
    "summary": "Source text for Ephesians 2 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:ephesians.2.1",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 2:1",
      "text": "και υμας οντας νεκρους τοις παραπτωμασιν και ταις αμαρτιαις",
      "paragraphStart": true
    },
    {
      "id": "byz:ephesians.2.2",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 2:2",
      "text": "εν αις ποτε περιεπατησατε κατα τον αιωνα του κοσμου τουτου κατα τον αρχοντα της εξουσιας του αερος του πνευματος του νυν ενεργουντος εν τοις υιοις της απειθειας",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.3",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 2:3",
      "text": "εν οις και ημεις παντες ανεστραφημεν ποτε εν ταις επιθυμιαις της σαρκος ημων ποιουντες τα θεληματα της σαρκος και των διανοιων και ημεν τεκνα φυσει οργης ως και οι λοιποι",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.4",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 2:4",
      "text": "ο δε θεος πλουσιος ων εν ελεει δια την πολλην αγαπην αυτου ην ηγαπησεν ημας",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.5",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 2:5",
      "text": "και οντας ημας νεκρους τοις παραπτωμασιν συνεζωοποιησεν τω χριστω χαριτι εστε σεσωσμενοι",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.6",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 2:6",
      "text": "και συνηγειρεν και συνεκαθισεν εν τοις επουρανιοις εν χριστω ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.7",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 2:7",
      "text": "ινα ενδειξηται εν τοις αιωσιν τοις επερχομενοις τον υπερβαλλοντα πλουτον της χαριτος αυτου εν χρηστοτητι εφ ημας εν χριστω ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.8",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 2:8",
      "text": "τη γαρ χαριτι εστε σεσωσμενοι δια της πιστεως και τουτο ουκ εξ υμων θεου το δωρον",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.9",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 2:9",
      "text": "ουκ εξ εργων ινα μη τις καυχησηται",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.10",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 2:10",
      "text": "αυτου γαρ εσμεν ποιημα κτισθεντες εν χριστω ιησου επι εργοις αγαθοις οις προητοιμασεν ο θεος ινα εν αυτοις περιπατησωμεν",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.11",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 2:11",
      "text": "διο μνημονευετε οτι υμεις ποτε τα εθνη εν σαρκι οι λεγομενοι ακροβυστια υπο της λεγομενης περιτομης εν σαρκι χειροποιητου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.12",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 2:12",
      "text": "οτι ητε εν τω καιρω εκεινω χωρις χριστου απηλλοτριωμενοι της πολιτειας του ισραηλ και ξενοι των διαθηκων της επαγγελιας ελπιδα μη εχοντες και αθεοι εν τω κοσμω",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.13",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 2:13",
      "text": "νυνι δε εν χριστω ιησου υμεις οι ποτε οντες μακραν εγγυς εγενηθητε εν τω αιματι του χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.14",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 2:14",
      "text": "αυτος γαρ εστιν η ειρηνη ημων ο ποιησας τα αμφοτερα εν και το μεσοτοιχον του φραγμου λυσας",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.15",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 2:15",
      "text": "την εχθραν εν τη σαρκι αυτου τον νομον των εντολων εν δογμασιν καταργησας ινα τους δυο κτιση εν εαυτω εις ενα καινον ανθρωπον ποιων ειρηνην",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.16",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 2:16",
      "text": "και αποκαταλλαξη τους αμφοτερους εν ενι σωματι τω θεω δια του σταυρου αποκτεινας την εχθραν εν αυτω",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.17",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 2:17",
      "text": "και ελθων ευηγγελισατο ειρηνην υμιν τοις μακραν και τοις εγγυς",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.18",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 2:18",
      "text": "οτι δι αυτου εχομεν την προσαγωγην οι αμφοτεροι εν ενι πνευματι προς τον πατερα",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.19",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 2:19",
      "text": "αρα ουν ουκετι εστε ξενοι και παροικοι αλλα συμπολιται των αγιων και οικειοι του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.20",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 2:20",
      "text": "εποικοδομηθεντες επι τω θεμελιω των αποστολων και προφητων οντος ακρογωνιαιου αυτου ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.21",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 2:21",
      "text": "εν ω πασα οικοδομη συναρμολογουμενη αυξει εις ναον αγιον εν κυριω",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.2.22",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Ephesians 2:22",
      "text": "εν ω και υμεις συνοικοδομεισθε εις κατοικητηριον του θεου εν πνευματι",
      "paragraphStart": false
    }
  ]
}
