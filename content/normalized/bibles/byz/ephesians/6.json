{
  "chapter": {
    "id": "byz:ephesians.6",
    "translationId": "byz",
    "bookSlug": "ephesians",
    "chapterNumber": 6,
    "referenceLabel": "Ephesians 6",
    "summary": "Source text for Ephesians 6 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:ephesians.6.1",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 6:1",
      "text": "τα τεκνα υπακουετε τοις γονευσιν υμων εν κυριω τουτο γαρ εστιν δικαιον",
      "paragraphStart": true
    },
    {
      "id": "byz:ephesians.6.2",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 6:2",
      "text": "τιμα τον πατερα σου και την μητερα ητις εστιν εντολη πρωτη εν επαγγελια",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.3",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 6:3",
      "text": "ινα ευ σοι γενηται και εση μακροχρονιος επι της γης",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.4",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 6:4",
      "text": "και οι πατερες μη παροργιζετε τα τεκνα υμων αλλ εκτρεφετε αυτα εν παιδεια και νουθεσια κυριου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.5",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 6:5",
      "text": "οι δουλοι υπακουετε τοις κυριοις κατα σαρκα μετα φοβου και τρομου εν απλοτητι της καρδιας υμων ως τω χριστω",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.6",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 6:6",
      "text": "μη κατ οφθαλμοδουλειαν ως ανθρωπαρεσκοι αλλ ως δουλοι του χριστου ποιουντες το θελημα του θεου εκ ψυχης",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.7",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 6:7",
      "text": "μετ ευνοιας δουλευοντες ως τω κυριω και ουκ ανθρωποις",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.8",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 6:8",
      "text": "ειδοτες οτι ο εαν τι εκαστος ποιηση αγαθον τουτο κομιειται παρα του κυριου ειτε δουλος ειτε ελευθερος",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.9",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 6:9",
      "text": "και οι κυριοι τα αυτα ποιειτε προς αυτους ανιεντες την απειλην ειδοτες οτι και υμων αυτων ο κυριος εστιν εν ουρανοις και προσωποληψια ουκ εστιν παρ αυτω",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.10",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 6:10",
      "text": "το λοιπον αδελφοι μου ενδυναμουσθε εν κυριω και εν τω κρατει της ισχυος αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.11",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 6:11",
      "text": "ενδυσασθε την πανοπλιαν του θεου προς το δυνασθαι υμας στηναι προς τας μεθοδειας του διαβολου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.12",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 6:12",
      "text": "οτι ουκ εστιν ημιν η παλη προς αιμα και σαρκα αλλα προς τας αρχας προς τας εξουσιας προς τους κοσμοκρατορας του σκοτους του αιωνος τουτου προς τα πνευματικα της πονηριας εν τοις επουρανιοις",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.13",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 6:13",
      "text": "δια τουτο αναλαβετε την πανοπλιαν του θεου ινα δυνηθητε αντιστηναι εν τη ημερα τη πονηρα και απαντα κατεργασαμενοι στηναι",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.14",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 6:14",
      "text": "στητε ουν περιζωσαμενοι την οσφυν υμων εν αληθεια και ενδυσαμενοι τον θωρακα της δικαιοσυνης",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.15",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 6:15",
      "text": "και υποδησαμενοι τους ποδας εν ετοιμασια του ευαγγελιου της ειρηνης",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.16",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 6:16",
      "text": "επι πασιν αναλαβοντες τον θυρεον της πιστεως εν ω δυνησεσθε παντα τα βελη του πονηρου τα πεπυρωμενα σβεσαι",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.17",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 6:17",
      "text": "και την περικεφαλαιαν του σωτηριου δεξασθαι και την μαχαιραν του πνευματος ο εστιν ρημα θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.18",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 6:18",
      "text": "δια πασης προσευχης και δεησεως προσευχομενοι εν παντι καιρω εν πνευματι και εις αυτο τουτο αγρυπνουντες εν παση προσκαρτερησει και δεησει περι παντων των αγιων",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.19",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 6:19",
      "text": "και υπερ εμου ινα μοι δοθη λογος εν ανοιξει του στοματος μου εν παρρησια γνωρισαι το μυστηριον του ευαγγελιου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.20",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 6:20",
      "text": "υπερ ου πρεσβευω εν αλυσει ινα εν αυτω παρρησιασωμαι ως δει με λαλησαι",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.21",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 6:21",
      "text": "ινα δε ειδητε και υμεις τα κατ εμε τι πρασσω παντα υμιν γνωρισει τυχικος ο αγαπητος αδελφος και πιστος διακονος εν κυριω",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.22",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "Ephesians 6:22",
      "text": "ον επεμψα προς υμας εις αυτο τουτο ινα γνωτε τα περι ημων και παρακαλεση τας καρδιας υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.23",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "Ephesians 6:23",
      "text": "ειρηνη τοις αδελφοις και αγαπη μετα πιστεως απο θεου πατρος και κυριου ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:ephesians.6.24",
      "translationId": "byz",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "Ephesians 6:24",
      "text": "η χαρις μετα παντων των αγαπωντων τον κυριον ημων ιησουν χριστον εν αφθαρσια αμην",
      "paragraphStart": false
    }
  ]
}
