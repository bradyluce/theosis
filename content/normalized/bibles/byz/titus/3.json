{
  "chapter": {
    "id": "byz:titus.3",
    "translationId": "byz",
    "bookSlug": "titus",
    "chapterNumber": 3,
    "referenceLabel": "Titus 3",
    "summary": "Source text for Titus 3 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:titus.3.1",
      "translationId": "byz",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Titus 3:1",
      "text": "υπομιμνησκε αυτους αρχαις και εξουσιαις υποτασσεσθαι πειθαρχειν προς παν εργον αγαθον ετοιμους ειναι",
      "paragraphStart": true
    },
    {
      "id": "byz:titus.3.2",
      "translationId": "byz",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Titus 3:2",
      "text": "μηδενα βλασφημειν αμαχους ειναι επιεικεις πασαν ενδεικνυμενους πραοτητα προς παντας ανθρωπους",
      "paragraphStart": false
    },
    {
      "id": "byz:titus.3.3",
      "translationId": "byz",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Titus 3:3",
      "text": "ημεν γαρ ποτε και ημεις ανοητοι απειθεις πλανωμενοι δουλευοντες επιθυμιαις και ηδοναις ποικιλαις εν κακια και φθονω διαγοντες στυγητοι μισουντες αλληλους",
      "paragraphStart": false
    },
    {
      "id": "byz:titus.3.4",
      "translationId": "byz",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Titus 3:4",
      "text": "οτε δε η χρηστοτης και η φιλανθρωπια επεφανη του σωτηρος ημων θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:titus.3.5",
      "translationId": "byz",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Titus 3:5",
      "text": "ουκ εξ εργων των εν δικαιοσυνη ων εποιησαμεν ημεις αλλα κατα τον αυτου ελεον εσωσεν ημας δια λουτρου παλιγγενεσιας και ανακαινωσεως πνευματος αγιου",
      "paragraphStart": false
    },
    {
      "id": "byz:titus.3.6",
      "translationId": "byz",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Titus 3:6",
      "text": "ου εξεχεεν εφ ημας πλουσιως δια ιησου χριστου του σωτηρος ημων",
      "paragraphStart": false
    },
    {
      "id": "byz:titus.3.7",
      "translationId": "byz",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Titus 3:7",
      "text": "ινα δικαιωθεντες τη εκεινου χαριτι κληρονομοι γενωμεθα κατ ελπιδα ζωης αιωνιου",
      "paragraphStart": false
    },
    {
      "id": "byz:titus.3.8",
      "translationId": "byz",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Titus 3:8",
      "text": "πιστος ο λογος και περι τουτων βουλομαι σε διαβεβαιουσθαι ινα φροντιζωσιν καλων εργων προιστασθαι οι πεπιστευκοτες θεω ταυτα εστιν τα καλα και ωφελιμα τοις ανθρωποις",
      "paragraphStart": false
    },
    {
      "id": "byz:titus.3.9",
      "translationId": "byz",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Titus 3:9",
      "text": "μωρας δε ζητησεις και γενεαλογιας και ερεις και μαχας νομικας περιιστασο εισιν γαρ ανωφελεις και ματαιοι",
      "paragraphStart": false
    },
    {
      "id": "byz:titus.3.10",
      "translationId": "byz",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Titus 3:10",
      "text": "αιρετικον ανθρωπον μετα μιαν και δευτεραν νουθεσιαν παραιτου",
      "paragraphStart": false
    },
    {
      "id": "byz:titus.3.11",
      "translationId": "byz",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Titus 3:11",
      "text": "ειδως οτι εξεστραπται ο τοιουτος και αμαρτανει ων αυτοκατακριτος",
      "paragraphStart": false
    },
    {
      "id": "byz:titus.3.12",
      "translationId": "byz",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Titus 3:12",
      "text": "οταν πεμψω αρτεμαν προς σε η τυχικον σπουδασον ελθειν προς με εις νικοπολιν εκει γαρ κεκρικα παραχειμασαι",
      "paragraphStart": false
    },
    {
      "id": "byz:titus.3.13",
      "translationId": "byz",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Titus 3:13",
      "text": "ζηναν τον νομικον και απολλω σπουδαιως προπεμψον ινα μηδεν αυτοις λειπη",
      "paragraphStart": false
    },
    {
      "id": "byz:titus.3.14",
      "translationId": "byz",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Titus 3:14",
      "text": "μανθανετωσαν δε και οι ημετεροι καλων εργων προιστασθαι εις τας αναγκαιας χρειας ινα μη ωσιν ακαρποι",
      "paragraphStart": false
    },
    {
      "id": "byz:titus.3.15",
      "translationId": "byz",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Titus 3:15",
      "text": "ασπαζονται σε οι μετ εμου παντες ασπασαι τους φιλουντας ημας εν πιστει η χαρις μετα παντων υμων αμην",
      "paragraphStart": false
    }
  ]
}
