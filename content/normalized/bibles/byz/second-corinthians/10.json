{
  "chapter": {
    "id": "byz:second-corinthians.10",
    "translationId": "byz",
    "bookSlug": "second-corinthians",
    "chapterNumber": 10,
    "referenceLabel": "2 Corinthians 10",
    "summary": "Source text for 2 Corinthians 10 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:second-corinthians.10.1",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 10:1",
      "text": "αυτος δε εγω παυλος παρακαλω υμας δια της πραοτητος και επιεικειας του χριστου ος κατα προσωπον μεν ταπεινος εν υμιν απων δε θαρρω εις υμας",
      "paragraphStart": true
    },
    {
      "id": "byz:second-corinthians.10.2",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 10:2",
      "text": "δεομαι δε το μη παρων θαρρησαι τη πεποιθησει η λογιζομαι τολμησαι επι τινας τους λογιζομενους ημας ως κατα σαρκα περιπατουντας",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.10.3",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 10:3",
      "text": "εν σαρκι γαρ περιπατουντες ου κατα σαρκα στρατευομεθα",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.10.4",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 10:4",
      "text": "τα γαρ οπλα της στρατειας ημων ου σαρκικα αλλα δυνατα τω θεω προς καθαιρεσιν οχυρωματων",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.10.5",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 10:5",
      "text": "λογισμους καθαιρουντες και παν υψωμα επαιρομενον κατα της γνωσεως του θεου και αιχμαλωτιζοντες παν νοημα εις την υπακοην του χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.10.6",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 10:6",
      "text": "και εν ετοιμω εχοντες εκδικησαι πασαν παρακοην οταν πληρωθη υμων η υπακοη",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.10.7",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 10:7",
      "text": "τα κατα προσωπον βλεπετε ει τις πεποιθεν εαυτω χριστου ειναι τουτο λογιζεσθω παλιν αφ εαυτου οτι καθως αυτος χριστου ουτως και ημεις χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.10.8",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 10:8",
      "text": "εαν τε γαρ και περισσοτερον τι καυχησωμαι περι της εξουσιας ημων ης εδωκεν ο κυριος ημιν εις οικοδομην και ουκ εις καθαιρεσιν υμων ουκ αισχυνθησομαι",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.10.9",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 10:9",
      "text": "ινα μη δοξω ως αν εκφοβειν υμας δια των επιστολων",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.10.10",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 10:10",
      "text": "οτι αι μεν επιστολαι φησιν βαρειαι και ισχυραι η δε παρουσια του σωματος ασθενης και ο λογος εξουθενημενος",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.10.11",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 10:11",
      "text": "τουτο λογιζεσθω ο τοιουτος οτι οιοι εσμεν τω λογω δι επιστολων αποντες τοιουτοι και παροντες τω εργω",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.10.12",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 10:12",
      "text": "ου γαρ τολμωμεν εγκριναι η συγκριναι εαυτους τισιν των εαυτους συνιστανοντων αλλα αυτοι εν εαυτοις εαυτους μετρουντες και συγκρινοντες εαυτους εαυτοις ου συνιουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.10.13",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 10:13",
      "text": "ημεις δε ουχι εις τα αμετρα καυχησομεθα αλλα κατα το μετρον του κανονος ου εμερισεν ημιν ο θεος μετρου εφικεσθαι αχρι και υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.10.14",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 10:14",
      "text": "ου γαρ ως μη εφικνουμενοι εις υμας υπερεκτεινομεν εαυτους αχρι γαρ και υμων εφθασαμεν εν τω ευαγγελιω του χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.10.15",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 10:15",
      "text": "ουκ εις τα αμετρα καυχωμενοι εν αλλοτριοις κοποις ελπιδα δε εχοντες αυξανομενης της πιστεως υμων εν υμιν μεγαλυνθηναι κατα τον κανονα ημων εις περισσειαν",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.10.16",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 10:16",
      "text": "εις τα υπερεκεινα υμων ευαγγελισασθαι ουκ εν αλλοτριω κανονι εις τα ετοιμα καυχησασθαι",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.10.17",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 10:17",
      "text": "ο δε καυχωμενος εν κυριω καυχασθω",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.10.18",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "2 Corinthians 10:18",
      "text": "ου γαρ ο εαυτον συνιστων εκεινος εστιν δοκιμος αλλ ον ο κυριος συνιστησιν",
      "paragraphStart": false
    }
  ]
}
