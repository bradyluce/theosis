{
  "chapter": {
    "id": "byz:second-corinthians.13",
    "translationId": "byz",
    "bookSlug": "second-corinthians",
    "chapterNumber": 13,
    "referenceLabel": "2 Corinthians 13",
    "summary": "Source text for 2 Corinthians 13 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:second-corinthians.13.1",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 13:1",
      "text": "τριτον τουτο ερχομαι προς υμας επι στοματος δυο μαρτυρων και τριων σταθησεται παν ρημα",
      "paragraphStart": true
    },
    {
      "id": "byz:second-corinthians.13.2",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 13:2",
      "text": "προειρηκα και προλεγω ως παρων το δευτερον και απων νυν γραφω τοις προημαρτηκοσιν και τοις λοιποις πασιν οτι εαν ελθω εις το παλιν ου φεισομαι",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.13.3",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 13:3",
      "text": "επει δοκιμην ζητειτε του εν εμοι λαλουντος χριστου ος εις υμας ουκ ασθενει αλλα δυνατει εν υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.13.4",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 13:4",
      "text": "και γαρ ει εσταυρωθη εξ ασθενειας αλλα ζη εκ δυναμεως θεου και γαρ ημεις ασθενουμεν εν αυτω αλλα ζησομεθα συν αυτω εκ δυναμεως θεου εις υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.13.5",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 13:5",
      "text": "εαυτους πειραζετε ει εστε εν τη πιστει εαυτους δοκιμαζετε η ουκ επιγινωσκετε εαυτους οτι ιησους χριστος εν υμιν εστιν ει μη τι αδοκιμοι εστε",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.13.6",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 13:6",
      "text": "ελπιζω δε οτι γνωσεσθε οτι ημεις ουκ εσμεν αδοκιμοι",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.13.7",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 13:7",
      "text": "ευχομαι δε προς τον θεον μη ποιησαι υμας κακον μηδεν ουχ ινα ημεις δοκιμοι φανωμεν αλλ ινα υμεις το καλον ποιητε ημεις δε ως αδοκιμοι ωμεν",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.13.8",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 13:8",
      "text": "ου γαρ δυναμεθα τι κατα της αληθειας αλλ υπερ της αληθειας",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.13.9",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 13:9",
      "text": "χαιρομεν γαρ οταν ημεις ασθενωμεν υμεις δε δυνατοι ητε τουτο δε και ευχομεθα την υμων καταρτισιν",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.13.10",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 13:10",
      "text": "δια τουτο ταυτα απων γραφω ινα παρων μη αποτομως χρησωμαι κατα την εξουσιαν ην εδωκεν μοι ο κυριος εις οικοδομην και ουκ εις καθαιρεσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.13.11",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 13:11",
      "text": "λοιπον αδελφοι χαιρετε καταρτιζεσθε παρακαλεισθε το αυτο φρονειτε ειρηνευετε και ο θεος της αγαπης και ειρηνης εσται μεθ υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.13.12",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 13:12",
      "text": "ασπασασθε αλληλους εν αγιω φιληματι",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.13.13",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 13:13",
      "text": "ασπαζονται υμας οι αγιοι παντες",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.13.14",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 13:14",
      "text": "η χαρις του κυριου ιησου χριστου και η αγαπη του θεου και η κοινωνια του αγιου πνευματος μετα παντων υμων αμην",
      "paragraphStart": false
    }
  ]
}
