{
  "chapter": {
    "id": "byz:second-corinthians.6",
    "translationId": "byz",
    "bookSlug": "second-corinthians",
    "chapterNumber": 6,
    "referenceLabel": "2 Corinthians 6",
    "summary": "Source text for 2 Corinthians 6 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:second-corinthians.6.1",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 6:1",
      "text": "συνεργουντες δε και παρακαλουμεν μη εις κενον την χαριν του θεου δεξασθαι υμας",
      "paragraphStart": true
    },
    {
      "id": "byz:second-corinthians.6.2",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 6:2",
      "text": "λεγει γαρ καιρω δεκτω επηκουσα σου και εν ημερα σωτηριας εβοηθησα σοι ιδου νυν καιρος ευπροσδεκτος ιδου νυν ημερα σωτηριας",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.6.3",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 6:3",
      "text": "μηδεμιαν εν μηδενι διδοντες προσκοπην ινα μη μωμηθη η διακονια",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.6.4",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 6:4",
      "text": "αλλ εν παντι συνιστωντες εαυτους ως θεου διακονοι εν υπομονη πολλη εν θλιψεσιν εν αναγκαις εν στενοχωριαις",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.6.5",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 6:5",
      "text": "εν πληγαις εν φυλακαις εν ακαταστασιαις εν κοποις εν αγρυπνιαις εν νηστειαις",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.6.6",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 6:6",
      "text": "εν αγνοτητι εν γνωσει εν μακροθυμια εν χρηστοτητι εν πνευματι αγιω εν αγαπη ανυποκριτω",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.6.7",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 6:7",
      "text": "εν λογω αληθειας εν δυναμει θεου δια των οπλων της δικαιοσυνης των δεξιων και αριστερων",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.6.8",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 6:8",
      "text": "δια δοξης και ατιμιας δια δυσφημιας και ευφημιας ως πλανοι και αληθεις",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.6.9",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 6:9",
      "text": "ως αγνοουμενοι και επιγινωσκομενοι ως αποθνησκοντες και ιδου ζωμεν ως παιδευομενοι και μη θανατουμενοι",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.6.10",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 6:10",
      "text": "ως λυπουμενοι αει δε χαιροντες ως πτωχοι πολλους δε πλουτιζοντες ως μηδεν εχοντες και παντα κατεχοντες",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.6.11",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 6:11",
      "text": "το στομα ημων ανεωγεν προς υμας κορινθιοι η καρδια ημων πεπλατυνται",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.6.12",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 6:12",
      "text": "ου στενοχωρεισθε εν ημιν στενοχωρεισθε δε εν τοις σπλαγχνοις υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.6.13",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 6:13",
      "text": "την δε αυτην αντιμισθιαν ως τεκνοις λεγω πλατυνθητε και υμεις",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.6.14",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 6:14",
      "text": "μη γινεσθε ετεροζυγουντες απιστοις τις γαρ μετοχη δικαιοσυνη και ανομια τις δε κοινωνια φωτι προς σκοτος",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.6.15",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 6:15",
      "text": "τις δε συμφωνησις χριστω προς βελιαρ η τις μερις πιστω μετα απιστου",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.6.16",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 6:16",
      "text": "τις δε συγκαταθεσις ναω θεου μετα ειδωλων υμεις γαρ ναος θεου εστε ζωντος καθως ειπεν ο θεος οτι ενοικησω εν αυτοις και εμπεριπατησω και εσομαι αυτων θεος και αυτοι εσονται μοι λαος",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.6.17",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 6:17",
      "text": "διο εξελθετε εκ μεσου αυτων και αφορισθητε λεγει κυριος και ακαθαρτου μη απτεσθε καγω εισδεξομαι υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.6.18",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "2 Corinthians 6:18",
      "text": "και εσομαι υμιν εις πατερα και υμεις εσεσθε μοι εις υιους και θυγατερας λεγει κυριος παντοκρατωρ",
      "paragraphStart": false
    }
  ]
}
