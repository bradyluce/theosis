{
  "chapter": {
    "id": "byz:second-corinthians.4",
    "translationId": "byz",
    "bookSlug": "second-corinthians",
    "chapterNumber": 4,
    "referenceLabel": "2 Corinthians 4",
    "summary": "Source text for 2 Corinthians 4 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:second-corinthians.4.1",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 4:1",
      "text": "δια τουτο εχοντες την διακονιαν ταυτην καθως ηλεηθημεν ουκ εκκακουμεν",
      "paragraphStart": true
    },
    {
      "id": "byz:second-corinthians.4.2",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 4:2",
      "text": "αλλα απειπαμεθα τα κρυπτα της αισχυνης μη περιπατουντες εν πανουργια μηδε δολουντες τον λογον του θεου αλλα τη φανερωσει της αληθειας συνιστωντες εαυτους προς πασαν συνειδησιν ανθρωπων ενωπιον του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.4.3",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 4:3",
      "text": "ει δε και εστιν κεκαλυμμενον το ευαγγελιον ημων εν τοις απολλυμενοις εστιν κεκαλυμμενον",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.4.4",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 4:4",
      "text": "εν οις ο θεος του αιωνος τουτου ετυφλωσεν τα νοηματα των απιστων εις το μη αυγασαι αυτοις τον φωτισμον του ευαγγελιου της δοξης του χριστου ος εστιν εικων του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.4.5",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 4:5",
      "text": "ου γαρ εαυτους κηρυσσομεν αλλα χριστον ιησουν κυριον εαυτους δε δουλους υμων δια ιησουν",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.4.6",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 4:6",
      "text": "οτι ο θεος ο ειπων εκ σκοτους φως λαμψαι ος ελαμψεν εν ταις καρδιαις ημων προς φωτισμον της γνωσεως της δοξης του θεου εν προσωπω ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.4.7",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 4:7",
      "text": "εχομεν δε τον θησαυρον τουτον εν οστρακινοις σκευεσιν ινα η υπερβολη της δυναμεως η του θεου και μη εξ ημων",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.4.8",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 4:8",
      "text": "εν παντι θλιβομενοι αλλ ου στενοχωρουμενοι απορουμενοι αλλ ουκ εξαπορουμενοι",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.4.9",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 4:9",
      "text": "διωκομενοι αλλ ουκ εγκαταλειπομενοι καταβαλλομενοι αλλ ουκ απολλυμενοι",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.4.10",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 4:10",
      "text": "παντοτε την νεκρωσιν του κυριου ιησου εν τω σωματι περιφεροντες ινα και η ζωη του ιησου εν τω σωματι ημων φανερωθη",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.4.11",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 4:11",
      "text": "αει γαρ ημεις οι ζωντες εις θανατον παραδιδομεθα δια ιησουν ινα και η ζωη του ιησου φανερωθη εν τη θνητη σαρκι ημων",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.4.12",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 4:12",
      "text": "ωστε ο μεν θανατος εν ημιν ενεργειται η δε ζωη εν υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.4.13",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 4:13",
      "text": "εχοντες δε το αυτο πνευμα της πιστεως κατα το γεγραμμενον επιστευσα διο ελαλησα και ημεις πιστευομεν διο και λαλουμεν",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.4.14",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 4:14",
      "text": "ειδοτες οτι ο εγειρας τον κυριον ιησουν και ημας δια ιησου εγερει και παραστησει συν υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.4.15",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 4:15",
      "text": "τα γαρ παντα δι υμας ινα η χαρις πλεονασασα δια των πλειονων την ευχαριστιαν περισσευση εις την δοξαν του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.4.16",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 4:16",
      "text": "διο ουκ εκκακουμεν αλλ ει και ο εξω ημων ανθρωπος διαφθειρεται αλλ ο εσωθεν ανακαινουται ημερα και ημερα",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.4.17",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 4:17",
      "text": "το γαρ παραυτικα ελαφρον της θλιψεως ημων καθ υπερβολην εις υπερβολην αιωνιον βαρος δοξης κατεργαζεται ημιν",
      "paragraphStart": false
    },
    {
      "id": "byz:second-corinthians.4.18",
      "translationId": "byz",
      "bookSlug": "second-corinthians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "2 Corinthians 4:18",
      "text": "μη σκοπουντων ημων τα βλεπομενα αλλα τα μη βλεπομενα τα γαρ βλεπομενα προσκαιρα τα δε μη βλεπομενα αιωνια",
      "paragraphStart": false
    }
  ]
}
