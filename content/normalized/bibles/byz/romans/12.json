{
  "chapter": {
    "id": "byz:romans.12",
    "translationId": "byz",
    "bookSlug": "romans",
    "chapterNumber": 12,
    "referenceLabel": "Romans 12",
    "summary": "Source text for Romans 12 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:romans.12.1",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Romans 12:1",
      "text": "παρακαλω ουν υμας αδελφοι δια των οικτιρμων του θεου παραστησαι τα σωματα υμων θυσιαν ζωσαν αγιαν ευαρεστον τω θεω την λογικην λατρειαν υμων",
      "paragraphStart": true
    },
    {
      "id": "byz:romans.12.2",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Romans 12:2",
      "text": "και μη συσχηματιζεσθαι τω αιωνι τουτω αλλα μεταμορφουσθαι τη ανακαινωσει του νοος υμων εις το δοκιμαζειν υμας τι το θελημα του θεου το αγαθον και ευαρεστον και τελειον",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.12.3",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Romans 12:3",
      "text": "λεγω γαρ δια της χαριτος της δοθεισης μοι παντι τω οντι εν υμιν μη υπερφρονειν παρ ο δει φρονειν αλλα φρονειν εις το σωφρονειν εκαστω ως ο θεος εμερισεν μετρον πιστεως",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.12.4",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Romans 12:4",
      "text": "καθαπερ γαρ εν ενι σωματι μελη πολλα εχομεν τα δε μελη παντα ου την αυτην εχει πραξιν",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.12.5",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Romans 12:5",
      "text": "ουτως οι πολλοι εν σωμα εσμεν εν χριστω ο δε καθ εις αλληλων μελη",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.12.6",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Romans 12:6",
      "text": "εχοντες δε χαρισματα κατα την χαριν την δοθεισαν ημιν διαφορα ειτε προφητειαν κατα την αναλογιαν της πιστεως",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.12.7",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Romans 12:7",
      "text": "ειτε διακονιαν εν τη διακονια ειτε ο διδασκων εν τη διδασκαλια",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.12.8",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Romans 12:8",
      "text": "ειτε ο παρακαλων εν τη παρακλησει ο μεταδιδους εν απλοτητι ο προισταμενος εν σπουδη ο ελεων εν ιλαροτητι",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.12.9",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Romans 12:9",
      "text": "η αγαπη ανυποκριτος αποστυγουντες το πονηρον κολλωμενοι τω αγαθω",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.12.10",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Romans 12:10",
      "text": "τη φιλαδελφια εις αλληλους φιλοστοργοι τη τιμη αλληλους προηγουμενοι",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.12.11",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Romans 12:11",
      "text": "τη σπουδη μη οκνηροι τω πνευματι ζεοντες τω κυριω δουλευοντες",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.12.12",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Romans 12:12",
      "text": "τη ελπιδι χαιροντες τη θλιψει υπομενοντες τη προσευχη προσκαρτερουντες",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.12.13",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Romans 12:13",
      "text": "ταις χρειαις των αγιων κοινωνουντες την φιλοξενιαν διωκοντες",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.12.14",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Romans 12:14",
      "text": "ευλογειτε τους διωκοντας υμας ευλογειτε και μη καταρασθε",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.12.15",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Romans 12:15",
      "text": "χαιρειν μετα χαιροντων και κλαιειν μετα κλαιοντων",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.12.16",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Romans 12:16",
      "text": "το αυτο εις αλληλους φρονουντες μη τα υψηλα φρονουντες αλλα τοις ταπεινοις συναπαγομενοι μη γινεσθε φρονιμοι παρ εαυτοις",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.12.17",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Romans 12:17",
      "text": "μηδενι κακον αντι κακου αποδιδοντες προνοουμενοι καλα ενωπιον παντων ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.12.18",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Romans 12:18",
      "text": "ει δυνατον το εξ υμων μετα παντων ανθρωπων ειρηνευοντες",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.12.19",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Romans 12:19",
      "text": "μη εαυτους εκδικουντες αγαπητοι αλλα δοτε τοπον τη οργη γεγραπται γαρ εμοι εκδικησις εγω ανταποδωσω λεγει κυριος",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.12.20",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Romans 12:20",
      "text": "εαν ουν πεινα ο εχθρος σου ψωμιζε αυτον εαν διψα ποτιζε αυτον τουτο γαρ ποιων ανθρακας πυρος σωρευσεις επι την κεφαλην αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.12.21",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Romans 12:21",
      "text": "μη νικω υπο του κακου αλλα νικα εν τω αγαθω το κακον",
      "paragraphStart": false
    }
  ]
}
