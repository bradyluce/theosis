{
  "chapter": {
    "id": "byz:romans.16",
    "translationId": "byz",
    "bookSlug": "romans",
    "chapterNumber": 16,
    "referenceLabel": "Romans 16",
    "summary": "Source text for Romans 16 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:romans.16.1",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Romans 16:1",
      "text": "συνιστημι δε υμιν φοιβην την αδελφην ημων ουσαν διακονον της εκκλησιας της εν κεγχρεαις",
      "paragraphStart": true
    },
    {
      "id": "byz:romans.16.2",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Romans 16:2",
      "text": "ινα αυτην προσδεξησθε εν κυριω αξιως των αγιων και παραστητε αυτη εν ω αν υμων χρηζη πραγματι και γαρ αυτη προστατις πολλων εγενηθη και αυτου εμου",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.3",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Romans 16:3",
      "text": "ασπασασθε πρισκαν και ακυλαν τους συνεργους μου εν χριστω ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.4",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Romans 16:4",
      "text": "οιτινες υπερ της ψυχης μου τον εαυτων τραχηλον υπεθηκαν οις ουκ εγω μονος ευχαριστω αλλα και πασαι αι εκκλησιαι των εθνων",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.5",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Romans 16:5",
      "text": "και την κατ οικον αυτων εκκλησιαν ασπασασθε επαινετον τον αγαπητον μου ος εστιν απαρχη της αχαιας εις χριστον",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.6",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Romans 16:6",
      "text": "ασπασασθε μαριαμ ητις πολλα εκοπιασεν εις ημας",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.7",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Romans 16:7",
      "text": "ασπασασθε ανδρονικον και ιουνιαν τους συγγενεις μου και συναιχμαλωτους μου οιτινες εισιν επισημοι εν τοις αποστολοις οι και προ εμου γεγονασιν εν χριστω",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.8",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Romans 16:8",
      "text": "ασπασασθε αμπλιαν τον αγαπητον μου εν κυριω",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.9",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Romans 16:9",
      "text": "ασπασασθε ουρβανον τον συνεργον ημων εν χριστω και σταχυν τον αγαπητον μου",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.10",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Romans 16:10",
      "text": "ασπασασθε απελλην τον δοκιμον εν χριστω ασπασασθε τους εκ των αριστοβουλου",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.11",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Romans 16:11",
      "text": "ασπασασθε ηρωδιωνα τον συγγενη μου ασπασασθε τους εκ των ναρκισσου τους οντας εν κυριω",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.12",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Romans 16:12",
      "text": "ασπασασθε τρυφαιναν και τρυφωσαν τας κοπιωσας εν κυριω ασπασασθε περσιδα την αγαπητην ητις πολλα εκοπιασεν εν κυριω",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.13",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Romans 16:13",
      "text": "ασπασασθε ρουφον τον εκλεκτον εν κυριω και την μητερα αυτου και εμου",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.14",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Romans 16:14",
      "text": "ασπασασθε ασυγκριτον φλεγοντα ερμαν πατροβαν ερμην και τους συν αυτοις αδελφους",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.15",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Romans 16:15",
      "text": "ασπασασθε φιλολογον και ιουλιαν νηρεα και την αδελφην αυτου και ολυμπαν και τους συν αυτοις παντας αγιους",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.16",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Romans 16:16",
      "text": "ασπασασθε αλληλους εν φιληματι αγιω ασπαζονται υμας αι εκκλησιαι του χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.17",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Romans 16:17",
      "text": "παρακαλω δε υμας αδελφοι σκοπειν τους τας διχοστασιας και τα σκανδαλα παρα την διδαχην ην υμεις εμαθετε ποιουντας και εκκλινατε απ αυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.18",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Romans 16:18",
      "text": "οι γαρ τοιουτοι τω κυριω ημων ιησου χριστω ου δουλευουσιν αλλα τη εαυτων κοιλια και δια της χρηστολογιας και ευλογιας εξαπατωσιν τας καρδιας των ακακων",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.19",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Romans 16:19",
      "text": "η γαρ υμων υπακοη εις παντας αφικετο χαιρω ουν το εφ υμιν θελω δε υμας σοφους μεν ειναι εις το αγαθον ακεραιους δε εις το κακον",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.20",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Romans 16:20",
      "text": "ο δε θεος της ειρηνης συντριψει τον σαταναν υπο τους ποδας υμων εν ταχει η χαρις του κυριου ημων ιησου χριστου μεθ υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.21",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "Romans 16:21",
      "text": "ασπαζονται υμας τιμοθεος ο συνεργος μου και λουκιος και ιασων και σωσιπατρος οι συγγενεις μου",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.22",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "Romans 16:22",
      "text": "ασπαζομαι υμας εγω τερτιος ο γραψας την επιστολην εν κυριω",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.23",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "Romans 16:23",
      "text": "ασπαζεται υμας γαιος ο ξενος μου και της εκκλησιας ολης ασπαζεται υμας εραστος ο οικονομος της πολεως και κουαρτος ο αδελφος",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.16.24",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "Romans 16:24",
      "text": "η χαρις του κυριου ημων ιησου χριστου μετα παντων υμων αμην",
      "paragraphStart": false
    }
  ]
}
