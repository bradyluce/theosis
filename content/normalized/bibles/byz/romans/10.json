{
  "chapter": {
    "id": "byz:romans.10",
    "translationId": "byz",
    "bookSlug": "romans",
    "chapterNumber": 10,
    "referenceLabel": "Romans 10",
    "summary": "Source text for Romans 10 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:romans.10.1",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Romans 10:1",
      "text": "αδελφοι η μεν ευδοκια της εμης καρδιας και η δεησις η προς τον θεον υπερ του ισραηλ εστιν εις σωτηριαν",
      "paragraphStart": true
    },
    {
      "id": "byz:romans.10.2",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Romans 10:2",
      "text": "μαρτυρω γαρ αυτοις οτι ζηλον θεου εχουσιν αλλ ου κατ επιγνωσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.10.3",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Romans 10:3",
      "text": "αγνοουντες γαρ την του θεου δικαιοσυνην και την ιδιαν δικαιοσυνην ζητουντες στησαι τη δικαιοσυνη του θεου ουχ υπεταγησαν",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.10.4",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Romans 10:4",
      "text": "τελος γαρ νομου χριστος εις δικαιοσυνην παντι τω πιστευοντι",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.10.5",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Romans 10:5",
      "text": "μωυσης γαρ γραφει την δικαιοσυνην την εκ του νομου οτι ο ποιησας αυτα ανθρωπος ζησεται εν αυτοις",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.10.6",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Romans 10:6",
      "text": "η δε εκ πιστεως δικαιοσυνη ουτως λεγει μη ειπης εν τη καρδια σου τις αναβησεται εις τον ουρανον τουτ εστιν χριστον καταγαγειν",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.10.7",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Romans 10:7",
      "text": "η τις καταβησεται εις την αβυσσον τουτ εστιν χριστον εκ νεκρων αναγαγειν",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.10.8",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Romans 10:8",
      "text": "αλλα τι λεγει εγγυς σου το ρημα εστιν εν τω στοματι σου και εν τη καρδια σου τουτ εστιν το ρημα της πιστεως ο κηρυσσομεν",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.10.9",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Romans 10:9",
      "text": "οτι εαν ομολογησης εν τω στοματι σου κυριον ιησουν και πιστευσης εν τη καρδια σου οτι ο θεος αυτον ηγειρεν εκ νεκρων σωθηση",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.10.10",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Romans 10:10",
      "text": "καρδια γαρ πιστευεται εις δικαιοσυνην στοματι δε ομολογειται εις σωτηριαν",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.10.11",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Romans 10:11",
      "text": "λεγει γαρ η γραφη πας ο πιστευων επ αυτω ου καταισχυνθησεται",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.10.12",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Romans 10:12",
      "text": "ου γαρ εστιν διαστολη ιουδαιου τε και ελληνος ο γαρ αυτος κυριος παντων πλουτων εις παντας τους επικαλουμενους αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.10.13",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Romans 10:13",
      "text": "πας γαρ ος αν επικαλεσηται το ονομα κυριου σωθησεται",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.10.14",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Romans 10:14",
      "text": "πως ουν επικαλεσονται εις ον ουκ επιστευσαν πως δε πιστευσουσιν ου ουκ ηκουσαν πως δε ακουσουσιν χωρις κηρυσσοντος",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.10.15",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Romans 10:15",
      "text": "πως δε κηρυξουσιν εαν μη αποσταλωσιν καθως γεγραπται ως ωραιοι οι ποδες των ευαγγελιζομενων ειρηνην των ευαγγελιζομενων τα αγαθα",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.10.16",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Romans 10:16",
      "text": "αλλ ου παντες υπηκουσαν τω ευαγγελιω ησαιας γαρ λεγει κυριε τις επιστευσεν τη ακοη ημων",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.10.17",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Romans 10:17",
      "text": "αρα η πιστις εξ ακοης η δε ακοη δια ρηματος θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.10.18",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Romans 10:18",
      "text": "αλλα λεγω μη ουκ ηκουσαν μενουνγε εις πασαν την γην εξηλθεν ο φθογγος αυτων και εις τα περατα της οικουμενης τα ρηματα αυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.10.19",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Romans 10:19",
      "text": "αλλα λεγω μη ουκ εγνω ισραηλ πρωτος μωυσης λεγει εγω παραζηλωσω υμας επ ουκ εθνει επι εθνει ασυνετω παροργιω υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.10.20",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Romans 10:20",
      "text": "ησαιας δε αποτολμα και λεγει ευρεθην τοις εμε μη ζητουσιν εμφανης εγενομην τοις εμε μη επερωτωσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.10.21",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Romans 10:21",
      "text": "προς δε τον ισραηλ λεγει ολην την ημεραν εξεπετασα τας χειρας μου προς λαον απειθουντα και αντιλεγοντα",
      "paragraphStart": false
    }
  ]
}
