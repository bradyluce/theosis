{
  "chapter": {
    "id": "byz:romans.15",
    "translationId": "byz",
    "bookSlug": "romans",
    "chapterNumber": 15,
    "referenceLabel": "Romans 15",
    "summary": "Source text for Romans 15 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:romans.15.1",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Romans 15:1",
      "text": "οφειλομεν δε ημεις οι δυνατοι τα ασθενηματα των αδυνατων βασταζειν και μη εαυτοις αρεσκειν",
      "paragraphStart": true
    },
    {
      "id": "byz:romans.15.2",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Romans 15:2",
      "text": "εκαστος ημων τω πλησιον αρεσκετω εις το αγαθον προς οικοδομην",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.3",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Romans 15:3",
      "text": "και γαρ ο χριστος ουχ εαυτω ηρεσεν αλλα καθως γεγραπται οι ονειδισμοι των ονειδιζοντων σε επεπεσον επ εμε",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.4",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Romans 15:4",
      "text": "οσα γαρ προεγραφη εις την ημετεραν διδασκαλιαν προεγραφη ινα δια της υπομονης και δια της παρακλησεως των γραφων την ελπιδα εχωμεν",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.5",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Romans 15:5",
      "text": "ο δε θεος της υπομονης και της παρακλησεως δωη υμιν το αυτο φρονειν εν αλληλοις κατα χριστον ιησουν",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.6",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Romans 15:6",
      "text": "ινα ομοθυμαδον εν ενι στοματι δοξαζητε τον θεον και πατερα του κυριου ημων ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.7",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Romans 15:7",
      "text": "διο προσλαμβανεσθε αλληλους καθως και ο χριστος προσελαβετο υμας εις δοξαν θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.8",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Romans 15:8",
      "text": "λεγω δε χριστον ιησουν διακονον γεγενησθαι περιτομης υπερ αληθειας θεου εις το βεβαιωσαι τας επαγγελιας των πατερων",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.9",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Romans 15:9",
      "text": "τα δε εθνη υπερ ελεους δοξασαι τον θεον καθως γεγραπται δια τουτο εξομολογησομαι σοι εν εθνεσιν και τω ονοματι σου ψαλω",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.10",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Romans 15:10",
      "text": "και παλιν λεγει ευφρανθητε εθνη μετα του λαου αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.11",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Romans 15:11",
      "text": "και παλιν αινειτε τον κυριον παντα τα εθνη και επαινεσατε αυτον παντες οι λαοι",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.12",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Romans 15:12",
      "text": "και παλιν ησαιας λεγει εσται η ριζα του ιεσσαι και ο ανισταμενος αρχειν εθνων επ αυτω εθνη ελπιουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.13",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Romans 15:13",
      "text": "ο δε θεος της ελπιδος πληρωσαι υμας πασης χαρας και ειρηνης εν τω πιστευειν εις το περισσευειν υμας εν τη ελπιδι εν δυναμει πνευματος αγιου",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.14",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Romans 15:14",
      "text": "πεπεισμαι δε αδελφοι μου και αυτος εγω περι υμων οτι και αυτοι μεστοι εστε αγαθωσυνης πεπληρωμενοι πασης γνωσεως δυναμενοι και αλλους νουθετειν",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.15",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Romans 15:15",
      "text": "τολμηροτερον δε εγραψα υμιν αδελφοι απο μερους ως επαναμιμνησκων υμας δια την χαριν την δοθεισαν μοι υπο του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.16",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Romans 15:16",
      "text": "εις το ειναι με λειτουργον ιησου χριστου εις τα εθνη ιερουργουντα το ευαγγελιον του θεου ινα γενηται η προσφορα των εθνων ευπροσδεκτος ηγιασμενη εν πνευματι αγιω",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.17",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Romans 15:17",
      "text": "εχω ουν καυχησιν εν χριστω ιησου τα προς τον θεον",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.18",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Romans 15:18",
      "text": "ου γαρ τολμησω λαλειν τι ων ου κατειργασατο χριστος δι εμου εις υπακοην εθνων λογω και εργω",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.19",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Romans 15:19",
      "text": "εν δυναμει σημειων και τερατων εν δυναμει πνευματος θεου ωστε με απο ιερουσαλημ και κυκλω μεχρι του ιλλυρικου πεπληρωκεναι το ευαγγελιον του χριστου",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.20",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Romans 15:20",
      "text": "ουτως δε φιλοτιμουμενον ευαγγελιζεσθαι ουχ οπου ωνομασθη χριστος ινα μη επ αλλοτριον θεμελιον οικοδομω",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.21",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Romans 15:21",
      "text": "αλλα καθως γεγραπται οις ουκ ανηγγελη περι αυτου οψονται και οι ουκ ακηκοασιν συνησουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.22",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Romans 15:22",
      "text": "διο και ενεκοπτομην τα πολλα του ελθειν προς υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.23",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Romans 15:23",
      "text": "νυνι δε μηκετι τοπον εχων εν τοις κλιμασιν τουτοις επιποθιαν δε εχων του ελθειν προς υμας απο πολλων ετων",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.24",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Romans 15:24",
      "text": "ως εαν πορευωμαι εις την σπανιαν ελευσομαι προς υμας ελπιζω γαρ διαπορευομενος θεασασθαι υμας και υφ υμων προπεμφθηναι εκει εαν υμων πρωτον απο μερους εμπλησθω",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.25",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Romans 15:25",
      "text": "νυνι δε πορευομαι εις ιερουσαλημ διακονων τοις αγιοις",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.26",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Romans 15:26",
      "text": "ευδοκησαν γαρ μακεδονια και αχαια κοινωνιαν τινα ποιησασθαι εις τους πτωχους των αγιων των εν ιερουσαλημ",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.27",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Romans 15:27",
      "text": "ευδοκησαν γαρ και οφειλεται αυτων εισιν ει γαρ τοις πνευματικοις αυτων εκοινωνησαν τα εθνη οφειλουσιν και εν τοις σαρκικοις λειτουργησαι αυτοις",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.28",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Romans 15:28",
      "text": "τουτο ουν επιτελεσας και σφραγισαμενος αυτοις τον καρπον τουτον απελευσομαι δι υμων εις την σπανιαν",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.29",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Romans 15:29",
      "text": "οιδα δε οτι ερχομενος προς υμας εν πληρωματι ευλογιας του ευαγγελιου του χριστου ελευσομαι",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.30",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Romans 15:30",
      "text": "παρακαλω δε υμας αδελφοι δια του κυριου ημων ιησου χριστου και δια της αγαπης του πνευματος συναγωνισασθαι μοι εν ταις προσευχαις υπερ εμου προς τον θεον",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.31",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Romans 15:31",
      "text": "ινα ρυσθω απο των απειθουντων εν τη ιουδαια και ινα η διακονια μου η εις ιερουσαλημ ευπροσδεκτος γενηται τοις αγιοις",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.32",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Romans 15:32",
      "text": "ινα εν χαρα ελθω προς υμας δια θεληματος θεου και συναναπαυσωμαι υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:romans.15.33",
      "translationId": "byz",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Romans 15:33",
      "text": "ο δε θεος της ειρηνης μετα παντων υμων αμην",
      "paragraphStart": false
    }
  ]
}
