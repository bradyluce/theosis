{
  "chapter": {
    "id": "byz:first-thessalonians.3",
    "translationId": "byz",
    "bookSlug": "first-thessalonians",
    "chapterNumber": 3,
    "referenceLabel": "1 Thessalonians 3",
    "summary": "Source text for 1 Thessalonians 3 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:first-thessalonians.3.1",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "1 Thessalonians 3:1",
      "text": "διο μηκετι στεγοντες ευδοκησαμεν καταλειφθηναι εν αθηναις μονοι",
      "paragraphStart": true
    },
    {
      "id": "byz:first-thessalonians.3.2",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "1 Thessalonians 3:2",
      "text": "και επεμψαμεν τιμοθεον τον αδελφον ημων και διακονον του θεου και συνεργον ημων εν τω ευαγγελιω του χριστου εις το στηριξαι υμας και παρακαλεσαι υμας περι της πιστεως υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.3.3",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "1 Thessalonians 3:3",
      "text": "το μηδενα σαινεσθαι εν ταις θλιψεσιν ταυταις αυτοι γαρ οιδατε οτι εις τουτο κειμεθα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.3.4",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "1 Thessalonians 3:4",
      "text": "και γαρ οτε προς υμας ημεν προελεγομεν υμιν οτι μελλομεν θλιβεσθαι καθως και εγενετο και οιδατε",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.3.5",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "1 Thessalonians 3:5",
      "text": "δια τουτο καγω μηκετι στεγων επεμψα εις το γνωναι την πιστιν υμων μηπως επειρασεν υμας ο πειραζων και εις κενον γενηται ο κοπος ημων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.3.6",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "1 Thessalonians 3:6",
      "text": "αρτι δε ελθοντος τιμοθεου προς ημας αφ υμων και ευαγγελισαμενου ημιν την πιστιν και την αγαπην υμων και οτι εχετε μνειαν ημων αγαθην παντοτε επιποθουντες ημας ιδειν καθαπερ και ημεις υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.3.7",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "1 Thessalonians 3:7",
      "text": "δια τουτο παρεκληθημεν αδελφοι εφ υμιν επι παση τη θλιψει και αναγκη ημων δια της υμων πιστεως",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.3.8",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "1 Thessalonians 3:8",
      "text": "οτι νυν ζωμεν εαν υμεις στηκετε εν κυριω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.3.9",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "1 Thessalonians 3:9",
      "text": "τινα γαρ ευχαριστιαν δυναμεθα τω θεω ανταποδουναι περι υμων επι παση τη χαρα η χαιρομεν δι υμας εμπροσθεν του θεου ημων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.3.10",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "1 Thessalonians 3:10",
      "text": "νυκτος και ημερας υπερ εκπερισσου δεομενοι εις το ιδειν υμων το προσωπον και καταρτισαι τα υστερηματα της πιστεως υμων",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.3.11",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "1 Thessalonians 3:11",
      "text": "αυτος δε ο θεος και πατηρ ημων και ο κυριος ημων ιησους χριστος κατευθυναι την οδον ημων προς υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.3.12",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "1 Thessalonians 3:12",
      "text": "υμας δε ο κυριος πλεονασαι και περισσευσαι τη αγαπη εις αλληλους και εις παντας καθαπερ και ημεις εις υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.3.13",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "1 Thessalonians 3:13",
      "text": "εις το στηριξαι υμων τας καρδιας αμεμπτους εν αγιωσυνη εμπροσθεν του θεου και πατρος ημων εν τη παρουσια του κυριου ημων ιησου χριστου μετα παντων των αγιων αυτου",
      "paragraphStart": false
    }
  ]
}
