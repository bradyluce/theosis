{
  "chapter": {
    "id": "byz:first-thessalonians.4",
    "translationId": "byz",
    "bookSlug": "first-thessalonians",
    "chapterNumber": 4,
    "referenceLabel": "1 Thessalonians 4",
    "summary": "Source text for 1 Thessalonians 4 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:first-thessalonians.4.1",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "1 Thessalonians 4:1",
      "text": "λοιπον ουν αδελφοι ερωτωμεν υμας και παρακαλουμεν εν κυριω ιησου καθως παρελαβετε παρ ημων το πως δει υμας περιπατειν και αρεσκειν θεω ινα περισσευητε μαλλον",
      "paragraphStart": true
    },
    {
      "id": "byz:first-thessalonians.4.2",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "1 Thessalonians 4:2",
      "text": "οιδατε γαρ τινας παραγγελιας εδωκαμεν υμιν δια του κυριου ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.4.3",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "1 Thessalonians 4:3",
      "text": "τουτο γαρ εστιν θελημα του θεου ο αγιασμος υμων απεχεσθαι υμας απο της πορνειας",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.4.4",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "1 Thessalonians 4:4",
      "text": "ειδεναι εκαστον υμων το εαυτου σκευος κτασθαι εν αγιασμω και τιμη",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.4.5",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "1 Thessalonians 4:5",
      "text": "μη εν παθει επιθυμιας καθαπερ και τα εθνη τα μη ειδοτα τον θεον",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.4.6",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "1 Thessalonians 4:6",
      "text": "το μη υπερβαινειν και πλεονεκτειν εν τω πραγματι τον αδελφον αυτου διοτι εκδικος ο κυριος περι παντων τουτων καθως και προειπομεν υμιν και διεμαρτυραμεθα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.4.7",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "1 Thessalonians 4:7",
      "text": "ου γαρ εκαλεσεν ημας ο θεος επι ακαθαρσια αλλ εν αγιασμω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.4.8",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "1 Thessalonians 4:8",
      "text": "τοιγαρουν ο αθετων ουκ ανθρωπον αθετει αλλα τον θεον τον και δοντα το πνευμα αυτου το αγιον εις υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.4.9",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "1 Thessalonians 4:9",
      "text": "περι δε της φιλαδελφιας ου χρειαν εχετε γραφειν υμιν αυτοι γαρ υμεις θεοδιδακτοι εστε εις το αγαπαν αλληλους",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.4.10",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "1 Thessalonians 4:10",
      "text": "και γαρ ποιειτε αυτο εις παντας τους αδελφους τους εν ολη τη μακεδονια παρακαλουμεν δε υμας αδελφοι περισσευειν μαλλον",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.4.11",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "1 Thessalonians 4:11",
      "text": "και φιλοτιμεισθαι ησυχαζειν και πρασσειν τα ιδια και εργαζεσθαι ταις ιδιαις χερσιν υμων καθως υμιν παρηγγειλαμεν",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.4.12",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "1 Thessalonians 4:12",
      "text": "ινα περιπατητε ευσχημονως προς τους εξω και μηδενος χρειαν εχητε",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.4.13",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "1 Thessalonians 4:13",
      "text": "ου θελομεν δε υμας αγνοειν αδελφοι περι των κεκοιμημενων ινα μη λυπησθε καθως και οι λοιποι οι μη εχοντες ελπιδα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.4.14",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "1 Thessalonians 4:14",
      "text": "ει γαρ πιστευομεν οτι ιησους απεθανεν και ανεστη ουτως και ο θεος τους κοιμηθεντας δια του ιησου αξει συν αυτω",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.4.15",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "1 Thessalonians 4:15",
      "text": "τουτο γαρ υμιν λεγομεν εν λογω κυριου οτι ημεις οι ζωντες οι περιλειπομενοι εις την παρουσιαν του κυριου ου μη φθασωμεν τους κοιμηθεντας",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.4.16",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "1 Thessalonians 4:16",
      "text": "οτι αυτος ο κυριος εν κελευσματι εν φωνη αρχαγγελου και εν σαλπιγγι θεου καταβησεται απ ουρανου και οι νεκροι εν χριστω αναστησονται πρωτον",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.4.17",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "1 Thessalonians 4:17",
      "text": "επειτα ημεις οι ζωντες οι περιλειπομενοι αμα συν αυτοις αρπαγησομεθα εν νεφελαις εις απαντησιν του κυριου εις αερα και ουτως παντοτε συν κυριω εσομεθα",
      "paragraphStart": false
    },
    {
      "id": "byz:first-thessalonians.4.18",
      "translationId": "byz",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "1 Thessalonians 4:18",
      "text": "ωστε παρακαλειτε αλληλους εν τοις λογοις τουτοις",
      "paragraphStart": false
    }
  ]
}
