{
  "chapter": {
    "id": "byz:mark.1",
    "translationId": "byz",
    "bookSlug": "mark",
    "chapterNumber": 1,
    "referenceLabel": "Mark 1",
    "summary": "Source text for Mark 1 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:mark.1.1",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Mark 1:1",
      "text": "αρχη του ευαγγελιου ιησου χριστου υιου του θεου",
      "paragraphStart": true
    },
    {
      "id": "byz:mark.1.2",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Mark 1:2",
      "text": "ως γεγραπται εν τοις προφηταις ιδου εγω αποστελλω τον αγγελον μου προ προσωπου σου ος κατασκευασει την οδον σου εμπροσθεν σου",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.3",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Mark 1:3",
      "text": "φωνη βοωντος εν τη ερημω ετοιμασατε την οδον κυριου ευθειας ποιειτε τας τριβους αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.4",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Mark 1:4",
      "text": "εγενετο ιωαννης βαπτιζων εν τη ερημω και κηρυσσων βαπτισμα μετανοιας εις αφεσιν αμαρτιων",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.5",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Mark 1:5",
      "text": "και εξεπορευετο προς αυτον πασα η ιουδαια χωρα και οι ιεροσολυμιται και εβαπτιζοντο παντες εν τω ιορδανη ποταμω υπ αυτου εξομολογουμενοι τας αμαρτιας αυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.6",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Mark 1:6",
      "text": "ην δε ο ιωαννης ενδεδυμενος τριχας καμηλου και ζωνην δερματινην περι την οσφυν αυτου και εσθιων ακριδας και μελι αγριον",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.7",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Mark 1:7",
      "text": "και εκηρυσσεν λεγων ερχεται ο ισχυροτερος μου οπισω μου ου ουκ ειμι ικανος κυψας λυσαι τον ιμαντα των υποδηματων αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.8",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Mark 1:8",
      "text": "εγω μεν εβαπτισα υμας εν υδατι αυτος δε βαπτισει υμας εν πνευματι αγιω",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.9",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Mark 1:9",
      "text": "και εγενετο εν εκειναις ταις ημεραις ηλθεν ιησους απο ναζαρετ της γαλιλαιας και εβαπτισθη υπο ιωαννου εις τον ιορδανην",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.10",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Mark 1:10",
      "text": "και ευθεως αναβαινων απο του υδατος ειδεν σχιζομενους τους ουρανους και το πνευμα ωσει περιστεραν καταβαινον επ αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.11",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Mark 1:11",
      "text": "και φωνη εγενετο εκ των ουρανων συ ει ο υιος μου ο αγαπητος εν ω ευδοκησα",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.12",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Mark 1:12",
      "text": "και ευθυς το πνευμα αυτον εκβαλλει εις την ερημον",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.13",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Mark 1:13",
      "text": "και ην εκει εν τη ερημω ημερας τεσσαρακοντα πειραζομενος υπο του σατανα και ην μετα των θηριων και οι αγγελοι διηκονουν αυτω",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.14",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Mark 1:14",
      "text": "μετα δε το παραδοθηναι τον ιωαννην ηλθεν ο ιησους εις την γαλιλαιαν κηρυσσων το ευαγγελιον της βασιλειας του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.15",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Mark 1:15",
      "text": "και λεγων οτι πεπληρωται ο καιρος και ηγγικεν η βασιλεια του θεου μετανοειτε και πιστευετε εν τω ευαγγελιω",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.16",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Mark 1:16",
      "text": "περιπατων δε παρα την θαλασσαν της γαλιλαιας ειδεν σιμωνα και ανδρεαν τον αδελφον αυτου του σιμωνος βαλλοντας αμφιβληστρον εν τη θαλασση ησαν γαρ αλιεις",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.17",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Mark 1:17",
      "text": "και ειπεν αυτοις ο ιησους δευτε οπισω μου και ποιησω υμας γενεσθαι αλιεις ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.18",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Mark 1:18",
      "text": "και ευθεως αφεντες τα δικτυα αυτων ηκολουθησαν αυτω",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.19",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Mark 1:19",
      "text": "και προβας εκειθεν ολιγον ειδεν ιακωβον τον του ζεβεδαιου και ιωαννην τον αδελφον αυτου και αυτους εν τω πλοιω καταρτιζοντας τα δικτυα",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.20",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Mark 1:20",
      "text": "και ευθεως εκαλεσεν αυτους και αφεντες τον πατερα αυτων ζεβεδαιον εν τω πλοιω μετα των μισθωτων απηλθον οπισω αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.21",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Mark 1:21",
      "text": "και εισπορευονται εις καπερναουμ και ευθεως τοις σαββασιν εισελθων εις την συναγωγην εδιδασκεν",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.22",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Mark 1:22",
      "text": "και εξεπλησσοντο επι τη διδαχη αυτου ην γαρ διδασκων αυτους ως εξουσιαν εχων και ουχ ως οι γραμματεις",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.23",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Mark 1:23",
      "text": "και ην εν τη συναγωγη αυτων ανθρωπος εν πνευματι ακαθαρτω και ανεκραξεν",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.24",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Mark 1:24",
      "text": "λεγων εα τι ημιν και σοι ιησου ναζαρηνε ηλθες απολεσαι ημας οιδα σε τις ει ο αγιος του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.25",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Mark 1:25",
      "text": "και επετιμησεν αυτω ο ιησους λεγων φιμωθητι και εξελθε εξ αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.26",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "Mark 1:26",
      "text": "και σπαραξαν αυτον το πνευμα το ακαθαρτον και κραξαν φωνη μεγαλη εξηλθεν εξ αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.27",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "Mark 1:27",
      "text": "και εθαμβηθησαν παντες ωστε συζητειν προς εαυτους λεγοντας τι εστιν τουτο τις η διδαχη η καινη αυτη οτι κατ εξουσιαν και τοις πνευμασιν τοις ακαθαρτοις επιτασσει και υπακουουσιν αυτω",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.28",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "Mark 1:28",
      "text": "εξηλθεν δε η ακοη αυτου ευθυς εις ολην την περιχωρον της γαλιλαιας",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.29",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "Mark 1:29",
      "text": "και ευθεως εκ της συναγωγης εξελθοντες ηλθον εις την οικιαν σιμωνος και ανδρεου μετα ιακωβου και ιωαννου",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.30",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "Mark 1:30",
      "text": "η δε πενθερα σιμωνος κατεκειτο πυρεσσουσα και ευθεως λεγουσιν αυτω περι αυτης",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.31",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "Mark 1:31",
      "text": "και προσελθων ηγειρεν αυτην κρατησας της χειρος αυτης και αφηκεν αυτην ο πυρετος ευθεως και διηκονει αυτοις",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.32",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "Mark 1:32",
      "text": "οψιας δε γενομενης οτε εδυ ο ηλιος εφερον προς αυτον παντας τους κακως εχοντας και τους δαιμονιζομενους",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.33",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "Mark 1:33",
      "text": "και η πολις ολη επισυνηγμενη ην προς την θυραν",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.34",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "Mark 1:34",
      "text": "και εθεραπευσεν πολλους κακως εχοντας ποικιλαις νοσοις και δαιμονια πολλα εξεβαλεν και ουκ ηφιεν λαλειν τα δαιμονια οτι ηδεισαν αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.35",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "Mark 1:35",
      "text": "και πρωι εννυχον λιαν αναστας εξηλθεν και απηλθεν εις ερημον τοπον κακει προσηυχετο",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.36",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "Mark 1:36",
      "text": "και κατεδιωξαν αυτον ο σιμων και οι μετ αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.37",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "Mark 1:37",
      "text": "και ευροντες αυτον λεγουσιν αυτω οτι παντες σε ζητουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.38",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "Mark 1:38",
      "text": "και λεγει αυτοις αγωμεν εις τας εχομενας κωμοπολεις ινα και εκει κηρυξω εις τουτο γαρ εξεληλυθα",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.39",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "Mark 1:39",
      "text": "και ην κηρυσσων εν ταις συναγωγαις αυτων εις ολην την γαλιλαιαν και τα δαιμονια εκβαλλων",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.40",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "Mark 1:40",
      "text": "και ερχεται προς αυτον λεπρος παρακαλων αυτον και γονυπετων αυτον και λεγων αυτω οτι εαν θελης δυνασαι με καθαρισαι",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.41",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 41,
      "referenceLabel": "Mark 1:41",
      "text": "ο δε ιησους σπλαγχνισθεις εκτεινας την χειρα ηψατο αυτου και λεγει αυτω θελω καθαρισθητι",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.42",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 42,
      "referenceLabel": "Mark 1:42",
      "text": "και ειποντος αυτου ευθεως απηλθεν απ αυτου η λεπρα και εκαθαρισθη",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.43",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 43,
      "referenceLabel": "Mark 1:43",
      "text": "και εμβριμησαμενος αυτω ευθεως εξεβαλεν αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.44",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 44,
      "referenceLabel": "Mark 1:44",
      "text": "και λεγει αυτω ορα μηδενι μηδεν ειπης αλλ υπαγε σεαυτον δειξον τω ιερει και προσενεγκε περι του καθαρισμου σου α προσεταξεν μωσης εις μαρτυριον αυτοις",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.1.45",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 45,
      "referenceLabel": "Mark 1:45",
      "text": "ο δε εξελθων ηρξατο κηρυσσειν πολλα και διαφημιζειν τον λογον ωστε μηκετι αυτον δυνασθαι φανερως εις πολιν εισελθειν αλλ εξω εν ερημοις τοποις ην και ηρχοντο προς αυτον πανταχοθεν",
      "paragraphStart": false
    }
  ]
}
