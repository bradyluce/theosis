{
  "chapter": {
    "id": "byz:mark.16",
    "translationId": "byz",
    "bookSlug": "mark",
    "chapterNumber": 16,
    "referenceLabel": "Mark 16",
    "summary": "Source text for Mark 16 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:mark.16.1",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Mark 16:1",
      "text": "και διαγενομενου του σαββατου μαρια η μαγδαληνη και μαρια ιακωβου και σαλωμη ηγορασαν αρωματα ινα ελθουσαι αλειψωσιν αυτον",
      "paragraphStart": true
    },
    {
      "id": "byz:mark.16.2",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Mark 16:2",
      "text": "και λιαν πρωι της μιας σαββατων ερχονται επι το μνημειον ανατειλαντος του ηλιου",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.16.3",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Mark 16:3",
      "text": "και ελεγον προς εαυτας τις αποκυλισει ημιν τον λιθον εκ της θυρας του μνημειου",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.16.4",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Mark 16:4",
      "text": "και αναβλεψασαι θεωρουσιν οτι αποκεκυλισται ο λιθος ην γαρ μεγας σφοδρα",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.16.5",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Mark 16:5",
      "text": "και εισελθουσαι εις το μνημειον ειδον νεανισκον καθημενον εν τοις δεξιοις περιβεβλημενον στολην λευκην και εξεθαμβηθησαν",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.16.6",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Mark 16:6",
      "text": "ο δε λεγει αυταις μη εκθαμβεισθε ιησουν ζητειτε τον ναζαρηνον τον εσταυρωμενον ηγερθη ουκ εστιν ωδε ιδε ο τοπος οπου εθηκαν αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.16.7",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Mark 16:7",
      "text": "αλλ υπαγετε ειπατε τοις μαθηταις αυτου και τω πετρω οτι προαγει υμας εις την γαλιλαιαν εκει αυτον οψεσθε καθως ειπεν υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.16.8",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Mark 16:8",
      "text": "και εξελθουσαι εφυγον απο του μνημειου ειχεν δε αυτας τρομος και εκστασις και ουδενι ουδεν ειπον εφοβουντο γαρ",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.16.9",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Mark 16:9",
      "text": "αναστας δε πρωι πρωτη σαββατου εφανη πρωτον μαρια τη μαγδαληνη αφ ης εκβεβληκει επτα δαιμονια",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.16.10",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Mark 16:10",
      "text": "εκεινη πορευθεισα απηγγειλεν τοις μετ αυτου γενομενοις πενθουσιν και κλαιουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.16.11",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Mark 16:11",
      "text": "κακεινοι ακουσαντες οτι ζη και εθεαθη υπ αυτης ηπιστησαν",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.16.12",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Mark 16:12",
      "text": "μετα δε ταυτα δυσιν εξ αυτων περιπατουσιν εφανερωθη εν ετερα μορφη πορευομενοις εις αγρον",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.16.13",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Mark 16:13",
      "text": "κακεινοι απελθοντες απηγγειλαν τοις λοιποις ουδε εκεινοις επιστευσαν",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.16.14",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Mark 16:14",
      "text": "υστερον ανακειμενοις αυτοις τοις ενδεκα εφανερωθη και ωνειδισεν την απιστιαν αυτων και σκληροκαρδιαν οτι τοις θεασαμενοις αυτον εγηγερμενον ουκ επιστευσαν",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.16.15",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Mark 16:15",
      "text": "και ειπεν αυτοις πορευθεντες εις τον κοσμον απαντα κηρυξατε το ευαγγελιον παση τη κτισει",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.16.16",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Mark 16:16",
      "text": "ο πιστευσας και βαπτισθεις σωθησεται ο δε απιστησας κατακριθησεται",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.16.17",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Mark 16:17",
      "text": "σημεια δε τοις πιστευσασιν ταυτα παρακολουθησει εν τω ονοματι μου δαιμονια εκβαλουσιν γλωσσαις λαλησουσιν καιναις",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.16.18",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Mark 16:18",
      "text": "οφεις αρουσιν καν θανασιμον τι πιωσιν ου μη αυτους βλαψη επι αρρωστους χειρας επιθησουσιν και καλως εξουσιν",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.16.19",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Mark 16:19",
      "text": "ο μεν ουν κυριος μετα το λαλησαι αυτοις ανεληφθη εις τον ουρανον και εκαθισεν εκ δεξιων του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.16.20",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Mark 16:20",
      "text": "εκεινοι δε εξελθοντες εκηρυξαν πανταχου του κυριου συνεργουντος και τον λογον βεβαιουντος δια των επακολουθουντων σημειων αμην",
      "paragraphStart": false
    }
  ]
}
