{
  "chapter": {
    "id": "byz:mark.5",
    "translationId": "byz",
    "bookSlug": "mark",
    "chapterNumber": 5,
    "referenceLabel": "Mark 5",
    "summary": "Source text for Mark 5 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:mark.5.1",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Mark 5:1",
      "text": "και ηλθον εις το περαν της θαλασσης εις την χωραν των γαδαρηνων",
      "paragraphStart": true
    },
    {
      "id": "byz:mark.5.2",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Mark 5:2",
      "text": "και εξελθοντι αυτω εκ του πλοιου ευθεως απηντησεν αυτω εκ των μνημειων ανθρωπος εν πνευματι ακαθαρτω",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.3",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Mark 5:3",
      "text": "ος την κατοικησιν ειχεν εν τοις μνημασιν και ουτε αλυσεσιν ουδεις εδυνατο αυτον δησαι",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.4",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Mark 5:4",
      "text": "δια το αυτον πολλακις πεδαις και αλυσεσιν δεδεσθαι και διεσπασθαι υπ αυτου τας αλυσεις και τας πεδας συντετριφθαι και ουδεις αυτον ισχυεν δαμασαι",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.5",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Mark 5:5",
      "text": "και δια παντος νυκτος και ημερας εν τοις ορεσιν και εν τοις μνημασιν ην κραζων και κατακοπτων εαυτον λιθοις",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.6",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Mark 5:6",
      "text": "ιδων δε τον ιησουν απο μακροθεν εδραμεν και προσεκυνησεν αυτω",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.7",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Mark 5:7",
      "text": "και κραξας φωνη μεγαλη ειπεν τι εμοι και σοι ιησου υιε του θεου του υψιστου ορκιζω σε τον θεον μη με βασανισης",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.8",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Mark 5:8",
      "text": "ελεγεν γαρ αυτω εξελθε το πνευμα το ακαθαρτον εκ του ανθρωπου",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.9",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Mark 5:9",
      "text": "και επηρωτα αυτον τι σοι ονομα και απεκριθη λεγων λεγεων ονομα μοι οτι πολλοι εσμεν",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.10",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Mark 5:10",
      "text": "και παρεκαλει αυτον πολλα ινα μη αυτους αποστειλη εξω της χωρας",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.11",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Mark 5:11",
      "text": "ην δε εκει προς τω ορει αγελη χοιρων μεγαλη βοσκομενη",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.12",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Mark 5:12",
      "text": "και παρεκαλεσαν αυτον παντες οι δαιμονες λεγοντες πεμψον ημας εις τους χοιρους ινα εις αυτους εισελθωμεν",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.13",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Mark 5:13",
      "text": "και επετρεψεν αυτοις ευθεως ο ιησους και εξελθοντα τα πνευματα τα ακαθαρτα εισηλθον εις τους χοιρους και ωρμησεν η αγελη κατα του κρημνου εις την θαλασσαν ησαν δε ως δισχιλιοι και επνιγοντο εν τη θαλασση",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.14",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Mark 5:14",
      "text": "οι δε βοσκοντες τους χοιρους εφυγον και ανηγγειλαν εις την πολιν και εις τους αγρους και εξηλθον ιδειν τι εστιν το γεγονος",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.15",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Mark 5:15",
      "text": "και ερχονται προς τον ιησουν και θεωρουσιν τον δαιμονιζομενον καθημενον και ιματισμενον και σωφρονουντα τον εσχηκοτα τον λεγεωνα και εφοβηθησαν",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.16",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Mark 5:16",
      "text": "διηγησαντο δε αυτοις οι ιδοντες πως εγενετο τω δαιμονιζομενω και περι των χοιρων",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.17",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Mark 5:17",
      "text": "και ηρξαντο παρακαλειν αυτον απελθειν απο των οριων αυτων",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.18",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Mark 5:18",
      "text": "και εμβαντος αυτου εις το πλοιον παρεκαλει αυτον ο δαιμονισθεις ινα η μετ αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.19",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Mark 5:19",
      "text": "ο δε ιησους ουκ αφηκεν αυτον αλλα λεγει αυτω υπαγε εις τον οικον σου προς τους σους και αναγγειλον αυτοις οσα σοι ο κυριος πεποιηκεν και ηλεησεν σε",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.20",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Mark 5:20",
      "text": "και απηλθεν και ηρξατο κηρυσσειν εν τη δεκαπολει οσα εποιησεν αυτω ο ιησους και παντες εθαυμαζον",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.21",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Mark 5:21",
      "text": "και διαπερασαντος του ιησου εν τω πλοιω παλιν εις το περαν συνηχθη οχλος πολυς επ αυτον και ην παρα την θαλασσαν",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.22",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Mark 5:22",
      "text": "και ιδου ερχεται εις των αρχισυναγωγων ονοματι ιαειρος και ιδων αυτον πιπτει προς τους ποδας αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.23",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Mark 5:23",
      "text": "και παρεκαλει αυτον πολλα λεγων οτι το θυγατριον μου εσχατως εχει ινα ελθων επιθης αυτη τας χειρας οπως σωθη και ζησεται",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.24",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Mark 5:24",
      "text": "και απηλθεν μετ αυτου και ηκολουθει αυτω οχλος πολυς και συνεθλιβον αυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.25",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Mark 5:25",
      "text": "και γυνη τις ουσα εν ρυσει αιματος ετη δωδεκα",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.26",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Mark 5:26",
      "text": "και πολλα παθουσα υπο πολλων ιατρων και δαπανησασα τα παρ αυτης παντα και μηδεν ωφεληθεισα αλλα μαλλον εις το χειρον ελθουσα",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.27",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Mark 5:27",
      "text": "ακουσασα περι του ιησου ελθουσα εν τω οχλω οπισθεν ηψατο του ιματιου αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.28",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "Mark 5:28",
      "text": "ελεγεν γαρ οτι καν των ιματιων αυτου αψωμαι σωθησομαι",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.29",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "Mark 5:29",
      "text": "και ευθεως εξηρανθη η πηγη του αιματος αυτης και εγνω τω σωματι οτι ιαται απο της μαστιγος",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.30",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "Mark 5:30",
      "text": "και ευθεως ο ιησους επιγνους εν εαυτω την εξ αυτου δυναμιν εξελθουσαν επιστραφεις εν τω οχλω ελεγεν τις μου ηψατο των ιματιων",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.31",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "Mark 5:31",
      "text": "και ελεγον αυτω οι μαθηται αυτου βλεπεις τον οχλον συνθλιβοντα σε και λεγεις τις μου ηψατο",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.32",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 32,
      "referenceLabel": "Mark 5:32",
      "text": "και περιεβλεπετο ιδειν την τουτο ποιησασαν",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.33",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 33,
      "referenceLabel": "Mark 5:33",
      "text": "η δε γυνη φοβηθεισα και τρεμουσα ειδυια ο γεγονεν επ αυτη ηλθεν και προσεπεσεν αυτω και ειπεν αυτω πασαν την αληθειαν",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.34",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 34,
      "referenceLabel": "Mark 5:34",
      "text": "ο δε ειπεν αυτη θυγατερ η πιστις σου σεσωκεν σε υπαγε εις ειρηνην και ισθι υγιης απο της μαστιγος σου",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.35",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 35,
      "referenceLabel": "Mark 5:35",
      "text": "ετι αυτου λαλουντος ερχονται απο του αρχισυναγωγου λεγοντες οτι η θυγατηρ σου απεθανεν τι ετι σκυλλεις τον διδασκαλον",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.36",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 36,
      "referenceLabel": "Mark 5:36",
      "text": "ο δε ιησους ευθεως ακουσας τον λογον λαλουμενον λεγει τω αρχισυναγωγω μη φοβου μονον πιστευε",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.37",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 37,
      "referenceLabel": "Mark 5:37",
      "text": "και ουκ αφηκεν ουδενα αυτω συνακολουθησαι ει μη πετρον και ιακωβον και ιωαννην τον αδελφον ιακωβου",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.38",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 38,
      "referenceLabel": "Mark 5:38",
      "text": "και ερχεται εις τον οικον του αρχισυναγωγου και θεωρει θορυβον κλαιοντας και αλαλαζοντας πολλα",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.39",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 39,
      "referenceLabel": "Mark 5:39",
      "text": "και εισελθων λεγει αυτοις τι θορυβεισθε και κλαιετε το παιδιον ουκ απεθανεν αλλα καθευδει",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.40",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 40,
      "referenceLabel": "Mark 5:40",
      "text": "και κατεγελων αυτου ο δε εκβαλων παντας παραλαμβανει τον πατερα του παιδιου και την μητερα και τους μετ αυτου και εισπορευεται οπου ην το παιδιον ανακειμενον",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.41",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 41,
      "referenceLabel": "Mark 5:41",
      "text": "και κρατησας της χειρος του παιδιου λεγει αυτη ταλιθα κουμι ο εστιν μεθερμηνευομενον το κορασιον σοι λεγω εγειραι",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.42",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 42,
      "referenceLabel": "Mark 5:42",
      "text": "και ευθεως ανεστη το κορασιον και περιεπατει ην γαρ ετων δωδεκα και εξεστησαν εκστασει μεγαλη",
      "paragraphStart": false
    },
    {
      "id": "byz:mark.5.43",
      "translationId": "byz",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 43,
      "referenceLabel": "Mark 5:43",
      "text": "και διεστειλατο αυτοις πολλα ινα μηδεις γνω τουτο και ειπεν δοθηναι αυτη φαγειν",
      "paragraphStart": false
    }
  ]
}
