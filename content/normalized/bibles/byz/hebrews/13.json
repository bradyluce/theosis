{
  "chapter": {
    "id": "byz:hebrews.13",
    "translationId": "byz",
    "bookSlug": "hebrews",
    "chapterNumber": 13,
    "referenceLabel": "Hebrews 13",
    "summary": "Source text for Hebrews 13 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:hebrews.13.1",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 13:1",
      "text": "η φιλαδελφια μενετω",
      "paragraphStart": true
    },
    {
      "id": "byz:hebrews.13.2",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 13:2",
      "text": "της φιλοξενιας μη επιλανθανεσθε δια ταυτης γαρ ελαθον τινες ξενισαντες αγγελους",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.3",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 13:3",
      "text": "μιμνησκεσθε των δεσμιων ως συνδεδεμενοι των κακουχουμενων ως και αυτοι οντες εν σωματι",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.4",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 13:4",
      "text": "τιμιος ο γαμος εν πασιν και η κοιτη αμιαντος πορνους δε και μοιχους κρινει ο θεος",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.5",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 13:5",
      "text": "αφιλαργυρος ο τροπος αρκουμενοι τοις παρουσιν αυτος γαρ ειρηκεν ου μη σε ανω ουδ ου μη σε εγκαταλειπω",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.6",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 13:6",
      "text": "ωστε θαρρουντας ημας λεγειν κυριος εμοι βοηθος και ου φοβηθησομαι τι ποιησει μοι ανθρωπος",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.7",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 13:7",
      "text": "μνημονευετε των ηγουμενων υμων οιτινες ελαλησαν υμιν τον λογον του θεου ων αναθεωρουντες την εκβασιν της αναστροφης μιμεισθε την πιστιν",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.8",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 13:8",
      "text": "ιησους χριστος χθες και σημερον ο αυτος και εις τους αιωνας",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.9",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 13:9",
      "text": "διδαχαις ποικιλαις και ξεναις μη παραφερεσθε καλον γαρ χαριτι βεβαιουσθαι την καρδιαν ου βρωμασιν εν οις ουκ ωφεληθησαν οι περιπατησαντες",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.10",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 13:10",
      "text": "εχομεν θυσιαστηριον εξ ου φαγειν ουκ εχουσιν εξουσιαν οι τη σκηνη λατρευοντες",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.11",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 13:11",
      "text": "ων γαρ εισφερεται ζωων το αιμα περι αμαρτιας εις τα αγια δια του αρχιερεως τουτων τα σωματα κατακαιεται εξω της παρεμβολης",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.12",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 13:12",
      "text": "διο και ιησους ινα αγιαση δια του ιδιου αιματος τον λαον εξω της πυλης επαθεν",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.13",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 13:13",
      "text": "τοινυν εξερχωμεθα προς αυτον εξω της παρεμβολης τον ονειδισμον αυτου φεροντες",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.14",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 13:14",
      "text": "ου γαρ εχομεν ωδε μενουσαν πολιν αλλα την μελλουσαν επιζητουμεν",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.15",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 13:15",
      "text": "δι αυτου ουν αναφερωμεν θυσιαν αινεσεως δια παντος τω θεω τουτ εστιν καρπον χειλεων ομολογουντων τω ονοματι αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.16",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 13:16",
      "text": "της δε ευποιιας και κοινωνιας μη επιλανθανεσθε τοιαυταις γαρ θυσιαις ευαρεστειται ο θεος",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.17",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 13:17",
      "text": "πειθεσθε τοις ηγουμενοις υμων και υπεικετε αυτοι γαρ αγρυπνουσιν υπερ των ψυχων υμων ως λογον αποδωσοντες ινα μετα χαρας τουτο ποιωσιν και μη στεναζοντες αλυσιτελες γαρ υμιν τουτο",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.18",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 13:18",
      "text": "προσευχεσθε περι ημων πεποιθαμεν γαρ οτι καλην συνειδησιν εχομεν εν πασιν καλως θελοντες αναστρεφεσθαι",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.19",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 13:19",
      "text": "περισσοτερως δε παρακαλω τουτο ποιησαι ινα ταχιον αποκατασταθω υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.20",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Hebrews 13:20",
      "text": "ο δε θεος της ειρηνης ο αναγαγων εκ νεκρων τον ποιμενα των προβατων τον μεγαν εν αιματι διαθηκης αιωνιου τον κυριον ημων ιησουν",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.21",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Hebrews 13:21",
      "text": "καταρτισαι υμας εν παντι εργω αγαθω εις το ποιησαι το θελημα αυτου ποιων εν υμιν το ευαρεστον ενωπιον αυτου δια ιησου χριστου ω η δοξα εις τους αιωνας των αιωνων αμην",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.22",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Hebrews 13:22",
      "text": "παρακαλω δε υμας αδελφοι ανεχεσθε του λογου της παρακλησεως και γαρ δια βραχεων επεστειλα υμιν",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.23",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Hebrews 13:23",
      "text": "γινωσκετε τον αδελφον τιμοθεον απολελυμενον μεθ ου εαν ταχιον ερχηται οψομαι υμας",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.24",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Hebrews 13:24",
      "text": "ασπασασθε παντας τους ηγουμενους υμων και παντας τους αγιους ασπαζονται υμας οι απο της ιταλιας",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.13.25",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Hebrews 13:25",
      "text": "η χαρις μετα παντων υμων αμην",
      "paragraphStart": false
    }
  ]
}
