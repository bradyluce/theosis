{
  "chapter": {
    "id": "byz:hebrews.10",
    "translationId": "byz",
    "bookSlug": "hebrews",
    "chapterNumber": 10,
    "referenceLabel": "Hebrews 10",
    "summary": "Source text for Hebrews 10 in Byzantine Textform."
  },
  "verses": [
    {
      "id": "byz:hebrews.10.1",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 10:1",
      "text": "σκιαν γαρ εχων ο νομος των μελλοντων αγαθων ουκ αυτην την εικονα των πραγματων κατ ενιαυτον ταις αυταις θυσιαις ας προσφερουσιν εις το διηνεκες ουδεποτε δυνανται τους προσερχομενους τελειωσαι",
      "paragraphStart": true
    },
    {
      "id": "byz:hebrews.10.2",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 10:2",
      "text": "επει ουκ αν επαυσαντο προσφερομεναι δια το μηδεμιαν εχειν ετι συνειδησιν αμαρτιων τους λατρευοντας απαξ κεκαθαρμενους",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.3",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 10:3",
      "text": "αλλ εν αυταις αναμνησις αμαρτιων κατ ενιαυτον",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.4",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 10:4",
      "text": "αδυνατον γαρ αιμα ταυρων και τραγων αφαιρειν αμαρτιας",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.5",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 10:5",
      "text": "διο εισερχομενος εις τον κοσμον λεγει θυσιαν και προσφοραν ουκ ηθελησας σωμα δε κατηρτισω μοι",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.6",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 10:6",
      "text": "ολοκαυτωματα και περι αμαρτιας ουκ ευδοκησας",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.7",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 10:7",
      "text": "τοτε ειπον ιδου ηκω εν κεφαλιδι βιβλιου γεγραπται περι εμου του ποιησαι ο θεος το θελημα σου",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.8",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 10:8",
      "text": "ανωτερον λεγων οτι θυσιαν και προσφοραν και ολοκαυτωματα και περι αμαρτιας ουκ ηθελησας ουδε ευδοκησας αιτινες κατα τον νομον προσφερονται",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.9",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 10:9",
      "text": "τοτε ειρηκεν ιδου ηκω του ποιησαι ο θεος το θελημα σου αναιρει το πρωτον ινα το δευτερον στηση",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.10",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 10:10",
      "text": "εν ω θεληματι ηγιασμενοι εσμεν οι δια της προσφορας του σωματος ιησου χριστου εφαπαξ",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.11",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 10:11",
      "text": "και πας μεν ιερευς εστηκεν καθ ημεραν λειτουργων και τας αυτας πολλακις προσφερων θυσιας αιτινες ουδεποτε δυνανται περιελειν αμαρτιας",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.12",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 10:12",
      "text": "αυτος δε μιαν υπερ αμαρτιων προσενεγκας θυσιαν εις το διηνεκες εκαθισεν εν δεξια του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.13",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 10:13",
      "text": "το λοιπον εκδεχομενος εως τεθωσιν οι εχθροι αυτου υποποδιον των ποδων αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.14",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 10:14",
      "text": "μια γαρ προσφορα τετελειωκεν εις το διηνεκες τους αγιαζομενους",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.15",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 10:15",
      "text": "μαρτυρει δε ημιν και το πνευμα το αγιον μετα γαρ το προειρηκεναι",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.16",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 10:16",
      "text": "αυτη η διαθηκη ην διαθησομαι προς αυτους μετα τας ημερας εκεινας λεγει κυριος διδους νομους μου επι καρδιας αυτων και επι των διανοιων αυτων επιγραψω αυτους",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.17",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 10:17",
      "text": "και των αμαρτιων αυτων και των ανομιων αυτων ου μη μνησθω ετι",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.18",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 10:18",
      "text": "οπου δε αφεσις τουτων ουκετι προσφορα περι αμαρτιας",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.19",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 10:19",
      "text": "εχοντες ουν αδελφοι παρρησιαν εις την εισοδον των αγιων εν τω αιματι ιησου",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.20",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Hebrews 10:20",
      "text": "ην ενεκαινισεν ημιν οδον προσφατον και ζωσαν δια του καταπετασματος τουτ εστιν της σαρκος αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.21",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Hebrews 10:21",
      "text": "και ιερεα μεγαν επι τον οικον του θεου",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.22",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Hebrews 10:22",
      "text": "προσερχωμεθα μετα αληθινης καρδιας εν πληροφορια πιστεως ερραντισμενοι τας καρδιας απο συνειδησεως πονηρας και λελουμενοι το σωμα υδατι καθαρω",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.23",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Hebrews 10:23",
      "text": "κατεχωμεν την ομολογιαν της ελπιδος ακλινη πιστος γαρ ο επαγγειλαμενος",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.24",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Hebrews 10:24",
      "text": "και κατανοωμεν αλληλους εις παροξυσμον αγαπης και καλων εργων",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.25",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Hebrews 10:25",
      "text": "μη εγκαταλειποντες την επισυναγωγην εαυτων καθως εθος τισιν αλλα παρακαλουντες και τοσουτω μαλλον οσω βλεπετε εγγιζουσαν την ημεραν",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.26",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Hebrews 10:26",
      "text": "εκουσιως γαρ αμαρτανοντων ημων μετα το λαβειν την επιγνωσιν της αληθειας ουκετι περι αμαρτιων απολειπεται θυσια",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.27",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Hebrews 10:27",
      "text": "φοβερα δε τις εκδοχη κρισεως και πυρος ζηλος εσθιειν μελλοντος τους υπεναντιους",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.28",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Hebrews 10:28",
      "text": "αθετησας τις νομον μωυσεως χωρις οικτιρμων επι δυσιν η τρισιν μαρτυσιν αποθνησκει",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.29",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Hebrews 10:29",
      "text": "ποσω δοκειτε χειρονος αξιωθησεται τιμωριας ο τον υιον του θεου καταπατησας και το αιμα της διαθηκης κοινον ηγησαμενος εν ω ηγιασθη και το πνευμα της χαριτος ενυβρισας",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.30",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Hebrews 10:30",
      "text": "οιδαμεν γαρ τον ειποντα εμοι εκδικησις εγω ανταποδωσω λεγει κυριος και παλιν κυριος κρινει τον λαον αυτου",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.31",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Hebrews 10:31",
      "text": "φοβερον το εμπεσειν εις χειρας θεου ζωντος",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.32",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Hebrews 10:32",
      "text": "αναμιμνησκεσθε δε τας προτερον ημερας εν αις φωτισθεντες πολλην αθλησιν υπεμεινατε παθηματων",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.33",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "Hebrews 10:33",
      "text": "τουτο μεν ονειδισμοις τε και θλιψεσιν θεατριζομενοι τουτο δε κοινωνοι των ουτως αναστρεφομενων γενηθεντες",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.34",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 34,
      "referenceLabel": "Hebrews 10:34",
      "text": "και γαρ τοις δεσμοις μου συνεπαθησατε και την αρπαγην των υπαρχοντων υμων μετα χαρας προσεδεξασθε γινωσκοντες εχειν εαυτοις κρειττονα υπαρξιν εν ουρανοις και μενουσαν",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.35",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 35,
      "referenceLabel": "Hebrews 10:35",
      "text": "μη αποβαλητε ουν την παρρησιαν υμων ητις εχει μισθαποδοσιαν μεγαλην",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.36",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 36,
      "referenceLabel": "Hebrews 10:36",
      "text": "υπομονης γαρ εχετε χρειαν ινα το θελημα του θεου ποιησαντες κομισησθε την επαγγελιαν",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.37",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 37,
      "referenceLabel": "Hebrews 10:37",
      "text": "ετι γαρ μικρον οσον οσον ο ερχομενος ηξει και ου χρονιει",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.38",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 38,
      "referenceLabel": "Hebrews 10:38",
      "text": "ο δε δικαιος εκ πιστεως ζησεται και εαν υποστειληται ουκ ευδοκει η ψυχη μου εν αυτω",
      "paragraphStart": false
    },
    {
      "id": "byz:hebrews.10.39",
      "translationId": "byz",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 39,
      "referenceLabel": "Hebrews 10:39",
      "text": "ημεις δε ουκ εσμεν υποστολης εις απωλειαν αλλα πιστεως εις περιποιησιν ψυχης",
      "paragraphStart": false
    }
  ]
}
