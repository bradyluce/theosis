{
  "chapter": {
    "id": "lxx-greek:psalms.74",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 74,
    "referenceLabel": "Psalms 74",
    "summary": "Source text for Psalms 74 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.74.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 1,
      "referenceLabel": "Psalms 74:1",
      "text": "\"Εις τον πρωτον μουσικον, επι Αλ-τασχεθ. Ψαλμος ωδης του Ασαφ.\" Δοξολογουμεν σε, Θεε, δοξολογουμεν, διοτι πλησιον ημων ειναι το ονομα σου κηρυττονται τα θαυμασια σου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.74.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 2,
      "referenceLabel": "Psalms 74:2",
      "text": "Οταν λαβω τον ωρισμενον καιρον, εγω θελω κρινει εν ευθυτητι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 3,
      "referenceLabel": "Psalms 74:3",
      "text": "Διελυθη η γη και παντες οι κατοικοι αυτης εγω εστερεωσα τους στυλους αυτης. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 4,
      "referenceLabel": "Psalms 74:4",
      "text": "Ειπα προς τους αφρονας, μη γινεσθε αφρονες και προς τους ασεβεις, μη υψωνετε κερας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 5,
      "referenceLabel": "Psalms 74:5",
      "text": "Μη υψονετε εις υψος το κερας υμων μη λαλειτε με τραχηλον σκληρον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 6,
      "referenceLabel": "Psalms 74:6",
      "text": "Διοτι ουτε εξ ανατολων, ουτε εκ δυσμων, ουτε εκ της ερημου, ερχεται υψωσις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 7,
      "referenceLabel": "Psalms 74:7",
      "text": "Αλλ' ο Θεος ειναι ο Κριτης τουτον ταπεινονει και εκεινον υψονει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 8,
      "referenceLabel": "Psalms 74:8",
      "text": "Διοτι εν τη χειρι του Κυριου ειναι ποτηριον πληρες κερασματος οινου ακρατου, και εκ τουτου θελει χυσει πλην την τρυγιαν αυτου θελουσι στραγγισει παντες οι ασεβεις της γης και θελουσι πιει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 9,
      "referenceLabel": "Psalms 74:9",
      "text": "Εγω δε θελω κηρυττει διαπαντος, θελω ψαλμωδει εις τον Θεον του Ιακωβ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 10,
      "referenceLabel": "Psalms 74:10",
      "text": "Και παντα τα κερατα των ασεβων θελω συντριψει τα δε κερατα των δικαιων θελουσιν υψωθη.",
      "paragraphStart": false
    }
  ]
}
