{
  "chapter": {
    "id": "lxx-greek:psalms.74",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 74,
    "referenceLabel": "Psalms 74",
    "summary": "Source text for Psalms 74 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.74.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 1,
      "referenceLabel": "Psalms 74:1",
      "text": "\"Μασχιλ του Ασαφ.\" Δια τι, Θεε, απερριψας ημας διαπαντος; δια τι καπνιζει η οργη σου εναντιον των προβατων της βοσκης σου;",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.74.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 2,
      "referenceLabel": "Psalms 74:2",
      "text": "Μνησθητι της συναγωγης σου, την οποιαν απεκτησας απ' αρχης την ραβδον της κληρονομιας σου, την οποιαν ελυτρωσας τουτο το ορος Σιων, εν ω κατωκησας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 3,
      "referenceLabel": "Psalms 74:3",
      "text": "Κινησον τα βηματα σου προς τας παντοτεινας ερημωσεις, προς παν κακον, το οποιον επραξεν ο εχθρος εν τω αγιαστηριω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 4,
      "referenceLabel": "Psalms 74:4",
      "text": "Οι εχθροι σου βρυχωνται εν τω μεσω των συναγωγων σου εθεσαν σημαιας τας σημαιας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 5,
      "referenceLabel": "Psalms 74:5",
      "text": "Γνωστον εγεινεν ως εαν τις σηκονων πελεκυν καταφερη επι πυκνα δενδρα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 6,
      "referenceLabel": "Psalms 74:6",
      "text": "ουτω τωρα αυτοι συνετριψαν δια μιας με πελεκεις και σφυρια, τα πελεκητα εργα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 7,
      "referenceLabel": "Psalms 74:7",
      "text": "Κατεκαυσαν εν πυρι το αγιαστηριον σου εως εδαφους εβεβηλωσαν το κατοικητηριον του ονοματος σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 8,
      "referenceLabel": "Psalms 74:8",
      "text": "Ειπον εν τη καρδια αυτων, Ας εξολοθρευσωμεν αυτους ομου κατεκαυσαν πασας τας συναγωγας του Θεου εν τη γη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 9,
      "referenceLabel": "Psalms 74:9",
      "text": "Τα σημεια ημων δεν βλεπομεν δεν υπαρχει πλεον προφητης ουδε γνωριζων μεταξυ ημων το εως ποτε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 10,
      "referenceLabel": "Psalms 74:10",
      "text": "Εως ποτε, Θεε, θελει ονειδιζει ο εναντιος; θελει βλασφημει ο εχθρος το ονομα σου διαπαντος;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 11,
      "referenceLabel": "Psalms 74:11",
      "text": "Δια τι αποστρεφεις την χειρα σου, και την δεξιαν σου; εκβαλε αυτην εκ μεσου του κολπου σου και αφανισον αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 12,
      "referenceLabel": "Psalms 74:12",
      "text": "Αλλ' ο Θεος ειναι εξ αρχης Βασιλευς μου, εργαζομενος σωτηριαν εν μεσω της γης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 13,
      "referenceLabel": "Psalms 74:13",
      "text": "Συ διεχωρισας δια της δυναμεως σου την θαλασσαν συ συνετριψας τας κεφαλας των δρακοντων εν τοις υδασι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 14,
      "referenceLabel": "Psalms 74:14",
      "text": "Συ συνετριψας τας κεφαλας τον Λευιαθαν εδωκας αυτον βρωσιν εις τον λαον, τον κατοικουντα εν ερημοις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 15,
      "referenceLabel": "Psalms 74:15",
      "text": "Συ ηνοιξας πηγας και χειμαρρους εξηρανας ποταμους δυνατους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 16,
      "referenceLabel": "Psalms 74:16",
      "text": "Σου ειναι η ημερα και σου η νυξ συ ητοιμασας το φως και τον ηλιον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 17,
      "referenceLabel": "Psalms 74:17",
      "text": "Συ εθεσας παντα τα ορια της γης συ εκαμες το θερος και τον χειμωνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 18,
      "referenceLabel": "Psalms 74:18",
      "text": "Μνησθητι τουτου, οτι ο εχθρος ωνειδισε τον Κυριον και λαος αφρων εβλασφημησε το ονομα σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 19,
      "referenceLabel": "Psalms 74:19",
      "text": "Μη παραδωσης εις τα θηρια την ψυχην της τρυγονος σου την συναξιν των πενητων σου μη λησμονησης διαπαντος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 20,
      "referenceLabel": "Psalms 74:20",
      "text": "Επιβλεψον επι την διαθηκην σου διοτι επλησθησαν οι σκοτεινοι της γης τοποι απο οικων καταδυναστειας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 21,
      "referenceLabel": "Psalms 74:21",
      "text": "Ας μη στραφη ο ταλαιπωρος εις τα οπισω κατησχυμμενος ο πτωχος και ο πενης ας επαινωσι το ονομα σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 22,
      "referenceLabel": "Psalms 74:22",
      "text": "Αναστα, Θεε δικασον την δικην σου μνησθητι του ονειδισμου, τον οποιον εις σε καμνει ο αφρων ολην την ημεραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.74.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 23,
      "referenceLabel": "Psalms 74:23",
      "text": "Μη λησμονησης την φωνην των εχθρων σου ο θορυβος των επανισταμενων κατα σου αυξανει διαπαντος.",
      "paragraphStart": false
    }
  ]
}
