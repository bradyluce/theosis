{
  "chapter": {
    "id": "lxx-greek:psalms.23",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 23,
    "referenceLabel": "Psalms 23",
    "summary": "Source text for Psalms 23 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.23.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Psalms 23:1",
      "text": "\"Ψαλμος του Δαβιδ.\" Του Κυριου ειναι η γη και το πληρωμα αυτης η οικουμενη και οι κατοικουντες εν αυτη.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.23.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Psalms 23:2",
      "text": "Διοτι αυτος εθεμελιωσεν αυτην επι των θαλασσων, και εστερεωσεν αυτην επι των ποταμων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.23.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Psalms 23:3",
      "text": "Τις θελει αναβη εις το ορος του Κυριου; και τις θελει σταθη εν τω τοπω τω αγιω αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.23.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Psalms 23:4",
      "text": "Ο αθωος τας χειρας και ο καθαρος την καρδιαν οστις δεν εδωκεν εις ματαιοτητα την ψυχην αυτου και δεν ωμοσε μετα δολιοτητος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.23.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Psalms 23:5",
      "text": "Ουτος θελει λαβει ευλογιαν παρα Κυριου και δικαιοσυνην παρα του Θεου της σωτηριας αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.23.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Psalms 23:6",
      "text": "Αυτη ειναι η γενεα των εκζητουντων αυτον, των ζητουντων το προσωπον σου, Θεε του Ιακωβ. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.23.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Psalms 23:7",
      "text": "Σηκωσατε, πυλαι, τας κεφαλας σας, και υψωθητε, θυραι αιωνιοι, και θελει εισελθει ο Βασιλευς της δοξης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.23.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Psalms 23:8",
      "text": "Τις ουτος ο Βασιλευς της δοξης; ο Κυριος ο κραταιος και δυνατος, ο Κυριος ο δυνατος εν πολεμω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.23.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Psalms 23:9",
      "text": "Σηκωσατε, πυλαι, τας κεφαλας σας, και υψωθητε, θυραι αιωνιοι, και θελει εισελθει ο Βασιλευς της δοξης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.23.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Psalms 23:10",
      "text": "Τις ειναι ουτος ο Βασιλευς της δοξης; ο Κυριος των δυναμεων αυτος ειναι ο Βασιλευς της δοξης. Διαψαλμα.",
      "paragraphStart": false
    }
  ]
}
