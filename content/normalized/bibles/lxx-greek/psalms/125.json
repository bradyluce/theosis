    "bookSlug": "psalms",
    "chapterNumber": 125,
    "referenceLabel": "Psalms 125",
    "summary": "Source text for Psalms 125 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.125.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 1,
      "referenceLabel": "Psalms 125:1",
      "text": "\"Ωιδη των Αναβαθμων.\" Οτε ο Κυριος επανεφερε τους αιχμαλωτους της Σιων, ημεθα ως οι ονειρευομενοι.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.125.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 2,
      "referenceLabel": "Psalms 125:2",
      "text": "Τοτε ενεπλησθη το στομα ημων απο γελωτος και η γλωσσα ημων απο αγαλλιασεως τοτε ελεγον μεταξυ των εθνων, Μεγαλεια εκαμε δι' αυτους ο Κυριος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.125.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 3,
      "referenceLabel": "Psalms 125:3",
      "text": "Μεγαλεια εκαμεν ο Κυριος δι' ημας ενεπλησθημεν χαρας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.125.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 4,
      "referenceLabel": "Psalms 125:4",
      "text": "Επιστρεψον, Κυριε, τους αιχμαλωτους ημων, ως τους χειμαρρους εν τω νοτω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.125.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 5,
      "referenceLabel": "Psalms 125:5",
      "text": "Οι σπειροντες μετα δακρυων εν αγαλλιασει θελουσι θερισει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.125.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 6,
      "referenceLabel": "Psalms 125:6",
      "text": "Οστις εξερχεται και κλαιει, βασταζων σπορον πολυτιμον, ουτος βεβαιως θελει επιστρεψει εν αγαλλιασει, βασταζων τα χειροβολα αυτου.",
      "paragraphStart": false
    }
  ]
}
