{
  "chapter": {
    "id": "lxx-greek:psalms.132",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 132,
    "referenceLabel": "Psalms 132",
    "summary": "Source text for Psalms 132 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.132.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 1,
      "referenceLabel": "Psalms 132:1",
      "text": "\"Ωιδη των Αναβαθμων.\" Ενθυμηθητι, Κυριε, τον Δαβιδ, και παντας τους αγωνας αυτου",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.132.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 2,
      "referenceLabel": "Psalms 132:2",
      "text": "πως ωμοσε προς τον Κυριον και εκαμεν ευχην εις τον ισχυρον Θεον του Ιακωβ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.132.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 3,
      "referenceLabel": "Psalms 132:3",
      "text": "Δεν θελω εισελθει υπο την στεγην του οικου μου, δεν θελω αναβη εις την κλινην της στρωμνης μου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.132.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 4,
      "referenceLabel": "Psalms 132:4",
      "text": "δεν θελω δωσει υπνον εις τους οφθαλμους μου, νυσταγμον εις τα βλεφαρα μου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.132.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 5,
      "referenceLabel": "Psalms 132:5",
      "text": "εωσου ευρω τοπον δια τον Κυριον, κατοικιαν δια τον ισχυρον Θεον του Ιακωβ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.132.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 6,
      "referenceLabel": "Psalms 132:6",
      "text": "Ιδου, ηκουσαμεν περι αυτης εν Εφραθα ευρηκαμεν αυτην εις τας πεδιαδας του Ιααρ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.132.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 7,
      "referenceLabel": "Psalms 132:7",
      "text": "Ας εισελθωμεν εις τας σκηνας αυτου ας προσκυνησωμεν εις το υποποδιον των ποδων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.132.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 8,
      "referenceLabel": "Psalms 132:8",
      "text": "Αναστηθι, Κυριε, εις την αναπαυσιν σου, συ και η κιβωτος της δυναμεως σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.132.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 9,
      "referenceLabel": "Psalms 132:9",
      "text": "Οι ιερεις σου ας ενδυθωσι δικαιοσυνην, και οι οσιοι σου ας αγαλλωνται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.132.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 10,
      "referenceLabel": "Psalms 132:10",
      "text": "Ενεκεν Δαβιδ του δουλου σου μη αποστρεψης το προσωπον του κεχρισμενου σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.132.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 11,
      "referenceLabel": "Psalms 132:11",
      "text": "Ωμοσεν ο Κυριος αληθειαν προς τον Δαβιδ, δεν θελει αθετησει αυτην, Εκ του καρπου του σωματος σου θελω θεσει επι τον θρονον σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.132.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 12,
      "referenceLabel": "Psalms 132:12",
      "text": "Εαν φυλαξωσιν οι υιοι σου την διαθηκην μου, και τα μαρτυρια μου τα οποια θελω διδαξει αυτους, και οι υιοι αυτων θελουσι καθισει διαπαντος επι του θρονου σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.132.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 13,
      "referenceLabel": "Psalms 132:13",
      "text": "Διοτι εξελεξεν ο Κυριος την Σιων ευηρεστηθη να κατοικη εν αυτη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.132.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 14,
      "referenceLabel": "Psalms 132:14",
      "text": "Αυτη ειναι η αναπαυσις μου εις τον αιωνα του αιωνος ενταυθα θελω κατοικει, διοτι ηγαπησα αυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.132.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 15,
      "referenceLabel": "Psalms 132:15",
      "text": "Θελω ευλογησει εν ευλογια τας τροφας αυτης τους πτωχους αυτης θελω χορτασει αρτον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.132.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 16,
      "referenceLabel": "Psalms 132:16",
      "text": "και τους ιερεις αυτης θελω ενδυσει σωτηριαν και οι οσιοι αυτης θελουσιν αγαλλεσθαι εν αγαλλιασει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.132.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 17,
      "referenceLabel": "Psalms 132:17",
      "text": "Εκει θελω καμει να βλαστηση κερας εις τον Δαβιδ ητοιμασα λυχνον δια τον κεχρισμενον μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.132.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 18,
      "referenceLabel": "Psalms 132:18",
      "text": "Τους εχθρους αυτου θελω ενδυσει αισχυνην επι δε αυτον θελει ανθει το διαδημα αυτου.",
      "paragraphStart": false
    }
  ]
}
