{
  "chapter": {
    "id": "lxx-greek:psalms.48",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 48,
    "referenceLabel": "Psalms 48",
    "summary": "Source text for Psalms 48 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.48.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 1,
      "referenceLabel": "Psalms 48:1",
      "text": "\"Ωιδη Ψαλμου δια τους υιους Κορε.\" Μεγας ο Κυριος και αινετος σφοδρα εν τη πολει του Θεου ημων, τω ορει της αγιοτητος αυτου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.48.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 2,
      "referenceLabel": "Psalms 48:2",
      "text": "Ωραιον την θεσιν, χαρα πασης της γης, ειναι το ορος Σιων, προς τα πλαγια του βορρα η πολις του Βασιλεως του μεγαλου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.48.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 3,
      "referenceLabel": "Psalms 48:3",
      "text": "ο Θεος εν τοις παλατιοις αυτης γνωριζεται ως προπυργιον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.48.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 4,
      "referenceLabel": "Psalms 48:4",
      "text": "Διοτι, ιδου, οι βασιλεις συνηχθησαν διηλθον ομου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.48.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 5,
      "referenceLabel": "Psalms 48:5",
      "text": "Αυτοι, ως ειδον, εθαυμασαν εταραχθησαν και μετα σπουδης εφυγον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.48.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 6,
      "referenceLabel": "Psalms 48:6",
      "text": "Τρομος συνελαβεν αυτους εκει πονοι ως τικτουσης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.48.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 7,
      "referenceLabel": "Psalms 48:7",
      "text": "Δι' ανεμου ανατολικου συντριβεις τα πλοια της Θαρσεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.48.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 8,
      "referenceLabel": "Psalms 48:8",
      "text": "Καθως ηκουσαμεν, ουτω και ειδομεν εν τη πολει του Κυριου των δυναμεων, εν τη πολει του Θεου ημων ο Θεος θελει θεμελιωσει αυτην εις τον αιωνα. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.48.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 9,
      "referenceLabel": "Psalms 48:9",
      "text": "Μελετωμεν, Θεε, το ελεος σου εν μεσω του ναου σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.48.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 10,
      "referenceLabel": "Psalms 48:10",
      "text": "Κατα το ονομα σου, Θεε, ουτω και η αινεσις σου ειναι εως των περατων της γης η δεξια σου ειναι πληρης δικαιοσυνης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.48.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 11,
      "referenceLabel": "Psalms 48:11",
      "text": "Ας ευφραινεται το ορος Σιων, ας αγαλλωνται αι θυγατερες του Ιουδα δια τας κρισεις σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.48.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 12,
      "referenceLabel": "Psalms 48:12",
      "text": "Κυκλωσατε την Σιων και περιελθετε αυτην αριθμησατε τους πυργους αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.48.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 13,
      "referenceLabel": "Psalms 48:13",
      "text": "Θεσατε την προσοχην σας εις τα περιτειχισματα αυτης περιεργασθητε τα παλατια αυτης δια να διηγησθε εις γενεαν μεταγενεστεραν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.48.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 14,
      "referenceLabel": "Psalms 48:14",
      "text": "Διοτι ουτος ο Θεος ειναι ο Θεος ημων εις τον αιωνα του αιωνος αυτος θελει οδηγει ημας μεχρι θανατου.",
      "paragraphStart": false
    }
  ]
}
