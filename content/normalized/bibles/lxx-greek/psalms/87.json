{
  "chapter": {
    "id": "lxx-greek:psalms.87",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 87,
    "referenceLabel": "Psalms 87",
    "summary": "Source text for Psalms 87 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.87.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 1,
      "referenceLabel": "Psalms 87:1",
      "text": "\"Ωιδη ψαλμου δια τους υιους Κορε, εις τον πρωτον μουσικον, επι Μαχαλαθ-λεανωθ, Μασχιλ του Αιμαν του Εζραιτου.\" Κυριε ο Θεος της σωτηριας μου, ημεραν και νυκτα εκραξα ενωπιον σου",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.87.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 2,
      "referenceLabel": "Psalms 87:2",
      "text": "Ας ελθη ενωπιον σου η προσευχη μου κλινον το ωτιον σου εις την κραυγην μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 3,
      "referenceLabel": "Psalms 87:3",
      "text": "Διοτι ενεπλησθη κακων η ψυχη μου, και η ζωη μου πλησιαζει εις τον αδην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 4,
      "referenceLabel": "Psalms 87:4",
      "text": "Συγκατηριθμηθην μετα των καταβαινοντων εις τον λακκον εγεινα ως ανθρωπος μη εχων δυναμιν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 5,
      "referenceLabel": "Psalms 87:5",
      "text": "εγκαταλελειμμενος μεταξυ των νεκρων, ως οι πεφονευμενοι, κοιτωμενοι εν τω ταφω, τους οποιους δεν ενθυμεισαι πλεον, και οιτινες απεκοπησαν απο της χειρος σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 6,
      "referenceLabel": "Psalms 87:6",
      "text": "Μ' εβαλες εις τον κατωτατον λακκον, εις το σκοτος, εις τα βαθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 7,
      "referenceLabel": "Psalms 87:7",
      "text": "Επ' εμε επεστηριχθη ο θυμος σου, και παντα τα κυματα σου επεφερες επ' εμε. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 8,
      "referenceLabel": "Psalms 87:8",
      "text": "Εμακρυνας τους γνωστους μου απ' εμου με εκαμες βδελυγμα προς αυτους απεκλεισθην και δεν δυναμαι να εξελθω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 9,
      "referenceLabel": "Psalms 87:9",
      "text": "Ο οφθαλμος μου ητονησεν απο της θλιψεως σε επεκαλεσθην, Κυριε, ολην την ημεραν ηπλωσα προς σε τας χειρας μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 10,
      "referenceLabel": "Psalms 87:10",
      "text": "Μηπως εις τους νεκρους θελεις καμει θαυμασια; η οι τεθνεωτες θελουσι σηκωθη και θελουσι σε αινεσει; Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 11,
      "referenceLabel": "Psalms 87:11",
      "text": "Μηπως εν τω ταφω θελουσι διηγεισθαι το ελεος σου η την αληθειαν σου εν τη φθορα;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 12,
      "referenceLabel": "Psalms 87:12",
      "text": "Μηπως θελουσι γνωρισθη εν τω σκοτει τα θαυμασια σου και η δικαιοσυνη σου εν τω τοπω της ληθης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 13,
      "referenceLabel": "Psalms 87:13",
      "text": "Αλλ' εγω προς σε, Κυριε, εκραξα και το πρωι η προσευχη μου θελει σε προφθασει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 14,
      "referenceLabel": "Psalms 87:14",
      "text": "Δια τι, Κυριε, απορριπτεις την ψυχην μου, αποκρυπτεις το προσωπον σου απ' εμου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 15,
      "referenceLabel": "Psalms 87:15",
      "text": "Ειμαι τεθλιμμενος και ψυχομαχων εκ νεοτητος δοκιμαζω τους φοβους σου και ευρισκομαι εν αμηχανια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 16,
      "referenceLabel": "Psalms 87:16",
      "text": "Επ' εμε διηλθον αι οργαι σου οι τρομοι σου με εφανισαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 17,
      "referenceLabel": "Psalms 87:17",
      "text": "Ως υδατα με περιετριγυρισαν ολην την ημεραν ομου με περιεκυκλωσαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 18,
      "referenceLabel": "Psalms 87:18",
      "text": "Απεμακρυνας απ' εμου τον αγαπητον και τον φιλον οι γνωστοι μου ειναι αφανεις.",
      "paragraphStart": false
    }
  ]
}
