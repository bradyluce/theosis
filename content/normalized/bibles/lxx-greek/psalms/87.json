{
  "chapter": {
    "id": "lxx-greek:psalms.87",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 87,
    "referenceLabel": "Psalms 87",
    "summary": "Source text for Psalms 87 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.87.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 1,
      "referenceLabel": "Psalms 87:1",
      "text": "\"Ψαλμος ωδης δια τους υιους Κορε.\" Το θεμελιον αυτου ειναι εις τα ορη τα αγια.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.87.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 2,
      "referenceLabel": "Psalms 87:2",
      "text": "Αγαπα ο Κυριος τας πυλας της Σιων υπερ παντα τα σκηνωματα του Ιακωβ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 3,
      "referenceLabel": "Psalms 87:3",
      "text": "Ενδοξα ελαληθησαν περι σου, πολις του Θεου. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 4,
      "referenceLabel": "Psalms 87:4",
      "text": "Θελω αναφερει την Ρααβ και την Βαβυλωνα μεταξυ των γνωριζοντων με ιδου, η Παλαιστινη και η Τυρος μετα της Αιθιοπιας ουτος εγεννηθη εκει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 5,
      "referenceLabel": "Psalms 87:5",
      "text": "Και περι της Σιων θελουσιν ειπει, ουτος και εκεινος εγεννηθη εν αυτη και αυτος ο Υψιστος θελει στερεωσει αυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 6,
      "referenceLabel": "Psalms 87:6",
      "text": "Ο Κυριος θελει αριθμησει, οταν καταγραψη τους λαους, οτι ουτος εγεννηθη εκει. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.87.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 7,
      "referenceLabel": "Psalms 87:7",
      "text": "Και οι ψαλται καθως και οι λαληται των οργανων θελουσι λεγει, Πασαι αι πηγαι μου ειναι εν σοι.",
      "paragraphStart": false
    }
  ]
}
