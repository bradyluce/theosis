{
  "chapter": {
    "id": "lxx-greek:psalms.93",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 93,
    "referenceLabel": "Psalms 93",
    "summary": "Source text for Psalms 93 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.93.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 1,
      "referenceLabel": "Psalms 93:1",
      "text": "Θεε των εκδικησεων, Κυριε, Θεε των εκδικησεων, εμφανηθι.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.93.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 2,
      "referenceLabel": "Psalms 93:2",
      "text": "Υψωθητι, Κριτα της γης αποδος ανταποδοσιν εις τους υπερηφανους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 3,
      "referenceLabel": "Psalms 93:3",
      "text": "Εως ποτε οι ασεβεις, Κυριε, εως ποτε οι ασεβεις θελουσι θριαμβευει;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 4,
      "referenceLabel": "Psalms 93:4",
      "text": "Εως ποτε θελουσι προφερει και λαλει σκληρα; θελουσι καυχασθαι παντες οι εργαται της ανομιας;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 5,
      "referenceLabel": "Psalms 93:5",
      "text": "Τον λαον σου, Κυριε, καταθλιβουσι και την κληρονομιαν σου κακοποιουσι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 6,
      "referenceLabel": "Psalms 93:6",
      "text": "Την χηραν και τον ξενον φονευουσι και θανατονουσι τους ορφανους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 7,
      "referenceLabel": "Psalms 93:7",
      "text": "Και λεγουσι, δεν θελει ιδει ο Κυριος ουδε θελει νοησει ο Θεος του Ιακωβ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 8,
      "referenceLabel": "Psalms 93:8",
      "text": "Εννοησατε, οι αφρονες μεταξυ του λαου και οι μωροι, ποτε θελετε φρονιμευσει;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 9,
      "referenceLabel": "Psalms 93:9",
      "text": "Ο φυτευσας το ωτιον, δεν θελει ακουσει; ο πλασας τον οφθαλμον, δεν θελει ιδει;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 10,
      "referenceLabel": "Psalms 93:10",
      "text": "Ο σωφρονιζων τα εθνη, δεν θελει ελεγξει; ο διδασκων τον ανθρωπον γνωσιν;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 11,
      "referenceLabel": "Psalms 93:11",
      "text": "Ο Κυριος γνωριζει τους διαλογισμους των ανθρωπων, οτι ειναι ματαιοι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 12,
      "referenceLabel": "Psalms 93:12",
      "text": "Μακαριος ο ανθρωπος, τον οποιον σωφρονιζεις, Κυριε, και δια του νομου σου διδασκεις αυτον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 13,
      "referenceLabel": "Psalms 93:13",
      "text": "δια να αναπαυης αυτον απο των ημερων της συμφορας, εωσου σκαφθη λακκος εις τον ασεβη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 14,
      "referenceLabel": "Psalms 93:14",
      "text": "Διοτι δεν θελει απορριψει ο Κυριος τον λαον αυτου, και την κληρονομιαν αυτου δεν θελει εγκαταλειψει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 15,
      "referenceLabel": "Psalms 93:15",
      "text": "Επειδη η κρισις θελει επιστρεψει εις την δικαιοσυνην, και θελουσιν ακολουθησει αυτην παντες οι ευθεις την καρδιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 16,
      "referenceLabel": "Psalms 93:16",
      "text": "Τις θελει σηκωθη υπερ εμου κατα των πονηρευομενων; τις θελει παρασταθη υπερ εμου κατα των εργατων της ανομιας;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 17,
      "referenceLabel": "Psalms 93:17",
      "text": "Εαν ο Κυριος δεν με εβοηθει, παρ' ολιγον ηθελε κατοικησει ψυχη μου εν τη σιωπη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 18,
      "referenceLabel": "Psalms 93:18",
      "text": "Οτε ελεγον, ωλισθησεν ο πους μου, το ελεος σου, Κυριε, με εβοηθει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 19,
      "referenceLabel": "Psalms 93:19",
      "text": "Εν τω πληθει των αμηχανιων της καρδιας μου, αι παρηγοριαι σου ευφραναν την ψυχην μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 20,
      "referenceLabel": "Psalms 93:20",
      "text": "Μηπως εχει μετα σου συγκοινωνιαν ο θρονος της ανομιας, οστις μηχαναται αδικιαν αντι νομου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 21,
      "referenceLabel": "Psalms 93:21",
      "text": "Αυτοι εφορμωσι κατα της ψυχης του δικαιου και αιμα αθωον καταδικαζουσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 22,
      "referenceLabel": "Psalms 93:22",
      "text": "Αλλ' ο Κυριος ειναι εις εμε καταφυγιον και ο Θεος μου το φρουριον της ελπιδος μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.93.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 23,
      "referenceLabel": "Psalms 93:23",
      "text": "Και θελει επιστρεψει επ' αυτους την ανομιαν αυτων και εν τη πονηρια αυτων θελει αφανισει αυτους Κυριος ο Θεος ημων θελει αφανισει αυτους.",
      "paragraphStart": false
    }
  ]
}
