{
  "chapter": {
    "id": "lxx-greek:psalms.99",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 99,
    "referenceLabel": "Psalms 99",
    "summary": "Source text for Psalms 99 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.99.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 1,
      "referenceLabel": "Psalms 99:1",
      "text": "\"Ψαλμος δοξολογιας.\" Αλαλαξατε εις τον Κυριον, πασα η γη.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.99.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 2,
      "referenceLabel": "Psalms 99:2",
      "text": "Δουλευσατε εις τον Κυριον εν ευφροσυνη ελθετε ενωπιον αυτου εν αγαλλιασει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.99.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 3,
      "referenceLabel": "Psalms 99:3",
      "text": "Γνωρισατε οτι ο Κυριος ειναι ο Θεος αυτος εκαμεν ημας, και ουχι ημεις ημεις ειμεθα λαος αυτου και προβατα της βοσκης αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.99.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 4,
      "referenceLabel": "Psalms 99:4",
      "text": "Εισελθετε εις τας πυλας αυτου εν δοξολογια, εις τας αυλας αυτου εν υμνω δοξολογειτε αυτον ευλογειτε το ονομα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.99.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 5,
      "referenceLabel": "Psalms 99:5",
      "text": "Διοτι ο Κυριος ειναι αγαθος εις τον αιωνα μενει το ελεος αυτου, και εως γενεας και γενεας η αληθεια αυτου.",
      "paragraphStart": false
    }
  ]
}
