{
  "chapter": {
    "id": "lxx-greek:psalms.99",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 99,
    "referenceLabel": "Psalms 99",
    "summary": "Source text for Psalms 99 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.99.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 1,
      "referenceLabel": "Psalms 99:1",
      "text": "Ο Κυριος βασιλευει, ας τρεμωσιν οι λαοι ο καθημενος επι των χερουβειμ ας σεισθη η γη.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.99.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 2,
      "referenceLabel": "Psalms 99:2",
      "text": "Ο Κυριος ειναι μεγας εν Σιων, και επι παντας τους λαους ειναι υψηλος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.99.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 3,
      "referenceLabel": "Psalms 99:3",
      "text": "Ας δοξολογωσι το ονομα σου το μεγα και φοβερον, διοτι ειναι αγιον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.99.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 4,
      "referenceLabel": "Psalms 99:4",
      "text": "και την δυναμιν του βασιλεως, οστις αγαπα την δικαιοσυνην συ διωρισας την ευθυτητα, συ εκαμες κρισιν και δικαιοσυνην εις τον Ιακωβ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.99.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 5,
      "referenceLabel": "Psalms 99:5",
      "text": "Υψουτε Κυριον τον Θεον ημων και προσκυνειτε εις το υποποδιον των ποδων αυτου διοτι ειναι αγιος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.99.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 6,
      "referenceLabel": "Psalms 99:6",
      "text": "Μωυσης και Ααρων μεταξυ των ιερεων αυτου, και Σαμουηλ μεταξυ των επικαλουμενων το ονομα αυτου, επεκαλουντο τον Κυριον, και αυτος εισηκουεν αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.99.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 7,
      "referenceLabel": "Psalms 99:7",
      "text": "Εν στυλω νεφελης ελαλει προς αυτους εφυλαξε τα μαρτυρια αυτου και τα προσταγματα, τα οποια εδωκεν εις αυτους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.99.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 8,
      "referenceLabel": "Psalms 99:8",
      "text": "Κυριε Θεε ημων, συ εισηκουες αυτων εγεινας εις αυτους Θεος συγχωρητικος, πλην και εκδικητης δια τας πραξεις αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.99.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 9,
      "referenceLabel": "Psalms 99:9",
      "text": "Υψουτε Κυριον τον Θεον ημων και προσκυνειτε εις το ορος το αγιον αυτου διοτι αγιος Κυριος ο Θεος ημων.",
      "paragraphStart": false
    }
  ]
}
