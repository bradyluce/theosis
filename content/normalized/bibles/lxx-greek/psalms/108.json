{
  "chapter": {
    "id": "lxx-greek:psalms.108",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 108,
    "referenceLabel": "Psalms 108",
    "summary": "Source text for Psalms 108 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.108.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 1,
      "referenceLabel": "Psalms 108:1",
      "text": "\"Ωιδη Ψαλμου του Δαβιδ.\" Ετοιμη ειναι η καρδια μου, Θεε θελω ψαλλει και θελω ψαλμωδει εν τη δοξη μου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.108.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 2,
      "referenceLabel": "Psalms 108:2",
      "text": "Εξεγερθητι, ψαλτηριον, και κιθαρα θελω εξεγερθη το πρωι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.108.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 3,
      "referenceLabel": "Psalms 108:3",
      "text": "Θελω σε επαινεσει, Κυριε, μεταξυ λαων, και θελω ψαλμωδει εις σε μεταξυ εθνων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.108.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 4,
      "referenceLabel": "Psalms 108:4",
      "text": "διοτι εμεγαλυνθη εως των ουρανων το ελεος σου και εως των νεφελων η αληθεια σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.108.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 5,
      "referenceLabel": "Psalms 108:5",
      "text": "Υψωθητι, Θεε, επι τους ουρανους και η δοξα σου ας ηναι εφ' ολην την γην",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.108.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 6,
      "referenceLabel": "Psalms 108:6",
      "text": "δια να ελευθερονωνται οι αγαπητοι σου σωσον δια της δεξιας σου και επακουσον μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.108.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 7,
      "referenceLabel": "Psalms 108:7",
      "text": "Ο Θεος ελαλησεν εν τω αγιαστηριω αυτου θελω χαιρει, θελω μοιρασει την Συχεμ και την κοιλαδα Σοκχωθ θελω διαμετρησει",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.108.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 8,
      "referenceLabel": "Psalms 108:8",
      "text": "Εμου ειναι ο Γαλααδ, εμου ο Μανασσης ο μεν Εφραιμ ειναι η δυναμις της κεφαλης μου ο δε Ιουδας ο νομοθετης μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.108.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 9,
      "referenceLabel": "Psalms 108:9",
      "text": "Ο Μωαβ ειναι η λεκανη του πλυσιματος μου επι τον Εδωμ θελω ριψει το υποδημα μου θελω αλαλαξει επι την Παλαιστινην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.108.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 10,
      "referenceLabel": "Psalms 108:10",
      "text": "Τις θελει με φερει εις την περιτετειχισμενην πολιν; τις θελει με οδηγησει εως Εδωμ;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.108.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 11,
      "referenceLabel": "Psalms 108:11",
      "text": "ουχι συ, Θεε, ο απορριψας ημας; και δεν θελεις εξελθει, Θεε, μετα των στρατευματων ημων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.108.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 12,
      "referenceLabel": "Psalms 108:12",
      "text": "Βοηθησον ημας απο της θλιψεως, διοτι ματαια ειναι η παρα των ανθρωπων σωτηρια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.108.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 13,
      "referenceLabel": "Psalms 108:13",
      "text": "Δια του Θεου θελομεν καμει ανδραγαθιας και αυτος θελει καταπατησει τους εχθρους ημων.",
      "paragraphStart": false
    }
  ]
}
