{
  "chapter": {
    "id": "lxx-greek:psalms.107",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 107,
    "referenceLabel": "Psalms 107",
    "summary": "Source text for Psalms 107 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.107.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 1,
      "referenceLabel": "Psalms 107:1",
      "text": "Δοξολογειτε τον Κυριον, διοτι ειναι αγαθος, διοτι το ελεος αυτου μενει εις τον αιωνα.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.107.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 2,
      "referenceLabel": "Psalms 107:2",
      "text": "Ας λεγωσιν ουτως οι λελυτρωμενοι του Κυριου, τους οποιους ελυτρωσεν εκ χειρος του εχθρου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 3,
      "referenceLabel": "Psalms 107:3",
      "text": "και συνηγαγεν αυτους εκ των χωρων, απο ανατολης και δυσεως απο βορρα και απο νοτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 4,
      "referenceLabel": "Psalms 107:4",
      "text": "Περιεπλανωντο εν τη ερημω, εν οδω ανυδρω ουδε ευρισκον πολιν δια κατοικησιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 5,
      "referenceLabel": "Psalms 107:5",
      "text": "Ησαν πεινωντες και διψωντες η ψυχη αυτων απεκαμνεν εν αυτοις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 6,
      "referenceLabel": "Psalms 107:6",
      "text": "Τοτε εβοησαν προς τον Κυριον εν τη θλιψει αυτων και ηλευθερωσεν αυτους απο των αναγκων αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 7,
      "referenceLabel": "Psalms 107:7",
      "text": "Και ωδηγησεν αυτους δι' ευθειας οδου, δια να υπαγωσιν εις πολιν κατοικιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 8,
      "referenceLabel": "Psalms 107:8",
      "text": "Ας υμνολογωσιν εις τον Κυριον τα ελεη αυτου και τα θαυμασια αυτου τα προς τους υιους των ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 9,
      "referenceLabel": "Psalms 107:9",
      "text": "Διοτι εχορτασε ψυχην διψωσαν, και ψυχην πεινωσαν ενεπλησεν απο αγαθων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 10,
      "referenceLabel": "Psalms 107:10",
      "text": "Τους καθημενους εν σκοτει και σκια θανατου, τους δεδεμενους εν θλιψει και εν σιδηρω",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 11,
      "referenceLabel": "Psalms 107:11",
      "text": "διοτι ηπειθησαν εις τα λογια του Θεου και την βουλην του Υψιστου κατεφρονησαν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 12,
      "referenceLabel": "Psalms 107:12",
      "text": "δια τουτο εταπεινωσε την καρδιαν αυτων εν κοπω επεσον, και δεν υπηρχεν ο βοηθων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 13,
      "referenceLabel": "Psalms 107:13",
      "text": "Τοτε εβοησαν προς τον Κυριον εν τη θλιψει αυτων, και εσωσεν αυτους απο των αναγκων αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 14,
      "referenceLabel": "Psalms 107:14",
      "text": "εξηγαγεν αυτους εκ του σκοτους και εκ της σκιας του θανατου και τα δεσμα αυτων συνετριψεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 15,
      "referenceLabel": "Psalms 107:15",
      "text": "Ας υμνολογωσιν εις τον Κυριον τα ελεη αυτου και τα θαυμασια αυτου τα προς τους υιους των ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 16,
      "referenceLabel": "Psalms 107:16",
      "text": "διοτι συνετριψε πυλας χαλκινας και μοχλους σιδηρους κατεκοψεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 17,
      "referenceLabel": "Psalms 107:17",
      "text": "Οι αφρονες βασανιζονται δια τας παραβασεις αυτων και δια τας ανομιας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 18,
      "referenceLabel": "Psalms 107:18",
      "text": "Παν φαγητον βδελυττεται η ψυχη αυτων, και πλησιαζουσιν εως των πυλων του θανατου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 19,
      "referenceLabel": "Psalms 107:19",
      "text": "Τοτε βοωσι προς τον Κυριον εν τη θλιψει αυτων, και σωζει αυτους απο των αναγκων αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 20,
      "referenceLabel": "Psalms 107:20",
      "text": "αποστελλει τον λογον αυτου και ιατρευει αυτους και ελευθερονει απο της φθορας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 21,
      "referenceLabel": "Psalms 107:21",
      "text": "Ας υμνολογωσιν εις τον Κυριον τα ελεη αυτου, και τα θαυμασια αυτου τα προς τους υιους των ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 22,
      "referenceLabel": "Psalms 107:22",
      "text": "και ας θυσιαζωσι θυσιας αινεσεως και ας κηρυττωσι τα εργα αυτου εν αγαλλιασει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 23,
      "referenceLabel": "Psalms 107:23",
      "text": "Οι καταβαινοντες εις την θαλασσαν με πλοια, καμνοντες εργασιας εν υδασι πολλοις,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 24,
      "referenceLabel": "Psalms 107:24",
      "text": "αυτοι βλεπουσι τα εργα του Κυριου και τα θαυμασια αυτου τα γινομενα εις τα βαθη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.25",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 25,
      "referenceLabel": "Psalms 107:25",
      "text": "Διοτι προσταζει, και εγειρεται ανεμος καταιγιδος, και υψονει τα κυματα αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.26",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 26,
      "referenceLabel": "Psalms 107:26",
      "text": "Αναβαινουσιν εως των ουρανων και καταβαινουσιν εως των αβυσσων η ψυχη αυτων τηκεται υπο της συμφορας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.27",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 27,
      "referenceLabel": "Psalms 107:27",
      "text": "Σειονται και κλονιζονται ως ο μεθυων, και πασα η σοφια αυτων χανεται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.28",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 28,
      "referenceLabel": "Psalms 107:28",
      "text": "Τοτε κραζουσι προς τον Κυριον εν τη θλιψει αυτων, και εξαγει αυτους απο των αναγκων αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.29",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 29,
      "referenceLabel": "Psalms 107:29",
      "text": "Κατασιγαζει την ανεμοζαλην, και σιωπωσι τα κυματα αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.30",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 30,
      "referenceLabel": "Psalms 107:30",
      "text": "Και ευφραινονται, διοτι ησυχασαν και οδηγει αυτους εις τον επιθυμητον λιμενα αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.31",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 31,
      "referenceLabel": "Psalms 107:31",
      "text": "Ας υμνολογωσιν εις τον Κυριον τα ελεη αυτου και τα θαυμασια αυτου τα προς τους υιους των ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.32",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 32,
      "referenceLabel": "Psalms 107:32",
      "text": "και ας υψονωσιν αυτον εν τη συναξει του λαου, και εν τω συνεδριω των πρεσβυτερων ας αινωσιν αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.33",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 33,
      "referenceLabel": "Psalms 107:33",
      "text": "Μεταβαλλει ποταμους εις ερημον και πηγας υδατων εις ξηρασιαν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.34",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 34,
      "referenceLabel": "Psalms 107:34",
      "text": "την καρποφορον γην εις αλμυραν, δια την κακιαν των κατοικουντων εν αυτη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.35",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 35,
      "referenceLabel": "Psalms 107:35",
      "text": "Μεταβαλλει την ερημον εις λιμνας υδατων και την ξηραν γην εις πηγας υδατων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.36",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 36,
      "referenceLabel": "Psalms 107:36",
      "text": "Και εκει κατοικιζει τους πεινωντας, και συγκροτουσι πολεις εις κατοικησιν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.37",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 37,
      "referenceLabel": "Psalms 107:37",
      "text": "και σπειρουσιν αγρους και φυτευουσιν αμπελωνας, οιτινες καμνουσι καρπους γεννηματος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.38",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 38,
      "referenceLabel": "Psalms 107:38",
      "text": "Και ευλογει αυτους, και πληθυνονται σφοδρα, και δεν ολιγοστευει τα κτηνη αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.39",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 39,
      "referenceLabel": "Psalms 107:39",
      "text": "Ολιγοστευουσιν ομως επειτα και ταπεινονονται, απο της στενοχωριας, της συμφορας και του πονου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.40",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 40,
      "referenceLabel": "Psalms 107:40",
      "text": "Επιχεει καταφρονησιν επι τους αρχοντας και καμνει αυτους να περιπλανωνται εν ερημω αβατω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.41",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 41,
      "referenceLabel": "Psalms 107:41",
      "text": "Τον δε πενητα υψονει απο της πτωχειας και καθιστα ως ποιμνια τας οικογενειας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.42",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 42,
      "referenceLabel": "Psalms 107:42",
      "text": "Οι ευθεις βλεπουσι και ευφραινονται πασα δε ανομια θελει εμφραξει το στομα αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.43",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 43,
      "referenceLabel": "Psalms 107:43",
      "text": "Οστις ειναι σοφος ας παρατηρη ταυτα και θελουσιν εννοησει τα ελεη του Κυριου.",
      "paragraphStart": false
    }
  ]
}
