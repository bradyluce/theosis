{
  "chapter": {
    "id": "lxx-greek:psalms.107",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 107,
    "referenceLabel": "Psalms 107",
    "summary": "Source text for Psalms 107 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.107.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 1,
      "referenceLabel": "Psalms 107:1",
      "text": "\"Ωιδη Ψαλμου του Δαβιδ.\" Ετοιμη ειναι η καρδια μου, Θεε θελω ψαλλει και θελω ψαλμωδει εν τη δοξη μου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.107.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 2,
      "referenceLabel": "Psalms 107:2",
      "text": "Εξεγερθητι, ψαλτηριον, και κιθαρα θελω εξεγερθη το πρωι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 3,
      "referenceLabel": "Psalms 107:3",
      "text": "Θελω σε επαινεσει, Κυριε, μεταξυ λαων, και θελω ψαλμωδει εις σε μεταξυ εθνων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 4,
      "referenceLabel": "Psalms 107:4",
      "text": "διοτι εμεγαλυνθη εως των ουρανων το ελεος σου και εως των νεφελων η αληθεια σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 5,
      "referenceLabel": "Psalms 107:5",
      "text": "Υψωθητι, Θεε, επι τους ουρανους και η δοξα σου ας ηναι εφ' ολην την γην",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 6,
      "referenceLabel": "Psalms 107:6",
      "text": "δια να ελευθερονωνται οι αγαπητοι σου σωσον δια της δεξιας σου και επακουσον μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 7,
      "referenceLabel": "Psalms 107:7",
      "text": "Ο Θεος ελαλησεν εν τω αγιαστηριω αυτου θελω χαιρει, θελω μοιρασει την Συχεμ και την κοιλαδα Σοκχωθ θελω διαμετρησει",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 8,
      "referenceLabel": "Psalms 107:8",
      "text": "Εμου ειναι ο Γαλααδ, εμου ο Μανασσης ο μεν Εφραιμ ειναι η δυναμις της κεφαλης μου ο δε Ιουδας ο νομοθετης μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 9,
      "referenceLabel": "Psalms 107:9",
      "text": "Ο Μωαβ ειναι η λεκανη του πλυσιματος μου επι τον Εδωμ θελω ριψει το υποδημα μου θελω αλαλαξει επι την Παλαιστινην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 10,
      "referenceLabel": "Psalms 107:10",
      "text": "Τις θελει με φερει εις την περιτετειχισμενην πολιν; τις θελει με οδηγησει εως Εδωμ;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 11,
      "referenceLabel": "Psalms 107:11",
      "text": "ουχι συ, Θεε, ο απορριψας ημας; και δεν θελεις εξελθει, Θεε, μετα των στρατευματων ημων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 12,
      "referenceLabel": "Psalms 107:12",
      "text": "Βοηθησον ημας απο της θλιψεως, διοτι ματαια ειναι η παρα των ανθρωπων σωτηρια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.107.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 13,
      "referenceLabel": "Psalms 107:13",
      "text": "Δια του Θεου θελομεν καμει ανδραγαθιας και αυτος θελει καταπατησει τους εχθρους ημων.",
      "paragraphStart": false
    }
  ]
}
