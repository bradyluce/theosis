{
  "chapter": {
    "id": "lxx-greek:psalms.139",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 139,
    "referenceLabel": "Psalms 139",
    "summary": "Source text for Psalms 139 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.139.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 1,
      "referenceLabel": "Psalms 139:1",
      "text": "\"Εις τον πρωτον μουσικον. Ψαλμος του Δαβιδ.\" Κυριε, εδοκιμασας με και με εγνωρισας.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.139.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 2,
      "referenceLabel": "Psalms 139:2",
      "text": "Συ γνωριζεις το καθισμα μου και την εγερσιν μου νοεις τους λογισμους μου απο μακροθεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 3,
      "referenceLabel": "Psalms 139:3",
      "text": "Εξερευνας το περιπατημα μου και το πλαγιασμα μου και πασας τας οδους μου γνωριζεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 4,
      "referenceLabel": "Psalms 139:4",
      "text": "Διοτι και πριν ελθη ο λογος εις την γλωσσαν μου, ιδου, Κυριε, γνωριζεις το παν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 5,
      "referenceLabel": "Psalms 139:5",
      "text": "Με περικυκλονεις οπισθεν και εμπροσθεν, και εθεσας επ' εμε την χειρα σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 6,
      "referenceLabel": "Psalms 139:6",
      "text": "Η γνωσις αυτη ειναι υπερθαυμαστος εις εμε ειναι υψηλη δεν δυναμαι να φθασω εις αυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 7,
      "referenceLabel": "Psalms 139:7",
      "text": "Που να υπαγω απο του πνευματος σου; και απο του προσωπου σου που να φυγω;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 8,
      "referenceLabel": "Psalms 139:8",
      "text": "Εαν αναβω εις τον ουρανον, εισαι εκει εαν πλαγιασω εις τον αδην, ιδου, συ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 9,
      "referenceLabel": "Psalms 139:9",
      "text": "Εαν λαβω τας πτερυγας της αυγης και κατοικησω εις τα εσχατα της θαλασσης,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 10,
      "referenceLabel": "Psalms 139:10",
      "text": "και εκει θελει με οδηγησει η χειρ σου και η δεξια σου θελει με κρατει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 11,
      "referenceLabel": "Psalms 139:11",
      "text": "Εαν ειπω, Αλλα το σκοτος θελει με σκεπασει, και η νυξ θελει εισθαι φως περι εμε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 12,
      "referenceLabel": "Psalms 139:12",
      "text": "και αυτο το σκοτος δεν σκεπαζει ουδεν απο σου και η νυξ λαμπει ως η ημερα εις σε το σκοτος ειναι ως το φως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 13,
      "referenceLabel": "Psalms 139:13",
      "text": "Διοτι συ εμορφωσας τους νεφρους μου με περιετυλιξας εν τη κοιλια της μητρος μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 14,
      "referenceLabel": "Psalms 139:14",
      "text": "Θελω σε υμνει, διοτι φοβερως και θαυμασιως επλασθην θαυμασια ειναι τα εργα σου και η ψυχη μου καλλιστα γνωριζει τουτο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 15,
      "referenceLabel": "Psalms 139:15",
      "text": "Δεν εκρυφθησαν τα οστα μου απο σου, ενω επλαττομην εν τω κρυπτω και διεμορφονομην εν τοις κατωτατοις της γης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 16,
      "referenceLabel": "Psalms 139:16",
      "text": "Το αδιαμορφωτον του σωματος μου ειδον οι οφθαλμοι σου και εν τω βιβλιω σου παντα ταυτα ησαν γεγραμμενα, ως και αι ημεραι καθ' ας εσχηματιζοντο, και ενω ουδεν εκ τουτων υπηρχε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 17,
      "referenceLabel": "Psalms 139:17",
      "text": "ποσον δε πολυτιμοι ειναι εις εμε αι βουλαι σου, Θεε ποσον εμεγαλυνθη ο αριθμος αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 18,
      "referenceLabel": "Psalms 139:18",
      "text": "Εαν ηθελον να απαριθμησω αυτας, υπερβαινουσι την αμμον εξυπνω, και ετι ειμαι μετα σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 19,
      "referenceLabel": "Psalms 139:19",
      "text": "Βεβαιως θελεις θανατωσει τους ασεβεις, Θεε απομακρυνθητε λοιπον απ' εμου, ανδρες αιματων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 20,
      "referenceLabel": "Psalms 139:20",
      "text": "Διοτι λαλουσι κατα σου ασεβως οι εχθροι σου λαμβανουσι το ονομα σου επι ματαιω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 21,
      "referenceLabel": "Psalms 139:21",
      "text": "Μη δεν μισω, Κυριε, τους μισουντας σε; και δεν αγανακτω κατα των επανισταμενων επι σε;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 22,
      "referenceLabel": "Psalms 139:22",
      "text": "Με τελειον μισος μισω αυτους δια εχθρους εχω αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 23,
      "referenceLabel": "Psalms 139:23",
      "text": "Δοκιμασον με, Θεε, και γνωρισον την καρδιαν μου εξετασον με και μαθε τους στοχασμους μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 24,
      "referenceLabel": "Psalms 139:24",
      "text": "και ιδε, αν υπαρχη εν εμοι οδος ανομιας και οδηγησον με εις την οδον την αιωνιον.",
      "paragraphStart": false
    }
  ]
}
