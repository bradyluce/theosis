{
  "chapter": {
    "id": "lxx-greek:psalms.139",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 139,
    "referenceLabel": "Psalms 139",
    "summary": "Source text for Psalms 139 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.139.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 1,
      "referenceLabel": "Psalms 139:1",
      "text": "\"Εις τον πρωτον μουσικον. Ψαλμος του Δαβιδ.\" Ελευθερωσον με, Κυριε, απο ανθρωπου πονηρου λυτρωσον με απο ανθρωπου αδικου",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.139.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 2,
      "referenceLabel": "Psalms 139:2",
      "text": "Οιτινες διαλογιζονται πονηρα εν τη καρδια ολην την ημεραν παραταττονται εις πολεμους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 3,
      "referenceLabel": "Psalms 139:3",
      "text": "Ηκονησαν την γλωσσαν αυτων ως οφεως φαρμακιον ασπιδος ειναι υπο τα χειλη αυτων. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 4,
      "referenceLabel": "Psalms 139:4",
      "text": "Φυλαξον με, Κυριε, απο χειρων ασεβους λυτρωσον με απο ανθρωπου αδικου οιτινες εμηχανευθησαν να υποσκελισωσι τα διαβηματα μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 5,
      "referenceLabel": "Psalms 139:5",
      "text": "Οι υπερηφανοι εκρυψαν κατ' εμου παγιδα, και με σχοινια ηπλωσαν δικτυα εις την διαβασιν μου εστησαν δι' εμε βροχια. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 6,
      "referenceLabel": "Psalms 139:6",
      "text": "Ειπα προς τον Κυριον, Συ εισαι ο Θεος μου ακροασθητι, Κυριε, της φωνης των δεησεων μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 7,
      "referenceLabel": "Psalms 139:7",
      "text": "Κυριε Θεε, η δυναμις της σωτηριας μου, συ περιεσκεπασας την κεφαλην μου εν ημερα πολεμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 8,
      "referenceLabel": "Psalms 139:8",
      "text": "Μη δωσης, Κυριε, εις τον ασεβη τας επιθυμιας αυτου μη αφησης να εκτελεσθη ο στοχασμος αυτου, μηποτε υψωθωσι. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 9,
      "referenceLabel": "Psalms 139:9",
      "text": "Η πονηρια των χειλεων των περικυκλουντων με ας σκεπαση την κεφαλην αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 10,
      "referenceLabel": "Psalms 139:10",
      "text": "Ανθρακες πεπυρακτωμενοι ας πεσωσιν επ' αυτους ας ριφθωσιν εις το πυρ, εις λακκους βαθεις, δια να μη εγερθωσι πλεον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 11,
      "referenceLabel": "Psalms 139:11",
      "text": "Ανθρωπος κακογλωσσος ας μη στερεωθη επι της γης η κακια θελει καταδιωξει τον αδικον ανθρωπον, εωσου απολεση αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 12,
      "referenceLabel": "Psalms 139:12",
      "text": "Εξευρω οτι ο Κυριος θελει καμει την κρισιν του τεθλιμμενου και την δικην των πτωχων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.139.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 13,
      "referenceLabel": "Psalms 139:13",
      "text": "Βεβαιως οι δικαιοι θελουσι δοξολογει το ονομα σου οι ευθεις θελουσι κατοικει εμπροσθεν του προσωπου σου.",
      "paragraphStart": false
    }
  ]
}
