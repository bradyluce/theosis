{
  "chapter": {
    "id": "lxx-greek:psalms.31",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 31,
    "referenceLabel": "Psalms 31",
    "summary": "Source text for Psalms 31 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.31.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 1,
      "referenceLabel": "Psalms 31:1",
      "text": "\"Εις τον πρωτον μουσικον. Ψαλμος του Δαβιδ.\" Επι σε, Κυριε, ηλπισα ας μη καταισχυνθω εις τον αιωνα εν τη δικαιοσυνη σου σωσον με.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.31.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 2,
      "referenceLabel": "Psalms 31:2",
      "text": "Κλινον εις εμε το ωτιον σου ταχυνον να με ελευθερωσης γενου εις εμε ισχυρος βραχος οικος καταφυγης, δια να με σωσης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 3,
      "referenceLabel": "Psalms 31:3",
      "text": "Διοτι πετρα μου και φρουριον μου εισαι και ενεκεν του ονοματος σου οδηγησον με και διαθρεψον με.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 4,
      "referenceLabel": "Psalms 31:4",
      "text": "Εκβαλε με εκ της παγιδος, την οποιαν εκρυψαν δι' εμε διοτι εισαι η δυναμις μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 5,
      "referenceLabel": "Psalms 31:5",
      "text": "Εις τας χειρας σου παραδιδω το πνευμα μου συ με ελυτρωσας, Κυριε ο Θεος της αληθειας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 6,
      "referenceLabel": "Psalms 31:6",
      "text": "Εμισησα τους προσεχοντας εις τας ματαιοτητας του ψευδους εγω δε επι τον Κυριον ελπιζω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 7,
      "referenceLabel": "Psalms 31:7",
      "text": "Θελω αγαλλεσθαι και ευφραινεσθαι εις το ελεος σου διοτι ειδες την θλιψιν μου, εγνωρισας την ψυχην μου εν στενοχωριαις,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 8,
      "referenceLabel": "Psalms 31:8",
      "text": "και δεν με συνεκλεισας εις την χειρα του εχθρου εστησας εν ευρυχωρια τους ποδας μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 9,
      "referenceLabel": "Psalms 31:9",
      "text": "Ελεησον με, Κυριε, διοτι ειμαι εν θλιψει εμαρανθη απο της λυπης ο οφθαλμος μου, η ψυχη μου και η κοιλια μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 10,
      "referenceLabel": "Psalms 31:10",
      "text": "Διοτι εξελιπεν εν οδυνη η ζωη μου και τα ετη μου εν στεναγμοις ησθενησεν απο ταλαιπωριας μου η δυναμις μου, και τα οστα μου κατεφθαρησαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 11,
      "referenceLabel": "Psalms 31:11",
      "text": "Εις παντας τους εχθρους μου εγεινα ονειδος και εις τους γειτονας μου σφοδρα, και φοβος εις τους γνωστους μου οι βλεποντες με εξω εφευγον απ' εμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 12,
      "referenceLabel": "Psalms 31:12",
      "text": "Ελησμονηθην απο της καρδιας ως νεκρος εγεινα ως σκευος συντετριμμενον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 13,
      "referenceLabel": "Psalms 31:13",
      "text": "Διοτι ηκουσα τον ονειδισμον πολλων φοβος ητο πανταχοθεν οτε συνεβουλευθησαν κατ' εμου εμηχανευθησαν να αφαιρεσωσι την ζωην μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 14,
      "referenceLabel": "Psalms 31:14",
      "text": "Αλλ' εγω επι σε, Κυριε, ηλπισα ειπα, συ εισαι ο Θεος μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 15,
      "referenceLabel": "Psalms 31:15",
      "text": "Εις τας χειρας σου ειναι οι καιροι μου λυτρωσον με εκ χειρος των εχθρων μου και εκ των καταδιωκοντων με.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 16,
      "referenceLabel": "Psalms 31:16",
      "text": "Επιφανον το προσωπον σου επι τον δουλον σου σωσον με εν τω ελεει σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 17,
      "referenceLabel": "Psalms 31:17",
      "text": "Κυριε, ας μη καταισχυνθω, διοτι σε επεκαλεσθην ας καταισχυνθωσιν οι ασεβεις, ας σιωπησωσιν εν τω αδη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 18,
      "referenceLabel": "Psalms 31:18",
      "text": "Αλαλα ας γεινωσι τα χειλη τα δολια, τα λαλουντα σκληρως κατα του δικαιου εν υπερηφανια και καταφρονησει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 19,
      "referenceLabel": "Psalms 31:19",
      "text": "Ποσον μεγαλη ειναι η αγαθοτης σου, την οποιαν εφυλαξας εις τους φοβουμενους σε και ενηργησας εις τους ελπιζοντας επι σε εμπροσθεν των υιων των ανθρωπων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 20,
      "referenceLabel": "Psalms 31:20",
      "text": "Θελεις κρυψει αυτους εν αποκρυφω του προσωπου σου απο της αλαζονειας των ανθρωπων θελεις κρυψει αυτους εν σκηνη απο της αντιλογιας των γλωσσων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 21,
      "referenceLabel": "Psalms 31:21",
      "text": "Ευλογητος ο Κυριος, διοτι εθαυμαστωσε το ελεος αυτου προς εμε εν πολει οχυρα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 22,
      "referenceLabel": "Psalms 31:22",
      "text": "Εγω δε ειπα εν τη εκπληξει μου, Απερριφθην απ' εμπροσθεν των οφθαλμων σου πλην συ ηκουσας της φωνης των δεησεων μου, οτε εβοησα προς σε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 23,
      "referenceLabel": "Psalms 31:23",
      "text": "Αγαπησατε τον Κυριον, παντες οι οσιοι αυτου ο Κυριος φυλαττει τους πιστους, και ανταποδιδει περισσως εις τους πραττοντας την υπερηφανιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.31.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 24,
      "referenceLabel": "Psalms 31:24",
      "text": "Ανδριζεσθε, και ας κραταιωθη η καρδια σας, παντες οι ελπιζοντες επι Κυριον.",
      "paragraphStart": false
    }
  ]
}
