{
  "chapter": {
    "id": "lxx-greek:psalms.64",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 64,
    "referenceLabel": "Psalms 64",
    "summary": "Source text for Psalms 64 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.64.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 1,
      "referenceLabel": "Psalms 64:1",
      "text": "\"Εις τον πρωτον μουσικον. Ψαλμος του Δαβιδ.\" Ακουσον, Θεε, της φωνης μου εν τη δεησει μου απο του φοβου του εχθρου φυλαξον την ζωην μου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.64.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 2,
      "referenceLabel": "Psalms 64:2",
      "text": "Σκεπασον με απο συμβουλιου πονηρων, απο φρυαγματος εργαζομενων ανομιαν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.64.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 3,
      "referenceLabel": "Psalms 64:3",
      "text": "οιτινες ακονωσιν ως ρομφαιαν την γλωσσαν αυτων ετοιμαζουσιν ως βελη λογους πικρους,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.64.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 4,
      "referenceLabel": "Psalms 64:4",
      "text": "δια να τοξευωσι κρυφιως τον αμεμπτον εξαιφνης τοξευουσιν αυτον και δεν φοβουνται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.64.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 5,
      "referenceLabel": "Psalms 64:5",
      "text": "Στερεουνται επι πονηρου πραγματος μελετωσι να κρυπτωσι παγιδας, λεγοντες, Τις θελει ιδει αυτους;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.64.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 6,
      "referenceLabel": "Psalms 64:6",
      "text": "Ανιχνευουσιν ανομιας απεκαμον ανιχνευοντες επιμελως εκαστου δε τα εντος και η καρδια ειναι βυθος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.64.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 7,
      "referenceLabel": "Psalms 64:7",
      "text": "Αλλ' ο Θεος θελει τοξευσει αυτους απο αιφνιδιου βελους θελουσιν εισθαι αι πληγαι αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.64.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 8,
      "referenceLabel": "Psalms 64:8",
      "text": "Και οι λογοι της γλωσσης αυτων θελουσι πεσει επ' αυτου θελουσι φευγει παντες οι βλεποντες αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.64.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 9,
      "referenceLabel": "Psalms 64:9",
      "text": "Και θελει φοβηθη πας ανθρωπος, και θελουσι διηγηθη το εργον του Θεου και εννοησει τας εργασιας αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.64.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 10,
      "referenceLabel": "Psalms 64:10",
      "text": "Ο δικαιος θελει ευφρανθη εις τον Κυριον και θελει ελπιζει επ' αυτον και θελουσι καυχασθαι παντες οι ευθεις την καρδιαν.",
      "paragraphStart": false
    }
  ]
}
