{
  "chapter": {
    "id": "lxx-greek:psalms.63",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 63,
    "referenceLabel": "Psalms 63",
    "summary": "Source text for Psalms 63 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.63.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 1,
      "referenceLabel": "Psalms 63:1",
      "text": "\"Ψαλμος του Δαβιδ, οτε ευρισκετο εν τη ερημω Ιουδα.\" Θεε, συ εισαι ο Θεος μου απο πρωιας σε ζητω σε διψα η ψυχη μου, σε ποθει η σαρξ μου, εν γη ερημω, ξηρα και ανυδρω",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.63.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 2,
      "referenceLabel": "Psalms 63:2",
      "text": "δια να βλεπω την δυναμιν σου και την δοξαν σου, καθως σε ειδον εν τω αγιαστηριω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.63.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 3,
      "referenceLabel": "Psalms 63:3",
      "text": "Διοτι το ελεος σου ειναι καλητερον παρα την ζωην τα χειλη μου θελουσι σε επαινει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.63.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 4,
      "referenceLabel": "Psalms 63:4",
      "text": "Ουτω θελω σε ευλογει εν τη ζωη μου εν τω ονοματι σου θελω υψονει τας χειρας μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.63.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 5,
      "referenceLabel": "Psalms 63:5",
      "text": "Ως απο παχους και μυελου θελει χορτασθη η ψυχη μου και δια χειλεων αγαλλιασεως θελει υμνει το στομα μου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.63.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 6,
      "referenceLabel": "Psalms 63:6",
      "text": "Οταν σε ενθυμωμαι επι της στρωμνης μου, εις σε μελετω εν ταις φυλακαις της νυκτος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.63.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 7,
      "referenceLabel": "Psalms 63:7",
      "text": "Επειδη εσταθης βοηθεια μου δια τουτο υπο την σκιαν των πτερυγων σου θελω χαιρει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.63.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 8,
      "referenceLabel": "Psalms 63:8",
      "text": "Προσεκολληθη η ψυχη μου κατοπιν σου η δεξια σου με υποστηριζει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.63.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 9,
      "referenceLabel": "Psalms 63:9",
      "text": "Οι δε ζητουντες την ψυχην μου, δια να εξολοθρευσωσιν αυτην, θελουσιν εμβη εις τα κατωτατα μερη της γης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.63.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 10,
      "referenceLabel": "Psalms 63:10",
      "text": "θελουσι πεσει δια ρομφαιας θελουσιν εισθαι μερις αλωπεκων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.63.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 11,
      "referenceLabel": "Psalms 63:11",
      "text": "Ο δε βασιλευς θελει ευφρανθη επι τον Θεον θελει δοξασθη πας ο ομνυων εις αυτον διοτι θελει φραχθη το στομα των λαλουντων ψευδος.",
      "paragraphStart": false
    }
  ]
}
