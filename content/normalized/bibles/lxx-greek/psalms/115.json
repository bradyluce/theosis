{
  "chapter": {
    "id": "lxx-greek:psalms.115",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 115,
    "referenceLabel": "Psalms 115",
    "summary": "Source text for Psalms 115 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.115.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 1,
      "referenceLabel": "Psalms 115:1",
      "text": "Μη εις ημας, Κυριε, μη εις ημας, αλλ' εις το ονομα σου δος δοξαν, δια το ελεος σου, δια την αληθειαν σου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.115.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 2,
      "referenceLabel": "Psalms 115:2",
      "text": "Δια τι να ειπωσι τα εθνη, και που ειναι ο Θεος αυτων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 3,
      "referenceLabel": "Psalms 115:3",
      "text": "Αλλ' ο Θεος ημων ειναι εν τω ουρανω παντα οσα ηθελησεν εποιησε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 4,
      "referenceLabel": "Psalms 115:4",
      "text": "Τα ειδωλα αυτων ειναι αργυριον και χρυσιον, εργα χειρων ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 5,
      "referenceLabel": "Psalms 115:5",
      "text": "Στομα εχουσι και δεν λαλουσιν οφθαλμους εχουσι και δεν βλεπουσιν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 6,
      "referenceLabel": "Psalms 115:6",
      "text": "ωτα εχουσι και δεν ακουουσι μυκτηρας εχουσι και δεν οσφραινονται",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 7,
      "referenceLabel": "Psalms 115:7",
      "text": "Χειρας εχουσι και δεν ψηλαφωσι ποδας εχουσι και δεν περιπατουσιν ουδε ομιλουσι δια του λαρυγγος αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 8,
      "referenceLabel": "Psalms 115:8",
      "text": "Ομοιοι αυτων ας γεινωσιν οι ποιουντες αυτα, πας ο ελπιζων επ' αυτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 9,
      "referenceLabel": "Psalms 115:9",
      "text": "Ο Ισραηλ ηλπισεν επι Κυριον αυτος ειναι βοηθος και ασπις αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 10,
      "referenceLabel": "Psalms 115:10",
      "text": "Ο οικος του Ααρων ηλπισεν επι Κυριον αυτος ειναι βοηθος και ασπις αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 11,
      "referenceLabel": "Psalms 115:11",
      "text": "Οι φοβουμενοι τον Κυριον ηλπισαν επι Κυριον αυτος ειναι βοηθος και ασπις αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 12,
      "referenceLabel": "Psalms 115:12",
      "text": "Ο Κυριος μας ενεθυμηθη θελει ευλογει, θελει ευλογει τον οικον Ισραηλ θελει ευλογει τον οικον Ααρων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 13,
      "referenceLabel": "Psalms 115:13",
      "text": "Θελει ευλογει τους φοβουμενους τον Κυριον, τους μικρους μετα των μεγαλων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 14,
      "referenceLabel": "Psalms 115:14",
      "text": "Ο Κυριος θελει αυξησει υμας, υμας και τα τεκνα υμων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 15,
      "referenceLabel": "Psalms 115:15",
      "text": "σεις εισθε οι ευλογημενοι του Κυριου, του ποιησαντος τον ουρανον και την γην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 16,
      "referenceLabel": "Psalms 115:16",
      "text": "Οι ουρανοι των ουρανων ειναι του Κυριου, την δε γην εδωκεν εις τους υιους των ανθρωπων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 17,
      "referenceLabel": "Psalms 115:17",
      "text": "Οι νεκροι δεν θελουσιν αινεσει τον Κυριον, ουδε παντες οι καταβαινοντες εις τον τοπον της σιωπης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 18,
      "referenceLabel": "Psalms 115:18",
      "text": "αλλ' ημεις θελομεν ευλογει τον Κυριον, απο του νυν και εως του αιωνος. Αλληλουια.",
      "paragraphStart": false
    }
  ]
}
