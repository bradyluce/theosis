{
  "chapter": {
    "id": "lxx-greek:psalms.115",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 115,
    "referenceLabel": "Psalms 115",
    "summary": "Source text for Psalms 115 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.115.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 1,
      "referenceLabel": "Psalms 115:1",
      "text": "Επιστευσα, δια τουτο ελαλησα εγω ημην σφοδρα τεθλιμμενος",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 2,
      "referenceLabel": "Psalms 115:2",
      "text": "εγω ειπα εν τη εκπληξει μου, πας ανθρωπος ειναι ψευστης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 3,
      "referenceLabel": "Psalms 115:3",
      "text": "Τι να ανταποδωσω εις τον Κυριον, δια πασας τας ευεργεσιας αυτου τας προς εμε;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 4,
      "referenceLabel": "Psalms 115:4",
      "text": "θελω λαβει το ποτηριον της σωτηριας και θελω επικαλεσθη το ονομα του Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 5,
      "referenceLabel": "Psalms 115:5",
      "text": "Τας ευχας μου θελω αποδωσει εις τον Κυριον, τωρα ενωπιον παντος του λαου αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 6,
      "referenceLabel": "Psalms 115:6",
      "text": "Πολυτιμος ενωπιον του Κυριου ο θανατος των οσιων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 7,
      "referenceLabel": "Psalms 115:7",
      "text": "Ναι, Κυριε διοτι ειμαι δουλος σου ειμαι δουλος σου, υιος της δουλης σου συ ελυσας τα δεσμα μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 8,
      "referenceLabel": "Psalms 115:8",
      "text": "Εις σε θελω θυσιασει θυσιαν αινεσεως και το ονομα του Κυριου θελω επικαλεσθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 9,
      "referenceLabel": "Psalms 115:9",
      "text": "Τας ευχας μου θελω αποδωσει εις τον Κυριον, τωρα εμπροσθεν παντος του λαου αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.115.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 10,
      "referenceLabel": "Psalms 115:10",
      "text": "εν ταις αυλαις του οικου του Κυριου, εν μεσω σου, Ιερουσαλημ. Αλληλουια.",
      "paragraphStart": false
    }
  ]
}
