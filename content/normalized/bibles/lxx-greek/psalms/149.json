{
  "chapter": {
    "id": "lxx-greek:psalms.149",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 149,
    "referenceLabel": "Psalms 149",
    "summary": "Source text for Psalms 149 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.149.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 1,
      "referenceLabel": "Psalms 149:1",
      "text": "Αινειτε τον Κυριον. Ψαλατε εις τον Κυριον ωδην νεαν, την αινεσιν αυτου εν τη συναξει των οσιων.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.149.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 2,
      "referenceLabel": "Psalms 149:2",
      "text": "Ας ευφραινεται ο Ισραηλ εις τον Ποιητην αυτου οι υιοι της Σιων ας αγαλλωνται εις τον Βασιλεα αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.149.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 3,
      "referenceLabel": "Psalms 149:3",
      "text": "Ας αινωσι το ονομα αυτου χοροστατουντες εν τυμπανω και κιθαρα ας ψαλμωδωσιν εις αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.149.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 4,
      "referenceLabel": "Psalms 149:4",
      "text": "Διοτι ο Κυριος ευδοκει εις τον λαον αυτου θελει δοξασει τους πραους εν σωτηρια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.149.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 5,
      "referenceLabel": "Psalms 149:5",
      "text": "Οι οσιοι θελουσιν αγαλλεσθαι εν δοξη θελουσιν αγαλλεσθαι επι τας κλινας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.149.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 6,
      "referenceLabel": "Psalms 149:6",
      "text": "Αι εξυμνησεις του Θεου θελουσιν εισθαι εν τω λαρυγγι αυτων, και ρομφαια διστομος εν τη χειρι αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.149.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 7,
      "referenceLabel": "Psalms 149:7",
      "text": "δια να καμνωσιν εκδικησιν εις τα εθνη, παιδειαν εις τους λαους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.149.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 8,
      "referenceLabel": "Psalms 149:8",
      "text": "δια να δεσωσι τους βασιλεις αυτων με αλυσεις και τους ενδοξους αυτων με δεσμα σιδηρα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.149.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 9,
      "referenceLabel": "Psalms 149:9",
      "text": "δια να καμωσιν επ' αυτους την γεγραμμενην κρισιν. Η δοξα αυτη θελει εισθαι εις παντας τους οσιους αυτου. Αλληλουια.",
      "paragraphStart": false
    }
  ]
}
