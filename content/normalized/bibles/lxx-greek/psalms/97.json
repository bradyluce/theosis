{
  "chapter": {
    "id": "lxx-greek:psalms.97",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 97,
    "referenceLabel": "Psalms 97",
    "summary": "Source text for Psalms 97 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.97.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 1,
      "referenceLabel": "Psalms 97:1",
      "text": "Ψαλατε εις τον Κυριον ασμα νεον διοτι εκαμε θαυμασια η δεξια αυτου και ο βραχιων ο αγιος αυτου ενηργησαν εις αυτον σωτηριαν.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.97.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 2,
      "referenceLabel": "Psalms 97:2",
      "text": "Ο Κυριος εκαμε γνωστην την σωτηριαν αυτου εμπροσθεν των εθνων απεκαλυψε την δικαιοσυνην αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.97.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 3,
      "referenceLabel": "Psalms 97:3",
      "text": "Ενεθυμηθη το ελεος αυτου και την αληθειαν αυτου προς τον οικον του Ισραηλ παντα τα περατα της γης ειδον την σωτηριαν του Θεου ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.97.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 4,
      "referenceLabel": "Psalms 97:4",
      "text": "Αλαλαξατε εις τον Κυριον, πασα η γη ευφραινεσθε και αγαλλεσθε και ψαλμωδειτε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.97.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 5,
      "referenceLabel": "Psalms 97:5",
      "text": "Ψαλμωδειτε εις τον Κυριον εν κιθαρα εν κιθαρα και φωνη ψαλμωδιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.97.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 6,
      "referenceLabel": "Psalms 97:6",
      "text": "Μετα σαλπιγγων και εν φωνη κερατινης αλαλαξατε ενωπιον του Βασιλεως Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.97.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 7,
      "referenceLabel": "Psalms 97:7",
      "text": "Ας ηχη η θαλασσα και το πληρωμα αυτης η οικουμενη και οι κατοικουντες εν αυτη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.97.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 8,
      "referenceLabel": "Psalms 97:8",
      "text": "Οι ποταμοι ας κροτωσι χειρας, τα ορη ας αγαλλωνται ομου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.97.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 9,
      "referenceLabel": "Psalms 97:9",
      "text": "ενωπιον του Κυριου διοτι ερχεται δια να κρινη την γην θελει κρινει την οικουμενην εν δικαιοσυνη και τους λαους εν ευθυτητι.",
      "paragraphStart": false
    }
  ]
}
