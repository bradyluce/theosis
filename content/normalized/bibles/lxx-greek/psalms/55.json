{
  "chapter": {
    "id": "lxx-greek:psalms.55",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 55,
    "referenceLabel": "Psalms 55",
    "summary": "Source text for Psalms 55 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.55.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 1,
      "referenceLabel": "Psalms 55:1",
      "text": "\"Εις τον πρωτον μουσικον, επι Ιωναθ-ελεμ-ρεχοκιμ, Μικταμ του Δαβιδ, οποτε εκρατησαν αυτον οι Φιλισταιοι εν Γαθ.\" Ελεησον με, ω Θεε, διοτι ανθρωπος χασκει να με καταπιη ολην την ημεραν πολεμων με καταθλιβει.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.55.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 2,
      "referenceLabel": "Psalms 55:2",
      "text": "Οι εχθροι μου χασκουσιν ολην την ημεραν να με καταπιωσι διοτι πολλοι ειναι, Υψιστε, οι πολεμουντες με.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.55.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 3,
      "referenceLabel": "Psalms 55:3",
      "text": "Καθ' ην ημεραν φοβηθω, επι σε θελω ελπιζει",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.55.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 4,
      "referenceLabel": "Psalms 55:4",
      "text": "εν τω Θεω θελω αινεσει τον λογον αυτου επι τον Θεον ηλπισα δεν θελω φοβηθη τι να μοι καμη σαρξ;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.55.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 5,
      "referenceLabel": "Psalms 55:5",
      "text": "Καθ' εκαστην μεταπλαττουσι τα λογια μου παντες οι διαλογισμοι αυτων ειναι κατ' εμου εις κακον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.55.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 6,
      "referenceLabel": "Psalms 55:6",
      "text": "Συναγονται, κρυπτονται, παραφυλαττουσι τα βηματα μου, πως να πιασωσι την ψυχην μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.55.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 7,
      "referenceLabel": "Psalms 55:7",
      "text": "Θελουσι λυτρωθη δια της ανομιας; Θεε, εν τη οργη σου κατακρημνισον τους λαους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.55.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 8,
      "referenceLabel": "Psalms 55:8",
      "text": "Συ αριθμεις τας αποπλανησεις μου θες τα δακρυα μου εις την φιαλην σου δεν ειναι ταυτα εν τω βιβλιω σου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.55.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 9,
      "referenceLabel": "Psalms 55:9",
      "text": "Τοτε θελουσιν επιστρεψει οι εχθροι μου εις τα οπισω, καθ' ην ημεραν σε επικαλεσθω εξευρω τουτο, διοτι ο Θεος ειναι υπερ εμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.55.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 10,
      "referenceLabel": "Psalms 55:10",
      "text": "Εν τω Θεω θελω αινεσει τον λογον αυτου εν τω Κυριω θελω αινεσει τον λογον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.55.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 11,
      "referenceLabel": "Psalms 55:11",
      "text": "Επι τον Θεον ελπιζω δεν θελω φοβηθη τι να μοι καμη ανθρωπος;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.55.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 12,
      "referenceLabel": "Psalms 55:12",
      "text": "Επανω μου, Θεε, ειναι αι προς σε ευχαι μου θελω σοι αποδιδει δοξολογιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.55.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 13,
      "referenceLabel": "Psalms 55:13",
      "text": "Διοτι ελυτρωσας την ψυχην μου εκ θανατου, ουχι και τους ποδας μου εξ ολισθηματος, δια να περιπατω ενωπιον του Θεου εν τω φωτι των ζωντων;",
      "paragraphStart": false
    }
  ]
}
