{
  "chapter": {
    "id": "lxx-greek:psalms.103",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 103,
    "referenceLabel": "Psalms 103",
    "summary": "Source text for Psalms 103 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.103.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 1,
      "referenceLabel": "Psalms 103:1",
      "text": "Ευλογει, η ψυχη μου, τον Κυριον. Κυριε Θεε μου, εμεγαλυνθης σφοδρα τιμην και μεγαλοπρεπειαν εισαι ενδεδυμενος",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.103.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 2,
      "referenceLabel": "Psalms 103:2",
      "text": "ο περιτυλιττομενος το φως ως ιματιον, ο εκτεινων τον ουρανον ως καταπετασμα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 3,
      "referenceLabel": "Psalms 103:3",
      "text": "ο στεγαζων με υδατα τα υπερωα αυτου ο ποιων τα νεφη αμαξαν αυτου ο περιπατων επι πτερυγων ανεμων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 4,
      "referenceLabel": "Psalms 103:4",
      "text": "ο ποιων τους αγγελους αυτου πνευματα, τους λειτουργους αυτου πυρος φλογα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 5,
      "referenceLabel": "Psalms 103:5",
      "text": "ο θεμελιων την γην επι την βασιν αυτης, δια να μη σαλευθη εις τον αιωνα του αιωνος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 6,
      "referenceLabel": "Psalms 103:6",
      "text": "Με την αβυσσον, ως με ιματιον, εκαλυψας αυτην τα υδατα εσταθησαν επι των ορεων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 7,
      "referenceLabel": "Psalms 103:7",
      "text": "απο επιτιμησεως σου εφυγον απο της φωνης της βροντης σου εσυρθησαν εν βια",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 8,
      "referenceLabel": "Psalms 103:8",
      "text": "ανεβησαν εις τα ορη, κατεβησαν εις τας κοιλαδας, εις τοπον, τον οποιον διωρισας δι' αυτα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 9,
      "referenceLabel": "Psalms 103:9",
      "text": "εθεσας οριον, το οποιον δεν θελουσιν υπερβη ουδε θελουσιν επιστρεψει δια να σκεπασωσι την γην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 10,
      "referenceLabel": "Psalms 103:10",
      "text": "Ο εξαποστελλων πηγας εις τας φαραγγας, δια να ρεωσιν αναμεσον των ορεων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 11,
      "referenceLabel": "Psalms 103:11",
      "text": "ποτιζουσι παντα τα θηρια του αγρου οι αγριοι ονοι σβυνουσι την διψαν αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 12,
      "referenceLabel": "Psalms 103:12",
      "text": "πλησιον αυτων τα πετεινα του ουρανου κατασκηνουσι, και αναμεσον των κλαδων κελαδουσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 13,
      "referenceLabel": "Psalms 103:13",
      "text": "Ο ποτιζων τα ορη εκ των υπερωων αυτου απο του καρπου των εργων σου χορταινει η γη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 14,
      "referenceLabel": "Psalms 103:14",
      "text": "Ο αναδιδων χορτον δια τα κτηνη και βοτανην προς χρησιν του ανθρωπου, δια να εξαγη τροφην εκ της γης,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 15,
      "referenceLabel": "Psalms 103:15",
      "text": "και οινον ευφραινοντα την καρδιαν του ανθρωπου, ελαιον δια να λαμπρυνη το προσωπον αυτου, και αρτον στηριζοντα την καρδιαν του ανθρωπου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 16,
      "referenceLabel": "Psalms 103:16",
      "text": "Εχορτασθησαν τα δενδρα του Κυριου αι κεδροι του Λιβανου, τας οποιας εφυτευσεν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 17,
      "referenceLabel": "Psalms 103:17",
      "text": "Οπου τα πετεινα καμνουσι φωλεας αι πευκαι ειναι η κατοικια του πελαργου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 18,
      "referenceLabel": "Psalms 103:18",
      "text": "Τα ορη τα υψηλα ειναι δια τας δορκαδας αι πετραι καταφυγη εις τους δασυποδας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 19,
      "referenceLabel": "Psalms 103:19",
      "text": "Εκαμε την σεληνην δια τους καιρους ο ηλιος γνωριζει την δυσιν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 20,
      "referenceLabel": "Psalms 103:20",
      "text": "Φερεις σκοτος, και γινεται νυξ εν αυτη περιφερονται παντα τα θηρια του δασους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 21,
      "referenceLabel": "Psalms 103:21",
      "text": "οι σκυμνοι βρυχωνται δια να αρπασωσι, και να ζητησωσι παρα του Θεου την τροφην αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 22,
      "referenceLabel": "Psalms 103:22",
      "text": "Ο ηλιος ανατελλει συναγονται και πλαγιαζουσιν εν τοις σπηλαιοις αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 23,
      "referenceLabel": "Psalms 103:23",
      "text": "εξερχεται ο ανθρωπος εις το εργον αυτου και εις την εργασιαν αυτου εως εσπερας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 24,
      "referenceLabel": "Psalms 103:24",
      "text": "Ποσον μεγαλα ειναι τα εργα σου, Κυριε τα παντα εν σοφια εποιησας η γη ειναι πληρης των ποιηματων σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.25",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 25,
      "referenceLabel": "Psalms 103:25",
      "text": "αυτη η θαλασσα η μεγαλη και ευρυχωρος. Εκει ειναι ερπετα αναριθμητα, ζωα μικρα μετα μεγαλων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.26",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 26,
      "referenceLabel": "Psalms 103:26",
      "text": "εκει διατρεχουσι τα πλοια εκει ο Λευιαθαν ουτος, τον οποιον επλασας δια να παιζη εν αυτη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.27",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 27,
      "referenceLabel": "Psalms 103:27",
      "text": "Παντα ταυτα επι σε ελπιζουσι, δια να δωσης εν καιρω την τροφην αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.28",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 28,
      "referenceLabel": "Psalms 103:28",
      "text": "Διδεις εις αυτα, συναγουσιν ανοιγεις την χειρα σου, χορταινουσιν αγαθα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.29",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 29,
      "referenceLabel": "Psalms 103:29",
      "text": "Αποστρεφεις το προσωπον σου, ταραττονται σηκονεις την πνοην αυτων, αποθνησκουσι και εις το χωμα αυτων επιστρεφουσιν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.30",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 30,
      "referenceLabel": "Psalms 103:30",
      "text": "εξαποστελλεις το πνευμα σου, κτιζονται, και ανανεονεις το προσωπον της γης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.31",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 31,
      "referenceLabel": "Psalms 103:31",
      "text": "Η δοξα του Κυριου εστω εις τον αιωνα ας ευφραινεται ο Κυριος εις τα εργα αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.32",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 32,
      "referenceLabel": "Psalms 103:32",
      "text": "ο επιβλεπων επι την γην και καμνων αυτην να τρεμη εγγιζει τα ορη, και καπνιζουσι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.33",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 33,
      "referenceLabel": "Psalms 103:33",
      "text": "Θελω ψαλλει εις τον Κυριον ενοσω ζω θελω ψαλμωδει εις τον Θεον μου ενοσω υπαρχω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.34",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 34,
      "referenceLabel": "Psalms 103:34",
      "text": "Η εις αυτον μελετη μου θελει εισθαι γλυκεια εγω θελω ευφραινεσθαι εις τον Κυριον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.35",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 35,
      "referenceLabel": "Psalms 103:35",
      "text": "Ας εκλειψωσιν οι αμαρτωλοι απο της γης και οι ασεβεις ας μη υπαρχωσι πλεον. Ευλογει, η ψυχη μου, τον Κυριον. Αλληλουια.",
      "paragraphStart": false
    }
  ]
}
