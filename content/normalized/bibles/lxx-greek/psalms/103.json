{
  "chapter": {
    "id": "lxx-greek:psalms.103",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 103,
    "referenceLabel": "Psalms 103",
    "summary": "Source text for Psalms 103 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.103.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 1,
      "referenceLabel": "Psalms 103:1",
      "text": "\"Ψαλμος του Δαβιδ.\" Ευλογει, η ψυχη μου, τον Κυριον και παντα τα εντος μου το ονομα το αγιον αυτου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.103.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 2,
      "referenceLabel": "Psalms 103:2",
      "text": "Ευλογει, η ψυχη μου, τον Κυριον, και μη λησμονης πασας τας ευεργεσιας αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 3,
      "referenceLabel": "Psalms 103:3",
      "text": "τον συγχωρουντα πασας τας ανομιας σου τον ιατρευοντα πασας τας αρρωστιας σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 4,
      "referenceLabel": "Psalms 103:4",
      "text": "τον λυτρονοντα εκ της φθορας την ζωην σου τον στεφανουντα σε με ελεος και οικτιρμους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 5,
      "referenceLabel": "Psalms 103:5",
      "text": "τον χορταζοντα εν αγαθοις το γηρας σου η νεοτης σου ανανεουται ως του αετου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 6,
      "referenceLabel": "Psalms 103:6",
      "text": "Ο Κυριος καμνει δικαιοσυνην και κρισιν εις παντας τους αδικουμενους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 7,
      "referenceLabel": "Psalms 103:7",
      "text": "Εφανερωσε τας οδους αυτου εις τον Μωυσην, τα εργα αυτου εις τους υιους Ισραηλ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 8,
      "referenceLabel": "Psalms 103:8",
      "text": "Οικτιρμων και ελεημων ειναι ο Κυριος, μακροθυμος και πολυελεος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 9,
      "referenceLabel": "Psalms 103:9",
      "text": "Δεν θελει δικολογει διαπαντος ουδε θελει φυλαττει την οργην αυτου εις τον αιωνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 10,
      "referenceLabel": "Psalms 103:10",
      "text": "Δεν εκαμεν εις ημας κατα τας αμαρτιας ημων, ουδε ανταπεδωκεν εις ημας κατα τας ανομιας ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 11,
      "referenceLabel": "Psalms 103:11",
      "text": "Διοτι οσον ειναι το υψος του ουρανου υπερανω της γης, τοσον μεγα ειναι το ελεος αυτου προς τους φοβουμενους αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 12,
      "referenceLabel": "Psalms 103:12",
      "text": "Οσον απεχει η ανατολη απο της δυσεως, τοσον εμακρυνεν αφ' ημων τας ανομιας ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 13,
      "referenceLabel": "Psalms 103:13",
      "text": "Καθως σπλαγχνιζεται ο πατηρ τα τεκνα, ουτως ο Κυριος σπλαγχνιζεται τους φοβουμενους αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 14,
      "referenceLabel": "Psalms 103:14",
      "text": "Διοτι αυτος γνωριζει την πλασιν ημων, ενθυμειται οτι ειμεθα χωμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 15,
      "referenceLabel": "Psalms 103:15",
      "text": "Του ανθρωπου αι ημεραι ειναι ως χορτος ως το ανθος του αγρου, ουτως ανθει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 16,
      "referenceLabel": "Psalms 103:16",
      "text": "Διοτι διερχεται ο ανεμος επ' αυτου, και δεν υπαρχει πλεον και ο τοπος αυτου δεν γνωριζει αυτο πλεον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 17,
      "referenceLabel": "Psalms 103:17",
      "text": "Το δε ελεος του Κυριου ειναι απο του αιωνος και εως του αιωνος επι τους φοβουμενους αυτον και η δικαιοσυνη αυτου επι τους υιους των υιων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 18,
      "referenceLabel": "Psalms 103:18",
      "text": "επι τους φυλαττοντας την διαθηκην αυτου και ενθυμουμενους τας εντολας αυτου δια να εκπληρωσιν αυτας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 19,
      "referenceLabel": "Psalms 103:19",
      "text": "Ο Κυριος ητοιμασε τον θρονον αυτου εν τω ουρανω, και η βασιλεια αυτου δεσποζει τα παντα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 20,
      "referenceLabel": "Psalms 103:20",
      "text": "Ευλογειτε τον Κυριον, αγγελοι αυτου, δυνατοι εν ισχυι, οι εκτελουντες τον λογον αυτου, οι ακουοντες της φωνης του λογου αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 21,
      "referenceLabel": "Psalms 103:21",
      "text": "Ευλογειτε τον Κυριον, πασαι αι δυναμεις αυτου λειτουργοι αυτου, οι εκτελουντες το θελημα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.103.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 22,
      "referenceLabel": "Psalms 103:22",
      "text": "Ευλογειτε τον Κυριον, παντα τα εργα αυτου εν παντι τοπω της δεσποτειας αυτου. Ευλογει, η ψυχη μου, τον Κυριον.",
      "paragraphStart": false
    }
  ]
}
