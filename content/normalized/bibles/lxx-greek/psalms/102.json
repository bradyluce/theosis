{
  "chapter": {
    "id": "lxx-greek:psalms.102",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 102,
    "referenceLabel": "Psalms 102",
    "summary": "Source text for Psalms 102 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.102.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 1,
      "referenceLabel": "Psalms 102:1",
      "text": "\"Ψαλμος του Δαβιδ.\" Ευλογει, η ψυχη μου, τον Κυριον και παντα τα εντος μου το ονομα το αγιον αυτου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.102.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 2,
      "referenceLabel": "Psalms 102:2",
      "text": "Ευλογει, η ψυχη μου, τον Κυριον, και μη λησμονης πασας τας ευεργεσιας αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 3,
      "referenceLabel": "Psalms 102:3",
      "text": "τον συγχωρουντα πασας τας ανομιας σου τον ιατρευοντα πασας τας αρρωστιας σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 4,
      "referenceLabel": "Psalms 102:4",
      "text": "τον λυτρονοντα εκ της φθορας την ζωην σου τον στεφανουντα σε με ελεος και οικτιρμους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 5,
      "referenceLabel": "Psalms 102:5",
      "text": "τον χορταζοντα εν αγαθοις το γηρας σου η νεοτης σου ανανεουται ως του αετου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 6,
      "referenceLabel": "Psalms 102:6",
      "text": "Ο Κυριος καμνει δικαιοσυνην και κρισιν εις παντας τους αδικουμενους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 7,
      "referenceLabel": "Psalms 102:7",
      "text": "Εφανερωσε τας οδους αυτου εις τον Μωυσην, τα εργα αυτου εις τους υιους Ισραηλ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 8,
      "referenceLabel": "Psalms 102:8",
      "text": "Οικτιρμων και ελεημων ειναι ο Κυριος, μακροθυμος και πολυελεος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 9,
      "referenceLabel": "Psalms 102:9",
      "text": "Δεν θελει δικολογει διαπαντος ουδε θελει φυλαττει την οργην αυτου εις τον αιωνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 10,
      "referenceLabel": "Psalms 102:10",
      "text": "Δεν εκαμεν εις ημας κατα τας αμαρτιας ημων, ουδε ανταπεδωκεν εις ημας κατα τας ανομιας ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 11,
      "referenceLabel": "Psalms 102:11",
      "text": "Διοτι οσον ειναι το υψος του ουρανου υπερανω της γης, τοσον μεγα ειναι το ελεος αυτου προς τους φοβουμενους αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 12,
      "referenceLabel": "Psalms 102:12",
      "text": "Οσον απεχει η ανατολη απο της δυσεως, τοσον εμακρυνεν αφ' ημων τας ανομιας ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 13,
      "referenceLabel": "Psalms 102:13",
      "text": "Καθως σπλαγχνιζεται ο πατηρ τα τεκνα, ουτως ο Κυριος σπλαγχνιζεται τους φοβουμενους αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 14,
      "referenceLabel": "Psalms 102:14",
      "text": "Διοτι αυτος γνωριζει την πλασιν ημων, ενθυμειται οτι ειμεθα χωμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 15,
      "referenceLabel": "Psalms 102:15",
      "text": "Του ανθρωπου αι ημεραι ειναι ως χορτος ως το ανθος του αγρου, ουτως ανθει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 16,
      "referenceLabel": "Psalms 102:16",
      "text": "Διοτι διερχεται ο ανεμος επ' αυτου, και δεν υπαρχει πλεον και ο τοπος αυτου δεν γνωριζει αυτο πλεον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 17,
      "referenceLabel": "Psalms 102:17",
      "text": "Το δε ελεος του Κυριου ειναι απο του αιωνος και εως του αιωνος επι τους φοβουμενους αυτον και η δικαιοσυνη αυτου επι τους υιους των υιων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 18,
      "referenceLabel": "Psalms 102:18",
      "text": "επι τους φυλαττοντας την διαθηκην αυτου και ενθυμουμενους τας εντολας αυτου δια να εκπληρωσιν αυτας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 19,
      "referenceLabel": "Psalms 102:19",
      "text": "Ο Κυριος ητοιμασε τον θρονον αυτου εν τω ουρανω, και η βασιλεια αυτου δεσποζει τα παντα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 20,
      "referenceLabel": "Psalms 102:20",
      "text": "Ευλογειτε τον Κυριον, αγγελοι αυτου, δυνατοι εν ισχυι, οι εκτελουντες τον λογον αυτου, οι ακουοντες της φωνης του λογου αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 21,
      "referenceLabel": "Psalms 102:21",
      "text": "Ευλογειτε τον Κυριον, πασαι αι δυναμεις αυτου λειτουργοι αυτου, οι εκτελουντες το θελημα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.102.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 22,
      "referenceLabel": "Psalms 102:22",
      "text": "Ευλογειτε τον Κυριον, παντα τα εργα αυτου εν παντι τοπω της δεσποτειας αυτου. Ευλογει, η ψυχη μου, τον Κυριον.",
      "paragraphStart": false
    }
  ]
}
