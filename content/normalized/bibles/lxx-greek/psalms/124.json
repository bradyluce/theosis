{
  "chapter": {
    "id": "lxx-greek:psalms.124",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 124,
    "referenceLabel": "Psalms 124",
    "summary": "Source text for Psalms 124 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.124.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 1,
      "referenceLabel": "Psalms 124:1",
      "text": "\"Ωιδη των Αναβαθμων, του Δαβιδ.\" Αν δεν ητο ο Κυριος μεθ' ημων, ας ειπη τωρα ο Ισραηλ",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.124.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 2,
      "referenceLabel": "Psalms 124:2",
      "text": "αν δεν ητο ο Κυριος μεθ' ημων, οτε εσηκωθησαν ανθρωποι εφ' ημας,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.124.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 3,
      "referenceLabel": "Psalms 124:3",
      "text": "ζωντας ηθελον μας καταπιει τοτε, ενω ο θυμος αυτων εφλεγετο εναντιον ημων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.124.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 4,
      "referenceLabel": "Psalms 124:4",
      "text": "Τοτε τα υδατα ηθελον μας καταποντισει, ο χειμαρρος ηθελε περασει επανωθεν της ψυχης ημων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.124.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 5,
      "referenceLabel": "Psalms 124:5",
      "text": "τοτε τα υδατα τα επηρμενα ηθελον περασει επανωθεν της ψυχης ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.124.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 6,
      "referenceLabel": "Psalms 124:6",
      "text": "Ευλογητος Κυριος, οστις δεν παρεδωκεν ημας θηραμα εις τους οδοντας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.124.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 7,
      "referenceLabel": "Psalms 124:7",
      "text": "Η ψυχη ημων ελυτρωθη ως πτηνον απο της παγιδος των θηρευτων η παγις συνετριβη, και ημεις ελυτρωθημεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.124.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 8,
      "referenceLabel": "Psalms 124:8",
      "text": "Η βοηθεια ημων ειναι εν τω ονοματι του Κυριου, του ποιησαντος τον ουρανον και την γην.",
      "paragraphStart": false
    }
  ]
}
