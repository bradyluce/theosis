{
  "chapter": {
    "id": "lxx-greek:psalms.114",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 114,
    "referenceLabel": "Psalms 114",
    "summary": "Source text for Psalms 114 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.114.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 1,
      "referenceLabel": "Psalms 114:1",
      "text": "Χαιρω οτι ο Κυριος εισηκουσε της φωνης μου, των δεησεων μου",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.114.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 2,
      "referenceLabel": "Psalms 114:2",
      "text": "οτι εκλινε το ωτιον αυτου προς εμε και ενοσω ζω, θελω επικαλεισθαι αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.114.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 3,
      "referenceLabel": "Psalms 114:3",
      "text": "Πονοι θανατου με περιεκυκλωσαν, και στενοχωριαι του αδου με ευρηκαν θλιψιν και πονον απηντησα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.114.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 4,
      "referenceLabel": "Psalms 114:4",
      "text": "Και επεκαλεσθην το ονομα του Κυριου ω Κυριε, λυτρωσον την ψυχην μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.114.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 5,
      "referenceLabel": "Psalms 114:5",
      "text": "Ελεημων ο Κυριος και δικαιος και ευσπλαγχνος ο Θεος ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.114.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 6,
      "referenceLabel": "Psalms 114:6",
      "text": "Ο Κυριος φυλαττει τους απλους εταλαιπωρηθην, και με εσωσεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.114.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 7,
      "referenceLabel": "Psalms 114:7",
      "text": "Επιστρεψον, ψυχη μου, εις την αναπαυσιν σου, διοτι ο Κυριος σε ευηργετησε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.114.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 8,
      "referenceLabel": "Psalms 114:8",
      "text": "Διοτι ελυτρωσας την ψυχην μου εκ θανατου, τους οφθαλμους μου απο δακρυων, τους ποδας μου απο ολισθηματος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.114.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 9,
      "referenceLabel": "Psalms 114:9",
      "text": "Θελω περιπατει ενωπιον του Κυριου εν γη ζωντων.",
      "paragraphStart": false
    }
  ]
}
