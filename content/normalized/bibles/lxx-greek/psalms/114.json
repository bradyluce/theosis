{
  "chapter": {
    "id": "lxx-greek:psalms.114",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 114,
    "referenceLabel": "Psalms 114",
    "summary": "Source text for Psalms 114 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.114.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 1,
      "referenceLabel": "Psalms 114:1",
      "text": "Οτε εξηλθεν ο Ισραηλ εξ Αιγυπτου, ο οικος του Ιακωβ εκ λαου βαρβαρου,",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.114.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 2,
      "referenceLabel": "Psalms 114:2",
      "text": "Ο Ιουδας εγεινεν αγιος αυτου, ο Ισραηλ δεσποτεια αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.114.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 3,
      "referenceLabel": "Psalms 114:3",
      "text": "Η θαλασσα ειδε και εφυγεν ο Ιορδανης εστραφη εις τα οπισω",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.114.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 4,
      "referenceLabel": "Psalms 114:4",
      "text": "τα ορη εσκιρτησαν ως κριοι, οι λοφοι ως αρνια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.114.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 5,
      "referenceLabel": "Psalms 114:5",
      "text": "Τι σοι συνεβη, θαλασσα, οτι εφυγες; και συ, Ιορδανη, οτι εστραφης εις τα οπισω;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.114.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 6,
      "referenceLabel": "Psalms 114:6",
      "text": "τα ορη, οτι εσκιρτησατε ως κριοι; και οι λοφοι, ως αρνια;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.114.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 7,
      "referenceLabel": "Psalms 114:7",
      "text": "Τρεμε, γη, απο προσωπου του Κυριου, απο προσωπου του Θεου του Ιακωβ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.114.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 8,
      "referenceLabel": "Psalms 114:8",
      "text": "οστις μετεβαλε την πετραν εις λιμνας υδατων, τον σκληρον βραχον εις πηγας υδατων.",
      "paragraphStart": false
    }
  ]
}
