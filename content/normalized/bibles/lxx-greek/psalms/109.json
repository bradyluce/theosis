{
  "chapter": {
    "id": "lxx-greek:psalms.109",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 109,
    "referenceLabel": "Psalms 109",
    "summary": "Source text for Psalms 109 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.109.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 1,
      "referenceLabel": "Psalms 109:1",
      "text": "\"Εις τον πρωτον μουσικον. Ψαλμος του Δαβιδ.\" Θεε της αινεσεως μου, μη σιωπησης",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.109.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 2,
      "referenceLabel": "Psalms 109:2",
      "text": "διοτι στομα ασεβους και στομα δολιου ηνοιχθησαν επ' εμε ελαλησαν κατ' εμου με γλωσσαν ψευδη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 3,
      "referenceLabel": "Psalms 109:3",
      "text": "και με λογους μισους με περιεκυκλωσαν και με επολεμησαν αναιτιως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 4,
      "referenceLabel": "Psalms 109:4",
      "text": "Αντι της αγαπης μου ειναι αντιδικοι εις εμε εγω δε προσευχομαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 5,
      "referenceLabel": "Psalms 109:5",
      "text": "Και ανταπεδωκαν εις εμε κακον αντι καλου, και μισος αντι της αγαπης μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 6,
      "referenceLabel": "Psalms 109:6",
      "text": "Καταστησον ασεβη επ' αυτον και διαβολος ας στεκη εκ δεξιων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 7,
      "referenceLabel": "Psalms 109:7",
      "text": "Οταν κρινηται, ας εξελθη καταδεδικασμενος και η προσευχη αυτου ας γεινη εις αμαρτιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 8,
      "referenceLabel": "Psalms 109:8",
      "text": "Ας γεινωσιν αι ημεραι αυτου ολιγαι αλλος ας λαβη την επισκοπην αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 9,
      "referenceLabel": "Psalms 109:9",
      "text": "Ας γεινωσιν οι υιοι αυτου ορφανοι και η γυνη αυτου χηρα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 10,
      "referenceLabel": "Psalms 109:10",
      "text": "Και ας περιπλανωνται παντοτε οι υιοι αυτου και ας γεινωσιν επαιται, και ας ζητωσιν εκ των ερειπιων αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 11,
      "referenceLabel": "Psalms 109:11",
      "text": "Ας παγιδευση ο δανειστης παντα τα υπαρχοντα αυτου και ας διαρπασωσιν οι ξενοι τους κοπους αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 12,
      "referenceLabel": "Psalms 109:12",
      "text": "Ας μη υπαρχη ο ελεων αυτον, και ας μη ηναι ο οικτειρων τα ορφανα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 13,
      "referenceLabel": "Psalms 109:13",
      "text": "Ας εξολοθρευθωσιν οι εκγονοι αυτου εν τη επερχομενη γενεα ας εξαλειφθη το ονομα αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 14,
      "referenceLabel": "Psalms 109:14",
      "text": "Ας ελθη εις ενθυμησιν ενωπιον του Κυριου η ανομια των πατερων αυτου και η αμαρτια της μητρος αυτου ας μη εξαλειφθη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 15,
      "referenceLabel": "Psalms 109:15",
      "text": "Ας ηναι παντοτε ενωπιον του Κυριου, δια να εκκοψη απο της γης το μνημοσυνον αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 16,
      "referenceLabel": "Psalms 109:16",
      "text": "Διοτι δεν ενεθυμηθη να καμη ελεος αλλα κατετρεξεν ανθρωπον πενητα και πτωχον, δια να θανατωση τον συντετριμμενον την καρδιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 17,
      "referenceLabel": "Psalms 109:17",
      "text": "Επειδη ηγαπησε καταραν, ας ελθη επ' αυτον επειδη δεν ηθελησεν ευλογιαν, ας απομακρυνθη απ' αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 18,
      "referenceLabel": "Psalms 109:18",
      "text": "Επειδη ενεδυθη καταραν ως ιματιον αυτου, ας εισελθη ως υδωρ εις τα εντοσθια αυτου και ως ελαιον εις τα οστα αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 19,
      "referenceLabel": "Psalms 109:19",
      "text": "Ας γεινη εις αυτον ως το ιματιον, το οποιον ενδυεται και ως η ζωνη, την οποιαν παντοτε περιζωννυται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 20,
      "referenceLabel": "Psalms 109:20",
      "text": "Αυτη ας ηναι των αντιδικων μου η αμοιβη παρα του Κυριου, και των λαλουντων κακα κατα της ψυχης μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 21,
      "referenceLabel": "Psalms 109:21",
      "text": "Αλλα συ, Κυριε Θεε, ενεργησον μετ' εμου δια το ονομα σου επειδη ειναι αγαθον το ελεος σου, λυτρωσον με.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 22,
      "referenceLabel": "Psalms 109:22",
      "text": "Διοτι πτωχος και πενης ειμαι, και η καρδια μου ειναι πεπληγωμενη εντος μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 23,
      "referenceLabel": "Psalms 109:23",
      "text": "Παρηλθον ως σκια, οταν εκκλινη εκτιναζομαι ως η ακρις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 24,
      "referenceLabel": "Psalms 109:24",
      "text": "Τα γονατα μου ητονησαν απο της νηστειας και η σαρξ μου εξεπεσεν απο του παχους αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.25",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 25,
      "referenceLabel": "Psalms 109:25",
      "text": "Και εγω εγεινα ονειδος εις αυτους οτε με ειδον, εκινησαν τας κεφαλας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.26",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 26,
      "referenceLabel": "Psalms 109:26",
      "text": "Βοηθησον μοι, Κυριε ο Θεος μου σωσον με κατα το ελεος σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.27",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 27,
      "referenceLabel": "Psalms 109:27",
      "text": "και ας γνωρισωσιν οτι η χειρ σου ειναι τουτο οτι συ, Κυριε, εκαμες αυτο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.28",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 28,
      "referenceLabel": "Psalms 109:28",
      "text": "Αυτοι θελουσι καταρασθαι, συ δε θελεις ευλογει θελουσι σηκωθη, πλην θελουσι καταισχυνθη ο δε δουλος σου θελει ευφραινεσθαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.29",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 29,
      "referenceLabel": "Psalms 109:29",
      "text": "Ας ενδυθωσιν εντροπην οι αντιδικοι μου και ας φορεσωσιν ως επενδυμα την αισχυνην αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.30",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 30,
      "referenceLabel": "Psalms 109:30",
      "text": "Θελω δοξολογει σφοδρα τον Κυριον δια του στοματος μου, και εν μεσω πολλων θελω υμνολογει αυτον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.109.31",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 31,
      "referenceLabel": "Psalms 109:31",
      "text": "Διοτι ισταται εν τη δεξια του πτωχου, δια να λυτρονη αυτον εκ των καταδικαζοντων την ψυχην αυτου.",
      "paragraphStart": false
    }
  ]
}
