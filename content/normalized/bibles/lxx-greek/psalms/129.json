{
  "chapter": {
    "id": "lxx-greek:psalms.129",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 129,
    "referenceLabel": "Psalms 129",
    "summary": "Source text for Psalms 129 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.129.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 1,
      "referenceLabel": "Psalms 129:1",
      "text": "\"Ωιδη των Αναβαθμων.\" Πολλακις με επολεμησαν εκ νεοτητος μου, ας ειπη τωρα ο Ισραηλ",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.129.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 2,
      "referenceLabel": "Psalms 129:2",
      "text": "Πολλακις με επολεμησαν εκ νεοτητος μου αλλα δεν υπερισχυσαν εναντιον μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.129.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 3,
      "referenceLabel": "Psalms 129:3",
      "text": "Οι γεωργοι ηροτριασαν επι των νωτων μου εσυραν μακρα τα αυλακια αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.129.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 4,
      "referenceLabel": "Psalms 129:4",
      "text": "Αλλα δικαιος ο Κυριος κατεκοψε τα σχοινια των ασεβων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.129.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 5,
      "referenceLabel": "Psalms 129:5",
      "text": "Ας αισχυνθωσι και ας στραφωσιν εις τα οπισω παντες οι μισουντες την Σιων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.129.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 6,
      "referenceLabel": "Psalms 129:6",
      "text": "Ας γεινωσιν ως ο χορτος των δωματων, οστις πριν εκριζωθη ξηραινεται",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.129.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 7,
      "referenceLabel": "Psalms 129:7",
      "text": "απο του οποιου δεν γεμιζει ο θεριστης την χειρα αυτου, ουδε ο δενων τα χειροβολα τον κολπον αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.129.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 8,
      "referenceLabel": "Psalms 129:8",
      "text": "ωστε οι διαβαται δεν θελουσιν ειπει, Ευλογια Κυριου εφ' υμας σας ευλογουμεν εν ονοματι Κυριου.",
      "paragraphStart": false
    }
  ]
}
