{
  "chapter": {
    "id": "lxx-greek:psalms.129",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 129,
    "referenceLabel": "Psalms 129",
    "summary": "Source text for Psalms 129 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.129.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 1,
      "referenceLabel": "Psalms 129:1",
      "text": "\"Ωιδη των Αναβαθμων.\" Εκ βαθεων εκραξα προς σε, Κυριε.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.129.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 2,
      "referenceLabel": "Psalms 129:2",
      "text": "Κυριε, εισακουσον της φωνης μου ας ηναι τα ωτα σου προσεκτικα εις την φωνην των δεησεων μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.129.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 3,
      "referenceLabel": "Psalms 129:3",
      "text": "Εαν, Κυριε, παρατηρησης ανομιας, Κυριε, τις θελει δυνηθη να σταθη;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.129.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 4,
      "referenceLabel": "Psalms 129:4",
      "text": "Παρα σοι ομως ειναι συγχωρησις, δια να σε φοβωνται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.129.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 5,
      "referenceLabel": "Psalms 129:5",
      "text": "Προσεμεινα τον Κυριον, προσεμεινεν η ψυχη μου, και ηλπισα επι τον λογον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.129.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 6,
      "referenceLabel": "Psalms 129:6",
      "text": "Η ψυχη μου προσμενει τον Κυριον, μαλλον παρα τους προσμενοντας την αυγην, ναι, τους προσμενοντας την αυγην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.129.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 7,
      "referenceLabel": "Psalms 129:7",
      "text": "Ας ελπιζη ο Ισραηλ επι τον Κυριον διοτι παρα τω Κυριω ειναι ελεος, και λυτρωσις πολλη παρ' αυτω",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.129.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 8,
      "referenceLabel": "Psalms 129:8",
      "text": "και αυτος θελει λυτρωσει τον Ισραηλ απο πασων των ανομιων αυτου.",
      "paragraphStart": false
    }
  ]
}
