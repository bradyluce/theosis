{
  "chapter": {
    "id": "lxx-greek:psalms.128",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 128,
    "referenceLabel": "Psalms 128",
    "summary": "Source text for Psalms 128 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.128.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 1,
      "referenceLabel": "Psalms 128:1",
      "text": "\"Ωιδη των Αναβαθμων.\" Πολλακις με επολεμησαν εκ νεοτητος μου, ας ειπη τωρα ο Ισραηλ",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.128.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 2,
      "referenceLabel": "Psalms 128:2",
      "text": "Πολλακις με επολεμησαν εκ νεοτητος μου αλλα δεν υπερισχυσαν εναντιον μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.128.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 3,
      "referenceLabel": "Psalms 128:3",
      "text": "Οι γεωργοι ηροτριασαν επι των νωτων μου εσυραν μακρα τα αυλακια αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.128.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 4,
      "referenceLabel": "Psalms 128:4",
      "text": "Αλλα δικαιος ο Κυριος κατεκοψε τα σχοινια των ασεβων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.128.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 5,
      "referenceLabel": "Psalms 128:5",
      "text": "Ας αισχυνθωσι και ας στραφωσιν εις τα οπισω παντες οι μισουντες την Σιων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.128.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 6,
      "referenceLabel": "Psalms 128:6",
      "text": "Ας γεινωσιν ως ο χορτος των δωματων, οστις πριν εκριζωθη ξηραινεται",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.128.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 7,
      "referenceLabel": "Psalms 128:7",
      "text": "απο του οποιου δεν γεμιζει ο θεριστης την χειρα αυτου, ουδε ο δενων τα χειροβολα τον κολπον αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.128.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 8,
      "referenceLabel": "Psalms 128:8",
      "text": "ωστε οι διαβαται δεν θελουσιν ειπει, Ευλογια Κυριου εφ' υμας σας ευλογουμεν εν ονοματι Κυριου.",
      "paragraphStart": false
    }
  ]
}
