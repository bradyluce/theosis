{
  "chapter": {
    "id": "lxx-greek:psalms.128",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 128,
    "referenceLabel": "Psalms 128",
    "summary": "Source text for Psalms 128 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.128.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 1,
      "referenceLabel": "Psalms 128:1",
      "text": "\"Ωιδη των Αναβαθμων.\" Μακαριος πας ο φοβουμενος τον Κυριον, ο περιπατων εν ταις οδοις αυτου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.128.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 2,
      "referenceLabel": "Psalms 128:2",
      "text": "Διοτι θελεις τρωγει απο του κοπου των χειρων σου μακαριος θελεις εισθαι, και ευτυχια εις σε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.128.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 3,
      "referenceLabel": "Psalms 128:3",
      "text": "Η γυνη σου θελει εισθαι ως αμπελος ευκαρπος εις τα πλαγια της οικιας σου οι υιοι σου ως νεοφυτα ελαιων κυκλω της τραπεζης σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.128.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 4,
      "referenceLabel": "Psalms 128:4",
      "text": "Ιδου, ουτω θελει ευλογηθη ο ανθρωπος ο φοβουμενος τον Κυριον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.128.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 5,
      "referenceLabel": "Psalms 128:5",
      "text": "Ο Κυριος θελει σε ευλογησει εκ της Σιων, και θελεις ιδει το καλον της Ιερουσαλημ πασας τας ημερας της ζωης σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.128.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 6,
      "referenceLabel": "Psalms 128:6",
      "text": "και θελεις ιδει υιους των υιων σου ειρηνη επι τον Ισραηλ.",
      "paragraphStart": false
    }
  ]
}
