{
  "chapter": {
    "id": "lxx-greek:psalms.85",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 85,
    "referenceLabel": "Psalms 85",
    "summary": "Source text for Psalms 85 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.85.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 1,
      "referenceLabel": "Psalms 85:1",
      "text": "\"Προσευχη του Δαβιδ.\" Κλινον, Κυριε, το ωτιον σου επακουσον μου, διοτι πτωχος και πενης ειμαι εγω.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.85.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 2,
      "referenceLabel": "Psalms 85:2",
      "text": "Φυλαξον την ψυχην μου, διοτι ειμαι οσιος συ, Θεε μου, σωσον τον δουλον σου τον ελπιζοντα επι σε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.85.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 3,
      "referenceLabel": "Psalms 85:3",
      "text": "Ελεησον με, Κυριε, διοτι προς σε κραζω ολην την ημεραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.85.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 4,
      "referenceLabel": "Psalms 85:4",
      "text": "Ευφρανον την ψυχην του δουλου σου, διοτι προς σε, Κυριε, υψονω την ψυχην μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.85.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 5,
      "referenceLabel": "Psalms 85:5",
      "text": "Διοτι συ, Κυριε, εισαι αγαθος και ευσπλαγχνος και πολυελεος εις παντας τους επικαλουμενους σε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.85.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 6,
      "referenceLabel": "Psalms 85:6",
      "text": "Ακροασθητι, Κυριε, της προσευχης μου και προσεξον εις την φωνην των δεησεων μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.85.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 7,
      "referenceLabel": "Psalms 85:7",
      "text": "Εν ημερα θλιψεως μου θελω σε επικαλεισθαι, διοτι θελεις μου εισακουει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.85.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 8,
      "referenceLabel": "Psalms 85:8",
      "text": "Δεν ειναι ομοιος σου μεταξυ των θεων, Κυριε ουδε εργα ομοια των εργων σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.85.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 9,
      "referenceLabel": "Psalms 85:9",
      "text": "Παντα τα εθνη, τα οποια εκαμες, θελουσιν ελθει και προσκυνησει ενωπιον σου, Κυριε, και θελουσι δοξασει το ονομα σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.85.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 10,
      "referenceLabel": "Psalms 85:10",
      "text": "διοτι μεγας εισαι και καμνεις θαυμασια συ εισαι Θεος μονος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.85.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 11,
      "referenceLabel": "Psalms 85:11",
      "text": "Διδαξον με, Κυριε, την οδον σου, και θελω περιπατει εν τη αληθεια σου προσηλονε την καρδιαν μου εις τον φοβον του ονοματος σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.85.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 12,
      "referenceLabel": "Psalms 85:12",
      "text": "Θελω σε αινει, Κυριε ο Θεος μου, εν ολη τη καρδια μου και θελω δοξαζει το ονομα σου εις τον αιωνα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.85.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 13,
      "referenceLabel": "Psalms 85:13",
      "text": "διοτι μεγα επ' εμε το ελεος σου και ηλευθερωσας την ψυχην μου εξ αδου κατωτατου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.85.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 14,
      "referenceLabel": "Psalms 85:14",
      "text": "Θεε, οι υπερηφανοι εσηκωθησαν κατ' εμου, και αι συναξεις των βιαστων εζητησαν την ψυχην μου και δεν σε εθεσαν ενωπιον αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.85.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 15,
      "referenceLabel": "Psalms 85:15",
      "text": "Αλλα συ, Κυριε, εισαι Θεος οικτιρμων και ελεημων, μακροθυμος και πολυελεος και αληθινος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.85.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 16,
      "referenceLabel": "Psalms 85:16",
      "text": "Επιβλεψον επ' εμε και ελεησον με δος την δυναμιν σου εις τον δουλον σου και σωσον τον υιον της δουλης σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.85.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 17,
      "referenceLabel": "Psalms 85:17",
      "text": "Καμε εις εμε σημειον εις αγαθον, δια να ιδωσιν οι μισουντες με και να αισχυνθωσι διοτι συ, Κυριε, με εβοηθησας και με παρηγορησας.",
      "paragraphStart": false
    }
  ]
}
