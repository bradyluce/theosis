{
  "chapter": {
    "id": "lxx-greek:psalms.72",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 72,
    "referenceLabel": "Psalms 72",
    "summary": "Source text for Psalms 72 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.72.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 1,
      "referenceLabel": "Psalms 72:1",
      "text": "\"Ψαλμος του Ασαφ.\" Αγαθος τωοντι ειναι ο Θεος εις τον Ισραηλ, εις τους καθαρους την καρδιαν.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.72.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 2,
      "referenceLabel": "Psalms 72:2",
      "text": "Εμου δε, οι ποδες μου σχεδον εκλονισθησαν παρ' ολιγον ωλισθησαν τα βηματα μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 3,
      "referenceLabel": "Psalms 72:3",
      "text": "Διοτι εζηλευσα τους μωρους, βλεπων την ευτυχιαν των ασεβων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 4,
      "referenceLabel": "Psalms 72:4",
      "text": "Επειδη δεν ειναι λυπαι εις τον θανατον αυτων, αλλ' η δυναμις αυτων ειναι στερεα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 5,
      "referenceLabel": "Psalms 72:5",
      "text": "Δεν ειναι εν κοποις, ως οι αλλοι ανθρωποι ουδε μαστιγονονται μετα των λοιπων ανθρωπων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 6,
      "referenceLabel": "Psalms 72:6",
      "text": "δια τουτο περικυκλονει αυτους η υπερηφανια ως περιδεραιον η αδικια σκεπαζει αυτους ως ιματιον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 7,
      "referenceLabel": "Psalms 72:7",
      "text": "Οι οφθαλμοι αυτων εξεχουσιν εκ του παχους εξεπερασαν τας επιθυμιας της καρδιας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 8,
      "referenceLabel": "Psalms 72:8",
      "text": "Εμπαιζουσι και λαλουσιν εν πονηρια καταδυναστειαν λαλουσιν υπερηφανως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 9,
      "referenceLabel": "Psalms 72:9",
      "text": "Θετουσιν εις τον ουρανον το στομα αυτων, και η γλωσσα αυτων διατρεχει την γην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 10,
      "referenceLabel": "Psalms 72:10",
      "text": "Δια τουτο θελει στραφη ενταυθα ο λαος αυτου και υδατα ποτηριου πληρους εκθλιβονται δι' αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 11,
      "referenceLabel": "Psalms 72:11",
      "text": "Και λεγουσι, Πως γνωριζει ταυτα ο Θεος; και υπαρχει γνωσις εν τω Υψιστω;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 12,
      "referenceLabel": "Psalms 72:12",
      "text": "Ιδου, ουτοι ειναι ασεβεις και ευτυχουσι διαπαντος αυξανουσι τα πλουτη αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 13,
      "referenceLabel": "Psalms 72:13",
      "text": "Αρα, ματαιως εκαθαρισα την καρδιαν μου και ενιψα εν αθωοτητι τας χειρας μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 14,
      "referenceLabel": "Psalms 72:14",
      "text": "Διοτι εμαστιγωθην ολην την ημεραν και ετιμωρηθην πασαν αυγην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 15,
      "referenceLabel": "Psalms 72:15",
      "text": "Αν ειπω, Θελω ομιλει ουτως ιδου, εξυβριζω εις την γενεαν των υιων σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 16,
      "referenceLabel": "Psalms 72:16",
      "text": "Και εστοχασθην να εννοησω τουτο, πλην μ' εφανη δυσκολον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 17,
      "referenceLabel": "Psalms 72:17",
      "text": "εωσου εισελθων εις το αγιαστηριον του Θεου, ενοησα τα τελη αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 18,
      "referenceLabel": "Psalms 72:18",
      "text": "Συ βεβαιως εθεσας αυτους εις τοπους ολισθηρους ερριψας αυτους εις κρημνον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 19,
      "referenceLabel": "Psalms 72:19",
      "text": "Πως δια μιας κατηντησαν εις ερημωσιν Ηφανισθησαν, απωλεσθησαν υπο αιφνιδιου ολεθρου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 20,
      "referenceLabel": "Psalms 72:20",
      "text": "Ως ονειρον εξεγειρομενου Κυριε, οταν εγερθης, θελεις αφανισει την εικονα αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 21,
      "referenceLabel": "Psalms 72:21",
      "text": "Ουτως εκαιετο η καρδια μου, και τα νεφρα μου εβασανιζοντο",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 22,
      "referenceLabel": "Psalms 72:22",
      "text": "και εγω ημην ανοητος και δεν εγνωριζον κτηνος ημην ενωπιον σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 23,
      "referenceLabel": "Psalms 72:23",
      "text": "Εγω ομως ειμαι παντοτε μετα σου συ με επιασας απο της δεξιας μου χειρος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 24,
      "referenceLabel": "Psalms 72:24",
      "text": "Δια της συμβουλης σου θελεις με οδηγησει και μετα ταυτα θελεις με προσλαβει εν δοξη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.25",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 25,
      "referenceLabel": "Psalms 72:25",
      "text": "Τινα αλλον εχω εν τω ουρανω; και επι της γης δεν θελω αλλον παρα σε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.26",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 26,
      "referenceLabel": "Psalms 72:26",
      "text": "Ητονησεν η σαρξ μου και η καρδια μου αλλ' ο Θεος ειναι η δυναμις της καρδιας μου και η μερις μου εις τον αιωνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.27",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 27,
      "referenceLabel": "Psalms 72:27",
      "text": "Διοτι, ιδου, οσοι απομακρυνονται απο σου, θελουσιν απολεσθη συ εξωλοθρευσας παντας τους εκκλινοντας απο σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.28",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 28,
      "referenceLabel": "Psalms 72:28",
      "text": "Αλλα δι' εμε, το να προσκολλωμαι εις τον Θεον ειναι το αγαθον μου εθεσα την ελπιδα μου επι Κυριον τον Θεον, δια να κηρυττω παντα τα εργα σου.",
      "paragraphStart": false
    }
  ]
}
