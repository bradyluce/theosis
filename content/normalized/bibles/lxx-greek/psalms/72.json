{
  "chapter": {
    "id": "lxx-greek:psalms.72",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 72,
    "referenceLabel": "Psalms 72",
    "summary": "Source text for Psalms 72 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.72.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 1,
      "referenceLabel": "Psalms 72:1",
      "text": "\"Ψαλμος δια τον Σολομωντα.\" Θεε, δος την κρισιν σου εις τον βασιλεα και την δικαιοσυνην σου εις τον υιον του βασιλεως",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.72.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 2,
      "referenceLabel": "Psalms 72:2",
      "text": "Δια να κρινη τον λαον σου εν δικαιοσυνη και τους πτωχους σου εν κρισει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 3,
      "referenceLabel": "Psalms 72:3",
      "text": "Τα ορη θελουσι φερει ειρηνην εις τον λαον και οι λοφοι δικαιοσυνην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 4,
      "referenceLabel": "Psalms 72:4",
      "text": "Θελει κρινει τους πτωχους του λαου θελει σωσει τους υιους των πενητων και συντριψει τον καταδυναστευοντα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 5,
      "referenceLabel": "Psalms 72:5",
      "text": "Θελουσι σε φοβεισθαι ενοσω διαμενει ο ηλιος και η σεληνη, εις γενεας γενεων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 6,
      "referenceLabel": "Psalms 72:6",
      "text": "Θελει καταβη ως βροχη επι θερισμενον λειβαδιον ως ρανιδες σταλαζουσαι επι την γην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 7,
      "referenceLabel": "Psalms 72:7",
      "text": "Εν ταις ημεραις αυτου θελει ανθει ο δικαιος και αφθονια ειρηνης θελει εισθαι εωσου μη υπαρξη η σεληνη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 8,
      "referenceLabel": "Psalms 72:8",
      "text": "Και θελει κατακυριευει απο θαλασσης εως θαλασσης και απο του ποταμου εως των περατων της γης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 9,
      "referenceLabel": "Psalms 72:9",
      "text": "Εμπροσθεν αυτου θελουσι γονυκλιτησει οι κατοικουντες εν ερημοις, και οι εχθροι αυτου θελουσι γλειψει το χωμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 10,
      "referenceLabel": "Psalms 72:10",
      "text": "Οι βασιλεις της Θαρσεις και των νησων θελουσι προσφερει προσφορας οι βασιλεις της Αραβιας και της Σεβα θελουσι προσφερει δωρα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 11,
      "referenceLabel": "Psalms 72:11",
      "text": "Και θελουσι προσκυνησει αυτον παντες οι βασιλεις παντα τα εθνη θελουσι δουλευσει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 12,
      "referenceLabel": "Psalms 72:12",
      "text": "Διοτι θελει ελευθερωσει τον πτωχον κραζοντα και τον πενητα και τον αβοηθητον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 13,
      "referenceLabel": "Psalms 72:13",
      "text": "Θελει ελεησει τον πτωχον και τον πενητα και τας ψυχας των πενητων θελει σωσει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 14,
      "referenceLabel": "Psalms 72:14",
      "text": "Εκ δολου και εξ αδικιας θελει λυτρονει τας ψυχας αυτων και πολυτιμον θελει εισθαι το αιμα αυτων εις τους οφθαλμους αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 15,
      "referenceLabel": "Psalms 72:15",
      "text": "Και θελει ζη, και θελει δοθη εις αυτον απο του χρυσιου της Αραβιας, και θελει γινεσθαι παντοτε προσευχη υπερ αυτου ολην την ημεραν θελουσιν ευλογει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 16,
      "referenceLabel": "Psalms 72:16",
      "text": "Δραξ σιτου εαν υπαρχη εν τη γη επι των κορυφων των ορεων, ο καρπος αυτου θελει σειεσθαι ως ο Λιβανος και οι κατοικοι εν τη πολει θελουσιν εξανθησει ως ο χορτος της γης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 17,
      "referenceLabel": "Psalms 72:17",
      "text": "Το ονομα αυτου θελει διαμενει εις τον αιωνα το ονομα αυτου θελει διαρκει ενοσω διαμενει ο ηλιος και οι ανθρωποι θελουσιν ευλογεισθαι εν αυτω παντα τα εθνη θελουσι μακαριζει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 18,
      "referenceLabel": "Psalms 72:18",
      "text": "Ευλογητος Κυριος ο Θεος, ο Θεος του Ισραηλ, οστις μονος καμνει θαυμασια",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 19,
      "referenceLabel": "Psalms 72:19",
      "text": "και ευλογημενον το ενδοξον ονομα αυτου εις τον αιωνα και ας πληρωθη απο της δοξης αυτου η πασα γη. Αμην, και αμην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.72.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 20,
      "referenceLabel": "Psalms 72:20",
      "text": "Ετελειωσαν αι προσευχαι του Δαβιδ υιου του Ιεσσαι.",
      "paragraphStart": false
    }
  ]
}
