{
  "chapter": {
    "id": "lxx-greek:psalms.36",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 36,
    "referenceLabel": "Psalms 36",
    "summary": "Source text for Psalms 36 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.36.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 1,
      "referenceLabel": "Psalms 36:1",
      "text": "\"Εις τον πρωτον μουσικον. Ψαλμος του Δαβιδ, δουλου του Κυριου.\" Του ασεβους η παρανομια λεγει εν τη καρδια μου, δεν ειναι φοβος Θεου εμπροσθεν των οφθαλμων αυτου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.36.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 2,
      "referenceLabel": "Psalms 36:2",
      "text": "Διοτι απατα εαυτον εις τους οφθαλμους αυτου περι του οτι θελει ευρεθη η ανομια αυτου δια να μισηθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.36.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 3,
      "referenceLabel": "Psalms 36:3",
      "text": "Τα λογια του στοματος αυτου ειναι ανομια και δολος δεν ηθελησε να νοηση δια να πραττη το αγαθον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.36.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 4,
      "referenceLabel": "Psalms 36:4",
      "text": "Ανομιαν διαλογιζεται επι της κλινης αυτου ισταται εν οδω ουχι καλη το κακον δεν μισει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.36.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 5,
      "referenceLabel": "Psalms 36:5",
      "text": "Κυριε, εως του ουρανου φθανει το ελεος σου, η αληθεια σου εως των νεφελων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.36.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 6,
      "referenceLabel": "Psalms 36:6",
      "text": "Η δικαιοσυνη σου ειναι ως τα υψηλα ορη αι κρισεις σου αβυσσος μεγαλη ανθρωπους και κτηνη σωζεις, Κυριε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.36.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 7,
      "referenceLabel": "Psalms 36:7",
      "text": "Ποσον πολυτιμον ειναι το ελεος σου, Θεε. Δια τουτο οι υιοι των ανθρωπων ελπιζουσιν επι την σκιαν των πτερυγων σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.36.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 8,
      "referenceLabel": "Psalms 36:8",
      "text": "Θελουσι χορτασθη απο του παχους του οικου σου, και απο του χειμαρρου της τρυφης σου θελεις ποτισει αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.36.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 9,
      "referenceLabel": "Psalms 36:9",
      "text": "Διοτι μετα σου ειναι η πηγη της ζωης εν τω φωτι σου θελομεν ιδει φως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.36.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 10,
      "referenceLabel": "Psalms 36:10",
      "text": "Εκτεινον το ελεος σου προς τους γνωριζοντας σε, και την δικαιοσυνην σου προς τους ευθεις την καρδιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.36.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 11,
      "referenceLabel": "Psalms 36:11",
      "text": "Ας μη ελθη επ' εμε πους υπερηφανιας και χειρ ασεβων ας μη με σαλευση.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.36.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 12,
      "referenceLabel": "Psalms 36:12",
      "text": "Εκει επεσον οι εργαται της ανομιας κατεσπρωχθησαν και δεν θελουσι δυνηθη να ανεγερθωσι.",
      "paragraphStart": false
    }
  ]
}
