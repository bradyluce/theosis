{
  "chapter": {
    "id": "lxx-greek:psalms.71",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 71,
    "referenceLabel": "Psalms 71",
    "summary": "Source text for Psalms 71 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.71.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 1,
      "referenceLabel": "Psalms 71:1",
      "text": "Επι σε, Κυριε, ηλπισα ας μη καταισχυνθω ποτε.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.71.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 2,
      "referenceLabel": "Psalms 71:2",
      "text": "Δια την δικαιοσυνην σου λυτρωσον με και ελευθερωσον με Κλινον προς εμε το ωτιον σου και σωσον με.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 3,
      "referenceLabel": "Psalms 71:3",
      "text": "Γενου εις εμε τοπος οχυρος, δια να καταφευγω παντοτε συ διεταξας να με σωσης, διοτι πετρα μου και φρουριον μου εισαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 4,
      "referenceLabel": "Psalms 71:4",
      "text": "Θεε μου, λυτρωσον με εκ δυναμεως ασεβους, εκ χειρος παρανομου και αδικου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 5,
      "referenceLabel": "Psalms 71:5",
      "text": "Διοτι συ εισαι η ελπις μου, Κυριε Θεε το θαρρος μου εκ νεοτητος μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 6,
      "referenceLabel": "Psalms 71:6",
      "text": "Επι σε επεστηριχθην εκ της κοιλιας συ εισαι σκεπη μου εκ των σπλαγχνων της μητρος μου εις σε θελει εισθαι παντοτε ο υμνος μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 7,
      "referenceLabel": "Psalms 71:7",
      "text": "Ως τερας κατεσταθην εις τους πολλους αλλα συ εισαι το δυνατον καταφυγιον μου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 8,
      "referenceLabel": "Psalms 71:8",
      "text": "Ας εμπλησθη το στομα μου απο του υμνου σου, απο της δοξης σου, ολην την ημεραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 9,
      "referenceLabel": "Psalms 71:9",
      "text": "Μη με απορριψης εν καιρω γηρατος οταν εκλειπη η δυναμις μου, μη με εγκαταλιπης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 10,
      "referenceLabel": "Psalms 71:10",
      "text": "Διοτι οι εχθροι μου λαλουσι περι εμου και οι παραφυλαττοντες την ψυχην μου συμβουλευονται ομου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 11,
      "referenceLabel": "Psalms 71:11",
      "text": "Λεγοντες, Ο Θεος εγκατελιπεν αυτον καταδιωξατε και πιασατε αυτον, διοτι δεν υπαρχει ο σωζων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 12,
      "referenceLabel": "Psalms 71:12",
      "text": "Θεε, μη μακρυνθης απ' εμου Θεε μου, ταχυνον εις βοηθειαν μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 13,
      "referenceLabel": "Psalms 71:13",
      "text": "Ας αισχυνθωσιν, ας εξαλειφθωσιν οι εχθροι της ψυχης μου ας σκεπασθωσι απο ονειδους και εντροπης οι ζητουντες το κακον μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 14,
      "referenceLabel": "Psalms 71:14",
      "text": "Εγω δε παντοτε θελω ελπιζει, και θελω προσθετει επι παντας τους επαινους σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 15,
      "referenceLabel": "Psalms 71:15",
      "text": "Το στομα μου θελει κηρυττει την δικαιοσυνην σου και την σωτηριαν σου ολην την ημεραν διοτι δεν δυναμαι να απαριθμησω αυτας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 16,
      "referenceLabel": "Psalms 71:16",
      "text": "Θελω περιπατει εν τη δυναμει Κυριου του Θεου θελω μνημονευει την δικαιοσυνην σου, σου μονου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 17,
      "referenceLabel": "Psalms 71:17",
      "text": "Θεε, συ με εδιδαξας εκ νεοτητος μου και μεχρι του νυν εκηρυττον τα θαυμασια σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 18,
      "referenceLabel": "Psalms 71:18",
      "text": "Μη με εγκαταλιπης μηδε μεχρι του γηρατος και πολιας, Θεε, εωσου κηρυξω τον βραχιονα σου εις ταυτην την γενεαν, την δυναμιν σου εις παντας τους μεταγενεστερους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 19,
      "referenceLabel": "Psalms 71:19",
      "text": "Διοτι η δικαιοσυνη σου, Θεε, ειναι υπερυψωμενη διοτι εκαμες μεγαλεια Θεε, τις ομοιος σου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 20,
      "referenceLabel": "Psalms 71:20",
      "text": "οστις εδειξας εις εμε θλιψεις πολλας και ταλαιπωριας, και παλιν με ανεζωοποιησας και εκ των αβυσσων της γης παλιν ανηγαγες με;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 21,
      "referenceLabel": "Psalms 71:21",
      "text": "Ηυξησας το μεγαλειον μου και επιστρεψας με παρηγορησας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 22,
      "referenceLabel": "Psalms 71:22",
      "text": "Και εγω, Θεε μου, θελω δοξολογει εν τω οργανω του ψαλτηριου σε και την αληθειαν σου εις σε θελω ψαλμωδει εν κιθαρα, Αγιε του Ισραηλ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 23,
      "referenceLabel": "Psalms 71:23",
      "text": "Θελουσιν αγαλλεσθαι τα χειλη μου, οταν εις σε ψαλμωδω και η ψυχη μου, την οποιαν ελυτρωσας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.71.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 24,
      "referenceLabel": "Psalms 71:24",
      "text": "Ετι δε η γλωσσα μου ολην την ημεραν θελει μελετα την δικαιοσυνην σου διοτι ενετραπησαν, διοτι κατησχυνθησαν, οι ζητουντες το κακον μου.",
      "paragraphStart": false
    }
  ]
}
