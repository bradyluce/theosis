{
  "chapter": {
    "id": "lxx-greek:psalms.53",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 53,
    "referenceLabel": "Psalms 53",
    "summary": "Source text for Psalms 53 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.53.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 1,
      "referenceLabel": "Psalms 53:1",
      "text": "\"Εις τον πρωτον μουσικον, επι Νεγινωθ Μασχιλ του Δαβιδ, οτε ηλθον οι Ζιφαιοι και ειπον προς τον Σαουλ, Δεν ειναι κεκρυμμενος ο Δαβιδ παρ' ημιν;\" Θεε, σωσον με εν τω ονοματι σου και εν τη δυναμει σου κρινον με.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.53.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 2,
      "referenceLabel": "Psalms 53:2",
      "text": "Θεε, ακουσον της προσευχης μου ακροασθητι των λογων του στοματος μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.53.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 3,
      "referenceLabel": "Psalms 53:3",
      "text": "Διοτι ξενοι ηγερθησαν κατ' εμου, και καταδυνασται ζητουσι την ψυχην μου δεν εθεσαν τον Θεον ενωπιον αυτων. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.53.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 4,
      "referenceLabel": "Psalms 53:4",
      "text": "Ιδου, ο Θεος με βοηθει ο Κυριος ειναι μετα των υποστηριζοντων την ψυχην μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.53.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 5,
      "referenceLabel": "Psalms 53:5",
      "text": "Θελει στρεψει το κακον επι τους εχθρους μου εξολοθρευσον αυτους εν τη αληθεια σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.53.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 6,
      "referenceLabel": "Psalms 53:6",
      "text": "Αυτοπροαιρετως θελω θυσιασει εις σε θελω δοξολογει το ονομα σου, Κυριε, διοτι ειναι αγαθον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.53.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 7,
      "referenceLabel": "Psalms 53:7",
      "text": "Διοτι εκ πασης στενοχωριας με ελυτρωσε, και ο οφθαλμος μου ειδε την εκδικησιν επι τους εχθρους μου.",
      "paragraphStart": false
    }
  ]
}
