{
  "chapter": {
    "id": "lxx-greek:psalms.20",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 20,
    "referenceLabel": "Psalms 20",
    "summary": "Source text for Psalms 20 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.20.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Psalms 20:1",
      "text": "\"Εις τον πρωτον μουσικον. Ψαλμος του Δαβιδ.\" Ο Κυριος να σου υπακουση εν ημερα θλιψεως το ονομα του Θεου του Ιακωβ να σε υπερασπιση.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.20.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Psalms 20:2",
      "text": "Να σοι εξαποστειλη βοηθειαν εκ του αγιαστηριου και εκ της Σιων να σε υποστηριξη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.20.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Psalms 20:3",
      "text": "Να ενθυμηθη πασας τας προσφορας σου και να προσδεχθη το ολοκαυτωμα σου. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.20.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Psalms 20:4",
      "text": "Να σοι δωση κατα την καρδιαν σου και να εκπληρωση πασαν βουλην σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.20.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Psalms 20:5",
      "text": "Εις την σωτηριαν σου θελομεν χαρη και εις το ονομα του Θεου ημων θελομεν υψωσει τας σημαιας ο Κυριος να εκπληρωση παντα τα αιτηματα σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.20.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Psalms 20:6",
      "text": "Τωρα εγνωρισα οτι εσωσεν ο Κυριος τον χριστον αυτου θελει εισακουσει αυτου εκ του ουρανου της αγιοτητος αυτου η σωτηρια της δεξιας αυτου γινεται εν δυναμει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.20.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Psalms 20:7",
      "text": "Οι μεν εις αμαξας, οι δε εις ιππους, αλλ' ημεις εις το ονομα Κυριου του Θεου ημων θελομεν καυχασθαι",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.20.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Psalms 20:8",
      "text": "ουτοι συνεκαμφθησαν και επεσον ημεις δε ανεστημεν και ανωρθωθημεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.20.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Psalms 20:9",
      "text": "Κυριε, σωσον τον βασιλεα και εισακουσον ημων, καθ' ην ημεραν σε επικαλεσθωμεν.",
      "paragraphStart": false
    }
  ]
}
