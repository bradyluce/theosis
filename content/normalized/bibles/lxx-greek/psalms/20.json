{
  "chapter": {
    "id": "lxx-greek:psalms.20",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 20,
    "referenceLabel": "Psalms 20",
    "summary": "Source text for Psalms 20 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.20.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Psalms 20:1",
      "text": "\"Εις τον πρωτον μουσικον. Ψαλμος του Δαβιδ.\" Κυριε, εν τη δυναμει σου θελει ευφραινεσθαι ο βασιλευς και ποσον θελει υπεραγαλλεσθαι εν τη σωτηρια σου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.20.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Psalms 20:2",
      "text": "Την επιθυμιαν της καρδιας αυτου εδωκας εις αυτον, και της αιτησεως των χειλεων αυτου δεν εστερησας αυτον. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.20.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Psalms 20:3",
      "text": "Διοτι προεφθασας αυτον εν ευλογιαις αγαθοτητος εθεσας επι την κεφαλην αυτου στεφανον εκ καθαρου χρυσιου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.20.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Psalms 20:4",
      "text": "Ζωην σε εζητησε, και εδωκας εις αυτον μακροτητα ημερων εις αιωνα αιωνος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.20.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Psalms 20:5",
      "text": "Μεγαλη η δοξα αυτου δια της σωτηριας σου τιμην και μεγαλοπρεπειαν εθεσας επ' αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.20.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Psalms 20:6",
      "text": "Διοτι εθεσας αυτον ευλογιαν εις τον αιωνα υπερευφρανας αυτον δια του προσωπου σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.20.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Psalms 20:7",
      "text": "Διοτι ο βασιλευς ελπιζει επι τον Κυριον, και δια του ελεους του Υψιστου δεν θελει σαλευθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.20.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Psalms 20:8",
      "text": "Η χειρ σου θελει ευρει παντας τους εχθρους σου η δεξια σου θελει ευρει τους μισουντας σε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.20.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Psalms 20:9",
      "text": "Θελεις καμει αυτους ως καμινον πυρος εν τω καιρω της οργης σου ο Κυριος θελει καταπιει αυτους εν τω θυμω αυτου και πυρ θελει καταφαγει αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.20.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Psalms 20:10",
      "text": "Θελεις αφανισει απο της γης τον καρπον αυτων, και το σπερμα αυτων απο των υιων των ανθρωπων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.20.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Psalms 20:11",
      "text": "Διοτι εμηχανευθησαν κακα εναντιον σου διελογισθησαν βουλην, αλλα δεν ισχυσαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.20.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Psalms 20:12",
      "text": "Δια τουτο θελεις καμει αυτους να τρεψωσι τα νωτα, οταν επι τας χορδας σου ετοιμασης τα βελη σου κατα του προσωπου αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.20.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "Psalms 20:13",
      "text": "Υψωθητι, Κυριε, εν τη δυναμει σου θελομεν υμνει και ψαλμωδει την δυναμιν σου.",
      "paragraphStart": false
    }
  ]
}
