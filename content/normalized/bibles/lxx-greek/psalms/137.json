{
  "chapter": {
    "id": "lxx-greek:psalms.137",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 137,
    "referenceLabel": "Psalms 137",
    "summary": "Source text for Psalms 137 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.137.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 1,
      "referenceLabel": "Psalms 137:1",
      "text": "Επι των ποταμων Βαβυλωνος, εκει εκαθισαμεν και εκλαυσαμεν, οτε ενεθυμηθημεν την Σιων.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.137.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 2,
      "referenceLabel": "Psalms 137:2",
      "text": "Επι τας ιτεας εν μεσω αυτης εκρεμασαμεν τας κιθαρας ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.137.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 3,
      "referenceLabel": "Psalms 137:3",
      "text": "Διοτι οι αιχμαλωτισαντες ημας εκει εζητησαν παρ' ημων λογους ασματων και οι ερημωσαντες ημας υμνον, λεγοντες, Ψαλατε εις ημας εκ των ωδων της Σιων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.137.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 4,
      "referenceLabel": "Psalms 137:4",
      "text": "Πως να ψαλωμεν την ωδην του Κυριου επι ξενης γης;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.137.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 5,
      "referenceLabel": "Psalms 137:5",
      "text": "Εαν σε λησμονησω, Ιερουσαλημ, ας λησμονηση η δεξια μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.137.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 6,
      "referenceLabel": "Psalms 137:6",
      "text": "Ας κολληθη η γλωσσα μου εις τον ουρανισκον μου, εαν δεν σε ενθυμωμαι εαν δεν προταξω την Ιερουσαλημ εις την αρχην της ευφροσυνης μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.137.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 7,
      "referenceLabel": "Psalms 137:7",
      "text": "Μνησθητι, Κυριε, των υιων Εδωμ, οιτινες την ημεραν της Ιερουσαλημ ελεγον, Κατεδαφισατε, κατεδαφισατε αυτην εως των θεμελιων αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.137.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 8,
      "referenceLabel": "Psalms 137:8",
      "text": "Θυγατηρ Βαβυλωνος, η μελλουσα να ερημωθης, μακαριος οστις σοι ανταποδωση την ανταμοιβην των οσα επραξας εις ημας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.137.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 9,
      "referenceLabel": "Psalms 137:9",
      "text": "Μακαριος οστις πιαση και ριψη τα νηπια σου επι την πετραν",
      "paragraphStart": false
    }
  ]
}
