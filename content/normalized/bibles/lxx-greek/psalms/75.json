{
  "chapter": {
    "id": "lxx-greek:psalms.75",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 75,
    "referenceLabel": "Psalms 75",
    "summary": "Source text for Psalms 75 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.75.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 1,
      "referenceLabel": "Psalms 75:1",
      "text": "\"Εις τον πρωτον μουσικον, επι Νεγινωθ. Ψαλμος ωδης του Ασαφ.\" Γνωστος ειναι εν τη Ιουδαια ο Θεος εν τω Ισραηλ μεγα το ονομα αυτου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.75.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 2,
      "referenceLabel": "Psalms 75:2",
      "text": "Η δε σκηνη αυτου ειναι εν Σαλημ, και το κατοικητηριον αυτου εν Σιων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.75.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 3,
      "referenceLabel": "Psalms 75:3",
      "text": "Εκει συνετριψε τα βελη του τοξου, την ασπιδα και την ρομφαιαν και τον πολεμον. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.75.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 4,
      "referenceLabel": "Psalms 75:4",
      "text": "Εισαι λαμπροτερος υπερ τα ορη των αρπακτηρων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.75.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 5,
      "referenceLabel": "Psalms 75:5",
      "text": "Οι θρασυκαρδιοι εγυμνωθησαν εκοιμηθησαν τον υπνον αυτων και ουδεις των ρωμαλεων ανδρων ευρηκε τας χειρας αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.75.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 6,
      "referenceLabel": "Psalms 75:6",
      "text": "Απο επιτιμησεως σου, Θεε του Ιακωβ, επεσον εις βαθυτατον υπνον και η αμαξα και ο ιππος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.75.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 7,
      "referenceLabel": "Psalms 75:7",
      "text": "Συ εισαι φοβερος και τις δυναται να σταθη εμπροσθεν σου, οταν οργισθης;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.75.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 8,
      "referenceLabel": "Psalms 75:8",
      "text": "Εξ ουρανου εκαμες να ακουσθη κρισις η γη εφοβηθη και ησυχασεν,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.75.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 9,
      "referenceLabel": "Psalms 75:9",
      "text": "οτε εσηκωθη εις κρισιν ο Θεος, δια να σωση παντας τους πραους της γης. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.75.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 10,
      "referenceLabel": "Psalms 75:10",
      "text": "Βεβαιως ο θυμος του ανθρωπου θελει καταντησει εις επαινον σου θελεις χαλινωσει το υπολοιπον του θυμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.75.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 11,
      "referenceLabel": "Psalms 75:11",
      "text": "Καμετε ευχας και αποδοτε εις Κυριον τον Θεον σας παντες οι κυκλω αυτου ας φερωσι δωρα εις τον φοβερον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.75.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 12,
      "referenceLabel": "Psalms 75:12",
      "text": "τον αφαιρουντα το πνευμα των αρχοντων, τον φοβερον εις τους βασιλεις της γης.",
      "paragraphStart": false
    }
  ]
}
