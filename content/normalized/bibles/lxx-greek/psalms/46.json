{
  "chapter": {
    "id": "lxx-greek:psalms.46",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 46,
    "referenceLabel": "Psalms 46",
    "summary": "Source text for Psalms 46 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.46.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 1,
      "referenceLabel": "Psalms 46:1",
      "text": "\"Εις τον πρωτον μουσικον. Ψαλμος δια τους υιους Κορε.\" Παντες οι λαοι, κροτησατε χειρας αλαλαξατε εις τον Θεον εν φωνη αγαλλιασεως.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.46.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 2,
      "referenceLabel": "Psalms 46:2",
      "text": "Διοτι ο Κυριος ειναι υψιστος, φοβερος, Βασιλευς μεγας επι πασαν την γην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.46.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 3,
      "referenceLabel": "Psalms 46:3",
      "text": "Υπεταξε λαους εις ημας και εθνη υπο τους ποδας ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.46.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 4,
      "referenceLabel": "Psalms 46:4",
      "text": "Εκλεξε δια ημας την κληρονομιαν την δοξαν του Ιακωβ, τον οποιον ηγαπησε. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.46.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 5,
      "referenceLabel": "Psalms 46:5",
      "text": "Ανεβη ο Θεος εν αλαλαγμω, ο Κυριος εν φωνη σαλπιγγος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.46.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 6,
      "referenceLabel": "Psalms 46:6",
      "text": "Ψαλατε εις τον Θεον, ψαλατε ψαλατε εις τον Βασιλεα ημων, ψαλατε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.46.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 7,
      "referenceLabel": "Psalms 46:7",
      "text": "Διοτι Βασιλευς πασης της γης ειναι ο Θεος ψαλατε μετα συνεσεως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.46.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 8,
      "referenceLabel": "Psalms 46:8",
      "text": "Ο Θεος βασιλευει επι τα εθνη ο Θεος καθηται επι του θρονου της αγιοτητος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.46.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 9,
      "referenceLabel": "Psalms 46:9",
      "text": "Οι αρχοντες των λαων συνηχθησαν μετα του λαου του Θεου του Αβρααμ διοτι του Θεου ειναι αι ασπιδες της γης υψωθη σφοδρα.",
      "paragraphStart": false
    }
  ]
}
