{
  "chapter": {
    "id": "lxx-greek:psalms.106",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 106,
    "referenceLabel": "Psalms 106",
    "summary": "Source text for Psalms 106 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.106.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 1,
      "referenceLabel": "Psalms 106:1",
      "text": "Αλληλουια. Αινειτε τον Κυριον, διοτι ειναι αγαθος διοτι το ελεος αυτου μενει εις τον αιωνα.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.106.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 2,
      "referenceLabel": "Psalms 106:2",
      "text": "Τις δυναται να κηρυξη τα κραταια εργα του Κυριου, να καμη ακουστας πασας τας αινεσεις αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 3,
      "referenceLabel": "Psalms 106:3",
      "text": "Μακαριοι οι φυλαττοντες κρισιν, οι πραττοντες δικαιοσυνην εν παντι καιρω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 4,
      "referenceLabel": "Psalms 106:4",
      "text": "Μνησθητι μου, Κυριε, εν τη ευμενεια τη προς τον λαον σου επισκεφθητι με εν τη σωτηρια σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 5,
      "referenceLabel": "Psalms 106:5",
      "text": "δια να βλεπω το καλον των εκλεκτων σου, δια να ευφραινωμαι εν τη ευφροσυνη του εθνους σου, δια να καυχωμαι μετα της κληρονομιας σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 6,
      "referenceLabel": "Psalms 106:6",
      "text": "Ημαρτησαμεν μετα των πατερων ημων ηνομησαμεν, ησεβησαμεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 7,
      "referenceLabel": "Psalms 106:7",
      "text": "Οι πατερες ημων εν Αιγυπτω δεν ενοησαν τα θαυμασια σου δεν ενεθυμηθησαν το πληθος του ελεους σου, και σε παρωργισαν εν τη θαλασση, εν τη Ερυθρα θαλασση.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 8,
      "referenceLabel": "Psalms 106:8",
      "text": "Και ομως εσωσεν αυτους δια το ονομα αυτου, δια να καμη γνωστα τα κραταια εργα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 9,
      "referenceLabel": "Psalms 106:9",
      "text": "Και επετιμησε την Ερυθραν θαλασσαν, και εξηρανθη και διεβιβασεν αυτους δια των αβυσσων ως δι' ερημου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 10,
      "referenceLabel": "Psalms 106:10",
      "text": "και εσωσεν αυτους εκ της χειρος του μισουντος αυτους, και ελυτρωσεν αυτους εκ της χειρος του εχθρου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 11,
      "referenceLabel": "Psalms 106:11",
      "text": "Και τα υδατα κατεκαλυψαν τους εχθρους αυτων δεν απελειφθη ουδε εις εξ αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 12,
      "referenceLabel": "Psalms 106:12",
      "text": "Τοτε επιστευσαν εις τους λογους αυτου εψαλαν την αινεσιν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 13,
      "referenceLabel": "Psalms 106:13",
      "text": "Πλην ταχεως ελησμονησαν τα εργα αυτου δεν περιεμειναν την βουλην αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 14,
      "referenceLabel": "Psalms 106:14",
      "text": "Αλλ' επεθυμησαν επιθυμιαν εν τη ερημω, και επειρασαν τον Θεον εν τη ανυδρω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 15,
      "referenceLabel": "Psalms 106:15",
      "text": "Και εδωκεν εις αυτους την αιτησιν αυτων απεστειλεν ομως εις αυτους νοσον θανατηφορον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 16,
      "referenceLabel": "Psalms 106:16",
      "text": "Εφθονησαν ετι τον Μωυσην εν τω στρατοπεδω και τον Ααρων τον αγιον του Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 17,
      "referenceLabel": "Psalms 106:17",
      "text": "Η γη ηνοιξε και κατεπιε τον Δαθαν, και εσκεπασε την συναγωγην του Αβειρων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 18,
      "referenceLabel": "Psalms 106:18",
      "text": "και πυρ εξηφθη εν τη συναγωγη αυτων η φλοξ κατεκαυσε τους ασεβεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 19,
      "referenceLabel": "Psalms 106:19",
      "text": "Κατεσκευασαν μοσχον εν Χωρηβ, και προσεκυνησαν το χωνευτον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 20,
      "referenceLabel": "Psalms 106:20",
      "text": "και μετηλλαξαν την δοξαν αυτων εις ομοιωμα βοος τρωγοντος χορτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 21,
      "referenceLabel": "Psalms 106:21",
      "text": "Ελησμονησαν τον Θεον τον σωτηρα αυτων τον ποιησαντα μεγαλεια εν Αιγυπτω,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 22,
      "referenceLabel": "Psalms 106:22",
      "text": "θαυμασια εν γη Χαμ, φοβερα εν τη Ερυθρα θαλασση.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 23,
      "referenceLabel": "Psalms 106:23",
      "text": "Και ειπε να εξολοθρευση αυτους, αν ο Μωυσης ο εκλεκτος αυτου δεν ιστατο εν τη θραυσει ενωπιον αυτου, δια να αποστρεψη την οργην αυτου, ωστε να μη αφανιση αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 24,
      "referenceLabel": "Psalms 106:24",
      "text": "Κατεφρονησαν ετι την γην την επιθυμητην δεν επιστευσαν εις τον λογον αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.25",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 25,
      "referenceLabel": "Psalms 106:25",
      "text": "και εγογγυσαν εν ταις σκηναις αυτων δεν εισηκουσαν της φωνης του Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.26",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 26,
      "referenceLabel": "Psalms 106:26",
      "text": "Δια τουτο εσηκωσε την χειρα αυτου κατ' αυτων, δια να καταστρεψη αυτους εν τη ερημω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.27",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 27,
      "referenceLabel": "Psalms 106:27",
      "text": "και να στρεψη το σπερμα αυτων μεταξυ των εθνων και να διασκορπιση αυτους εις τους τοπους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.28",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 28,
      "referenceLabel": "Psalms 106:28",
      "text": "Και προσεκολληθησαν εις τον Βεελ-φεγωρ, και εφαγον θυσιας νεκρων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.29",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 29,
      "referenceLabel": "Psalms 106:29",
      "text": "και παρωξυναν αυτον εν τοις εργοις αυτων, ωστε εφωρμησεν επ' αυτους η πληγη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.30",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 30,
      "referenceLabel": "Psalms 106:30",
      "text": "Αλλα σταθεις ο Φινεες εκαμε κρισιν και η πληγη επαυσε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.31",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 31,
      "referenceLabel": "Psalms 106:31",
      "text": "και ελογισθη εις αυτον δια δικαιοσυνην, εις γενεαν και γενεαν εως αιωνος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.32",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 32,
      "referenceLabel": "Psalms 106:32",
      "text": "Και παρωξυναν αυτον εν τοις υδασι της αντιλογιας, και επαθε κακως ο Μωυσης δι' αυτους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.33",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 33,
      "referenceLabel": "Psalms 106:33",
      "text": "διοτι παρωργισαν το πνευμα αυτου, ωστε ελαλησεν αστοχαστως δια των χειλεων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.34",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 34,
      "referenceLabel": "Psalms 106:34",
      "text": "Δεν εξωλοθρευσαν τα εθνη τα οποια ο Κυριος προσεταξεν εις αυτους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.35",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 35,
      "referenceLabel": "Psalms 106:35",
      "text": "αλλ' εσμιχθησαν μετα των εθνων και εμαθον τα εργα αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.36",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 36,
      "referenceLabel": "Psalms 106:36",
      "text": "και ελατρευσαν τα γλυπτα αυτων, τα οποια εγειναν παγις εις αυτους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.37",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 37,
      "referenceLabel": "Psalms 106:37",
      "text": "και εθυσιασαν τους υιους αυτων και τας θυγατερας αυτων εις τα δαιμονια",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.38",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 38,
      "referenceLabel": "Psalms 106:38",
      "text": "Και εχυσαν αιμα αθωον, το αιμα των υιων αυτων και των θυγατερων αυτων τους οποιους εθυσιασαν εις τα γλυπτα της Χανααν και εμιανθη η γη εξ αιματων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.39",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 39,
      "referenceLabel": "Psalms 106:39",
      "text": "Και εμολυνθησαν με τα εργα αυτων, και επορνευσαν με τας πραξεις αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.40",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 40,
      "referenceLabel": "Psalms 106:40",
      "text": "Δια τουτο η οργη του Κυριου εξηφθη κατα του λαου αυτου, και εβδελυχθη την κληρονομιαν αυτου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.41",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 41,
      "referenceLabel": "Psalms 106:41",
      "text": "Και παρεδωκεν αυτους εις τας χειρας των εθνων και εκυριευσαν αυτους οι μισουντες αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.42",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 42,
      "referenceLabel": "Psalms 106:42",
      "text": "Και εθλιψαν αυτους οι εχθροι αυτων, και εταπεινωθησαν υπο τας χειρας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.43",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 43,
      "referenceLabel": "Psalms 106:43",
      "text": "Πολλακις ελυτρωσεν αυτους, αλλ' αυτοι παρωργισαν αυτον με τας βουλας αυτων διο εταπεινωθησαν δια την ανομιαν αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.44",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 44,
      "referenceLabel": "Psalms 106:44",
      "text": "Πλην επεβλεψεν επι την θλιψιν αυτων, οτε ηκουσε την κραυγην αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.45",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 45,
      "referenceLabel": "Psalms 106:45",
      "text": "και ενεθυμηθη την προς αυτους διαθηκην αυτου και μετεμεληθη κατα το πληθος του ελεους αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.46",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 46,
      "referenceLabel": "Psalms 106:46",
      "text": "Και εκαμεν αυτους να ευρωσιν ελεος ενωπιον παντων των αιχμαλωτισαντων αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.47",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 47,
      "referenceLabel": "Psalms 106:47",
      "text": "Σωσον ημας, Κυριε ο Θεος ημων, και συναγαγε ημας απο των εθνων, δια να δοξολογωμεν το ονομα σου το αγιον και να καυχωμεθα εις την αινεσιν σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.48",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 48,
      "referenceLabel": "Psalms 106:48",
      "text": "Ευλογητος Κυριος ο Θεος του Ισραηλ, απο του αιωνος και εως του αιωνος και ας λεγη πας ο λαος, Αμην. Αλληλουια.",
      "paragraphStart": false
    }
  ]
}
