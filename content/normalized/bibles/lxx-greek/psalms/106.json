{
  "chapter": {
    "id": "lxx-greek:psalms.106",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 106,
    "referenceLabel": "Psalms 106",
    "summary": "Source text for Psalms 106 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.106.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 1,
      "referenceLabel": "Psalms 106:1",
      "text": "Δοξολογειτε τον Κυριον, διοτι ειναι αγαθος, διοτι το ελεος αυτου μενει εις τον αιωνα.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.106.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 2,
      "referenceLabel": "Psalms 106:2",
      "text": "Ας λεγωσιν ουτως οι λελυτρωμενοι του Κυριου, τους οποιους ελυτρωσεν εκ χειρος του εχθρου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 3,
      "referenceLabel": "Psalms 106:3",
      "text": "και συνηγαγεν αυτους εκ των χωρων, απο ανατολης και δυσεως απο βορρα και απο νοτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 4,
      "referenceLabel": "Psalms 106:4",
      "text": "Περιεπλανωντο εν τη ερημω, εν οδω ανυδρω ουδε ευρισκον πολιν δια κατοικησιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 5,
      "referenceLabel": "Psalms 106:5",
      "text": "Ησαν πεινωντες και διψωντες η ψυχη αυτων απεκαμνεν εν αυτοις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 6,
      "referenceLabel": "Psalms 106:6",
      "text": "Τοτε εβοησαν προς τον Κυριον εν τη θλιψει αυτων και ηλευθερωσεν αυτους απο των αναγκων αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 7,
      "referenceLabel": "Psalms 106:7",
      "text": "Και ωδηγησεν αυτους δι' ευθειας οδου, δια να υπαγωσιν εις πολιν κατοικιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 8,
      "referenceLabel": "Psalms 106:8",
      "text": "Ας υμνολογωσιν εις τον Κυριον τα ελεη αυτου και τα θαυμασια αυτου τα προς τους υιους των ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 9,
      "referenceLabel": "Psalms 106:9",
      "text": "Διοτι εχορτασε ψυχην διψωσαν, και ψυχην πεινωσαν ενεπλησεν απο αγαθων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 10,
      "referenceLabel": "Psalms 106:10",
      "text": "Τους καθημενους εν σκοτει και σκια θανατου, τους δεδεμενους εν θλιψει και εν σιδηρω",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 11,
      "referenceLabel": "Psalms 106:11",
      "text": "διοτι ηπειθησαν εις τα λογια του Θεου και την βουλην του Υψιστου κατεφρονησαν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 12,
      "referenceLabel": "Psalms 106:12",
      "text": "δια τουτο εταπεινωσε την καρδιαν αυτων εν κοπω επεσον, και δεν υπηρχεν ο βοηθων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 13,
      "referenceLabel": "Psalms 106:13",
      "text": "Τοτε εβοησαν προς τον Κυριον εν τη θλιψει αυτων, και εσωσεν αυτους απο των αναγκων αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 14,
      "referenceLabel": "Psalms 106:14",
      "text": "εξηγαγεν αυτους εκ του σκοτους και εκ της σκιας του θανατου και τα δεσμα αυτων συνετριψεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 15,
      "referenceLabel": "Psalms 106:15",
      "text": "Ας υμνολογωσιν εις τον Κυριον τα ελεη αυτου και τα θαυμασια αυτου τα προς τους υιους των ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 16,
      "referenceLabel": "Psalms 106:16",
      "text": "διοτι συνετριψε πυλας χαλκινας και μοχλους σιδηρους κατεκοψεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 17,
      "referenceLabel": "Psalms 106:17",
      "text": "Οι αφρονες βασανιζονται δια τας παραβασεις αυτων και δια τας ανομιας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 18,
      "referenceLabel": "Psalms 106:18",
      "text": "Παν φαγητον βδελυττεται η ψυχη αυτων, και πλησιαζουσιν εως των πυλων του θανατου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 19,
      "referenceLabel": "Psalms 106:19",
      "text": "Τοτε βοωσι προς τον Κυριον εν τη θλιψει αυτων, και σωζει αυτους απο των αναγκων αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 20,
      "referenceLabel": "Psalms 106:20",
      "text": "αποστελλει τον λογον αυτου και ιατρευει αυτους και ελευθερονει απο της φθορας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 21,
      "referenceLabel": "Psalms 106:21",
      "text": "Ας υμνολογωσιν εις τον Κυριον τα ελεη αυτου, και τα θαυμασια αυτου τα προς τους υιους των ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 22,
      "referenceLabel": "Psalms 106:22",
      "text": "και ας θυσιαζωσι θυσιας αινεσεως και ας κηρυττωσι τα εργα αυτου εν αγαλλιασει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 23,
      "referenceLabel": "Psalms 106:23",
      "text": "Οι καταβαινοντες εις την θαλασσαν με πλοια, καμνοντες εργασιας εν υδασι πολλοις,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 24,
      "referenceLabel": "Psalms 106:24",
      "text": "αυτοι βλεπουσι τα εργα του Κυριου και τα θαυμασια αυτου τα γινομενα εις τα βαθη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.25",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 25,
      "referenceLabel": "Psalms 106:25",
      "text": "Διοτι προσταζει, και εγειρεται ανεμος καταιγιδος, και υψονει τα κυματα αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.26",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 26,
      "referenceLabel": "Psalms 106:26",
      "text": "Αναβαινουσιν εως των ουρανων και καταβαινουσιν εως των αβυσσων η ψυχη αυτων τηκεται υπο της συμφορας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.27",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 27,
      "referenceLabel": "Psalms 106:27",
      "text": "Σειονται και κλονιζονται ως ο μεθυων, και πασα η σοφια αυτων χανεται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.28",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 28,
      "referenceLabel": "Psalms 106:28",
      "text": "Τοτε κραζουσι προς τον Κυριον εν τη θλιψει αυτων, και εξαγει αυτους απο των αναγκων αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.29",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 29,
      "referenceLabel": "Psalms 106:29",
      "text": "Κατασιγαζει την ανεμοζαλην, και σιωπωσι τα κυματα αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.30",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 30,
      "referenceLabel": "Psalms 106:30",
      "text": "Και ευφραινονται, διοτι ησυχασαν και οδηγει αυτους εις τον επιθυμητον λιμενα αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.31",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 31,
      "referenceLabel": "Psalms 106:31",
      "text": "Ας υμνολογωσιν εις τον Κυριον τα ελεη αυτου και τα θαυμασια αυτου τα προς τους υιους των ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.32",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 32,
      "referenceLabel": "Psalms 106:32",
      "text": "και ας υψονωσιν αυτον εν τη συναξει του λαου, και εν τω συνεδριω των πρεσβυτερων ας αινωσιν αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.33",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 33,
      "referenceLabel": "Psalms 106:33",
      "text": "Μεταβαλλει ποταμους εις ερημον και πηγας υδατων εις ξηρασιαν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.34",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 34,
      "referenceLabel": "Psalms 106:34",
      "text": "την καρποφορον γην εις αλμυραν, δια την κακιαν των κατοικουντων εν αυτη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.35",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 35,
      "referenceLabel": "Psalms 106:35",
      "text": "Μεταβαλλει την ερημον εις λιμνας υδατων και την ξηραν γην εις πηγας υδατων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.36",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 36,
      "referenceLabel": "Psalms 106:36",
      "text": "Και εκει κατοικιζει τους πεινωντας, και συγκροτουσι πολεις εις κατοικησιν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.37",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 37,
      "referenceLabel": "Psalms 106:37",
      "text": "και σπειρουσιν αγρους και φυτευουσιν αμπελωνας, οιτινες καμνουσι καρπους γεννηματος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.38",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 38,
      "referenceLabel": "Psalms 106:38",
      "text": "Και ευλογει αυτους, και πληθυνονται σφοδρα, και δεν ολιγοστευει τα κτηνη αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.39",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 39,
      "referenceLabel": "Psalms 106:39",
      "text": "Ολιγοστευουσιν ομως επειτα και ταπεινονονται, απο της στενοχωριας, της συμφορας και του πονου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.40",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 40,
      "referenceLabel": "Psalms 106:40",
      "text": "Επιχεει καταφρονησιν επι τους αρχοντας και καμνει αυτους να περιπλανωνται εν ερημω αβατω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.41",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 41,
      "referenceLabel": "Psalms 106:41",
      "text": "Τον δε πενητα υψονει απο της πτωχειας και καθιστα ως ποιμνια τας οικογενειας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.42",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 42,
      "referenceLabel": "Psalms 106:42",
      "text": "Οι ευθεις βλεπουσι και ευφραινονται πασα δε ανομια θελει εμφραξει το στομα αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.106.43",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 43,
      "referenceLabel": "Psalms 106:43",
      "text": "Οστις ειναι σοφος ας παρατηρη ταυτα και θελουσιν εννοησει τα ελεη του Κυριου.",
      "paragraphStart": false
    }
  ]
}
