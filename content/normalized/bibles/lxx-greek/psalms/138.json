{
  "chapter": {
    "id": "lxx-greek:psalms.138",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 138,
    "referenceLabel": "Psalms 138",
    "summary": "Source text for Psalms 138 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.138.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 1,
      "referenceLabel": "Psalms 138:1",
      "text": "\"Εις τον πρωτον μουσικον. Ψαλμος του Δαβιδ.\" Κυριε, εδοκιμασας με και με εγνωρισας.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.138.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 2,
      "referenceLabel": "Psalms 138:2",
      "text": "Συ γνωριζεις το καθισμα μου και την εγερσιν μου νοεις τους λογισμους μου απο μακροθεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 3,
      "referenceLabel": "Psalms 138:3",
      "text": "Εξερευνας το περιπατημα μου και το πλαγιασμα μου και πασας τας οδους μου γνωριζεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 4,
      "referenceLabel": "Psalms 138:4",
      "text": "Διοτι και πριν ελθη ο λογος εις την γλωσσαν μου, ιδου, Κυριε, γνωριζεις το παν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 5,
      "referenceLabel": "Psalms 138:5",
      "text": "Με περικυκλονεις οπισθεν και εμπροσθεν, και εθεσας επ' εμε την χειρα σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 6,
      "referenceLabel": "Psalms 138:6",
      "text": "Η γνωσις αυτη ειναι υπερθαυμαστος εις εμε ειναι υψηλη δεν δυναμαι να φθασω εις αυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 7,
      "referenceLabel": "Psalms 138:7",
      "text": "Που να υπαγω απο του πνευματος σου; και απο του προσωπου σου που να φυγω;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 8,
      "referenceLabel": "Psalms 138:8",
      "text": "Εαν αναβω εις τον ουρανον, εισαι εκει εαν πλαγιασω εις τον αδην, ιδου, συ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 9,
      "referenceLabel": "Psalms 138:9",
      "text": "Εαν λαβω τας πτερυγας της αυγης και κατοικησω εις τα εσχατα της θαλασσης,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 10,
      "referenceLabel": "Psalms 138:10",
      "text": "και εκει θελει με οδηγησει η χειρ σου και η δεξια σου θελει με κρατει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 11,
      "referenceLabel": "Psalms 138:11",
      "text": "Εαν ειπω, Αλλα το σκοτος θελει με σκεπασει, και η νυξ θελει εισθαι φως περι εμε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 12,
      "referenceLabel": "Psalms 138:12",
      "text": "και αυτο το σκοτος δεν σκεπαζει ουδεν απο σου και η νυξ λαμπει ως η ημερα εις σε το σκοτος ειναι ως το φως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 13,
      "referenceLabel": "Psalms 138:13",
      "text": "Διοτι συ εμορφωσας τους νεφρους μου με περιετυλιξας εν τη κοιλια της μητρος μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 14,
      "referenceLabel": "Psalms 138:14",
      "text": "Θελω σε υμνει, διοτι φοβερως και θαυμασιως επλασθην θαυμασια ειναι τα εργα σου και η ψυχη μου καλλιστα γνωριζει τουτο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 15,
      "referenceLabel": "Psalms 138:15",
      "text": "Δεν εκρυφθησαν τα οστα μου απο σου, ενω επλαττομην εν τω κρυπτω και διεμορφονομην εν τοις κατωτατοις της γης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 16,
      "referenceLabel": "Psalms 138:16",
      "text": "Το αδιαμορφωτον του σωματος μου ειδον οι οφθαλμοι σου και εν τω βιβλιω σου παντα ταυτα ησαν γεγραμμενα, ως και αι ημεραι καθ' ας εσχηματιζοντο, και ενω ουδεν εκ τουτων υπηρχε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 17,
      "referenceLabel": "Psalms 138:17",
      "text": "ποσον δε πολυτιμοι ειναι εις εμε αι βουλαι σου, Θεε ποσον εμεγαλυνθη ο αριθμος αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 18,
      "referenceLabel": "Psalms 138:18",
      "text": "Εαν ηθελον να απαριθμησω αυτας, υπερβαινουσι την αμμον εξυπνω, και ετι ειμαι μετα σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 19,
      "referenceLabel": "Psalms 138:19",
      "text": "Βεβαιως θελεις θανατωσει τους ασεβεις, Θεε απομακρυνθητε λοιπον απ' εμου, ανδρες αιματων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 20,
      "referenceLabel": "Psalms 138:20",
      "text": "Διοτι λαλουσι κατα σου ασεβως οι εχθροι σου λαμβανουσι το ονομα σου επι ματαιω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 21,
      "referenceLabel": "Psalms 138:21",
      "text": "Μη δεν μισω, Κυριε, τους μισουντας σε; και δεν αγανακτω κατα των επανισταμενων επι σε;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 22,
      "referenceLabel": "Psalms 138:22",
      "text": "Με τελειον μισος μισω αυτους δια εχθρους εχω αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 23,
      "referenceLabel": "Psalms 138:23",
      "text": "Δοκιμασον με, Θεε, και γνωρισον την καρδιαν μου εξετασον με και μαθε τους στοχασμους μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.138.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 24,
      "referenceLabel": "Psalms 138:24",
      "text": "και ιδε, αν υπαρχη εν εμοι οδος ανομιας και οδηγησον με εις την οδον την αιωνιον.",
      "paragraphStart": false
    }
  ]
}
