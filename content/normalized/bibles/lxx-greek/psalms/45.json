{
  "chapter": {
    "id": "lxx-greek:psalms.45",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 45,
    "referenceLabel": "Psalms 45",
    "summary": "Source text for Psalms 45 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.45.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 1,
      "referenceLabel": "Psalms 45:1",
      "text": "\"Εις τον πρωτον μουσικον, δια τους υιους Κορε ωδη επι Αλαμωθ.\" Ο Θεος ειναι καταφυγη ημων και δυναμις, βοηθεια ετοιμοτατη εν ταις θλιψεσι.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.45.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 2,
      "referenceLabel": "Psalms 45:2",
      "text": "Δια τουτο δεν θελομεν φοβηθη, και αν σαλευθη η γη και μετατοπισθωσι τα ορη εις το μεσον των θαλασσων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.45.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 3,
      "referenceLabel": "Psalms 45:3",
      "text": "και αν ηχωσι και ταραττωνται τα υδατα αυτων και σειωνται τα ορη δια το επαρμα αυτων. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.45.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 4,
      "referenceLabel": "Psalms 45:4",
      "text": "Ποταμος, και οι ρυακες αυτου θελουσιν ευφραινει την πολιν του Θεου, τον αγιον τοπον των σκηνωματων του Υψιστου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.45.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 5,
      "referenceLabel": "Psalms 45:5",
      "text": "Ο Θεος ειναι εν τω μεσω αυτης δεν θελει σαλευθη θελει βοηθησει αυτην ο Θεος απο του χαραγματος της αυγης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.45.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 6,
      "referenceLabel": "Psalms 45:6",
      "text": "Εφρυαξαν τα εθνη εσαλευθησαν αι βασιλειαι εδωκε φωνην αυτου η γη ανελυθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.45.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 7,
      "referenceLabel": "Psalms 45:7",
      "text": "Ο Κυριος των δυναμεων ειναι μεθ' ημων προπυργιον ημων ειναι ο Θεος του Ιακωβ. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.45.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 8,
      "referenceLabel": "Psalms 45:8",
      "text": "Ελθετε, ιδετε τα εργα του Κυριου οποιας καταστροφας εκαμεν εν τη γη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.45.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 9,
      "referenceLabel": "Psalms 45:9",
      "text": "Καταπαυει τους πολεμους εως των περατων της γης συντριβει τοξον και κατακοπτει λογχην καιει αμαξας εν πυρι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.45.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 10,
      "referenceLabel": "Psalms 45:10",
      "text": "Ησυχασατε και γνωρισατε οτι εγω ειμαι ο Θεος θελω υψωθη μεταξυ των εθνων θελω υψωθη εν τη γη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.45.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 11,
      "referenceLabel": "Psalms 45:11",
      "text": "Ο Κυριος των δυναμεων ειναι μεθ' ημων προπυργιον ημων ειναι ο Θεος του Ιακωβ. Διαψαλμα.",
      "paragraphStart": false
    }
  ]
}
