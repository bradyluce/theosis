{
  "chapter": {
    "id": "lxx-greek:psalms.116",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 116,
    "referenceLabel": "Psalms 116",
    "summary": "Source text for Psalms 116 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.116.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 1,
      "referenceLabel": "Psalms 116:1",
      "text": "Χαιρω οτι ο Κυριος εισηκουσε της φωνης μου, των δεησεων μου",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.116.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 2,
      "referenceLabel": "Psalms 116:2",
      "text": "οτι εκλινε το ωτιον αυτου προς εμε και ενοσω ζω, θελω επικαλεισθαι αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.116.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 3,
      "referenceLabel": "Psalms 116:3",
      "text": "Πονοι θανατου με περιεκυκλωσαν, και στενοχωριαι του αδου με ευρηκαν θλιψιν και πονον απηντησα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.116.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 4,
      "referenceLabel": "Psalms 116:4",
      "text": "Και επεκαλεσθην το ονομα του Κυριου ω Κυριε, λυτρωσον την ψυχην μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.116.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 5,
      "referenceLabel": "Psalms 116:5",
      "text": "Ελεημων ο Κυριος και δικαιος και ευσπλαγχνος ο Θεος ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.116.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 6,
      "referenceLabel": "Psalms 116:6",
      "text": "Ο Κυριος φυλαττει τους απλους εταλαιπωρηθην, και με εσωσεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.116.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 7,
      "referenceLabel": "Psalms 116:7",
      "text": "Επιστρεψον, ψυχη μου, εις την αναπαυσιν σου, διοτι ο Κυριος σε ευηργετησε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.116.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 8,
      "referenceLabel": "Psalms 116:8",
      "text": "Διοτι ελυτρωσας την ψυχην μου εκ θανατου, τους οφθαλμους μου απο δακρυων, τους ποδας μου απο ολισθηματος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.116.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 9,
      "referenceLabel": "Psalms 116:9",
      "text": "Θελω περιπατει ενωπιον του Κυριου εν γη ζωντων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.116.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 10,
      "referenceLabel": "Psalms 116:10",
      "text": "Επιστευσα, δια τουτο ελαλησα εγω ημην σφοδρα τεθλιμμενος",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.116.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 11,
      "referenceLabel": "Psalms 116:11",
      "text": "εγω ειπα εν τη εκπληξει μου, πας ανθρωπος ειναι ψευστης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.116.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 12,
      "referenceLabel": "Psalms 116:12",
      "text": "Τι να ανταποδωσω εις τον Κυριον, δια πασας τας ευεργεσιας αυτου τας προς εμε;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.116.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 13,
      "referenceLabel": "Psalms 116:13",
      "text": "θελω λαβει το ποτηριον της σωτηριας και θελω επικαλεσθη το ονομα του Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.116.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 14,
      "referenceLabel": "Psalms 116:14",
      "text": "Τας ευχας μου θελω αποδωσει εις τον Κυριον, τωρα ενωπιον παντος του λαου αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.116.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 15,
      "referenceLabel": "Psalms 116:15",
      "text": "Πολυτιμος ενωπιον του Κυριου ο θανατος των οσιων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.116.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 16,
      "referenceLabel": "Psalms 116:16",
      "text": "Ναι, Κυριε διοτι ειμαι δουλος σου ειμαι δουλος σου, υιος της δουλης σου συ ελυσας τα δεσμα μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.116.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 17,
      "referenceLabel": "Psalms 116:17",
      "text": "Εις σε θελω θυσιασει θυσιαν αινεσεως και το ονομα του Κυριου θελω επικαλεσθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.116.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 18,
      "referenceLabel": "Psalms 116:18",
      "text": "Τας ευχας μου θελω αποδωσει εις τον Κυριον, τωρα εμπροσθεν παντος του λαου αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.116.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 19,
      "referenceLabel": "Psalms 116:19",
      "text": "εν ταις αυλαις του οικου του Κυριου, εν μεσω σου, Ιερουσαλημ. Αλληλουια.",
      "paragraphStart": false
    }
  ]
}
