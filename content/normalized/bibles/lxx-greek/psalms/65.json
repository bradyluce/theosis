{
  "chapter": {
    "id": "lxx-greek:psalms.65",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 65,
    "referenceLabel": "Psalms 65",
    "summary": "Source text for Psalms 65 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.65.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 1,
      "referenceLabel": "Psalms 65:1",
      "text": "\"Εις τον πρωτον μουσικον. Ψαλμος ωδης του Δαβιδ.\" Σε προσμενει υμνος, Θεε, εν Σιων και εις σε θελει αποδοθη η ευχη.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.65.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 2,
      "referenceLabel": "Psalms 65:2",
      "text": "Ω ακουων προσευχην, εις σε θελει ερχεσθαι πασα σαρξ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 3,
      "referenceLabel": "Psalms 65:3",
      "text": "Λογοι ανομιας υπερισχυσαν κατ' εμου συ θελεις καθαρισει τας παραβασεις ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 4,
      "referenceLabel": "Psalms 65:4",
      "text": "Μακαριος εκεινος, τον οποιον εξελεξας και προσελαβες, δια να κατοικη εν ταις αυλαις σου θελομεν χορτασθη απο των αγαθων του οικου σου, του αγιου ναου σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 5,
      "referenceLabel": "Psalms 65:5",
      "text": "Δια τρομερων πραγματων μετα δικαιοσυνης θελεις αποκρινεσθαι προς ημας, Θεε της σωτηριας ημων, η ελπις παντων των περατων της γης, και των μακραν εν θαλασση",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 6,
      "referenceLabel": "Psalms 65:6",
      "text": "ο στερεονων δια της δυναμεως σου τα ορη, ο περιεζωσμενος ισχυν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 7,
      "referenceLabel": "Psalms 65:7",
      "text": "ο κατασιγαζων τον ηχον της θαλασσης, τον ηχον των κυματων αυτης και τον θορυβον των λαων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 8,
      "referenceLabel": "Psalms 65:8",
      "text": "και αυτοι οι κατοικουντες τα περατα φοβουνται τα σημεια σου χαροποιεις τας αρχας της αυγης και της εσπερας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 9,
      "referenceLabel": "Psalms 65:9",
      "text": "Επισκεπτεσαι την γην και ποτιζεις αυτην υπερπλουτιζεις αυτην ο ποταμος του Θεου ειναι πληρης υδατων ετοιμαζεις τον σιτον αυτων, επειδη ουτω διεταξας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 10,
      "referenceLabel": "Psalms 65:10",
      "text": "Τα αυλακια αυτης ποτιζεις εξομαλιζεις τους βωλους αυτης απαλυνεις αυτην δια σταλακτης βροχης ευλογεις τα βλαστηματα αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 11,
      "referenceLabel": "Psalms 65:11",
      "text": "Στεφανονεις το ετος με τα αγαθα σου και τα ιχνη σου σταλαζουσι παχος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 12,
      "referenceLabel": "Psalms 65:12",
      "text": "Σταλαζουσιν αι βοσκαι της ερημου και οι λοφοι περιζωνονται χαραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 13,
      "referenceLabel": "Psalms 65:13",
      "text": "Αι πεδιαδες ειναι ενδεδυμεναι ποιμνια και αι κοιλαδες εσκεπασμεναι υπο σιτου αλαλαζουσι και ετι υμνολογουσι.",
      "paragraphStart": false
    }
  ]
}
