{
  "chapter": {
    "id": "lxx-greek:psalms.65",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 65,
    "referenceLabel": "Psalms 65",
    "summary": "Source text for Psalms 65 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.65.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 1,
      "referenceLabel": "Psalms 65:1",
      "text": "\"Εις τον πρωτον μουσικον. Ωιδη ψαλμου.\" Αλαλαξατε εις τον Θεον, πασα η γη.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.65.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 2,
      "referenceLabel": "Psalms 65:2",
      "text": "Ψαλατε την δοξαν του ονοματος αυτου καμετε ενδοξον τον υμνον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 3,
      "referenceLabel": "Psalms 65:3",
      "text": "Ειπατε προς τον Θεον, Ποσον ειναι φοβερα τα εργα σου δια το μεγεθος της δυναμεως σου, υποκρινονται υποταγην εις σε οι εχθροι σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 4,
      "referenceLabel": "Psalms 65:4",
      "text": "Πασα η γη θελει σε προσκυνει και ψαλμωδει εις σε θελουσι ψαλμωδει το ονομα σου. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 5,
      "referenceLabel": "Psalms 65:5",
      "text": "Ελθετε και ιδετε τα εργα του Θεου ειναι φοβερος εις τας πραξεις προς τους υιους των ανθρωπων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 6,
      "referenceLabel": "Psalms 65:6",
      "text": "Μετεβαλε την θαλασσαν εις ξηραν πεζοι διεβησαν δια του ποταμου εκει ευφρανθημεν εις αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 7,
      "referenceLabel": "Psalms 65:7",
      "text": "Δια της δυναμεως αυτου δεσποζει εις τον αιωνα οι οφθαλμοι αυτου επιβλεπουσιν επι τα εθνη οι αποσταται ας μη υψονωσιν εαυτους. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 8,
      "referenceLabel": "Psalms 65:8",
      "text": "Ευλογειτε, λαοι, τον Θεον ημων, και καμετε να ακουσθη η φωνη της αινεσεως αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 9,
      "referenceLabel": "Psalms 65:9",
      "text": "οστις διαφυλαττει εν ζωη την ψυχην ημων και δεν αφινει να κλονιζωνται οι ποδες ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 10,
      "referenceLabel": "Psalms 65:10",
      "text": "Διοτι συ ηρευνησας ημας, Θεε εδοκιμασας ημας, ως δοκιμαζεται το αργυριον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 11,
      "referenceLabel": "Psalms 65:11",
      "text": "Ενεβαλες ημας εις το δικτυον εθεσας βαρυ φορτιον επι τα νωτα ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 12,
      "referenceLabel": "Psalms 65:12",
      "text": "Επεβιβασας ανθρωπους επι τας κεφαλας ημων διηλθομεν δια πυρος και υδατος και εξηγαγες ημας εις αναψυχην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 13,
      "referenceLabel": "Psalms 65:13",
      "text": "Θελω εισελθει εις τον οικον σου με ολοκαυτωματα θελω σοι αποδωσει τας ευχας μου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 14,
      "referenceLabel": "Psalms 65:14",
      "text": "τας οποιας επροφεραν τα χειλη μου, και ελαλησε το στομα μου, εν τη θλιψει μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 15,
      "referenceLabel": "Psalms 65:15",
      "text": "Παχεα ολοκαυτωματα κριων θελω σοι προσφερει μετα θυμιαματος θελω προσφερει βοας μετα τραγων. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 16,
      "referenceLabel": "Psalms 65:16",
      "text": "Ελθετε, ακουσατε, παντες οι φοβουμενοι τον Θεον και θελω διηγηθη οσα εκαμεν εις την ψυχην μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 17,
      "referenceLabel": "Psalms 65:17",
      "text": "Προς αυτον εβοησα δια του στοματος μου, και υψωθη δια της γλωσσης μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 18,
      "referenceLabel": "Psalms 65:18",
      "text": "Εαν εθεωρουν αδικιαν εν τη καρδια μου, ο Κυριος δεν ηθελεν ακουσει",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 19,
      "referenceLabel": "Psalms 65:19",
      "text": "αλλ' ο Θεος βεβαιως εισηκουσεν επροσεξεν εις την φωνην της προσευχης μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.65.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 20,
      "referenceLabel": "Psalms 65:20",
      "text": "Ευλογητος ο Θεος, οστις δεν απεμακρυνε την προσευχην μου και το ελεος αυτου απ' εμου.",
      "paragraphStart": false
    }
  ]
}
