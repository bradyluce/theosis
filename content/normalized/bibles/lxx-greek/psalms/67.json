{
  "chapter": {
    "id": "lxx-greek:psalms.67",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 67,
    "referenceLabel": "Psalms 67",
    "summary": "Source text for Psalms 67 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.67.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 1,
      "referenceLabel": "Psalms 67:1",
      "text": "\"Εις τον πρωτον μουσικον, επι Νεγινωθ. Ψαλμος ωδης.\" Ο Θεος να σπλαγχνισθη ημας και να ευλογηση ημας να επιφανη το προσωπον αυτου εφ' ημας Διαψαλμα.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.67.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 2,
      "referenceLabel": "Psalms 67:2",
      "text": "Δια να γνωρισθη εν τη γη η οδος σου, εν πασι τοις εθνεσιν η σωτηρια σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.67.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 3,
      "referenceLabel": "Psalms 67:3",
      "text": "Ας σε υμνωσιν οι λαοι, Θεε ας σε υμνωσι παντες οι λαοι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.67.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 4,
      "referenceLabel": "Psalms 67:4",
      "text": "Ας ευφρανθωσι και ας αλαλαξωσι τα εθνη διοτι θελεις κρινει τους λαους εν ευθυτητι και τα εθνη εν τη γη θελεις οδηγησει. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.67.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 5,
      "referenceLabel": "Psalms 67:5",
      "text": "Ας σε υμνωσιν οι λαοι, Θεε, ας σε υμνωσι παντες οι λαοι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.67.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 6,
      "referenceLabel": "Psalms 67:6",
      "text": "Η γη θελει διδει τον καρπον αυτης θελει μας ευλογησει ο Θεος, ο Θεος ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.67.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 7,
      "referenceLabel": "Psalms 67:7",
      "text": "Θελει μας ευλογησει ο Θεος, και θελουσι φοβηθη αυτον παντα τα περατα της γης.",
      "paragraphStart": false
    }
  ]
}
