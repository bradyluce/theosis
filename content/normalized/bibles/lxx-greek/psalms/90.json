{
  "chapter": {
    "id": "lxx-greek:psalms.90",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 90,
    "referenceLabel": "Psalms 90",
    "summary": "Source text for Psalms 90 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.90.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 1,
      "referenceLabel": "Psalms 90:1",
      "text": "Ο κατοικων υπο την σκεπην του Υψιστου υπο την σκιαν του Παντοκρατορος θελει διατριβει.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.90.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 2,
      "referenceLabel": "Psalms 90:2",
      "text": "Θελω λεγει προς τον Κυριον, Συ εισαι καταφυγη μου και φρουριον μου Θεος μου επ' αυτον θελω ελπιζει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 3,
      "referenceLabel": "Psalms 90:3",
      "text": "Διοτι αυτος θελει σε λυτρονει εκ της παγιδος των κυνηγων και εκ θανατηφορου λοιμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 4,
      "referenceLabel": "Psalms 90:4",
      "text": "Με τα πτερα αυτου θελει σε σκεπαζει, και υπο τας πτερυγας αυτου θελεις εισθαι ασφαλης η αληθεια αυτου ειναι πανοπλια και ασπις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 5,
      "referenceLabel": "Psalms 90:5",
      "text": "Δεν θελεις φοβεισθαι απο φοβου νυκτερινου, την ημεραν απο βελους πετωμενου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 6,
      "referenceLabel": "Psalms 90:6",
      "text": "Απο θανατικου, το οποιον περιπατει εν σκοτει απο ολεθρου, οστις ερημονει εν μεσημβρια",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 7,
      "referenceLabel": "Psalms 90:7",
      "text": "Χιλιας θελει πιπτει εξ αριστερων σου και μυριας εκ δεξιων σου πλην εις σε δεν θελει πλησιαζει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 8,
      "referenceLabel": "Psalms 90:8",
      "text": "Μονον με τους οφθαλμους σου θελεις θεωρει και θελεις βλεπει των ασεβων την ανταποδοσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 9,
      "referenceLabel": "Psalms 90:9",
      "text": "Επειδη συ τον Κυριον, την ελπιδα μου, τον Υψιστον εκαμες καταφυγιον σου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 10,
      "referenceLabel": "Psalms 90:10",
      "text": "δεν θελει συμβαινει εις σε κακον, και μαστιξ δεν θελει πλησιαζει εις την σκηνην σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 11,
      "referenceLabel": "Psalms 90:11",
      "text": "Διοτι θελει προσταξει εις τους αγγελους αυτου περι σου, δια να σε διαφυλαττωσιν εν πασαις ταις οδοις σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 12,
      "referenceLabel": "Psalms 90:12",
      "text": "Θελουσι σε σηκονει επι των χειρων αυτων, δια να μη προσκοψης προς λιθον τον ποδα σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 13,
      "referenceLabel": "Psalms 90:13",
      "text": "Θελεις πατησει επι λεοντα και επι ασπιδα θελεις καταπατησει σκυμνον και δρακοντα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 14,
      "referenceLabel": "Psalms 90:14",
      "text": "Επειδη εθεσεν εις εμε την αγαπην αυτου, δια τουτο θελω λυτρωσει αυτον θελω υψωσει αυτον, διοτι εγνωρισε το ονομα μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 15,
      "referenceLabel": "Psalms 90:15",
      "text": "Θελει με επικαλεισθαι, και θελω εισακουει αυτου μετ' αυτου θελω εισθαι εν θλιψει θελω λυτρονει αυτον και θελω δοξαζει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 16,
      "referenceLabel": "Psalms 90:16",
      "text": "Θελω χορτασει αυτον μακροτητα ημερων και θελω δειξει εις αυτον την σωτηριαν μου.",
      "paragraphStart": false
    }
  ]
}
