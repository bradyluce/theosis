{
  "chapter": {
    "id": "lxx-greek:psalms.90",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 90,
    "referenceLabel": "Psalms 90",
    "summary": "Source text for Psalms 90 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.90.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 1,
      "referenceLabel": "Psalms 90:1",
      "text": "\"Προσευχη του Μωυσεως, του ανθρωπου του Θεου.\" Κυριε, συ εγεινες εις ημας καταφυγη εις γενεαν και γενεαν.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.90.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 2,
      "referenceLabel": "Psalms 90:2",
      "text": "Πριν γεννηθωσι τα ορη, και πλασης την γην και την οικουμενην, και απο του αιωνος εως του αιωνος, συ εισαι ο Θεος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 3,
      "referenceLabel": "Psalms 90:3",
      "text": "Επαναφερεις τον ανθρωπον εις τον χουν και λεγεις, Επιστρεψατε, υιοι των ανθρωπων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 4,
      "referenceLabel": "Psalms 90:4",
      "text": "Διοτι χιλια ετη ενωπιον σου ειναι ως ημερα η χθες, ητις παρηλθε, και ως φυλακη νυκτος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 5,
      "referenceLabel": "Psalms 90:5",
      "text": "Κατακλυζεις αυτους ειναι ως ονειρον της αυγης, ως χορτος οστις παρερχεται",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 6,
      "referenceLabel": "Psalms 90:6",
      "text": "το πρωι ανθει και παρακμαζει το εσπερας κοπτεται και ξηραινεται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 7,
      "referenceLabel": "Psalms 90:7",
      "text": "Διοτι εκλειπομεν εν τη οργη σου και εν τω θυμω σου ταραττομεθα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 8,
      "referenceLabel": "Psalms 90:8",
      "text": "Εθεσας τας ανομιας ημων ενωπιον σου, τα κρυφια ημων εις το φως του προσωπου σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 9,
      "referenceLabel": "Psalms 90:9",
      "text": "Επειδη πασαι αι ημεραι ημων παρερχονται εν τη οργη σου διατρεχομεν τα ετη ημων ως διανοημα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 10,
      "referenceLabel": "Psalms 90:10",
      "text": "Αι ημεραι της ζωης ημων ειναι καθ' εαυτας εβδομηκοντα ετη, και εαν εν ευρωστια, ογδοηκοντα ετη πλην και το καλητερον μερος αυτων ειναι κοπος και πονος, διοτι ταχεως παρερχεται και εμεις πετωμεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 11,
      "referenceLabel": "Psalms 90:11",
      "text": "Τις γνωριζει την δυναμιν της οργης σου και του θυμου σου αναλογως του φοβου σου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 12,
      "referenceLabel": "Psalms 90:12",
      "text": "Διδαξον ημας να μετρωμεν ουτω τας ημερας ημων, ωστε να προσκολλωμεν τας καρδιας ημων εις την σοφιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 13,
      "referenceLabel": "Psalms 90:13",
      "text": "Επιστρεψον, Κυριε εως ποτε; και γενου ιλεως εις τους δουλους σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 14,
      "referenceLabel": "Psalms 90:14",
      "text": "Χορτασον ημας του ελεους σου απο πρωιας, και θελομεν αγαλλεσθαι και ευφραινεσθαι κατα πασας τας ημερας ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 15,
      "referenceLabel": "Psalms 90:15",
      "text": "Ευφρανον ημας αντι των ημερων, καθ' ας εθλιψας ημας, των ετων καθ' α ειδομεν κακα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 16,
      "referenceLabel": "Psalms 90:16",
      "text": "Ας γεινη το εργον σου φανερον εις τους δουλους σου και η δοξα σου εις τους υιους αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.90.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 17,
      "referenceLabel": "Psalms 90:17",
      "text": "και ας ηναι η λαμπροτης Κυριου του Θεου ημων εφ' ημας και το εργον των χειρων ημων στερεονε εφ' ημας ναι, το εργον των χειρων ημων, στερεονε αυτο.",
      "paragraphStart": false
    }
  ]
}
