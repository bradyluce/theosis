{
  "chapter": {
    "id": "lxx-greek:psalms.8",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 8,
    "referenceLabel": "Psalms 8",
    "summary": "Source text for Psalms 8 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.8.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Psalms 8:1",
      "text": "\"Εις τον πρωτον μουσικον, επι Γιττιθ. Ψαλμος του Δαβιδ.\" Κυριε ο Κυριος ημων, ποσον ειναι θαυμαστον το ονομα σου εν παση τη γη οστις εθεσας την δοξαν σου υπερανω των ουρανων.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.8.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Psalms 8:2",
      "text": "Εκ στοματος νηπιων και θηλαζοντων ητοιμασας αινεσιν ενεκα των εχθρων σου, δια να καταργησης τον εχθρον και τον εκδικητην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.8.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Psalms 8:3",
      "text": "Οταν θεωρω τους ουρανους σου, το εργον των δακτυλων σου, την σεληνην και τους αστερας, τα οποια συ εθεμελιωσας,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.8.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Psalms 8:4",
      "text": "Τι ειναι ο ανθρωπος, ωστε να ενθυμησαι αυτον; η ο υιος του ανθρωπου, ωστε να επισκεπτησαι αυτον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.8.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Psalms 8:5",
      "text": "Συ δε εκαμες αυτον ολιγον τι κατωτερον των αγγελων, και με δοξαν και τιμην εστεφανωσας αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.8.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Psalms 8:6",
      "text": "Κατεστησας αυτον κυριον επι τα εργα των χειρων σου παντα υπεταξας υποκατω των ποδων αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.8.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Psalms 8:7",
      "text": "παντα τα προβατα και τους βοας, ετι δε και τα ζωα του αγρου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.8.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Psalms 8:8",
      "text": "τα πετεινα του ουρανου, και τους ιχθυας της θαλασσης, παντα τα διαπορευομενα τας οδους των θαλασσων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.8.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Psalms 8:9",
      "text": "Κυριε ο Κυριος ημων, ποσον ειναι θαυμαστον το ονομα σου εν παση τη γη.",
      "paragraphStart": false
    }
  ]
}
