{
  "chapter": {
    "id": "lxx-greek:psalms.2",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 2,
    "referenceLabel": "Psalms 2",
    "summary": "Source text for Psalms 2 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.2.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Psalms 2:1",
      "text": "Δια τι εφρυαξαν τα εθνη και οι λαοι εμελετησαν ματαια;",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.2.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Psalms 2:2",
      "text": "Παρεσταθησαν οι βασιλεις της γης, και οι αρχοντες συνηχθησαν ομου, κατα του Κυριου, και κατα του χριστου αυτου, λεγοντες,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.2.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Psalms 2:3",
      "text": "Ας διασπασωμεν τους δεσμους αυτων, και ας απορριψωμεν αφ' ημων τας αλυσεις αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.2.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Psalms 2:4",
      "text": "Ο καθημενος εν ουρανοις θελει γελασει ο Κυριος θελει εκμυκτηρισει αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.2.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Psalms 2:5",
      "text": "Τοτε θελει λαλησει προς αυτους εν τη οργη αυτου, και εν τω θυμω αυτου θελει συνταραξει αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.2.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Psalms 2:6",
      "text": "Αλλ' εγω, θελει ειπει, εχρισα τον Βασιλεα μου επι Σιων, το ορος το αγιον μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.2.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Psalms 2:7",
      "text": "Εγω θελω αναγγειλει το προσταγμα ο Κυριος ειπε προς εμε, Υιος μου εισαι συ εγω σημερον σε εγεννησα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.2.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Psalms 2:8",
      "text": "Ζητησον παρ' εμου, και θελω σοι δωσει τα εθνη κληρονομιαν σου, και ιδιοκτησιαν σου τα περατα της γης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.2.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Psalms 2:9",
      "text": "θελεις ποιμανει αυτους εν ραβδω σιδηρα ως σκευος κεραμεως θελεις συντριψει αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.2.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Psalms 2:10",
      "text": "Τωρα λοιπον, βασιλεις, συνετισθητε διδαχθητε, κριται της γης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.2.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Psalms 2:11",
      "text": "Δουλευετε τον Κυριον εν φοβω και αγαλλεσθε εν τρομω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.2.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Psalms 2:12",
      "text": "Φιλειτε τον Υιον, μηποτε οργισθη, και απολεσθητε εκ της οδου, οταν εξαφθη ταχεως ο θυμος αυτου. Μακαριοι παντες οι πεποιθοτες επ' αυτον.",
      "paragraphStart": false
    }
  ]
}
