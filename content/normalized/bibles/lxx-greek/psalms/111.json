{
  "chapter": {
    "id": "lxx-greek:psalms.111",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 111,
    "referenceLabel": "Psalms 111",
    "summary": "Source text for Psalms 111 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.111.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 1,
      "referenceLabel": "Psalms 111:1",
      "text": "Αινειτε τον Κυριον. Θελω εξυμνει τον Κυριον εν ολη καρδια, εν βουλη ευθεων και εν συναξει.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.111.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 2,
      "referenceLabel": "Psalms 111:2",
      "text": "Μεγαλα τα εργα του Κυριου, εξηκριβωμενα υπο παντων των ηδυνομενων εις αυτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.111.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 3,
      "referenceLabel": "Psalms 111:3",
      "text": "Ενδοξον και μεγαλοπρεπες το εργον αυτου, και η δικαιοσυνη αυτου μενει εις τον αιωνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.111.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 4,
      "referenceLabel": "Psalms 111:4",
      "text": "Αξιομνημονευτα εκαμε τα θαυμασια αυτου ελεημων και οικτιρμων ειναι ο Κυριος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.111.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 5,
      "referenceLabel": "Psalms 111:5",
      "text": "Εδωκε τροφην εις τους φοβουμενους αυτον θελει ενθυμεισθαι διαπαντος την διαθηκην αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.111.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 6,
      "referenceLabel": "Psalms 111:6",
      "text": "Ανηγγειλε προς τον λαον αυτου την δυναμιν των εργων αυτου, δια να δωση εις αυτους κληρονομιαν εθνων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.111.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 7,
      "referenceLabel": "Psalms 111:7",
      "text": "Τα εργα των χειρων αυτου ειναι αληθεια και κρισις αληθιναι πασαι αι εντολαι αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.111.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 8,
      "referenceLabel": "Psalms 111:8",
      "text": "εστερεωμεναι εις τον αιωνα του αιωνος, πεποιημεναι εν αληθεια και ευθυτητι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.111.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 9,
      "referenceLabel": "Psalms 111:9",
      "text": "Απεστειλε λυτρωσιν προς τον λαον αυτου διωρισε την διαθηκην αυτου εις τον αιωνα αγιον και φοβερον το ονομα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.111.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 10,
      "referenceLabel": "Psalms 111:10",
      "text": "Αρχη σοφιας φοβος Κυριου παντες οι πραττοντες αυτας εχουσι συνεσιν καλην η αινεσις αυτου μενει εις τον αιωνα.",
      "paragraphStart": false
    }
  ]
}
