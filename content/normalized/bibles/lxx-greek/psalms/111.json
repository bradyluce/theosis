{
  "chapter": {
    "id": "lxx-greek:psalms.111",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 111,
    "referenceLabel": "Psalms 111",
    "summary": "Source text for Psalms 111 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.111.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 1,
      "referenceLabel": "Psalms 111:1",
      "text": "Αινειτε τον Κυριον. Μακαριος ο ανθρωπος ο φοβουμενος τον Κυριον εις τας εντολας αυτου ηδυνεται σφοδρα.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.111.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 2,
      "referenceLabel": "Psalms 111:2",
      "text": "Το σπερμα αυτου θελει εισθαι δυνατον εν τη γη η γενεα των ευθεων θελει ευλογηθη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.111.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 3,
      "referenceLabel": "Psalms 111:3",
      "text": "Αγαθα και πλουτη θελουσιν εισθαι εν τω οικω αυτου, και η δικαιοσυνη αυτου μενει εις τον αιωνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.111.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 4,
      "referenceLabel": "Psalms 111:4",
      "text": "Φως ανατελλει εν τω σκοτει δια τους ευθεις ειναι ελεημων και οικτιρμων και δικαιος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.111.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 5,
      "referenceLabel": "Psalms 111:5",
      "text": "Ο καλος ανθρωπος ελεει και δανειζει οικονομει τα πραγματα αυτου εν κρισει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.111.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 6,
      "referenceLabel": "Psalms 111:6",
      "text": "Βεβαιως δεν θελει ποτε κλονισθη εις μνημοσυνον αιωνιον θελει εισθαι ο δικαιος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.111.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 7,
      "referenceLabel": "Psalms 111:7",
      "text": "Απο κακης φημης δεν θελει φοβηθη η καρδια αυτου ειναι στερεα, ελπιζουσα επι τον Κυριον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.111.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 8,
      "referenceLabel": "Psalms 111:8",
      "text": "Εστηριγμενη ειναι η καρδια αυτου δεν θελει φοβηθη, εωσου ιδη την εκδικησιν επι τους εχθρους αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.111.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 9,
      "referenceLabel": "Psalms 111:9",
      "text": "Εσκορπισεν, εδωκεν εις τους πενητας η δικαιοσυνη αυτου μενει εις τον αιωνα το κερας αυτου θελει υψωθη εν δοξη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.111.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 10,
      "referenceLabel": "Psalms 111:10",
      "text": "Ο ασεβης θελει ιδει και θελει οργισθη θελει τριξει τους οδοντας αυτου και θελει αναλυθη η επιθυμια των ασεβων θελει απολεσθη.",
      "paragraphStart": false
    }
  ]
}
