{
  "chapter": {
    "id": "lxx-greek:psalms.150",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 150,
    "referenceLabel": "Psalms 150",
    "summary": "Source text for Psalms 150 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.150.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 1,
      "referenceLabel": "Psalms 150:1",
      "text": "Αινειτε τον Κυριον. Αινειτε τον Θεον εν τω αγιαστηριω αυτου αινειτε αυτον εν τω στερεωματι της δυναμεως αυτου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.150.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 2,
      "referenceLabel": "Psalms 150:2",
      "text": "Αινειτε αυτον δια τα μεγαλεια αυτου αινειτε αυτον κατα το πληθος της μεγαλωσυνης αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.150.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 3,
      "referenceLabel": "Psalms 150:3",
      "text": "Αινειτε αυτον εν ηχω σαλπιγγος αινειτε αυτον εν ψαλτηριω και κιθαρα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.150.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 4,
      "referenceLabel": "Psalms 150:4",
      "text": "Αινειτε αυτον εν τυμπανω και χοροστασια αινειτε αυτον εν χορδαις και οργανω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.150.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 5,
      "referenceLabel": "Psalms 150:5",
      "text": "Αινειτε αυτον εν κυμβαλοις ευηχοις αινειτε αυτον εν κυμβαλοις αλαλαγμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.150.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 6,
      "referenceLabel": "Psalms 150:6",
      "text": "Πασα πνοη ας αινη τον Κυριον. Αλληλουια.",
      "paragraphStart": false
    }
  ]
}
