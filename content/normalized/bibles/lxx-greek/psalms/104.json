{
  "chapter": {
    "id": "lxx-greek:psalms.104",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 104,
    "referenceLabel": "Psalms 104",
    "summary": "Source text for Psalms 104 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.104.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 1,
      "referenceLabel": "Psalms 104:1",
      "text": "Δοξολογειτε τον Κυριον επικαλεισθε το ονομα αυτου καμετε γνωστα εν τοις λαοις τα εργα αυτου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.104.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 2,
      "referenceLabel": "Psalms 104:2",
      "text": "Ψαλλετε εις αυτον ψαλμωδειτε εις αυτον λαλειτε περι παντων των θαυμασιων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 3,
      "referenceLabel": "Psalms 104:3",
      "text": "Καυχασθε εις το αγιον αυτου ονομα ας ευφραινεται η καρδια των εκζητουντων τον Κυριον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 4,
      "referenceLabel": "Psalms 104:4",
      "text": "Ζητειτε τον Κυριον και την δυναμιν αυτου εκζητειτε το προσωπον αυτου διαπαντος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 5,
      "referenceLabel": "Psalms 104:5",
      "text": "Μνημονευετε των θαυμασιων αυτου τα οποια εκαμε των τεραστιων αυτου και των κρισεων του στοματος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 6,
      "referenceLabel": "Psalms 104:6",
      "text": "Σπερμα Αβρααμ του δουλου αυτου, υιοι Ιακωβ, οι εκλεκτοι αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 7,
      "referenceLabel": "Psalms 104:7",
      "text": "Αυτος ειναι Κυριος ο Θεος ημων εν παση τη γη ειναι αι κρισεις αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 8,
      "referenceLabel": "Psalms 104:8",
      "text": "Μνημονευετε παντοτε της διαθηκης αυτου, του λογου, τον οποιον προσεταξεν εις χιλιας γενεας,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 9,
      "referenceLabel": "Psalms 104:9",
      "text": "της διαθηκης, την οποιαν εκαμε προς τον Αβρααμ, και του ορκου αυτου προς τον Ισαακ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 10,
      "referenceLabel": "Psalms 104:10",
      "text": "και εβεβαιωσεν αυτον προς τον Ιακωβ δια νομου, προς τον Ισραηλ δια διαθηκην αιωνιον,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 11,
      "referenceLabel": "Psalms 104:11",
      "text": "λεγων, Εις σε θελω δωσει την γην Χανααν, μεριδα της κληρονομιας σας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 12,
      "referenceLabel": "Psalms 104:12",
      "text": "Ενω ησαν αυτοι ολιγοστοι τον αριθμον, ολιγοι, και παροικοι εν αυτη,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 13,
      "referenceLabel": "Psalms 104:13",
      "text": "και διηρχοντο απο εθνους εις εθνος, απο βασιλειου εις αλλον λαον,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 14,
      "referenceLabel": "Psalms 104:14",
      "text": "δεν αφηκεν ανθρωπον να αδικηση αυτους μαλιστα υπερ αυτων ηλεγξε βασιλεις,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 15,
      "referenceLabel": "Psalms 104:15",
      "text": "λεγων, μη εγγισητε τους κεχρισμενους μου και μη κακοποιησητε τους προφητας μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 16,
      "referenceLabel": "Psalms 104:16",
      "text": "Και εκαλεσε πειναν επι την γην συνετριψε παν στηριγμα αρτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 17,
      "referenceLabel": "Psalms 104:17",
      "text": "Απεστειλεν εμπροσθεν αυτων ανθρωπον, Ιωσηφ τον πωληθεντα ως δουλον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 18,
      "referenceLabel": "Psalms 104:18",
      "text": "του οποιου τους ποδας εσφιγξαν εν δεσμοις εβαλον αυτον εις τα σιδηρα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 19,
      "referenceLabel": "Psalms 104:19",
      "text": "εωσου ελθη ο λογος αυτου ο λογος του Κυριου εδοκιμασεν αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 20,
      "referenceLabel": "Psalms 104:20",
      "text": "Απεστειλεν ο βασιλευς και ελυσεν αυτον ο αρχων των λαων, και ηλευθερωσεν αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 21,
      "referenceLabel": "Psalms 104:21",
      "text": "Κατεστησεν αυτον κυριον του οικου αυτου, και αρχοντα επι παντων των κτηματων αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 22,
      "referenceLabel": "Psalms 104:22",
      "text": "δια να παιδευη τους αρχοντας αυτου κατα την αρεσκειαν αυτου, και να διδαξη σοφιαν τους πρεσβυτερους αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 23,
      "referenceLabel": "Psalms 104:23",
      "text": "Τοτε ηλθεν ο Ισραηλ εις την Αιγυπτον, και ο Ιακωβ παρωκησεν εν γη Χαμ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 24,
      "referenceLabel": "Psalms 104:24",
      "text": "Και ο Κυριος ηυξησε σφοδρα τον λαον αυτου, και εκραταιωσεν αυτον υπερ τους εχθρους αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.25",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 25,
      "referenceLabel": "Psalms 104:25",
      "text": "Εστραφη η καρδια αυτων εις το να μισωσι τον λαον αυτου, εις το να δολιευωνται εναντιον των δουλων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.26",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 26,
      "referenceLabel": "Psalms 104:26",
      "text": "Εξαπεστειλε Μωυσην τον δουλον αυτου, και Ααρων, τον οποιον εξελεξεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.27",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 27,
      "referenceLabel": "Psalms 104:27",
      "text": "Εξετελεσαν εν μεσω αυτων τους λογους των σημειων αυτου και τα θαυμασια αυτου εν γη Χαμ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.28",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 28,
      "referenceLabel": "Psalms 104:28",
      "text": "Εξαπεστειλε σκοτος, και εσκοτασε και δεν ηπειθησαν εις τους λογους αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.29",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 29,
      "referenceLabel": "Psalms 104:29",
      "text": "Μετεβαλε τα υδατα αυτων εις αιμα και εθανατωσε τους ιχθυας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.30",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 30,
      "referenceLabel": "Psalms 104:30",
      "text": "Η γη αυτων ανεβρυσε βατραχους, εως των ταμειων των βασιλεων αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.31",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 31,
      "referenceLabel": "Psalms 104:31",
      "text": "Ειπε, και ηλθε κυνομυια, και σκνιπες εις παντα τα ορια αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.32",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 32,
      "referenceLabel": "Psalms 104:32",
      "text": "Εδωκεν εις αυτους χαλαζαν αντι βροχης, και πυρ φλογερον εις την γην αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.33",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 33,
      "referenceLabel": "Psalms 104:33",
      "text": "και επαταξε τας αμπελους αυτων και τας συκεας αυτων, και συνετριψε τα δενδρα των οριων αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.34",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 34,
      "referenceLabel": "Psalms 104:34",
      "text": "Ειπε, και ηλθεν ακρις, και βρουχος αναριθμητος",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.35",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 35,
      "referenceLabel": "Psalms 104:35",
      "text": "και κατεφαγε παντα τον χορτον εν τη γη αυτων, και κατεφαγε τον καρπον της γης αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.36",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 36,
      "referenceLabel": "Psalms 104:36",
      "text": "Και επαταξε παν πρωτοτοκον εν τη γη αυτων, την απαρχην πασης δυναμεως αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.37",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 37,
      "referenceLabel": "Psalms 104:37",
      "text": "Και εξηγαγεν αυτους μετα αργυριου και χρυσιου, και δεν υπηρχεν ασθενης εν ταις φυλαις αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.38",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 38,
      "referenceLabel": "Psalms 104:38",
      "text": "Ευφρανθη η Αιγυπτος εις την εξοδον αυτων διοτι ο φοβος αυτων ειχεν επιπεσει επ' αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.39",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 39,
      "referenceLabel": "Psalms 104:39",
      "text": "Εξηπλωσε νεφελην δια να σκεπαζη αυτους, και πυρ δια να φεγγη την νυκτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.40",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 40,
      "referenceLabel": "Psalms 104:40",
      "text": "Εζητησαν, και εφερεν ορτυκια και αρτον ουρανου εχορτασεν αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.41",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 41,
      "referenceLabel": "Psalms 104:41",
      "text": "Διηνοιξε την πετραν, και ανεβλυσαν υδατα, και διερρευσαν ποταμοι εν τοποις ανυδροις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.42",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 42,
      "referenceLabel": "Psalms 104:42",
      "text": "Διοτι ενεθυμηθη τον λογον τον αγιον αυτου, τον προς Αβρααμ τον δουλον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.43",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 43,
      "referenceLabel": "Psalms 104:43",
      "text": "Και εξηγαγε τον λαον αυτου εν αγαλλιασει, τους εκλεκτους αυτου εν χαρα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.44",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 44,
      "referenceLabel": "Psalms 104:44",
      "text": "και εδωκεν εις αυτους τας γαιας των εθνων, και εκληρονομησαν τους κοπους των λαων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.104.45",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 45,
      "referenceLabel": "Psalms 104:45",
      "text": "δια να φυλαττωσι τα διαταγματα αυτου, και να εκτελωσι τους νομους αυτου. Αλληλουια.",
      "paragraphStart": false
    }
  ]
}
