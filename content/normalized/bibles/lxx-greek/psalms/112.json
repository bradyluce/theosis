{
  "chapter": {
    "id": "lxx-greek:psalms.112",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 112,
    "referenceLabel": "Psalms 112",
    "summary": "Source text for Psalms 112 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.112.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 1,
      "referenceLabel": "Psalms 112:1",
      "text": "Αινειτε τον Κυριον. Αινειτε, δουλοι του Κυριου, αινειτε το ονομα του Κυριου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.112.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 2,
      "referenceLabel": "Psalms 112:2",
      "text": "Ειη το ονομα Κυριου ευλογημενον απο του νυν και εως του αιωνος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.112.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 3,
      "referenceLabel": "Psalms 112:3",
      "text": "Απο ανατολων ηλιου εως δυσμων αυτου, ας αινηται το ονομα του Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.112.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 4,
      "referenceLabel": "Psalms 112:4",
      "text": "Ο Κυριος ειναι υψηλος επι παντα τα εθνη επι τους ουρανους ειναι η δοξα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.112.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 5,
      "referenceLabel": "Psalms 112:5",
      "text": "Τις ως Κυριος ο Θεος ημων; ο κατοικων εν υψηλοις",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.112.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 6,
      "referenceLabel": "Psalms 112:6",
      "text": "Ο συγκαταβαινων δια να επιβλεπη τα εν τω ουρανω και τα εν τη γη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.112.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 7,
      "referenceLabel": "Psalms 112:7",
      "text": "ο εγειρων απο του χωματος τον πτωχον και απο της κοπριας ανυψων τον πενητα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.112.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 8,
      "referenceLabel": "Psalms 112:8",
      "text": "δια να καθιση αυτον μετα των αρχοντων, μετα των αρχοντων του λαου αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.112.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 9,
      "referenceLabel": "Psalms 112:9",
      "text": "ο κατοικιζων την στειραν εν οικω, μητερα ευφραινομενην εις τεκνα. Αλληλουια.",
      "paragraphStart": false
    }
  ]
}
