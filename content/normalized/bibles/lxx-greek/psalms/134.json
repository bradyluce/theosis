{
  "chapter": {
    "id": "lxx-greek:psalms.134",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 134,
    "referenceLabel": "Psalms 134",
    "summary": "Source text for Psalms 134 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.134.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 1,
      "referenceLabel": "Psalms 134:1",
      "text": "Αινειτε τον Κυριον. Αινειτε το ονομα του Κυριου αινειτε, δουλοι του Κυριου,",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.134.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 2,
      "referenceLabel": "Psalms 134:2",
      "text": "Οι ισταμενοι εν τω οικω του Κυριου, εν ταις αυλαις του οικου του Θεου ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.134.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 3,
      "referenceLabel": "Psalms 134:3",
      "text": "Αινειτε τον Κυριον, διοτι αγαθος ο Κυριος ψαλμωδησατε εις το ονομα αυτου, διοτι ειναι τερπνον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.134.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 4,
      "referenceLabel": "Psalms 134:4",
      "text": "Διοτι τον Ιακωβ εξελεξεν εις εαυτον ο Κυριος, τον Ισραηλ εις θησαυρον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.134.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 5,
      "referenceLabel": "Psalms 134:5",
      "text": "Διοτι εγω εγνωρισα οτι μεγας ο Κυριος και ο Κυριος ημων ειναι υπερ παντας τους θεους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.134.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 6,
      "referenceLabel": "Psalms 134:6",
      "text": "Παντα οσα ηθελησεν ο Κυριος εποιησεν, εν τω ουρανω και εν τη γη, εν ταις θαλασσαις και εν πασαις ταις αβυσσοις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.134.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 7,
      "referenceLabel": "Psalms 134:7",
      "text": "Αναβιβαζει νεφελας απο των εσχατων της γης καμνει αστραπας δια βροχην εκβαλλει ανεμους εκ των θησαυρων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.134.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 8,
      "referenceLabel": "Psalms 134:8",
      "text": "Οστις επαταξε τα πρωτοτοκα της Αιγυπτου, απο ανθρωπου εως κτηνους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.134.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 9,
      "referenceLabel": "Psalms 134:9",
      "text": "εξαπεστειλε σημεια και τερατα εις το μεσον σου, Αιγυπτε, επι τον Φαραω και επι παντας τους δουλους αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.134.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 10,
      "referenceLabel": "Psalms 134:10",
      "text": "Οστις επαταξεν εθνη μεγαλα και απεκτεινε βασιλεις κραταιους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.134.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 11,
      "referenceLabel": "Psalms 134:11",
      "text": "τον Σηων, βασιλεα των Αμορραιων, και τον Ωγ, βασιλεα της Βασαν, και πασας τας βασιλειας Χανααν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.134.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 12,
      "referenceLabel": "Psalms 134:12",
      "text": "και εδωκε την γην αυτων κληρονομιαν, κληρονομιαν εις τον Ισραηλ τον λαον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.134.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 13,
      "referenceLabel": "Psalms 134:13",
      "text": "Το ονομα σου, Κυριε, μενει εις τον αιωνα το μνημοσυνον σου, Κυριε, εις γενεαν και γενεαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.134.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 14,
      "referenceLabel": "Psalms 134:14",
      "text": "Διοτι θελει κρινει ο Κυριος τον λαον αυτου και τους δουλους αυτου θελει ελεησει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.134.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 15,
      "referenceLabel": "Psalms 134:15",
      "text": "Τα ειδωλα των εθνων ειναι αργυριον και χρυσιον, εργον χειρων ανθρωπου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.134.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 16,
      "referenceLabel": "Psalms 134:16",
      "text": "Στομα εχουσι και δεν λαλουσιν οφθαλμους εχουσι και δεν βλεπουσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.134.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 17,
      "referenceLabel": "Psalms 134:17",
      "text": "Ωτα εχουσι και δεν ακουουσιν ουδε ειναι πνοη εν τω στοματι αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.134.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 18,
      "referenceLabel": "Psalms 134:18",
      "text": "Ομοιοι αυτων ας γεινωσιν οι ποιουντες αυτα πας ο ελπιζων επ' αυτα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.134.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 19,
      "referenceLabel": "Psalms 134:19",
      "text": "Οικος Ισραηλ, ευλογησατε τον Κυριον οικος Ααρων, ευλογησατε τον Κυριον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.134.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 20,
      "referenceLabel": "Psalms 134:20",
      "text": "οικος Λευι, ευλογησατε τον Κυριον οι φοβουμενοι τον Κυριον, ευλογησατε τον Κυριον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.134.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 21,
      "referenceLabel": "Psalms 134:21",
      "text": "Ευλογητος ο Κυριος εν Σιων, ο κατοικων εν Ιερουσαλημ. Αλληλουια.",
      "paragraphStart": false
    }
  ]
}
