{
  "chapter": {
    "id": "lxx-greek:psalms.28",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 28,
    "referenceLabel": "Psalms 28",
    "summary": "Source text for Psalms 28 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.28.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Psalms 28:1",
      "text": "\"Ψαλμος του Δαβιδ.\" Αποδοτε εις τον Κυριον, υιοι των δυνατων, αποδοτε εις τον Κυριον δοξαν και κρατος.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.28.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Psalms 28:2",
      "text": "Αποδοτε εις τον Κυριον την δοξαν του ονοματος αυτου προσκυνησατε τον Κυριον εν τω μεγαλοπρεπει αγιαστηριω αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.28.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Psalms 28:3",
      "text": "Η φωνη του Κυριου ειναι επι των υδατων ο Θεος της δοξης βροντα ο Κυριος ειναι επι υδατων πολλων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.28.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Psalms 28:4",
      "text": "Η φωνη του Κυριου ειναι δυνατη η φωνη του Κυριου ειναι μεγαλοπρεπης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.28.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Psalms 28:5",
      "text": "Η φωνη του Κυριου συντριβει κεδρους και συντριβει Κυριος τας κεδρους του Λιβανου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.28.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Psalms 28:6",
      "text": "Και καμνει αυτας να σκιρτωσιν ως μοσχος τον Λιβανον και το Σιριων ως νεος μονοκερως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.28.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Psalms 28:7",
      "text": "Η φωνη του Κυριου καταδιαιρει τας φλογας του πυρος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.28.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Psalms 28:8",
      "text": "Η φωνη του Κυριου σειει την ερημον ο Κυριος σειει την ερημον Καδης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.28.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Psalms 28:9",
      "text": "Η φωνη του Κυριου καμνει να κοιλοπονωσιν αι ελαφοι και γυμνονει τα δαση εν δε τω ναω αυτου πας τις κηρυττει την δοξαν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.28.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Psalms 28:10",
      "text": "Ο Κυριος καθηται επι τον κατακλυσμον και καθηται ο Κυριος Βασιλευς εις τον αιωνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.28.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Psalms 28:11",
      "text": "Ο Κυριος θελει δωσει δυναμιν εις τον λαον αυτου ο Κυριος θελει ευλογησει τον λαον αυτου εν ειρηνη.",
      "paragraphStart": false
    }
  ]
}
