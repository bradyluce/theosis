{
  "chapter": {
    "id": "lxx-greek:psalms.120",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 120,
    "referenceLabel": "Psalms 120",
    "summary": "Source text for Psalms 120 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.120.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 1,
      "referenceLabel": "Psalms 120:1",
      "text": "\"Ωιδη των Αναβαθμων.\" Υψονω τους οφθαλμους μου προς τα ορη ποθεν θελει ελθει η βοηθεια μου;",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.120.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 2,
      "referenceLabel": "Psalms 120:2",
      "text": "Η βοηθεια μου ερχεται απο του Κυριου, του ποιησαντος τον ουρανον και την γην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.120.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 3,
      "referenceLabel": "Psalms 120:3",
      "text": "Δεν θελει αφησει να κλονισθη ο πους σου ουδε θελει νυσταξει ο φυλαττων σε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.120.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 4,
      "referenceLabel": "Psalms 120:4",
      "text": "Ιδου, δεν θελει νυσταξει ουδε θελει αποκοιμηθη, ο φυλαττων τον Ισραηλ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.120.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 5,
      "referenceLabel": "Psalms 120:5",
      "text": "Ο Κυριος ειναι ο φυλαξ σου ο Κυριος ειναι η σκεπη σου εκ δεξιων σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.120.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 6,
      "referenceLabel": "Psalms 120:6",
      "text": "Την ημεραν ο ηλιος δεν θελει σε βλαψει, ουδε η σεληνη την νυκτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.120.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 7,
      "referenceLabel": "Psalms 120:7",
      "text": "Ο Κυριος θελει σε φυλαττει απο παντος κακου θελει φυλαττει την ψυχην σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.120.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 8,
      "referenceLabel": "Psalms 120:8",
      "text": "Ο Κυριος θελει φυλαττει την εξοδον σου και την εισοδον σου, απο του νυν και εως του αιωνος.",
      "paragraphStart": false
    }
  ]
}
