{
  "chapter": {
    "id": "lxx-greek:psalms.24",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 24,
    "referenceLabel": "Psalms 24",
    "summary": "Source text for Psalms 24 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.24.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Psalms 24:1",
      "text": "\"Ψαλμος του Δαβιδ.\" Προς σε, Κυριε, υψωσα την ψυχην μου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.24.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Psalms 24:2",
      "text": "Θεε μου, επι σε ηλπισα ας μη καταισχυνθω, ας μη χαρωσιν επ' εμε οι εχθροι μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Psalms 24:3",
      "text": "Βεβαιως παντες οι προσμενοντες σε δεν θελουσι καταισχυνθη ας καταισχυνθωσιν οι μωροι παραβαται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Psalms 24:4",
      "text": "Δειξον μοι, Κυριε, τας οδους σου διδαξον με τα βηματα σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Psalms 24:5",
      "text": "Οδηγησον με εν τη αληθεια σου και διδαξον με διοτι συ εισαι ο Θεος της σωτηριας μου σε προσμενω ολην την ημεραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Psalms 24:6",
      "text": "Μνησθητι, Κυριε, τους οικτιρμους σου και τα ελεη σου, διοτι ειναι απ' αιωνος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Psalms 24:7",
      "text": "Τας αμαρτιας της νεοτητος μου και τας παραβασεις μου μη μνησθης κατα το ελεος σου μνησθητι μου συ, Κυριε, ενεκεν της αγαθοτητος σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Psalms 24:8",
      "text": "Αγαθος και ευθυς ο Κυριος δια τουτο θελει διδαξει τους αμαρτωλους την οδον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Psalms 24:9",
      "text": "Θελει οδηγησει τους πραους εν κρισει και θελει διδαξει τους πραους την οδον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Psalms 24:10",
      "text": "Πασαι αι οδοι του Κυριου ειναι ελεος και αληθεια εις τους φυλαττοντας την διαθηκην αυτου και τα μαρτυρια αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 11,
      "referenceLabel": "Psalms 24:11",
      "text": "Ενεκεν του ονοματος σου, Κυριε, συγχωρησον την ανομιαν μου, διοτι ειναι μεγαλη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 12,
      "referenceLabel": "Psalms 24:12",
      "text": "Τις ειναι ο ανθρωπος ο φοβουμενος τον Κυριον; αυτον θελει διδαξει την οδον, την οποιαν πρεπει να εκλεξη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 13,
      "referenceLabel": "Psalms 24:13",
      "text": "Η ψυχη αυτου θελει κατοικει εν αγαθοις, και το σπερμα αυτου θελει κληρονομησει την γην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 14,
      "referenceLabel": "Psalms 24:14",
      "text": "Το απορρητον του Κυριου ειναι μετα των φοβουμενων αυτον και την διαθηκην αυτου θελει φανερωσει εις αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 15,
      "referenceLabel": "Psalms 24:15",
      "text": "Οι οφθαλμοι μου ειναι διαπαντος προς τον Κυριον, διοτι αυτος θελει εξαγαγει εκ παγιδος τους ποδας μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 16,
      "referenceLabel": "Psalms 24:16",
      "text": "Επιβλεψον επ' εμε και ελεησον με, διοτι μεμονωμενος και τεθλιμμενος ειμαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 17,
      "referenceLabel": "Psalms 24:17",
      "text": "Αι θλιψεις της καρδιας μου ηυξησαν εξαγαγε με εκ των στενοχωριων μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 18,
      "referenceLabel": "Psalms 24:18",
      "text": "Ιδε την θλιψιν μου και τον μοχθον μου, και αφες πασας τας αμαρτιας μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 19,
      "referenceLabel": "Psalms 24:19",
      "text": "Ιδε τους εχθρους μου, διοτι επληθυνθησαν και μισος αδικον με εμισησαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 20,
      "referenceLabel": "Psalms 24:20",
      "text": "Φυλαξον την ψυχην μου και σωσον με ας μη καταισχυνθω, διοτι επι σε ηλπισα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 21,
      "referenceLabel": "Psalms 24:21",
      "text": "Ακακια και ευθυτης ας με περιφυλαττωσι, διοτι σε προσεμεινα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 22,
      "referenceLabel": "Psalms 24:22",
      "text": "Λυτρωσον, Θεε, τον Ισραηλ εκ πασων των θλιψεων αυτου.",
      "paragraphStart": false
    }
  ]
}
