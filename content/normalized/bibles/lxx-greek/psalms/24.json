{
  "chapter": {
    "id": "lxx-greek:psalms.24",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 24,
    "referenceLabel": "Psalms 24",
    "summary": "Source text for Psalms 24 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.24.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Psalms 24:1",
      "text": "\"Ψαλμος του Δαβιδ.\" Του Κυριου ειναι η γη και το πληρωμα αυτης η οικουμενη και οι κατοικουντες εν αυτη.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.24.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Psalms 24:2",
      "text": "Διοτι αυτος εθεμελιωσεν αυτην επι των θαλασσων, και εστερεωσεν αυτην επι των ποταμων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Psalms 24:3",
      "text": "Τις θελει αναβη εις το ορος του Κυριου; και τις θελει σταθη εν τω τοπω τω αγιω αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Psalms 24:4",
      "text": "Ο αθωος τας χειρας και ο καθαρος την καρδιαν οστις δεν εδωκεν εις ματαιοτητα την ψυχην αυτου και δεν ωμοσε μετα δολιοτητος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Psalms 24:5",
      "text": "Ουτος θελει λαβει ευλογιαν παρα Κυριου και δικαιοσυνην παρα του Θεου της σωτηριας αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Psalms 24:6",
      "text": "Αυτη ειναι η γενεα των εκζητουντων αυτον, των ζητουντων το προσωπον σου, Θεε του Ιακωβ. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Psalms 24:7",
      "text": "Σηκωσατε, πυλαι, τας κεφαλας σας, και υψωθητε, θυραι αιωνιοι, και θελει εισελθει ο Βασιλευς της δοξης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Psalms 24:8",
      "text": "Τις ουτος ο Βασιλευς της δοξης; ο Κυριος ο κραταιος και δυνατος, ο Κυριος ο δυνατος εν πολεμω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Psalms 24:9",
      "text": "Σηκωσατε, πυλαι, τας κεφαλας σας, και υψωθητε, θυραι αιωνιοι, και θελει εισελθει ο Βασιλευς της δοξης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.24.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Psalms 24:10",
      "text": "Τις ειναι ουτος ο Βασιλευς της δοξης; ο Κυριος των δυναμεων αυτος ειναι ο Βασιλευς της δοξης. Διαψαλμα.",
      "paragraphStart": false
    }
  ]
}
