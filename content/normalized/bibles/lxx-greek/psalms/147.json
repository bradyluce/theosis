{
  "chapter": {
    "id": "lxx-greek:psalms.147",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 147,
    "referenceLabel": "Psalms 147",
    "summary": "Source text for Psalms 147 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.147.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 1,
      "referenceLabel": "Psalms 147:1",
      "text": "Επαινει, Ιερουσαλημ, τον Κυριον αινει τον Θεον σου, Σιων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 2,
      "referenceLabel": "Psalms 147:2",
      "text": "Διοτι ενεδυναμωσε τους μοχλους των πυλων σου ηυλογησε τους υιους σου εν μεσω σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 3,
      "referenceLabel": "Psalms 147:3",
      "text": "Βαλλει ειρηνην εις τα ορια σου σε χορταινει με το παχος του σιτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 4,
      "referenceLabel": "Psalms 147:4",
      "text": "Αποστελλει το προσταγμα αυτου εις την γην, ο λογος αυτου τρεχει ταχυτατα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 5,
      "referenceLabel": "Psalms 147:5",
      "text": "Διδει χιονα ως μαλλιον διασπειρει την παχνην ως στακτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 6,
      "referenceLabel": "Psalms 147:6",
      "text": "Ριπτει τον κρυσταλλον αυτου ως κομματια εμπροσθεν του ψυχους αυτου τις δυναται να σταθη;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 7,
      "referenceLabel": "Psalms 147:7",
      "text": "Αποστελλει τον λογον αυτου και διαλυει αυτα φυσα τον ανεμον αυτου, και τα υδατα ρεουσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 8,
      "referenceLabel": "Psalms 147:8",
      "text": "Αναγγελλει τον λογον αυτου προς τον Ιακωβ, τα διαταγματα αυτου και τας κρισεις αυτου προς τον Ισραηλ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 9,
      "referenceLabel": "Psalms 147:9",
      "text": "Δεν εκαμεν ουτως εις ουδεν εθνος ουδε εγνωρισαν τας κρισεις αυτου. Αλληλουια.",
      "paragraphStart": false
    }
  ]
}
