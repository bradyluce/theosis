{
  "chapter": {
    "id": "lxx-greek:psalms.147",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 147,
    "referenceLabel": "Psalms 147",
    "summary": "Source text for Psalms 147 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.147.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 1,
      "referenceLabel": "Psalms 147:1",
      "text": "Αινειτε τον Κυριον διοτι ειναι καλον να ψαλλωμεν εις τον Θεον ημων διοτι ειναι τερπνον, η αινεσις πρεπουσα.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.147.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 2,
      "referenceLabel": "Psalms 147:2",
      "text": "Ο Κυριος οικοδομει την Ιερουσαλημ θελει συναξει τους διεσπαρμενους του Ισραηλ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 3,
      "referenceLabel": "Psalms 147:3",
      "text": "Ιατρευει τους συντετριμμενους την καρδιαν και δενει τας πληγας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 4,
      "referenceLabel": "Psalms 147:4",
      "text": "Αριθμει τα πληθη των αστρων Καλει τα παντα ονομαστι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 5,
      "referenceLabel": "Psalms 147:5",
      "text": "Μεγας ο Κυριος ημων και μεγαλη η δυναμις αυτου η συνεσις αυτου αμετρητος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 6,
      "referenceLabel": "Psalms 147:6",
      "text": "Ο Κυριος υψονει τους πραους, τους δε ασεβεις ταπεινονει εως εδαφους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 7,
      "referenceLabel": "Psalms 147:7",
      "text": "Ψαλατε εις τον Κυριον ευχαριστουντες ψαλμωδειτε εις τον Θεον ημων εν κιθαρα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 8,
      "referenceLabel": "Psalms 147:8",
      "text": "τον σκεπαζοντα τον ουρανον με νεφελας τον ετοιμαζοντα βροχην δια την γην τον αναδιδοντα χορτον επι των ορεων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 9,
      "referenceLabel": "Psalms 147:9",
      "text": "τον διδοντα εις τα κτηνη την τροφην αυτων και εις τους νεοσσους των κορακων, οιτινες κραζουσι προς αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 10,
      "referenceLabel": "Psalms 147:10",
      "text": "Δεν χαιρει εις την δυναμιν του ιππου δεν ηδυνεται εις τους ποδας του ανδρος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 11,
      "referenceLabel": "Psalms 147:11",
      "text": "Ο Κυριος ηδυνεται εις τους φοβουμενους αυτον, εις τους ελπιζοντας επι το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 12,
      "referenceLabel": "Psalms 147:12",
      "text": "Επαινει, Ιερουσαλημ, τον Κυριον αινει τον Θεον σου, Σιων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 13,
      "referenceLabel": "Psalms 147:13",
      "text": "Διοτι ενεδυναμωσε τους μοχλους των πυλων σου ηυλογησε τους υιους σου εν μεσω σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 14,
      "referenceLabel": "Psalms 147:14",
      "text": "Βαλλει ειρηνην εις τα ορια σου σε χορταινει με το παχος του σιτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 15,
      "referenceLabel": "Psalms 147:15",
      "text": "Αποστελλει το προσταγμα αυτου εις την γην, ο λογος αυτου τρεχει ταχυτατα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 16,
      "referenceLabel": "Psalms 147:16",
      "text": "Διδει χιονα ως μαλλιον διασπειρει την παχνην ως στακτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 17,
      "referenceLabel": "Psalms 147:17",
      "text": "Ριπτει τον κρυσταλλον αυτου ως κομματια εμπροσθεν του ψυχους αυτου τις δυναται να σταθη;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 18,
      "referenceLabel": "Psalms 147:18",
      "text": "Αποστελλει τον λογον αυτου και διαλυει αυτα φυσα τον ανεμον αυτου, και τα υδατα ρεουσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 19,
      "referenceLabel": "Psalms 147:19",
      "text": "Αναγγελλει τον λογον αυτου προς τον Ιακωβ, τα διαταγματα αυτου και τας κρισεις αυτου προς τον Ισραηλ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.147.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 20,
      "referenceLabel": "Psalms 147:20",
      "text": "Δεν εκαμεν ουτως εις ουδεν εθνος ουδε εγνωρισαν τας κρισεις αυτου. Αλληλουια.",
      "paragraphStart": false
    }
  ]
}
