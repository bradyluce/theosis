{
  "chapter": {
    "id": "lxx-greek:psalms.26",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 26,
    "referenceLabel": "Psalms 26",
    "summary": "Source text for Psalms 26 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.26.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Psalms 26:1",
      "text": "\"Ψαλμος του Δαβιδ.\" Κρινον με, Κυριε διοτι εγω περιεπατησα εν ακακια μου και επι τον Κυριον ηλπισα, και δεν θελω σαλευθη.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.26.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Psalms 26:2",
      "text": "Εξετασον με, Κυριε, και δοκιμασον με δοκιμασον τους νεφρους μου και την καρδιαν μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.26.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Psalms 26:3",
      "text": "Διοτι το ελεος σου ειναι εμπροσθεν των οφθαλμων μου και περιεπατησα εν τη αληθεια σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.26.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Psalms 26:4",
      "text": "Δεν εκαθησα μετα ανθρωπων ματαιων και μετα υποκριτων δεν θελω υπαγει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.26.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Psalms 26:5",
      "text": "Εμισησα την συναξιν των πονηρευομενων, και μετα ασεβων δεν θελω καθησει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.26.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Psalms 26:6",
      "text": "Θελω νιψει εν αθωοτητι τας χειρας μου και θελω περικυκλωσει το θυσιαστηριον σου, Κυριε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.26.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Psalms 26:7",
      "text": "δια να καμω να αντηχηση φωνη αινεσεως, και δια να διηγηθω παντα τα θαυμασια σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.26.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Psalms 26:8",
      "text": "Κυριε, ηγαπησα την κατοικησιν του οικου σου και τον τοπον της σκηνης της δοξης σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.26.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Psalms 26:9",
      "text": "Μη συμπεριλαβης μετα αμαρτωλων την ψυχην μου και μετα ανδρων αιματων την ζωην μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.26.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Psalms 26:10",
      "text": "εις των οποιων τας χειρας ειναι ανομια, και η δεξια αυτων πληρης δωρων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.26.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Psalms 26:11",
      "text": "Αλλ' εγω θελω περιπατει εν ακακια μου λυτρωσον με και ελεησον με.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.26.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Psalms 26:12",
      "text": "Ο πους μου ισταται εν τη ευθυτητι εν εκκλησιαις θελω ευλογει τον Κυριον.",
      "paragraphStart": false
    }
  ]
}
