{
  "chapter": {
    "id": "lxx-greek:psalms.61",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 61,
    "referenceLabel": "Psalms 61",
    "summary": "Source text for Psalms 61 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.61.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 1,
      "referenceLabel": "Psalms 61:1",
      "text": "\"Εις τον πρωτον μουσικον, επι Νεγινωθ. Ψαλμος του Δαβιδ.\" Εισακουσον, Θεε, της κραυγης μου προσεξον εις την προσευχην μου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.61.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 2,
      "referenceLabel": "Psalms 61:2",
      "text": "Απο των περατων της γης προς σε θελω κραζει, οταν λιποθυμη η καρδια μου. Οδηγησον με εις την πετραν, ητις ειναι παραπολυ υψηλη δι' εμε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.61.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 3,
      "referenceLabel": "Psalms 61:3",
      "text": "Διοτι συ εγεινες καταφυγη μου, πυργος ισχυρος εμπροσθεν του εχθρου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.61.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 4,
      "referenceLabel": "Psalms 61:4",
      "text": "Εν τη σκηνη σου θελω παροικει διαπαντος θελω καταφυγει υπο την σκεπην των πτερυγων σου. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.61.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 5,
      "referenceLabel": "Psalms 61:5",
      "text": "Διοτι συ, Θεε, εισηκουσας των ευχων μου εδωκας μοι την κληρονομιαν των φοβουμενων το ονομα σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.61.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 6,
      "referenceLabel": "Psalms 61:6",
      "text": "Θελεις προσθεσει ημερας εις τας ημερας του βασιλεως τα ετη αυτου ας ηναι εις γενεαν και γενεαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.61.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 7,
      "referenceLabel": "Psalms 61:7",
      "text": "Θελει διαμενει εις τον αιωνα ενωπιον του Θεου καμε να διαφυλαττωσιν αυτον το ελεος και η αληθεια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.61.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 8,
      "referenceLabel": "Psalms 61:8",
      "text": "Ουτω θελω ψαλμωδει διαπαντος το ονομα σου, δια να εκπληρω τας ευχας μου καθ' ημεραν.",
      "paragraphStart": false
    }
  ]
}
