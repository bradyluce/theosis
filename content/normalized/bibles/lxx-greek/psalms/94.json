{
  "chapter": {
    "id": "lxx-greek:psalms.94",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 94,
    "referenceLabel": "Psalms 94",
    "summary": "Source text for Psalms 94 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.94.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 1,
      "referenceLabel": "Psalms 94:1",
      "text": "Δευτε, ας αγαλλιασθωμεν εις τον Κυριον ας αλαλαξωμεν εις το φρουριον της σωτηριας ημων.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.94.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 2,
      "referenceLabel": "Psalms 94:2",
      "text": "Ας προφθασωμεν ενωπιον αυτου μετα δοξολογιας εν ψαλμοις ας αλαλαξωμεν εις αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.94.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 3,
      "referenceLabel": "Psalms 94:3",
      "text": "Διοτι Θεος μεγας ειναι ο Κυριος, και Βασιλευς μεγας υπερ παντας τους θεους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.94.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 4,
      "referenceLabel": "Psalms 94:4",
      "text": "Διοτι εις αυτου την χειρα ειναι τα βαθη της γης και τα υψη των ορεων ειναι αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.94.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 5,
      "referenceLabel": "Psalms 94:5",
      "text": "Διοτι αυτου ειναι η θαλασσα, και αυτος εκαμεν αυτην και την ξηραν αι χειρες αυτου επλασαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.94.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 6,
      "referenceLabel": "Psalms 94:6",
      "text": "Δευτε, ας προσκυνησωμεν και ας προσπεσωμεν ας γονατισωμεν ενωπιον του Κυριου, του Ποιητου ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.94.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 7,
      "referenceLabel": "Psalms 94:7",
      "text": "Διοτι αυτος ειναι ο Θεος ημων και ημεις λαος της βοσκης αυτου και προβατα της χειρος αυτου. Σημερον εαν ακουσητε της φωνης αυτου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.94.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 8,
      "referenceLabel": "Psalms 94:8",
      "text": "μη σκληρυνητε την καρδιαν σας, ως εν τω παροργισμω, ως εν τη ημερα του πειρασμου εν τη ερημω",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.94.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 9,
      "referenceLabel": "Psalms 94:9",
      "text": "οπου οι πατερες σας με επειρασαν, με εδοκιμασαν και ειδον τα εργα μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.94.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 10,
      "referenceLabel": "Psalms 94:10",
      "text": "Τεσσαρακοντα ετη δυσηρεστηθην με την γενεαν εκεινην, και ειπα, ουτος ειναι λαος πεπλανημενος την καρδιαν, και αυτοι δεν εγνωρισαν τας οδους μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.94.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 11,
      "referenceLabel": "Psalms 94:11",
      "text": "Δια τουτο ωμοσα εν τη οργη μου, οτι εις την αναπαυσιν μου δεν θελουσιν εισελθει.",
      "paragraphStart": false
    }
  ]
}
