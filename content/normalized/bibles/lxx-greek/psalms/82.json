{
  "chapter": {
    "id": "lxx-greek:psalms.82",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 82,
    "referenceLabel": "Psalms 82",
    "summary": "Source text for Psalms 82 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.82.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 1,
      "referenceLabel": "Psalms 82:1",
      "text": "\"Ωιδη Ψαλμου του Ασαφ.\" Θεε, μη σιωπησης μη σιγησης και μη ησυχασης, Θεε.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.82.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 2,
      "referenceLabel": "Psalms 82:2",
      "text": "Διοτι, ιδου, οι εχθροι σου θορυβουσι, και οι μισουντες σε υψωσαν κεφαλην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 3,
      "referenceLabel": "Psalms 82:3",
      "text": "Κακην βουλην ελαβον κατα του λαου σου και συνεβουλευθησαν κατα των εκλεκτων σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 4,
      "referenceLabel": "Psalms 82:4",
      "text": "Ειπον, Ελθετε, και ας εξολοθρευσωμεν αυτους απο του να ηναι εθνος και το ονομα του Ισραηλ ας μη μνημονευηται πλεον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 5,
      "referenceLabel": "Psalms 82:5",
      "text": "Διοτι εκ συμφωνου συνεβουλευθησαν ομου συνεμαχησαν κατα σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 6,
      "referenceLabel": "Psalms 82:6",
      "text": "αι σκηναι του Εδωμ και οι Ισμαηλιται ο Μωαβ και οι Αγαρηνοι",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 7,
      "referenceLabel": "Psalms 82:7",
      "text": "Ο Γεβαλ και ο Αμμων και ο Αμαληκ οι Φιλισταιοι μετα των κατοικουντων την Τυρον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 8,
      "referenceLabel": "Psalms 82:8",
      "text": "Και αυτος ο Ασσουρ ηνωθη μετ' αυτων εβοηθησαν τους υιους του Λωτ. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 9,
      "referenceLabel": "Psalms 82:9",
      "text": "Καμε εις αυτους ως εις τους Μαδιανιτας, ως εις τον Σισαραν, ως εις τον Ιαβειν εν τω χειμαρρω Κεισων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 10,
      "referenceLabel": "Psalms 82:10",
      "text": "οιτινες απωλεσθησαν εν Εν-δωρ εγειναν κοπρος δια την γην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 11,
      "referenceLabel": "Psalms 82:11",
      "text": "Καμε τους αρχοντας αυτων ως τον Ωρηβ και ως τον Ζηβ και ως τον Ζεβεε και ως τον Σαλμαναν παντας τους αρχηγους αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 12,
      "referenceLabel": "Psalms 82:12",
      "text": "οιτινες ειπον, Ας κληρονομησωμεν εις εαυτους τα κατοικητηρια του Θεου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 13,
      "referenceLabel": "Psalms 82:13",
      "text": "Θεε μου, καμε αυτους ως τροχον, ως αχυρον κατα προσωπον ανεμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 14,
      "referenceLabel": "Psalms 82:14",
      "text": "Ως το πυρ καιει το δασος, και ως η φλοξ κατακαιει τα ορη,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 15,
      "referenceLabel": "Psalms 82:15",
      "text": "ουτω καταδιωξον αυτους με την ανεμοζαλην σου, και με τον ανεμοστροβιλον σου κατατρομαξον αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 16,
      "referenceLabel": "Psalms 82:16",
      "text": "Γεμισον τα προσωπα αυτων απο ατιμιας, και θελουσι ζητησει το ονομα σου, Κυριε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 17,
      "referenceLabel": "Psalms 82:17",
      "text": "Ας καταισχυνθωσι και ας ταραχθωσι διαπαντος και ας εντραπωσι και ας απολεσθωσι",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 18,
      "referenceLabel": "Psalms 82:18",
      "text": "και ας γνωρισωσιν οτι συ, του οποιου το ονομα ειναι Κυριος, εισαι ο μονος Υψιστος επι πασαν την γην.",
      "paragraphStart": false
    }
  ]
}
