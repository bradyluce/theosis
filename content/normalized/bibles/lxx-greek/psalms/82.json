{
  "chapter": {
    "id": "lxx-greek:psalms.82",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 82,
    "referenceLabel": "Psalms 82",
    "summary": "Source text for Psalms 82 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.82.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 1,
      "referenceLabel": "Psalms 82:1",
      "text": "\"Ψαλμος του Ασαφ.\" Ο Θεος ισταται εν τη συναξει των δυνατων αναμεσον των θεων θελει κρινει.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.82.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 2,
      "referenceLabel": "Psalms 82:2",
      "text": "Εως ποτε θελετε κρινει αδικως, και θελετε προσωποληπτει τους ασεβεις; Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 3,
      "referenceLabel": "Psalms 82:3",
      "text": "Κρινατε τον πτωχον και τον ορφανον καμετε δικαιοσυνην εις τον τεθλιμμενον και πενητα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 4,
      "referenceLabel": "Psalms 82:4",
      "text": "Ελευθερονετε τον πτωχον και τον πενητα λυτρονετε αυτον εκ χειρος των ασεβων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 5,
      "referenceLabel": "Psalms 82:5",
      "text": "Δεν γνωριζουσιν, ουδε νοουσι περιπατουσιν εν σκοτει παντα τα θεμελια της γης σαλευονται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 6,
      "referenceLabel": "Psalms 82:6",
      "text": "Εγω ειπα, θεοι εισθε σεις και υιοι Υψιστου παντες",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 7,
      "referenceLabel": "Psalms 82:7",
      "text": "σεις ομως ως ανθρωποι αποθνησκετε, και ως εις των αρχοντων πιπτετε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.82.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 8,
      "referenceLabel": "Psalms 82:8",
      "text": "Αναστα, Θεε, κρινον την γην διοτι συ θελεις κατακληρονομησει παντα τα εθνη.",
      "paragraphStart": false
    }
  ]
}
