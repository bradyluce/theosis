{
  "chapter": {
    "id": "lxx-greek:psalms.49",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 49,
    "referenceLabel": "Psalms 49",
    "summary": "Source text for Psalms 49 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.49.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 1,
      "referenceLabel": "Psalms 49:1",
      "text": "\"Εις τον πρωτον μουσικον. Ψαλμος δια τους υιους Κορε.\" Ακουσατε ταυτα, παντες οι λαοι ακροασθητε, παντες οι κατοικοι της οικουμενης",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.49.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 2,
      "referenceLabel": "Psalms 49:2",
      "text": "μικροι τε και μεγαλοι, πλουσιοι ομου και πενητες.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.49.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 3,
      "referenceLabel": "Psalms 49:3",
      "text": "Το στομα μου θελει λαλησει σοφιαν και η μελετη της καρδιας μου ειναι συνεσις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.49.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 4,
      "referenceLabel": "Psalms 49:4",
      "text": "Θελω κλινει εις παραβολην το ωτιον μου θελω εκθεσει εν κιθαρα το αινιγμα μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.49.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 5,
      "referenceLabel": "Psalms 49:5",
      "text": "Δια τι να φοβωμαι εν ημεραις συμφορας, οταν με περικυκλωση η ανομια των ενεδρευοντων με;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.49.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 6,
      "referenceLabel": "Psalms 49:6",
      "text": "Οιτινες ελπιζουσιν εις τα αγαθα αυτων και καυχωνται εις το πληθος του πλουτου αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.49.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 7,
      "referenceLabel": "Psalms 49:7",
      "text": "ουδεις δυναται ποτε να εξαγοραση αδελφον, μηδε να δωση εις τον Θεον λυτρον δι' αυτον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.49.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 8,
      "referenceLabel": "Psalms 49:8",
      "text": "διοτι πολυτιμος ειναι η απολυτρωσις της ψυχης αυτων, και ανευρητος διαπαντος,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.49.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 9,
      "referenceLabel": "Psalms 49:9",
      "text": "ωστε να ζη αιωνιως, να μη ιδη διαφθοραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.49.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 10,
      "referenceLabel": "Psalms 49:10",
      "text": "Διοτι βλεπει τους σοφους αποθνησκοντας, καθως και τον αφρονα και τον ανοητον απολλυμενους και καταλειποντας εις αλλους τα αγαθα αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.49.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 11,
      "referenceLabel": "Psalms 49:11",
      "text": "Ο εσωτερικος λογισμος αυτων ειναι οτι οι οικοι αυτων θελουσιν υπαρχει εις τον αιωνα, αι κατοικιαι αυτων εις γενεαν και γενεαν ονομαζουσι τα υποστατικα αυτων με τα ιδια αυτων ονοματα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.49.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 12,
      "referenceLabel": "Psalms 49:12",
      "text": "Πλην ο ανθρωπος ο εν τιμη δεν διαμενει, ωμοιωθη με τα κτηνη τα φθειρομενα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.49.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 13,
      "referenceLabel": "Psalms 49:13",
      "text": "Αυτη η οδος αυτων ειναι μωρια αυτων και ομως οι απογονοι αυτων ηδυνονται εις τα λογια αυτων. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.49.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 14,
      "referenceLabel": "Psalms 49:14",
      "text": "Ως προβατα εβληθησαν εις τον αδην θανατος θελει ποιμανει αυτους και οι ευθεις θελουσι κατακυριευσει αυτους το πρωι η δε δυναμις αυτων θελει παλαιωθη εν τω αδη, αφου εκαστος αφηση την κατοικιαν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.49.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 15,
      "referenceLabel": "Psalms 49:15",
      "text": "Αλλ' ο Θεος θελει λυτρωσει την ψυχην μου εκ χειρος αδου διοτι θελει με δεχθη. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.49.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 16,
      "referenceLabel": "Psalms 49:16",
      "text": "Μη φοβου οταν πλουτηση ανθρωπος, οταν αυξηση η δοξα της οικιας αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.49.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 17,
      "referenceLabel": "Psalms 49:17",
      "text": "διοτι εν τω θανατω αυτου, δεν θελει συμπαραλαβει ουδεν, ουδε θελει καταβη κατοπιν αυτου η δοξα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.49.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 18,
      "referenceLabel": "Psalms 49:18",
      "text": "Αν και ηυλογησε την ψυχην αυτου εν τη ζωη αυτου, και οι ανθρωποι θελωσι σε επαινει αγαθοποιουντα σεαυτον,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.49.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 19,
      "referenceLabel": "Psalms 49:19",
      "text": "Θελει υπαγει εις την γενεαν των πατερων αυτου εις τον αιωνα δεν θελουσιν ιδει φως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.49.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 20,
      "referenceLabel": "Psalms 49:20",
      "text": "Ο ανθρωπος ο εν τιμη και μη εννοων ωμοιωθη με τα κτηνη τα φθειρομενα.",
      "paragraphStart": false
    }
  ]
}
