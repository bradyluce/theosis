{
  "chapter": {
    "id": "lxx-greek:psalms.146",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 146,
    "referenceLabel": "Psalms 146",
    "summary": "Source text for Psalms 146 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.146.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 1,
      "referenceLabel": "Psalms 146:1",
      "text": "Αινειτε τον Κυριον διοτι ειναι καλον να ψαλλωμεν εις τον Θεον ημων διοτι ειναι τερπνον, η αινεσις πρεπουσα.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.146.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 2,
      "referenceLabel": "Psalms 146:2",
      "text": "Ο Κυριος οικοδομει την Ιερουσαλημ θελει συναξει τους διεσπαρμενους του Ισραηλ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.146.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 3,
      "referenceLabel": "Psalms 146:3",
      "text": "Ιατρευει τους συντετριμμενους την καρδιαν και δενει τας πληγας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.146.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 4,
      "referenceLabel": "Psalms 146:4",
      "text": "Αριθμει τα πληθη των αστρων Καλει τα παντα ονομαστι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.146.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 5,
      "referenceLabel": "Psalms 146:5",
      "text": "Μεγας ο Κυριος ημων και μεγαλη η δυναμις αυτου η συνεσις αυτου αμετρητος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.146.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 6,
      "referenceLabel": "Psalms 146:6",
      "text": "Ο Κυριος υψονει τους πραους, τους δε ασεβεις ταπεινονει εως εδαφους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.146.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 7,
      "referenceLabel": "Psalms 146:7",
      "text": "Ψαλατε εις τον Κυριον ευχαριστουντες ψαλμωδειτε εις τον Θεον ημων εν κιθαρα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.146.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 8,
      "referenceLabel": "Psalms 146:8",
      "text": "τον σκεπαζοντα τον ουρανον με νεφελας τον ετοιμαζοντα βροχην δια την γην τον αναδιδοντα χορτον επι των ορεων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.146.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 9,
      "referenceLabel": "Psalms 146:9",
      "text": "τον διδοντα εις τα κτηνη την τροφην αυτων και εις τους νεοσσους των κορακων, οιτινες κραζουσι προς αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.146.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 10,
      "referenceLabel": "Psalms 146:10",
      "text": "Δεν χαιρει εις την δυναμιν του ιππου δεν ηδυνεται εις τους ποδας του ανδρος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.146.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 11,
      "referenceLabel": "Psalms 146:11",
      "text": "Ο Κυριος ηδυνεται εις τους φοβουμενους αυτον, εις τους ελπιζοντας επι το ελεος αυτου.",
      "paragraphStart": false
    }
  ]
}
