{
  "chapter": {
    "id": "lxx-greek:psalms.119",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 119,
    "referenceLabel": "Psalms 119",
    "summary": "Source text for Psalms 119 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.119.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 1,
      "referenceLabel": "Psalms 119:1",
      "text": "\"Ωιδη των Αναβαθμων.\" Εν τη θλιψει μου εκραξα προς τον Κυριον, και εισηκουσε μου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.119.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 2,
      "referenceLabel": "Psalms 119:2",
      "text": "Κυριε, λυτρωσον την ψυχην μου απο χειλεων ψευδων, απο γλωσσης δολιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.119.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 3,
      "referenceLabel": "Psalms 119:3",
      "text": "Τι θελει σοι δωσει η τι θελει σοι προσθεσει, η δολια γλωσσα;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.119.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 4,
      "referenceLabel": "Psalms 119:4",
      "text": "Τα ηκονημενα βελη του δυνατου, μετα ανθρακων αρκευθου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.119.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 5,
      "referenceLabel": "Psalms 119:5",
      "text": "Ουαι εις εμε, διοτι παροικω εν Μεσεχ, κατοικω εν ταις σκηναις του Κηδαρ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.119.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 6,
      "referenceLabel": "Psalms 119:6",
      "text": "Πολυν καιρον κατωκησεν η ψυχη μου μετα των μισουντων την ειρηνην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.119.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 7,
      "referenceLabel": "Psalms 119:7",
      "text": "Εγω αγαπω την ειρηνην αλλ' οταν ομιλω, αυτοι ετοιμαζονται δια πολεμον.",
      "paragraphStart": false
    }
  ]
}
