{
  "chapter": {
    "id": "lxx-greek:psalms.89",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 89,
    "referenceLabel": "Psalms 89",
    "summary": "Source text for Psalms 89 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.89.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 1,
      "referenceLabel": "Psalms 89:1",
      "text": "\"Μασχιλ του Εθαν του Εζραιτου.\" Τα ελεη του Κυριου εις τον αιωνα θελω ψαλλει δια του στοματος μου θελω αναγγελλει την αληθειαν σου εις γενεαν και γενεαν.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.89.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 2,
      "referenceLabel": "Psalms 89:2",
      "text": "Διοτι ειπα, το ελεος σου θελει θεμελιωθη εις τον αιωνα εν τοις ουρανοις θελεις στερεωσει την αληθειαν σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 3,
      "referenceLabel": "Psalms 89:3",
      "text": "Εκαμα διαθηκην μετα του εκλεκτου μου ωμοσα προς Δαβιδ τον δουλον μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 4,
      "referenceLabel": "Psalms 89:4",
      "text": "Διαπαντος θελω στερεωσει το σπερμα σου, και θελω οικοδομησει τον θρονον σου εις γενεαν και γενεαν. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 5,
      "referenceLabel": "Psalms 89:5",
      "text": "Και οι ουρανοι θελουσιν υμνει τα θαυμασια σου, Κυριε και η αληθεια σου θελει εξυμνεισθαι εν τη συναξει των αγιων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 6,
      "referenceLabel": "Psalms 89:6",
      "text": "Διοτι τις εν τω ουρανω δυναται να εξισωθη με τον Κυριον; Τις μεταξυ των υιων των δυνατων δυναται να ομοιωθη με τον Κυριον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 7,
      "referenceLabel": "Psalms 89:7",
      "text": "Ο Θεος ειναι φοβερος σφοδρα εν τη βουλη των αγιων και σεβαστος εν πασι τοις κυκλω αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 8,
      "referenceLabel": "Psalms 89:8",
      "text": "Κυριε Θεε των δυναμεων, τις ομοιος σου; δυνατος εισαι, Κυριε, και η αληθεια σου ειναι κυκλω σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 9,
      "referenceLabel": "Psalms 89:9",
      "text": "Συ δεσποζεις την επαρσιν της θαλασσης οταν σηκονωνται τα κυματα αυτης, συ ταπεινονεις αυτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 10,
      "referenceLabel": "Psalms 89:10",
      "text": "Συ συνετριψας την Ρααβ ως τραυματιαν δια του βραχιονος της δυναμεως σου διεσκορπισας τους εχθρους σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 11,
      "referenceLabel": "Psalms 89:11",
      "text": "Σου ειναι οι ουρανοι και σου η γη την οικουμενην και το πληρωμα αυτης, συ εθεμελιωσας αυτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 12,
      "referenceLabel": "Psalms 89:12",
      "text": "Τον βορραν και τον νοτον, συ εκτισας αυτους Θαβωρ και Αερμων εις το ονομα σου θελουσιν αγαλλεσθαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 13,
      "referenceLabel": "Psalms 89:13",
      "text": "Εχεις ισχυρον τον βραχιονα κραταια ειναι η χειρ σου υψηλη η δεξια σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 14,
      "referenceLabel": "Psalms 89:14",
      "text": "Η δικαιοσυνη και η κρισις ειναι η βασις του θρονου σου το ελεος και η αληθεια θελουσι προπορευεσθαι εμπροσθεν του προσωπου σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 15,
      "referenceLabel": "Psalms 89:15",
      "text": "Μακαριος ο λαος ο γινωσκων αλαλαγμον θελουσι περιπατει, Κυριε, εν τω φωτι του προσωπου σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 16,
      "referenceLabel": "Psalms 89:16",
      "text": "Εις το ονομα σου θελουσιν αγαλλεσθαι ολην την ημεραν και εις την δικαιοσυνην σου θελουσιν υψωθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 17,
      "referenceLabel": "Psalms 89:17",
      "text": "Διοτι συ εισαι το καυχημα της δυναμεως αυτων και δια της ευμενειας σου θελει υψωθη το κερας ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 18,
      "referenceLabel": "Psalms 89:18",
      "text": "Διοτι ο Κυριος ειναι η ασπις ημων και ο Αγιος του Ισραηλ ο βασιλευς ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 19,
      "referenceLabel": "Psalms 89:19",
      "text": "Ελαλησας τοτε δι' οραματος προς τον οσιον σου και ειπας εθεσα βοηθειαν επι τον δυνατον υψωσα εκλεκτον εκ του λαου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 20,
      "referenceLabel": "Psalms 89:20",
      "text": "Ευρηκα Δαβιδ τον δουλον μου με το ελαιον το αγιον μου εχρισα αυτον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 21,
      "referenceLabel": "Psalms 89:21",
      "text": "η χειρ μου θελει στερεονει αυτον και ο βραχιων μου θελει ενδυναμονει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 22,
      "referenceLabel": "Psalms 89:22",
      "text": "δεν θελει υπερισχυσει εχθρος κατ' αυτου ουδε υιος ανομιας θελει ταλαιπωρησει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 23,
      "referenceLabel": "Psalms 89:23",
      "text": "Και θελω κατακοψει απ' εμπροσθεν αυτου τους εχθρους αυτου και τους μισουντας αυτον θελω κατατροπωσει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 24,
      "referenceLabel": "Psalms 89:24",
      "text": "Η δε αληθεια μου και το ελεος μου θελουσιν εισθαι μετ' αυτου και εν τω ονοματι μου θελει υψωθη το κερας αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.25",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 25,
      "referenceLabel": "Psalms 89:25",
      "text": "Και θελω θεσει την χειρα αυτου επι την θαλασσαν, και επι τους ποταμους την δεξιαν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.26",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 26,
      "referenceLabel": "Psalms 89:26",
      "text": "Αυτος θελει κραξει προς εμε, Πατηρ μου εισαι, Θεος μου και πετρα της σωτηριας μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.27",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 27,
      "referenceLabel": "Psalms 89:27",
      "text": "Εγω βεβαιως θελω καμει αυτον πρωτοτοκον μου, Υψιστον επι τους βασιλεις της γης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.28",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 28,
      "referenceLabel": "Psalms 89:28",
      "text": "Διαπαντος θελω φυλαττει εις αυτον το ελεος μου, και η διαθηκη μου θελει εισθαι στερεα μετ' αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.29",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 29,
      "referenceLabel": "Psalms 89:29",
      "text": "Και θελω καμει να διαμενη το σπερμα αυτου εις τον αιωνα, και ο θρονος αυτου ως αι ημεραι του ουρανου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.30",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 30,
      "referenceLabel": "Psalms 89:30",
      "text": "Εαν εγκαταλιπωσιν οι υιοι αυτου τον νομον μου και εις τας κρισεις μου δεν περιπατησωσιν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.31",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 31,
      "referenceLabel": "Psalms 89:31",
      "text": "Εαν παραβωσι τα διαταγματα μου και δεν φυλαξωσι τας εντολας μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.32",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 32,
      "referenceLabel": "Psalms 89:32",
      "text": "Τοτε θελω επισκεφθη με ραβδον τας παραβασεις αυτων και με πληγας τας παρανομιας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.33",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 33,
      "referenceLabel": "Psalms 89:33",
      "text": "Το ελεος μου ομως δεν θελω αφαιρεσει απ' αυτου, ουδε θελω ψευσθη κατα της αληθειας μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.34",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 34,
      "referenceLabel": "Psalms 89:34",
      "text": "Δεν θελω παραβη την διαθηκην μου, ουδε θελω αθετησει ο, τι εξηλθεν εκ των χειλεων μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.35",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 35,
      "referenceLabel": "Psalms 89:35",
      "text": "Απαξ ωμοσα εις την αγιοτητα μου, οτι δεν θελω ψευσθη προς τον Δαβιδ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.36",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 36,
      "referenceLabel": "Psalms 89:36",
      "text": "Το σπερμα αυτου θελει διαμενει εις τον αιωνα και ο θρονος αυτου ως ο ηλιος, ενωπιον μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.37",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 37,
      "referenceLabel": "Psalms 89:37",
      "text": "Ως η σεληνη θελει στερεωθη εις τον αιωνα και μαρτυς πιστος εν τω ουρανω. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.38",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 38,
      "referenceLabel": "Psalms 89:38",
      "text": "Αλλα συ απεβαλες και εβδελυχθης, ωργισθης κατα του χριστου σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.39",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 39,
      "referenceLabel": "Psalms 89:39",
      "text": "ηκυρωσας την διαθηκην του δουλου σου εβεβηλωσας το διαδημα αυτου εως της γης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.40",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 40,
      "referenceLabel": "Psalms 89:40",
      "text": "Κατεβαλες παντας τους φραγμους αυτου ηφανισας τα οχυρωματα αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.41",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 41,
      "referenceLabel": "Psalms 89:41",
      "text": "διαρπαζουσιν αυτον παντες οι διαβαινοντες την οδον κατεσταθη ονειδος εις τους γειτονας αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.42",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 42,
      "referenceLabel": "Psalms 89:42",
      "text": "Υψωσας την δεξιαν των εναντιων αυτου ευφρανας παντας τους εχθρους αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.43",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 43,
      "referenceLabel": "Psalms 89:43",
      "text": "ημβλυνας μαλιστα το κοπτερον της ρομφαιας αυτου και δεν εστερεωσας αυτον εν τη μαχη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.44",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 44,
      "referenceLabel": "Psalms 89:44",
      "text": "Επαυσας την δοξαν αυτου και τον θρονον αυτου ερριψας κατα γης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.45",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 45,
      "referenceLabel": "Psalms 89:45",
      "text": "Ωλιγοστευσας τας ημερας της νεοτητος αυτου ενεδυσας αυτον με αισχυνην. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.46",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 46,
      "referenceLabel": "Psalms 89:46",
      "text": "Εως ποτε, Κυριε; θελεις κρυπτεσθαι διαπαντος; θελει καιεσθαι ως πυρ η οργη σου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.47",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 47,
      "referenceLabel": "Psalms 89:47",
      "text": "Μνησθητι ποσον βραχυς ειναι ο καιρος μου, εν τινι ματαιοτητι εποιησας παντας τους υιους των ανθρωπων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.48",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 48,
      "referenceLabel": "Psalms 89:48",
      "text": "Τις ανθρωπος θελει ζησει και δεν θελει ιδει θανατον; τις θελει λυτρωσει την ψυχην αυτου εκ της χειρος του αδου; Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.49",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 49,
      "referenceLabel": "Psalms 89:49",
      "text": "Που ειναι τα ελεη σου τα αρχαια, Κυριε, τα οποια ωμοσας προς τον Δαβιδ εν τη αληθεια σου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.50",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 50,
      "referenceLabel": "Psalms 89:50",
      "text": "Μνησθητι, Κυριε, του ονειδισμου των δουλων σου, τον οποιον φερω εν τω κολπω μου υπο τοσουτων πολυαριθμων λαων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.51",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 51,
      "referenceLabel": "Psalms 89:51",
      "text": "με τον οποιον ωνειδισαν οι εχθροι σου, Κυριε με τον οποιον ωνειδισαν τα ιχνη του χριστου σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.89.52",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 52,
      "referenceLabel": "Psalms 89:52",
      "text": "Ευλογητος Κυριος εις τον αιωνα. Αμην, και αμην.",
      "paragraphStart": false
    }
  ]
}
