{
  "chapter": {
    "id": "lxx-greek:psalms.148",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 148,
    "referenceLabel": "Psalms 148",
    "summary": "Source text for Psalms 148 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.148.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 1,
      "referenceLabel": "Psalms 148:1",
      "text": "Αινειτε τον Κυριον. Αινειτε τον Κυριον εκ των ουρανων αινειτε αυτον εν τοις υψιστοις.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.148.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 2,
      "referenceLabel": "Psalms 148:2",
      "text": "Αινειτε αυτον, παντες οι αγγελοι αυτου αινειτε αυτον, πασαι αι δυναμεις αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.148.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 3,
      "referenceLabel": "Psalms 148:3",
      "text": "Αινειτε αυτον, ηλιε και σεληνη αινειτε αυτον, παντα τα αστρα του φωτος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.148.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 4,
      "referenceLabel": "Psalms 148:4",
      "text": "Αινειτε αυτον, οι ουρανοι των ουρανων, και τα υδατα τα υπερανω των ουρανων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.148.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 5,
      "referenceLabel": "Psalms 148:5",
      "text": "Ας αινωσι το ονομα του Κυριου διοτι αυτος προσεταξε, και εκτισθησαν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.148.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 6,
      "referenceLabel": "Psalms 148:6",
      "text": "και εστερεωσεν αυτα εις τον αιωνα και εις τον αιωνα εθεσε διαταγμα, το οποιον δεν θελει παρελθει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.148.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 7,
      "referenceLabel": "Psalms 148:7",
      "text": "Αινειτε τον Κυριον εκ της γης, δρακοντες και πασαι αβυσσοι",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.148.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 8,
      "referenceLabel": "Psalms 148:8",
      "text": "πυρ και χαλαζα, χιων και ατμις, ανεμοστροβιλος, ο εκτελων τον λογον αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.148.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 9,
      "referenceLabel": "Psalms 148:9",
      "text": "τα ορη και παντα τα βουνα δενδρα καρποφορα και πασαι κεδροι",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.148.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 10,
      "referenceLabel": "Psalms 148:10",
      "text": "τα θηρια και παντα τα κτηνη ερπετα και πετεινα πτερωτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.148.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 11,
      "referenceLabel": "Psalms 148:11",
      "text": "Βασιλεις της γης και παντες λαοι αρχοντες και παντες κριται της γης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.148.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 12,
      "referenceLabel": "Psalms 148:12",
      "text": "νεοι τε και παρθενοι, γεροντες μετα νεωτερων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.148.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 13,
      "referenceLabel": "Psalms 148:13",
      "text": "ας αινωσι το ονομα του Κυριου διοτι το ονομα αυτου μονου ειναι υψωμενον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.148.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 14,
      "referenceLabel": "Psalms 148:14",
      "text": "Η δοξα αυτου ειναι επι την γην και τον ουρανον και αυτος υψωσε κερας εις τον λαον αυτου, υμνον εις παντας τους οσιους αυτου, εις τους υιους Ισραηλ, λαον οστις ειναι πλησιον αυτου. Αλληλουια.",
      "paragraphStart": false
    }
  ]
}
