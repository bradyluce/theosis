{
  "chapter": {
    "id": "lxx-greek:psalms.95",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 95,
    "referenceLabel": "Psalms 95",
    "summary": "Source text for Psalms 95 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.95.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 1,
      "referenceLabel": "Psalms 95:1",
      "text": "Ψαλατε εις τον Κυριον ασμα νεον ψαλατε εις τον Κυριον, πασα η γη.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.95.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 2,
      "referenceLabel": "Psalms 95:2",
      "text": "Ψαλατε εις τον Κυριον ευλογειτε το ονομα αυτου κηρυττετε απο ημερας εις ημεραν την σωτηριαν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.95.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 3,
      "referenceLabel": "Psalms 95:3",
      "text": "Αναγγειλατε εν τοις εθνεσι την δοξαν αυτου, εν πασι τοις λαοις τα θαυμασια αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.95.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 4,
      "referenceLabel": "Psalms 95:4",
      "text": "Διοτι μεγας ο Κυριος και αξιυμνητος σφοδρα ειναι φοβερος υπερ παντας τους θεους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.95.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 5,
      "referenceLabel": "Psalms 95:5",
      "text": "Διοτι παντες οι θεοι των εθνων ειναι ειδωλα ο δε Κυριος τους ουρανους εποιησε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.95.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 6,
      "referenceLabel": "Psalms 95:6",
      "text": "Δοξα και μεγαλοπρεπεια ειναι ενωπιον αυτου ισχυς και ωραιοτης εν τω αγιαστηριω αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.95.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 7,
      "referenceLabel": "Psalms 95:7",
      "text": "Αποδοτε εις τον Κυριον, πατριαι των λαων, αποδοτε εις τον Κυριον δοξαν και ισχυν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.95.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 8,
      "referenceLabel": "Psalms 95:8",
      "text": "Αποδοτε εις τον Κυριον την δοξαν του ονοματος αυτου λαβετε προσφορας και εισελθετε εις τας αυλας αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.95.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 9,
      "referenceLabel": "Psalms 95:9",
      "text": "Προσκυνησατε τον Κυριον εν τω μεγαλοπρεπει αγιαστηριω αυτου φοβεισθε απο προσωπου αυτου, πασα η γη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.95.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 10,
      "referenceLabel": "Psalms 95:10",
      "text": "Ειπατε εν τοις εθνεσιν, Ο Κυριος βασιλευει η οικουμενη θελει βεβαιως εισθαι εστερεωμενη δεν θελει σαλευθη αυτος θελει κρινει τους λαους εν ευθυτητι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.95.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 11,
      "referenceLabel": "Psalms 95:11",
      "text": "Ας ευφραινωνται οι ουρανοι, και ας αγαλλεται η γη ας ηχη η θαλασσα και το πληρωμα αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.95.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 12,
      "referenceLabel": "Psalms 95:12",
      "text": "Ας χαιρωσιν αι πεδιαδες και παντα τα εν αυταις τοτε θελουσιν αγαλλεσθαι παντα τα δενδρα του δασους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.95.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 13,
      "referenceLabel": "Psalms 95:13",
      "text": "ενωπιον του Κυριου διοτι ερχεται, διοτι ερχεται δια να κρινη την γην θελει κρινει την οικουμενην εν δικαιοσυνη και τους λαους εν τη αληθεια αυτου.",
      "paragraphStart": false
    }
  ]
}
