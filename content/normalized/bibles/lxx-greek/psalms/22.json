{
  "chapter": {
    "id": "lxx-greek:psalms.22",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 22,
    "referenceLabel": "Psalms 22",
    "summary": "Source text for Psalms 22 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.22.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Psalms 22:1",
      "text": "\"Εις τον πρωτον μουσικον, επι Αγελεθ Σαχαρ. Ψαλμος του Δαβιδ.\" Θεε μου, Θεε μου, δια τι με εγκατελιπες; δια τι ιστασαι μακραν απο της σωτηριας μου και απο των λογων των στεναγμων μου;",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.22.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Psalms 22:2",
      "text": "Θεε μου, κραζω την ημεραν, και δεν αποκρινεσαι και την νυκτα, και δεν σιωπω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Psalms 22:3",
      "text": "Συ δε ο Αγιος κατοικεις μεταξυ των επαινων του Ισραηλ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Psalms 22:4",
      "text": "Επι σε ηλπισαν οι πατερες ημων ηλπισαν, και ηλευθερωσας αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Psalms 22:5",
      "text": "Προς σε εκραξαν και εσωθησαν επι σε ηλπισαν και δεν κατησχυνθησαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Psalms 22:6",
      "text": "Εγω δε ειμαι σκωληξ και ουχι ανθρωπος ονειδος ανθρωπων και εξουθενημα του λαου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Psalms 22:7",
      "text": "Με εμυκτηρισαν παντες οι βλεποντες με ανοιγουσι τα χειλη, κινουσι την κεφαλην, λεγοντες,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Psalms 22:8",
      "text": "Ηλπισεν επι τον Κυριον ας ελευθερωση αυτον ας σωση αυτον, επειδη θελει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Psalms 22:9",
      "text": "Αλλα συ εισαι ο εκσπασας με εκ της κοιλιας η ελπις μου απο των μαστων της μητρος μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Psalms 22:10",
      "text": "Επι σε ερριφθην εκ μητρας εκ κοιλιας της μητρος μου συ εισαι ο Θεος μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Psalms 22:11",
      "text": "Μη απομακρυνθης απ' εμου διοτι η θλιψις ειναι πλησιον διοτι ουδεις ο βοηθων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Psalms 22:12",
      "text": "Ταυροι πολλοι με περιεκυκλωσαν ταυροι δυνατοι εκ Βασαν με περιεστοιχισαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Psalms 22:13",
      "text": "Ηνοιξαν επ' εμε το στομα αυτων, ως λεων αρπαζων και βρυχομενος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Psalms 22:14",
      "text": "Εξεχυθην ως υδωρ, και εξηρθρωθησαν παντα τα οστα μου η καρδια μου εγεινεν ως κηριον, κατατηκεται εν μεσω των εντοσθιων μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Psalms 22:15",
      "text": "Η δυναμις μου εξηρανθη ως οστρακον, και η γλωσσα μου εκολληθη εις τον λαρυγγα μου και συ με κατεβιβασας εις το χωμα του θανατου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Psalms 22:16",
      "text": "Διοτι κυνες με περιεκυκλωσαν συναξις πονηρευομενων με περιεκλεισεν ετρυπησαν τας χειρας μου και τους ποδας μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Psalms 22:17",
      "text": "Δυναμαι να αριθμησω παντα τα οστα μου ουτοι με ενατενιζουσι και με παρατηρουσι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Psalms 22:18",
      "text": "Διεμερισθησαν τα ιματια μου εις εαυτους και επι τον ιματισμον μου εβαλον κληρον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Psalms 22:19",
      "text": "Αλλα συ, Κυριε, μη απομακρυνθης συ, η δυναμις μου, σπευσον εις βοηθειαν μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Psalms 22:20",
      "text": "Ελευθερωσον απο ρομφαιας την ψυχην μου την μεμονωμενην μου απο δυναμεως κυνος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Psalms 22:21",
      "text": "Σωσον με εκ στοματος λεοντος και εισακουσον μου, ελευθερονων με απο κερατων μονοκερωτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Psalms 22:22",
      "text": "Θελω διηγεισθαι το ονομα σου προς τους αδελφους μου εν μεσω συναξεως θελω σε επαινει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Psalms 22:23",
      "text": "Οι φοβουμενοι τον Κυριον, αινειτε αυτον απαν το σπερμα Ιακωβ, δοξασατε αυτον και φοβηθητε αυτον, απαν το σπερμα Ισραηλ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Psalms 22:24",
      "text": "Διοτι δεν εξουθενωσε και δεν απεστραφη την θλιψιν του τεθλιμμενου, και δεν εκρυψε το προσωπον αυτου απ' αυτου και οτε εβοησε προς αυτον, εισηκουσεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.25",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Psalms 22:25",
      "text": "Απο σου θελει αρχιζει η αινεσις μου εν εκκλησια μεγαλη θελω αποδωσει τας ευχας μου ενωπιον των φοβουμενων αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.26",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Psalms 22:26",
      "text": "Οι τεθλιμμενοι θελουσι φαγει και θελουσι χορτασθη θελουσιν αινεσει τον Κυριον οι εκζητουντες αυτον η καρδια σας θελει ζη εις τον αιωνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.27",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Psalms 22:27",
      "text": "Θελουσιν ενθυμηθη και επιστραφη προς τον Κυριον παντα τα περατα της γης και θελουσι προσκυνησει ενωπιον σου πασαι αι φυλαι των εθνων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.28",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Psalms 22:28",
      "text": "Διοτι του Κυριου ειναι η βασιλεια, και αυτος εξουσιαζει τα εθνη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.29",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Psalms 22:29",
      "text": "Θελουσι φαγει και θελουσι προσκυνησει παντες οι παχεις της γης ενωπιον αυτου θελουσι κλινει παντες οι καταβαινοντες εις το χωμα και ουδεις την ζωην αυτου θελει δυνηθη να φυλαξη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.30",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "Psalms 22:30",
      "text": "Οι μεταγενεστεροι θελουσι δουλευσει αυτον θελουσιν αναγραφη εις τον Κυριον ως γενεα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.31",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 31,
      "referenceLabel": "Psalms 22:31",
      "text": "Θελουσιν ελθει και αναγγειλει την δικαιοσυνην αυτου, προς λαον, οστις μελλει να γεννηθη διοτι αυτος εκαμε τουτο.",
      "paragraphStart": false
    }
  ]
}
