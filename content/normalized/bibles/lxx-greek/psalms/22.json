{
  "chapter": {
    "id": "lxx-greek:psalms.22",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 22,
    "referenceLabel": "Psalms 22",
    "summary": "Source text for Psalms 22 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.22.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Psalms 22:1",
      "text": "\"Ψαλμος του Δαβιδ.\" Ο Κυριος ειναι ο ποιμην μου δεν θελω στερηθη ουδενος.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.22.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Psalms 22:2",
      "text": "Εις βοσκας χλοερας με ανεπαυσεν εις υδατα αναπαυσεως με ωδηγησεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Psalms 22:3",
      "text": "Ηνωρθωσε την ψυχην μου με ωδηγησε δια τριβων δικαιοσυνης ενεκεν του ονοματος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Psalms 22:4",
      "text": "Και εν κοιλαδι σκιας θανατου εαν περιπατησω, δεν θελω φοβηθη κακον διοτι συ εισαι μετ' εμου η ραβδος σου και η βακτηρια σου, αυται με παρηγορουσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Psalms 22:5",
      "text": "Ητοιμασας εμπροσθεν μου τραπεζαν απεναντι των εχθρων μου ηλειψας εν ελαιω την κεφαλην μου το ποτηριον μου υπερχειλιζει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.22.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Psalms 22:6",
      "text": "Βεβαιως χαρις και ελεος θελουσι με ακολουθει πασας τας ημερας της ζωης μου και θελω κατοικει εν τω οικω του Κυριου εις μακροτητα ημερων.",
      "paragraphStart": false
    }
  ]
}
