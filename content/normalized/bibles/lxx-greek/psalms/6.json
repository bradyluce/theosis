{
  "chapter": {
    "id": "lxx-greek:psalms.6",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 6,
    "referenceLabel": "Psalms 6",
    "summary": "Source text for Psalms 6 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.6.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Psalms 6:1",
      "text": "\"Εις τον πρωτον μουσικον, επι Νεγινωθ, επι Σεμινιθ. Ψαλμος του Δαβιδ.\" Κυριε, μη με ελεγξης εν τω θυμω σου, μηδε εν τη οργη σου παιδευσης με.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.6.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Psalms 6:2",
      "text": "Ελεησον με, Κυριε, διοτι ειμαι αδυνατος ιατρευσον με, Κυριε, διοτι εταραχθησαν τα οστα μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.6.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Psalms 6:3",
      "text": "Και η ψυχη μου εταραχθη σφοδρα αλλα συ, Κυριε, εως ποτε;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.6.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Psalms 6:4",
      "text": "Επιστρεψον, Κυριε λυτρωσον την ψυχην μου σωσον με δια το ελεος σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.6.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Psalms 6:5",
      "text": "Διοτι εν τω θανατω δεν υπαρχει ενθυμησις περι σου εν τω αδη τις θελει σε δοξολογησει;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.6.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Psalms 6:6",
      "text": "Απεκαμον εν τω στεναγμω μου ολην την νυκτα λουω την κλινην μου με τα δακρυα μου καταβρεχω την στρωμνην μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.6.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Psalms 6:7",
      "text": "Ο οφθαλμος μου εμαρανθη εκ της θλιψεως εγηρασεν εξ αιτιας παντων των εχθρων μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.6.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Psalms 6:8",
      "text": "Απομακρυνθητε απ' εμου, παντες οι εργαται της ανομιας, διοτι ηκουσεν ο Κυριος την φωνην του κλαυθμου μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.6.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Psalms 6:9",
      "text": "Ηκουσεν ο Κυριος την δεησιν μου ο Κυριος εδεχθη την προσευχην μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.6.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Psalms 6:10",
      "text": "Ας αισχυνθωσι και ας ταραχθωσι σφοδρα παντες οι εχθροι μου ας στραφωσιν εις τα οπισω ας καταισχυνθωσιν αιφνιδιως.",
      "paragraphStart": false
    }
  ]
}
