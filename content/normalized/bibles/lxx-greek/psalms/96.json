{
  "chapter": {
    "id": "lxx-greek:psalms.96",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 96,
    "referenceLabel": "Psalms 96",
    "summary": "Source text for Psalms 96 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.96.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 1,
      "referenceLabel": "Psalms 96:1",
      "text": "Ο Κυριος βασιλευει ας αγαλλεται η γη ας ευφραινεται το πληθος των νησων.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.96.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 2,
      "referenceLabel": "Psalms 96:2",
      "text": "Νεφελη και ομιχλη ειναι κυκλω αυτου δικαιοσυνη και κρισις η βασις του θρονου αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 3,
      "referenceLabel": "Psalms 96:3",
      "text": "πυρ προπορευεται εμπροσθεν αυτου και καταφλεγει πανταχοθεν, τους εχθρους αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 4,
      "referenceLabel": "Psalms 96:4",
      "text": "Αι αστραπαι αυτου φωτιζουσι την οικουμενην ειδεν η γη και εσαλευθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 5,
      "referenceLabel": "Psalms 96:5",
      "text": "Τα ορη διαλυονται ως κηρος απο της παρουσιας του Κυριου, απο της παρουσιας του Κυριου πασης της γης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 6,
      "referenceLabel": "Psalms 96:6",
      "text": "Αναγγελλουσιν οι ουρανοι την δικαιοσυνην αυτου, και βλεπουσι παντες οι λαοι την δοξαν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 7,
      "referenceLabel": "Psalms 96:7",
      "text": "Ας αισχυνθωσι παντες οι λατρευοντες τα γλυπτα, οι καυχωμενοι εις τα ειδωλα προσκυνειτε αυτον, παντες οι θεοι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 8,
      "referenceLabel": "Psalms 96:8",
      "text": "Ηκουσεν η Σιων και ευφρανθη, και εχαρησαν αι θυγατερες του Ιουδα δια τας κρισεις σου, Κυριε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 9,
      "referenceLabel": "Psalms 96:9",
      "text": "Διοτι συ, Κυριε, εισαι υψιστος εφ' ολην την γην σφοδρα υπερυψωθης υπερ παντας τους θεους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 10,
      "referenceLabel": "Psalms 96:10",
      "text": "Οι αγαπωντες τον Κυριον, μισειτε το κακον αυτος φυλαττει τας ψυχας των οσιων αυτου ελευθερονει αυτους εκ χειρος ασεβων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 11,
      "referenceLabel": "Psalms 96:11",
      "text": "Φως σπειρεται δια τον δικαιον και ευφροσυνη δια τους ευθεις την καρδιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 12,
      "referenceLabel": "Psalms 96:12",
      "text": "Ευφραινεσθε, δικαιοι, εν Κυριω, και υμνειτε την μνημην της αγιωσυνης αυτου.",
      "paragraphStart": false
    }
  ]
}
