{
  "chapter": {
    "id": "lxx-greek:psalms.96",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 96,
    "referenceLabel": "Psalms 96",
    "summary": "Source text for Psalms 96 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.96.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 1,
      "referenceLabel": "Psalms 96:1",
      "text": "Ψαλατε εις τον Κυριον ασμα νεον ψαλατε εις τον Κυριον, πασα η γη.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.96.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 2,
      "referenceLabel": "Psalms 96:2",
      "text": "Ψαλατε εις τον Κυριον ευλογειτε το ονομα αυτου κηρυττετε απο ημερας εις ημεραν την σωτηριαν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 3,
      "referenceLabel": "Psalms 96:3",
      "text": "Αναγγειλατε εν τοις εθνεσι την δοξαν αυτου, εν πασι τοις λαοις τα θαυμασια αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 4,
      "referenceLabel": "Psalms 96:4",
      "text": "Διοτι μεγας ο Κυριος και αξιυμνητος σφοδρα ειναι φοβερος υπερ παντας τους θεους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 5,
      "referenceLabel": "Psalms 96:5",
      "text": "Διοτι παντες οι θεοι των εθνων ειναι ειδωλα ο δε Κυριος τους ουρανους εποιησε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 6,
      "referenceLabel": "Psalms 96:6",
      "text": "Δοξα και μεγαλοπρεπεια ειναι ενωπιον αυτου ισχυς και ωραιοτης εν τω αγιαστηριω αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 7,
      "referenceLabel": "Psalms 96:7",
      "text": "Αποδοτε εις τον Κυριον, πατριαι των λαων, αποδοτε εις τον Κυριον δοξαν και ισχυν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 8,
      "referenceLabel": "Psalms 96:8",
      "text": "Αποδοτε εις τον Κυριον την δοξαν του ονοματος αυτου λαβετε προσφορας και εισελθετε εις τας αυλας αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 9,
      "referenceLabel": "Psalms 96:9",
      "text": "Προσκυνησατε τον Κυριον εν τω μεγαλοπρεπει αγιαστηριω αυτου φοβεισθε απο προσωπου αυτου, πασα η γη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 10,
      "referenceLabel": "Psalms 96:10",
      "text": "Ειπατε εν τοις εθνεσιν, Ο Κυριος βασιλευει η οικουμενη θελει βεβαιως εισθαι εστερεωμενη δεν θελει σαλευθη αυτος θελει κρινει τους λαους εν ευθυτητι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 11,
      "referenceLabel": "Psalms 96:11",
      "text": "Ας ευφραινωνται οι ουρανοι, και ας αγαλλεται η γη ας ηχη η θαλασσα και το πληρωμα αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 12,
      "referenceLabel": "Psalms 96:12",
      "text": "Ας χαιρωσιν αι πεδιαδες και παντα τα εν αυταις τοτε θελουσιν αγαλλεσθαι παντα τα δενδρα του δασους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.96.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 13,
      "referenceLabel": "Psalms 96:13",
      "text": "ενωπιον του Κυριου διοτι ερχεται, διοτι ερχεται δια να κρινη την γην θελει κρινει την οικουμενην εν δικαιοσυνη και τους λαους εν τη αληθεια αυτου.",
      "paragraphStart": false
    }
  ]
}
