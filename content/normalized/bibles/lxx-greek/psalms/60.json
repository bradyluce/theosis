{
  "chapter": {
    "id": "lxx-greek:psalms.60",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 60,
    "referenceLabel": "Psalms 60",
    "summary": "Source text for Psalms 60 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.60.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 1,
      "referenceLabel": "Psalms 60:1",
      "text": "\"Εις τον πρωτον μουσικον, επι Σουσαν-εδουθ, Μικταμ του Δαβιδ προς διδασκαλιαν, οποτε επολεμησε την Συριαν της Μεσοποταμιας και την Συριαν Σωβα, ο δε Ιωαβ επεστρεψε και επαταξε του Εδωμ εν τη κοιλαδι του αλατος δωδεκα χιλιαδας.\" Θεε, απερριψας ημας διεσκορπισας ημας ωργισθης επιστρεψον εις ημας.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.60.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 2,
      "referenceLabel": "Psalms 60:2",
      "text": "Εσεισας την γην διεσχισας αυτην ιασαι τα συντριμματα αυτης, διοτι σαλευεται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.60.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 3,
      "referenceLabel": "Psalms 60:3",
      "text": "Εδειξας εις τον λαον σου πραγματα σκληρα εποτισας ημας οινον παραφροσυνης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.60.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 4,
      "referenceLabel": "Psalms 60:4",
      "text": "Εδωκας εις τους φοβουμενους σε σημαιαν, δια να υψονηται υπερ της αληθειας. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.60.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 5,
      "referenceLabel": "Psalms 60:5",
      "text": "Δια να ελευθερονωνται οι αγαπητοι σου, σωσον δια της δεξιας σου και επακουσον μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.60.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 6,
      "referenceLabel": "Psalms 60:6",
      "text": "Ο Θεος ελαλησεν εν τω αγιαστηριω αυτου θελω χαιρει θελω μοιρασει την Συχεμ και την κοιλαδα Σοκχωθ θελω διαμετρησει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.60.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 7,
      "referenceLabel": "Psalms 60:7",
      "text": "Εμου ειναι ο Γαλααδ και εμου ο Μανασσης ο μεν Εφραιμ ειναι η δυναμις της κεφαλης μου ο δε Ιουδας ο νομοθετης μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.60.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 8,
      "referenceLabel": "Psalms 60:8",
      "text": "Ο Μωαβ ειναι η λεκανη του νιψιματος μου επι τον Εδωμ θελω ριψει το υποδημα μου αλαλαξον επ' εμοι, Παλαιστινη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.60.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 9,
      "referenceLabel": "Psalms 60:9",
      "text": "Τις θελει με φερει εις την περιτετειχισμενην πολιν; τις θελει με οδηγησει εως Εδωμ;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.60.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 10,
      "referenceLabel": "Psalms 60:10",
      "text": "Ουχι συ, Θεε, ο απορριψας ημας; και δεν θελεις εξελθει, Θεε, μετα των στρατευματων ημων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.60.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 11,
      "referenceLabel": "Psalms 60:11",
      "text": "Βοηθησον ημας απο της θλιψεως διοτι ματαια ειναι η παρα των ανθρωπων σωτηρια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.60.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 12,
      "referenceLabel": "Psalms 60:12",
      "text": "Δια του Θεου θελομεν καμει ανδραγαθιας, και αυτος θελει καταπατησει τους εχθρους ημων.",
      "paragraphStart": false
    }
  ]
}
