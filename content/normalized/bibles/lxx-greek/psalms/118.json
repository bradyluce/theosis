{
  "chapter": {
    "id": "lxx-greek:psalms.118",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 118,
    "referenceLabel": "Psalms 118",
    "summary": "Source text for Psalms 118 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.118.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 1,
      "referenceLabel": "Psalms 118:1",
      "text": "Δοξολογειτε τον Κυριον, διοτι ειναι αγαθος, διοτι το ελεος αυτου μενει εις τον αιωνα.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.118.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 2,
      "referenceLabel": "Psalms 118:2",
      "text": "Ας ειπη τωρα ο Ισραηλ, οτι το ελεος αυτου μενει εις τον αιωνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 3,
      "referenceLabel": "Psalms 118:3",
      "text": "Ας ειπη τωρα ο οικος Ααρων, οτι το ελεος αυτου μενει εις τον αιωνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 4,
      "referenceLabel": "Psalms 118:4",
      "text": "Ας ειπωσι τωρα οι φοβουμενοι τον Κυριον, οτι το ελεος αυτου μενει εις τον αιωνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 5,
      "referenceLabel": "Psalms 118:5",
      "text": "Εν θλιψει επεκαλεσθην τον Κυριον ο Κυριος μου υπηκουσε, δους ευρυχωριαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 6,
      "referenceLabel": "Psalms 118:6",
      "text": "Ο Κυριος ειναι υπερ εμου δεν θελω φοβηθη τι να μοι καμη ανθρωπος;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 7,
      "referenceLabel": "Psalms 118:7",
      "text": "Ο Κυριος ειναι υπερ εμου μεταξυ των βοηθουντων με και εγω θελω ιδει την εκδικησιν επι τους εχθρους μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 8,
      "referenceLabel": "Psalms 118:8",
      "text": "Καλλιον να ελπιζη τις επι Κυριον, παρα να θαρρη επ' ανθρωπον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 9,
      "referenceLabel": "Psalms 118:9",
      "text": "Καλλιον να ελπιζη τις επι Κυριον, παρα να θαρρη επ' αρχοντας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 10,
      "referenceLabel": "Psalms 118:10",
      "text": "Παντα τα εθνη με περιεκυκλωσαν αλλ' εν τω ονοματι τον Κυριου θελω κατατροπωσει αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 11,
      "referenceLabel": "Psalms 118:11",
      "text": "Με περιεκυκλωσαν, ναι, με περιεκυκλωσαν πανταχοθεν αλλ' εν τω ονοματι του Κυριου θελω κατατροπωσει αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 12,
      "referenceLabel": "Psalms 118:12",
      "text": "Με περιεκυκλωσαν ως μελισσαι εσβεσθησαν ως πυρ ακανθων διοτι εν τω ονοματι του Κυριου θελω κατατροπωσει αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 13,
      "referenceLabel": "Psalms 118:13",
      "text": "Με ωθησας δυνατα δια να πεσω αλλ' ο Κυριος με εβοηθησε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 14,
      "referenceLabel": "Psalms 118:14",
      "text": "Δυναμις μου και υμνος ειναι ο Κυριος, και εγεινεν εις εμε σωτηρια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 15,
      "referenceLabel": "Psalms 118:15",
      "text": "Φωνη αγαλλιασεως και σωτηριας ειναι εν σκηναις δικαιων η δεξια του Κυριου καμνει κατορθωματα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 16,
      "referenceLabel": "Psalms 118:16",
      "text": "Η δεξια του Κυριου υψωθη η δεξια του Κυριου καμνει κατορθωματα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 17,
      "referenceLabel": "Psalms 118:17",
      "text": "Δεν θελω αποθανει αλλα θελω ζησει και θελω διηγεισθαι τα εργα του Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 18,
      "referenceLabel": "Psalms 118:18",
      "text": "Αυστηρως με επαιδευσεν ο Κυριος, αλλα δεν με παρεδωκεν εις θανατον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 19,
      "referenceLabel": "Psalms 118:19",
      "text": "Ανοιξατε εις εμε τας πυλας της δικαιοσυνης θελω εισελθει εις αυτας και θελω δοξολογησει τον Κυριον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 20,
      "referenceLabel": "Psalms 118:20",
      "text": "Αυτη ειναι η πυλη του Κυριου οι δικαιοι θελουσιν εισελθει εις αυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 21,
      "referenceLabel": "Psalms 118:21",
      "text": "Θελω σε δοξολογει, διοτι μου επηκουσας και εγεινες εις εμε σωτηρια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 22,
      "referenceLabel": "Psalms 118:22",
      "text": "Ο λιθος, τον οποιον απεδοκιμασαν οι οικοδομουντες, ουτος εγεινε κεφαλη γωνιας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 23,
      "referenceLabel": "Psalms 118:23",
      "text": "παρα Κυριου εγεινεν αυτη και ειναι θαυμαστη εν οφθαλμοις ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 24,
      "referenceLabel": "Psalms 118:24",
      "text": "Αυτη ειναι η ημερα, την οποιαν εκαμεν ο Κυριος ας αγαλλιασθωμεν και ας ευφρανθωμεν εν αυτη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.25",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 25,
      "referenceLabel": "Psalms 118:25",
      "text": "Ω Κυριε, σωσον, δεομαι ω Κυριε, ευοδωσον, δεομαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.26",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 26,
      "referenceLabel": "Psalms 118:26",
      "text": "Ευλογημενος ο ερχομενος εν ονοματι Κυριου σας ευλογησαμεν εκ του οικου του Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.27",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 27,
      "referenceLabel": "Psalms 118:27",
      "text": "Ο Θεος ειναι ο Κυριος και εδειξε φως εις ημας φερετε την θυσιαν δεδεμενην με σχοινια εως των κερατων του θυσιαστηριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.28",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 28,
      "referenceLabel": "Psalms 118:28",
      "text": "Συ εισαι ο Θεος μου, και θελω σε δοξολογει ο Θεος μου, θελω σε υψονει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.118.29",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 29,
      "referenceLabel": "Psalms 118:29",
      "text": "Δοξολογειτε τον Κυριον, διοτι ειναι αγαθος, διοτι το ελεος αυτου μενει εις τον αιωνα.",
      "paragraphStart": false
    }
  ]
}
