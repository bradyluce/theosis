{
  "chapter": {
    "id": "lxx-greek:psalms.3",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 3,
    "referenceLabel": "Psalms 3",
    "summary": "Source text for Psalms 3 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.3.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Psalms 3:1",
      "text": "\"Ψαλμος του Δαβιδ, οτε εφυγεν απ' εμπροσθεν του υιου αυτου Αβεσσαλωμ.\" Κυριε, ποσον επληθυνθησαν οι εχθροι μου πολλοι επανιστανται επ' εμε",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.3.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Psalms 3:2",
      "text": "πολλοι λεγουσι περι της ψυχης μου, δεν ειναι δι' αυτον σωτηρια εν τω Θεω Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.3.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Psalms 3:3",
      "text": "Αλλα συ, Κυριε, εισαι η ασπις μου, η δοξα μου και ο υψονων την κεφαλην μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.3.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Psalms 3:4",
      "text": "Εκραξα με την φωνην μου προς τον Κυριον, και εισηκουσε μου εκ του ορους του αγιου αυτου. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.3.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Psalms 3:5",
      "text": "Εγω επλαγιασα και εκοιμηθην εξηγερθην διοτι ο Κυριος με υποστηριζει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.3.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Psalms 3:6",
      "text": "Δεν θελω φοβηθη απο μυριαδων λαου των αντιπαρατασσομενων κατ' εμου κυκλω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.3.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Psalms 3:7",
      "text": "Αναστηθι, Κυριε σωσον με, Θεε μου διοτι συ επαταξας παντας τους εχθρους μου κατα της σιαγονος συνετριψας τους οδοντας των ασεβων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.3.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Psalms 3:8",
      "text": "Του Κυριου ειναι η σωτηρια επι τον λαον σου ειναι η ευλογια σου. Διαψαλμα.",
      "paragraphStart": false
    }
  ]
}
