{
  "chapter": {
    "id": "lxx-greek:psalms.47",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 47,
    "referenceLabel": "Psalms 47",
    "summary": "Source text for Psalms 47 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.47.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 1,
      "referenceLabel": "Psalms 47:1",
      "text": "\"Εις τον πρωτον μουσικον. Ψαλμος δια τους υιους Κορε.\" Παντες οι λαοι, κροτησατε χειρας αλαλαξατε εις τον Θεον εν φωνη αγαλλιασεως.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.47.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 2,
      "referenceLabel": "Psalms 47:2",
      "text": "Διοτι ο Κυριος ειναι υψιστος, φοβερος, Βασιλευς μεγας επι πασαν την γην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.47.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 3,
      "referenceLabel": "Psalms 47:3",
      "text": "Υπεταξε λαους εις ημας και εθνη υπο τους ποδας ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.47.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 4,
      "referenceLabel": "Psalms 47:4",
      "text": "Εκλεξε δια ημας την κληρονομιαν την δοξαν του Ιακωβ, τον οποιον ηγαπησε. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.47.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 5,
      "referenceLabel": "Psalms 47:5",
      "text": "Ανεβη ο Θεος εν αλαλαγμω, ο Κυριος εν φωνη σαλπιγγος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.47.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 6,
      "referenceLabel": "Psalms 47:6",
      "text": "Ψαλατε εις τον Θεον, ψαλατε ψαλατε εις τον Βασιλεα ημων, ψαλατε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.47.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 7,
      "referenceLabel": "Psalms 47:7",
      "text": "Διοτι Βασιλευς πασης της γης ειναι ο Θεος ψαλατε μετα συνεσεως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.47.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 8,
      "referenceLabel": "Psalms 47:8",
      "text": "Ο Θεος βασιλευει επι τα εθνη ο Θεος καθηται επι του θρονου της αγιοτητος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.47.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 9,
      "referenceLabel": "Psalms 47:9",
      "text": "Οι αρχοντες των λαων συνηχθησαν μετα του λαου του Θεου του Αβρααμ διοτι του Θεου ειναι αι ασπιδες της γης υψωθη σφοδρα.",
      "paragraphStart": false
    }
  ]
}
