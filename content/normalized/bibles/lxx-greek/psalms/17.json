{
  "chapter": {
    "id": "lxx-greek:psalms.17",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 17,
    "referenceLabel": "Psalms 17",
    "summary": "Source text for Psalms 17 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.17.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Psalms 17:1",
      "text": "\"Προσευχη του Δαβιδ.\" Ακουσον, Κυριε, το δικαιον προσεξον εις την δεησιν μου ακροασθητι την προσευχην μου, την γινομενην ουχι με χειλη δολια.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.17.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Psalms 17:2",
      "text": "Ας εξελθη η κρισις μου παρα του προσωπου σου οι οφθαλμοι σου ας ιδωσι την ευθυτητα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.17.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Psalms 17:3",
      "text": "Ηρευνησας την καρδιαν μου επεσκεφθης αυτην εν καιρω νυκτος εδοκιμασας με και δεν ηυρες ουδεν εν εμοι ο στοχασμος μου δεν ειναι διαφορος των λογων μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.17.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Psalms 17:4",
      "text": "Ως προς τα εργα των ανθρωπων, εγω δια των λογων των χειλεων σου εφυλαχθην απο των οδων των παρανομων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.17.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Psalms 17:5",
      "text": "Στηριξον τα διαβηματα μου εν ταις οδοις σου, δια να μη σαλευθωσιν οι ποδες μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.17.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Psalms 17:6",
      "text": "Εγω σε επεκαλεσθην, Θεε, διοτι θελεις μου εισακουσει Κλινον εις εμε το ωτιον σου, ακουσον τους λογους μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.17.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Psalms 17:7",
      "text": "Θαυμαστωσον τα ελεη σου, συ ο σωζων τους ελπιζοντας επι σε εκ των επανισταμενων κατα της δεξιας σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.17.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Psalms 17:8",
      "text": "Φυλαξον με ως κορην οφθαλμου κρυψον με υπο την σκιαν των πτερυγων σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.17.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Psalms 17:9",
      "text": "απ' εμπροσθεν των ασεβων των ταλαιπωρουντων με οι εχθροι της ψυχης μου με περιεκυκλωσαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.17.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Psalms 17:10",
      "text": "Υπερεπαχυναν το στομα αυτων λαλει υπερηφανα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.17.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Psalms 17:11",
      "text": "Τωρα περιεκυκλωσαν τα διαβηματα ημων προσηλωσαν τους οφθαλμους αυτων δια να κρημνισωσιν ημας κατα γης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.17.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Psalms 17:12",
      "text": "Ως λεων επιθυμων να κατασπαραξη και ως σκυμνος, καθημενος εν αποκρυφοις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.17.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Psalms 17:13",
      "text": "Αναστηθι, Κυριε προφθασον αυτον, υποσκελισον αυτον ελευθερωσον την ψυχην μου απο του ασεβους, οστις ειναι η ρομφαια σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.17.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Psalms 17:14",
      "text": "Απο ανθρωπων, Κυριε, της χειρος σου απο ανθρωπων του κοσμου, οιτινες λαμβανουσι την μεριδα αυτων εν ταυτη τη ζωη, και των οποιων την κοιλιαν γεμιζεις απο των θησαυρων σου εχορτασαν τους υιους, και αφινουσι τα υπολοιπα αυτων εις τους εγγονους αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.17.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Psalms 17:15",
      "text": "Εγω δε εν δικαιοσυνη θελω ιδει το προσωπον σου θελω χορτασθη απο της θεωριας σου, οταν εξεγερθω.",
      "paragraphStart": false
    }
  ]
}
