{
  "chapter": {
    "id": "lxx-greek:psalms.145",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 145,
    "referenceLabel": "Psalms 145",
    "summary": "Source text for Psalms 145 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.145.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 1,
      "referenceLabel": "Psalms 145:1",
      "text": "\"Αινεσις του Δαβιδ.\" Θελω σε υψονει, Θεε μου, βασιλευ και θελω ευλογει το ονομα σου εις τον αιωνα και εις τον αιωνα.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.145.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 2,
      "referenceLabel": "Psalms 145:2",
      "text": "Καθ' εκαστην ημεραν θελω σε ευλογει και θελω αινει το ονομα σου εις τον αιωνα και εις τον αιωνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 3,
      "referenceLabel": "Psalms 145:3",
      "text": "Μεγας ο Κυριος και αξιυμνητος σφοδρα και η μεγαλωσυνη αυτου ανεξιχνιαστος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 4,
      "referenceLabel": "Psalms 145:4",
      "text": "Γενεα εις γενεαν θελει επαινει τα εργα σου, και τα μεγαλεια σου θελουσι διηγεισθαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 5,
      "referenceLabel": "Psalms 145:5",
      "text": "Θελω λαλει περι της ενδοξου μεγαλοπρεπειας της μεγαλειοτητος σου και περι των θαυμαστων εργων σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 6,
      "referenceLabel": "Psalms 145:6",
      "text": "και θελουσι λεγει την δυναμιν των φοβερων σου κατορθωματων, και θελω διηγεισθαι την μεγαλωσυνην σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 7,
      "referenceLabel": "Psalms 145:7",
      "text": "Θελουσι διαδιδει την μνημην του πληθους της αγαθοτητος σου, και θελουσιν αλαλαξει την δικαιοσυνην σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 8,
      "referenceLabel": "Psalms 145:8",
      "text": "Ελεημων και οικτιρμων ο Κυριος μακροθυμος και πολυελεος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 9,
      "referenceLabel": "Psalms 145:9",
      "text": "Αγαθος ο Κυριος προς παντας και οι οικτιρμοι αυτου επι παντα τα ποιηματα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 10,
      "referenceLabel": "Psalms 145:10",
      "text": "Παντα τα ποιηματα σου, Κυριε, θελουσι σε αινει και οι οσιοι σου θελουσι σε ευλογει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 11,
      "referenceLabel": "Psalms 145:11",
      "text": "Την δοξαν της βασιλειας σου θελουσι κηρυττει και θελουσι διηγεισθαι το μεγαλειον σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 12,
      "referenceLabel": "Psalms 145:12",
      "text": "δια να γνωστοποιησωσιν εις τους υιους των ανθρωπων τα μεγαλεια αυτου, και την δοξαν της μεγαλοπρεπειας της βασιλειας αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 13,
      "referenceLabel": "Psalms 145:13",
      "text": "Η βασιλεια σου βασιλεια παντων των αιωνων, και η δεσποτεια σου εν παση γενεα και γενεα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 14,
      "referenceLabel": "Psalms 145:14",
      "text": "Ο Κυριος υποστηριζει παντας τους πιπτοντας και ανορθοι παντας τους κεκυρτωμενους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 15,
      "referenceLabel": "Psalms 145:15",
      "text": "Οι οφθαλμοι παντων αποβλεπουσι προς σε και συ διδεις εις αυτους την τροφην αυτων εν καιρω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 16,
      "referenceLabel": "Psalms 145:16",
      "text": "Ανοιγεις την χειρα σου και χορταινεις την επιθυμιαν παντος ζωντος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 17,
      "referenceLabel": "Psalms 145:17",
      "text": "Δικαιος ο Κυριος εν πασαις ταις οδοις αυτου και αγαθος εν πασι τοις εργοις αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 18,
      "referenceLabel": "Psalms 145:18",
      "text": "Ο Κυριος ειναι πλησιον παντων των επικαλουμενων αυτον παντων των επικαλουμενων αυτον εν αληθεια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 19,
      "referenceLabel": "Psalms 145:19",
      "text": "Εκπληροι την επιθυμιαν των φοβουμενων αυτον, και της κραυγης αυτων εισακουει και σωζει αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 20,
      "referenceLabel": "Psalms 145:20",
      "text": "Ο Κυριος φυλαττει παντας τους αγαπωντας αυτον θελει δε εξολοθρευσει παντας τους ασεβεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 21,
      "referenceLabel": "Psalms 145:21",
      "text": "Το στομα μου θελει λαλει την αινεσιν του Κυριου και πασα σαρξ ας ευλογη το ονομα το αγιον αυτου εις τον αιωνα και εις τον αιωνα.",
      "paragraphStart": false
    }
  ]
}
