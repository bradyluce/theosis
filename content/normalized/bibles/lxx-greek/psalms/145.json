{
  "chapter": {
    "id": "lxx-greek:psalms.145",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 145,
    "referenceLabel": "Psalms 145",
    "summary": "Source text for Psalms 145 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.145.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 1,
      "referenceLabel": "Psalms 145:1",
      "text": "Αινειτε τον Κυριον. Αινει, η ψυχη μου, τον Κυριον.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.145.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 2,
      "referenceLabel": "Psalms 145:2",
      "text": "Θελω αινει τον Κυριον ενοσω ζω θελω ψαλμωδει εις τον Θεον μου ενοσω υπαρχω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 3,
      "referenceLabel": "Psalms 145:3",
      "text": "Μη πεποιθατε επ' αρχοντας, επι υιον ανθρωπου, εκ του οποιου δεν ειναι σωτηρια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 4,
      "referenceLabel": "Psalms 145:4",
      "text": "Το πνευμα αυτου εξερχεται αυτος επιστρεφει εις την γην αυτου εν εκεινη τη ημερα οι διαλογισμοι αυτου αφανιζονται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 5,
      "referenceLabel": "Psalms 145:5",
      "text": "Μακαριος εκεινος, του οποιου βοηθος ειναι ο Θεος του Ιακωβ του οποιου η ελπις ειναι επι Κυριον τον Θεον αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 6,
      "referenceLabel": "Psalms 145:6",
      "text": "τον ποιησαντα τον ουρανον και την γην, την θαλασσαν και παντα τα εν αυτοις τον φυλαττοντα αληθειαν εις τον αιωνα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 7,
      "referenceLabel": "Psalms 145:7",
      "text": "τον ποιουντα κρισιν εις τους αδικουμενους τον διδοντα τροφην εις τους πεινωντας. Ο Κυριος ελευθερονει τους δεσμιους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 8,
      "referenceLabel": "Psalms 145:8",
      "text": "Ο Κυριος ανοιγει τους οφθαλμους των τυφλων ο Κυριος ανορθοι τους κεκυρτωμενους ο Κυριος αγαπα τους δικαιους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 9,
      "referenceLabel": "Psalms 145:9",
      "text": "ο Κυριος διαφυλαττει τους ξενους υπερασπιζεται τον ορφανον και την χηραν, την δε οδον των αμαρτωλων καταστρεφει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.145.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 10,
      "referenceLabel": "Psalms 145:10",
      "text": "Ο Κυριος θελει βασιλευει εις τον αιωνα ο Θεος σου, Σιων, εις γενεαν και γενεαν. Αλληλουια.",
      "paragraphStart": false
    }
  ]
}
