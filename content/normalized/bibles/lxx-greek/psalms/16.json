{
  "chapter": {
    "id": "lxx-greek:psalms.16",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 16,
    "referenceLabel": "Psalms 16",
    "summary": "Source text for Psalms 16 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.16.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Psalms 16:1",
      "text": "\"Μικταμ του Δαβιδ.\" Φυλαξον με, Θεε, διοτι επι σε ηλπισα.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.16.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Psalms 16:2",
      "text": "Συ ψυχη μου, ειπας προς τον Κυριον, συ εισαι ο Κυριος μου η αγαθοτης μου δεν εκτεινεται εις σε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.16.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Psalms 16:3",
      "text": "Αλλ' εις τους αγιους τους οντας εν τη γη και εις τους εξαιρετους, εις τους οποιους ειναι ολη μου η ευχαριστησις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.16.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Psalms 16:4",
      "text": "Οι πονοι των τρεχοντων κατοπιν αλλων θεων θελουσι πολλαπλασιασθη εγω δεν θελω προσφερει τας εξ αιματος σπονδας αυτων, ουδε θελω λαβει εις τα χειλη μου τα ονοματα αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.16.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Psalms 16:5",
      "text": "Ο Κυριος ειναι η μερις της κληρονομιας μου και του ποτηριου μου συ διαφυλαττεις τον κληρον μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.16.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Psalms 16:6",
      "text": "Αι μεριδες μου επεσον εις τοπους τερπνους ελαβον ωραιοτατην κληρονομιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.16.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Psalms 16:7",
      "text": "Θελω ευλογει τον Κυριον τον νουθετησαντα με ετι και εν καιρω νυκτος με διδασκουσιν οι νεφροι μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.16.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Psalms 16:8",
      "text": "Ενωπιον μου ειχον τον Κυριον διαπαντος διοτι ειναι εκ δεξιων μου, δια να μη σαλευθω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.16.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Psalms 16:9",
      "text": "Δια τουτο ευφρανθη η καρδια μου και ηγαλλιασεν η γλωσσα μου ετι δε και η σαρξ μου θελει αναπαυθη επ' ελπιδι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.16.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Psalms 16:10",
      "text": "Διοτι δεν θελεις εγκαταλειψει την ψυχην μου εν τω αδη, ουδε θελεις αφησει τον Οσιον σου να ιδη διαφθοραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.16.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Psalms 16:11",
      "text": "Εφανερωσας εις εμε την οδον της ζωης χορτασμος ευφροσυνης ειναι το προσωπον σου τερπνοτητες ειναι διαπαντος εν τη δεξια σου.",
      "paragraphStart": false
    }
  ]
}
