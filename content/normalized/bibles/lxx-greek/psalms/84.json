{
  "chapter": {
    "id": "lxx-greek:psalms.84",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 84,
    "referenceLabel": "Psalms 84",
    "summary": "Source text for Psalms 84 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.84.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 1,
      "referenceLabel": "Psalms 84:1",
      "text": "\"Εις τον πρωτον μουσικον. Ψαλμος δια τους υιους Κορε.\" Ευηρεστηθης, Κυριε, εις την γην σου εφερες απο της αιχμαλωσιας τον Ιακωβ.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.84.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 2,
      "referenceLabel": "Psalms 84:2",
      "text": "Συνεχωρησας την ανομιαν του λαου σου εσκεπασας πασας τας αμαρτιας αυτων. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.84.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 3,
      "referenceLabel": "Psalms 84:3",
      "text": "Κατεπαυσας πασαν την οργην σου απεστρεψας απο της οργης του θυμου σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.84.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 4,
      "referenceLabel": "Psalms 84:4",
      "text": "Επιστρεψον ημας, Θεε της σωτηριας ημων, και καταπαυσον τον καθ' ημων θυμον σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.84.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 5,
      "referenceLabel": "Psalms 84:5",
      "text": "Θελεις εισθαι διαπαντος ωργισμενος εις ημας; θελεις επεκτεινει την οργην σου απο γενεας εις γενεαν;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.84.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 6,
      "referenceLabel": "Psalms 84:6",
      "text": "Δεν θελεις παλιν ζωοποιησει ημας, δια να ευφραινηται ο λαος σου εις σε;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.84.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 7,
      "referenceLabel": "Psalms 84:7",
      "text": "Δειξον εις ημας, Κυριε, το ελεος σου και δος εις ημας την σωτηριαν σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.84.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 8,
      "referenceLabel": "Psalms 84:8",
      "text": "Θελω ακουσει τι θελει λαλησει Κυριος ο Θεος διοτι θελει λαλησει ειρηνην προς τον λαον αυτου και προς τους οσιους αυτου και ας μη επιστρεψωσιν εις αφροσυνην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.84.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 9,
      "referenceLabel": "Psalms 84:9",
      "text": "Βεβαιως πλησιον των φοβουμενων αυτον ειναι η σωτηρια αυτου, δια να κατοικη δοξα εν τη γη ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.84.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 10,
      "referenceLabel": "Psalms 84:10",
      "text": "Ελεος και αληθεια συναπηντηθησαν δικαιοσυνη και ειρηνη εφιληθησαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.84.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 11,
      "referenceLabel": "Psalms 84:11",
      "text": "Αληθεια εκ της γης θελει αναβλαστησει και δικαιοσυνη εξ ουρανου θελει κυψει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.84.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 12,
      "referenceLabel": "Psalms 84:12",
      "text": "Ο Κυριος βεβαιως θελει δωσει το αγαθον και η γη ημων θελει δωσει τον καρπον αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.84.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 13,
      "referenceLabel": "Psalms 84:13",
      "text": "Δικαιοσυνη εμπροσθεν αυτου θελει προπορευεσθαι, και θελει βαλει αυτην εις την οδον των διαβηματων αυτου.",
      "paragraphStart": false
    }
  ]
}
