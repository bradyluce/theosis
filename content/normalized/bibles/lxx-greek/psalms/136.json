{
  "chapter": {
    "id": "lxx-greek:psalms.136",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 136,
    "referenceLabel": "Psalms 136",
    "summary": "Source text for Psalms 136 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.136.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 1,
      "referenceLabel": "Psalms 136:1",
      "text": "Δοξολογειτε τον Κυριον, διοτι ειναι αγαθος, διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.136.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 2,
      "referenceLabel": "Psalms 136:2",
      "text": "Δοξολογειτε τον Θεον των θεων διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 3,
      "referenceLabel": "Psalms 136:3",
      "text": "Δοξολογειτε τον Κυριον των κυριων διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 4,
      "referenceLabel": "Psalms 136:4",
      "text": "Τον μονον ποιουντα θαυμασια μεγαλα διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 5,
      "referenceLabel": "Psalms 136:5",
      "text": "Τον ποιησαντα τους ουρανους εν συνεσει διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 6,
      "referenceLabel": "Psalms 136:6",
      "text": "Τον στερεωσαντα την γην επι των υδατων διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 7,
      "referenceLabel": "Psalms 136:7",
      "text": "Τον ποιησαντα τους φωστηρας τους μεγαλους διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 8,
      "referenceLabel": "Psalms 136:8",
      "text": "τον ηλιον, δια να εξουσιαζη επι της ημερας διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 9,
      "referenceLabel": "Psalms 136:9",
      "text": "την σεληνην και τους αστερας, δια να εξουσιαζωσιν επι της νυκτος διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 10,
      "referenceLabel": "Psalms 136:10",
      "text": "Τον παταξαντα την Αιγυπτον εις τα πρωτοτοκα αυτης διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 11,
      "referenceLabel": "Psalms 136:11",
      "text": "και εξαγαγοντα τον Ισραηλ εκ μεσου αυτης διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 12,
      "referenceLabel": "Psalms 136:12",
      "text": "Εν χειρι κραταια και εν βραχιονι ηπλωμενω διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 13,
      "referenceLabel": "Psalms 136:13",
      "text": "Τον διαιρεσαντα την Ερυθραν θαλασσαν εις δυο μερη διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 14,
      "referenceLabel": "Psalms 136:14",
      "text": "και διαβιβασαντα τον Ισραηλ δια μεσου αυτης διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 15,
      "referenceLabel": "Psalms 136:15",
      "text": "και καταστρεψαντα τον Φαραω και το στρατευμα αυτου εν τη Ερυθρα θαλασση διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 16,
      "referenceLabel": "Psalms 136:16",
      "text": "Τον οδηγησαντα τον λαον αυτου εν τη ερημω διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 17,
      "referenceLabel": "Psalms 136:17",
      "text": "Τον παταξαντα βασιλεις μεγαλους διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 18,
      "referenceLabel": "Psalms 136:18",
      "text": "και αποκτειναντα βασιλεις κραταιους διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 19,
      "referenceLabel": "Psalms 136:19",
      "text": "τον Σηων, βασιλεα των Αμορραιων διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 20,
      "referenceLabel": "Psalms 136:20",
      "text": "και τον Ωγ βασιλεα της Βασαν διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 21,
      "referenceLabel": "Psalms 136:21",
      "text": "και δοντα την γην αυτην εις κληρονομιαν διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 22,
      "referenceLabel": "Psalms 136:22",
      "text": "κληρονομιαν εις τον Ισραηλ τον δουλον αυτου διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 23,
      "referenceLabel": "Psalms 136:23",
      "text": "Τον μνησθεντα ημων εν τη ταπεινωσει ημων διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 24,
      "referenceLabel": "Psalms 136:24",
      "text": "και λυτρωσαντα ημας εκ των εχθρων ημων διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.25",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 25,
      "referenceLabel": "Psalms 136:25",
      "text": "Τον διδοντα τροφην εις πασαν σαρκα διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.136.26",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 26,
      "referenceLabel": "Psalms 136:26",
      "text": "Δοξολογειτε τον Θεον του ουρανου διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    }
  ]
}
