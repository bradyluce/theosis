{
  "chapter": {
    "id": "lxx-greek:psalms.98",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 98,
    "referenceLabel": "Psalms 98",
    "summary": "Source text for Psalms 98 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.98.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 1,
      "referenceLabel": "Psalms 98:1",
      "text": "Ο Κυριος βασιλευει, ας τρεμωσιν οι λαοι ο καθημενος επι των χερουβειμ ας σεισθη η γη.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.98.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 2,
      "referenceLabel": "Psalms 98:2",
      "text": "Ο Κυριος ειναι μεγας εν Σιων, και επι παντας τους λαους ειναι υψηλος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.98.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 3,
      "referenceLabel": "Psalms 98:3",
      "text": "Ας δοξολογωσι το ονομα σου το μεγα και φοβερον, διοτι ειναι αγιον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.98.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 4,
      "referenceLabel": "Psalms 98:4",
      "text": "και την δυναμιν του βασιλεως, οστις αγαπα την δικαιοσυνην συ διωρισας την ευθυτητα, συ εκαμες κρισιν και δικαιοσυνην εις τον Ιακωβ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.98.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 5,
      "referenceLabel": "Psalms 98:5",
      "text": "Υψουτε Κυριον τον Θεον ημων και προσκυνειτε εις το υποποδιον των ποδων αυτου διοτι ειναι αγιος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.98.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 6,
      "referenceLabel": "Psalms 98:6",
      "text": "Μωυσης και Ααρων μεταξυ των ιερεων αυτου, και Σαμουηλ μεταξυ των επικαλουμενων το ονομα αυτου, επεκαλουντο τον Κυριον, και αυτος εισηκουεν αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.98.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 7,
      "referenceLabel": "Psalms 98:7",
      "text": "Εν στυλω νεφελης ελαλει προς αυτους εφυλαξε τα μαρτυρια αυτου και τα προσταγματα, τα οποια εδωκεν εις αυτους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.98.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 8,
      "referenceLabel": "Psalms 98:8",
      "text": "Κυριε Θεε ημων, συ εισηκουες αυτων εγεινας εις αυτους Θεος συγχωρητικος, πλην και εκδικητης δια τας πραξεις αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.98.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 9,
      "referenceLabel": "Psalms 98:9",
      "text": "Υψουτε Κυριον τον Θεον ημων και προσκυνειτε εις το ορος το αγιον αυτου διοτι αγιος Κυριος ο Θεος ημων.",
      "paragraphStart": false
    }
  ]
}
