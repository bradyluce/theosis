{
  "chapter": {
    "id": "lxx-greek:psalms.122",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 122,
    "referenceLabel": "Psalms 122",
    "summary": "Source text for Psalms 122 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.122.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 1,
      "referenceLabel": "Psalms 122:1",
      "text": "\"Ωιδη των Αναβαθμων, του Δαβιδ.\" Ευφρανθην οτε μοι ειπον, Ας υπαγωμεν εις τον οικον του Κυριου",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.122.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 2,
      "referenceLabel": "Psalms 122:2",
      "text": "Οι ποδες ημων θελουσιν ιστασθαι εν ταις πυλαις σου, Ιερουσαλημ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.122.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 3,
      "referenceLabel": "Psalms 122:3",
      "text": "Ιερουσαλημ, η ωκοδομημενη ως πολις συνηρμοσμενη ομου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.122.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 4,
      "referenceLabel": "Psalms 122:4",
      "text": "Εκει αναβαινουσιν αι φυλαι, αι φυλαι του Κυριου, κατα το διατεταγμενον εις τον Ισραηλ, δια να δοξολογησωσι το ονομα του Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.122.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 5,
      "referenceLabel": "Psalms 122:5",
      "text": "Διοτι εκει ετεθησαν θρονοι δια κρισιν, οι θρονοι του οικου του Δαβιδ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.122.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 6,
      "referenceLabel": "Psalms 122:6",
      "text": "Ζητειτε την ειρηνην της Ιερουσαλημ ας ευτυχωσιν οι αγαπωντες σε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.122.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 7,
      "referenceLabel": "Psalms 122:7",
      "text": "Ας ηναι ειρηνη εις τα τειχη σου, αφθονια εις τα παλατια σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.122.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 8,
      "referenceLabel": "Psalms 122:8",
      "text": "Ενεκεν των αδελφων μου και των πλησιον μου, θελω λεγει τωρα, Ειρηνη εις σε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.122.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 9,
      "referenceLabel": "Psalms 122:9",
      "text": "ενεκεν του οικου Κυριου του Θεου ημων, θελω ζητει το καλον σου.",
      "paragraphStart": false
    }
  ]
}
