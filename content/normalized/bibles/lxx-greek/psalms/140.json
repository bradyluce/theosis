{
  "chapter": {
    "id": "lxx-greek:psalms.140",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 140,
    "referenceLabel": "Psalms 140",
    "summary": "Source text for Psalms 140 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.140.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 1,
      "referenceLabel": "Psalms 140:1",
      "text": "\"Εις τον πρωτον μουσικον. Ψαλμος του Δαβιδ.\" Ελευθερωσον με, Κυριε, απο ανθρωπου πονηρου λυτρωσον με απο ανθρωπου αδικου",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.140.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 2,
      "referenceLabel": "Psalms 140:2",
      "text": "Οιτινες διαλογιζονται πονηρα εν τη καρδια ολην την ημεραν παραταττονται εις πολεμους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.140.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 3,
      "referenceLabel": "Psalms 140:3",
      "text": "Ηκονησαν την γλωσσαν αυτων ως οφεως φαρμακιον ασπιδος ειναι υπο τα χειλη αυτων. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.140.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 4,
      "referenceLabel": "Psalms 140:4",
      "text": "Φυλαξον με, Κυριε, απο χειρων ασεβους λυτρωσον με απο ανθρωπου αδικου οιτινες εμηχανευθησαν να υποσκελισωσι τα διαβηματα μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.140.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 5,
      "referenceLabel": "Psalms 140:5",
      "text": "Οι υπερηφανοι εκρυψαν κατ' εμου παγιδα, και με σχοινια ηπλωσαν δικτυα εις την διαβασιν μου εστησαν δι' εμε βροχια. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.140.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 6,
      "referenceLabel": "Psalms 140:6",
      "text": "Ειπα προς τον Κυριον, Συ εισαι ο Θεος μου ακροασθητι, Κυριε, της φωνης των δεησεων μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.140.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 7,
      "referenceLabel": "Psalms 140:7",
      "text": "Κυριε Θεε, η δυναμις της σωτηριας μου, συ περιεσκεπασας την κεφαλην μου εν ημερα πολεμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.140.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 8,
      "referenceLabel": "Psalms 140:8",
      "text": "Μη δωσης, Κυριε, εις τον ασεβη τας επιθυμιας αυτου μη αφησης να εκτελεσθη ο στοχασμος αυτου, μηποτε υψωθωσι. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.140.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 9,
      "referenceLabel": "Psalms 140:9",
      "text": "Η πονηρια των χειλεων των περικυκλουντων με ας σκεπαση την κεφαλην αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.140.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 10,
      "referenceLabel": "Psalms 140:10",
      "text": "Ανθρακες πεπυρακτωμενοι ας πεσωσιν επ' αυτους ας ριφθωσιν εις το πυρ, εις λακκους βαθεις, δια να μη εγερθωσι πλεον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.140.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 11,
      "referenceLabel": "Psalms 140:11",
      "text": "Ανθρωπος κακογλωσσος ας μη στερεωθη επι της γης η κακια θελει καταδιωξει τον αδικον ανθρωπον, εωσου απολεση αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.140.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 12,
      "referenceLabel": "Psalms 140:12",
      "text": "Εξευρω οτι ο Κυριος θελει καμει την κρισιν του τεθλιμμενου και την δικην των πτωχων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.140.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 13,
      "referenceLabel": "Psalms 140:13",
      "text": "Βεβαιως οι δικαιοι θελουσι δοξολογει το ονομα σου οι ευθεις θελουσι κατοικει εμπροσθεν του προσωπου σου.",
      "paragraphStart": false
    }
  ]
}
