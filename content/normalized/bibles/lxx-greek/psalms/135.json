{
  "chapter": {
    "id": "lxx-greek:psalms.135",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 135,
    "referenceLabel": "Psalms 135",
    "summary": "Source text for Psalms 135 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.135.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 1,
      "referenceLabel": "Psalms 135:1",
      "text": "Αινειτε τον Κυριον. Αινειτε το ονομα του Κυριου αινειτε, δουλοι του Κυριου,",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.135.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 2,
      "referenceLabel": "Psalms 135:2",
      "text": "Οι ισταμενοι εν τω οικω του Κυριου, εν ταις αυλαις του οικου του Θεου ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 3,
      "referenceLabel": "Psalms 135:3",
      "text": "Αινειτε τον Κυριον, διοτι αγαθος ο Κυριος ψαλμωδησατε εις το ονομα αυτου, διοτι ειναι τερπνον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 4,
      "referenceLabel": "Psalms 135:4",
      "text": "Διοτι τον Ιακωβ εξελεξεν εις εαυτον ο Κυριος, τον Ισραηλ εις θησαυρον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 5,
      "referenceLabel": "Psalms 135:5",
      "text": "Διοτι εγω εγνωρισα οτι μεγας ο Κυριος και ο Κυριος ημων ειναι υπερ παντας τους θεους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 6,
      "referenceLabel": "Psalms 135:6",
      "text": "Παντα οσα ηθελησεν ο Κυριος εποιησεν, εν τω ουρανω και εν τη γη, εν ταις θαλασσαις και εν πασαις ταις αβυσσοις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 7,
      "referenceLabel": "Psalms 135:7",
      "text": "Αναβιβαζει νεφελας απο των εσχατων της γης καμνει αστραπας δια βροχην εκβαλλει ανεμους εκ των θησαυρων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 8,
      "referenceLabel": "Psalms 135:8",
      "text": "Οστις επαταξε τα πρωτοτοκα της Αιγυπτου, απο ανθρωπου εως κτηνους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 9,
      "referenceLabel": "Psalms 135:9",
      "text": "εξαπεστειλε σημεια και τερατα εις το μεσον σου, Αιγυπτε, επι τον Φαραω και επι παντας τους δουλους αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 10,
      "referenceLabel": "Psalms 135:10",
      "text": "Οστις επαταξεν εθνη μεγαλα και απεκτεινε βασιλεις κραταιους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 11,
      "referenceLabel": "Psalms 135:11",
      "text": "τον Σηων, βασιλεα των Αμορραιων, και τον Ωγ, βασιλεα της Βασαν, και πασας τας βασιλειας Χανααν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 12,
      "referenceLabel": "Psalms 135:12",
      "text": "και εδωκε την γην αυτων κληρονομιαν, κληρονομιαν εις τον Ισραηλ τον λαον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 13,
      "referenceLabel": "Psalms 135:13",
      "text": "Το ονομα σου, Κυριε, μενει εις τον αιωνα το μνημοσυνον σου, Κυριε, εις γενεαν και γενεαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 14,
      "referenceLabel": "Psalms 135:14",
      "text": "Διοτι θελει κρινει ο Κυριος τον λαον αυτου και τους δουλους αυτου θελει ελεησει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 15,
      "referenceLabel": "Psalms 135:15",
      "text": "Τα ειδωλα των εθνων ειναι αργυριον και χρυσιον, εργον χειρων ανθρωπου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 16,
      "referenceLabel": "Psalms 135:16",
      "text": "Στομα εχουσι και δεν λαλουσιν οφθαλμους εχουσι και δεν βλεπουσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 17,
      "referenceLabel": "Psalms 135:17",
      "text": "Ωτα εχουσι και δεν ακουουσιν ουδε ειναι πνοη εν τω στοματι αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 18,
      "referenceLabel": "Psalms 135:18",
      "text": "Ομοιοι αυτων ας γεινωσιν οι ποιουντες αυτα πας ο ελπιζων επ' αυτα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 19,
      "referenceLabel": "Psalms 135:19",
      "text": "Οικος Ισραηλ, ευλογησατε τον Κυριον οικος Ααρων, ευλογησατε τον Κυριον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 20,
      "referenceLabel": "Psalms 135:20",
      "text": "οικος Λευι, ευλογησατε τον Κυριον οι φοβουμενοι τον Κυριον, ευλογησατε τον Κυριον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 21,
      "referenceLabel": "Psalms 135:21",
      "text": "Ευλογητος ο Κυριος εν Σιων, ο κατοικων εν Ιερουσαλημ. Αλληλουια.",
      "paragraphStart": false
    }
  ]
}
