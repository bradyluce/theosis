{
  "chapter": {
    "id": "lxx-greek:psalms.135",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 135,
    "referenceLabel": "Psalms 135",
    "summary": "Source text for Psalms 135 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.135.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 1,
      "referenceLabel": "Psalms 135:1",
      "text": "Δοξολογειτε τον Κυριον, διοτι ειναι αγαθος, διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.135.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 2,
      "referenceLabel": "Psalms 135:2",
      "text": "Δοξολογειτε τον Θεον των θεων διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 3,
      "referenceLabel": "Psalms 135:3",
      "text": "Δοξολογειτε τον Κυριον των κυριων διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 4,
      "referenceLabel": "Psalms 135:4",
      "text": "Τον μονον ποιουντα θαυμασια μεγαλα διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 5,
      "referenceLabel": "Psalms 135:5",
      "text": "Τον ποιησαντα τους ουρανους εν συνεσει διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 6,
      "referenceLabel": "Psalms 135:6",
      "text": "Τον στερεωσαντα την γην επι των υδατων διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 7,
      "referenceLabel": "Psalms 135:7",
      "text": "Τον ποιησαντα τους φωστηρας τους μεγαλους διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 8,
      "referenceLabel": "Psalms 135:8",
      "text": "τον ηλιον, δια να εξουσιαζη επι της ημερας διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 9,
      "referenceLabel": "Psalms 135:9",
      "text": "την σεληνην και τους αστερας, δια να εξουσιαζωσιν επι της νυκτος διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 10,
      "referenceLabel": "Psalms 135:10",
      "text": "Τον παταξαντα την Αιγυπτον εις τα πρωτοτοκα αυτης διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 11,
      "referenceLabel": "Psalms 135:11",
      "text": "και εξαγαγοντα τον Ισραηλ εκ μεσου αυτης διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 12,
      "referenceLabel": "Psalms 135:12",
      "text": "Εν χειρι κραταια και εν βραχιονι ηπλωμενω διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 13,
      "referenceLabel": "Psalms 135:13",
      "text": "Τον διαιρεσαντα την Ερυθραν θαλασσαν εις δυο μερη διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 14,
      "referenceLabel": "Psalms 135:14",
      "text": "και διαβιβασαντα τον Ισραηλ δια μεσου αυτης διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 15,
      "referenceLabel": "Psalms 135:15",
      "text": "και καταστρεψαντα τον Φαραω και το στρατευμα αυτου εν τη Ερυθρα θαλασση διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 16,
      "referenceLabel": "Psalms 135:16",
      "text": "Τον οδηγησαντα τον λαον αυτου εν τη ερημω διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 17,
      "referenceLabel": "Psalms 135:17",
      "text": "Τον παταξαντα βασιλεις μεγαλους διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 18,
      "referenceLabel": "Psalms 135:18",
      "text": "και αποκτειναντα βασιλεις κραταιους διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 19,
      "referenceLabel": "Psalms 135:19",
      "text": "τον Σηων, βασιλεα των Αμορραιων διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 20,
      "referenceLabel": "Psalms 135:20",
      "text": "και τον Ωγ βασιλεα της Βασαν διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 21,
      "referenceLabel": "Psalms 135:21",
      "text": "και δοντα την γην αυτην εις κληρονομιαν διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 22,
      "referenceLabel": "Psalms 135:22",
      "text": "κληρονομιαν εις τον Ισραηλ τον δουλον αυτου διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 23,
      "referenceLabel": "Psalms 135:23",
      "text": "Τον μνησθεντα ημων εν τη ταπεινωσει ημων διοτι εις τον αιωνα το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 24,
      "referenceLabel": "Psalms 135:24",
      "text": "και λυτρωσαντα ημας εκ των εχθρων ημων διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.25",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 25,
      "referenceLabel": "Psalms 135:25",
      "text": "Τον διδοντα τροφην εις πασαν σαρκα διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.135.26",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 26,
      "referenceLabel": "Psalms 135:26",
      "text": "Δοξολογειτε τον Θεον του ουρανου διοτι εις τον αιωνα το ελεος αυτου.",
      "paragraphStart": false
    }
  ]
}
