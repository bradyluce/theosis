{
  "chapter": {
    "id": "lxx-greek:psalms.79",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 79,
    "referenceLabel": "Psalms 79",
    "summary": "Source text for Psalms 79 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.79.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 1,
      "referenceLabel": "Psalms 79:1",
      "text": "\"Εις τον πρωτον μουσικον, επι Σοσανιμ-εδουθ. Ψαλμος του Ασαφ.\" Ακροασθητι, ο ποιμαινων τον Ισραηλ, συ ο οδηγων ως ποιμνιον τον Ιωσηφ ο καθημενος επι των χερουβειμ, εμφανισθητι.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.79.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 2,
      "referenceLabel": "Psalms 79:2",
      "text": "Εμπροσθεν του Εφραιμ και του Βενιαμιν και του Μανασση διεγειρον την δυναμιν σου και ελθε εις σωτηριαν ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.79.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 3,
      "referenceLabel": "Psalms 79:3",
      "text": "Επιστρεψον ημας, Θεε, και επιλαμψον το προσωπον σου, και θελομεν λυτρωθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.79.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 4,
      "referenceLabel": "Psalms 79:4",
      "text": "Κυριε Θεε των δυναμεων, εως ποτε θελεις οργιζεσθαι κατα της προσευχης του λαου σου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.79.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 5,
      "referenceLabel": "Psalms 79:5",
      "text": "Τρεφεις αυτους με αρτον δακρυων και ποτιζεις αυτους αφθονως με δακρυα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.79.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 6,
      "referenceLabel": "Psalms 79:6",
      "text": "Εκαμες ημας εριδα εις τους γειτονας ημων και οι εχθροι ημων γελωσι μεταξυ αλληλων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.79.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 7,
      "referenceLabel": "Psalms 79:7",
      "text": "Επιστρεψον ημας, Θεε των δυναμεων, και επιλαμψον το προσωπον σου, και θελομεν λυτρωθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.79.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 8,
      "referenceLabel": "Psalms 79:8",
      "text": "Αμπελον εξ Αιγυπτου μετεκομισας εξεδιωξας εθνη και εφυτευσας αυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.79.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 9,
      "referenceLabel": "Psalms 79:9",
      "text": "Ητοιμασας τοπον εμπροσθεν αυτης και βαθεως ερριζωσας αυτην και εγεμισε την γην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.79.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 10,
      "referenceLabel": "Psalms 79:10",
      "text": "Εσκεπασθησαν τα ορη υπο της σκιας αυτης, και αι αναδενδραδες αυτης ησαν ως αι υψηλαι κεδροι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.79.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 11,
      "referenceLabel": "Psalms 79:11",
      "text": "Εξετεινε τα κληματα αυτης εως θαλασσης και τους βλαστους αυτης εως του ποταμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.79.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 12,
      "referenceLabel": "Psalms 79:12",
      "text": "Δια τι εκρημνισας τους φραγμους αυτης, και τρυγωσιν αυτην παντες οι διαβαινοντες την οδον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.79.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 13,
      "referenceLabel": "Psalms 79:13",
      "text": "Ερημονει αυτην ο αγριοχοιρος εκ του δασους, και το θηριον του αγρου νεμεται αυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.79.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 14,
      "referenceLabel": "Psalms 79:14",
      "text": "Επιστρεψον, δεομεθα, Θεε των δυναμεων επιβλεψον εξ ουρανου και ιδε, και επισκεψαι την αμπελον ταυτην,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.79.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 15,
      "referenceLabel": "Psalms 79:15",
      "text": "και το φυτον, το οποιον εφυτευσεν η δεξια σου και τον βλαστον, τον οποιον εκραταιωσας εις σεαυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.79.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 16,
      "referenceLabel": "Psalms 79:16",
      "text": "Εκαυθη εν πυρι εκοπη εχαθησαν απο επιτιμησεως του προσωπου σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.79.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 17,
      "referenceLabel": "Psalms 79:17",
      "text": "Ας ηναι η χειρ σου επι τον ανδρα της δεξιας σου επι τον υιον του ανθρωπου, τον οποιον εκαμες δυνατον εις σεαυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.79.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 18,
      "referenceLabel": "Psalms 79:18",
      "text": "Και ημεις δεν θελομεν εκκλινει απο σου ζωοποιησον ημας, και το ονομα σου θελομεν επικαλεισθαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.79.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 19,
      "referenceLabel": "Psalms 79:19",
      "text": "Επιστρεψον ημας, Κυριε Θεε των δυναμεων επιλαμψον το προσωπον σου, και θελομεν λυτρωθη.",
      "paragraphStart": false
    }
  ]
}
