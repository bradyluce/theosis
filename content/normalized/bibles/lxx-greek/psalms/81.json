{
  "chapter": {
    "id": "lxx-greek:psalms.81",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 81,
    "referenceLabel": "Psalms 81",
    "summary": "Source text for Psalms 81 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.81.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 1,
      "referenceLabel": "Psalms 81:1",
      "text": "\"Ψαλμος του Ασαφ.\" Ο Θεος ισταται εν τη συναξει των δυνατων αναμεσον των θεων θελει κρινει.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.81.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 2,
      "referenceLabel": "Psalms 81:2",
      "text": "Εως ποτε θελετε κρινει αδικως, και θελετε προσωποληπτει τους ασεβεις; Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 3,
      "referenceLabel": "Psalms 81:3",
      "text": "Κρινατε τον πτωχον και τον ορφανον καμετε δικαιοσυνην εις τον τεθλιμμενον και πενητα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 4,
      "referenceLabel": "Psalms 81:4",
      "text": "Ελευθερονετε τον πτωχον και τον πενητα λυτρονετε αυτον εκ χειρος των ασεβων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 5,
      "referenceLabel": "Psalms 81:5",
      "text": "Δεν γνωριζουσιν, ουδε νοουσι περιπατουσιν εν σκοτει παντα τα θεμελια της γης σαλευονται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 6,
      "referenceLabel": "Psalms 81:6",
      "text": "Εγω ειπα, θεοι εισθε σεις και υιοι Υψιστου παντες",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 7,
      "referenceLabel": "Psalms 81:7",
      "text": "σεις ομως ως ανθρωποι αποθνησκετε, και ως εις των αρχοντων πιπτετε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 8,
      "referenceLabel": "Psalms 81:8",
      "text": "Αναστα, Θεε, κρινον την γην διοτι συ θελεις κατακληρονομησει παντα τα εθνη.",
      "paragraphStart": false
    }
  ]
}
