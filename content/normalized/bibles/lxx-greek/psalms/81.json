{
  "chapter": {
    "id": "lxx-greek:psalms.81",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 81,
    "referenceLabel": "Psalms 81",
    "summary": "Source text for Psalms 81 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.81.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 1,
      "referenceLabel": "Psalms 81:1",
      "text": "\"Εις τον πρωτον μουσικον, επι Γιττιθ. Ψαλμος του Ασαφ.\" Ψαλατε εν ευφροσυνη εις τον Θεον, την δυναμιν ημων αλαλαξατε εις τον Θεον του Ιακωβ.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.81.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 2,
      "referenceLabel": "Psalms 81:2",
      "text": "Υψωσατε ψαλμωδιαν και κρουετε τυμπανον, κιθαραν τερπνην μετα ψαλτηριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 3,
      "referenceLabel": "Psalms 81:3",
      "text": "Σαλπισατε σαλπιγγα εν νεομηνια, εν καιρω ωρισμενω, εν τη ημερα της εορτης ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 4,
      "referenceLabel": "Psalms 81:4",
      "text": "Διοτι προσταγμα ειναι τουτο εις τον Ισραηλ, νομος του Θεου του Ιακωβ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 5,
      "referenceLabel": "Psalms 81:5",
      "text": "Εις μαρτυριον διεταξε τουτο εις τον Ιωσηφ, οτε εξηλθε κατα της γης Αιγυπτου οπου ηκουσα γλωσσαν, την οποιαν δεν εγνωριζον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 6,
      "referenceLabel": "Psalms 81:6",
      "text": "απεμακρυνα απο του φορτιου τον ωμον αυτου αι χειρες αυτου επαυσαν απο κοφινου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 7,
      "referenceLabel": "Psalms 81:7",
      "text": "εν καιρω θλιψεως επεκαλεσθης, και σε ελυτρωσα σοι απεκριθην απο του αποκρυφου τοπου της βροντης σε εδοκιμασα εν τοις υδασι της αντιλογιας. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 8,
      "referenceLabel": "Psalms 81:8",
      "text": "Ακουσον, λαε μου, και θελω διαμαρτυρηθη κατα σου Ισραηλ, εαν μου ακουσης,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 9,
      "referenceLabel": "Psalms 81:9",
      "text": "Ας μη ηναι εις σε θεος ξενος, και μη προσκυνησης θεον αλλοτριον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 10,
      "referenceLabel": "Psalms 81:10",
      "text": "Εγω ειμαι Κυριος ο Θεος σου, οστις σε ανηγαγεν εκ γης Αιγυπτου πλατυνον το στομα σου, και θελω γεμισει αυτο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 11,
      "referenceLabel": "Psalms 81:11",
      "text": "Αλλ' ο λαος μου δεν ηκουσε της φωνης μου, και ο Ισραηλ δεν επροσεξεν εις εμε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 12,
      "referenceLabel": "Psalms 81:12",
      "text": "Δια τουτο παρεδωκα αυτους εις τας επιθυμιας της καρδιας αυτων και περιεπατησαν εν ταις βουλαις αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 13,
      "referenceLabel": "Psalms 81:13",
      "text": "Ειθε να μου ηκουεν ο λαος μου, και ο Ισραηλ να περιεπατει εις τας οδους μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 14,
      "referenceLabel": "Psalms 81:14",
      "text": "παραυτα ηθελον καταβαλει τους εχθρους αυτων, και κατα των θλιβοντων αυτους ηθελον στρεψει την χειρα μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 15,
      "referenceLabel": "Psalms 81:15",
      "text": "Οι μισουντες τον Κυριον ηθελον αποτυχει εναντιον αυτου, ο δε καιρος εκεινων ηθελε διαμενει παντοτε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.81.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 16,
      "referenceLabel": "Psalms 81:16",
      "text": "και ηθελε θρεψει αυτους με το παχος του σιτου, και με μελι εκ πετρας ηθελον σε χορτασει.",
      "paragraphStart": false
    }
  ]
}
