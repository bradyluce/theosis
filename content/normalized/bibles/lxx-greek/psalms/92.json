{
  "chapter": {
    "id": "lxx-greek:psalms.92",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 92,
    "referenceLabel": "Psalms 92",
    "summary": "Source text for Psalms 92 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.92.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 1,
      "referenceLabel": "Psalms 92:1",
      "text": "\"Ψαλμος ωδης δια την ημεραν του Σαββατου.\" Αγαθον το να δοξολογη τις τον Κυριον και να ψαλμωδη εις το ονομα σου, Υψιστε",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.92.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 2,
      "referenceLabel": "Psalms 92:2",
      "text": "να αναγγελλη το πρωι το ελεος σου και την αληθειαν σου πασαν νυκτα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.92.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 3,
      "referenceLabel": "Psalms 92:3",
      "text": "με δεκαχορδον οργανον και με ψαλτηριον με ωδην και κιθαραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.92.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 4,
      "referenceLabel": "Psalms 92:4",
      "text": "Διοτι με ευφρανας, Κυριε, εν τοις ποιημασι σου θελω αγαλλεσθαι εν τοις εργοις των χειρων σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.92.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 5,
      "referenceLabel": "Psalms 92:5",
      "text": "Ποσον μεγαλα ειναι τα εργα σου, Κυριε βαθεις ειναι οι διαλογισμοι σου σφοδρα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.92.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 6,
      "referenceLabel": "Psalms 92:6",
      "text": "Ο ανθρωπος ο ανοητος δεν γνωριζει, και ο μωρος δεν εννοει τουτο",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.92.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 7,
      "referenceLabel": "Psalms 92:7",
      "text": "οτι οι ασεβεις βλαστανουσιν ως ο χορτος, και ανθουσι παντες οι εργαται της ανομιας, δια να αφανισθωσιν αιωνιως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.92.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 8,
      "referenceLabel": "Psalms 92:8",
      "text": "Αλλα συ, Κυριε, εισαι υψιστος εις τον αιωνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.92.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 9,
      "referenceLabel": "Psalms 92:9",
      "text": "Διοτι, ιδου, οι εχθροι σου, Κυριε, διοτι, ιδου, οι εχθροι σου θελουσιν εξολοθρευθη θελουσι διασκορπισθη παντες οι εργαται της ανομιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.92.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 10,
      "referenceLabel": "Psalms 92:10",
      "text": "Αλλα συ θελεις υψωσει ως του μονοκερωτος το κερας μου εγω θελω χρισθη με νεον ελαιον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.92.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 11,
      "referenceLabel": "Psalms 92:11",
      "text": "και ο οφθαλμος μου θελει ιδει την εκδικησιν των εχθρων μου τα ωτα μου θελουσιν ακουσει περι των κακοποιων των επανισταμενων κατ' εμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.92.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 12,
      "referenceLabel": "Psalms 92:12",
      "text": "Ο δικαιος ως φοινιξ θελει ανθει ως κεδρος του Λιβανου θελει αυξανει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.92.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 13,
      "referenceLabel": "Psalms 92:13",
      "text": "Πεφυτευμενοι εν τω οικω του Κυριου, θελουσιν ανθει εν ταις αυλαις του Θεου ημων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.92.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 14,
      "referenceLabel": "Psalms 92:14",
      "text": "θελουσι καρποφορει και εν αυτω τω βαθει γηρατι, θελουσιν εισθαι ακμαζοντες και ανθηροι",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.92.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 15,
      "referenceLabel": "Psalms 92:15",
      "text": "δια να αναγγελλωσιν οτι δικαιος ειναι ο Κυριος, το φρουριον μου και δεν υπαρχει αδικια εν αυτω.",
      "paragraphStart": false
    }
  ]
}
