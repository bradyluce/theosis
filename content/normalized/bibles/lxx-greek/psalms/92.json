{
  "chapter": {
    "id": "lxx-greek:psalms.92",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 92,
    "referenceLabel": "Psalms 92",
    "summary": "Source text for Psalms 92 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.92.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 1,
      "referenceLabel": "Psalms 92:1",
      "text": "Ο Κυριος βασιλευει μεγαλοπρεπειαν ειναι ενδεδυμενος ενδεδυμενος ειναι ο Κυριος δυναμιν και περιεζωσμενος και την οικουμενην εστερεωσεν, ωστε δεν θελει σαλευθη.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.92.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 2,
      "referenceLabel": "Psalms 92:2",
      "text": "Απ' αρχης ειναι εστερεωμενος ο θρονος σου απο του αιωνος συ εισαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.92.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 3,
      "referenceLabel": "Psalms 92:3",
      "text": "Υψωσαν οι ποταμοι, Κυριε, υψωσαν οι ποταμοι την φωνην αυτων οι ποταμοι υψωσαν τα κυματα αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.92.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 4,
      "referenceLabel": "Psalms 92:4",
      "text": "Ο Κυριος ο εν υψιστοις ειναι δυνατωτερος υπερ τον ηχον πολλων υδατων, υπερ τα δυνατα κυματα της θαλασσης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.92.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 5,
      "referenceLabel": "Psalms 92:5",
      "text": "τα μαρτυρια σου ειναι πιστα σφοδρα εις τον οικον σου ανηκει αγιοτης, Κυριε, εις μακροτητα ημερων.",
      "paragraphStart": false
    }
  ]
}
