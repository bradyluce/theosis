{
  "chapter": {
    "id": "lxx-greek:psalms.113",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 113,
    "referenceLabel": "Psalms 113",
    "summary": "Source text for Psalms 113 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.113.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 1,
      "referenceLabel": "Psalms 113:1",
      "text": "Οτε εξηλθεν ο Ισραηλ εξ Αιγυπτου, ο οικος του Ιακωβ εκ λαου βαρβαρου,",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.113.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 2,
      "referenceLabel": "Psalms 113:2",
      "text": "Ο Ιουδας εγεινεν αγιος αυτου, ο Ισραηλ δεσποτεια αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 3,
      "referenceLabel": "Psalms 113:3",
      "text": "Η θαλασσα ειδε και εφυγεν ο Ιορδανης εστραφη εις τα οπισω",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 4,
      "referenceLabel": "Psalms 113:4",
      "text": "τα ορη εσκιρτησαν ως κριοι, οι λοφοι ως αρνια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 5,
      "referenceLabel": "Psalms 113:5",
      "text": "Τι σοι συνεβη, θαλασσα, οτι εφυγες; και συ, Ιορδανη, οτι εστραφης εις τα οπισω;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 6,
      "referenceLabel": "Psalms 113:6",
      "text": "τα ορη, οτι εσκιρτησατε ως κριοι; και οι λοφοι, ως αρνια;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 7,
      "referenceLabel": "Psalms 113:7",
      "text": "Τρεμε, γη, απο προσωπου του Κυριου, απο προσωπου του Θεου του Ιακωβ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 8,
      "referenceLabel": "Psalms 113:8",
      "text": "οστις μετεβαλε την πετραν εις λιμνας υδατων, τον σκληρον βραχον εις πηγας υδατων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 9,
      "referenceLabel": "Psalms 113:9",
      "text": "Μη εις ημας, Κυριε, μη εις ημας, αλλ' εις το ονομα σου δος δοξαν, δια το ελεος σου, δια την αληθειαν σου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.113.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 10,
      "referenceLabel": "Psalms 113:10",
      "text": "Δια τι να ειπωσι τα εθνη, και που ειναι ο Θεος αυτων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 11,
      "referenceLabel": "Psalms 113:11",
      "text": "Αλλ' ο Θεος ημων ειναι εν τω ουρανω παντα οσα ηθελησεν εποιησε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 12,
      "referenceLabel": "Psalms 113:12",
      "text": "Τα ειδωλα αυτων ειναι αργυριον και χρυσιον, εργα χειρων ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 13,
      "referenceLabel": "Psalms 113:13",
      "text": "Στομα εχουσι και δεν λαλουσιν οφθαλμους εχουσι και δεν βλεπουσιν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 14,
      "referenceLabel": "Psalms 113:14",
      "text": "ωτα εχουσι και δεν ακουουσι μυκτηρας εχουσι και δεν οσφραινονται",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 15,
      "referenceLabel": "Psalms 113:15",
      "text": "Χειρας εχουσι και δεν ψηλαφωσι ποδας εχουσι και δεν περιπατουσιν ουδε ομιλουσι δια του λαρυγγος αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 16,
      "referenceLabel": "Psalms 113:16",
      "text": "Ομοιοι αυτων ας γεινωσιν οι ποιουντες αυτα, πας ο ελπιζων επ' αυτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 17,
      "referenceLabel": "Psalms 113:17",
      "text": "Ο Ισραηλ ηλπισεν επι Κυριον αυτος ειναι βοηθος και ασπις αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 18,
      "referenceLabel": "Psalms 113:18",
      "text": "Ο οικος του Ααρων ηλπισεν επι Κυριον αυτος ειναι βοηθος και ασπις αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 19,
      "referenceLabel": "Psalms 113:19",
      "text": "Οι φοβουμενοι τον Κυριον ηλπισαν επι Κυριον αυτος ειναι βοηθος και ασπις αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 20,
      "referenceLabel": "Psalms 113:20",
      "text": "Ο Κυριος μας ενεθυμηθη θελει ευλογει, θελει ευλογει τον οικον Ισραηλ θελει ευλογει τον οικον Ααρων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 21,
      "referenceLabel": "Psalms 113:21",
      "text": "Θελει ευλογει τους φοβουμενους τον Κυριον, τους μικρους μετα των μεγαλων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 22,
      "referenceLabel": "Psalms 113:22",
      "text": "Ο Κυριος θελει αυξησει υμας, υμας και τα τεκνα υμων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 23,
      "referenceLabel": "Psalms 113:23",
      "text": "σεις εισθε οι ευλογημενοι του Κυριου, του ποιησαντος τον ουρανον και την γην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 24,
      "referenceLabel": "Psalms 113:24",
      "text": "Οι ουρανοι των ουρανων ειναι του Κυριου, την δε γην εδωκεν εις τους υιους των ανθρωπων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.25",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 25,
      "referenceLabel": "Psalms 113:25",
      "text": "Οι νεκροι δεν θελουσιν αινεσει τον Κυριον, ουδε παντες οι καταβαινοντες εις τον τοπον της σιωπης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.113.26",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 26,
      "referenceLabel": "Psalms 113:26",
      "text": "αλλ' ημεις θελομεν ευλογει τον Κυριον, απο του νυν και εως του αιωνος. Αλληλουια.",
      "paragraphStart": false
    }
  ]
}
