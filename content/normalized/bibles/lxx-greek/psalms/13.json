    "summary": "Source text for Psalms 13 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.13.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Psalms 13:1",
      "text": "\"Εις τον πρωτον μουσικον. Ψαλμος του Δαβιδ.\" Εως ποτε, Κυριε, θελεις με λησμονει διαπαντος; εως ποτε θελεις κρυπτει το προσωπον σου απ' εμου;",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.13.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Psalms 13:2",
      "text": "Εως ποτε θελω εχει βουλας εν τη ψυχη μου, οδυνας καθ' ημεραν εν τη καρδια μου εως ποτε θελει υψονεσθαι ο εχθρος μου επ' εμε;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.13.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Psalms 13:3",
      "text": "Επιβλεψον εισακουσον μου, Κυριε ο Θεος μου φωτισον τους οφθαλμους μου, μηποτε υπνωσω τον υπνον του θανατου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.13.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Psalms 13:4",
      "text": "Μηποτε ειπη ο εχθρος μου, Υπερισχυσα κατ' αυτου, και οι θλιβοντες με αγαλλιασθωσιν, εαν σαλευθω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.13.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Psalms 13:5",
      "text": "Αλλ' εγω ηλπισα επι το ελεος σου η καρδια μου θελει αγαλλεσθαι εις την σωτηριαν σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.13.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Psalms 13:6",
      "text": "Θελω ψαλλει εις τον Κυριον, διοτι με αντημειψε.",
      "paragraphStart": false
    }
  ]
}
