{
  "chapter": {
    "id": "lxx-greek:psalms.33",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 33,
    "referenceLabel": "Psalms 33",
    "summary": "Source text for Psalms 33 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.33.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 1,
      "referenceLabel": "Psalms 33:1",
      "text": "\"Ψαλμος του Δαβιδ, οτε μετεβαλε τον τροπον αυτου εμπροσθεν του Αβιμελεχ ουτος δε απελυσεν αυτον, και απηλθε.\" Θελω ευλογει τον Κυριον εν παντι καιρω η αινεσις αυτου θελει εισθαι διαπαντος εν τω στοματι μου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.33.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 2,
      "referenceLabel": "Psalms 33:2",
      "text": "Εις τον Κυριον θελει καυχασθαι η ψυχη μου οι ταπεινοι θελουσιν ακουσει, και θελουσι χαρη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 3,
      "referenceLabel": "Psalms 33:3",
      "text": "Μεγαλυνατε τον Κυριον μετ' εμου, και ας υψωσωμεν ομου το ονομα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 4,
      "referenceLabel": "Psalms 33:4",
      "text": "Εξεζητησα τον Κυριον, και επηκουσε μου, και εκ παντων των φοβων μου με ηλευθερωσεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 5,
      "referenceLabel": "Psalms 33:5",
      "text": "Απεβλεψαν προς αυτον και εφωτισθησαν, και τα προσωπα αυτων δεν κατησχυνθησαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 6,
      "referenceLabel": "Psalms 33:6",
      "text": "Ουτος ο πτωχος εκραξε, και ο Κυριος εισηκουσε, και εκ πασων των θλιψεων αυτου εσωσεν αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 7,
      "referenceLabel": "Psalms 33:7",
      "text": "Αγγελος Κυριου στρατοπεδευει κυκλω των φοβουμενων αυτον και ελευθερονει αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 8,
      "referenceLabel": "Psalms 33:8",
      "text": "Γευθητε και ιδετε οτι αγαθος ο Κυριος μακαριος ο ανθρωπος ο ελπιζων επ' αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 9,
      "referenceLabel": "Psalms 33:9",
      "text": "Φοβηθητε τον Κυριον, οι αγιοι αυτου διοτι δεν υπαρχει στερησις εις τους φοβουμενους αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 10,
      "referenceLabel": "Psalms 33:10",
      "text": "Οι πλουσιοι πτωχευουσι και πεινωσιν αλλ' οι εκζητουντες τον Κυριον δεν στερουνται ουδενος αγαθου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 11,
      "referenceLabel": "Psalms 33:11",
      "text": "Ελθετε, τεκνα, ακουσατε μου τον φοβον του Κυριου θελω σας διδαξει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 12,
      "referenceLabel": "Psalms 33:12",
      "text": "Τις ειναι ο ανθρωπος οστις θελει ζωην, αγαπα ημερας, δια να ιδη καλον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 13,
      "referenceLabel": "Psalms 33:13",
      "text": "Φυλαττε την γλωσσαν σου απο κακου, και τα χειλη σου απο του να λαλωσι δολον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 14,
      "referenceLabel": "Psalms 33:14",
      "text": "Εκκλινον απο του κακου και πραττε το αγαθον ζητει ειρηνην και κυνηγει αυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 15,
      "referenceLabel": "Psalms 33:15",
      "text": "Οι οφθαλμοι του Κυριου ειναι επι τους δικαιους, και τα ωτα αυτου εις την κραυγην αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 16,
      "referenceLabel": "Psalms 33:16",
      "text": "Το προσωπον του Κυριου ειναι κατα των πραττοντων κακον, δια να αφανιση απο της γης το μνημοσυνον αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 17,
      "referenceLabel": "Psalms 33:17",
      "text": "Εκραξαν οι δικαιοι, και ο Κυριος εισηκουσε, και εκ πασων των θλιψεων αυτων ελευθερωσεν αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 18,
      "referenceLabel": "Psalms 33:18",
      "text": "Ο Κυριος ειναι πλησιον των συντετριμμενων την καρδιαν, και σωζει τους ταπεινους το πνευμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 19,
      "referenceLabel": "Psalms 33:19",
      "text": "Πολλαι αι θλιψεις του δικαιου, αλλ' εκ πασων τουτων θελει ελευθερωσει αυτον ο Κυριος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 20,
      "referenceLabel": "Psalms 33:20",
      "text": "Αυτος φυλαττει παντα τα οστα αυτου ουδεν εκ τουτων θελει συντριφθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 21,
      "referenceLabel": "Psalms 33:21",
      "text": "Η κακια θελει θανατωσει τον αμαρτωλον και οι μισουντες τον δικαιον θελουσιν απολεσθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 22,
      "referenceLabel": "Psalms 33:22",
      "text": "Ο Κυριος λυτρονει την ψυχην των δουλων αυτου, και δεν θελουσιν απολεσθη παντες οι ελπιζοντες επ' αυτον.",
      "paragraphStart": false
    }
  ]
}
