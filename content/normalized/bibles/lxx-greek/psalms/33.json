{
  "chapter": {
    "id": "lxx-greek:psalms.33",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 33,
    "referenceLabel": "Psalms 33",
    "summary": "Source text for Psalms 33 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.33.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 1,
      "referenceLabel": "Psalms 33:1",
      "text": "Αγαλλεσθε, δικαιοι, εν Κυριω εις τους ευθεις αρμοζει η αινεσις.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.33.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 2,
      "referenceLabel": "Psalms 33:2",
      "text": "Υμνειτε τον Κυριον εν κιθαρα εν ψαλτηριω δεκαχορδω ψαλμωδησατε εις αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 3,
      "referenceLabel": "Psalms 33:3",
      "text": "Ψαλλετε εις αυτον ασμα νεον καλως σημαινετε τα οργανα σας εν αλαλαγμω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 4,
      "referenceLabel": "Psalms 33:4",
      "text": "Διοτι ευθυς ειναι ο λογος του Κυριου, και παντα τα εργα αυτου μετα αληθειας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 5,
      "referenceLabel": "Psalms 33:5",
      "text": "Αγαπα δικαιοσυνην και κρισιν απο του ελεους του Κυριου ειναι πληρης η γη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 6,
      "referenceLabel": "Psalms 33:6",
      "text": "Με τον λογον του Κυριου εγειναν οι ουρανοι, και δια της πνοης του στοματος αυτου πασα η στρατια αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 7,
      "referenceLabel": "Psalms 33:7",
      "text": "Συνηγαγεν ως σωρον τα υδατα της θαλασσης εβαλεν εις αποθηκας τας αβυσσους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 8,
      "referenceLabel": "Psalms 33:8",
      "text": "Ας φοβηθη τον Κυριον πασα η γη ας τρομαξωσιν απ' αυτου παντες οι κατοικοι της οικουμενης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 9,
      "referenceLabel": "Psalms 33:9",
      "text": "Διοτι αυτος ειπε, και εγεινεν αυτος προσεταξε, και εστερεωθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 10,
      "referenceLabel": "Psalms 33:10",
      "text": "Ο Κυριος ματαιονει την βουλην των εθνων, ανατρεπει τους διαλογισμους των λαων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 11,
      "referenceLabel": "Psalms 33:11",
      "text": "Η βουλη του Κυριου μενει εις τον αιωνα οι λογισμοι της καρδιας αυτου εις γενεαν και γενεαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 12,
      "referenceLabel": "Psalms 33:12",
      "text": "Μακαριον το εθνος, του οποιου ο Θεος ειναι ο Κυριος. Ο λαος, τον οποιον εξελεξε δια κληρονομιαν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 13,
      "referenceLabel": "Psalms 33:13",
      "text": "Ο Κυριος διεκυψεν εξ ουρανου ειδε παντας τους υιους των ανθρωπων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 14,
      "referenceLabel": "Psalms 33:14",
      "text": "Εκ του τοπου της κατοικησεως αυτου θεωρει παντας τους κατοικους της γης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 15,
      "referenceLabel": "Psalms 33:15",
      "text": "Εξ ισου επλασε τας καρδιας αυτων γνωριζει παντα τα εργα αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 16,
      "referenceLabel": "Psalms 33:16",
      "text": "Δεν σωζεται βασιλευς δια πληθους στρατευματος ο δυνατος δεν ελευθερουται δια της μεγαλης αυτου ανδρειας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 17,
      "referenceLabel": "Psalms 33:17",
      "text": "Ματαιος ο ιππος προς σωτηριαν και δια της πολλης αυτου δυναμεως δεν θελει σωσει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 18,
      "referenceLabel": "Psalms 33:18",
      "text": "Ιδου, ο οφθαλμος του Κυριου ειναι επι τους φοβουμενους αυτον επι τους ελπιζοντας επι το ελεος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 19,
      "referenceLabel": "Psalms 33:19",
      "text": "δια να ελευθερωση εκ θανατου την ψυχην αυτων, και εν καιρω πεινης να διαφυλαξη αυτους εις ζωην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 20,
      "referenceLabel": "Psalms 33:20",
      "text": "Η ψυχη ημων προσμενει τον Κυριον αυτος ειναι βοηθος ημων και ασπις ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 21,
      "referenceLabel": "Psalms 33:21",
      "text": "Διοτι εις αυτον θελει ευφρανθη η καρδια ημων, επειδη επι το ονομα αυτου το αγιον ηλπισαμεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.33.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 22,
      "referenceLabel": "Psalms 33:22",
      "text": "Γενοιτο, Κυριε, το ελεος σου εφ' ημας, καθως ηλπισαμεν επι σε.",
      "paragraphStart": false
    }
  ]
}
