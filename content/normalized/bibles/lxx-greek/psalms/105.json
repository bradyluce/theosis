{
  "chapter": {
    "id": "lxx-greek:psalms.105",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 105,
    "referenceLabel": "Psalms 105",
    "summary": "Source text for Psalms 105 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.105.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 1,
      "referenceLabel": "Psalms 105:1",
      "text": "Δοξολογειτε τον Κυριον επικαλεισθε το ονομα αυτου καμετε γνωστα εν τοις λαοις τα εργα αυτου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.105.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 2,
      "referenceLabel": "Psalms 105:2",
      "text": "Ψαλλετε εις αυτον ψαλμωδειτε εις αυτον λαλειτε περι παντων των θαυμασιων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 3,
      "referenceLabel": "Psalms 105:3",
      "text": "Καυχασθε εις το αγιον αυτου ονομα ας ευφραινεται η καρδια των εκζητουντων τον Κυριον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 4,
      "referenceLabel": "Psalms 105:4",
      "text": "Ζητειτε τον Κυριον και την δυναμιν αυτου εκζητειτε το προσωπον αυτου διαπαντος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 5,
      "referenceLabel": "Psalms 105:5",
      "text": "Μνημονευετε των θαυμασιων αυτου τα οποια εκαμε των τεραστιων αυτου και των κρισεων του στοματος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 6,
      "referenceLabel": "Psalms 105:6",
      "text": "Σπερμα Αβρααμ του δουλου αυτου, υιοι Ιακωβ, οι εκλεκτοι αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 7,
      "referenceLabel": "Psalms 105:7",
      "text": "Αυτος ειναι Κυριος ο Θεος ημων εν παση τη γη ειναι αι κρισεις αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 8,
      "referenceLabel": "Psalms 105:8",
      "text": "Μνημονευετε παντοτε της διαθηκης αυτου, του λογου, τον οποιον προσεταξεν εις χιλιας γενεας,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 9,
      "referenceLabel": "Psalms 105:9",
      "text": "της διαθηκης, την οποιαν εκαμε προς τον Αβρααμ, και του ορκου αυτου προς τον Ισαακ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 10,
      "referenceLabel": "Psalms 105:10",
      "text": "και εβεβαιωσεν αυτον προς τον Ιακωβ δια νομου, προς τον Ισραηλ δια διαθηκην αιωνιον,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 11,
      "referenceLabel": "Psalms 105:11",
      "text": "λεγων, Εις σε θελω δωσει την γην Χανααν, μεριδα της κληρονομιας σας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 12,
      "referenceLabel": "Psalms 105:12",
      "text": "Ενω ησαν αυτοι ολιγοστοι τον αριθμον, ολιγοι, και παροικοι εν αυτη,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 13,
      "referenceLabel": "Psalms 105:13",
      "text": "και διηρχοντο απο εθνους εις εθνος, απο βασιλειου εις αλλον λαον,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 14,
      "referenceLabel": "Psalms 105:14",
      "text": "δεν αφηκεν ανθρωπον να αδικηση αυτους μαλιστα υπερ αυτων ηλεγξε βασιλεις,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 15,
      "referenceLabel": "Psalms 105:15",
      "text": "λεγων, μη εγγισητε τους κεχρισμενους μου και μη κακοποιησητε τους προφητας μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 16,
      "referenceLabel": "Psalms 105:16",
      "text": "Και εκαλεσε πειναν επι την γην συνετριψε παν στηριγμα αρτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 17,
      "referenceLabel": "Psalms 105:17",
      "text": "Απεστειλεν εμπροσθεν αυτων ανθρωπον, Ιωσηφ τον πωληθεντα ως δουλον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 18,
      "referenceLabel": "Psalms 105:18",
      "text": "του οποιου τους ποδας εσφιγξαν εν δεσμοις εβαλον αυτον εις τα σιδηρα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 19,
      "referenceLabel": "Psalms 105:19",
      "text": "εωσου ελθη ο λογος αυτου ο λογος του Κυριου εδοκιμασεν αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 20,
      "referenceLabel": "Psalms 105:20",
      "text": "Απεστειλεν ο βασιλευς και ελυσεν αυτον ο αρχων των λαων, και ηλευθερωσεν αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 21,
      "referenceLabel": "Psalms 105:21",
      "text": "Κατεστησεν αυτον κυριον του οικου αυτου, και αρχοντα επι παντων των κτηματων αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 22,
      "referenceLabel": "Psalms 105:22",
      "text": "δια να παιδευη τους αρχοντας αυτου κατα την αρεσκειαν αυτου, και να διδαξη σοφιαν τους πρεσβυτερους αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 23,
      "referenceLabel": "Psalms 105:23",
      "text": "Τοτε ηλθεν ο Ισραηλ εις την Αιγυπτον, και ο Ιακωβ παρωκησεν εν γη Χαμ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 24,
      "referenceLabel": "Psalms 105:24",
      "text": "Και ο Κυριος ηυξησε σφοδρα τον λαον αυτου, και εκραταιωσεν αυτον υπερ τους εχθρους αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.25",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 25,
      "referenceLabel": "Psalms 105:25",
      "text": "Εστραφη η καρδια αυτων εις το να μισωσι τον λαον αυτου, εις το να δολιευωνται εναντιον των δουλων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.26",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 26,
      "referenceLabel": "Psalms 105:26",
      "text": "Εξαπεστειλε Μωυσην τον δουλον αυτου, και Ααρων, τον οποιον εξελεξεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.27",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 27,
      "referenceLabel": "Psalms 105:27",
      "text": "Εξετελεσαν εν μεσω αυτων τους λογους των σημειων αυτου και τα θαυμασια αυτου εν γη Χαμ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.28",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 28,
      "referenceLabel": "Psalms 105:28",
      "text": "Εξαπεστειλε σκοτος, και εσκοτασε και δεν ηπειθησαν εις τους λογους αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.29",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 29,
      "referenceLabel": "Psalms 105:29",
      "text": "Μετεβαλε τα υδατα αυτων εις αιμα και εθανατωσε τους ιχθυας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.30",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 30,
      "referenceLabel": "Psalms 105:30",
      "text": "Η γη αυτων ανεβρυσε βατραχους, εως των ταμειων των βασιλεων αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.31",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 31,
      "referenceLabel": "Psalms 105:31",
      "text": "Ειπε, και ηλθε κυνομυια, και σκνιπες εις παντα τα ορια αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.32",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 32,
      "referenceLabel": "Psalms 105:32",
      "text": "Εδωκεν εις αυτους χαλαζαν αντι βροχης, και πυρ φλογερον εις την γην αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.33",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 33,
      "referenceLabel": "Psalms 105:33",
      "text": "και επαταξε τας αμπελους αυτων και τας συκεας αυτων, και συνετριψε τα δενδρα των οριων αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.34",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 34,
      "referenceLabel": "Psalms 105:34",
      "text": "Ειπε, και ηλθεν ακρις, και βρουχος αναριθμητος",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.35",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 35,
      "referenceLabel": "Psalms 105:35",
      "text": "και κατεφαγε παντα τον χορτον εν τη γη αυτων, και κατεφαγε τον καρπον της γης αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.36",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 36,
      "referenceLabel": "Psalms 105:36",
      "text": "Και επαταξε παν πρωτοτοκον εν τη γη αυτων, την απαρχην πασης δυναμεως αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.37",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 37,
      "referenceLabel": "Psalms 105:37",
      "text": "Και εξηγαγεν αυτους μετα αργυριου και χρυσιου, και δεν υπηρχεν ασθενης εν ταις φυλαις αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.38",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 38,
      "referenceLabel": "Psalms 105:38",
      "text": "Ευφρανθη η Αιγυπτος εις την εξοδον αυτων διοτι ο φοβος αυτων ειχεν επιπεσει επ' αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.39",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 39,
      "referenceLabel": "Psalms 105:39",
      "text": "Εξηπλωσε νεφελην δια να σκεπαζη αυτους, και πυρ δια να φεγγη την νυκτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.40",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 40,
      "referenceLabel": "Psalms 105:40",
      "text": "Εζητησαν, και εφερεν ορτυκια και αρτον ουρανου εχορτασεν αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.41",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 41,
      "referenceLabel": "Psalms 105:41",
      "text": "Διηνοιξε την πετραν, και ανεβλυσαν υδατα, και διερρευσαν ποταμοι εν τοποις ανυδροις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.42",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 42,
      "referenceLabel": "Psalms 105:42",
      "text": "Διοτι ενεθυμηθη τον λογον τον αγιον αυτου, τον προς Αβρααμ τον δουλον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.43",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 43,
      "referenceLabel": "Psalms 105:43",
      "text": "Και εξηγαγε τον λαον αυτου εν αγαλλιασει, τους εκλεκτους αυτου εν χαρα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.44",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 44,
      "referenceLabel": "Psalms 105:44",
      "text": "και εδωκεν εις αυτους τας γαιας των εθνων, και εκληρονομησαν τους κοπους των λαων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.45",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 45,
      "referenceLabel": "Psalms 105:45",
      "text": "δια να φυλαττωσι τα διαταγματα αυτου, και να εκτελωσι τους νομους αυτου. Αλληλουια.",
      "paragraphStart": false
    }
  ]
}
