{
  "chapter": {
    "id": "lxx-greek:psalms.105",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 105,
    "referenceLabel": "Psalms 105",
    "summary": "Source text for Psalms 105 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.105.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 1,
      "referenceLabel": "Psalms 105:1",
      "text": "Αλληλουια. Αινειτε τον Κυριον, διοτι ειναι αγαθος διοτι το ελεος αυτου μενει εις τον αιωνα.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.105.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 2,
      "referenceLabel": "Psalms 105:2",
      "text": "Τις δυναται να κηρυξη τα κραταια εργα του Κυριου, να καμη ακουστας πασας τας αινεσεις αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 3,
      "referenceLabel": "Psalms 105:3",
      "text": "Μακαριοι οι φυλαττοντες κρισιν, οι πραττοντες δικαιοσυνην εν παντι καιρω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 4,
      "referenceLabel": "Psalms 105:4",
      "text": "Μνησθητι μου, Κυριε, εν τη ευμενεια τη προς τον λαον σου επισκεφθητι με εν τη σωτηρια σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 5,
      "referenceLabel": "Psalms 105:5",
      "text": "δια να βλεπω το καλον των εκλεκτων σου, δια να ευφραινωμαι εν τη ευφροσυνη του εθνους σου, δια να καυχωμαι μετα της κληρονομιας σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 6,
      "referenceLabel": "Psalms 105:6",
      "text": "Ημαρτησαμεν μετα των πατερων ημων ηνομησαμεν, ησεβησαμεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 7,
      "referenceLabel": "Psalms 105:7",
      "text": "Οι πατερες ημων εν Αιγυπτω δεν ενοησαν τα θαυμασια σου δεν ενεθυμηθησαν το πληθος του ελεους σου, και σε παρωργισαν εν τη θαλασση, εν τη Ερυθρα θαλασση.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 8,
      "referenceLabel": "Psalms 105:8",
      "text": "Και ομως εσωσεν αυτους δια το ονομα αυτου, δια να καμη γνωστα τα κραταια εργα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 9,
      "referenceLabel": "Psalms 105:9",
      "text": "Και επετιμησε την Ερυθραν θαλασσαν, και εξηρανθη και διεβιβασεν αυτους δια των αβυσσων ως δι' ερημου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 10,
      "referenceLabel": "Psalms 105:10",
      "text": "και εσωσεν αυτους εκ της χειρος του μισουντος αυτους, και ελυτρωσεν αυτους εκ της χειρος του εχθρου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 11,
      "referenceLabel": "Psalms 105:11",
      "text": "Και τα υδατα κατεκαλυψαν τους εχθρους αυτων δεν απελειφθη ουδε εις εξ αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 12,
      "referenceLabel": "Psalms 105:12",
      "text": "Τοτε επιστευσαν εις τους λογους αυτου εψαλαν την αινεσιν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 13,
      "referenceLabel": "Psalms 105:13",
      "text": "Πλην ταχεως ελησμονησαν τα εργα αυτου δεν περιεμειναν την βουλην αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 14,
      "referenceLabel": "Psalms 105:14",
      "text": "Αλλ' επεθυμησαν επιθυμιαν εν τη ερημω, και επειρασαν τον Θεον εν τη ανυδρω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 15,
      "referenceLabel": "Psalms 105:15",
      "text": "Και εδωκεν εις αυτους την αιτησιν αυτων απεστειλεν ομως εις αυτους νοσον θανατηφορον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 16,
      "referenceLabel": "Psalms 105:16",
      "text": "Εφθονησαν ετι τον Μωυσην εν τω στρατοπεδω και τον Ααρων τον αγιον του Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 17,
      "referenceLabel": "Psalms 105:17",
      "text": "Η γη ηνοιξε και κατεπιε τον Δαθαν, και εσκεπασε την συναγωγην του Αβειρων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 18,
      "referenceLabel": "Psalms 105:18",
      "text": "και πυρ εξηφθη εν τη συναγωγη αυτων η φλοξ κατεκαυσε τους ασεβεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 19,
      "referenceLabel": "Psalms 105:19",
      "text": "Κατεσκευασαν μοσχον εν Χωρηβ, και προσεκυνησαν το χωνευτον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 20,
      "referenceLabel": "Psalms 105:20",
      "text": "και μετηλλαξαν την δοξαν αυτων εις ομοιωμα βοος τρωγοντος χορτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 21,
      "referenceLabel": "Psalms 105:21",
      "text": "Ελησμονησαν τον Θεον τον σωτηρα αυτων τον ποιησαντα μεγαλεια εν Αιγυπτω,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 22,
      "referenceLabel": "Psalms 105:22",
      "text": "θαυμασια εν γη Χαμ, φοβερα εν τη Ερυθρα θαλασση.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 23,
      "referenceLabel": "Psalms 105:23",
      "text": "Και ειπε να εξολοθρευση αυτους, αν ο Μωυσης ο εκλεκτος αυτου δεν ιστατο εν τη θραυσει ενωπιον αυτου, δια να αποστρεψη την οργην αυτου, ωστε να μη αφανιση αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 24,
      "referenceLabel": "Psalms 105:24",
      "text": "Κατεφρονησαν ετι την γην την επιθυμητην δεν επιστευσαν εις τον λογον αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.25",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 25,
      "referenceLabel": "Psalms 105:25",
      "text": "και εγογγυσαν εν ταις σκηναις αυτων δεν εισηκουσαν της φωνης του Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.26",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 26,
      "referenceLabel": "Psalms 105:26",
      "text": "Δια τουτο εσηκωσε την χειρα αυτου κατ' αυτων, δια να καταστρεψη αυτους εν τη ερημω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.27",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 27,
      "referenceLabel": "Psalms 105:27",
      "text": "και να στρεψη το σπερμα αυτων μεταξυ των εθνων και να διασκορπιση αυτους εις τους τοπους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.28",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 28,
      "referenceLabel": "Psalms 105:28",
      "text": "Και προσεκολληθησαν εις τον Βεελ-φεγωρ, και εφαγον θυσιας νεκρων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.29",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 29,
      "referenceLabel": "Psalms 105:29",
      "text": "και παρωξυναν αυτον εν τοις εργοις αυτων, ωστε εφωρμησεν επ' αυτους η πληγη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.30",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 30,
      "referenceLabel": "Psalms 105:30",
      "text": "Αλλα σταθεις ο Φινεες εκαμε κρισιν και η πληγη επαυσε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.31",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 31,
      "referenceLabel": "Psalms 105:31",
      "text": "και ελογισθη εις αυτον δια δικαιοσυνην, εις γενεαν και γενεαν εως αιωνος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.32",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 32,
      "referenceLabel": "Psalms 105:32",
      "text": "Και παρωξυναν αυτον εν τοις υδασι της αντιλογιας, και επαθε κακως ο Μωυσης δι' αυτους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.33",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 33,
      "referenceLabel": "Psalms 105:33",
      "text": "διοτι παρωργισαν το πνευμα αυτου, ωστε ελαλησεν αστοχαστως δια των χειλεων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.34",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 34,
      "referenceLabel": "Psalms 105:34",
      "text": "Δεν εξωλοθρευσαν τα εθνη τα οποια ο Κυριος προσεταξεν εις αυτους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.35",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 35,
      "referenceLabel": "Psalms 105:35",
      "text": "αλλ' εσμιχθησαν μετα των εθνων και εμαθον τα εργα αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.36",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 36,
      "referenceLabel": "Psalms 105:36",
      "text": "και ελατρευσαν τα γλυπτα αυτων, τα οποια εγειναν παγις εις αυτους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.37",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 37,
      "referenceLabel": "Psalms 105:37",
      "text": "και εθυσιασαν τους υιους αυτων και τας θυγατερας αυτων εις τα δαιμονια",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.38",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 38,
      "referenceLabel": "Psalms 105:38",
      "text": "Και εχυσαν αιμα αθωον, το αιμα των υιων αυτων και των θυγατερων αυτων τους οποιους εθυσιασαν εις τα γλυπτα της Χανααν και εμιανθη η γη εξ αιματων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.39",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 39,
      "referenceLabel": "Psalms 105:39",
      "text": "Και εμολυνθησαν με τα εργα αυτων, και επορνευσαν με τας πραξεις αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.40",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 40,
      "referenceLabel": "Psalms 105:40",
      "text": "Δια τουτο η οργη του Κυριου εξηφθη κατα του λαου αυτου, και εβδελυχθη την κληρονομιαν αυτου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.41",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 41,
      "referenceLabel": "Psalms 105:41",
      "text": "Και παρεδωκεν αυτους εις τας χειρας των εθνων και εκυριευσαν αυτους οι μισουντες αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.42",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 42,
      "referenceLabel": "Psalms 105:42",
      "text": "Και εθλιψαν αυτους οι εχθροι αυτων, και εταπεινωθησαν υπο τας χειρας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.43",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 43,
      "referenceLabel": "Psalms 105:43",
      "text": "Πολλακις ελυτρωσεν αυτους, αλλ' αυτοι παρωργισαν αυτον με τας βουλας αυτων διο εταπεινωθησαν δια την ανομιαν αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.44",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 44,
      "referenceLabel": "Psalms 105:44",
      "text": "Πλην επεβλεψεν επι την θλιψιν αυτων, οτε ηκουσε την κραυγην αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.45",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 45,
      "referenceLabel": "Psalms 105:45",
      "text": "και ενεθυμηθη την προς αυτους διαθηκην αυτου και μετεμεληθη κατα το πληθος του ελεους αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.46",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 46,
      "referenceLabel": "Psalms 105:46",
      "text": "Και εκαμεν αυτους να ευρωσιν ελεος ενωπιον παντων των αιχμαλωτισαντων αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.47",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 47,
      "referenceLabel": "Psalms 105:47",
      "text": "Σωσον ημας, Κυριε ο Θεος ημων, και συναγαγε ημας απο των εθνων, δια να δοξολογωμεν το ονομα σου το αγιον και να καυχωμεθα εις την αινεσιν σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.105.48",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 48,
      "referenceLabel": "Psalms 105:48",
      "text": "Ευλογητος Κυριος ο Θεος του Ισραηλ, απο του αιωνος και εως του αιωνος και ας λεγη πας ο λαος, Αμην. Αλληλουια.",
      "paragraphStart": false
    }
  ]
}
