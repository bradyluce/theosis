{
  "chapter": {
    "id": "lxx-greek:psalms.43",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 43,
    "referenceLabel": "Psalms 43",
    "summary": "Source text for Psalms 43 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.43.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 1,
      "referenceLabel": "Psalms 43:1",
      "text": "\"Εις τον πρωτον μουσικον, δια τους υιους Κορε Μασχιλ.\" Θεε, με τα ωτα ημων ηκουσαμεν, οι πατερες ημων διηγηθησαν προς ημας το εργον, το οποιον επραξας εν ταις ημεραις αυτων, εν ημεραις αρχαιαις.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.43.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 2,
      "referenceLabel": "Psalms 43:2",
      "text": "Συ δια της χειρος σου εξεδιωξας εθνη και εφυτευσας αυτους κατεθλιψας λαους και απεδιωξας αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 3,
      "referenceLabel": "Psalms 43:3",
      "text": "Διοτι δεν εκληρονομησαν την γην δια της ρομφαιας αυτων, και ο βραχιων αυτων δεν εσωσεν αυτους αλλ' η δεξια σου και ο βραχιων σου και το φως του προσωπου σου διοτι ευηρεστηθης εις αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 4,
      "referenceLabel": "Psalms 43:4",
      "text": "Συ εισαι ο βασιλευς μου, Θεε, ο διοριζων τας σωτηριας του Ιακωβ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 5,
      "referenceLabel": "Psalms 43:5",
      "text": "Δια σου θελομεν καταβαλει τους εχθρους ημων δια του ονοματος σου θελομεν καταπατησει τους επανισταμενους εφ' ημας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 6,
      "referenceLabel": "Psalms 43:6",
      "text": "Διοτι δεν θελω ελπισει επι το τοξον ουδε η ρομφαια μου θελει με σωσει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 7,
      "referenceLabel": "Psalms 43:7",
      "text": "Διοτι συ εσωσας ημας εκ των εχθρων ημων και κατησχυνας τους μισουντας ημας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 8,
      "referenceLabel": "Psalms 43:8",
      "text": "εις τον Θεον θελομεν καυχασθαι ολην την ημεραν, και το ονομα σου εις τον αιωνα θελομεν υμνει. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 9,
      "referenceLabel": "Psalms 43:9",
      "text": "Ομως απεβαλες και κατησχυνας ημας, και δεν εξερχεσαι πλεον μετα των στρατευματων ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 10,
      "referenceLabel": "Psalms 43:10",
      "text": "Εκαμες ημας να στρεψωμεν εις τα οπισω εμπροσθεν του εχθρου και οι μισουντες ημας διαρπαζουσι τα ημετερα εις εαυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 11,
      "referenceLabel": "Psalms 43:11",
      "text": "Παρεδωκας ημας ως προβατα εις βρωσιν και εις τα εθνη διεσκορπισας ημας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 12,
      "referenceLabel": "Psalms 43:12",
      "text": "Επωλησας τον λαον σου ανευ τιμης, και δεν ηυξησας τον πλουτον σου εκ της πωλησεως αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 13,
      "referenceLabel": "Psalms 43:13",
      "text": "Κατεστησας ημας ονειδος εις τους γειτονας ημων, καταγελων και χλευασμον εις τους περιξ ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 14,
      "referenceLabel": "Psalms 43:14",
      "text": "Κατεστησας ημας παροιμιαν μεταξυ των εθνων, κινησιν κεφαλης μεταξυ των λαων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 15,
      "referenceLabel": "Psalms 43:15",
      "text": "Ολην την ημεραν η εντροπη μου ειναι ενωπιον μου, και η αισχυνη του προσωπου μου με εκαλυψε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 16,
      "referenceLabel": "Psalms 43:16",
      "text": "δια την φωνην του ονειδιζοντος και υβριζοντος δια τον εχθρον και εκδικητην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 17,
      "referenceLabel": "Psalms 43:17",
      "text": "Παντα ταυτα ηλθον εφ' ημας, ομως δεν σε ελησμονησαμεν και δεν ηθετησαμεν την διαθηκην σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 18,
      "referenceLabel": "Psalms 43:18",
      "text": "Ουδε εστραφη εις τα οπισω η καρδια ημων, ουδε εξεκλιναν τα βηματα ημων απο της οδου σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 19,
      "referenceLabel": "Psalms 43:19",
      "text": "Αν και συνετριψας ημας εν τω τοπω των δρακοντων και περιεκαλυψας ημας δια της σκιας του θανατου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 20,
      "referenceLabel": "Psalms 43:20",
      "text": "Εαν ελησμονουμεν το ονομα του Θεου ημων και εξετεινομεν τας χειρας ημων εις Θεον αλλοτριον,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 21,
      "referenceLabel": "Psalms 43:21",
      "text": "ο Θεος δεν ηθελεν εξετασει τουτο; διοτι αυτος εξευρει τα κρυφια της καρδιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 22,
      "referenceLabel": "Psalms 43:22",
      "text": "Οτι ενεκα σου θανατουμεθα ολην την ημεραν ελογισθημεν ως προβατα σφαγης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 23,
      "referenceLabel": "Psalms 43:23",
      "text": "Εξεγερθητι, δια τι καθευδεις, Κυριε; εξεγερθητι, μη αποβαλης ημας διαπαντος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 24,
      "referenceLabel": "Psalms 43:24",
      "text": "Δια τι κρυπτεις το προσωπον σου; λησμονεις την ταλαιπωριαν ημων και την καταδυναστευσιν ημων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.25",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 25,
      "referenceLabel": "Psalms 43:25",
      "text": "Διοτι εταπεινωθη εως χωματος η ψυχη ημων εκολληθη εις την γην η κοιλια ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.43.26",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 26,
      "referenceLabel": "Psalms 43:26",
      "text": "Αναστηθι εις βοηθειαν ημων και λυτρωσον ημας ενεκεν του ελεους σου.",
      "paragraphStart": false
    }
  ]
}
