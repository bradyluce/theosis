{
  "chapter": {
    "id": "lxx-greek:psalms.50",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 50,
    "referenceLabel": "Psalms 50",
    "summary": "Source text for Psalms 50 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.50.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 1,
      "referenceLabel": "Psalms 50:1",
      "text": "\"Εις τον πρωτον μουσικον. Ψαλμος του Δαβιδ, οτε ηλθε Ναθαν ο προφητης προς αυτον, αφου εισηλθε προς την Βηθσαβεε.\" Ελεησον με, ω Θεε, κατα το ελεος σου κατα το πληθος των οικτιρμων σου εξαλειψον τα ανομηματα μου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.50.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 2,
      "referenceLabel": "Psalms 50:2",
      "text": "Πλυνον με μαλλον και μαλλον απο της ανομιας μου και απο της αμαρτιας μου καθαρισον με.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.50.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 3,
      "referenceLabel": "Psalms 50:3",
      "text": "Διοτι τα ανομηματα μου εγω γνωριζω, και η αμαρτια μου ενωπιον μου ειναι διαπαντος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.50.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 4,
      "referenceLabel": "Psalms 50:4",
      "text": "Εις σε, εις σε μονον ημαρτον και το πονηρον ενωπιον σου επραξα δια να δικαιωθης εν τοις λογοις σου και να ησαι αμεμπτος εις τας κρισεις σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.50.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 5,
      "referenceLabel": "Psalms 50:5",
      "text": "Ιδου, συνεληφθην εν ανομια, και εν αμαρτια με εγεννησεν μητηρ μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.50.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 6,
      "referenceLabel": "Psalms 50:6",
      "text": "Ιδου, ηγαπησας αληθειαν εν τη καρδια, και εις τα ενδομυχα θελεις με διδαξει σοφιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.50.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 7,
      "referenceLabel": "Psalms 50:7",
      "text": "Ραντισον με με υσσωπον, και θελω εισθαι καθαρος πλυνον με, και θελω εισθαι λευκοτερος χιονος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.50.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 8,
      "referenceLabel": "Psalms 50:8",
      "text": "Καμε με να ακουσω αγαλλιασιν και ευφροσυνην, δια να ευφρανθωσι τα οστα, τα οποια συνεθλασας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.50.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 9,
      "referenceLabel": "Psalms 50:9",
      "text": "Αποστρεψον το προσωπον σου απο των αμαρτιων μου και πασας τας ανομιας μου εξαλειψον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.50.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 10,
      "referenceLabel": "Psalms 50:10",
      "text": "Καρδιαν καθαραν κτισον εν εμοι, Θεε και πνευμα ευθες ανανεωσον εντος μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.50.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 11,
      "referenceLabel": "Psalms 50:11",
      "text": "Μη με απορριψης απο του προσωπου σου και το πνευμα το αγιον σου μη αφαιρεσης απ' εμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.50.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 12,
      "referenceLabel": "Psalms 50:12",
      "text": "Αποδος μοι την αγαλλιασιν της σωτηριας σου και με πνευμα ηγεμονικον στηριξον με.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.50.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 13,
      "referenceLabel": "Psalms 50:13",
      "text": "Θελω διδαξει εις τους παραβατας τας οδους σου και αμαρτωλοι θελουσιν επιστρεφει εις σε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.50.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 14,
      "referenceLabel": "Psalms 50:14",
      "text": "Ελευθερωσον με απο αιματων, Θεε, Θεε της σωτηριας μου η γλωσσα μου θελει ψαλλει εν αγαλλιασει την δικαιοσυνην σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.50.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 15,
      "referenceLabel": "Psalms 50:15",
      "text": "Κυριε, ανοιξον τα χειλη μου και το στομα μου θελει αναγγελλει την αινεσιν σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.50.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 16,
      "referenceLabel": "Psalms 50:16",
      "text": "Διοτι δεν θελεις θυσιαν, αλλως ηθελον προσφερει εις ολοκαυτωματα δεν αρεσκεσαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.50.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 17,
      "referenceLabel": "Psalms 50:17",
      "text": "Θυσιαι του Θεου ειναι πνευμα συντετριμμενον καρδιαν συντετριμμενην και τεταπεινωμενην, Θεε, δεν θελεις καταφρονησει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.50.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 18,
      "referenceLabel": "Psalms 50:18",
      "text": "Ευεργετησον την Σιων δια της ευνοιας σου οικοδομησον τα τειχη της Ιερουσαλημ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.50.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 19,
      "referenceLabel": "Psalms 50:19",
      "text": "Τοτε θελεις ευαρεστηθη εις θυσιας δικαιοσυνης, εις προσφορας και ολοκαυτωματα τοτε θελουσι προσφερει μοσχους επι το θυσιαστηριον σου.",
      "paragraphStart": false
    }
  ]
}
