{
  "chapter": {
    "id": "lxx-greek:psalms.9",
    "translationId": "lxx-greek",
    "bookSlug": "psalms",
    "chapterNumber": 9,
    "referenceLabel": "Psalms 9",
    "summary": "Source text for Psalms 9 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:psalms.9.1",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Psalms 9:1",
      "text": "\"Εις τον πρωτον μουσικον, επι Μουθ-λαββεν. Ψαλμος του Δαβιδ.\" Θελω σε δοξολογησει, Κυριε, εν ολη καρδια μου θελω διηγηθη παντα τα θαυμασια σου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.9.2",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Psalms 9:2",
      "text": "Θελω ευφρανθη και χαρη εν σοι θελω ψαλμωδησει εις το ονομα σου, Υψιστε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.3",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Psalms 9:3",
      "text": "Οταν στραφωσιν οι εχθροι μου εις τα οπισω, πεσωσι και αφανισθωσιν απ' εμπροσθεν σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.4",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Psalms 9:4",
      "text": "Διοτι συ εκαμες την κρισιν μου και την δικην μου εκαθησας επι θρονου κρινων εν δικαιοσυνη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.5",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Psalms 9:5",
      "text": "Επετιμησας τα εθνη εξωλοθρευσας τον ασεβη το ονομα αυτων εξηλειψας εις τον αιωνα του αιωνος",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.6",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Psalms 9:6",
      "text": "Εχθρε, αι ερημωσεις εξελιπον διαπαντος και κατηδαφισας πολεις το μνημοσυνον αυτων εχαθη μετ' αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.7",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Psalms 9:7",
      "text": "Αλλ' ο Κυριος διαμενει εις τον αιωνα ητοιμασε τον θρονον αυτου δια κρισιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.8",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Psalms 9:8",
      "text": "Και αυτος θελει κρινει την οικουμενην εν δικαιοσυνη θελει κρινει τους λαους εν ευθυτητι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.9",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Psalms 9:9",
      "text": "Και ο Κυριος θελει εισθαι καταφυγιον εις τον πενητα, καταφυγιον εν καιρω θλιψεως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.10",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Psalms 9:10",
      "text": "Και θελουσιν ελπισει επι σε οι γνωριζοντες το ονομα σου διοτι δεν εγκατελιπες τους εκζητουντας σε, Κυριε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.11",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Psalms 9:11",
      "text": "Ψαλμωδειτε εις τον Κυριον, τον κατοικουντα εν Σιων αναγγειλατε μεταξυ των λαων τα κατορθωματα αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.12",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Psalms 9:12",
      "text": "διοτι οταν καμνη εκζητησιν αιματων, ενθυμειται αυτους δεν λησμονει την κραυγην των ταλαιπωρουμενων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.13",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Psalms 9:13",
      "text": "Ελεησον με, Κυριε ιδε την θλιψιν μου την εκ των εχθρων μου, συ ο υψονων με εκ των πυλων του θανατου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.14",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Psalms 9:14",
      "text": "δια να διηγηθω πασας τας αινεσεις σου εν ταις πυλαις της θυγατρος Σιων εγω θελω αγαλλιασθαι δια την σωτηριαν σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.15",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Psalms 9:15",
      "text": "Τα εθνη κατεβυθισθησαν εις τον λακκον, τον οποιον εκαμον εν τη παγιδι, την οποιαν εκρυψαν, επιασθη ο πους αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.16",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Psalms 9:16",
      "text": "Ο Κυριος γνωριζεται δια την κρισιν, την οποιαν καμνει ο ασεβης παγιδευεται εν τω εργω των χειρων αυτου Ιγαιων Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.17",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Psalms 9:17",
      "text": "Οι ασεβεις θελουσιν επιστραφη εις τον αδην παντα τα εθνη τα λησμονουντα τον Θεον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.18",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Psalms 9:18",
      "text": "Διοτι δεν θελει λησμονηθη διαπαντος ο πτωχος η προσδοκια των πενητων δεν θελει απολεσθη διαπαντος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.19",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Psalms 9:19",
      "text": "Αναστηθι, Κυριε ας μη υπερισχυη ανθρωπος ας κριθωσι τα εθνη ενωπιον σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.20",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Psalms 9:20",
      "text": "Καταστησον, Κυριε, νομοθετην επ' αυτους ας γνωρισωσι τα εθνη, οτι ειναι ανθρωποι. Διαψαλμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.21",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Psalms 9:21",
      "text": "Δια τι, Κυριε, ιστασαι μακροθεν; κρυπτεσαι εν καιρω θλιψεως;",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:psalms.9.22",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "Psalms 9:22",
      "text": "Εν τη υπερηφανια του ασεβους κατακαιεται ο πτωχος ας πιασθωσιν εν ταις πανουργιαις, τας οποιας διαλογιζονται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.23",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "Psalms 9:23",
      "text": "Διοτι ο ασεβης καυχαται εις τας επιθυμιας της ψυχης αυτου, και ο πλεονεκτης μακαριζει εαυτον καταφρονει τον Κυριον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.24",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "Psalms 9:24",
      "text": "Ο ασεβης δια την αλαζονειαν του προσωπου αυτου δεν θελει εκζητησει τον Κυριον παντες οι διαλογισμοι αυτου ειναι οτι δεν υπαρχει Θεος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.25",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "Psalms 9:25",
      "text": "Αι οδοι αυτου μολυνονται εν παντι καιρω αι κρισεις σου ειναι πολυ υψηλα απο προσωπου αυτου φυσα εναντιον παντων των εχθρων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.26",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "Psalms 9:26",
      "text": "Ειπεν εν τη καρδια αυτου, δεν θελω σαλευθη απο γενεας εις γενεαν διοτι δεν θελω πεσει εις δυστυχιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.27",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "Psalms 9:27",
      "text": "Το στομα αυτου γεμει καταρας και απατης και δολου υπο την γλωσσαν αυτου ειναι κακια και ανομια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.28",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "Psalms 9:28",
      "text": "Καθηται εν ενεδρα των προαυλιων, εν αποκρυφοις, δια να φονευση τον αθωον οι οφθαλμοι αυτου παραμονευουσι τον πενητα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.29",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 29,
      "referenceLabel": "Psalms 9:29",
      "text": "Ενεδρευει εν αποκρυφω, ως λεων εν τω σπηλαιω αυτου ενεδρευει δια να αρπαση τον πτωχον αρπαζει τον πτωχον, οταν συρη αυτον εν τη παγιδι αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.30",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 30,
      "referenceLabel": "Psalms 9:30",
      "text": "Κυπτει, χαμηλονει, δια να πεσωσιν οι πτωχοι εις τους ονυχας αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.31",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 31,
      "referenceLabel": "Psalms 9:31",
      "text": "Ειπεν εν τη καρδια αυτου, ελησμονησεν ο Θεος εκρυψε το προσωπον αυτου δεν θελει ιδει ποτε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.32",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 32,
      "referenceLabel": "Psalms 9:32",
      "text": "Αναστηθι, Κυριε Θεε, υψωσον την χειρα σου μη λησμονησης τους τεθλιμμενους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.33",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 33,
      "referenceLabel": "Psalms 9:33",
      "text": "Δια τι παρωξυνεν ο ασεβης τον Θεον; ειπεν εν τη καρδια αυτου, Δεν θελεις εξετασει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.34",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 34,
      "referenceLabel": "Psalms 9:34",
      "text": "Ειδες διοτι συ παρατηρεις την αδικιαν και την υβριν, δια να ανταποδωσης με την χειρα σου εις σε αφιερονεται ο πτωχος εις τον ορφανον συ εισαι ο βοηθος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.35",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 35,
      "referenceLabel": "Psalms 9:35",
      "text": "Συντριψον τον βραχιονα του ασεβους και πονηρου εξερευνησον την ασεβειαν αυτου, εωσου μη ευρης αυτην πλεον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.36",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 36,
      "referenceLabel": "Psalms 9:36",
      "text": "Ο Κυριος ειναι βασιλευς εις τον αιωνα του αιωνος τα εθνη θελουσιν εξαλειφθη εκ της γης αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.37",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 37,
      "referenceLabel": "Psalms 9:37",
      "text": "Κυριε, εισηκουσας την επιθυμιαν των πενητων θελεις στηριξει την καρδιαν αυτων, θελεις καμει προσεκτικον το ωτιον σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:psalms.9.38",
      "translationId": "lxx-greek",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 38,
      "referenceLabel": "Psalms 9:38",
      "text": "δια να κρινης τον ορφανον και τον τεταπεινωμενον, ωστε ο ανθρωπος ο γηινος να μη καταδυναστευη πλεον.",
      "paragraphStart": false
    }
  ]
}
