{
  "chapter": {
    "id": "lxx-greek:proverbs.11",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 11,
    "referenceLabel": "Proverbs 11",
    "summary": "Source text for Proverbs 11 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.11.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 11:1",
      "text": "Δολια πλαστιγξ βδελυγμα εις τον Κυριον δικαιον δε ζυγιον ευαρεστησις αυτου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.11.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 11:2",
      "text": "Οπου εισελθη υπερηφανια, εισερχεται και καταισχυνη η δε σοφια ειναι μετα των ταπεινων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 11:3",
      "text": "Η ακεραιοτης των ευθεων θελει οδηγει αυτους η δε υπουλοτης των σκολιων θελει απολεσει αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 11:4",
      "text": "Τα πλουτη δεν ωφελουσιν εν ημερα οργης η δε δικαιοσυνη ελευθερονει εκ θανατου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 11:5",
      "text": "Η δικαιοσυνη του ακεραιου θελει ορθοτομησει την οδον αυτου ο δε ασεβης θελει πεσει δια της ασεβειας αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 11:6",
      "text": "Η δικαιοσυνη των ευθεων θελει ελευθερωσει αυτους οι δε παραβαται θελουσι συλληφθη εν τη κακια αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 11:7",
      "text": "Οταν ο ασεβης ανθρωπος αποθνησκη, η ελπις αυτου απολλυται απολλυται και η προσδοκια των ανομων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 11:8",
      "text": "Ο δικαιος ελευθερονεται εκ της θλιψεως, αντ' αυτου δε εισερχεται ο ασεβης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 11:9",
      "text": "Ο υποκριτης δια του στοματος αφανιζει τον πλησιον αυτου αλλ' οι δικαιοι θελουσιν ελευθερωθη δια της γνωσεως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 11:10",
      "text": "Εις την ευοδωσιν των δικαιων η πολις ευφραινεται και εις τον ολεθρον των ασεβων αγαλλεται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 11:11",
      "text": "Δια της ευλογιας των ευθεων υψονεται πολις δια του στοματος δε των ασεβων καταστρεφεται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 11:12",
      "text": "Ο ενδεης φρενων περιφρονει τον πλησιον αυτου ο δε φρονιμος ανθρωπος σιωπα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 11:13",
      "text": "Ο σπερμολογος περιερχεται αποκαλυπτων τα μυστικα ο δε την ψυχην πιστος κρυπτει το πραγμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 11:14",
      "text": "Οπου δεν ειναι κυβερνησις, ο λαος πιπτει εκ του πληθους δε των συμβουλων προερχεται σωτηρια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 11:15",
      "text": "Οστις εγγυαται δι' αλλον, θελει παθει κακον και οστις μισει την εγγυησιν, ειναι ασφαλης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 11:16",
      "text": "Η ευκοσμος γυνη απολαμβανει τιμην οι δε καρτερικοι απολαμβανουσι πλουτη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 11:17",
      "text": "Ο ελεημων ανθρωπος αγαθοποιει την ψυχην αυτου ο δε ανελεημων θλιβει την σαρκα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 11:18",
      "text": "Ο ασεβης εργαζεται εργον ψευδες εις δε τον σπειροντα δικαιοσυνην θελει εισθαι μισθος ασφαλης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 11:19",
      "text": "Καθως η δικαιοσυνη τεινει εις ζωην, ουτως ο κυνηγων το κακον τρεχει εις τον θανατον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 11:20",
      "text": "Οι διεστραμμενοι την καρδιαν ειναι βδελυγμα εις τον Κυριον αλλ' οι αμεμπτοι την οδον ειναι δεκτοι εις αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 11:21",
      "text": "Και χειρ με χειρα εαν συναπτηται, ο ασεβης δεν θελει μενει ατιμωρητος το δε σπερμα των δικαιων θελει ελευθερωθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 11:22",
      "text": "Ως ερρινον χρυσουν εις χοιρου μυτην, ουτω γυνη ωραια χωρις φρονησεως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 11:23",
      "text": "Η επιθυμια των δικαιων ειναι μονον το καλον η προσδοκια δε των ασεβων οργη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 11:24",
      "text": "Οι μεν σκορπιζουσι, και ομως περισσευονται οι δε παρα το δεον φειδονται, και ομως ερχονται εις ενδειαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 11:25",
      "text": "Η αγαθοποιος ψυχη θελει παχυνθη και οστις ποτιζει, θελει ποτισθη και αυτος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 11:26",
      "text": "Οστις κρατει σιτον, θελει εισθαι λαοκαταρατος ευλογια δε θελει εισθαι επι την κεφαλην του πωλουντος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 11:27",
      "text": "Οστις προθυμειται εις το καλον, θελει απολαυσει χαριν αλλ' οστις ζητει το κακον, θελει επελθει επ' αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 11:28",
      "text": "Οστις ελπιζει επι τον πλουτον αυτου, ουτος θελει πεσει οι δε δικαιοι ως βλαστος θελουσιν ανθησει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.29",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 11:29",
      "text": "Οστις ταραττει τον οικον αυτου, θελει κληρονομησει ανεμον και ο αφρων θελει εισθαι δουλος εις τον φρονιμον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.30",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 11:30",
      "text": "Ο καρπος του δικαιου ειναι δενδρον ζωης και οστις κερδιζει ψυχας, ειναι σοφος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.11.31",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 11:31",
      "text": "Αν ο δικαιος παιδευηται επι της γης, πολλω μαλλον ο ασεβης και ο αμαρτωλος.",
      "paragraphStart": false
    }
  ]
}
