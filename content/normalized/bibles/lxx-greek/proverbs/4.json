{
  "chapter": {
    "id": "lxx-greek:proverbs.4",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 4,
    "referenceLabel": "Proverbs 4",
    "summary": "Source text for Proverbs 4 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.4.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 4:1",
      "text": "Ακουσατε, τεκνα, παιδειαν πατρος, και προσεχετε να μαθητε συνεσιν.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.4.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 4:2",
      "text": "Διοτι διδω εις εσας καλην διδασκαλιαν μη εγκαταλιπητε τον νομον μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 4:3",
      "text": "Διοτι και εγω εσταθην υιος του πατρος μου, αγαπητος και μονογενης ενωπιον της μητρος μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 4:4",
      "text": "και με εδιδασκε και μοι ελεγεν, Ας κρατη η καρδια σου τους λογους μου φυλαττε τας εντολας μου και θελεις ζησει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 4:5",
      "text": "Αποκτησον σοφιαν, αποκτησον συνεσιν μη λησμονησης αυτην, μηδε εκκλινης απο των λογων του στοματος μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 4:6",
      "text": "μη εγκαταλιπης αυτην, και θελει σε περιφυλαττει αγαπα αυτην, και θελει σε διατηρει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 4:7",
      "text": "Η σοφια ειναι το πρωτιστον αποκτησον σοφιαν και υπερ πασαν αποκτησιν σου αποκτησον συνεσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 4:8",
      "text": "Αναλαβε αυτην και θελει σε υψωσει θελει σε δοξασει, οταν εναγκαλισθης αυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 4:9",
      "text": "Θελει επιθεσει επι την κεφαλην σου στεφανον χαριτων θελει σοι δωσει διαδημα δοξης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 4:10",
      "text": "Ακουε, υιε μου, και δεχθητι τους λογους μου και θελουσι πληθυνθη τα ετη της ζωης σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 4:11",
      "text": "Σε διδασκω την οδον της σοφιας σε εμβιβαζω εις τριβους ευθειας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 4:12",
      "text": "Οταν περιπατης, τα βηματα σου δεν θελουσιν εισθαι εστενοχωρημενα και οταν τρεχης, δεν θελεις προσκοψει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 4:13",
      "text": "Δραξον την παιδειαν, μη αφησης αυτην φυλαττε αυτην, διοτι ειναι η ζωη σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 4:14",
      "text": "Μη εισελθης εις την τριβον των ασεβων, και μη υπαγης εις την οδον των πονηρων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 4:15",
      "text": "Αποφευγε αυτην, μη περασης δι' αυτης, εκκλινον απ' αυτης και διαβα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 4:16",
      "text": "Διοτι αυτοι δεν κοιμωνται, εαν δεν κακοποιησωσι και ο υπνος αυτων αφαιρειται, εαν δεν υποσκελισωσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 4:17",
      "text": "Επειδη τρωγουσιν αρτον ασεβειας και πινουσιν οινον δυναστειας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 4:18",
      "text": "Η οδος ομως των δικαιων ειναι ως το λαμπρον φως, το φεγγον επι μαλλον και μαλλον, εωσου γεινη τελεια ημερα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 4:19",
      "text": "Η οδος των ασεβων ειναι ως το σκοτος δεν γνωριζουσι που προσκοπτουσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 4:20",
      "text": "Υιε μου, προσεχε εις τας ρησεις μου κλινον το ωτιον σου εις τα λογια μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 4:21",
      "text": "Ας μη απομακρυνθωσιν απο των οφθαλμων σου φυλαττε αυτα εν τη καρδια σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 4:22",
      "text": "διοτι ειναι ζωη εις τους ευρισκοντας αυτα και ιασις εις πασαν αυτων την σαρκα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 4:23",
      "text": "Μετα πασης φυλαξεως φυλαττε την καρδιαν σου διοτι εκ ταυτης προερχονται αι εκβασεις της ζωης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 4:24",
      "text": "Αποβαλε απο σου σκολιοτητα στοματος, και διαστροφην χειλεων απομακρυνον απο σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 4:25",
      "text": "Οι οφθαλμοι σου ας βλεπωσιν ορθα, και τα βλεφαρα σου ας κατευθυνωνται εμπροσθεν σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 4:26",
      "text": "Σταθμιζε το βαδισμα των ποδων σου, και πασαι αι οδοι σου θελουσι κατευθυνθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.4.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 4:27",
      "text": "Μη εκκλινης δεξια η αριστερα αποστρεψον τον ποδα σου απο κακου.",
      "paragraphStart": false
    }
  ]
}
