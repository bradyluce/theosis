{
  "chapter": {
    "id": "lxx-greek:proverbs.7",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 7,
    "referenceLabel": "Proverbs 7",
    "summary": "Source text for Proverbs 7 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.7.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 7:1",
      "text": "Υιε μου, φυλαττε τους λογους μου και ταμιευσον τας εντολας μου παρα σεαυτω.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.7.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 7:2",
      "text": "Φυλαττε τας εντολας μου, και θελεις ζησει και τον νομον μου, ως την κορην των οφθαλμων σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 7:3",
      "text": "Δεσον αυτα επι τους δακτυλους σου, εγχαραξον αυτα επι την πλακα της καρδιας σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 7:4",
      "text": "Ειπε προς την σοφιαν; συ εισαι αδελφη μου και καλεσον την φρονησιν συγγενη σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 7:5",
      "text": "δια να σε φυλαττωσιν απο ξενης γυναικος, απο αλλοτριας κολακευουσης δια των λογων αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 7:6",
      "text": "Επειδη απο του παραθυρου της οικιας μου εκυψα δια του δικτυωτου μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 7:7",
      "text": "και ειδον μεταξυ των αφρονων, παρετηρησα μεταξυ των νεανισκων, νεον ενδεη φρενων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 7:8",
      "text": "οστις διεβαινε δια της πλατειας, πλησιον της γωνιας αυτης, και διηρχετο την οδον προς την οικιαν αυτης,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 7:9",
      "text": "εν τω εσπερινω σκοτει της ημερας, εν τω σκοτασμω της νυκτος και τω γνοφω",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 7:10",
      "text": "και ιδου, συναπαντα αυτον γυνη εχουσα σχημα πορνικον, και καρδιαν δολιοφρονα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 7:11",
      "text": "φλυαρος και αναιδης οι ποδες αυτης δεν μενουσιν εν τω οικω αυτης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 7:12",
      "text": "τωρα ειναι εξω, τωρα εν ταις πλατειαις, και ενεδρευει πλησιον πασης γωνιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 7:13",
      "text": "Και πιανει αυτον και φιλει αυτον και με αναιδες προσωπον λεγει προς αυτον,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 7:14",
      "text": "Εχω θυσιας ειρηνικας σημερον απεδωκα τας ευχας μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 7:15",
      "text": "δια τουτο εξηλθον εις απαντησιν σου, ποθουσα το προσωπον σου, και σε ευρηκα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 7:16",
      "text": "εστρωσα την κλινην μου με πεπλους, με ταπητας πεποικιλμενους, με νηματα της Αιγυπτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 7:17",
      "text": "εθυμιασα την κλινην μου με σμυρναν, αλοην και κιναμωμον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 7:18",
      "text": "ελθε, ας μεθυσθωμεν απο ερωτος μεχρι της αυγης ας εντρυφησωμεν εις ερωτας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 7:19",
      "text": "διοτι δεν ειναι ο ανηρ εν τη οικια αυτου, υπηγεν εις οδον μακραν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 7:20",
      "text": "ελαβε βαλαντιον αργυριου εν τη χειρι αυτου εν ωρισμενω καιρω θελει επανελθει εις την οικιαν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 7:21",
      "text": "Δια της πολλης αυτης τεχνης απεπλανησεν αυτον δια της κολακειας των χειλεων αυτης ειλκυσεν αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 7:22",
      "text": "Ευθυς ακολουθει αυτην κατοπιν, καθως ο βους υπαγει εις την σφαγην, η καθως η ελαφος πηδα εις τον βροχον,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 7:23",
      "text": "εωσου βελος διαπεραση το ηπαρ αυτης καθως το πτηνον σπευδει εις την παγιδα και δεν εξευρει οτι ειναι εναντιον της ζωης αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 7:24",
      "text": "Τωρα λοιπον ακουσατε μου, τεκνα, και προσεχετε εις τους λογους του στοματος μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 7:25",
      "text": "Ας μη εκκλινη εις τας οδους αυτης η καρδια σου, μη παρεκτραπης εις τας τριβους αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 7:26",
      "text": "Διοτι πολλους εκαμε να πεσωσι πεπληγωμενοι, και δυνατοι ειναι οι φονευθεντες υπ' αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.7.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 7:27",
      "text": "Οδοι αδου ειναι ο οικος αυτης, καταβαινουσαι εις τα ταμεια του θανατου.",
      "paragraphStart": false
    }
  ]
}
