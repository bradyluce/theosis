{
  "chapter": {
    "id": "lxx-greek:proverbs.16",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 16,
    "referenceLabel": "Proverbs 16",
    "summary": "Source text for Proverbs 16 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.16.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 16:1",
      "text": "Του ανθρωπου ειναι αι προπαρασκευαι της καρδιας παρα δε του Κυριου η αποκρισις της γλωσσης.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.16.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 16:2",
      "text": "Πασαι αι οδοι του ανθρωπου φαινονται ορθαι εις τους οφθαλμους αυτου πλην ο Κυριος σταθμιζει τα πνευματα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 16:3",
      "text": "Αφιερονε τα εργα σου εις τον Κυριον, και αι βουλαι σου θελουσι στερεωθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 16:4",
      "text": "Ο Κυριος εκαμε τα παντα δι' εαυτον, ετι και τον ασεβη δια την ημεραν την κακην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 16:5",
      "text": "Βδελυγμα εις τον Κυριον ειναι πας υψηλοκαρδιος και χειρ με χειρα αν συναπτηται, δεν θελει μενει ατιμωρητος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 16:6",
      "text": "Δια χαριτος και αληθειας καθαριζεται η ανομια και δια του φοβου του Κυριου εκκλινουσιν οι ανθρωποι απο του κακου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 16:7",
      "text": "Οταν ο Κυριος αρεσκηται εις τας οδους του ανθρωπου, και τους εχθρους αυτου ειρηνευει μετ' αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 16:8",
      "text": "Καλητερον ολιγον μετα δικαιοσυνης, παρα εισοδηματα μεγαλα μετα αδικιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 16:9",
      "text": "Η καρδια του ανθρωπου βουλευεται την οδον αυτου αλλ' ο Κυριος διευθυνει τα βηματα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 16:10",
      "text": "Χρησμος ειναι εις τα χειλη του βασιλεως το στομα αυτου δεν σφαλλει εν τη κρισει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 16:11",
      "text": "Δικαια σταθμη και πλαστιγξ ειναι του Κυριου παντα τα ζυγια του σακκιου ειναι εργου αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 16:12",
      "text": "Βδελυγμα ειναι εις τους βασιλεις να πραττωσιν ανομιαν διοτι ο θρονος στερεονεται μετα της δικαιοσυνης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 16:13",
      "text": "Τα δικαια χειλη ειναι ευπροσδεκτα εις τους βασιλεις, και αγαπωσι τον λαλουντα ορθα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 16:14",
      "text": "Θυμος βασιλεως ειναι αγγελος θανατου αλλ' ο σοφος ανθρωπος καταπραυνει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 16:15",
      "text": "Εις το φως του προσωπου του βασιλεως ειναι ζωη και η ευνοια αυτου ειναι ως νεφος οψιμου βροχης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 16:16",
      "text": "Ποσον καλητερα ειναι η αποκτησις της σοφιας παρα το χρυσιον και προκριτωτερα η αποκτησις της συνεσεως παρα το αργυριον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 16:17",
      "text": "Η οδος των ευθεων ειναι να εκκλινωσιν απο του κακου οστις φυλαττει την οδον αυτου, διατηρει την ψυχην αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 16:18",
      "text": "Η υπερηφανια προηγειται του ολεθρου, και υψηλοφροσυνη του πνευματος προηγειται της πτωσεως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 16:19",
      "text": "Καλητερον να ηναι τις ταπεινοφρων μετα των ταπεινων, παρα να μοιραζη λαφυρα μετα των υπερηφανων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 16:20",
      "text": "Ο συνετος εις τα πραγματα θελει ευρει καλον και ο ελπιζων επι τον Κυριον ειναι μακαριος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 16:21",
      "text": "Ο σοφος την καρδιαν θελει ονομαζεσθαι φρονιμος και η γλυκυτης των χειλεων προσθετει μαθησιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 16:22",
      "text": "Η συνεσις ειναι πηγη ζωης εις τον εχοντα αυτην η δε παιδεια των αφρονων μωρια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 16:23",
      "text": "Η καρδια του σοφου συνετιζει το στομα αυτου, και εις τα χειλη αυτου προσθετει μαθησιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 16:24",
      "text": "Κηρηθρα μελιτος οι ευαρεστοι λογοι γλυκυτης εις την ψυχην και ιασις εις τα οστα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 16:25",
      "text": "Υπαρχει οδος ητις φαινεται ορθη εις τον ανθρωπον, αλλα τα τελη αυτης ειναι οδοι θανατου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 16:26",
      "text": "Ο εργαζομενος εργαζεται δι' εαυτον διοτι το στομα αυτου αναγκαζει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 16:27",
      "text": "Ο αχρειος ανθρωπος σκαπτει κακον και εις τα χειλη αυτου ειναι ως πυρ καιον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 16:28",
      "text": "Ο διεστραμμενος ανθρωπος διασπειρει εριδας και ο ψιθυριστης διαχωριζει τους στενωτερους φιλους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.29",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 16:29",
      "text": "Ο βιαιος ανθρωπος αποπλανα τον πλησιον αυτου και φερει αυτον εις οδον ουχι καλην",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.30",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 16:30",
      "text": "Κλειων τους οφθαλμους αυτου μηχαναται διεστραμμενα δαγκανων τα χειλη αυτου εκτελει το κακον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.31",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 16:31",
      "text": "Η πολια ειναι στεφανος δοξης, ευρισκομενη εν τη οδω της δικαιοσυνης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.32",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 16:32",
      "text": "Καλητερος ο μακροθυμος παρα τον δυνατον και ο εξουσιαζων το πνευμα αυτου παρα τον εκπορθουντα πολιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.16.33",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 16:33",
      "text": "Ο κληρος ριπτεται εις την καλπην ολη ομως η κρισις αυτου ειναι παρα Κυριου.",
      "paragraphStart": false
    }
  ]
}
