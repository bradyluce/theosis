{
  "chapter": {
    "id": "lxx-greek:proverbs.24",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 24,
    "referenceLabel": "Proverbs 24",
    "summary": "Source text for Proverbs 24 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.24.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 24:1",
      "text": "Μη ζηλευε τους κακους ανθρωπους, μηδε επιθυμει να ησαι μετ' αυτων",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.24.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 24:2",
      "text": "διοτι η καρδια αυτων μελετα καταδυναστευσιν, και τα χειλη αυτων λαλουσι κακουργιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 24:3",
      "text": "Δια της σοφιας οικοδομειται οικος και δια της συνεσεως στερεονεται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 24:4",
      "text": "Και δια της γνωσεως τα ταμεια θελουσι γεμισθη απο παντος πολυτιμου και ευφροσυνου πλουτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 24:5",
      "text": "Ο σοφος ανθρωπος ισχυει, και ο ανθρωπος ο φρονιμος αυξανει δυναμιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 24:6",
      "text": "Διοτι δια σοφων βουλων θελεις καμει τον πολεμον σου εκ του πληθους δε των συμβουλων προερχεται σωτηρια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 24:7",
      "text": "Η σοφια ειναι παραπολυ υψηλη δια τον αφρονα δεν θελει ανοιξει το στομα αυτου εν τη πυλη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 24:8",
      "text": "Οστις μελετα να πραξη κακον, θελει ονομασθη ανηρ κακεντρεχης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 24:9",
      "text": "Η μελετη της αφροσυνης ειναι αμαρτια και ο χλευαστης βδελυγμα εις τους ανθρωπους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 24:10",
      "text": "Εαν μικροψυχησης εν τη ημερα της συμφορας, μικρα ειναι η δυναμις σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 24:11",
      "text": "Ελευθερονε τους συρομενους εις θανατον, και μη αποσυρου απο των οντων εις ακμην σφαγης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 24:12",
      "text": "Εαν ειπης, Ιδου, ημεις δεν εξευρομεν τουτο δεν γνωριζει ο σταθμιζων τας καρδιας; και ο φυλαττων την ψυχην σου και αποδιδων εις εκαστον κατα τα εργα αυτου, δεν εξευρει;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 24:13",
      "text": "Υιε μου, φαγε μελι, διοτι ειναι καλον και κηρηθραν, διοτι ειναι γλυκεια επι του ουρανισκον σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 24:14",
      "text": "Τοιαυτη θελει εισθαι εις την ψυχην σου η γνωσις της σοφιας οταν ευρης αυτην, τοτε θελεις λαβει αμοιβην, και η ελπις σου δεν θελει εκκοπη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 24:15",
      "text": "Μη στηνε παγιδα, ω ανομε, κατα της κατοικιας του δικαιου μη ταραξης τον τοπον της αναπαυσεως αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 24:16",
      "text": "διοτι ο δικαιος πιπτει επτακις και σηκονεται αλλ' οι ασεβεις θελουσι πεσει εις ολεθρον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 24:17",
      "text": "Εις την πτωσιν του εχθρου σου μη χαρης και εις το ολισθημα αυτου ας μη ευφραινεται η καρδια σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 24:18",
      "text": "Μηποτε ο Κυριος ιδη και φανη τουτο κακον εις τους οφθαλμους αυτου και μεταστρεψη τον θυμον αυτου απ' αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 24:19",
      "text": "Μη αγανακτει περι των πονηρευομενων μη ζηλευε τους ασεβεις",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 24:20",
      "text": "διοτι δεν θελει εχει τελος αγαθον ο κακος ο λυχνος των ασεβων θελει σβεσθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 24:21",
      "text": "Υιε μου, φοβου τον Κυριον και τον βασιλεα και μη εχε συγκοινωνιαν μετα στασιαστων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 24:22",
      "text": "διοτι η συμφορα αυτων θελει επελθει εξαιφνης και τις γνωριζει αμφοτερων τας τιμωριας;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 24:23",
      "text": "Ταυτα προσετι ειναι δια τους σοφους. Η προσωποληψια εν τη κρισει δεν ειναι καλον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 24:24",
      "text": "Τον λεγοντα προς τον ασεβη, Εισαι δικαιος, τουτον οι λαοι θελουσι καταρασθη και τα εθνη θελουσι βδελυττεσθαι",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 24:25",
      "text": "αλλ' εις τους ελεγχοντας αυτον θελει εισθαι χαρις, και ευλογια αγαθων θελει ελθει επ' αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 24:26",
      "text": "Οστις αποκρινεται λογους ορθους, ειναι ως ο φιλων τα χειλη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 24:27",
      "text": "Διαταττε το εργον σου εξω και προετοιμαζε αυτο εις σεαυτον εν τω αγρω και επειτα οικοδομησον τον οικον σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 24:28",
      "text": "Μη ησο μαρτυς αδικος κατα του πλησιον σου, μηδε απατα δια των χειλεων σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.29",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 24:29",
      "text": "Μη ειπης, Καθως εκαμεν εις εμε, ουτω θελω καμει εις αυτον θελω αποδωσει εις τον ανθρωπον κατα το εργον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.30",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 24:30",
      "text": "Διεβαινον δια του αγρου του οκνηρου και δια του αμπελωνος του ανθρωπου του ενδεους φρενων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.31",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 24:31",
      "text": "και ιδου, πανταχου ειχον βλαστησει ακανθαι κνιδαι ειχον σκεπασει το προσωπον αυτου, και το λιθοφραγμα αυτου ητο κατακεκρημνισμενον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.32",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 24:32",
      "text": "Τοτε εγω θεωρησας εσυλλογισθην εν τη καρδια μου ειδον, και ελαβον διδασκαλιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.33",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 24:33",
      "text": "Ολιγος υπνος, ολιγος νυσταγμος, ολιγη συμπλοκη των χειρων εις τον υπνον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.24.34",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 24:34",
      "text": "επειτα η πτωχεια σου ερχεται ως ταχυδρομος, και η ενδεια σου ως ανηρ ενοπλος.",
      "paragraphStart": false
    }
  ]
}
