{
  "chapter": {
    "id": "lxx-greek:proverbs.22",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 22,
    "referenceLabel": "Proverbs 22",
    "summary": "Source text for Proverbs 22 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.22.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 22:1",
      "text": "Προτιμοτερον ονομα καλον παρα πλουτη μεγαλα, χαρις αγαθη παρα αργυριον και χρυσιον.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.22.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 22:2",
      "text": "Πλουσιος και πτωχος συναπαντωνται ο Κυριος ειναι ο Ποιητης αμφοτερων τουτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 22:3",
      "text": "Ο φρονιμος προβλεπει το κακον και κρυπτεται οι αφρονες ομως προχωρουσι και τιμωρουνται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 22:4",
      "text": "Η αμοιβη της ταπεινωσεως και του φοβου του Κυριου ειναι πλουτος και δοξα και ζωη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 22:5",
      "text": "Τριβολοι και παγιδες ειναι εν τη οδω του σκολιου οστις φυλαττει την ψυχην αυτου, θελει εισθαι μακραν απ' αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 22:6",
      "text": "Διδαξον το παιδιον εν αρχη της οδου αυτου και δεν θελει απομακρυνθη απ' αυτης ουδε οταν γηραση.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 22:7",
      "text": "Ο πλουσιος εξουσιαζει τους πτωχους και ο δανειζομενος ειναι δουλος του δανειζοντος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 22:8",
      "text": "Ο σπειρων ανομιαν θελει θερισει συμφορας και η ραβδος της υβρεως αυτου θελει εκλειψει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 22:9",
      "text": "Ο εχων ομμα αγαθον θελει ευλογηθη διοτι διδει εκ του αρτου αυτου εις τον πτωχον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 22:10",
      "text": "Εκδιωξον τον χλευαστην και θελει συνεξελθει η φιλονεικια, και η ερις και η υβρις θελουσι παυσει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 22:11",
      "text": "Οστις αγαπα την καθαροτητα της καρδιας, δια την χαριν των χειλεων αυτου ο βασιλευς θελει εισθαι φιλος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 22:12",
      "text": "Οι οφθαλμοι του Κυριου περιφρουρουσι την γνωσιν ανατρεπει δε τας υποθεσεις του παρανομου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 22:13",
      "text": "Ο οκνηρος λεγει, Λεων ειναι εξω εν τω μεσω των πλατειων θελω φονευθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 22:14",
      "text": "Στομα γυναικος αλλοτριας ειναι λακκος βαθυς ο μισουμενος υπο Κυριου θελει εμπεσει εις αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 22:15",
      "text": "Η ανοησια ειναι συνδεδεμενη μετα της καρδιας του παιδιου η ραβδος της παιδειας θελει αποχωρισει αυτην απ' αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 22:16",
      "text": "Οστις καταθλιβει τον πτωχον δια να αυξηση τα πλουτη αυτου, και οστις διδει εις τον πλουσιον, θελει ελθει βεβαιως εις ενδειαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 22:17",
      "text": "Κλινον το ωτιον σου και ακουε τους λογους των σοφων, και προσκολλησον την καρδιαν σου εις την γνωσιν μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 22:18",
      "text": "διοτι ειναι τερπνοι, εαν φυλαττη αυτους εν τη καρδια σου και θελουσι συναρμοζεσθαι ομου επι των χειλεων σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 22:19",
      "text": "Δια να ηναι το θαρρος σου επι τον Κυριον, εδιδαξα ταυτα εις σε την ημεραν ταυτην, μαλιστα εις σε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 22:20",
      "text": "Δεν εγραψα εις σε πολλακις δια συμβουλων και γνωσεων,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 22:21",
      "text": "δια να σε καμω να γνωρισης την βεβαιοτητα των λογων της αληθειας, ωστε να αποκρινησαι λογους αληθειας προς τους εξαποστελλοντας σε;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 22:22",
      "text": "Μη γυμνονης τον πτωχον, διοτι ειναι πτωχος μηδε καταθλιβε εις την πυλην τον δυστυχουντα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 22:23",
      "text": "διοτι ο Κυριος θελει εκδικασει την δικην αυτων και θελει γυμνωσει την ψυχην των γυμνωσαντων αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 22:24",
      "text": "Μη καμνε φιλιαν μετα ανθρωπου θυμωδους και μετα ανθρωπου οργιλου μη συμπεριπατει",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 22:25",
      "text": "μηποτε μαθης τας οδους αυτου, και λαβης παγιδα εις την ψυχην σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 22:26",
      "text": "Μη εσο εκ των διδοντων χειρα, εκ των εγγυωμενων δια χρεη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 22:27",
      "text": "Εαν δεν εχης ποθεν να πληρωσης, δια τι να παρωσι την κλινην σου υποκατωθεν σου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 22:28",
      "text": "Μη μετακινει ορια αρχαια, τα οποια εθεσαν οι πατερες σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.22.29",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 22:29",
      "text": "Ειδες ανθρωπον επιτηδειον εις τα εργα αυτου; αυτος θελει παρασταθη ενωπιον βασιλεων δεν θελει παρασταθη ενωπιον ουτιδανων.",
      "paragraphStart": false
    }
  ]
}
