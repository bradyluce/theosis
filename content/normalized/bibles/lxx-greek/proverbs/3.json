{
  "chapter": {
    "id": "lxx-greek:proverbs.3",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 3,
    "referenceLabel": "Proverbs 3",
    "summary": "Source text for Proverbs 3 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.3.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 3:1",
      "text": "Υιε μου, μη λησμονης τους νομους μου, και η καρδια σου ας φυλαττη τας εντολας μου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.3.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 3:2",
      "text": "Διοτι μακροτητα ημερων και ετη ζωης και ειρηνην θελουσι προσθεσει εις σε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 3:3",
      "text": "Ελεος και αληθεια ας μη σε εγκαταλιπωσι δεσον αυτας περι τον τραχηλον σου εγχαραξον αυτας επι την πλακα της καρδιας σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 3:4",
      "text": "ουτω θελεις ευρει χαριν και ευνοιαν ενωπιον Θεου και ανθρωπων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 3:5",
      "text": "Ελπιζε επι Κυριον εξ ολης σου της καρδιας, και μη επιστηριζεσαι εις την συνεσιν σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 3:6",
      "text": "εν πασαις ταις οδοις σου αυτον γνωριζε, και αυτος θελει διευθυνει τα διαβηματα σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 3:7",
      "text": "Μη φανταζεσαι σεαυτον σοφον φοβου τον Κυριον και εκκλινον απο κακου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 3:8",
      "text": "Τουτο θελει εισθαι ιασις εις τα νευρα σου και μυελωσις εις τα οστα σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 3:9",
      "text": "Τιμα τον Κυριον απο των υπαρχοντων σου και απο των απαρχων παντων των γεννηματων σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 3:10",
      "text": "και θελουσιν εμπλησθη αι σιτοθηκαι σου απο αφθονιας και οι ληνοι σου θελουσιν εκχειλιζει απο νεου οινου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 3:11",
      "text": "Υιε μου, μη καταφρονει την παιδειαν του Κυριου και μη αθυμει ελεγχομενος υπ' αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 3:12",
      "text": "Διοτι ο Κυριος ελεγχει οντινα αγαπα, καθως και ο πατηρ τον υιον, εις τον οποιον ευαρεστειται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 3:13",
      "text": "Μακαριος ο ανθρωπος, οστις ευρηκε σοφιαν, και ο ανθρωπος, οστις απεκτησε συνεσιν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 3:14",
      "text": "Διοτι το εμποριον αυτης ειναι καλητερον παρα το εμποριον του αργυριου και το κερδος αυτης παρα χρυσιον καθαρον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 3:15",
      "text": "Ειναι τιμιωτερα πολυτιμων λιθων και παντα οσα επιθυμησης δεν ειναι ανταξια αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 3:16",
      "text": "Μακροτης ημερων ειναι εν τη δεξια αυτης εν τη αριστερα αυτης, πλουτος και δοξα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 3:17",
      "text": "Αι οδοι αυτης ειναι οδοι τερπναι και πασαι αι τριβοι αυτης ειρηνη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 3:18",
      "text": "Ειναι δενδρον ζωης εις τους εναγκαλιζομενους αυτην και μακαριοι οι κρατουντες αυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 3:19",
      "text": "Δια της σοφιας εθεμελιωσεν ο Κυριος, εστερεωσε τους ουρανους εν συνεσει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 3:20",
      "text": "Δια της γνωσεως αυτου αι αβυσσοι ηνοιχθησαν και τα νεφη σταλαζουσι δροσον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 3:21",
      "text": "Υιε μου, ας μη απομακρυνθωσι ταυτα απο των οφθαλμων σου φυλαττε ορθην βουλην και φρονησιν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 3:22",
      "text": "και θελει εισθαι ζωη εις την ψυχην σου και χαρις εις τον τραχηλον σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 3:23",
      "text": "Τοτε θελεις περιπατει ασφαλως την οδον σου, και ο πους σου δεν θελει προσκοψει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 3:24",
      "text": "Οταν πλαγιαζης, δεν θελεις τρομαζει μαλιστα θελεις πλαγιαζει, και ο υπνος σου θελει εισθαι γλυκυς.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 3:25",
      "text": "Δεν θελεις τρομαξει απο αιφνιδιου φοβου ουδε απο του ολεθρου των ασεβων, οταν επελθη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 3:26",
      "text": "Διοτι ο Κυριος θελει εισθαι η ελπις σου, και θελει φυλαξει τον ποδα σου απο του να πιασθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 3:27",
      "text": "Μη αρνηθης το καλον προς εκεινους, εις τους οποιους πρεπει, οταν ηναι εν τη χειρι σου να καμνης αυτο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 3:28",
      "text": "Μη ειπης προς τον πλησιον σου, Υπαγε και επαναστρεψον και αυριον θελω σοι δωσει ενω εχεις τουτο παρα σεαυτω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.29",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 3:29",
      "text": "Μη μηχανευου κακον κατα του πλησιον σου, ενω πεποιθως κατοικει μετα σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.30",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 3:30",
      "text": "Μη μαχου τινα αναιτιως, εαν δεν εκαμε κακον εις σε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.31",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 3:31",
      "text": "Μη ζηλευε τον βιαιον ανθρωπον και μη εκλεξης μηδεμιαν εκ των οδων αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.32",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 3:32",
      "text": "διοτι ο Κυριος βδελυττεται τον σκολιον το δε απορρητον αυτου φανερονεται εις τους δικαιους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.33",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 3:33",
      "text": "Καταρα Κυριου εν τω οικω του ασεβους ευλογει δε την κατοικιαν των δικαιων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.34",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 3:34",
      "text": "Βεβαιως αυτος αντιταττεται εις τους υπερηφανους εις δε τους ταπεινους διδει χαριν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.3.35",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 3:35",
      "text": "Οι σοφοι θελουσι κληρονομησει δοξαν το δε υψος των αφρονων θελει εισθαι η ατιμια.",
      "paragraphStart": false
    }
  ]
}
