{
  "chapter": {
    "id": "lxx-greek:proverbs.9",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 9,
    "referenceLabel": "Proverbs 9",
    "summary": "Source text for Proverbs 9 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.9.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 9:1",
      "text": "Η σοφια ωκοδομησε τον οικον αυτης, ελατομησε τους στυλους αυτης επτα",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.9.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 9:2",
      "text": "εσφαξε τη σφαγια αυτης, εκερασε τον οινον αυτης, και ητοιμασε την τραπεζαν αυτης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.9.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 9:3",
      "text": "απεστειλε τας θεραπαινας αυτης, κηρυττει επι των υψηλων τοπων της πολεως,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.9.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 9:4",
      "text": "Οστις ειναι αφρων, ας στραφη εδω και, προς τους ενδεεις φρενων, λεγει προς αυτους,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.9.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 9:5",
      "text": "Ελθετε, φαγετε απο του αρτου μου, και πιετε απο του οινου τον οποιον εκερασα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.9.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 9:6",
      "text": "αφησατε την αφροσυνην και ζησατε και κατευθυνθητε εν τη οδω της συνεσεως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.9.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 9:7",
      "text": "Ο νουθετων χλευαστην λαμβανει εις εαυτον ατιμιαν και ο ελεγχων τον ασεβη λαμβανει εις εαυτον μωμον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.9.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 9:8",
      "text": "Μη ελεγχε χλευαστην, δια να μη σε μισηση ελεγχε σοφον, και θελει σε αγαπησει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.9.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 9:9",
      "text": "Διδε αφορμην εις τον σοφον και θελει γεινει σοφωτερος διδασκε τον δικαιον και θελει αυξηθη εις μαθησιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.9.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 9:10",
      "text": "Αρχη σοφιας φοβος Κυριου και επιγνωσις αγιων φρονησις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.9.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 9:11",
      "text": "Διοτι δι' εμου αι ημεραι σου θελουσι πολλαπλασιασθη, και ετη ζωης θελουσι προστεθη εις σε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.9.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 9:12",
      "text": "Εαν γεινης σοφος, θελεις εισθαι σοφος δια σεαυτον και εαν γεινης χλευαστης, συ μονος θελεις πασχει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.9.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 9:13",
      "text": "Γυνη αφρων, θρασεια, ανοητος και μη γνωριζουσα μηδεν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.9.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 9:14",
      "text": "καθηται εν τη θυρα της οικιας αυτης επι θρονου, εν τοις υψηλοις τοποις της πολεως,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.9.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 9:15",
      "text": "προσκαλουσα τους διαβατας τους κατευθυνομενους εις την οδον αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.9.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 9:16",
      "text": "οστις ειναι αφρων, ας στραφη εδω και προς τον ενδεη φρενων, λεγει προς αυτον,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.9.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 9:17",
      "text": "Τα κλοπιμαια υδατα ειναι γλυκεα, και ο κρυφιος αρτος ειναι ηδυς.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.9.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 9:18",
      "text": "Αλλ' αυτος αγνοει οτι εκει ειναι οι νεκροι, και εις τα βαθη του αδου οι κεκλημενοι αυτης.",
      "paragraphStart": false
    }
  ]
}
