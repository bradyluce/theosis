{
  "chapter": {
    "id": "lxx-greek:proverbs.8",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 8,
    "referenceLabel": "Proverbs 8",
    "summary": "Source text for Proverbs 8 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.8.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 8:1",
      "text": "Δεν κραζει η σοφια; και δεν εκπεμπει την φωνην αυτης η συνεσις;",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.8.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 8:2",
      "text": "Ισταται επι της κορυφης των υψηλων τοπων, υπερ την οδον, εν τω μεσω των τριοδων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 8:3",
      "text": "Κραζει πλησιον των πυλων, εν τη εισοδω της πολεως, εν τη εισοδω των θυρων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 8:4",
      "text": "προς εσας, ανθρωποι, κραζω και η φωνη μου εκπεμπεται προς τους υιους των ανθρωπων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 8:5",
      "text": "Απλοι, νοησατε φρονησιν και αφρονες, αποκτησατε νοημονα καρδιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 8:6",
      "text": "Ακουσατε διοτι θελω λαλησει πραγματα εξοχα, και τα χειλη μου θελουσι προφερει ορθα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 8:7",
      "text": "Διοτι αληθειαν θελει λαλησει ο λαρυγξ μου τα δε χειλη μου βδελυττονται την ασεβειαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 8:8",
      "text": "Παντες οι λογοι του στοματος μου ειναι μετα δικαιοσυνης δεν υπαρχει εν αυτοις δολιον διεστραμμενον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 8:9",
      "text": "Παντες ειναι σαφεις εις τον νοουντα και ορθοι εις τους ευρισκοντας γνωσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 8:10",
      "text": "Λαβετε την παιδειαν μου, και μη αργυριον και γνωσιν, μαλλον παρα χρυσιον εκλεκτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 8:11",
      "text": "Διοτι η σοφια ειναι καλητερα λιθων πολυτιμων και παντα τα επιθυμητα πραγματα δεν ειναι ανταξια αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 8:12",
      "text": "Εγω η σοφια κατοικω μετα της φρονησεως, και εφευρισκω γνωσιν συνετων βουλευματων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 8:13",
      "text": "Ο φοβος του Κυριου ειναι να μιση τις το κακον αλαζονειαν και αυθαδειαν και πονηραν οδον και διεστραμμενον στομα εγω μισω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 8:14",
      "text": "Εμου ειναι η βουλη και η ασφαλεια εγω ειμαι η συνεσις εμου η δυναμις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 8:15",
      "text": "Δι' εμου οι βασιλεις βασιλευουσι, και οι αρχοντες θεσπιζουσι δικαιοσυνην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 8:16",
      "text": "Δι' εμου οι ηγεμονες ηγεμονευουσι, και οι μεγιστανες, παντες οι κριται της γης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 8:17",
      "text": "Εγω τους εμε αγαπωντας αγαπω και οι ζητουντες με θελουσι με ευρει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 8:18",
      "text": "Πλουτος και δοξα ειναι μετ' εμου, αγαθα διαμενοντα και δικαιοσυνη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 8:19",
      "text": "Οι καρποι μου ειναι καλητεροι χρυσιου και χρυσιου καθαρου και τα γεννηματα μου, εκλεκτου αργυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 8:20",
      "text": "Περιπατω εν οδω δικαιοσυνης, αναμεσον των τριβων της κρισεως,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 8:21",
      "text": "δια να καμω τους αγαπωντας με να κληρονομησωσιν αγαθα, και να γεμισω τους θησαυρους αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 8:22",
      "text": "Ο Κυριος με ειχεν εν τη αρχη των οδων αυτου, προ των εργων αυτου, απ' αιωνος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 8:23",
      "text": "Προ του αιωνος με εχρισεν, απ' αρχης, πριν υπαρξη η γη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 8:24",
      "text": "Εγεννηθην οτε δεν ησαν αι αβυσσοι, οτε δεν υπηρχον αι πηγαι αι αναβρυουσαι υδατα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 8:25",
      "text": "Πριν τα ορη θεμελιωθωσι, προ των λοφων, εγω εγεννηθην",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 8:26",
      "text": "ενω δεν ειχεν ετι καμει την γην ουτε πεδιαδας, ουτε κορυφας χωματων της οικουμενης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 8:27",
      "text": "Οτε ητοιμαζε τους ουρανους, εγω ημην εκει οτε περιεγραφε καμαραν υπερανω του προσωπου της αβυσσου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 8:28",
      "text": "οτε εστερεονε τον αιθερα επανω οτε ωχυρονε τας πηγας της αβυσσου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.29",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 8:29",
      "text": "οτε επεβαλλε τον νομον αυτου εις την θαλασσαν, να μη παραβωσι τα υδατα το προσταγμα αυτου οτε διεταττε τα θεμελια της γης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.30",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 8:30",
      "text": "τοτε ημην πλησιον αυτου δημιουργουσα και εγω ημην καθ' ημεραν η τρυφη αυτου, ευφραινομενη παντοτε ενωπιον αυτου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.31",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 8:31",
      "text": "ευφραινομενη εν τη οικουμενη της γης αυτου και η τρυφη μου ητο μετα των υιων των ανθρωπων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.32",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 8:32",
      "text": "Τωρα λοιπον ακουσατε μου, ω τεκνα διοτι μακαριοι οι φυλαττοντες τας οδους μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.33",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 8:33",
      "text": "Ακουσατε παιδειαν και γενεσθε σοφοι, και μη αποδοκιμαζετε αυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.34",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 8:34",
      "text": "Μακαριος ο ανθρωπος, οστις μου ακουση, αγρυπνων καθ' ημεραν εν ταις πυλαις μου, περιμενων εις τους παραστατας των θυρων μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.35",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 8:35",
      "text": "διοτι οστις ευρη εμε, θελει ευρει ζωην, και θελει λαβει χαριν παρα Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.8.36",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 36,
      "referenceLabel": "Proverbs 8:36",
      "text": "Οστις ομως αμαρτηση εις εμε, την εαυτου ψυχην αδικει παντες οι μισουντες με αγαπωσι θανατον.",
      "paragraphStart": false
    }
  ]
}
