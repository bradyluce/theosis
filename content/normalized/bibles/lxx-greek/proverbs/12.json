{
  "chapter": {
    "id": "lxx-greek:proverbs.12",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 12,
    "referenceLabel": "Proverbs 12",
    "summary": "Source text for Proverbs 12 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.12.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 12:1",
      "text": "Οστις αγαπα παιδειαν, αγαπα γνωσιν αλλ' οστις μισει ελεγχον, ειναι αφρων.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.12.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 12:2",
      "text": "Ο καλος ευρισκει χαριν παρα Κυριου τον δε μηχανευομενον κακα θελει καταδικασει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 12:3",
      "text": "Δεν θελει στερεωθη ανθρωπος δια της ανομιας η ριζα δε των δικαιων θελει μενει ασαλευτος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 12:4",
      "text": "Η εναρετος γυνη ειναι στεφανος εις τον ανδρα αυτης η δε προξενουσα αισχυνην ειναι ως σαπρια εις τα οστα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 12:5",
      "text": "Οι λογισμοι των δικαιων ειναι ευθυτης αι δε βουλαι των ασεβων δολος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 12:6",
      "text": "Οι λογοι των ασεβων ενεδρευουσιν αιμα το δε στομα των ευθεων θελει ελευθερωσει αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 12:7",
      "text": "Οι ασεβεις καταστρεφονται και δεν υπαρχουσιν ο οικος δε των δικαιων θελει διαμενει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 12:8",
      "text": "Ο ανθρωπος εγκωμιαζεται κατα την συνεσιν αυτου ο δε διεστραμμενος την καρδιαν θελει εισθαι εις καταφρονησιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 12:9",
      "text": "Καλητερος ο ανθρωπος ο μη τιμωμενος και επαρκων εις εαυτον, παρα ο κενοδοξων και στερουμενος αρτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 12:10",
      "text": "Ο δικαιος επιμελειται την ζωην του κτηνους αυτου τα δε σπλαγχνα των ασεβων ειναι ανελεημονα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 12:11",
      "text": "Ο εργαζομενος την γην αυτου θελει χορτασθη αρτον ο δε ακολουθων τους ματαιοφρονας ειναι ενδεης φρενων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 12:12",
      "text": "Ο ασεβης ζητει την υπερασπισιν των κακων αλλ' η ριζα του δικαιου αναδιδει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 12:13",
      "text": "Δι' αμαρτιαν χειλεων παγιδευεται ο ασεβης ο δε δικαιος εξερχεται εκ στενοχωριας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 12:14",
      "text": "Εκ των καρπων του στοματος αυτου ο ανθρωπος θελει εμπλησθη αγαθων και η αμοιβη των χειρων του ανθρωπου θελει επιστρεψει εις αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 12:15",
      "text": "Η οδος του αφρονος ειναι ορθη εις τους οφθαλμους αυτου ο δε ακουων συμβουλας ειναι σοφος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 12:16",
      "text": "Ο αφρων φανερονει ευθυς την οργην αυτου ο δε φρονιμος σκεπαζει το ονειδος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 12:17",
      "text": "Ο λαλων αληθειαν αναγγελλει το δικαιον ο δε ψευδομαρτυς δολον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 12:18",
      "text": "Ο φλυαρος ειναι ως τραυματα μαχαιρας η δε γλωσσα των σοφων, ιασις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 12:19",
      "text": "Τα χειλη της αληθειας θελουσιν εισθαι σταθερα διαπαντος η δε ψευδης γλωσσα μονον στιγμιαια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 12:20",
      "text": "Δολος ειναι εν τη καρδια των μηχανευομενων κακα ευφροσυνη δε εις τους βουλευομενους ειρηνην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 12:21",
      "text": "Ουδεμια βλαβη θελει συμβη εις τον δικαιον οι δε ασεβεις θελουσιν εμπλησθη κακων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 12:22",
      "text": "Ψευδη χειλη βδελυγμα εις τον Κυριον οι δε ποιουντες αληθειαν ειναι δεκτοι εις αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 12:23",
      "text": "Ο φρονιμος ανθρωπος καλυπτει γνωσιν η δε καρδια των αφρονων διακηρυττει μωριαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 12:24",
      "text": "Η χειρ των επιμελων θελει εξουσιαζει οι δε οκνηροι θελουσιν εισθαι υποτελεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 12:25",
      "text": "Η λυπη εν τη καρδια του ανθρωπου ταπεινονει αυτην ο δε καλος λογος ευφραινει αυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 12:26",
      "text": "Ο δικαιος υπερεχει του πλησιον αυτου η δε οδος των ασεβων πλανα αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 12:27",
      "text": "Ο οκνηρος δεν επιτυγχανει του θηραματος αυτου τα δε υπαρχοντα του επιμελους ανθρωπου ειναι πολυτιμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.12.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 12:28",
      "text": "Εν τη οδω της δικαιοσυνης ειναι ζωη και η πορεια της οδου αυτης δεν φερει εις θανατον.",
      "paragraphStart": false
    }
  ]
}
