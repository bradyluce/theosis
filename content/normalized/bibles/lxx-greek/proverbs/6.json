{
  "chapter": {
    "id": "lxx-greek:proverbs.6",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 6,
    "referenceLabel": "Proverbs 6",
    "summary": "Source text for Proverbs 6 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.6.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 6:1",
      "text": "Υιε μου, εαν εγεινας εγγυητης δια τον φιλον σου, εαν εδωκας την χειρα σου εις ξενον,",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.6.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 6:2",
      "text": "επαγιδευθης δια των λογων του στοματος σου, επιασθης δια των λογων του στοματος σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 6:3",
      "text": "Καμε λοιπον τουτο, υιε μου, και σωζου, επειδη ηλθες εις τας χειρας του φιλου σου υπαγε, μη αποκαμης, και βιαζε τον φιλον σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 6:4",
      "text": "Μη δωσης υπνον εις τους οφθαλμους σου, μηδε νυσταγμον εις τα βλεφαρα σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 6:5",
      "text": "Σωζου, ως δορκαδιον εκ χειρος του κυνηγου και ως πτηνον εκ χειρος του ιξευτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 6:6",
      "text": "Υπαγε προς τον μυρμηκα, ω οκνηρε παρατηρησον τας οδους αυτου και γινου σοφος",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 6:7",
      "text": "οστις μη εχων αρχοντα, επιστατην η κυβερνητην,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 6:8",
      "text": "ετοιμαζει την τροφην αυτου το θερος, συναγει τας τροφας αυτου εν τω θερισμω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 6:9",
      "text": "Εως ποτε θελεις κοιμασθαι, οκνηρε; ποτε θελεις σηκωθη εκ του υπνου σου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 6:10",
      "text": "Ολιγος υπνος, ολιγος νυσταγμος, ολιγη συμπλοκη των χειρων εις τον υπνον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 6:11",
      "text": "Επειτα η πτωχεια σου ερχεται ως ταχυδρομος, και η ενδεια σου ως ανηρ ενοπλος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 6:12",
      "text": "Ο αχρειος ανθρωπος, ο κακοτροπος ανθρωπος, περιπατει με στομα διεστραμμενον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 6:13",
      "text": "Καμνει νευμα δια των οφθαλμων αυτου, σημαινει δια των ποδων αυτου, διδασκει δια των δακτυλων αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 6:14",
      "text": "μετα διεστραμμενης καρδιας μηχαναται κακα εν παντι καιρω εγειρει εριδας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 6:15",
      "text": "δια τουτο εξαιφνης θελει επελθει η απωλεια αυτου εξαιφνης θελει συντριφθη ανιατως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 6:16",
      "text": "Ταυτα τα εξ μισει ο Κυριος, επτα μαλιστα βδελυττεται η ψυχη αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 6:17",
      "text": "οφθαλμους υπερηφανους, γλωσσαν ψευδη και χειρας εκχεουσας αιμα αθωον,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 6:18",
      "text": "καρδιαν μηχανευομενην λογισμους κακους, ποδας τρεχοντας ταχεως εις το κακοποιειν,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 6:19",
      "text": "μαρτυρα ψευδη λαλουντα ψευδος και τον εμβαλλοντα εριδας μεταξυ αδελφων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 6:20",
      "text": "Υιε μου, φυλαττε την εντολην του πατρος σου, και μη απορριψης τον νομον της μητρος σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 6:21",
      "text": "Περιαψον αυτα διαπαντος επι της καρδιας σου, περιδεσον αυτα περι τον τραχηλον σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 6:22",
      "text": "Οταν περιπατης, θελει σε οδηγει οταν κοιμασαι, θελει σε φυλαττει και οταν εξυπνησης, θελει συνομιλει μετα σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 6:23",
      "text": "Διοτι λυχνος ειναι η εντολη και φως ο νομος, και οι ελεγχοι της παιδειας οδος ζωης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 6:24",
      "text": "δια να σε φυλαττωσιν απο κακης γυναικος, απο κολακειας γλωσσης γυναικος αλλοτριας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 6:25",
      "text": "Μη ορεχθης το καλλος αυτης εν τη καρδια σου και ας μη σε θηρευση δια των βλεφαρων αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 6:26",
      "text": "Διοτι εξ αιτιας γυναικος πορνης καταντα τις εως τμηματος αρτου, η δε μοιχαλις θηρευει την πολυτιμον ψυχην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 6:27",
      "text": "Δυναται τις να βαλη πυρ εις τον κολπον αυτου, και τα ιματια αυτου να μη καωσι;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 6:28",
      "text": "Δυναται τις να περιπατηση επ' ανθρακων πυρος, και οι ποδες αυτου να μη κατακαωσιν;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.29",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 6:29",
      "text": "Ουτω και ο εισερχομενος προς την γυναικα του πλησιον αυτου οστις εγγιζει αυτην, δεν θελει αθωωθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.30",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 6:30",
      "text": "Τον κλεπτην δεν αποστρεφονται, εαν κλεπτη δια να χορταση την ψυχην αυτου, οταν πεινα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.31",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 6:31",
      "text": "αλλ' εαν πιασθη, θελει αποδωσει επταπλασια θελει δωσει παντα τα υπαρχοντα της οικιας αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.32",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 6:32",
      "text": "Οστις ομως μοιχευει με γυναικα, ειναι ενδεης φρενων απωλειαν φερει εις την ψυχην αυτου, οστις πραττει τουτο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.33",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 6:33",
      "text": "Πληγας και ατιμιαν θελει υποφερει και το ονειδος αυτου δεν θελει εξαλειφθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.34",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 6:34",
      "text": "Διοτι η ζηλοτυπια ειναι μανια του ανδρος, και δεν θελει δειξει ελεος εις την ημεραν της εκδικησεως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.6.35",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 6:35",
      "text": "Δεν θελει δεχθη ουδεν λυτρον ουδε θελει εξιλεωθη, και αν πολλαπλασιασης τα δωρα.",
      "paragraphStart": false
    }
  ]
}
