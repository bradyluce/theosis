{
  "chapter": {
    "id": "lxx-greek:proverbs.10",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 10,
    "referenceLabel": "Proverbs 10",
    "summary": "Source text for Proverbs 10 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.10.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 10:1",
      "text": "Παροιμιαι Σολομωντος. Υιος σοφος ευφραινει πατερα υιος δε αφρων ειναι λυπη της μητρος αυτου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.10.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 10:2",
      "text": "Οι θησαυροι της ανομιας δεν ωφελουσιν η δε δικαιοσυνη ελευθερονει εκ θανατου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 10:3",
      "text": "Ο Κυριος δεν θελει λιμοκτονησει ψυχην δικαιου ανατρεπει δε την περιουσιαν των ασεβων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 10:4",
      "text": "Η οκνηρα χειρ πτωχειαν φερει πλουτιζει δε η χειρ του επιμελους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 10:5",
      "text": "Ο συναγων εν τω θερει ειναι υιος συνεσεως ο δε κοιμωμενος εν τω θερισμω υιος αισχυνης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 10:6",
      "text": "Ευλογια επι την κεφαλην του δικαιου το στομα δε των ασεβων αδικια καλυπτει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 10:7",
      "text": "Η μνημη του δικαιου ειναι μετ' ευλογιας το δε ονομα των ασεβων σηπεται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 10:8",
      "text": "Ο σοφος την καρδιαν θελει δεχεσθαι εντολας ο δε μωρος τα χειλη θελει υποσκελισθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 10:9",
      "text": "Ο περιπατων εν ακεραιοτητι περιπατει ασφαλως ο δε διαστρεφων τας οδους αυτου θελει γνωρισθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 10:10",
      "text": "Οστις νευει δια του οφθαλμου, προξενει οδυνην ο δε μωρος τα χειλη θελει υποσκελισθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 10:11",
      "text": "Το στομα του δικαιου ειναι πηγη ζωης το στομα δε των ασεβων αδικια καλυπτει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 10:12",
      "text": "Το μισος διεγειρει εριδας αλλ' η αγαπη καλυπτει παντα τα σφαλματα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 10:13",
      "text": "Εις τα χειλη του συνετου ευρισκεται η σοφια η δε ραβδος ειναι δια την ραχιν του ενδεους φρενων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 10:14",
      "text": "Οι σοφοι αποταμιευουσι γνωσιν το στομα δε του προπετους ειναι πλησιον απωλειας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 10:15",
      "text": "Τα αγαθα του πλουσιου ειναι η οχυρα αυτου πολις καταστροφη δε των πενητων πτωχεια αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 10:16",
      "text": "Τα εργα του δικαιου ειναι εις ζωην το προιον του ασεβους εις αμαρτιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 10:17",
      "text": "Ο φυλαττων την παιδειαν ευρισκεται εν οδω ζωης ο δε εγκαταλειπων τον ελεγχον αποπλαναται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 10:18",
      "text": "Οστις καλυπτει μισος υπο χειλη ψευδη, και οστις προφερει συκοφαντιαν, ειναι αφρων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 10:19",
      "text": "Εν τη πολυλογια δεν λειπει αμαρτια αλλ' οστις κρατει τα χειλη αυτου, ειναι συνετος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 10:20",
      "text": "Η γλωσσα του δικαιου αργυριον εκλεκτον η καρδια των ασεβων πραγμα μηδαμινον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 10:21",
      "text": "Τα χειλη του δικαιου βοσκουσι πολλους οι δε αφρονες αποθνησκουσι δι' ελλειψιν φρενων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 10:22",
      "text": "Η ευλογια του Κυριου πλουτιζει, και λυπη δεν θελει προστεθη εις αυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 10:23",
      "text": "Ως γελως ειναι εις τον αφρονα να πραττη κακον η δε σοφια ειναι ανδρος συνετου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 10:24",
      "text": "Ο φοβος του ασεβους θελει επελθει επ' αυτον η επιθυμια δε των δικαιων θελει εκπληρωθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 10:25",
      "text": "Καθως παρερχεται ο ανεμοστροβιλος, ουτως ο ασεβης δεν υπαρχει ο δε δικαιος θελει εισθαι τεθεμελιωμενος εις τον αιωνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 10:26",
      "text": "Καθως το οξος εις τους οδοντας και ο καπνος εις τους οφθαλμους, ουτως ειναι ο οκνηρος εις τους αποστελλοντας αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 10:27",
      "text": "Ο φοβος του Κυριου προσθετει ημερας τα δε ετη των ασεβων θελουσιν ελαττωθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 10:28",
      "text": "Η προσδοκια των δικαιων θελει εισθαι ευφροσυνη η ελπις ομως των ασεβων θελει απολεσθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.29",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 10:29",
      "text": "Η οδος του Κυριου ειναι οχυρωμα εις τον αμεμπτον, ολεθρος δε εις τους εργατας της ανομιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.30",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 10:30",
      "text": "Ο δικαιος εις τον αιωνα δεν θελει σαλευθη οι δε ασεβεις δεν θελουσι κατοικησει την γην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.31",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 10:31",
      "text": "Το στομα του δικαιου αναδιδει σοφιαν η δε ψευδης γλωσσα θελει εκκοπη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.10.32",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 10:32",
      "text": "Τα χειλη του δικαιου γνωριζουσι το ευχαριστον το στομα δε των ασεβων τα διεστραμμενα.",
      "paragraphStart": false
    }
  ]
}
