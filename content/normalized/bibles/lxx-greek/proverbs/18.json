{
  "chapter": {
    "id": "lxx-greek:proverbs.18",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 18,
    "referenceLabel": "Proverbs 18",
    "summary": "Source text for Proverbs 18 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.18.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 18:1",
      "text": "Ο ιδιογνωμων ζητει κατα την επιθυμιαν αυτου και εναντιονεται εις παν ο, τι ειναι ορθον.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.18.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 18:2",
      "text": "Ο αφρων δεν ηδυνεται εις την συνεσιν, αλλ' εις ο, τι φανταζεται η καρδια αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 18:3",
      "text": "Οταν ερχηται ο ασεβης, ερχεται και η καταφρονησις και μετα του ονειδους, η ατιμια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 18:4",
      "text": "Οι λογοι του στοματος του ανθρωπου ειναι υδατα βαθεα και η πηγη της σοφιας, χειμαρρος αναπηδων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 18:5",
      "text": "Δεν ειναι καλον να προσωποληπτη τις τον ασεβη, δια να ανατρεπη το δικαιον εν τη κρισει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 18:6",
      "text": "Τα χειλη του αφρονος εμβαινουσιν εις εριδας, και το στομα αυτου προσκαλει ραπισματα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 18:7",
      "text": "Το στομα του αφρονος ειναι ο αφανισμος αυτου, και τα χειλη αυτου παγις εις την ψυχην αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 18:8",
      "text": "Οι λογοι του ψιθυριστου καταπινονται ηδεως και καταβαινουσιν εως των ενδομυχων της κοιλιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 18:9",
      "text": "Ο οκνηρος εις το εργον αυτου ειναι βεβαιως αδελφος του ασωτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 18:10",
      "text": "Το ονομα του Κυριου ειναι πυργος οχυρος ο δικαιος, καταφευγων εις αυτον, ειναι εν ασφαλεια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 18:11",
      "text": "Τα αγαθα του πλουσιου ειναι η οχυρα αυτου πολις, και φανταζεται αυτα ως υψηλον τειχος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 18:12",
      "text": "Προ του αφανισμου υψονεται η καρδια του ανθρωπου και η ταπεινωσις προπορευεται της δοξης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 18:13",
      "text": "Το να αποκρινηται τις πριν ακουση, ειναι εις αυτον αφροσυνη και ονειδος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 18:14",
      "text": "Το πνευμα του ανθρωπου θελει υποστηριζει την αδυναμιαν αυτου αλλα το κατατεθλιμμενον πνευμα τις δυναται να υποφερη;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 18:15",
      "text": "Η καρδια του φρονιμου αποκτα συνεσιν και το ωτιον των σοφων ζητει γνωσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 18:16",
      "text": "Το δωρον του ανθρωπου ανοιγει τοπον εις αυτον, και φερει αυτον εμπροσθεν των μεγαλων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 18:17",
      "text": "Ο πρωτολογων εν τη κρισει αυτου φαινεται δικαιος αλλ' ο αντιδικος αυτου ερχεται και εξελεγχει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 18:18",
      "text": "Ο κληρος παυει τας αντιλογιας και αποφασιζει μεταξυ των δυνατων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 18:19",
      "text": "Αδελφος δυσαρεστηθεις υποτασσεται δυσκολωτερα παρα οχυρα πολις αι δε διαφοραι αυτων ειναι ως μοχλοι φρουριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 18:20",
      "text": "Εκ των καρπων του στοματος του ανθρωπου θελει χορτασθη η κοιλια αυτου απο του προιοντος των χειλεων αυτου θελει εμπλησθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 18:21",
      "text": "Θανατος και ζωη ειναι εις την χειρα της γλωσσης και οι αγαπωντες αυτην θελουσι φαγει τους καρπους αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 18:22",
      "text": "Οστις ευρηκε γυναικα, ευρηκεν αγαθον και απηλαυσε χαριν παρα Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 18:23",
      "text": "Ο πενης λαλει μετα ικεσιων αλλ' ο πλουσιος αποκρινεται μετα σκληροτητος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.18.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 18:24",
      "text": "Ο ανθρωπος ο εχων φιλους πρεπει να φερηται φιλικως και υπαρχει φιλος στενωτερος αδελφου.",
      "paragraphStart": false
    }
  ]
}
