{
  "chapter": {
    "id": "lxx-greek:proverbs.17",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 17,
    "referenceLabel": "Proverbs 17",
    "summary": "Source text for Proverbs 17 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.17.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 17:1",
      "text": "Καλητερον ξηρον ψωμιον και ειρηνη μετ' αυτου, παρα οικον πληρη θυματων μετα εριδος.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.17.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 17:2",
      "text": "Ο φρονιμος υπηρετης θελει εξουσιαζει επι υιου αισχυνης και θελει συμμοιρασθη την κληρονομιαν μεταξυ αδελφων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 17:3",
      "text": "Το χωνευτηριον δοκιμαζει τον αργυρον και η καμινος τον χρυσον, ο δε Κυριος τας καρδιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 17:4",
      "text": "Ο κακοποιος υπακουει εις τα ανομα χειλη ο ψευστης διδει ακροασιν εις την κακην γλωσσαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 17:5",
      "text": "Οστις περιγελα τον πτωχον, ονειδιζει τον Ποιητην αυτου οστις χαιρει εις συμφορας, δεν θελει μεινει ατιμωρητος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 17:6",
      "text": "Τεκνα τεκνων ειναι ο στεφανος των γεροντων και η δοξα των τεκνων οι πατερες αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 17:7",
      "text": "Χειλη υπεροχης δεν αρμοζουσιν εις τον αφρονα πολυ ολιγωτερον χειλη ψευδους εις τον αρχοντα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 17:8",
      "text": "Το δωρον ειναι ως λιθος πολυτιμος εις τους οφθαλμους του δωροδοκουμενου οπου τουτο εμφανισθη, κατορθονει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 17:9",
      "text": "Οστις κρυπτει παραβασιν, ζητει φιλιαν αλλ' οστις επαναλεγει το πραγμα, χωριζει τους στενωτερους φιλους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 17:10",
      "text": "Περισσοτερον τυπτει ο ελεγχος τον φρονιμον, παρα εκατον μαστιγωσεις τον αφρονα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 17:11",
      "text": "Ο κακος ζητει μονον στασεις δια τουτο αγγελος σκληρος θελει πεμφθη κατ' αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 17:12",
      "text": "Ας απαντηση τον ανθρωπον αρκτος στερηθεισα των τεκνων αυτης και ουχι αφρων εν τη μωρια αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 17:13",
      "text": "Οστις αποδιδει κακον αντι καλου, κακον δεν θελει αναχωρησει απο του οικου αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 17:14",
      "text": "Οστις αρχιζει φιλονεικιαν, ειναι ως ο εκφραττων υδατα οθεν παυσον απο της φιλονεικιας πριν εξαφθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 17:15",
      "text": "Ο δικαιονων τον ασεβη και ο καταδικαζων τον δικαιον, αμφοτεροι ειναι βδελυγμα εις τον Κυριον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 17:16",
      "text": "Τι χρησιμευουσι τα χρηματα εις την χειρα του αφρονος, δια να αγοραση σοφιαν, αφου δεν εχει γνωσιν;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 17:17",
      "text": "Εν παντι καιρω αγαπα ο φιλος, και ο αδελφος γενναται δια καιρον αναγκης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 17:18",
      "text": "Ανθρωπος ενδεης φρενων διδει χειρα και εγγυαται δια τον φιλον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 17:19",
      "text": "Ο αγαπων εριδας αγαπα αμαρτηματα ο υπερυψονων την πυλην αυτου ζητει ολεθρον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 17:20",
      "text": "Ο σκολιος την καρδιαν δεν ευρισκει καλον και ο διεστραμμενος την γλωσσαν αυτου πιπτει εις συμφοραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 17:21",
      "text": "Οστις γεννα αφρονα, γεννα αυτον δια λυπην αυτου και ο πατηρ του ανοητου δεν απολαμβανει χαραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 17:22",
      "text": "Η ευφραινομενη καρδια διδει ευεξιαν ως ιατρικον το δε κατατεθλιμμενον πνευμα ξηραινει τα οστα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 17:23",
      "text": "Ο ασεβης δεχεται δωρον απο του κολπου, δια να διαστρεψη τας οδους της κρισεως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 17:24",
      "text": "Επι του προσωπου του συνετου ειναι σοφια αλλ' οι οφθαλμοι του αφρονος βλεπουσιν εις τα ακρα της γης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 17:25",
      "text": "Ο αφρων υιος ειναι βαρυθυμια εις τον πατερα αυτου και πικρια εις την γεννησασαν αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 17:26",
      "text": "Δεν ειναι ποτε καλον να επιβαλληται ποινη εις τον δικαιον, να επιβουλευηται τις τους αρχοντας δια την ευθυτητα αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 17:27",
      "text": "Ο κρατων τους λογους αυτου ειναι γνωστικος ο μακροθυμος ανθρωπος ειναι φρονιμος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.17.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 17:28",
      "text": "Και αυτος ο αφρων, οταν σιωπα λογιζεται σοφος και ο κλειων τα χειλη αυτου, συνετος.",
      "paragraphStart": false
    }
  ]
}
