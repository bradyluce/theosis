{
  "chapter": {
    "id": "lxx-greek:proverbs.26",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 26,
    "referenceLabel": "Proverbs 26",
    "summary": "Source text for Proverbs 26 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.26.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 26:1",
      "text": "Καθως η χιων εν τω θερει και καθως η βροχη εν τω θερισμω, ουτως εις τον αφρονα η τιμη δεν αρμοζει.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.26.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 26:2",
      "text": "Ως περιφερεται το στρουθιον, ως περιπετα η χελιδων, ουτως η αδικος καταρα δεν θελει επιφθασει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 26:3",
      "text": "Μαστιξ δια τον ιππον, κημος δια τον ονον, και ραβδος δια την ραχιν των αφρονων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 26:4",
      "text": "Μη αποκρινου εις τον αφρονα κατα την αφροσυνην αυτου, δια να μη γεινης και συ ομοιος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 26:5",
      "text": "Αποκρινου εις τον αφρονα κατα την αφροσυνην αυτου, δια να μη ηναι σοφος εις τους οφθαλμους αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 26:6",
      "text": "Οστις αποστελλει μηνυμα δια χειρος του αφρονος, αποκοπτει τους ποδας αυτου και πινει ζημιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 26:7",
      "text": "Ως τα σκελη του χωλου κρεμονται ανωφελη, ουτως ειναι και παροιμια εν τω στοματι των αφρονων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 26:8",
      "text": "Ως ο δεσμευων λιθον εις σφενδονην, ουτως ειναι οστις διδει τιμην εις τον αφρονα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 26:9",
      "text": "Ως η ακανθα ωθουμενη εις την χειρα του μεθυσου, ουτως ειναι η παροιμια εν τω στοματι των αφρονων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 26:10",
      "text": "Ο δυναστης μιαινει τα παντα και μισθονει τους αφρονας, μισθονει και τους παραβατας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 26:11",
      "text": "Ως ο κυων επιστρεφει εις τον εμετον αυτου, ουτως ο αφρων επαναλαμβανει την αφροσυνην αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 26:12",
      "text": "Ειδες ανθρωπον νομιζοντα εαυτον σοφον; μαλλον ελπις ειναι εκ του αφρονος παρα εξ αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 26:13",
      "text": "Ο οκνηρος λεγει, Λεων ειναι εν τη οδω, λεων εν ταις πλατειαις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 26:14",
      "text": "Ως η θυρα περιστρεφεται επι τας στροφιγγας αυτης, ουτως ο οκνηρος επι την κλινην αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 26:15",
      "text": "Ο οκνηρος εμβαπτει την χειρα αυτου εις το τρυβλιον και βαρυνεται να επιστρεψη αυτην εις το στομα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 26:16",
      "text": "Ο οκνηρος νομιζει εαυτον σοφωτερον παρα επτα σοφους γνωμοδοτας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 26:17",
      "text": "Οστις διαβαινων ανακατονεται εις εριδα μη ανηκουσαν εις αυτον, ομοιαζει τον πιανοντα κυνα απο των ωτιων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 26:18",
      "text": "Ως ο μανιακος οστις ριπτει φλογας, βελη και θανατον,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 26:19",
      "text": "ουτως ειναι ο ανθρωπος, οστις απατα τον πλησιον αυτου και λεγει, δεν εκαμον εγω παιζων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 26:20",
      "text": "Οπου δεν ειναι ξυλα, το πυρ σβυνεται και οπου δεν ειναι ψιθυριστης, η ερις ησυχαζει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 26:21",
      "text": "Οι ανθρακες δια την ανθρακιαν και τα ξυλα δια το πυρ, και ο φιλερις ανθρωπος δια να εξαπτη εριδας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 26:22",
      "text": "Οι λογοι του ψιθυριστου καταπινονται ηδεως, και καταβαινουσιν εις τα ενδομυχα της κοιλιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 26:23",
      "text": "Τα ενθερμα χειλη μετα πονηρας καρδιας ειναι ως σκωρια αργυρου επικεχρισμενη επι πηλινον αγγειον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 26:24",
      "text": "Οστις μισει, υποκρινεται με τα χειλη αυτου, και μηχανευεται δολον εν τη καρδια αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 26:25",
      "text": "Οταν ομιλη χαριεντως, μη πιστευε αυτον διοτι εχει επτα βδελυγματα εν τη καρδια αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 26:26",
      "text": "Οστις σκεπαζει το μισος δια δολου, η πονηρια αυτου θελει φανερωθη εν μεσω της συναξεως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 26:27",
      "text": "Οστις σκαπτει λακκον, θελει πεσει εις αυτον και ο λιθος θελει επιστρεψει επι τον κυλιοντα αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.26.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 26:28",
      "text": "Η ψευδης γλωσσα μισει τους υπ' αυτης καταθλιβομενους και το απατηλον στομα εργαζεται καταστροφην.",
      "paragraphStart": false
    }
  ]
}
