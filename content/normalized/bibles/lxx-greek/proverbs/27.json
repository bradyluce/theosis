{
  "chapter": {
    "id": "lxx-greek:proverbs.27",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 27,
    "referenceLabel": "Proverbs 27",
    "summary": "Source text for Proverbs 27 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.27.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 27:1",
      "text": "Μη καυχασαι εις την αυριον ημεραν διοτι δεν εξευρεις τι θελει γεννησει η ημερα.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.27.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 27:2",
      "text": "Ας σε επαινη αλλος και μη το στομα σου ξενος, και μη τα χειλη σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 27:3",
      "text": "Βαρυς ειναι ο λιθος και δυσβαστακτος η αμμος αλλ' η οργη του αφρονος ειναι βαρυτερα των δυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 27:4",
      "text": "Ο θυμος ειναι σκληρος και η οργη οξεια αλλα τις δυναται να σταθη εμπροσθεν της ζηλοτυπιας;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 27:5",
      "text": "Ο φανερος ελεγχος ειναι καλητερος παρα κρυπτομενη αγαπη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 27:6",
      "text": "πληγαι φιλου ειναι πισται φιληματα δε εχθρων πολυαριθμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 27:7",
      "text": "Κεχορτασμενη ψυχη αποστρεφεται την κηρηθραν εις δε την πεινασμενην ψυχην παν πικρον φαινεται γλυκυ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 27:8",
      "text": "Ως το πτηνον το αποπλανωμενον απο της φωλεας αυτου, ουτως ειναι ο ανθρωπος ο αποπλανωμενος απο του τοπου αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 27:9",
      "text": "Τα μυρα και τα θυμιαματα ευφραινουσι την καρδιαν, και η γλυκυτης του φιλου δια της εγκαρδιου συμβουλης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 27:10",
      "text": "Τον φιλον σου και τον φιλον του πατρος σου μη εγκαταλιπης εις δε τον οικον του αδελφου σου μη εισελθης εν τη ημερα της συμφορας σου διοτι καλητερον ειναι γειτων πλησιον παρα αδελφος μακραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 27:11",
      "text": "Υιε μου, γινου σοφος και ευφραινε την καρδιαν μου, δια να εχω τι να αποκρινωμαι προς τον ονειδιζοντα με.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 27:12",
      "text": "Ο φρονιμος προβλεπει το κακον και κρυπτεται οι αφρονες εξακολουθουσι και τιμωρουνται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 27:13",
      "text": "Λαβε το ιματιον του εγγυωμενου δια ξενον και λαβε ενεχυρον απ' αυτου, εγγυωμενου περι ξενων πραγματων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 27:14",
      "text": "Ο εγειρομενος το πρωι και ευλογων μετα μεγαλης φωνης τον πλησιον αυτου θελει λογισθη ως καταρωμενος αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 27:15",
      "text": "Ακαταπαυστον σταξιμον εν ημερα βροχερα, και φιλερις γυνη ειναι ομοια",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 27:16",
      "text": "ο κρυπτων αυτην κρυπτει τον ανεμον και το μυρον εν τη δεξια αυτου κρυπτομενον φωναζει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 27:17",
      "text": "Ο σιδηρος ακονιζει τον σιδηρον και ο ανθρωπος ακονιζει το προσωπον του φιλου αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 27:18",
      "text": "Ο φυλαττων την συκην θελει φαγει τον καρπον αυτης και ο φυλαττων τον κυριον αυτου θελει τιμηθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 27:19",
      "text": "Καθως εις το υδωρ ανταποκρινεται προσωπον εις προσωπον, ουτω καρδια ανθρωπου εις ανθρωπον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 27:20",
      "text": "Ο αδης και η απωλεια δεν χορταινουσι και οι οφθαλμοι του ανθρωπου δεν χορταινουσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 27:21",
      "text": "Ο αργυρος δοκιμαζεται δια του χωνευτηριου και ο χρυσος δια της καμινου ο δε ανθρωπος δια του στοματος των εγκωμιαζοντων αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 27:22",
      "text": "Και αν κοπανισης δια κοπανου τον αφρονα εν ιγδιω μεταξυ σιτου κοπανιζομενου, η αφροσυνη αυτου δεν θελει χωρισθη απ' αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 27:23",
      "text": "Προσεχε να γνωριζης την καταστασιν των ποιμνιων σου, και επιμελου καλως τας αγελας σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 27:24",
      "text": "Διοτι ο πλουτος δεν μενει διαπαντος ουδε το διαδημα απο γενεας εις γενεαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 27:25",
      "text": "Ο χορτος βλαστανει και η χλοη αναφαινεται, και τα χορτα των ορεων συναγονται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 27:26",
      "text": "Τα αρνια ειναι δια τα ενδυματα σου, και οι τραγοι δια την πληρωμην του αγρου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.27.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 27:27",
      "text": "Και θελεις εχει αφθονον γαλα αιγων δια την τροφην σου, δια την τροφην του οικου σου και την ζωην των θεραπαινων σου.",
      "paragraphStart": false
    }
  ]
}
