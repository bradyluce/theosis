{
  "chapter": {
    "id": "lxx-greek:proverbs.28",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 28,
    "referenceLabel": "Proverbs 28",
    "summary": "Source text for Proverbs 28 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.28.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 28:1",
      "text": "Οι ασεβεις φευγουσιν ουδενος διωκοντος οι δε δικαιοι εχουσι θαρρος ως λεων.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.28.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 28:2",
      "text": "Δια τα αμαρτηματα του τοπου πολλοι ειναι οι αρχοντες αυτου δι' ανθρωπου ομως συνετου και νοημονος το πολιτευμα αυτου θελει διαρκει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 28:3",
      "text": "Πτωχος ανθρωπος και δυναστευων πτωχους ειναι ως βροχη κατακλυζουσα, ητις δεν διδει αρτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 28:4",
      "text": "Οσοι εγκαταλειπουσι τον νομον, εγκωμιαζουσι τους ασεβεις αλλ' οι φυλαττοντες τον νομον αντιμαχονται εις αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 28:5",
      "text": "Οι κακοι ανθρωποι δεν θελουσι νοησει κρισιν αλλ' οι ζητουντες τον Κυριον θελουσι νοησει τα παντα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 28:6",
      "text": "Καλητερος ο πτωχος ο περιπατων εν τη ακεραιοτητι αυτου, παρα τον διεστραμμενον τας οδους αυτου, και αν ηναι πλουσιος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 28:7",
      "text": "Ο φυλαττων τον νομον ειναι υιος συνετος ο δε φιλος των ασωτων καταισχυνει τον πατερα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 28:8",
      "text": "Ο αυξανων την περιουσιαν αυτου δια τοκου και πλεονεξιας συναγει αυτην δια τον ελεουντα τους πτωχους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 28:9",
      "text": "Του εκκλινοντος το ωτιον αυτου απο του να ακουη τον νομον, και αυτη η προσευχη αυτου θελει εισθαι βδελυγμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 28:10",
      "text": "Ο αποπλανων τους ευθεις εις οδον κακην αυτος θελει πεσει εις τον ιδιον αυτου λακκον αλλ' οι αμεμπτοι θελουσι κληρονομησει αγαθα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 28:11",
      "text": "Ο πλουσιος ανθρωπος νομιζει εαυτον σοφον αλλ' ο συνετος πτωχος εξελεγχει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 28:12",
      "text": "Οταν οι δικαιοι θριαμβευωσι, μεγαλη ειναι η δοξα αλλ' οταν οι ασεβεις υψονωνται, οι ανθρωποι κρυπτονται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 28:13",
      "text": "Ο κρυπτων τας αμαρτιας αυτου δεν θελει ευοδωθη ο δε εξομολογουμενος και παραιτων αυτας θελει ελεηθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 28:14",
      "text": "Μακαριος ο ανθρωπος ο φοβουμενος παντοτε οστις ομως σκληρυνει την καρδιαν αυτου, θελει πεσει εις συμφοραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 28:15",
      "text": "Λεων βρυχωμενος και αρκτος πεινωσα ειναι διοικητης ασεβης επι λαον πενιχρον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 28:16",
      "text": "Ο ηγεμων ο στερουμενος συνεσεως πληθυνει τας καταδυναστειας ο δε μισων την αρπαγην θελει μακρυνει τας ημερας αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 28:17",
      "text": "Ο ανθρωπος ο ενοχος αιματος ανθρωπου θελει σπευσει εις τον λακκον ουδεις θελει κρατησει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 28:18",
      "text": "Ο περιπατων εν ακεραιοτητι θελει σωθη ο δε διεστραμμενος εν ταις οδοις αυτου θελει πεσει δια μιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 28:19",
      "text": "Ο εργαζομενος την γην αυτου θελει χορτασθη αρτον ο δε ακολουθων τους ματαιοφρονας θελει εμπλησθη πτωχειας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 28:20",
      "text": "Ο πιστος ανθρωπος θελει εχει πολλην ευλογιαν αλλ' οστις σπευδει να πλουτηση, δεν θελει μεινει ατιμωρητος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 28:21",
      "text": "Να ηναι τις προσωποληπτης, δεν ειναι καλον διοτι ο τοιουτος ανθρωπος δι' εν κομματιον αρτου θελει ανομησει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 28:22",
      "text": "Ο εχων πονηρον οφθαλμον σπευδει να πλουτηση, και δεν καταλαμβανει οτι η ενδεια θελει ελθει επ' αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 28:23",
      "text": "Ο ελεγχων ανθρωπον υστερον θελει ευρει περισσοτεραν χαριν, παρα τον κολακευοντα δια της γλωσσης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 28:24",
      "text": "Ο κλεπτων τον πατερα αυτου η την μητερα αυτου, και λεγων, Τουτο δεν ειναι αμαρτια, αυτος ειναι συντροφος του ληστου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 28:25",
      "text": "Ο αλαζων την καρδιαν διεγειρει εριδας ο δε θαρρων επι Κυριον θελει παχυνθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 28:26",
      "text": "Ο θαρρων επι την ιδιαν αυτου καρδιαν ειναι αφρων αλλ' ο περιπατων εν σοφια, ουτος θελει σωθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 28:27",
      "text": "Οστις διδει εις τους πτωχους, δεν θελει ελθει εις ενδειαν αλλ' οστις αποστρεφει τους οφθαλμους αυτου, θελει εχει πολλας καταρας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.28.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 28:28",
      "text": "Οταν οι ασεβεις υψονωνται, οι ανθρωποι κρυπτονται αλλ' εν τη απωλεια εκεινων οι δικαιοι πληθυνονται.",
      "paragraphStart": false
    }
  ]
}
