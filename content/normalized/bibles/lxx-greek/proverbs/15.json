{
  "chapter": {
    "id": "lxx-greek:proverbs.15",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 15,
    "referenceLabel": "Proverbs 15",
    "summary": "Source text for Proverbs 15 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.15.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 15:1",
      "text": "Η γλυκεια αποκρισις καταπραυνει θυμον αλλ' ο λυπηρος λογος διεγειρει οργην.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.15.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 15:2",
      "text": "Η γλωσσα των σοφων καλλωπιζει την γνωσιν το στομα δε των αφρονων εξερευγεται μωριαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 15:3",
      "text": "Οι οφθαλμοι του Κυριου ειναι εν παντι τοπω, παρατηρουντες κακους και αγαθους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 15:4",
      "text": "Η υγιαινουσα γλωσσα ειναι δενδρον ζωης η δε διεστραμμενη, συντριψις εις το πνευμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 15:5",
      "text": "Ο αφρων καταφρονει την διδασκαλιαν του πατρος αυτου ο δε φυλαττων ελεγχον ειναι φρονιμος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 15:6",
      "text": "Εν τω οικω του δικαιου ειναι θησαυρος πολυς εις δε το εισοδημα του ασεβους διασκορπισμος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 15:7",
      "text": "Τα χειλη των σοφων διαδιδουσι γνωσιν αλλ' η καρδια των αφρονων δεν ειναι ουτως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 15:8",
      "text": "Η θυσια των ασεβων ειναι βδελυγμα εις τον Κυριον αλλ' η δεησις των ευθεων ευπροσδεκτος εις αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 15:9",
      "text": "Βδελυγμα ειναι εις τον Κυριον η οδος του ασεβους αγαπα δε τον θηρευοντα την δικαιοσυνην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 15:10",
      "text": "Η διδασκαλια ειναι δυσαρεστος εις τον εγκαταλειποντα την οδον ο μισων τον ελεγχον θελει τελευτησει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 15:11",
      "text": "Ο αδης και η απωλεια ειναι εμπροσθεν του Κυριου ποσω μαλλον αι καρδιαι των υιων των ανθρωπων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 15:12",
      "text": "Ο χλευαστης δεν αγαπα τον ελεγχοντα αυτον, ουδε θελει υπαγει προς τους σοφους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 15:13",
      "text": "Καρδια ευφραινομενη ιλαρυνει το προσωπον υπο δε της λυπης της καρδιας καταθλιβεται το πνευμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 15:14",
      "text": "Η καρδια του συνετου ζητει γνωσιν το δε στομα των αφρονων βοσκει μωριαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 15:15",
      "text": "Πασαι αι ημεραι του τεθλιμμενου ειναι κακαι ο δε ευφραινομενος την καρδιαν εχει ευωχιαν παντοτεινην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 15:16",
      "text": "Καλητερον το ολιγον εν φοβω Κυριου, παρα θησαυροι πολλοι και ταραχη εν αυτοις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 15:17",
      "text": "Καλητερον ξενισμος λαχανων μετα αγαπης, παρα μοσχος σιτευτος μετα μισους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 15:18",
      "text": "Ο θυμωδης ανθρωπος διεγειρει μαχας ο δε μακροθυμος καταπαυει εριδας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 15:19",
      "text": "Η οδος του οκνηρου ειναι ως πεφραγμενη απο ακανθας αλλ' η οδος των ευθεων ειναι εξωμαλισμενη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 15:20",
      "text": "Υιος σοφος ευφραινει πατερα ο δε μωρος ανθρωπος καταφρονει την μητερα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 15:21",
      "text": "Η μωρια ειναι χαρα εις τον ενδεη φρενων ο δε συνετος ανθρωπος περιπατει ορθως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 15:22",
      "text": "Οπου συμβουλιον δεν υπαρχει, οι σκοποι ματαιονονται εν δε τω πληθει των συμβουλων στερεονονται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 15:23",
      "text": "Χαρα εις τον ανθρωπον δια την αποκρισιν του στοματος αυτου, και λογος εν καιρω, ποσον καλος ειναι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 15:24",
      "text": "Η οδος της ζωης εις τον συνετον ειναι προς τα ανω, δια να εκκλινη απο του αδου κατω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 15:25",
      "text": "Ο Κυριος καταστρεφει τον οικον των υπερηφανων στερεονει δε το οριον της χηρας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 15:26",
      "text": "Οι λογισμοι του πονηρου ειναι βδελυγμα εις τον Κυριον των δε καθαρων οι λογοι ευαρεστοι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 15:27",
      "text": "Ο δωροληπτης ταραττει τον οικον αυτου αλλ' οστις μισει τα δωρα θελει ζησει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 15:28",
      "text": "Η καρδια του δικαιου προμελετα δια να αποκριθη το δε στομα των ασεβων εξερευγεται κακα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.29",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 15:29",
      "text": "Ο Κυριος ειναι μακραν απο των ασεβων εισακουει δε της δεησεως των δικαιων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.30",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 15:30",
      "text": "Το φως των οφθαλμων ευφραινει την καρδιαν και η καλη φημη παχυνει τα οστα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.31",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 15:31",
      "text": "Το ωτιον, το οποιον ακουει τον ελεγχον της ζωης, διατριβει μεταξυ των σοφων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.32",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 15:32",
      "text": "Οστις απωθει την διδασκαλιαν, αποστρεφεται την ψυχην αυτου αλλ' οστις ακουει τον ελεγχον, αποκτα συνεσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.15.33",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 15:33",
      "text": "Ο φοβος του Κυριου ειναι διδασκαλια σοφιας και η ταπεινωσις προπορευεται της δοξης.",
      "paragraphStart": false
    }
  ]
}
