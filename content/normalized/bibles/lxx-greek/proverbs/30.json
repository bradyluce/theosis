{
  "chapter": {
    "id": "lxx-greek:proverbs.30",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 30,
    "referenceLabel": "Proverbs 30",
    "summary": "Source text for Proverbs 30 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.30.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 30:1",
      "text": "Οι λογοι του Αγουρ, υιου του Ιακαι τουτεστιν ο χρησμος, τον οποιον ο ανθρωπος ελαλησε προς τον Ιθιηλ, προς τον Ιθιηλ και τον Ουκαλ.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.30.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 30:2",
      "text": "Βεβαιως εγω ειμαι ο αφρονεστερος των ανθρωπων, και φρονησις ανθρωπου δεν υπαρχει εν εμοι",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 30:3",
      "text": "και δεν εμαθον την σοφιαν, ουτε εξευρω την γνωσιν των αγιων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 30:4",
      "text": "Τις ανεβη εις τον ουρανον και κατεβη; τις συνηγαγε τον ανεμον εν ταις χερσιν αυτου; τις εδεσμευσε τα υδατα εν ιματιω; τις εστερεωσε παντα τα ακρα της γης; τι το ονομα αυτου; και τι το ονομα του υιου αυτου, εαν εξευρης;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 30:5",
      "text": "Πας λογος Θεου ειναι δεδοκιμασμενος ειναι ασπις εις τους πεποιθοτας επ' αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 30:6",
      "text": "Μη προσθεσης εις τους λογους αυτου μηποτε σε εξελεγξη, και ευρεθης ψευστης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 30:7",
      "text": "Δυο ζητω παρα σου μη αρνηθης ταυτα εις εμε πριν αποθανω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 30:8",
      "text": "Ματαιοτητα και λογον ψευδη απομακρυνε απ' εμου πτωχειαν και πλουτον μη δωσης εις εμε τρεφε με με αυταρκη τροφην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 30:9",
      "text": "Μηποτε χορτασθω και σε αρνηθω και ειπω, Τις ειναι ο Κυριος; η μηποτε ευρεθεις πτωχος κλεψω και λαβω το ονομα του Θεου μου επι ματαιω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 30:10",
      "text": "Μη καταλαλει υπηρετην προς τον κυριον αυτου μηποτε σε καταρασθη και ευρεθης ενοχος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 30:11",
      "text": "Υπαρχει γενεα, ητις καταραται τον πατερα αυτης και δεν ευλογει την μητερα αυτης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 30:12",
      "text": "Υπαρχει γενεα καθαρα εις τους οφθαλμους αυτης, αλλα δεν ειναι πεπλυμενη απο της ακαθαρσιας αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 30:13",
      "text": "Υπαρχει γενεα, της οποιας ποσον υψηλοι ειναι οι οφθαλμοι και τα βλεφαρα αυτης επηρμενα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 30:14",
      "text": "Υπαρχει γενεα, της οποιας οι οδοντες ειναι ρομφαιαι και οι μυλοδοντες μαχαιραι, δια να κατατρωγωσι τους πτωχους της γης και τους ενδεεις εκ μεσου των ανθρωπων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 30:15",
      "text": "Η βδελλα εχει δυο θυγατερας, αιτινες φωναζουσι, Φερε, φερε. Τα τρια ταυτα δεν χορταινουσι ποτε, μαλιστα τεσσαρα δεν λεγουσι ποτε, Αρκει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 30:16",
      "text": "Ο αδης, και η στειρα μητρα η γη, ητις δεν χορταινει απο υδατος, και το πυρ, το οποιον δεν λεγει, Αρκει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 30:17",
      "text": "Τον οφθαλμον, οστις εμπαιζει τον πατερα αυτου και καταφρονει να υπακουση εις την μητερα αυτου, οι κορακες της φαραγγος θελουσιν εκβαλει και οι νεοσσοι των αετων θελουσι φαγει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 30:18",
      "text": "Τα τρια ταυτα ειναι θαυμαστα εις εμε, μαλιστα τεσσαρα δεν εννοω",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 30:19",
      "text": "Τα ιχνη του αετου εις τον ουρανον τα ιχνη του οφεως επι του βραχου τα ιχνη του πλοιου εν μεσω της θαλασσης και τα ιχνη του ανθρωπου εν τη νεοτητι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 30:20",
      "text": "Τοιαυτη ειναι η οδος της μοιχαλιδος γυναικος τρωγει και σπογγιζει το στομα αυτης, και λεγει, Δεν επραξα ανομιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 30:21",
      "text": "Δια τρια η γη ταραττεται, μαλιστα δια τεσσαρα, τα οποια δεν δυναται να υποφερη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 30:22",
      "text": "Δια τον δουλον, οταν βασιλευση και τον αφρονα, οταν χορτασθη αρτον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 30:23",
      "text": "δια την μισητην γυναικα, οταν υπανδρευθη και την δουλην, οταν εκδιωξη την κυριαν αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 30:24",
      "text": "Τα τεσσαρα ταυτα ειναι ελαχιστα επι της γης, ειναι ομως σοφωτατα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 30:25",
      "text": "οι μυρμηκες, οιτινες ειναι λαος αδυνατος αλλ' εν τω θερει ετοιμαζουσι την τροφην αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 30:26",
      "text": "οι χοιρογρυλλιοι, οιτινες ειναι λαος ανισχυρος αλλα καμνουσι τους οικους αυτων επι βραχου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 30:27",
      "text": "αι ακριδες, αιτινες δεν εχουσι βασιλεα αλλ' εκβαινουσι πασαι ομου κατα ταγματα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 30:28",
      "text": "ο ασκαλαβος, οστις βασταζεται εν ταις χερσιν αυτου, και διατριβει εν τοις παλατιοις των βασιλεων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.29",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 30:29",
      "text": "Τα τρια ταυτα βαδιζουσι καλως, μαλιστα τεσσαρα περιπατουσιν ευπρεπως",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.30",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 30:30",
      "text": "Ο λεων, οστις ειναι ο ισχυροτερος των ζωων, και δεν στρεφει απο προσωπου τινος",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.31",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 30:31",
      "text": "Ο αλεκτωρ, ο τραγος ετι και ο βασιλευς, περικεκυκλωμενος υπο του λαου αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.32",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 30:32",
      "text": "Εαν επραξας αφρονως υψονων σεαυτον, και εαν εβουλευθης κακον, βαλε χειρα επι στοματος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.30.33",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 30:33",
      "text": "Διοτι οστις κτυπα το γαλα, εκβαλλει βουτυρον και οστις εκθλιβει την ρινα, εκβαλλει αιμα και οστις ερεθιζει οργην, εξαγει μαχας.",
      "paragraphStart": false
    }
  ]
}
