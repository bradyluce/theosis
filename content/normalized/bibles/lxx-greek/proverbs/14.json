{
  "chapter": {
    "id": "lxx-greek:proverbs.14",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 14,
    "referenceLabel": "Proverbs 14",
    "summary": "Source text for Proverbs 14 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.14.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 14:1",
      "text": "Αι σοφαι γυναικες οικοδομουσι τον οικον αυτων η δε αφρων κατασκαπτει αυτον δια των χειρων αυτης.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.14.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 14:2",
      "text": "Ο περιπατων εν τη ευθυτητι αυτου φοβειται τον Κυριον ο δε σκολιος τας οδους αυτου καταφρονει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 14:3",
      "text": "Εν στοματι αφρονος ειναι η ραβδος της υπερηφανιας τα δε χειλη των σοφων θελουσι φυλαττει αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 14:4",
      "text": "Οπου δεν ειναι βοες, η αποθηκη ειναι κενη η δε αφθονια των γεννηματων ειναι εκ της δυναμεως του βοος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 14:5",
      "text": "Ο αληθης μαρτυς δεν θελει ψευδεσθαι ο δε ψευδης μαρτυς εκχεει ψευδη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 14:6",
      "text": "Ο χλευαστης ζητει σοφιαν και δεν ευρισκει εις δε τον συνετον ειναι ευκολος η μαθησις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 14:7",
      "text": "Υπαγε κατεναντι του αφρονος ανθρωπου και δεν θελεις ευρει χειλη συνεσεως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 14:8",
      "text": "Η σοφια του φρονιμου ειναι να γνωριζη την οδον αυτου η δε μωρια των αφρονων αποπλανησις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 14:9",
      "text": "Οι αφρονες γελωσιν εις την ανομιαν εν μεσω δε των ευθεων ειναι χαρις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 14:10",
      "text": "Η καρδια του ανθρωπου γνωριζει την πικριαν της ψυχης αυτου και ξενος δεν συμμετεχει της χαρας αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 14:11",
      "text": "Η οικια των ασεβων θελει αφανισθη η δε σκηνη των ευθεων θελει ανθει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 14:12",
      "text": "Υπαρχει οδος, ητις φαινεται ορθη εις τον ανθρωπον, αλλα τα τελη αυτης φερουσιν εις θανατον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 14:13",
      "text": "Ετι και εις τον γελωτα πονει η καρδια και το τελος της χαρας ειναι λυπη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 14:14",
      "text": "Ο διεφθαρμενος την καρδιαν θελει εμπλησθη απο των οδων αυτου ο δε αγαθος ανθρωπος αφ' εαυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 14:15",
      "text": "Ο απλους πιστευει εις παντα λογον ο δε φρονιμος προσεχει εις τα βηματα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 14:16",
      "text": "Ο σοφος φοβειται και φευγει απο του κακου αλλ' ο αφρων προχωρει και θρασυνεται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 14:17",
      "text": "Ο οξυθυμος πραττει αστοχαστως και ο κακοβουλος ανθρωπος ειναι μισητος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 14:18",
      "text": "Οι αφρονες κληρονομουσι μωριαν οι δε φρονιμοι στεφανουνται συνεσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 14:19",
      "text": "Οι κακοι υποκλινουσιν εμπροσθεν των αγαθων, και οι ασεβεις εις τας πυλας των δικαιων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 14:20",
      "text": "Ο πτωχος μισειται και υπο του πλησιον αυτου του δε πλουσιου οι φιλοι πολλοι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 14:21",
      "text": "Ο καταφρονων τον πλησιον αυτου αμαρτανει ο δε ελεων τους πτωχους ειναι μακαριος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 14:22",
      "text": "Δεν πλανωνται οι βουλευομενοι κακον; ελεος ομως και αληθεια θελει εισθαι εις τους βουλευομενους αγαθον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 14:23",
      "text": "Εν παντι κοπω υπαρχει κερδος η δε φλυαρια των χειλεων φερει μονον εις ενδειαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 14:24",
      "text": "Τα πλουτη των σοφων ειναι στεφανος εις αυτους των δε αφρονων η υπεροχη μωρια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 14:25",
      "text": "Ο αληθης μαρτυς ελευθερονει ψυχας ο δε δολιος εκχεει ψευδη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 14:26",
      "text": "Εν τω φοβω του Κυριου ειναι ελπις ισχυρα και εις τα τεκνα αυτου θελει υπαρχει καταφυγιον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 14:27",
      "text": "Ο φοβος του Κυριου ειναι πηγη ζωης, απομακρυνων απο παγιδων θανατου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 14:28",
      "text": "Εν τω πληθει του λαου ειναι η δοξα του βασιλεως εν δε τη ελλειψει του λαου ο αφανισμος του ηγεμονευοντος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.29",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 14:29",
      "text": "Ο μακροθυμος εχει μεγαλην φρονησιν ο δε οξυθυμος ανεγειρει την αφροσυνην αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.30",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 14:30",
      "text": "Η υγιαινουσα καρδια ειναι ζωη της σαρκος ο δε φθονος σαπρια των οστεων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.31",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 14:31",
      "text": "Ο καταθλιβων τον πενητα ονειδιζει τον Ποιητην αυτου ο δε τιμων αυτον ελεει τον πτωχον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.32",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 14:32",
      "text": "Ο ασεβης εκτινασσεται εν τη ασεβεια αυτου ο δε δικαιος και εν τω θανατω αυτου εχει ελπιδα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.33",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 14:33",
      "text": "Εν τη καρδια του συνετου επαναπαυεται σοφια εν μεσω δε των αφρονων φανερουται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.34",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 14:34",
      "text": "Η δικαιοσυνη υψονει εθνος η δε αμαρτια ειναι ονειδος λαων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.14.35",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 14:35",
      "text": "Ευνοια του βασιλεως ειναι προς φρονιμον δουλον θυμος δε αυτου προς τον προξενουντα αισχυνην.",
      "paragraphStart": false
    }
  ]
}
