{
  "chapter": {
    "id": "lxx-greek:proverbs.1",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 1,
    "referenceLabel": "Proverbs 1",
    "summary": "Source text for Proverbs 1 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.1.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 1:1",
      "text": "Παροιμιαι Σολομωντος, υιου του Δαβιδ, βασιλεως του Ισραηλ,",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.1.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 1:2",
      "text": "δια να γνωριση τις σοφιαν και παιδειαν, δια να νοηση λογους φρονησεως,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 1:3",
      "text": "δια να λαβη διδασκαλιαν συνεσεως, δικαιοσυνης και κρισεως και ευθυτητος,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 1:4",
      "text": "δια να δωση νοησιν εις τους απλους, και εις τον νεον μαθησιν και διαγνωσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 1:5",
      "text": "Ο σοφος ακουων θελει γεινει σοφωτερος, και ο νοημων θελει αποκτησει επιστημην κυβερνησεως",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 1:6",
      "text": "ωστε να εννοη παροιμιαν και σκοτεινον λογον, ρησεις σοφων και αινιγματα αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 1:7",
      "text": "Αρχη σοφιας φοβος Κυριου οι αφρονες καταφρονουσι την σοφιαν και την διδασκαλιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 1:8",
      "text": "Ακουε, υιε μου, την διδασκαλιαν του πατρος σου, και μη απορριψης τον νομον της μητρος σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 1:9",
      "text": "Διοτι ταυτα θελουσιν εισθαι στεφανος χαριτων εις την κορυφην σου και περιδεραιον περι τον τραχηλον σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 1:10",
      "text": "Υιε μου, εαν θελησωσιν οι αμαρτωλοι να σε δελεασωσι, μη θελησης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 1:11",
      "text": "εαν ειπωσιν, Ελθε μεθ' ημων, ας ενεδρευσωμεν δι' αιμα, ας επιβουλευθωμεν αναιτιως τον αθωον,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 1:12",
      "text": "Ας καταπιωμεν αυτους ζωντας, ως ο αδης, και ολοκληρους ως τους καταβαινοντας εις τον λακκον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 1:13",
      "text": "θελομεν ευρει παν πολυτιμον αγαθον, θελομεν γεμισει τους οικους ημων απο λαφυρων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 1:14",
      "text": "θες τον κληρον σου μεταξυ ημων, εν βαλαντιον ας ηναι εις παντας ημας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 1:15",
      "text": "υιε μου, μη περιπατησης εν οδω μετ' αυτων απεχε τον ποδα σου απο των τριβων αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 1:16",
      "text": "διοτι οι ποδες αυτων τρεχουσιν εις το κακον, και σπευδουσιν εις το να χυσωσιν αιμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 1:17",
      "text": "Διοτι ματαιως εξαπλονεται δικτυον εμπροσθεν των οφθαλμων παντος πτερωτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 1:18",
      "text": "Διοτι ουτοι ενεδρευουσι κατα του ιδιου αυτων αιματος, επιβουλευονται τας εαυτων ψυχας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 1:19",
      "text": "Τοιαυται ειναι αι οδοι παντος πλεονεκτου η πλεονεξια αφαιρει την ζωην των κυριευομενων υπ' αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 1:20",
      "text": "Η σοφια φωναζει εξω, εκπεμπει την φωνην αυτης εν ταις πλατειαις",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 1:21",
      "text": "Κραζει επι κεφαλης των αγορων, εν ταις εισοδοις των πυλων απαγγελλει τους λογους αυτης δια της πολεως, λεγουσα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 1:22",
      "text": "Εως ποτε, μωροι, θελετε αγαπα την μωριαν, και οι χλευασται θελουσιν ηδυνεσθαι εις τους χλευασμους αυτων, και οι αφρονες θελουσι μισει την γνωσιν;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 1:23",
      "text": "Επιστρεψατε προς τους ελεγχους μου ιδου, εγω θελω εκχεει το πνευμα μου εφ' υμας, θελω σας καμει να νοησητε τους λογους μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 1:24",
      "text": "Επειδη εγω εκραζον, και σεις δεν υπηκουετε εξετεινον την χειρα μου, και ουδεις προσειχεν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 1:25",
      "text": "Αλλα κατεφρονειτε πασας τας συμβουλας μου και τους ελεγχους μου δεν εδεχεσθε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 1:26",
      "text": "δια τουτο και εγω θελω επιγελασει εις τον ολεθρον σας θελω καταχαρη, οταν επελθη ο φοβος σας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 1:27",
      "text": "Οταν ο φοβος σας επελθη ως ερημωσις και η καταστροφη σας εφορμηση ως ανεμοστροβιλος, οταν η θλιψις και η στενοχωρια ελθωσιν εφ' υμας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 1:28",
      "text": "τοτε θελουσι με επικαλεσθη, αλλα δεν θελω αποκριθη επιμονως θελουσι με εκζητησει, αλλα δεν θελουσι με ευρει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.29",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 1:29",
      "text": "Διοτι εμισησαν την γνωσιν και τον φοβον του Κυριου δεν εξελεξαν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.30",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 1:30",
      "text": "δεν ηθελησαν τας συμβουλας μου κατεφρονησαν παντας τους ελεγχους μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.31",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 1:31",
      "text": "δια τουτο θελουσι φαγει απο των καρπων της οδου αυτων και θελουσι χορτασθη απο των κακοβουλιων αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.32",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 1:32",
      "text": "Διοτι η αποστασια των μωρων θελει θανατωσει αυτους, και η αμεριμνησια των αφρονων θελει αφανισει αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.1.33",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 1:33",
      "text": "Οστις ομως ακουει εμου, θελει κατοικησει εν ασφαλεια και θελει ησυχαζει, μη φοβουμενος κακον.",
      "paragraphStart": false
    }
  ]
}
