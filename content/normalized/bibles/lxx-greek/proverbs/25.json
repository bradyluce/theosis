{
  "chapter": {
    "id": "lxx-greek:proverbs.25",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 25,
    "referenceLabel": "Proverbs 25",
    "summary": "Source text for Proverbs 25 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.25.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 25:1",
      "text": "Και αυται ειναι παροιμιαι του Σολομωντος, τας οποιας συνελεξαν οι ανθρωποι του Εζεκιου, βασιλεως του Ιουδα.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.25.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 25:2",
      "text": "Δοξα του Θεου ειναι να καλυπτη το πραγμα δοξα δε των βασιλεων να εξιχνιαζωσι το πραγμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 25:3",
      "text": "Ο ουρανος κατα το υψος και η γη κατα το βαθος και η καρδια των βασιλεων ειναι ανεξερευνητα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 25:4",
      "text": "Αφαιρεσον την σκωριαν απο του αργυρου, και σκευος θελει εξελθει εις τον χρυσοχοον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 25:5",
      "text": "αφαιρεσον τους ασεβεις απ' εμπροσθεν του βασιλεως, και ο θρονος αυτου θελει στερεωθη εν δικαιοσυνη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 25:6",
      "text": "Μη αλαζονευου εμπροσθεν του βασιλεως, και μη ιστασαι εν τω τοπω των μεγαλων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 25:7",
      "text": "Διοτι καλητερον να σοι ειπωσιν, Αναβα εδω, παρα να καταβιβασθης επι παρουσια του αρχοντος, τον οποιον ειδον οι οφθαλμοι σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 25:8",
      "text": "Μη εξελθης εις εριδα ταχεως μηποτε εν τω τελει απορησης τι να καμης, οταν ο πλησιον σου σε καταισχυνη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 25:9",
      "text": "Εκδικασον την δικην σου μετα του πλησιον σου και μη ανακαλυπτε το μυστικον αλλου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 25:10",
      "text": "Μηποτε ο ακουων σε ονειδιση και η καταισχυνη σου δεν εξαλειφθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 25:11",
      "text": "Λογος λαληθεις πρεποντως ειναι μηλα χρυσα εις ποικιλματα αργυρα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 25:12",
      "text": "Ως ενωτιον χρυσουν και στολιδιον καθαρου χρυσιου, ειναι ο σοφος ο ελεγχων ωτιον υπηκοον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 25:13",
      "text": "Ως το ψυχος της χιονος εν καιρω του θερισμου, ουτως ειναι ο πιστος πρεσβυς εις τους αποστελλοντας αυτον διοτι αναπαυει την ψυχην των κυριων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 25:14",
      "text": "Ο καυχωμενος εις δωρον ψευδες ομοιαζει συννεφα και ανεμον χωρις βροχης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 25:15",
      "text": "Δι' υπομονης πειθεται ο ηγεμων και η γλυκεια γλωσσα συντριβει οστα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 25:16",
      "text": "Ευρηκας μελι; φαγε οσον σοι ειναι αρκετον, μηποτε υπερεμπλησθης απ' αυτου και εξεμεσης αυτο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 25:17",
      "text": "Σπανιως βαλε τον ποδα σου εις τον οικον του πλησιον σου, μηποτε σε βαρυνθη και σε μισηση.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 25:18",
      "text": "Ο ανθρωπος, οστις μαρτυρει κατα του πλησιον αυτου μαρτυριαν ψευδη, ειναι ως ροπαλον και μαχαιρα και βελος οξυ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 25:19",
      "text": "Πιστις προς απιστον εν ημερα συμφορας ειναι ως οδοντιον σεσηπος και πους εξηρθρωμενος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 25:20",
      "text": "Ως ο εκδυομενος ιματιον εν ημερα ψυχους και το οξος επι νιτρον, ουτως ειναι ο ψαλλων ασματα εις λελυπημενην καρδιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 25:21",
      "text": "Εαν πεινα ο εχθρος σου, δος εις αυτον αρτον να φαγη και εαν διψα, ποτισον αυτον υδωρ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 25:22",
      "text": "διοτι θελεις σωρευσει ανθρακας πυρος επι την κεφαλην αυτου, και ο Κυριος θελει σε ανταμειψει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 25:23",
      "text": "Ο βορρας ανεμος εκδιωκει την βροχην το δε ωργισμενον προσωπον την υποψιθυριζουσαν γλωσσαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 25:24",
      "text": "Καλητερον να κατοικη τις εν γωνια δωματος, παρα εν οικω ευρυχωρω μετα γυναικος φιλεριδος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 25:25",
      "text": "Ως υδωρ ψυχρον εις ψυχην διψωσαν, ουτως ειναι αγγελιαι αγαθαι απο μακρυνης γης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 25:26",
      "text": "Ο δικαιος σφαλλων εμπροσθεν του ασεβους ειναι ως πηγη θολερα και βρυσις διαφθαρεισα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 25:27",
      "text": "Καθως δεν ειναι καλον να τρωγη τις πολυ μελι, ουτω δεν ειναι ενδοξον να ζητη την ιδιαν αυτου δοξαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.25.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 25:28",
      "text": "Οστις δεν κρατει το πνευμα αυτου, ειναι ως πολις κατηδαφισμενη και ατειχιστος.",
      "paragraphStart": false
    }
  ]
}
