{
  "chapter": {
    "id": "lxx-greek:proverbs.31",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 31,
    "referenceLabel": "Proverbs 31",
    "summary": "Source text for Proverbs 31 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.31.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 31:1",
      "text": "Οι λογοι του βασιλεως Λεμουηλ, ο χρησμος, τον οποιον η μητηρ αυτου εδιδαξεν αυτον.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.31.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 31:2",
      "text": "Τι, υιε μου; και τι, τεκνον της κοιλιας μου; και τι, υιε των ευχων μου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 31:3",
      "text": "Μη δωσης τας δυναμεις σου εις τας γυναικας, μηδε τας οδους σου εις τας αφανιστριας των βασιλεων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 31:4",
      "text": "Δεν ειναι των βασιλεων, Λεμουηλ, δεν ειναι των βασιλεων να πινωσιν οινον, ουδε των ηγεμονων, σικερα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 31:5",
      "text": "μηποτε πιοντες λησμονησωσι τον νομον και διαστρεψωσι την κρισιν τινος τεθλιμμενου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 31:6",
      "text": "Διδετε σικερα εις τους τεθλιμμενους, και οινον εις τους πεπικραμενους την ψυχην",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 31:7",
      "text": "δια να πιωσι και να λησμονησωσι την πτωχειαν αυτων και να μη ενθυμωνται πλεον την δυστυχιαν αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 31:8",
      "text": "Ανοιγε το στομα σου υπερ του αφωνου, υπερ της κρισεως παντων των εγκαταλελειμμενων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 31:9",
      "text": "Ανοιγε το στομα σου, κρινε δικαιως, και υπερασπιζου τον πτωχον και τον ενδεη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 31:10",
      "text": "Γυναικα εναρετον τις θελει ευρει; διοτι η τοιαυτη ειναι πολυ τιμιωτερα υπερ τους μαργαριτας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 31:11",
      "text": "Η καρδια του ανδρος αυτης θαρρει επ' αυτην, και δεν θελει στερεισθαι αφθονιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 31:12",
      "text": "Θελει φερει εις αυτον καλον και ουχι κακον, πασας τας ημερας της ζωης αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 31:13",
      "text": "Ζητει μαλλιον και λιναριον και εργαζεται ευχαριστως με τας χειρας αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 31:14",
      "text": "Ειναι ως τα πλοια των εμπορων φερει την τροφην αυτης απο μακροθεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 31:15",
      "text": "Και εγειρεται ενω ειναι ετι νυξ και διδει τροφην εις τον οικον αυτης, και εργα εις τας θεραπαινας αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 31:16",
      "text": "Θεωρει αγρον και αγοραζει αυτον εκ του καρπου των χειρων αυτης φυτευει αμπελωνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 31:17",
      "text": "Ζωνει την οσφυν αυτης με δυναμιν, και ενισχυει τους βραχιονας αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 31:18",
      "text": "Αισθανεται οτι το εμποριον αυτης ειναι καλον ο λυχνος αυτης δεν σβυνεται την νυκτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 31:19",
      "text": "Βαλλει τας χειρας αυτης εις το αδρακτιον και κρατει εν τη χειρι αυτης την ηλακατην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 31:20",
      "text": "Ανοιγει την χειρα αυτης εις τους πτωχους και εκτεινει τας χειρας αυτης προς τους ενδεεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 31:21",
      "text": "Δεν φοβειται την χιονα δια τον οικον αυτης διοτι πας ο οικος αυτης ειναι ενδεδυμενοι διπλα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 31:22",
      "text": "Καμνει εις εαυτην σκεπασματα το ενδυμα αυτης ειναι βυσσος και πορφυρα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 31:23",
      "text": "Ο ανηρ αυτης γνωριζεται εν ταις πυλαις, οταν καθηται μεταξυ των πρεσβυτερων του τοπου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 31:24",
      "text": "Καμνει λεπτον πανιον και πωλει και διδει ζωνας εις τους εμπορους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 31:25",
      "text": "Ισχυν και ευπρεπειαν ειναι ενδεδυμενη και ευφραινεται δια τον μελλοντα καιρον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 31:26",
      "text": "Ανοιγει το στομα αυτης εν σοφια και επι της γλωσσης αυτης ειναι νομος ευμενειας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 31:27",
      "text": "Επαγρυπνει εις την κυβερνησιν του οικου αυτης και αρτον οκνηριας δεν τρωγει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 31:28",
      "text": "Τα τεκνα αυτης σηκονονται και μακαριζουσιν αυτην ο ανηρ αυτης, και επαινει αυτην",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.29",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 31:29",
      "text": "Πολλαι θυγατερες εφερθησαν αξιως, αλλα συ υπερεβης πασας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.30",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 31:30",
      "text": "Ψευδης ειναι η χαρις και ματαιον το καλλος η γυνη η φοβουμενη τον Κυριον, αυτη θελει επαινεισθαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.31.31",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 31:31",
      "text": "Δοτε εις αυτην εκ του καρπου των χειρων αυτης και τα εργα αυτης ας επαινωσιν αυτην εν ταις πυλαις.",
      "paragraphStart": false
    }
  ]
}
