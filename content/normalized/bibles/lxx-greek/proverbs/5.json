{
  "chapter": {
    "id": "lxx-greek:proverbs.5",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 5,
    "referenceLabel": "Proverbs 5",
    "summary": "Source text for Proverbs 5 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.5.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 5:1",
      "text": "Υιε μου, προσεχε εις την σοφιαν μου, κλινον το ωτιον σου εις την συνεσιν μου",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.5.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 5:2",
      "text": "δια να τηρης φρονησιν και τα χειλη σου να φυλαττωσι γνωσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 5:3",
      "text": "Διοτι τα χειλη της αλλοτριας γυναικος σταζουσιν ως κηρηθρα μελιτος, και ο ουρανισκος αυτης ειναι μαλακωτερος ελαιου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 5:4",
      "text": "το τελος ομως αυτης ειναι πικρον ως αψινθιον, οξυ ως μαχαιρα διστομος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 5:5",
      "text": "Οι ποδες αυτης καταβαινουσιν εις θανατον τα βηματα αυτης καταντωσιν εις τον αδην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 5:6",
      "text": "δια να μη γνωρισης την οδον της ζωης, αι πορειαι αυτης ειναι αστατοι και ουχι ευδιαγνωστοι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 5:7",
      "text": "Ακουσατε μου λοιπον τωρα, τεκνα, και μη αποστραφητε τους λογους του στοματος μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 5:8",
      "text": "Απομακρυνον την οδον σου απ' αυτης, και μη πλησιασης εις την θυραν του οικου αυτης,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 5:9",
      "text": "δια να μη δωσης την τιμην σου εις αλλους και τα ετη σου εις τους ανελεημονας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 5:10",
      "text": "δια να μη χορτασθωσι ξενοι απο της περιουσιας σου και οι κοποι σου ελθωσιν εις οικον αλλοτριου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 5:11",
      "text": "και συ στεναζης εις τα εσχατα σου, οταν η σαρξ σου και το σωμα σου καταναλωθωσι,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 5:12",
      "text": "και λεγης, Πως εμισησα την παιδειαν, και η καρδια μου κατεφρονησε τους ελεγχους,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 5:13",
      "text": "και δεν υπηκουσα εις την φωνην των διδασκοντων με, ουδε εκλινα το ωτιον μου εις τους νουθετουντας με.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 5:14",
      "text": "Παρ' ολιγον επεσον εις παν κακον, εν μεσω της συναξεως και της συναγωγης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 5:15",
      "text": "Πινε υδατα εκ της δεξαμενης σου και πηγαζοντα εκ του φρεατος σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 5:16",
      "text": "Ας εκχεωνται εξω αι πηγαι σου, και τα ρυακια των υδατων σου εις τας πλατειας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 5:17",
      "text": "σου μονου ας ηναι αυτα, και ουχι ξενων μετα σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 5:18",
      "text": "η πηγη σου ας ηναι ευλογημενη και ευφραινου μετα της γυναικος της νεοτητος σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 5:19",
      "text": "Ας ηναι εις σε ως ελαφος ερασμια και δορκας κεχαριτωμενη ας σε ποτιζωσιν οι μαστοι αυτης εν παντι καιρω ευφραινου παντοτε εις την αγαπην αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 5:20",
      "text": "Και δια τι, υιε μου, θελεις θελγεσθαι υπο ξενης και θελεις εναγκαλιζεσθαι κολπον αλλοτριας;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 5:21",
      "text": "Διοτι του ανθρωπου αι οδοι ειναι ενωπιον των οφθαλμων του Κυριου, και σταθμιζει πασας τας πορειας αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 5:22",
      "text": "Αι ιδιαι αυτου ανομιαι θελουσι συλλαβει τον ασεβη, και με τα σχοινια της αμαρτιας αυτου θελει σφιγγεσθαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.5.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 5:23",
      "text": "Ουτος θελει αποθανει απαιδευτος και εκ του πληθους της αφροσυνης αυτου θελει περιπλανασθαι.",
      "paragraphStart": false
    }
  ]
}
