{
  "chapter": {
    "id": "lxx-greek:proverbs.13",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 13,
    "referenceLabel": "Proverbs 13",
    "summary": "Source text for Proverbs 13 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.13.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 13:1",
      "text": "Ο σοφος υιος δεχεται την διδασκαλιαν του πατρος ο δε χλευαστης δεν ακουει ελεγχον.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.13.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 13:2",
      "text": "Εκ των καρπων του στοματος αυτου ο ανθρωπος θελει φαγει αγαθα η δε ψυχη των ανομων αδικιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 13:3",
      "text": "Ο φυλαττων το στομα αυτου διαφυλαττει την ζωην αυτου ο δε ανοιγων προπετως τα χειλη αυτου θελει απολεσθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 13:4",
      "text": "Η ψυχη του οκνηρου επιθυμει και δεν εχει η δε ψυχη των επιμελων θελει χορτασθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 13:5",
      "text": "Ο δικαιος μισει λογον ψευδη ο δε ασεβης καθισταται δυσωδης και ατιμος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 13:6",
      "text": "Η δικαιοσυνη φυλαττει τον τελειον την οδον η δε ασεβεια καταστρεφει τον αμαρτωλον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 13:7",
      "text": "Υπαρχει ανθρωπος οστις καμνει τον πλουσιον, και δεν εχει ουδεν και αλλος οστις καμνει τον πτωχον, και εχει πλουτον πολυν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 13:8",
      "text": "Το λυτρον της ψυχης του ανθρωπου ειναι ο πλουτος αυτου ο δε πτωχος δεν ακουει επιπληξιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 13:9",
      "text": "Το φως των δικαιων ειναι φαιδρον ο δε λυχνος των ασεβων θελει σβεσθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 13:10",
      "text": "Μονον απο της υπερηφανιας προερχεται η ερις η δε σοφια ειναι μετα των δεχομενων συμβουλας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 13:11",
      "text": "Τα εκ ματαιοτητος πλουτη θελουσιν ελαττωθη ο δε συναγων με την χειρα αυτου θελει αυξηνθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 13:12",
      "text": "Η ελπις αναβαλλομενη ατονιζει την καρδιαν το δε ποθουμενον, οταν ερχηται, ειναι δενδρον ζωης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 13:13",
      "text": "Ο καταφρονων τον λογον θελει αφανισθη ο δε φοβουμενος την εντολην, ουτος θελει ανταμειφθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 13:14",
      "text": "Ο νομος του σοφου ειναι πηγη ζωης, απομακρυνων απο παγιδων θανατου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 13:15",
      "text": "Συνεσις αγαθη διδει χαριν η δε οδος των παρανομων φερει εις ολεθρον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 13:16",
      "text": "Πας φρονιμος πραττει μετα γνωσεως ο δε αφρων ανακαλυπτει μωριαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 13:17",
      "text": "Ο κακος μηνυτης πιπτει εις δυστυχιαν ο δε πιστος πρεσβυς ειναι ιασις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 13:18",
      "text": "Πτωχεια και αισχυνη θελουσιν εισθαι εις τον αποβαλλοντα την διδασκαλιαν ο δε φυλαττων τον ελεγχον θελει τιμηθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 13:19",
      "text": "Επιθυμια εκπληρωθεισα ευφραινει την ψυχην εις δε τους αφρονας ειναι βδελυρον να εκκλινωσιν απο του κακου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 13:20",
      "text": "Ο περιπατων μετα σοφων θελει εισθαι σοφος ο δε συντροφος των αφρονων θελει απολεσθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 13:21",
      "text": "Κακον παρακολουθει τους αμαρτωλους εις δε τους δικαιους θελει ανταποδοθη καλον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 13:22",
      "text": "Ο αγαθος αφινει κληρονομιαν εις υιους υιων ο πλουτος δε του αμαρτωλου θησαυριζεται δια τον δικαιον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 13:23",
      "text": "Πολλην τροφην διδει ο αγρος των πτωχων τινες δε δι' ελλειψιν κρισεως αφανιζονται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 13:24",
      "text": "Ο φειδομενος της ραβδου αυτου μισει τον υιον αυτου αλλ' ο αγαπων αυτον παιδευει αυτον εν καιρω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.13.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 13:25",
      "text": "Ο δικαιος τρωγει μεχρι χορτασμου της ψυχης αυτου η δε κοιλια των ασεβων θελει στερεισθαι.",
      "paragraphStart": false
    }
  ]
}
