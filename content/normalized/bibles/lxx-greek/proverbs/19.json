{
  "chapter": {
    "id": "lxx-greek:proverbs.19",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 19,
    "referenceLabel": "Proverbs 19",
    "summary": "Source text for Proverbs 19 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.19.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 19:1",
      "text": "Καλητερος ο πτωχος ο περιπατων εν τη ακεραιοτητι αυτου, παρα τον πλουσιον τον διεστραμμενον τα χειλη αυτου και οντα αφρονα.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.19.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 19:2",
      "text": "Ψυχη ανευ γνωσεως βεβαιως δεν ειναι καλον και οστις σπευδει με τους ποδας, προσκοπτει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 19:3",
      "text": "Η αφροσυνη του ανθρωπου διαστρεφει την οδον αυτου και η καρδια αυτου αγανακτει κατα του Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 19:4",
      "text": "Ο πλουτος προσθετει φιλους πολλους ο δε πτωχος εγκαταλειπεται υπο του φιλου αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 19:5",
      "text": "Ο ψευδης μαρτυς δεν θελει μεινει ατιμωρητος και ο λαλων ψευδη δεν θελει εκφυγει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 19:6",
      "text": "Πολλοι κολακευουσι το προσωπον του αρχοντος και πας τις ειναι φιλος του διδοντος ανθρωπου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 19:7",
      "text": "Τον πτωχον μισουσι παντες οι αδελφοι αυτου ποσω μαλλον θελουσιν αποφευγει αυτον οι φιλοι αυτου; αυτος ακολουθει φωναζων αλλ' εκεινοι δεν αποκρινονται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 19:8",
      "text": "Οστις αποκτα σοφιαν, αγαπα την ψυχην αυτου οστις φυλαττει φρονησιν, θελει ευρει καλον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 19:9",
      "text": "Ο ψευδης μαρτυς δεν θελει μεινει ατιμωρητος και ο λαλων ψευδη θελει απολεσθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 19:10",
      "text": "Η τρυφη δεν αρμοζει εις αφρονα πολυ ολιγωτερον εις δουλον, να εξουσιαζη επ' αρχοντων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 19:11",
      "text": "Η φρονησις του ανθρωπου συστελλει τον θυμον αυτου και ειναι δοξα αυτου να παραβλεπη την παραβασιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 19:12",
      "text": "Η οργη του βασιλεως ειναι ως βρυχηθμος λεοντος η δε ευνοια αυτου ως δροσος επι τον χορτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 19:13",
      "text": "Ο αφρων υιος ειναι ολεθρος εις τον πατερα αυτου και αι εριδες της γυναικος ειναι ακαταπαυστον σταξιμον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 19:14",
      "text": "Οικος και πλουτη κληρονομουνται εκ των πατερων αλλ' η φρονιμος γυνη παρα Κυριου διδεται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 19:15",
      "text": "Η οκνηρια ριπτει εις βαθυν υπνον και η αεργος ψυχη θελει πεινα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 19:16",
      "text": "Ο φυλαττων την εντολην φυλαττει την ψυχην αυτου ο δε καταφρονων τας οδους αυτου θελει απολεσθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 19:17",
      "text": "Ο ελεων πτωχον δανειζει εις τον Κυριον και θελει γεινει εις αυτον η ανταποδοσις αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 19:18",
      "text": "Παιδευε τον υιον σου ενοσω ειναι ελπις αλλα μη διεγειρης την ψυχην σου, ωστε να θανατωσης αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 19:19",
      "text": "Ο οργιλος θελει λαβει ποινην διοτι και αν ελευθερωσης αυτον, παλιν θελεις καμει το αυτο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 19:20",
      "text": "Ακουε συμβουλην και δεχου διδασκαλιαν δια να γεινης σοφος εις τα εσχατα σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 19:21",
      "text": "Ειναι πολλοι λογισμοι εν τη καρδια του ανθρωπου η βουλη ομως του Κυριου, εκεινη θελει μενει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 19:22",
      "text": "Τιμη του ανθρωπου ειναι η αγαθοτης αυτου και καλητερος ο πτωχος παρα τον ψευστην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 19:23",
      "text": "Ο φοβος του Κυριου φερει ζωην, και ο φοβουμενος αυτον θελει πλαγιαζει κεχορτασμενος κακον δεν θελει συναπαντησει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 19:24",
      "text": "Ο οκνηρος εμβαπτει την χειρα αυτου εις το τρυβλιον, και δεν θελει ουδε εις το στομα αυτου να επιστρεψη αυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 19:25",
      "text": "Εαν μαστιγωσης τον χλευαστην, ο απλους θελει γεινει προσεκτικος και εαν ελεγξης τον φρονιμον, θελει εννοησει γνωσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 19:26",
      "text": "Οστις ατιμαζει τον πατερα και απωθει την μητερα, ειναι υιος προξενων αισχυνην και ονειδος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 19:27",
      "text": "Παυσον, υιε μου, να ακουης διδασκαλιαν παρεκτρεπουσαν απο των λογων της γνωσεως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 19:28",
      "text": "Ο ασεβης μαρτυς χλευαζει το δικαιον και το στομα των ασεβων καταπινει ανομιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.19.29",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 19:29",
      "text": "Κρισεις ετοιμαζονται δια τους χλευαστας, και ραβδισμοι δια την ραχιν των αφρονων.",
      "paragraphStart": false
    }
  ]
}
