{
  "chapter": {
    "id": "lxx-greek:proverbs.2",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 2,
    "referenceLabel": "Proverbs 2",
    "summary": "Source text for Proverbs 2 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.2.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 2:1",
      "text": "Υιε μου, εαν δεχθης τους λογους μου και ταμιευσης τας εντολας μου παρα σεαυτω,",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.2.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 2:2",
      "text": "ωστε να προσεξη το ωτιον σου εις την σοφιαν, να κλινης την καρδιαν σου εις την συνεσιν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 2:3",
      "text": "και εαν επικαλεσθης την φρονησιν, και υψωσης την φωνην σου εις την συνεσιν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 2:4",
      "text": "εαν ζητησης αυτην ως αργυριον και εξερευνησης αυτην ως κεκρυμμενους θησαυρους,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 2:5",
      "text": "τοτε θελεις εννοησει τον φοβον του Κυριου και θελεις ευρει την επιγνωσιν του Θεου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 2:6",
      "text": "Διοτι ο Κυριος διδει σοφιαν εκ του στοματος αυτου εξερχεται γνωσις και συνεσις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 2:7",
      "text": "Αποταμιευει σωτηριαν εις τους ευθεις ειναι ασπις εις τους περιπατουντας εν ακεραιοτητι,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 2:8",
      "text": "υπερασπιζων τας οδους της δικαιοσυνης και φυλαττων την οδον των οσιων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 2:9",
      "text": "Τοτε θελεις εννοησει δικαιοσυνην και κρισιν και ευθυτητα, πασαν οδον αγαθην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 2:10",
      "text": "Εαν η σοφια εισελθη εις την καρδιαν σου και η γνωσις ηδυνη την ψυχην σου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 2:11",
      "text": "ορθη βουλη θελει σε φυλαττει, συνεσις θελει σε διατηρει",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 2:12",
      "text": "δια να σε ελευθερονη απο της οδου της πονηρας, απο ανθρωπου λαλουντος δολια,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 2:13",
      "text": "οιτινες εγκαταλειπουσι τας οδους της ευθυτητος, δια να περιπατωσιν εν ταις οδοις του σκοτους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 2:14",
      "text": "οιτινες ηδυνονται εις το να καμνωσι κακον, χαιρουσιν εις τας διαστροφας της κακιας,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 2:15",
      "text": "των οποιων αι οδοι ειναι σκολιαι και αι πορειαι αυτων διεστραμμεναι",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 2:16",
      "text": "δια να σε ελευθερονη απο ξενης γυναικος, απο αλλοτριας κολακευουσης με τους λογους αυτης,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 2:17",
      "text": "ητις εγκατελιπε τον επιστηθιον της νεοτητος αυτης και ελησμονησε την διαθηκην του Θεου αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 2:18",
      "text": "Διοτι ο οικος αυτης καταβιβαζει εις τον θανατον, και τα βηματα αυτης εις τους νεκρους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 2:19",
      "text": "παντες οι εισερχομενοι προς αυτην δεν επιστρεφουσιν ουδε αναλαμβανουσι τας οδους της ζωης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 2:20",
      "text": "δια να περιπατης εν τη οδω των αγαθων και να φυλαττης τας τριβους των δικαιων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 2:21",
      "text": "Διοτι οι ευθεις θελουσι κατοικησει την γην, και οι τελειοι θελουσιν εναπολειφη εν αυτη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.2.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 2:22",
      "text": "Οι δε ασεβεις θελουσιν εκκοπη απο της γης, και οι παρανομοι θελουσιν εκριζωθη απ' αυτης.",
      "paragraphStart": false
    }
  ]
}
