{
  "chapter": {
    "id": "lxx-greek:proverbs.21",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 21,
    "referenceLabel": "Proverbs 21",
    "summary": "Source text for Proverbs 21 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.21.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 21:1",
      "text": "Η καρδια του βασιλεως ειναι εν τη χειρι του Κυριου ως ρευματα υδατων οπου θελει στρεφει αυτην.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.21.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 21:2",
      "text": "Πασαι αι οδοι του ανθρωπου φαινονται ορθαι εις τους οφθαλμους αυτου πλην ο Κυριος σταθμιζει τας καρδιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 21:3",
      "text": "Να καμνη τις δικαιοσυνην και κρισιν ειναι αρεστοτερον εις τον Κυριον παρα θυσιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 21:4",
      "text": "Το επηρμενον ομμα και η αλαζων καρδια, ο λυχνος των ασεβων, ειναι αμαρτια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 21:5",
      "text": "Οι λογισμοι του επιμελους φερουσι βεβαιως εις αφθονιαν παντος δε προπετους βεβαιως εις ενδειαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 21:6",
      "text": "Το αποκταν θησαυρους δια ψευδους γλωσσης ειναι ματαιοτης αστατος των ζητουντων θανατον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 21:7",
      "text": "Αι αρπαγαι των ασεβων θελουσιν εξολοθρευσει αυτους διοτι αρνουνται να πραττωσι το δικαιον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 21:8",
      "text": "Η οδος του διεφθαρμενου ανθρωπου ειναι σκολια του δε καθαρου το εργον ειναι ευθες.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 21:9",
      "text": "Καλητερον να κατοικη τις εν γωνια δωματος, παρα εν οικω ευρυχωρω μετα γυναικος φιλεριδος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 21:10",
      "text": "Η ψυχη του ασεβους επιθυμει κακον ο πλησιον αυτου δεν ευρισκει χαριν εις τους οφθαλμους αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 21:11",
      "text": "Οταν ο χλευαστης τιμωρηται, ο απλους γινεται σοφωτερος και ο σοφος διδασκομενος λαμβανει γνωσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 21:12",
      "text": "Ο δικαιος συλλογιζεται την οικιαν του ασεβους, οταν οι ασεβεις κατακρημνιζωνται εις την κακιαν αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 21:13",
      "text": "Οστις εμφραττει τα ωτα αυτου εις την κραυγην του πτωχου, θελει φωναξει και αυτος και δεν θελει εισακουσθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 21:14",
      "text": "Δωρον κρυφιον καταπραυνει θυμον και χαρισμα εις τον κολπον βαλλομενον, οργην ισχυραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 21:15",
      "text": "Χαρα ειναι εις τον δικαιον να καμνη κρισιν ολεθρος δε εις τους εργατας της ανομιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 21:16",
      "text": "Ανθρωπος αποπλανωμενος απο της οδου της συνεσεως θελει κατασκηνωσει εν τη συναξει των τεθανατωμενων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 21:17",
      "text": "Ο αγαπων ευθυμιαν θελει κατασταθη πενης ο αγαπων οινον και μυρα δεν θελει πλουτησει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 21:18",
      "text": "Ο ασεβης θελει εισθαι αντιλυτρον του δικαιου, και των ευθεων ο παραβατης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 21:19",
      "text": "Καλητερον να κατοικη τις εν γη ερημω παρα μετα γυναικος φιλεριδος και θυμωδους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 21:20",
      "text": "Θησαυρος πολυτιμος και μυρα ευρισκονται εν τω οικω του σοφου ο δε αφρων ανθρωπος καταδαπανα αυτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 21:21",
      "text": "Ο θηρευων δικαιοσυνην και ελεος θελει ευρει ζωην, δικαιοσυνην και δοξαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 21:22",
      "text": "Ο σοφος εκπορθει την πολιν των δυνατων και καταβαλλει το οχυρωμα του θαρρους αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 21:23",
      "text": "Οστις φυλαττει το στομα αυτου και την γλωσσαν αυτου, φυλαττει την ψυχην αυτου απο στενοχωριων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 21:24",
      "text": "Υπερηφανος και αλαζων χλευαστης καλειται, οστις πραττει μετα θυμου αλαζονειας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 21:25",
      "text": "Αι επιθυμιαι του οκνηρου θανατονουσιν αυτον διοτι αι χειρες αυτου δεν θελουσι να εργαζωνται",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 21:26",
      "text": "επιθυμει ολην την ημεραν επιθυμιας ο δε δικαιος διδει και δεν φειδεται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 21:27",
      "text": "Η θυσια των ασεβων ειναι βδελυγμα πολλω μαλλον οταν προσφερωσιν αυτην μετα πονηριας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 21:28",
      "text": "Ο ψευδης μαρτυς θελει απολεσθη ο δε ανθρωπος οστις υπακουει θελει λαλει παντοτε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.29",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 21:29",
      "text": "Ο ασεβης ανθρωπος σκληρυνει το προσωπον αυτου αλλ' ο ευθυς κατευθυνει τας οδους αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.30",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 21:30",
      "text": "Δεν ειναι σοφια ουτε συνεσις ουτε βουλη εναντιον του Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.21.31",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 21:31",
      "text": "Ο ιππος ετοιμαζεται δια την ημεραν της μαχης η σωτηρια ομως ειναι παρα Κυριου.",
      "paragraphStart": false
    }
  ]
}
