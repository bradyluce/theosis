{
  "chapter": {
    "id": "lxx-greek:proverbs.23",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 23,
    "referenceLabel": "Proverbs 23",
    "summary": "Source text for Proverbs 23 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.23.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 23:1",
      "text": "Οταν καθησης να φαγης μετα αρχοντος, παρατηρει επιμελως τα παρατιθεμενα εμπροσθεν σου",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.23.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 23:2",
      "text": "και βαλε μαχαιραν εις τον λαιμον σου, εαν ησαι αδηφαγος",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 23:3",
      "text": "μη επιθυμει τα εδεσματα αυτου διοτι ταυτα ειναι τροφη δολιοτητος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 23:4",
      "text": "Μη μεριμνα δια να γεινης πλουσιος απεχε απο της σοφιας σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 23:5",
      "text": "Θελεις επιστησει τους οφθαλμους σου εις το μη υπαρχον; διοτι ο πλουτος κατασκευαζει βεβαιως εις εαυτον πτερυγας ως αετου και πετα προς τον ουρανον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 23:6",
      "text": "Μη τρωγε τον αρτον του φθονερου, μηδε επιθυμει τα εδεσματα αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 23:7",
      "text": "διοτι καθως φρονει εν τη ψυχη αυτου, τοιουτος ειναι φαγε και πιε, λεγει προς σε αλλ' η καρδια αυτου δεν ειναι μετα σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 23:8",
      "text": "Το ψωμιον, το οποιον εφαγες, θελεις εξεμεσει και θελεις χασει τας γλυκειας συνομιλιας σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 23:9",
      "text": "Μη λαλει εις τα ωτα του αφρονος διοτι θελει καταφρονησει την σοφιαν των λογων σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 23:10",
      "text": "Μη μετακινει ορια αρχαια και μη εισελθης εις τους αγρους των ορφανων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 23:11",
      "text": "διοτι ο Λυτρωτης αυτων ειναι ισχυρος αυτος θελει εκδικασει την δικην αυτων εναντιον σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 23:12",
      "text": "Προσκολλησον την καρδιαν σου εις την παιδειαν και τα ωτα σου εις τους λογους της γνωσεως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 23:13",
      "text": "Μη φειδου να παιδευης το παιδιον διοτι εαν κτυπησης αυτο δια της ραβδου, δεν θελει αποθανει",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 23:14",
      "text": "συ κτυπων αυτο δια της ραβδου, θελεις ελευθερωσει την ψυχην αυτου εκ του αδου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 23:15",
      "text": "Υιε μου, εαν η καρδια σου γεινη σοφη, θελει ευφραινεσθαι και η καρδια εμου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 23:16",
      "text": "και τα νεφρα μου θελουσιν αγαλλεσθαι, οταν τα χειλη σου λαλωσιν ορθα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 23:17",
      "text": "Ας μη ζηλευη η καρδια σου τους αμαρτωλους αλλ' εσο εν τω φοβω του Κυριου ολην την ημεραν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 23:18",
      "text": "διοτι βεβαιως ειναι αμοιβη, και η ελπις σου δεν θελει εκκοπη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 23:19",
      "text": "Ακουε συ, υιε μου, και γινου σοφος, και κατευθυνε την καρδιαν σου εις την οδον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 23:20",
      "text": "Μη εσο μεταξυ οινοποτων, μεταξυ κρεοφαγων ασωτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 23:21",
      "text": "διοτι ο μεθυσος και ο ασωτος θελουσι πτωχευσει και ο υπνωδης θελει ενδυθη ρακη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 23:22",
      "text": "Υπακουε εις τον πατερα σου, οστις σε εγεννησε και μη καταφρονει την μητερα σου, οταν γηραση.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 23:23",
      "text": "Αγοραζε την αληθειαν και μη πωλει την σοφιαν και την παιδειαν και την συνεσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 23:24",
      "text": "Ο πατηρ του δικαιου θελει χαρη σφοδρα και οστις γεννα σοφον υιον, θελει ευφραινεσθαι εις αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 23:25",
      "text": "Ο πατηρ σου και η μητηρ σου θελουσιν ευφραινεσθαι μαλιστα εκεινη, ητις σε εγεννησε, θελει χαιρει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 23:26",
      "text": "Υιε μου, δος την καρδιαν σου εις εμε, και ας προσεχωσιν οι οφθαλμοι σου εις τας οδους μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 23:27",
      "text": "διοτι η πορνη ειναι λακκος βαθυς και η αλλοτρια γυνη στενον φρεαρ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 23:28",
      "text": "Αυτη προσετι ενεδρευει ως ληστης και πληθυνει τους παραβατας μεταξυ των ανθρωπων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.29",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 23:29",
      "text": "Εις τινα ειναι ουαι; εις τινα στεναγμοι; εις τινα εριδες; εις τινα ματαιολογιαι; εις τινα κτυπηματα ανευ αιτιας; εις τινα φλογωσις οφθαλμων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.30",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 23:30",
      "text": "Εις τους εγχρονιζοντας εν τω οινω εις εκεινους οιτινες διαγουσιν ανιχνευοντες οινοποσιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.31",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 23:31",
      "text": "Μη θεωρει τον οινον οτι κοκκινιζει, οτι διδει το χρωμα αυτου εις το ποτηριον, οτι καταβαινει ευαρεστως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.32",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 23:32",
      "text": "Εν τω τελει αυτου δακνει ως οφις και κεντρονει ως βασιλισκος",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.33",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 23:33",
      "text": "Οι οφθαλμοι σου θελουσι κυτταξει αλλοτριας γυναικας, και η καρδια σου θελει λαλησει αισχρα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.34",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 23:34",
      "text": "και θελεις εισθαι ως κοιμωμενος εν μεσω θαλασσης, και ως κοιτωμενος επι κορυφης, καταρτιου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.23.35",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 23:35",
      "text": "με ετυπτον, θελεις ειπει, και δεν επονεσα με εδειραν, και δεν ησθανθην ποτε θελω εγερθη, δια να υπαγω να ζητησω αυτον παλιν;",
      "paragraphStart": false
    }
  ]
}
