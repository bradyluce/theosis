{
  "chapter": {
    "id": "lxx-greek:proverbs.20",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 20,
    "referenceLabel": "Proverbs 20",
    "summary": "Source text for Proverbs 20 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.20.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 20:1",
      "text": "Ο οινος ειναι χλευαστης, και τα σικερα στασιαστικα και οστις δελεαζεται υπο τουτων, δεν ειναι φρονιμος.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.20.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 20:2",
      "text": "Απειλη βασιλεως ειναι βρυχηθμος λεοντος οστις παροξυνει αυτον, αμαρτανει εις την ιδιαν αυτου ζωην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 20:3",
      "text": "Τιμη ειναι εις τον ανθρωπον να παυη απο της εριδος πας δε αφρων εμπλεκεται εις ταυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 20:4",
      "text": "Ο οκνηρος δεν θελει να αροτρια εξ αιτιας του χειμωνος δια τουτο θελει ζητει εν τω θερει και δεν θελει λαμβανει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 20:5",
      "text": "Η βουλη εν τη καρδια του ανθρωπου ειναι ως υδατα βαθεα αλλ' ο συνετος ανθρωπος θελει ανασυρει αυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 20:6",
      "text": "Πολλοι ανθρωποι κηρυττουσιν εκαστος την καλοκαγαθιαν αυτου αλλα τις θελει ευρη ανθρωπον πιστον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 20:7",
      "text": "Ο δικαιος περιπατει εν τη ακεραιοτητι αυτου και τα τεκνα αυτου ειναι μακαρια μετ' αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 20:8",
      "text": "Βασιλευς, καθημενος επι θρονου κρισεως, διασκεδαζει παν κακον δια των οφθαλμων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 20:9",
      "text": "Τις δυναται να ειπη, Εκαθαρισα την καρδιαν μου, ειμαι καθαρος απο των αμαρτιων μου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 20:10",
      "text": "Ζυγια διαφορα, μετρα διαφορα, ειναι αμφοτερα βδελυγμα εις τον Κυριον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 20:11",
      "text": "Γνωριζεται και αυτο το παιδιον εκ των πραξεων αυτου, αν τα εργα αυτου ειναι καθαρα, και αν ευθεα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 20:12",
      "text": "Το ωτιον ακουει και ο οφθαλμος βλεπει αλλ' ο Κυριος εκαμεν αμφοτερα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 20:13",
      "text": "Μη αγαπα τον υπνον, δια να μη ελθης εις πτωχειαν ανοιξον τους οφθαλμους σου και θελεις χορτασθη αρτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 20:14",
      "text": "Κακον, κακον, λεγει ο αγοραστης αλλ' αφου αναχωρηση, τοτε καυχαται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 20:15",
      "text": "Υπαρχει χρυσιον και πληθος μαργαριτων τα χειλη ομως της γνωσεως ειναι το πολυτιμου κειμηλιον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 20:16",
      "text": "Λαβε το ιματιον του εγγυωμενου δια ξενον και λαβε ενεχυρον απ' αυτου, εγγυωμενου περι ξενων πραγματων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 20:17",
      "text": "Ο αρτος του ψευδους ειναι γλυκυς εις τον ανθρωπον μετα ταυτα ομως το στομα αυτου θελει γεμισθη χαλικων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 20:18",
      "text": "Οι σκοποι στερεονονται δια της συμβουλης και μετα καλην σκεψιν καμνε πολεμον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 20:19",
      "text": "Ο σπερμολογος περιερχομενος αποκαλυπτει τα μυστικα δια τουτο μη σμιγου μετα του πλατυνοντος τα χειλη αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 20:20",
      "text": "Ο λυχνος του κακολογουντος τον πατερα αυτου η την μητερα αυτου θελει σβεσθη εν βαθει σκοτει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 20:21",
      "text": "Κληρονομια αποκτηθεισα ταχεως την αρχην, εις το τελος δεν ευλογειται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 20:22",
      "text": "Μη ειπης, Θελω ανταποδωσει κακον αναμενε τον Κυριον και θελει σε σωσει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 20:23",
      "text": "Ζυγια διαφορα ειναι βδελυγμα εις τον Κυριον και η δολια πλαστιγξ δεν ειναι καλον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 20:24",
      "text": "Τα διαβηματα του ανθρωπου διευθυνονται υπο του Κυριου πως λοιπον ο ανθρωπος ηθελε γνωρισει την εαυτου οδον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 20:25",
      "text": "Παγις ειναι εις τον ανθρωπον, προπετως να λαλη περι ιερων και μετα τας ευχας να σκεπτηται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 20:26",
      "text": "Ο σοφος βασιλευς λικμιζει τους ασεβεις και στρεφει τον τροχον επ' αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 20:27",
      "text": "Λυχνος του Κυριου ειναι το πνευμα του ανθρωπου, το οποιον διερευνα παντα τα ενδομυχα της καρδιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.28",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 20:28",
      "text": "Ελεος και αληθεια διαφυλαττουσι τον βασιλεα και ο θρονος αυτου υποστηριζεται υπο του ελεους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.29",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 20:29",
      "text": "Καυχημα των νεων ειναι η δυναμις αυτων και δοξα των γεροντων η πολια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.20.30",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 20:30",
      "text": "Τα μελανισματα των πληγων λευκαινουσι τον κακον και τα κτυπηματα τα ενδομυχα της καρδιας.",
      "paragraphStart": false
    }
  ]
}
