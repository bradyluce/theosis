{
  "chapter": {
    "id": "lxx-greek:proverbs.29",
    "translationId": "lxx-greek",
    "bookSlug": "proverbs",
    "chapterNumber": 29,
    "referenceLabel": "Proverbs 29",
    "summary": "Source text for Proverbs 29 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:proverbs.29.1",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 29:1",
      "text": "Ανθρωπος οστις ελεγχομενος σκληρυνει τον τραχηλον, εξαιφνης θελει αφανισθη και χωρις ιασεως.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:proverbs.29.2",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 29:2",
      "text": "Οταν οι δικαιοι μεγαλυνθωσιν, ο λαος ευφραινεται αλλ' οταν ο ασεβης εξουσιαζη, στεναζει ο λαος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.3",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 29:3",
      "text": "Οστις αγαπα την σοφιαν, ευφραινει τον πατερα αυτου αλλ' οστις συναναστρεφεται με πορνας, φθειρει την περιουσιαν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.4",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 29:4",
      "text": "Ο βασιλευς δια της δικαιοσυνης στερεονει τον τοπον αλλ' ο δωροληπτης καταστρεφει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.5",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 29:5",
      "text": "Ο ανθρωπος οστις κολακευει τον πλησιον αυτου, εκτεινει δικτυον εμπροσθεν των βηματων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.6",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 29:6",
      "text": "Ο κακος ανθρωπος παγιδευεται εν τη ανομια αλλ' ο δικαιος ψαλλει και ευφραινεται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.7",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 29:7",
      "text": "Ο δικαιος λαμβανει γνωσιν της κρισεως των πενητων ο ασεβης δεν νοει γνωσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.8",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 29:8",
      "text": "Οι χλευασται ανθρωποι καταφλεγουσι την πολιν αλλ' οι σοφοι αποστρεφουσι την οργην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.9",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 29:9",
      "text": "Ο σοφος ανθρωπος, διαφερομενος μετα του αφρονος ανθρωπου, ειτε οργιζεται, ειτε γελα, δεν ευρισκει αναπαυσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.10",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 29:10",
      "text": "Οι ανδρες των αιματων μισουσι τον αμεμπτον αλλ' οι ευθεις εκζητουσι την ζωην αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.11",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 29:11",
      "text": "Ο αφρων εκθετει ολην αυτου την ψυχην ο δε σοφος αναχαιτιζει αυτην εις τα οπισω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.12",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 29:12",
      "text": "Εαν ο διοικητης προσεχη εις λογους ψευδεις, παντες οι υπηρεται αυτου γινονται ασεβεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.13",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 29:13",
      "text": "Πενης και δανειστης συναπαντωνται ο Κυριος φωτιζει αμφοτερων τους οφθαλμους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.14",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 29:14",
      "text": "Βασιλεως κρινοντος τους πτωχους εν αληθεια, ο θρονος αυτου θελει στερεωθη διαπαντος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.15",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 29:15",
      "text": "Η ραβδος και ο ελεγχος διδουσι σοφιαν παιδιον δε απολελυμενον καταισχυνει την μητερα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.16",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 29:16",
      "text": "Οταν οι ασεβεις πληθυνωνται, η ανομια περισσευει αλλ' οι δικαιοι θελουσιν ιδει την πτωσιν αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.17",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 29:17",
      "text": "Παιδευε τον υιον σου και θελει φερει αναπαυσιν εις σε και θελει φερει ηδονην εις την ψυχην σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.18",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 29:18",
      "text": "Οπου δεν υπαρχει ορασις, ο λαος διαφθειρεται ειναι δε μακαριος ο φυλαττων τον νομον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.19",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 29:19",
      "text": "Ο δουλος δια λογων δεν θελει διορθωθη επειδη καταλαμβανει μεν, αλλα δεν υπακουει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.20",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 29:20",
      "text": "Ειδες ανθρωπον ταχυν εις τους λογους αυτου; περισσοτερα ελπις ειναι εκ του αφρονος παρα εξ αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.21",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 29:21",
      "text": "Εαν τις ανατρεφη παιδιοθεν τον δουλον αυτου τρυφηλως, τελος παντων θελει κατασταθη υιος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.22",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 29:22",
      "text": "Ο θυμωδης ανθρωπος εξαπτει εριδα, και ο οργιλος ανθρωπος πληθυνει ανομιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.23",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 29:23",
      "text": "Η υπερηφανια του ανθρωπου θελει ταπεινωσει αυτον ο δε ταπεινοφρων απολαμβανει τιμην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.24",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 29:24",
      "text": "Ο συμμεριστης του κλεπτου μισει την εαυτου ψυχην ακουει τον ορκον και δεν ομολογει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.25",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 29:25",
      "text": "Ο φοβος του ανθρωπου στηνει παγιδα ο δε πεποιθως επι Κυριον θελει εισθαι εν ασφαλεια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.26",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 29:26",
      "text": "Πολλοι ζητουσι το προσωπον του ηγεμονος αλλ' η του ανθρωπου κρισις ειναι παρα Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:proverbs.29.27",
      "translationId": "lxx-greek",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 29:27",
      "text": "Ο αδικος ανθρωπος ειναι βδελυγμα εις τους δικαιους και ο ευθυς εις την οδον αυτου, βδελυγμα εις τους ασεβεις.",
      "paragraphStart": false
    }
  ]
}
