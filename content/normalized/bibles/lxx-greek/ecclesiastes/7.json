{
  "chapter": {
    "id": "lxx-greek:ecclesiastes.7",
    "translationId": "lxx-greek",
    "bookSlug": "ecclesiastes",
    "chapterNumber": 7,
    "referenceLabel": "Ecclesiastes 7",
    "summary": "Source text for Ecclesiastes 7 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:ecclesiastes.7.1",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Ecclesiastes 7:1",
      "text": "Καλλιον ονομα καλον παρα πολυτιμον μυρον και η ημερα του θανατου παρα την ημεραν της γεννησεως.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:ecclesiastes.7.2",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Ecclesiastes 7:2",
      "text": "Καλλιον να υπαγη τις εις οικον πενθους, παρα να υπαγη εις οικον συμποσιου διοτι τουτο ειναι το τελος παντος ανθρωπου, και ο ζων θελει βαλει αυτο εις την καρδιαν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.3",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Ecclesiastes 7:3",
      "text": "Καλλιον η λυπη παρα τον γελωτα διοτι εκ της σκυθρωποτητος του προσωπου η καρδια γινεται φαιδροτερα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.4",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Ecclesiastes 7:4",
      "text": "Η καρδια των σοφων ειναι εν οικω πενθους αλλ' η καρδια των αφρονων εν οικω ευφροσυνης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.5",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Ecclesiastes 7:5",
      "text": "Καλλιον εις τον ανθρωπον να ακουη επιπληξιν σοφου, παρα να ακουη ασμα αφρονων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.6",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Ecclesiastes 7:6",
      "text": "διοτι καθως ειναι ο ηχος των ακανθων υποκατω του λεβητος, ουτως ο γελως του αφρονος και τουτο ματαιοτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.7",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Ecclesiastes 7:7",
      "text": "Βεβαιως η καταδυναστεια παραλογιζει τον σοφον και το δωρον διαφθειρει την καρδιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.8",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Ecclesiastes 7:8",
      "text": "Καλλιον το τελος του πραγματος παρα την αρχην αυτου καλητερος ο μακροθυμος παρα τον υψηλοφρονα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.9",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Ecclesiastes 7:9",
      "text": "Μη σπευδε εν τω πνευματι σου να θυμονης διοτι ο θυμος αναπαυεται εν τω κολπω των αφρονων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.10",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Ecclesiastes 7:10",
      "text": "Μη ειπης, Τις η αιτια, δια την οποιαν αι παρελθουσαι ημεραι ησαν καλητεραι παρα ταυτας; διοτι δεν ερωτας φρονιμως περι τουτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.11",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Ecclesiastes 7:11",
      "text": "Η σοφια ειναι καλη ως η κληρονομια, και ωφελιμος εις τους βλεποντας τον ηλιον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.12",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Ecclesiastes 7:12",
      "text": "Διοτι η σοφια ειναι σκεπη, ως ειναι σκεπη το αργυριον πλην η υπεροχη της γνωσεως ειναι, οτι η σοφια ζωοποιει τους εχοντας αυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.13",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Ecclesiastes 7:13",
      "text": "Θεωρει το εργον του Θεου διοτι τις δυναται να καμη ευθες εκεινο, το οποιον αυτος εκαμε στρεβλον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.14",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Ecclesiastes 7:14",
      "text": "Εν ημερα ευτυχιας ευφραινου, εν δε ημερα δυστυχιας σκεπτου διοτι ο Θεος εκαμε το εν αντιστιχον του αλλου, δια να μη ευρισκη ο ανθρωπος μηδεν οπισω αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.15",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Ecclesiastes 7:15",
      "text": "Τα παντα ειδον εν ταις ημεραις της ματαιοτητος μου υπαρχει δικαιος, οστις αφανιζεται εν τη δικαιοσυνη αυτου και υπαρχει ασεβης, οστις μακροημερευει εν τη κακια αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.16",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Ecclesiastes 7:16",
      "text": "Μη γινου δικαιος παραπολυ, και μη φρονει σεαυτον υπερμετρα σοφον δια τι να αφανισθης;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.17",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Ecclesiastes 7:17",
      "text": "Μη γινου κακος παραπολυ, και μη εσο αφρων δια τι να αποθανης προ του καιρου σου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.18",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Ecclesiastes 7:18",
      "text": "Ειναι καλον να κρατης τουτο, απο δε εκεινου να μη αποσυρης την χειρα σου διοτι ο φοβουμενος τον Θεον θελει εκφυγει παντα ταυτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.19",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Ecclesiastes 7:19",
      "text": "Η σοφια ενδυναμονει τον σοφον περισσοτερον παρα δεκα εξουσιαζοντες, οιτινες ειναι εν τη πολει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.20",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Ecclesiastes 7:20",
      "text": "Διοτι δεν υπαρχει ανθρωπος δικαιος επι της γης, οστις να πραττη το καλον και να μη αμαρτανη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.21",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Ecclesiastes 7:21",
      "text": "Προσετι, μη δωσης την προσοχην σου εις παντας τους λογους οσοι λεγονται μηποτε ακουσης τον δουλον σου καταρωμενον σε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.22",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Ecclesiastes 7:22",
      "text": "διοτι πολλακις και η καρδια σου γνωριζει οτι και συ παρομοιως κατηρασθης αλλους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.23",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Ecclesiastes 7:23",
      "text": "Παντα ταυτα εδοκιμασα δια της σοφιας ειπα, Θελω γεινει σοφος αλλ' αυτη απεμακρυνθη απ' εμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.24",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Ecclesiastes 7:24",
      "text": "Ο, τι ειναι πολυ μακραν και εις ακρον βαρυ, τις δυναται να ευρη τουτο;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.25",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Ecclesiastes 7:25",
      "text": "Εγω περιηλθον εν τη καρδια μου δια να μαθω και να ανιχνευσω, και να εκζητησω σοφιαν και τον λογον των πραγματων, και να γνωρισω την ασεβειαν της αφροσυνης και την ηλιθιοτητα της ανοησιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.26",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "Ecclesiastes 7:26",
      "text": "Και ευρον οτι πικροτερα ειναι παρα θανατον η γυνη, της οποιας η καρδια ειναι παγιδες και δικτυα και αι χειρες αυτης δεσμα ο αρεστος ενωπιον του Θεου θελει εκφυγει απ' αυτης ο δε αμαρτωλος θελει συλληφθη εν αυτη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.27",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "Ecclesiastes 7:27",
      "text": "Ιδε, τουτο ευρηκα, λεγει ο Εκκλησιαστης, εξεταζων εν προς εν, δια να ευρω τον λογον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.28",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "Ecclesiastes 7:28",
      "text": "τον οποιον ετι η ψυχη μου εκζητει αλλα δεν ευρισκω ανδρα ενα μεταξυ χιλιων ευρηκα γυναικα ομως μιαν μεταξυ πασων τουτων δεν ευρηκα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.7.29",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "Ecclesiastes 7:29",
      "text": "Ιδου, τουτο μονον ευρηκα οτι ο Θεος εκαμε τον ανθρωπον ευθυν, αλλ' αυτοι επεζητησαν λογισμους πολλους.",
      "paragraphStart": false
    }
  ]
}
