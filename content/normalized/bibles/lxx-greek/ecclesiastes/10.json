{
  "chapter": {
    "id": "lxx-greek:ecclesiastes.10",
    "translationId": "lxx-greek",
    "bookSlug": "ecclesiastes",
    "chapterNumber": 10,
    "referenceLabel": "Ecclesiastes 10",
    "summary": "Source text for Ecclesiastes 10 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:ecclesiastes.10.1",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Ecclesiastes 10:1",
      "text": "Μυιαι αποθνησκουσαι καμνουσι το μυρον του μυρεψου να βρωμα, να αναβραζη και μικρα αφροσυνη ατιμαζει τον εν υποληψει επι σοφια και τιμη.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:ecclesiastes.10.2",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Ecclesiastes 10:2",
      "text": "Η καρδια του σοφου ειναι εν τη δεξια αυτου η δε καρδια του αφρονος εν τη αριστερα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.10.3",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Ecclesiastes 10:3",
      "text": "Και ετι οταν ο αφρων περιπατη εν τη οδω, λειπει συνεσις αυτου και αναγγελλει προς παντας οτι ειναι αφρων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.10.4",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Ecclesiastes 10:4",
      "text": "Εαν το πνευμα του ηγεμονος εγερθη εναντιον σου, μη αφησης τον τοπον σου διοτι η γλυκυτης καταπαυει αμαρτιας μεγαλας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.10.5",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Ecclesiastes 10:5",
      "text": "Ειναι κακον το οποιον ειδον υπο τον ηλιον, λαθος, λεγω, προερχομενον απο του εξουσιαστου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.10.6",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Ecclesiastes 10:6",
      "text": "οτι ο αφρων βαλλεται εις μεγαλας αξιας, οι δε πλουσιοι καθηνται εν ταπεινω τοπω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.10.7",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Ecclesiastes 10:7",
      "text": "Ειδον δουλους εφ' ιππων και αρχοντας περιπατουντας ως δουλους επι της γης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.10.8",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Ecclesiastes 10:8",
      "text": "Οστις σκαπτει λακκον, θελει πεσει εις αυτον και οστις χαλα φραγμον, οφις θελει δαγκασει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.10.9",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Ecclesiastes 10:9",
      "text": "Ο μετακινων λιθους θελει βλαφθη υπ' αυτων ο σχιζων ξυλα θελει κινδυνευσει εν αυτοις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.10.10",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Ecclesiastes 10:10",
      "text": "Εαν ο σιδηρος αμβλυνθη και δεν ακονιση τις την κοψιν αυτου, πρεπει να προσθεση δυναμιν η σοφια δε ειναι ωφελιμος προς διευθυνσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.10.11",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Ecclesiastes 10:11",
      "text": "Εαν ο οφις δαγκανη χωρις συριγμου, πλην και ο συκοφαντης καλητερος δεν ειναι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.10.12",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Ecclesiastes 10:12",
      "text": "Οι λογοι του στοματος του σοφου ειναι χαρις τα δε χειλη του αφρονος θελουσι καταπιει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.10.13",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Ecclesiastes 10:13",
      "text": "Η αρχη των λογων του στοματος αυτου ειναι αφροσυνη και το τελος της ομιλιας αυτου κακη μωρια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.10.14",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Ecclesiastes 10:14",
      "text": "Ο αφρων προσετι πληθυνει λογους, ενω ο ανθρωπος δεν εξευρει τι μελλει γενεσθαι και τις δυναται να απαγγειλη προς αυτον τι θελει εισθαι μετ' αυτον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.10.15",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Ecclesiastes 10:15",
      "text": "Ο μοχθος των αφρονων απαυδιζει αυτους, επειδη δεν εξευρουσι να υπαγωσιν εις την πολιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.10.16",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Ecclesiastes 10:16",
      "text": "Ουαι εις σε, γη, της οποιας ο βασιλευς ειναι νεος, και οι αρχοντες σου τρωγουσι το πρωι",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.10.17",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Ecclesiastes 10:17",
      "text": "Μακαρια συ, γη, της οποιας ο βασιλευς ειναι υιος ευγενων, και οι αρχοντες σου τρωγουσιν εν καιρω προς ενισχυσιν και ουχι προς μεθην",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.10.18",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Ecclesiastes 10:18",
      "text": "Δια την πολλην οκνηριαν πιπτει η στεγασις και δια την αργιαν των χειρων σταλαζει η οικια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.10.19",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Ecclesiastes 10:19",
      "text": "Δι' ευθυμιαν καμνουσι συμποσια, και ο οινος ευφραινει τους ζωντας το δε αργυριον αποκρινεται εις παντα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ecclesiastes.10.20",
      "translationId": "lxx-greek",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Ecclesiastes 10:20",
      "text": "Μη καταρασθης τον βασιλεα μηδε εν τη διανοια σου και μη καταρασθης τον πλουσιον εν τω ταμειω του κοιτωνος σου διοτι πτηνον του ουρανου θελει φερει την φωνην, και το εχον τας πτερυγας θελει αναγγειλει το πραγμα.",
      "paragraphStart": false
    }
  ]
}
