{
  "chapter": {
    "id": "lxx-greek:numbers.34",
    "translationId": "lxx-greek",
    "bookSlug": "numbers",
    "chapterNumber": 34,
    "referenceLabel": "Numbers 34",
    "summary": "Source text for Numbers 34 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:numbers.34.1",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 1,
      "referenceLabel": "Numbers 34:1",
      "text": "Και ελαλησε Κυριος προς τον Μωυσην, λεγων,",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:numbers.34.2",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 2,
      "referenceLabel": "Numbers 34:2",
      "text": "Προσταξον τους υιους Ισραηλ και ειπε προς αυτους, Οταν εισελθητε εις την γην Χανααν, την γην εκεινην ητις θελει σας πεσει εις κληρονομιαν, την γην Χανααν μετα των οριων αυτης,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.3",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 3,
      "referenceLabel": "Numbers 34:3",
      "text": "τοτε το μερος σας το προς μεσημβριαν θελει εισθαι απο της ερημου Σιν εως πλησιον Εδωμ και τα μεσημβρινα ορια σας θελουσιν εισθαι απο του ακρου της αλμυρας θαλασσης προς ανατολας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.4",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 4,
      "referenceLabel": "Numbers 34:4",
      "text": "και το οριον σας θελει στρεφει απο μεσημβριας προς την αναβασιν Ακραββιμ, και θελει διερχεσθαι εις Σιν και θελει προχωρει απο του μεσημβρινου μερους εως Καδης-βαρνη, και θελει εκβαινει εις Ασαρ-αδδαρ, και θελει διαβαινει εως Ασμων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.5",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 5,
      "referenceLabel": "Numbers 34:5",
      "text": "και θελει στρεφεσθαι το οριον απο Ασμων εως του χειμαρρου της Αιγυπτου, και θελει καταντησει εις την θαλασσαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.6",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 6,
      "referenceLabel": "Numbers 34:6",
      "text": "Δυτικον δε οριον θελετε εχει την θαλασσαν την μεγαλην αυτη θελει εισθαι το δυτικον οριον σας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.7",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 7,
      "referenceLabel": "Numbers 34:7",
      "text": "Και ταυτα θελουσιν εισθαι τα αρκτικα ορια σας απο της μεγαλης θαλασσης θελετε θεσει οριον σας το ορος Ωρ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.8",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 8,
      "referenceLabel": "Numbers 34:8",
      "text": "απο του ορους Ωρ θελετε θεσει οριον σας εως της εισοδου Αιμαθ, και θελει προχωρει το οριον εις Σεδαδ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.9",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 9,
      "referenceLabel": "Numbers 34:9",
      "text": "και θελει προχωρει το οριον εις Ζιφρων, και θελει καταντησει εις Ασαρ-εναν τουτο θελει εισθαι το αρκτικον οριον σας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.10",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 10,
      "referenceLabel": "Numbers 34:10",
      "text": "Και θελετε θεσει τα ανατολικα ορια σας απο Ασαρ-εναν εως Σεπφαμ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.11",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 11,
      "referenceLabel": "Numbers 34:11",
      "text": "και θελει καταβαινει το οριον απο Σεπφαμ εως Ριβλα, προς ανατολας του Αειν και θελει καταβαινει το οριον και θελει φθανει εις το πλαγιον της θαλασσης Χιννερωθ προς ανατολας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.12",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 12,
      "referenceLabel": "Numbers 34:12",
      "text": "και θελει καταβαινει το οριον προς τον Ιορδανην και θελει καταντησει εις την αλμυραν θαλασσαν. Αυτη ειναι η γη σας κατα τα ορια αυτης κυκλω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.13",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 13,
      "referenceLabel": "Numbers 34:13",
      "text": "Και προσεταξεν ο Μωυσης τους υιους Ισραηλ λεγων, Αυτη ειναι η γη, την οποιαν θελετε κληρονομησει δια κληρων, την οποιαν ο Κυριος προσεταξε να δοθη εις τας εννεα φυλας και εις το ημισυ της φυλης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.14",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 14,
      "referenceLabel": "Numbers 34:14",
      "text": "Διοτι η φυλη των υιων Ρουβην κατα τον οικον των πατερων αυτων και η φυλη των υιων Γαδ κατα τον οικον των πατερων αυτων, ελαβον την κληρονομιαν αυτων και το ημισυ της φυλης του Μανασση ελαβε την κληρονομιαν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.15",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 15,
      "referenceLabel": "Numbers 34:15",
      "text": "Αι δυο φυλαι και το ημισυ της φυλης ελαβον την κληρονομιαν αυτων εντευθεν του Ιορδανου κατεναντι της Ιεριχω, προς ανατολας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.16",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 16,
      "referenceLabel": "Numbers 34:16",
      "text": "Και ελαλησε Κυριος προς τον Μωυσην, λεγων,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.17",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 17,
      "referenceLabel": "Numbers 34:17",
      "text": "Ταυτα ειναι τα ονοματα των ανδρων, οιτινες θελουσι κληροδοτησει εις εσας την γην Ελεαζαρ ο ιερευς και Ιησους ο υιος του Ναυη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.18",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 18,
      "referenceLabel": "Numbers 34:18",
      "text": "και θελετε λαβει ανα ενα αρχοντα αφ' εκαστης φυλης, δια να κληροδοτησωσι την γην",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.19",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 19,
      "referenceLabel": "Numbers 34:19",
      "text": "και ταυτα ειναι τα ονοματα των ανδρων Εκ της φυλης Ιουδα, Χαλεβ ο υιος του Ιεφοννη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.20",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 20,
      "referenceLabel": "Numbers 34:20",
      "text": "και εκ της φυλης των υιων Συμεων, Σαμουηλ ο υιος του Αμμιουδ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.21",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 21,
      "referenceLabel": "Numbers 34:21",
      "text": "εκ της φυλης Βενιαμιν, Ελιδαδ ο υιος του Χισλων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.22",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 22,
      "referenceLabel": "Numbers 34:22",
      "text": "και εκ της φυλης των υιων Δαν, ο αρχων Βουκκι ο υιος του Ιογλι",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.23",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 23,
      "referenceLabel": "Numbers 34:23",
      "text": "εκ των υιων Ιωσηφ, εκ της φυλης των υιων Μανασση, ο αρχων Ανιηλ ο υιος του Εφωδ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.24",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 24,
      "referenceLabel": "Numbers 34:24",
      "text": "και εκ της φυλης των υιων Εφραιμ, ο αρχων Κεμουηλ ο υιος του Σιφταν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.25",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 25,
      "referenceLabel": "Numbers 34:25",
      "text": "και εκ της φυλης των υιων Ζαβουλων, ο αρχων Ελισαφαν ο υιος του Φαρναχ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.26",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 26,
      "referenceLabel": "Numbers 34:26",
      "text": "και εκ της φυλης των υιων Ισσαχαρ, ο αρχων Φαλτιηλ ο υιος του Αζαν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.27",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 27,
      "referenceLabel": "Numbers 34:27",
      "text": "και εκ της φυλης των υιων Ασηρ, ο αρχων Αχιουδ ο υιος του Σελωμι",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.28",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 28,
      "referenceLabel": "Numbers 34:28",
      "text": "και εκ της φυλης των υιων Νεφθαλι, ο αρχων Φεδαηλ ο υιος του Αμμιουδ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.34.29",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 29,
      "referenceLabel": "Numbers 34:29",
      "text": "Ουτοι ειναι, τους οποιους προσεταξεν ο Κυριος να κληροδοτησωσιν εις τους υιους Ισραηλ εν τη γη Χανααν.",
      "paragraphStart": false
    }
  ]
}
