{
  "chapter": {
    "id": "lxx-greek:numbers.33",
    "translationId": "lxx-greek",
    "bookSlug": "numbers",
    "chapterNumber": 33,
    "referenceLabel": "Numbers 33",
    "summary": "Source text for Numbers 33 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:numbers.33.1",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 1,
      "referenceLabel": "Numbers 33:1",
      "text": "Αυται ειναι αι οδοιποριαι των υιων Ισραηλ, των εξελθοντων εκ της γης Αιγυπτου κατα τα στρατευματα αυτων δια χειρος του Μωυσεως και του Ααρων.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:numbers.33.2",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 2,
      "referenceLabel": "Numbers 33:2",
      "text": "Και εγραψεν ο Μωυσης τας εξοδους αυτων κατα τας οδοιποριας αυτων, δια προσταγης του Κυριου και αυται ειναι αι οδοιποριαι αυτων κατα τας εξοδους αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.3",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 3,
      "referenceLabel": "Numbers 33:3",
      "text": "Και εσηκωθησαν απο Ραμεσση τον πρωτον μηνα, τη δεκατη πεμπτη ημερα του πρωτου μηνος τη επαυριον του πασχα εξηλθον οι υιοι Ισραηλ εν χειρι υψηλη ενωπιον παντων των Αιγυπτιων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.4",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 4,
      "referenceLabel": "Numbers 33:4",
      "text": "ενω οι Αιγυπτιοι εθαπτον εκεινους, τους οποιους ο Κυριος επαταξε μεταξυ αυτων, παν πρωτοτοκον και εις τους θεους αυτων εκαμεν ο Κυριος εκδικησιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.5",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 5,
      "referenceLabel": "Numbers 33:5",
      "text": "Και σηκωθεντες οι υιοι Ισραηλ απο Ραμεσση, εστρατοπεδευσαν εν Σοκχωθ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.6",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 6,
      "referenceLabel": "Numbers 33:6",
      "text": "Και σηκωθεντες απο Σοκχωθ, εστρατοπεδευσαν εν Εθαμ, ητις ειναι εν τω ακρω της ερημου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.7",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 7,
      "referenceLabel": "Numbers 33:7",
      "text": "Και σηκωθεντες απο Εθαμ, εστρεψαν προς Πι-αιρωθ, ητις ειναι κατεναντι Βεελ-σεφων και εστρατοπεδευσαν κατεναντι της Μιγδωλ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.8",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 8,
      "referenceLabel": "Numbers 33:8",
      "text": "Και σηκωθεντες απ' εμπροσθεν της Αιρωθ, διεβησαν δια της θαλασσης εις την ερημον και ωδοιπορησαν οδον τριων ημερων δια της ερημου Εθαμ και εστρατοπεδευσαν εν Μερρα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.9",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 9,
      "referenceLabel": "Numbers 33:9",
      "text": "Και σηκωθεντες απο Μερρα, ηλθον εις Αιλειμ και ησαν εν Αιλειμ δωδεκα πηγαι υδατων και εβδομηκοντα δενδρα φοινικων και εστρατοπεδευσαν εκει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.10",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 10,
      "referenceLabel": "Numbers 33:10",
      "text": "Και σηκωθεντες απο Αιλειμ, εστρατοπεδευσαν παρα την Ερυθραν θαλασσαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.11",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 11,
      "referenceLabel": "Numbers 33:11",
      "text": "Και σηκωθεντες απο της Ερυθρας θαλασσης, εστρατοπεδευσαν εν τη ερημω Σιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.12",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 12,
      "referenceLabel": "Numbers 33:12",
      "text": "Και σηκωθεντες απο της ερημου Σιν, εστρατοπεδευσαν εν Δοφκα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.13",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 13,
      "referenceLabel": "Numbers 33:13",
      "text": "Και σηκωθεντες απο Δοφκα, εστρατοπεδευσαν εν Αιλους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.14",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 14,
      "referenceLabel": "Numbers 33:14",
      "text": "Και σηκωθεντες απο Αιλους, εστρατοπεδευσαν εν Ραφιδειν, οπου δεν ητο υδωρ δια να πιη ο λαος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.15",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 15,
      "referenceLabel": "Numbers 33:15",
      "text": "Και σηκωθεντες απο Ραφιδειν, εστρατοπεδευσαν εν τη ερημω Σινα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.16",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 16,
      "referenceLabel": "Numbers 33:16",
      "text": "Και σηκωθεντες απο της ερημου Σινα, εστρατοπεδευσαν εν Κιβρωθ-αττααβα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.17",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 17,
      "referenceLabel": "Numbers 33:17",
      "text": "Και σηκωθεντες απο Κιβρωθ-αττααβα, εστρατοπεδευσαν εν Ασηρωθ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.18",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 18,
      "referenceLabel": "Numbers 33:18",
      "text": "Και σηκωθεντες απο Ασηρωθ, εστρατοπεδευσαν εν Ριθμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.19",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 19,
      "referenceLabel": "Numbers 33:19",
      "text": "Και σηκωθεντες απο Ριθμα, εστρατοπεδευσαν εν Ριμμων-φαρες.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.20",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 20,
      "referenceLabel": "Numbers 33:20",
      "text": "Και σηκωθεντες απο Ριμμων-φαρες, εστρατοπεδευσαν εν Λιβνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.21",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 21,
      "referenceLabel": "Numbers 33:21",
      "text": "Και σηκωθεντες απο Λιβνα, εστρατοπεδευσαν εν Ρισσα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.22",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 22,
      "referenceLabel": "Numbers 33:22",
      "text": "Και σηκωθεντες απο Ρισσα, εστρατοπεδευσαν εν Κεελαθα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.23",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 23,
      "referenceLabel": "Numbers 33:23",
      "text": "Και σηκωθεντες απο Κεελαθα, εστρατοπεδευσαν εν τω ορει Σαφερ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.24",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 24,
      "referenceLabel": "Numbers 33:24",
      "text": "Και σηκωθεντες απο του ορους Σαφερ, εστρατοπεδευσαν εν Χαραδα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.25",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 25,
      "referenceLabel": "Numbers 33:25",
      "text": "Και σηκωθεντες απο Χαραδα, εστρατοπεδευσαν εν Μακηλωθ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.26",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 26,
      "referenceLabel": "Numbers 33:26",
      "text": "Και σηκωθεντες απο Μακηλωθ, εστρατοπεδευσαν εν Ταχαθ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.27",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 27,
      "referenceLabel": "Numbers 33:27",
      "text": "Και σηκωθεντες απο Ταχαθ, εστρατοπεδευσαν εν Θαρα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.28",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 28,
      "referenceLabel": "Numbers 33:28",
      "text": "Και σηκωθεντες απο Θαρα, εστρατοπεδευσαν εν Μιθκα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.29",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 29,
      "referenceLabel": "Numbers 33:29",
      "text": "Και σηκωθεντες απο Μιθκα, εστρατοπεδευσαν εν Ασεμωνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.30",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 30,
      "referenceLabel": "Numbers 33:30",
      "text": "Και σηκωθεντες απο Ασεμωνα, εστρατοπεδευσαν εν Μοσηρωθ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.31",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 31,
      "referenceLabel": "Numbers 33:31",
      "text": "Και σηκωθεντες απο Μοσηρωθ, εστρατοπεδευσαν εν Βενε-ιακαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.32",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 32,
      "referenceLabel": "Numbers 33:32",
      "text": "Και σηκωθεντες απο Βενε-ιακαν, εστρατοπεδευσαν εν τω ορει Γαδγαδ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.33",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 33,
      "referenceLabel": "Numbers 33:33",
      "text": "Και σηκωθεντες απο του ορους Γαδγαδ, εστρατοπεδευσαν εν Ιοτβαθα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.34",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 34,
      "referenceLabel": "Numbers 33:34",
      "text": "Και σηκωθεντες απο Ιοτβαθα, εστρατοπεδευσαν εν Εβρωνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.35",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 35,
      "referenceLabel": "Numbers 33:35",
      "text": "Και σηκωθεντες απο Εβρωνα, εστρατοπεδευσαν εν Εσιων-γαβερ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.36",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 36,
      "referenceLabel": "Numbers 33:36",
      "text": "Και σηκωθεντες απο Εσιων-γαβερ, εστρατοπεδευσαν εν τη ερημω Σιν, ητις ειναι η Καδης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.37",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 37,
      "referenceLabel": "Numbers 33:37",
      "text": "Και σηκωθεντες απο Καδης, εστρατοπεδευσαν εν τω ορει Ωρ, κατα το ακρον της γης Εδωμ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.38",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 38,
      "referenceLabel": "Numbers 33:38",
      "text": "Και ανεβη Ααρων ο ιερευς, δια προσταγης του Κυριου, εις το ορος Ωρ και απεθανεν εκει, το τεσσαρακοστον ετος της εξοδου των υιων Ισραηλ εκ γης Αιγυπτου, τον πεμπτον μηνα την πρωτην του μηνος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.39",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 39,
      "referenceLabel": "Numbers 33:39",
      "text": "Και ο Ααρων ητο εκατον εικοσιτριων ετων, οτε απεθανεν εν τω ορει Ωρ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.40",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 40,
      "referenceLabel": "Numbers 33:40",
      "text": "Και ηκουσεν ο Χαναναιος, βασιλευς της Αραδ, οστις κατωκει προς μεσημβριαν, εν γη Χανααν, την ελευσιν των υιων Ισραηλ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.41",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 41,
      "referenceLabel": "Numbers 33:41",
      "text": "Και σηκωθεντες απο του ορους Ωρ, εστρατοπεδευσαν εν Σαλμωνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.42",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 42,
      "referenceLabel": "Numbers 33:42",
      "text": "Και σηκωθεντες απο Σαλμωνα, εστρατοπεδευσαν εν Φυνων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.43",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 43,
      "referenceLabel": "Numbers 33:43",
      "text": "Και σηκωθεντες απο Φυνων, εστρατοπεδευσαν εν Ωβωθ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.44",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 44,
      "referenceLabel": "Numbers 33:44",
      "text": "Και σηκωθεντες απο Ωβωθ, εστρατοπεδευσαν εν Ιιε-αβαριμ, κατα τα ορια του Μωαβ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.45",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 45,
      "referenceLabel": "Numbers 33:45",
      "text": "Και σηκωθεντες απο Ιειμ, εστρατοπεδευσαν εν Δαιβων-γαδ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.46",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 46,
      "referenceLabel": "Numbers 33:46",
      "text": "Και σηκωθεντες απο Δαιβων-γαδ, εστρατοπεδευσαν εν Αλμων-διβλαθαιμ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.47",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 47,
      "referenceLabel": "Numbers 33:47",
      "text": "Και σηκωθεντες απο Αλμων-διβλαθαιμ, εστρατοπεδευσαν εις τα ορη Αβαριμ, κατεναντι Νεβω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.48",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 48,
      "referenceLabel": "Numbers 33:48",
      "text": "Και σηκωθεντες απο των ορεων Αβαριμ, εστρατοπεδευσαν εις τας πεδιαδας Μωαβ παρα τον Ιορδανην κατεναντι της Ιεριχω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.49",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 49,
      "referenceLabel": "Numbers 33:49",
      "text": "Και εστρατοπεδευσαν παρα τον Ιορδανην, απο Βαιθ-ιεσιμωθ εως Αβελ-σιττιμ, εις τας πεδιαδας Μωαβ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.50",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 50,
      "referenceLabel": "Numbers 33:50",
      "text": "Και ελαλησε Κυριος προς τον Μωυσην εις τας πεδιαδας Μωαβ παρα τον Ιορδανην κατεναντι της Ιεριχω, λεγων,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.51",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 51,
      "referenceLabel": "Numbers 33:51",
      "text": "Λαλησον προς τους υιους Ισραηλ και ειπε προς αυτους, Αφου διαβητε τον Ιορδανην προς την γην Χανααν,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.52",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 52,
      "referenceLabel": "Numbers 33:52",
      "text": "θελετε εκδιωξει παντας τους κατοικους της γης απ' εμπροσθεν σας και καταστρεψει πασας τας εικονας αυτων και καταστρεψει παντα τα χυτα ειδωλα αυτων και κατεδαφισει παντας τους βωμους αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.53",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 53,
      "referenceLabel": "Numbers 33:53",
      "text": "και θελετε κυριευσει την γην και κατοικησει εν αυτη διοτι εις εσας εδωκα την γην ταυτην εις κληρονομιαν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:numbers.33.54",
      "translationId": "lxx-greek",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 54,
      "referenceLabel": "Numbers 33:54",
