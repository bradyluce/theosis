{
  "chapter": {
    "id": "lxx-greek:lamentations.5",
    "translationId": "lxx-greek",
    "bookSlug": "lamentations",
    "chapterNumber": 5,
    "referenceLabel": "Lamentations 5",
    "summary": "Source text for Lamentations 5 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:lamentations.5.1",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Lamentations 5:1",
      "text": "Ενθυμηθητι, Κυριε, τι εγεινεν εις ημας επιβλεψον, και ιδε τον ονειδισμον ημων.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:lamentations.5.2",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Lamentations 5:2",
      "text": "Η κληρονομια ημων μετεστραφη εις αλλοτριους, αι οικιαι ημων εις ξενους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.3",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Lamentations 5:3",
      "text": "Εγειναμεν ορφανοι ανευ πατρος, αι μητερες ημων ως χηραι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.4",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Lamentations 5:4",
      "text": "Με αργυριον επιομεν το υδωρ ημων τα ξυλα ημων επωληθησαν εις ημας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.5",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Lamentations 5:5",
      "text": "Επι τον τραχηλον ημων ειναι διωγμος εμοχθησαμεν, αναπαυσιν δεν εχομεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.6",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Lamentations 5:6",
      "text": "Ηπλωσαμεν χειρα προς τους Αιγυπτιους, προς τους Ασσυριους, δια να χορτασθωμεν αρτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.7",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Lamentations 5:7",
      "text": "Οι πατερες ημων ημαρτησαν, εκεινοι δεν υπαρχουσι και ημεις φερομεν τας ανομιας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.8",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Lamentations 5:8",
      "text": "Δουλοι εξουσιαζουσιν εφ' ημας δεν υπαρχει ο λυτρονων εκ της χειρος αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.9",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Lamentations 5:9",
      "text": "Φερομεν τον αρτον ημων μετα κινδυνου της ζωης ημων, απ' εμπροσθεν της ρομφαιας της ερημου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.10",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Lamentations 5:10",
      "text": "Το δερμα ημων ημαυρωθη ως κλιβανος, απο της καυσεως της πεινης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.11",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Lamentations 5:11",
      "text": "Εταπεινωσαν τας γυναικας εν Σιων, τας παρθενους εν ταις πολεσιν Ιουδα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.12",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Lamentations 5:12",
      "text": "Οι αρχοντες εκρεμασθησαν υπο των χειρων αυτων τα προσωπα των πρεσβυτερων δεν ετιμηθησαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.13",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Lamentations 5:13",
      "text": "Οι νεοι υπεβληθησαν εις το αλεσμα, και τα παιδια επεσον υπο τα ξυλα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.14",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Lamentations 5:14",
      "text": "Οι πρεσβυτεροι επαυσαν απο των πυλων, οι νεοι απο των ασματων αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.15",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Lamentations 5:15",
      "text": "Επαυσεν η χαρα της καρδιας ημων, ο χορος ημων εστραφη εις πενθος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.16",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Lamentations 5:16",
      "text": "Ο στεφανος της κεφαλης ημων επεσεν ουαι δε εις ημας, διοτι ημαρτησαμεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.17",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Lamentations 5:17",
      "text": "Δια τουτο εξελιπεν η καρδια ημων, δια ταυτα εσκοτοδινιασαν οι οφθαλμοι ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.18",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Lamentations 5:18",
      "text": "Δια την ερημωσιν του ορους Σιων, αι αλωπεκες περιπατουσιν εν αυτω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.19",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Lamentations 5:19",
      "text": "Συ, Κυριε, κατοικεις εις τον αιωνα ο θρονος σου διαμενει εις γενεαν και γενεαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.20",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Lamentations 5:20",
      "text": "Δια τι θελεις μας λησμονησει δια παντος; θελεις μας εγκαταλειψει εις μακροτητα ημερων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.21",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Lamentations 5:21",
      "text": "Επιστρεψον ημας, Κυριε, προς σε και θελομεν επιστραφη. Ανανεωσον τας ημερας ημων ως το προτερον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.5.22",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Lamentations 5:22",
      "text": "Διατι απερριψας ημας ολοτελως, ωργισθης εναντιον ημων εως σφοδρα;",
      "paragraphStart": false
    }
  ]
}
