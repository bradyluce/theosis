{
  "chapter": {
    "id": "lxx-greek:lamentations.3",
    "translationId": "lxx-greek",
    "bookSlug": "lamentations",
    "chapterNumber": 3,
    "referenceLabel": "Lamentations 3",
    "summary": "Source text for Lamentations 3 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:lamentations.3.1",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Lamentations 3:1",
      "text": "Εγω ειμαι ο ανθρωπος, οστις ειδον θλιψιν απο της ραβδου του θυμου αυτου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:lamentations.3.2",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Lamentations 3:2",
      "text": "Με ωδηγησε και εφερεν εις σκοτος και ουχι εις φως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.3",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Lamentations 3:3",
      "text": "Ναι, κατ' εμου εστραφη κατ' εμου εστρεψε την χειρα αυτου ολην την ημεραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.4",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Lamentations 3:4",
      "text": "Επαλαιωσε την σαρκα μου και το δερμα μου συνετριψε τα οστα μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.5",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Lamentations 3:5",
      "text": "Ωικοδομησε κατ' εμου και με περιεκυκλωσε χολην και μοχθον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.6",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Lamentations 3:6",
      "text": "Με εκαθισεν εν σκοτεινοις ως νεκρους αιωνιους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.7",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Lamentations 3:7",
      "text": "Με περιεφραξε, δια να μη εξελθω εβαρυνε τας αλυσεις μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.8",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Lamentations 3:8",
      "text": "Ετι και οταν κραζω και αναβοω, αποκλειει την προσευχην μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.9",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Lamentations 3:9",
      "text": "Περιεφραξε με πελεκητους λιθους τας οδους μου, εστρεβλωσε τας τριβους μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.10",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Lamentations 3:10",
      "text": "Εγεινεν εις εμε αρκτος ενεδρευουσα, λεων εν αποκρυφοις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.11",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Lamentations 3:11",
      "text": "Παρετρεψε τας οδους μου και με κατεσπαραξε, με κατεστηαεν ηφανισμενην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.12",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Lamentations 3:12",
      "text": "Ενετεινε το τοξον αυτου και με εστησεν ως σκοπον εις βελος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.13",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Lamentations 3:13",
      "text": "Ενεπηξεν εις τα νεφρα μου τα βελη της φαρετρας αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.14",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Lamentations 3:14",
      "text": "Εγεινα γελως εις παντα τον λαον μου, ασμα αυτων ολην την ημεραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.15",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Lamentations 3:15",
      "text": "Με εχορτασε πικριαν με εμεθυσεν αψινθιον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.16",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Lamentations 3:16",
      "text": "Και συνετριψε τους οδοντας μου με χαλικας με εκαλυψε με σποδον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.17",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Lamentations 3:17",
      "text": "Και απεσπρωξα, απο ειρηνης την ψυχην μου ελησμονησα το αγαθον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.18",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Lamentations 3:18",
      "text": "Και ειπα, Απωλεσθη η δυναμις μου και η ελπις μου υπο του Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.19",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Lamentations 3:19",
      "text": "Ενθυμηθητι την θλιψιν μου και την εξωσιν μου, το αψινθιον και την χολην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.20",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Lamentations 3:20",
      "text": "Η ψυχη μου ενθυμειται ταυτα ακαταπαυστως και ειναι τεταπεινωμενη εν εμοι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.21",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Lamentations 3:21",
      "text": "Τουτο ανακαλω εις την καρδιαν μου, οθεν εχω ελπιδα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.22",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Lamentations 3:22",
      "text": "Ελεος του Κυριου ειναι, οτι δεν συνετελεσθημεν, επειδη δεν εξελιπον οι οικτιρμοι αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.23",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Lamentations 3:23",
      "text": "Ανανεονονται εν ταις πρωιαις μεγαλη ειναι η πιστοτης σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.24",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Lamentations 3:24",
      "text": "Ο Κυριος ειναι η μερις μου, ειπεν η ψυχη μου δια τουτο θελω ελπιζει επ' αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.25",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Lamentations 3:25",
      "text": "Αγαθος ο Κυριος εις τους προσμενοντας αυτον, εις την ψυχην την εκζητουσαν αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.26",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Lamentations 3:26",
      "text": "Καλον ειναι και να ελπιζη τις και να εφησυχαζη εις την σωτηριαν του Κυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.27",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Lamentations 3:27",
      "text": "Καλον εις τον ανθρωπον να βασταζη ζυγον εν τη νεοτητι αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.28",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Lamentations 3:28",
      "text": "Θελει καθησθαι κατα μονας και σιωπα, επειδη ο Θεος επεβαλε φορτιον επ' αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.29",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Lamentations 3:29",
      "text": "Θελει βαλει το στομα αυτου εις το χωμα, ισως ηναι ελπις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.30",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Lamentations 3:30",
      "text": "Θελει δωσει την σιαγονα εις τον ραπιζοντα αυτον θελει χορτασθη απο ονειδισμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.31",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Lamentations 3:31",
      "text": "Διοτι ο Κυριος δεν απορριπτει εις τον αιωνα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.32",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "Lamentations 3:32",
      "text": "Αλλ' εαν και θλιψη, θελει ομως και οικτειρησει κατα το πληθος του ελεους αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.33",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "Lamentations 3:33",
      "text": "Διοτι δεν θλιβει εκ καρδιας αυτου ουδε καταθλιβει τους υιους των ανθρωπων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.34",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "Lamentations 3:34",
      "text": "Το να καταπατη τις υπο τους ποδας αυτου παντας τους δεσμιους της γης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.35",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "Lamentations 3:35",
      "text": "Το να διαστρεφη κρισιν ανθρωπου κατεναντι του προσωπου του Υψιστου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.36",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 36,
      "referenceLabel": "Lamentations 3:36",
      "text": "Το να αδικη ανθρωπον εν τη δικη αυτου ο Κυριος δεν βλεπει ταυτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.37",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 37,
      "referenceLabel": "Lamentations 3:37",
      "text": "Τις λεγει τι και γινεται, χωρις να προσταξη αυτο ο Κυριος;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.38",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 38,
      "referenceLabel": "Lamentations 3:38",
      "text": "Εκ του στοματος του Υψιστου δεν εξερχονται τα κακα και τα αγαθα;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.39",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 39,
      "referenceLabel": "Lamentations 3:39",
      "text": "Δια τι ηθελε γογγυσει ανθρωπος ζων, ανθρωπος, δια την ποινην της αμαρτιας αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.40",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 40,
      "referenceLabel": "Lamentations 3:40",
      "text": "Ας ερευνησωμεν τας οδους ημων και ας εξετασωμεν και ας επιστρεψωμεν εις τον Κυριον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.41",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 41,
      "referenceLabel": "Lamentations 3:41",
      "text": "Ας υψωσωμεν τας καρδιας ημων και τας χειρας προς τον Θεον τον εν τοις ουρανοις, λεγοντες,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.42",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 42,
      "referenceLabel": "Lamentations 3:42",
      "text": "Ημαρτησαμεν και απεστατησαμεν συ δεν μας συνεχωρησας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.43",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 43,
      "referenceLabel": "Lamentations 3:43",
      "text": "Περιεκαλυψας με θυμον και κατεδιωξας ημας εφονευσας, δεν εφεισθης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.44",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 44,
      "referenceLabel": "Lamentations 3:44",
      "text": "Εκαλυψας σεαυτον με νεφος, δια να μη διαβαινη η προσευχη ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.45",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 45,
      "referenceLabel": "Lamentations 3:45",
      "text": "Μας εκαμες σκυβαλον και βδελυγμα εν μεσω των λαων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.46",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 46,
      "referenceLabel": "Lamentations 3:46",
      "text": "Παντες οι εχθροι ημων ηνοιξαν το στομα αυτων εφ' ημας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.47",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 47,
      "referenceLabel": "Lamentations 3:47",
      "text": "Φοβος και λακκος ηλθον εφ' ημας, ερημωσις και συντριμμος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.48",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 48,
      "referenceLabel": "Lamentations 3:48",
      "text": "Ρυακας υδατων καταβιβαζει ο οφθαλμος μου δια τον συντριμμον της θυγατρος του λαου μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.49",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 49,
      "referenceLabel": "Lamentations 3:49",
      "text": "Ο οφθαλμος μου σταλαζει και δεν σιωπα, διοτι δεν εχει ανεσιν,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.50",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 50,
      "referenceLabel": "Lamentations 3:50",
      "text": "Εωσου ο Κυριος διακυψη και ιδη εξ ουρανου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.51",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 51,
      "referenceLabel": "Lamentations 3:51",
      "text": "Ο οφθαλμος μου καταθλιβει την ψυχην μου, εκ πασων των θυγατερων της πολεως μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.52",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 52,
      "referenceLabel": "Lamentations 3:52",
      "text": "Οι εχθρευομενοι με αναιτιως με εκυνηγησαν ακαταπαυστως ως στρουθιον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.53",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 53,
      "referenceLabel": "Lamentations 3:53",
      "text": "Εκοψαν την ζωην μου εν τω λακκω και ερριψαν λιθον επ' εμε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.54",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 54,
      "referenceLabel": "Lamentations 3:54",
      "text": "Τα υδατα επλημμυρησαν υπερανω της κεφαλης μου ειπα, Απερριφθην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.55",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 55,
      "referenceLabel": "Lamentations 3:55",
      "text": "Επεκαλεσθην το ονομα σου, Κυριε, εκ λακκου κατωτατου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.56",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 56,
      "referenceLabel": "Lamentations 3:56",
      "text": "Ηκουσας την φωνην μου μη κλεισης το ωτιον σου εις τον στεναγμον μου, εις την κραυγην μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.57",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 57,
      "referenceLabel": "Lamentations 3:57",
      "text": "Επλησιασας καθ' ην ημεραν σε επεκαλεσθην ειπας, Μη φοβου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:lamentations.3.58",
      "translationId": "lxx-greek",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 58,
      "referenceLabel": "Lamentations 3:58",
      "text": "Εδικασας, Κυριε, την δικην της ψυχης μου ελυτρωσας την ζωην μου.",
      "paragraphStart": false
    },
    {
