      "chapterNumber": 3,
      "verseNumber": 59,
      "referenceLabel": "Lamentations 3:59",
      "text": "Ειδες, Κυριε, το προς εμε αδικον κρινον την κρισιν μου.",
      "paragraphStart": false
    },
