      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 60,
      "referenceLabel": "Lamentations 3:60",
      "text": "Ειδες πασας τας εκδικησεις αυτων, παντας τους διαλογισμους αυτων κατ' εμου.",
