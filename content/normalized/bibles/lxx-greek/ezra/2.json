{
  "chapter": {
    "id": "lxx-greek:ezra.2",
    "translationId": "lxx-greek",
    "bookSlug": "ezra",
    "chapterNumber": 2,
    "referenceLabel": "Ezra 2",
    "summary": "Source text for Ezra 2 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:ezra.2.1",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Ezra 2:1",
      "text": "Ουτοι δε ειναι οι ανθρωποι της επαρχιας οι αναβαντες εκ της αιχμαλωσιας, εκ των μετοικισθεντων, τους οποιους Ναβουχοδονοσορ ο βασιλευς της Βαβυλωνος μετωκισεν εις Βαβυλωνα, και επιστρεψαντες εις Ιερουσαλημ και εις την Ιουδαιαν, εκαστος εις την πολιν αυτου",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:ezra.2.2",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Ezra 2:2",
      "text": "οιτινες ηλθον μετα Ζοροβαβελ, Ιησου, Νεεμια, Σεραια, Ρεελαια, Μαροδοχαιου, Βιλσαν, Μισπαρ, Βιγουαι, Ρεουμ, Βαανα. Αριθμος των ανδρων του λαου του Ισραηλ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.3",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Ezra 2:3",
      "text": "Υιοι Φαρως, δισχιλιοι εκατον εβδομηκοντα δυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.4",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Ezra 2:4",
      "text": "Υιοι Σεφατια, τριακοσιοι εβδομηκοντα δυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.5",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Ezra 2:5",
      "text": "Υιοι Αραχ, επτακοσιοι εβδομηκοντα πεντε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.6",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Ezra 2:6",
      "text": "Υιοι Φααθ-μωαβ, εκ των υιων Ιησου και Ιωαβ, δισχιλιοι οκτακοσιοι δωδεκα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.7",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Ezra 2:7",
      "text": "Υιοι Ελαμ, χιλιοι διακοσιοι πεντηκοντα τεσσαρες.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.8",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Ezra 2:8",
      "text": "Υιοι Ζατθου, εννεακοσιοι τεσσαρακοντα πεντε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.9",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Ezra 2:9",
      "text": "Υιοι Ζακχαι, επτακοσιοι εξηκοντα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.10",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Ezra 2:10",
      "text": "Υιοι Βανι, εξακοσιοι τεσσαρακοντα δυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.11",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Ezra 2:11",
      "text": "Υιοι Βηβαι, εξακοσιοι εικοσιτρεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.12",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Ezra 2:12",
      "text": "Υιοι Αζγαδ, χιλιοι διακοσιοι εικοσιδυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.13",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Ezra 2:13",
      "text": "Υιοι Αδωνικαμ, εξακοσιοι εξηκοντα εξ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.14",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Ezra 2:14",
      "text": "Υιοι Βιγουαι, δισχιλιοι πεντηκοντα εξ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.15",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Ezra 2:15",
      "text": "Υιοι Αδιν, τετρακοσιοι πεντηκοντα τεσσαρες.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.16",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Ezra 2:16",
      "text": "Υιοι Ατηρ εκ του Εζεκιου, ενενηκοντα οκτω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.17",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Ezra 2:17",
      "text": "Υιοι Βησαι, τριακοσιοι εικοσιτρεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.18",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Ezra 2:18",
      "text": "Υιοι Ιωρα, εκατον δωδεκα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.19",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Ezra 2:19",
      "text": "Υιοι Ασουμ, διακοσιοι εικοσιτρεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.20",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Ezra 2:20",
      "text": "Υιοι Γιββαρ, ενενηκοντα πεντε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.21",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Ezra 2:21",
      "text": "Υιοι Βηθλεεμ, εκατον εικοσιτρεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.22",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Ezra 2:22",
      "text": "Ανδρες Νετωφα, πεντηκοντα εξ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.23",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Ezra 2:23",
      "text": "Ανδρες Αναθωθ, εκατον εικοσιοκτω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.24",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "Ezra 2:24",
      "text": "Υιοι Αζμαβεθ, τεσσαρακοντα δυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.25",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "Ezra 2:25",
      "text": "Υιοι Κιριαθ-αρειμ, Χεφειρα και Βηρωθ, επτακοσιοι τεσσαρακοντα τρεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.26",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "Ezra 2:26",
      "text": "Υιοι Ραμα και Γαβαα, εξακοσιοι εικοσι και εις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.27",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "Ezra 2:27",
      "text": "Ανδρες Μιχμας, εκατον εικοσιδυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.28",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "Ezra 2:28",
      "text": "Ανδρες Βαιθηλ και Γαι, διακοσιοι εικοσιτρεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.29",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 29,
      "referenceLabel": "Ezra 2:29",
      "text": "Υιοι Νεβω, πεντηκοντα δυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.30",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 30,
      "referenceLabel": "Ezra 2:30",
      "text": "Υιοι Μαγβις, εκατον πεντηκοντα εξ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.31",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 31,
      "referenceLabel": "Ezra 2:31",
      "text": "Υιοι του αλλου Ελαμ, χιλιοι διακοσιοι πεντηκοντα τεσσαρες.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.32",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 32,
      "referenceLabel": "Ezra 2:32",
      "text": "Υιοι Χαρημ, τριακοσιοι εικοσι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.33",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 33,
      "referenceLabel": "Ezra 2:33",
      "text": "Υιοι Λωδ, Αδιδ, και Ωνω, επτακοσιοι εικοσιπεντε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.34",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 34,
      "referenceLabel": "Ezra 2:34",
      "text": "Υιοι Ιεριχω, τριακοσιοι τεσσαρακοντα πεντε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.35",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 35,
      "referenceLabel": "Ezra 2:35",
      "text": "Υιοι Σεναα, τρισχιλιοι και εξακοσιοι τριακοντα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.36",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 36,
      "referenceLabel": "Ezra 2:36",
      "text": "Οι ιερεις υιοι Ιεδαια, εκ του οικου Ιησου, εννεακοσιοι εβδομηκοντα τρεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.37",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 37,
      "referenceLabel": "Ezra 2:37",
      "text": "Υιοι Ιμμηρ, χιλιοι πεντηκοντα δυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.38",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 38,
      "referenceLabel": "Ezra 2:38",
      "text": "Υιοι Πασχωρ, χιλιοι διακοσιοι τεσσαρακοντα επτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.39",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 39,
      "referenceLabel": "Ezra 2:39",
      "text": "Υιοι Χαρημ, χιλιοι δεκαεπτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.40",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 40,
      "referenceLabel": "Ezra 2:40",
      "text": "Οι Λευιται υιοι Ιησου, και Καδμιηλ, εκ των υιων Ωδουια, εβδομηκοντα τεσσαρες.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.41",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 41,
      "referenceLabel": "Ezra 2:41",
      "text": "Οι ψαλτωδοι υιοι Ασαφ, εκατον εικοσιοκτω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.42",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 42,
      "referenceLabel": "Ezra 2:42",
      "text": "Οι υιοι των πυλωρων υιοι Σαλλουμ, υιοι Ατηρ, υιοι Ταλμων, υιοι Ακκουβ, υιοι Ατιτα, υιοι Σωβαι παντες εκατον τριακοντα εννεα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.43",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 43,
      "referenceLabel": "Ezra 2:43",
      "text": "Οι Νεθινειμ υιοι Σιχα, υιοι Ασουφα, υιοι Ταββαωθ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.44",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 44,
      "referenceLabel": "Ezra 2:44",
      "text": "υιοι Κηρως, υιοι Σιαα, υιοι Φαδων,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.45",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 45,
      "referenceLabel": "Ezra 2:45",
      "text": "υιοι Λεβανα, υιοι Αγαβα, υιοι Ακκουβ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.46",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 46,
      "referenceLabel": "Ezra 2:46",
      "text": "υιοι Αγαβ, υιοι Σαλμαι, υιοι Αναν,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.47",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 47,
      "referenceLabel": "Ezra 2:47",
      "text": "υιοι Γιδδηλ, υιοι Γααρ, υιοι Ρεαια,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.48",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 48,
      "referenceLabel": "Ezra 2:48",
      "text": "υιοι Ρεσιν, υιοι Νεκωδα, υιοι Γαζαμ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.49",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 49,
      "referenceLabel": "Ezra 2:49",
      "text": "υιοι Ουζα, υιοι Φασεα, υιοι Βησαι,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.50",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 50,
      "referenceLabel": "Ezra 2:50",
      "text": "υιοι Ασενα, υιοι Μεουνειμ, υιοι Νεφουσειμ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.51",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 51,
      "referenceLabel": "Ezra 2:51",
      "text": "υιοι Βακβουκ, υιοι Ακουφα, υιοι Αρουρ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.52",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 52,
      "referenceLabel": "Ezra 2:52",
      "text": "υιοι Βασλουθ, υιοι Μειδα, υιοι Αρσα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.53",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 53,
      "referenceLabel": "Ezra 2:53",
      "text": "υιοι Βαρκως, υιοι Σισαρα, υιοι Θαμα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.54",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 54,
      "referenceLabel": "Ezra 2:54",
      "text": "υιοι Νεσια, υιοι Ατιφα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.55",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 55,
      "referenceLabel": "Ezra 2:55",
      "text": "Οι υιοι των δουλων του Σολομωντος υιοι Σωται, υιοι Σωφερεθ, υιοι Φερουδα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.56",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 56,
      "referenceLabel": "Ezra 2:56",
      "text": "υιοι Ιααλα, υιοι Δαρκων, υιοι Γιδδηλ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.57",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 57,
      "referenceLabel": "Ezra 2:57",
      "text": "υιοι Σεφατια, υιοι Αττιλ, υιοι Φοχερεθ απο Σεβαιμ, υιοι Αμι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.58",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 58,
      "referenceLabel": "Ezra 2:58",
      "text": "Παντες οι Νεθινειμ, και οι υιοι των δουλων του Σολομωντος, ησαν τριακοσιοι ενενηκοντα δυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.59",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 59,
      "referenceLabel": "Ezra 2:59",
      "text": "Ουτοι δε ησαν οι αναβαντες απο Θελ-μελαχ, Θελ-αρησα, Χερουβ, Αδδαν και Ιμμηρ δεν ηδυναντο ομως να δειξωσι τον οικον της πατριας αυτων και το σπερμα αυτων, αν ησαν εκ του Ισραηλ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.60",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 60,
      "referenceLabel": "Ezra 2:60",
      "text": "Υιοι Δαλαια, υιοι Τωβια, υιοι Νεκωδα, εξακοσιοι πεντηκοντα δυο",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.61",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 61,
      "referenceLabel": "Ezra 2:61",
      "text": "και εκ των υιων των ιερεων υιοι Αβαια, υιοι Ακκως, υιοι Βαρζελλαι, οστις ελαβε γυναικα εκ των θυγατερων Βαρζελλαι του Γαλααδιτου και ωνομασθη κατα το ονομα αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.62",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 62,
      "referenceLabel": "Ezra 2:62",
      "text": "Ουτοι εζητησαν την καταγραφην αυτων μεταξυ των απαριθμηθεντων κατα γενεαλογιαν, και δεν ευρεθησαν οθεν εξεβληθησαν απο της ιερατειας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.63",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 63,
      "referenceLabel": "Ezra 2:63",
      "text": "Και ειπε προς αυτους ο Θιρσαθα να μη φαγωσιν απο των αγιωτατων πραγματων, εωσου αναστηθη ιερευς μετα Ουριμ και Θουμμιμ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.64",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 64,
      "referenceLabel": "Ezra 2:64",
      "text": "Πασα η συναξις ομου ησαν τεσσαρακοντα δυο χιλιαδες τριακοσιοι εξηκοντα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.65",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 65,
      "referenceLabel": "Ezra 2:65",
      "text": "εκτος των δουλων αυτων και των θεραπαινιδων αυτων, οιτινες ησαν επτακισχιλιοι τριακοσιοι τριακοντα επτα και πλην τουτων, διακοσιοι ψαλτωδοι και ψαλτριαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.66",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 66,
      "referenceLabel": "Ezra 2:66",
      "text": "Οι ιπποι αυτων επτακοσιοι τριακοντα εξ αι ημιονοι αυτων, διακοσιαι τεσσαρακοντα πεντε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.67",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 67,
      "referenceLabel": "Ezra 2:67",
      "text": "αι καμηλοι αυτων, τετρακοσιαι τριακοντα πεντε αι ονοι, εξακισχιλιαι επτακοσιαι εικοσι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.68",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 68,
      "referenceLabel": "Ezra 2:68",
      "text": "Και τινες εκ των αρχηγων των πατριων, οτε ηλθον εις τον οικον του Κυριου τον εν Ιερουσαλημ, προσεφεραν αυτοπροαιρετως δια τον οικον του Θεου, να ανεγειρωσιν αυτον εν τω τοπω αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.69",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 69,
      "referenceLabel": "Ezra 2:69",
      "text": "εδωκαν κατα την δυναμιν αυτων εις το θησαυροφυλακιον του εργου εξ μυριαδας και χιλιας δραχμας χρυσιου και πεντε χιλιαδας μνας αργυριου και εκατον ιερατικους χιτωνας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:ezra.2.70",
      "translationId": "lxx-greek",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 70,
      "referenceLabel": "Ezra 2:70",
      "text": "Ουτως οι ιερεις και οι Λευιται και μερος εκ του λαου και οι ψαλτωδοι και οι πυλωροι και οι Νεθινειμ κατωκησαν εν ταις πολεσιν αυτων, και πας ο Ισραηλ εν ταις πολεσιν αυτου.",
      "paragraphStart": false
    }
  ]
}
