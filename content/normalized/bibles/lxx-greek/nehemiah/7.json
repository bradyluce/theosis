{
  "chapter": {
    "id": "lxx-greek:nehemiah.7",
    "translationId": "lxx-greek",
    "bookSlug": "nehemiah",
    "chapterNumber": 7,
    "referenceLabel": "Nehemiah 7",
    "summary": "Source text for Nehemiah 7 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:nehemiah.7.1",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Nehemiah 7:1",
      "text": "Αφου δε το τειχος εκτισθη, και εστησα τας θυρας, και διωρισθησαν οι πυλωροι και οι ψαλτωδοι και οι Λευιται,",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:nehemiah.7.2",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Nehemiah 7:2",
      "text": "προσεταξα περι της Ιερουσαλημ τον αδελφον μου Ανανι και τον Ανανιαν τον αρχοντα του φρουριου διοτι ητο ως ανθρωπος πιστος και φοβουμενος τον Θεον, υπερ πολλους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.3",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Nehemiah 7:3",
      "text": "Και ειπα προς αυτους, Ας μη ανοιγωνται αι πυλαι της Ιερουσαλημ εωσου θερμανη ο ηλιος και εκεινων ετι παροντων, να κλειωνται αι θυραι και να ασφαλιζωνται και φυλακαι να διοριζωνται εκ των κατοικων της Ιερουσαλημ, εκαστος εν τη φυλακη αυτου και εκαστος απεναντι της οικιας αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.4",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Nehemiah 7:4",
      "text": "Και η πολις ητο ευρυχωρος και μεγαλη, ο δε λαος ολιγος εν αυτη, και οικιαι δεν ησαν ωκοδομημεναι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.5",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Nehemiah 7:5",
      "text": "Και εβαλεν ο Θεος μου εν τη καρδια μου να συναξω τους προκριτους και τους προεστωτας και τον λαον, δια να αριθμηθωσι κατα γενεαλογιαν. Και ευρηκα βιβλιον της γενεαλογιας εκεινων, οιτινες ανεβησαν κατ' αρχας και ευρηκα γεγραμμενον εν αυτω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.6",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Nehemiah 7:6",
      "text": "Ουτοι ειναι οι ανθρωποι της επαρχιας, οι αναβαντες εκ της αιχμαλωσιας, εκ των μετοικισθεντων, τους οποιους μετωκισε Ναβουχοδονοσορ ο βασιλευς της Βαβυλωνος, και επιστρεψαντες εις Ιερουσαλημ και εις την Ιουδαιαν, εκαστος εις την πολιν αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.7",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Nehemiah 7:7",
      "text": "οι ελθοντες μετα Ζοροβαβελ, Ιησου, Νεεμια, Αζαρια, Ρααμια, Νααμανι, Μαροδοχαιου, Βιλσαν, Μισπερεθ, Βιγουαι, Νεουμ, Βαανα. Αριθμος των ανδρων του λαου Ισραηλ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.8",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Nehemiah 7:8",
      "text": "υιοι Φαρως, δισχιλιοι εκατον εβδομηκοντα δυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.9",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Nehemiah 7:9",
      "text": "Υιοι Σεφατια, τριακοσιοι εβδομηκοντα δυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.10",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Nehemiah 7:10",
      "text": "Υιοι Αραχ, εξακοσιοι πεντηκοντα δυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.11",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Nehemiah 7:11",
      "text": "Υιοι Φααθ-μωαβ, εκ των υιων Ιησου και Ιωαβ, δισχιλιοι και οκτακοσιοι δεκαοκτω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.12",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Nehemiah 7:12",
      "text": "Υιοι Ελαμ, χιλιοι διακοσιοι πεντηκοντα τεσσαρες.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.13",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Nehemiah 7:13",
      "text": "Υιοι Ζατθου, οκτακοσιοι τεσσαρακοντα πεντε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.14",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Nehemiah 7:14",
      "text": "Υιοι Ζακχαι, επτακοσιοι εξηκοντα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.15",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Nehemiah 7:15",
      "text": "Υιοι Βιννουι, εξακοσιοι τεσσαρακοντα οκτω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.16",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Nehemiah 7:16",
      "text": "Υιοι Βηβαι, εξακοσιοι εικοσιοκτω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.17",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Nehemiah 7:17",
      "text": "Υιοι Αζγαδ, δισχιλιοι τριακοσιοι εικοσιδυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.18",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Nehemiah 7:18",
      "text": "Υιοι Αδωνικαμ, εξακοσιοι εξηκοντα επτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.19",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Nehemiah 7:19",
      "text": "Υιοι Βιγουαι, δισχιλιοι εξηκοντα επτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.20",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Nehemiah 7:20",
      "text": "Υιοι Αδιν, εξακοσιοι πεντηκοντα πεντε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.21",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Nehemiah 7:21",
      "text": "Υιοι Ατηρ εκ του Εζεκιου, ενενηκοντα οκτω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.22",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Nehemiah 7:22",
      "text": "Υιοι Ασουμ, τριακοσιοι εικοσιοκτω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.23",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Nehemiah 7:23",
      "text": "Υιοι Βησαι, τριακοσιοι εικοσιτεσσαρες.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.24",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Nehemiah 7:24",
      "text": "Υιοι Αριφ, εκατον δωδεκα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.25",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Nehemiah 7:25",
      "text": "Υιοι Γαβαων, ενενηκοντα πεντε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.26",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "Nehemiah 7:26",
      "text": "Ανδρες Βηθλεεμ και Νετωφα, εκατον ογδοηκοντα οκτω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.27",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "Nehemiah 7:27",
      "text": "Ανδρες Αναθωθ, εκατον εικοσιοκτω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.28",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "Nehemiah 7:28",
      "text": "Ανδρες Βαιθ-ασμαβεθ, τεσσαρακοντα δυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.29",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "Nehemiah 7:29",
      "text": "Ανδρες Κιριαθ-ιαρειμ, Χεφειρα, και Βηρωθ, επτακοσιοι τεσσαρακοντα τρεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.30",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 30,
      "referenceLabel": "Nehemiah 7:30",
      "text": "Ανδρες Ραμα και Γαβαα, εξακοσιοι εικοσι και εις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.31",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 31,
      "referenceLabel": "Nehemiah 7:31",
      "text": "Ανδρες Μιχμας, εκατον εικοσιδυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.32",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 32,
      "referenceLabel": "Nehemiah 7:32",
      "text": "Ανδρες Βαιθηλ, και Γαι, εκατον εικοσιτρεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.33",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 33,
      "referenceLabel": "Nehemiah 7:33",
      "text": "Ανδρες της αλλης Νεβω, πεντηκοντα δυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.34",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 34,
      "referenceLabel": "Nehemiah 7:34",
      "text": "Υιοι του αλλου Ελαμ, χιλιοι διακοσιοι πεντηκοντα τεσσαρες.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.35",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 35,
      "referenceLabel": "Nehemiah 7:35",
      "text": "Υιοι Χαρημ, τριακοσιοι εικοσι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.36",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 36,
      "referenceLabel": "Nehemiah 7:36",
      "text": "Υιοι Ιεριχω, τριακοσιοι τεσσαρακοντα πεντε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.37",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 37,
      "referenceLabel": "Nehemiah 7:37",
      "text": "Υιοι Λωδ, Αδιδ, και Ωνω, επτακοσιοι εικοσι και εις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.38",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 38,
      "referenceLabel": "Nehemiah 7:38",
      "text": "Υιοι Σεναα, τρισχιλιοι εννεακοσιοι τριακοντα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.39",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 39,
      "referenceLabel": "Nehemiah 7:39",
      "text": "Οι ιερεις υιοι Ιεδαια, εκ του οικου Ιησου, εννεακοσιοι εβδομηκοντα τρεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.40",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 40,
      "referenceLabel": "Nehemiah 7:40",
      "text": "Υιοι Ιμμηρ, χιλιοι πεντηκοντα δυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.41",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 41,
      "referenceLabel": "Nehemiah 7:41",
      "text": "Υιοι Πασχωρ, χιλιοι διακοσιοι τεσσαρακοντα επτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.42",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 42,
      "referenceLabel": "Nehemiah 7:42",
      "text": "Υιοι Χαρημ, χιλιοι δεκαεπτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.43",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 43,
      "referenceLabel": "Nehemiah 7:43",
      "text": "Οι Λευιται υιοι Ιησου εκ του Καδμιηλ, εκ των υιων Ωδαυια, εβδομηκοντα τεσσαρες.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.44",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 44,
      "referenceLabel": "Nehemiah 7:44",
      "text": "Οι ψαλτωδοι υιοι Ασαφ, εκατον τεσσαρακοντα οκτω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.45",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 45,
      "referenceLabel": "Nehemiah 7:45",
      "text": "Οι πυλωροι υιοι Σαλλουμ, υιοι Ατηρ, υιοι Ταλμων, υιοι Ακκουβ, υιοι Ατιτα, υιοι Σωβαι, εκατον τριακοντα οκτω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.46",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 46,
      "referenceLabel": "Nehemiah 7:46",
      "text": "Οι Νεθινειμ υιοι Σιχα, υιοι Ασουφα, υιοι Ταββαωθ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.47",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 47,
      "referenceLabel": "Nehemiah 7:47",
      "text": "υιοι Κηρως, υιοι Σιαα, υιοι Φαδων,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.48",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 48,
      "referenceLabel": "Nehemiah 7:48",
      "text": "υιοι Λεβανα, υιοι Αγαβα, υιοι Σαλμαι,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.49",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 49,
      "referenceLabel": "Nehemiah 7:49",
      "text": "υιοι Αναν, υιοι Γιδδηλ, υιοι Γααρ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.50",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 50,
      "referenceLabel": "Nehemiah 7:50",
      "text": "υιοι Ρεαια, υιοι Ρεσιν, υιοι Νεκωδα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.51",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 51,
      "referenceLabel": "Nehemiah 7:51",
      "text": "υιοι Γαζαμ, υιοι Ουζα, υιοι Φασεα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.52",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 52,
      "referenceLabel": "Nehemiah 7:52",
      "text": "υιοι Βησαι, υιοι Μεουνειμ, υιοι Ναφουσεσειμ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.53",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 53,
      "referenceLabel": "Nehemiah 7:53",
      "text": "υιοι Βακβουκ, υιοι Ακουφα, υιοι Αρουρ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.54",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 54,
      "referenceLabel": "Nehemiah 7:54",
      "text": "υιοι Βασλιθ, υιοι Μειδα, υιοι Αρσα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.55",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 55,
      "referenceLabel": "Nehemiah 7:55",
      "text": "υιοι Βαρκως, υιοι Σισαρα, υιοι Θαμα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.56",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 56,
      "referenceLabel": "Nehemiah 7:56",
      "text": "υιοι Νεσια, υιοι Ατιφα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.57",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 57,
      "referenceLabel": "Nehemiah 7:57",
      "text": "Οι υιοι των δουλων του Σολομωντος υιοι Σωται, υιοι Σωφερεθ, υιοι Φερειδα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.58",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 58,
      "referenceLabel": "Nehemiah 7:58",
      "text": "υιοι Ιααλα, υιοι Δαρκων, υιοι Γιδδηλ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.59",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 59,
      "referenceLabel": "Nehemiah 7:59",
      "text": "υιοι Σεφατια, υιοι Αττιλ, υιοι Φοχερεθ απο Σεβαιμ, υιοι Αμων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.60",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 60,
      "referenceLabel": "Nehemiah 7:60",
      "text": "Παντες οι Νεθινειμ, και οι υιοι των δουλων του Σολομωντος, ησαν τριακοσιοι ενενηκοντα δυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.61",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 61,
      "referenceLabel": "Nehemiah 7:61",
      "text": "Ουτοι δε ησαν οι αναβαντες απο Θελ-μελαχ, Θελ-αρησα, Χερουβ, Αδδων, και Ιμμηρ δεν ηδυναντο ομως να δειξωσι τον οικον της πατριας αυτων και το σπερμα αυτων, αν ησαν εκ του Ισραηλ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.62",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 62,
      "referenceLabel": "Nehemiah 7:62",
      "text": "Υιοι Δαλαια, υιοι Τωβια, υιοι Νεκωδα, εξακοσιοι τεσσαρακοντα δυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.63",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 63,
      "referenceLabel": "Nehemiah 7:63",
      "text": "Και εκ των ιερεων υιοι Αβαια, υιοι Ακκως, υιοι Βαρζελλαι, οστις ελαβε γυναικα εκ των θυγατερων Βαρζελλαι του Γαλααδιτου και ωνομασθη κατα το ονομα αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.64",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 64,
      "referenceLabel": "Nehemiah 7:64",
      "text": "Ουτοι εζητησαν την καταγραφην αυτων μεταξυ των απαριθμηθεντων κατα γενεαλογιαν, και δεν ευρεθη οθεν εξεβληθησαν απο της ιερατειας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.65",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 65,
      "referenceLabel": "Nehemiah 7:65",
      "text": "Και ειπε προς αυτους ο Θιρσαθα, να μη φαγωσιν απο των αγιωτατων πραγματων, εωσου αναστηθη ιερευς μετα Ουριμ και Θουμμιμ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.66",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 66,
      "referenceLabel": "Nehemiah 7:66",
      "text": "Πασα η συναξις ομου ησαν τεσσαρακοντα δυο χιλιαδες τριακοσιοι εξηκοντα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.67",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 67,
      "referenceLabel": "Nehemiah 7:67",
      "text": "εκτος των δουλων αυτων και των θεραπαινιδων αυτων, οιτινες ησαν επτακισχιλιοι τριακοσιοι τριακοντα επτα και πλην τουτων διακοσιοι τεσσαρακοντα πεντε ψαλτωδοι και ψαλτριαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.68",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 68,
      "referenceLabel": "Nehemiah 7:68",
      "text": "Οι ιπποι αυτων, επτακοσιοι τριακοντα εξ αι ημιονοι αυτων, διακοσιαι τεσσαρακοντα πεντε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.69",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 69,
      "referenceLabel": "Nehemiah 7:69",
      "text": "αι καμηλοι, τετρακοσιαι τριακοντα πεντε αι ονοι, εξακισχιλιαι επτακοσιαι εικοσι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.70",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 70,
      "referenceLabel": "Nehemiah 7:70",
      "text": "Και τινες εκ των αρχηγων των πατριων εδωκαν δια το εργον. Ο Θιρσαθα εδωκεν εις το θησαυροφυλακιον χιλιας δραχμας χρυσιου, πεντηκοντα φιαλας, πεντακοσιους τριακοντα ιερατικους χιτωνας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.71",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 71,
      "referenceLabel": "Nehemiah 7:71",
      "text": "Και τινες εκ των αρχηγων των πατριων εδωκαν εις το θησαυροφυλακιον του εργου εικοσι χιλιαδας δραχμας χρυσιου και δυο χιλιαδας διακοσιας μνας αργυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.72",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 72,
      "referenceLabel": "Nehemiah 7:72",
      "text": "Και το δοθεν απο του επιλοιπου λαου ητο εικοσι χιλιαδες δραχμαι χρυσιου, και δισχιλιαι μναι αργυριου, και εξηκοντα επτα ιερατικοι χιτωνες.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.7.73",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 73,
      "referenceLabel": "Nehemiah 7:73",
      "text": "Ουτως οι ιερεις και οι Λευιται και οι πυλωροι και οι ψαλτωδοι και μερος εκ του λαου και οι Νεθινειμ και πας ο Ισραηλ, κατωκησαν εν ταις πολεσιν αυτων. Και οτε εφθασεν ο εβδομος μην, οι υιοι Ισραηλ ησαν εν ταις πολεσιν αυτων.",
      "paragraphStart": false
    }
  ]
}
