{
  "chapter": {
    "id": "lxx-greek:nehemiah.11",
    "translationId": "lxx-greek",
    "bookSlug": "nehemiah",
    "chapterNumber": 11,
    "referenceLabel": "Nehemiah 11",
    "summary": "Source text for Nehemiah 11 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:nehemiah.11.1",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Nehemiah 11:1",
      "text": "Και κατωκησαν οι αρχοντες του λαου εν Ιερουσαλημ και το υπολοιπον του λαου ερριψαν κληρους, δια να φερωσιν ενα εκ των δεκα να κατοικηση εν Ιερουσαλημ τη αγια πολει, τα δε εννεα μερη εν ταις αλλαις πολεσι.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:nehemiah.11.2",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Nehemiah 11:2",
      "text": "Και ηυλογησεν ο λαος παντας τους ανθρωπους, οσοι προσεφεραν αυτοπροαιρετως εαυτους να κατοικησωσιν εν Ιερουσαλημ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.3",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Nehemiah 11:3",
      "text": "Ουτοι δε ειναι οι αρχοντες της επαρχιας οι κατοικησαντες εν Ιερουσαλημ εν δε ταις πολεσι του Ιουδα κατωκησαν εκαστος εν τη ιδιοκτησια αυτου, εν ταις πολεσιν αυτων, ο Ισραηλ, οι ιερεις και οι Λευιται και οι Νεθινειμ και οι υιοι των δουλων του Σολομωντος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.4",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Nehemiah 11:4",
      "text": "Και εν Ιερουσαλημ κατωκησαν τινες εκ των υιων Ιουδα και εκ των υιων Βενιαμιν εκ των υιων Ιουδα, Αθαιας ο υιος του Οζια, υιου Ζαχαρια, υιου Αμαρια, υιου Σεφατια, υιου Μααλελεηλ, εκ των υιων Φαρες",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.5",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Nehemiah 11:5",
      "text": "και Μαασιας ο υιος του Βαρουχ, υιου Χολ-οζε, υιου Αζαια, υιου Αδαια, υιου Ιωιαριβ, υιου Ζαχαρια, υιου του Σηλωνι",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.6",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Nehemiah 11:6",
      "text": "παντες οι υιοι Φαρες οι κατοικησαντες εν Ιερουσαλημ ησαν τετρακοσιοι εξηκοντα οκτω ανδρες δυναμεως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.7",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Nehemiah 11:7",
      "text": "Οι δε υιοι Βενιαμιν ειναι ουτοι Σαλλου ο υιος του Μεσουλλαμ, υιου Ιωαδ, υιου Φεδαια, υιου Κωλαια, υιου Μαασια, υιου Ιθιηλ, υιου Ιεσαια",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.8",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Nehemiah 11:8",
      "text": "και μετ' αυτων, Γαββαει, Σαλλαι, εννεακοσιοι εικοσιοκτω",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.9",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Nehemiah 11:9",
      "text": "και Ιωηλ ο υιος του Ζιχρι ητο εφορος αυτων ο δε Ιουδας, ο υιος του Σενουα, δευτερος επι την πολιν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.10",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Nehemiah 11:10",
      "text": "Εκ των ιερεων, Ιεδαιας ο υιος του Ιωιαριβ, Ιαχειν,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.11",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Nehemiah 11:11",
      "text": "Σεραιας ο υιος του Χελκια, υιου Μεσσουλλαμ, υιου Σαδωκ, υιου Μεραιωθ, υιου Αχιτωβ, ο αρχων του οικου του Θεου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.12",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Nehemiah 11:12",
      "text": "Και οι αδελφοι αυτων οι ποιουντες το εργον του οικου ησαν οκτακοσιοι εικοσιδυο και Αδαιας ο υιος του Ιεροαμ, υιου Φελαλια, υιου Αμσι, υιου Ζαχαρια, υιου Πασχωρ, υιου Μαλχια,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.13",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Nehemiah 11:13",
      "text": "και οι αδελφοι αυτου, αρχοντες πατριων, διακοσιοι τεσσαρακοντα δυο και Αμασσαι ο υιος του Αζαρεηλ, υιου Ααζαι, υιου Μεσιλλεμωθ, υιου Ιμμηρ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.14",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Nehemiah 11:14",
      "text": "και οι αδελφοι αυτων, ανδρες δυνατοι εν ισχυι, εκατον εικοσιοκτω εφορος δε αυτων ητο Ζαβδιηλ, υιος του Γεδωλειμ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.15",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Nehemiah 11:15",
      "text": "Και εκ των Λευιτων, Σεμαιας ο υιος του Ασσουβ, υιου Αζρικαμ, υιου Ασαβια, υιου Βουννι",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.16",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Nehemiah 11:16",
      "text": "και Σαββεθαι και Ιωζαβαδ, εκ των αρχοντων των Λευιτων, ησαν επι των εξωτερικων εργων του οικου του Θεου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.17",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Nehemiah 11:17",
      "text": "Και Ματθανιας ο υιος του Μιχα, υιου Ζαβδι, υιου Ασαφ, ητο ο εξαρχων της υμνωδιας εν τη προσευχη και Βακβουκιας ο δευτερος μεταξυ των αδελφων αυτου, και Αβδα ο υιος του Σαμμουα, υιου Ταλαλ, υιου Ιεδουθουν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.18",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Nehemiah 11:18",
      "text": "Παντες οι Λευιται εν τη αγια πολει ησαν διακοσιοι ογδοηκοντα τεσσαρες.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.19",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Nehemiah 11:19",
      "text": "Οι δε πυλωροι, Ακκουβ, Ταλμων, και οι αδελφοι αυτων οι φυλαττοντες εν ταις πυλαις, ησαν εκατον εβδομηκοντα δυο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.20",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Nehemiah 11:20",
      "text": "Και το υπολοιπον του Ισραηλ, οι ιερεις και Λευιται, ησαν εν πασαις ταις πολεσιν Ιουδα, εκαστος εν τη κληρονομια αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.21",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Nehemiah 11:21",
      "text": "Οι δε Νεθινειμ κατωκησαν εν Οφηλ και ο Σιχα και ο Γισπα ησαν επι των Νεθινειμ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.22",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Nehemiah 11:22",
      "text": "Και ο εφορος των Λευιτων εν Ιερουσαλημ ητο Οζι, ο υιος του Βανι, υιου Ασαβια, υιου Ματθανια, υιου Μιχα. Εκ των υιων του Ασαφ, οι ψαλτωδοι ησαν επι του εργου του οικου του Θεου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.23",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Nehemiah 11:23",
      "text": "Διοτι ητο προσταγη του βασιλεως περι αυτων, και διατεταγμενον μεριδιον δια τους ψαλτωδους κατα πασαν ημεραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.24",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Nehemiah 11:24",
      "text": "Και Πεθαια ο υιος του Μεσηζαβεηλ, εκ των υιων του Ζερα υιου του Ιουδα, ητο επιτροπος του βασιλεως εν παση υποθεσει περι του λαου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.25",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Nehemiah 11:25",
      "text": "Περι δε των χωριων, μετα των αγρων αυτων, τινες εκ των υιων Ιουδα κατωκησαν εν Κιριαθ-αρβα και ταις κωμαις αυτης, και εν Δαιβων και ταις κωμαις αυτης, και εν Ιεκαβσεηλ και τοις χωριοις αυτης,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.26",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Nehemiah 11:26",
      "text": "και εν Ιησουα και εν Μωλαδα και εν Βαιθ-φελετ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.27",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Nehemiah 11:27",
      "text": "και εν Ασαρ-σουαλ και εν Βηρ-σαβεε και ταις κωμαις αυτης,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.28",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "Nehemiah 11:28",
      "text": "και εν Σικλαγ και εν Μεκονα και εν ταις κωμαις αυτης,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.29",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "Nehemiah 11:29",
      "text": "και εν Εν-ριμμων και εν Σαρεα και εν Ιαρμουθ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.30",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "Nehemiah 11:30",
      "text": "Ζανωα, Οδολλαμ και τοις χωριοις αυτων, Λαχεις και τοις αγροις αυτης, Αζηκα και ταις κωμαις αυτης. Και κατωκησαν απο Βηρ-σαβεε εως της φαραγγος Εννομ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.31",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "Nehemiah 11:31",
      "text": "Και οι υιοι Βενιαμιν κατωκησαν απο Γεβα εν Μιχμας και Αιια και Βαιθηλ και ταις κωμαις αυτης,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.32",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 32,
      "referenceLabel": "Nehemiah 11:32",
      "text": "εν Αναθωθ, Νωβ, Ανανια,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.33",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 33,
      "referenceLabel": "Nehemiah 11:33",
      "text": "Ασωρ, Ραμα, Γιτθαιμ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.34",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 34,
      "referenceLabel": "Nehemiah 11:34",
      "text": "Αδιδ, Σεβωειμ, Νεβαλλατ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.35",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 35,
      "referenceLabel": "Nehemiah 11:35",
      "text": "Λωδ, και Ωνω, τη φαραγγι των τεκτονων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.11.36",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 36,
      "referenceLabel": "Nehemiah 11:36",
      "text": "Και εκ των Λευιτων κατωκησαν διαιρεσεις εν Ιουδα και Βενιαμιν.",
      "paragraphStart": false
    }
  ]
}
