{
  "chapter": {
    "id": "lxx-greek:nehemiah.10",
    "translationId": "lxx-greek",
    "bookSlug": "nehemiah",
    "chapterNumber": 10,
    "referenceLabel": "Nehemiah 10",
    "summary": "Source text for Nehemiah 10 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:nehemiah.10.1",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Nehemiah 10:1",
      "text": "Οι δε επισφραγισαντες ησαν Νεεμιας ο Θιρσαθα ο υιος του Αχαλια, και Σεδεκιας,",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:nehemiah.10.2",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Nehemiah 10:2",
      "text": "Σεραιας, Αζαριας, Ιερεμιας,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.3",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Nehemiah 10:3",
      "text": "Πασχωρ, Αμαριας, Μαλχιας,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.4",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Nehemiah 10:4",
      "text": "Χαττους, Σεβανιας, Μαλλουχ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.5",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Nehemiah 10:5",
      "text": "Χαρημ, Μερημωθ, Οβαδιας,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.6",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Nehemiah 10:6",
      "text": "Δανιηλ, Γιννεθων, Βαρουχ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.7",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Nehemiah 10:7",
      "text": "Μεσσουλλαμ, Αβια, Μειαμειν,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.8",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Nehemiah 10:8",
      "text": "Μααζιας, Βιλγαι, Σεμαιας ουτοι ησαν οι ιερεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.9",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Nehemiah 10:9",
      "text": "Και οι Λευιται Ιησους ο υιος του Αζανια, Βιννουι εκ των υιων Ηναδαδ, Καδμιηλ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.10",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Nehemiah 10:10",
      "text": "και οι αδελφοι αυτων, Σεβανιας, Ωδιας, Κελιτα, Φελαιας, Αναν,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.11",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Nehemiah 10:11",
      "text": "Μιχα, Ρεωβ, Ασαβιας,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.12",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Nehemiah 10:12",
      "text": "Ζακχουρ, Σερεβιας, Σεβανιας,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.13",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Nehemiah 10:13",
      "text": "Ωδιας, Βανι, Βενινου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.14",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Nehemiah 10:14",
      "text": "Οι αρχοντες του λαου Φαρως, Φααθ-μωαβ, Ελαμ, Ζατθου, Βανι,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.15",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Nehemiah 10:15",
      "text": "Βουννι, Αζγαδ, Βηβαι,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.16",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Nehemiah 10:16",
      "text": "Αδωνιας, Βιγουαι, Αδιν,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.17",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Nehemiah 10:17",
      "text": "Ατηρ, Εζεκιας, Αζουρ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.18",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Nehemiah 10:18",
      "text": "Ωδιας, Ασουμ, Βησαι,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.19",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Nehemiah 10:19",
      "text": "Αριφ, Αναθωθ, Νεβαι,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.20",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Nehemiah 10:20",
      "text": "Μαγφιας, Μεσουλλαμ, Εζειρ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.21",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Nehemiah 10:21",
      "text": "Μεσηζαβεηλ, Σαδωκ, Ιαδδουα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.22",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Nehemiah 10:22",
      "text": "Φελατιας, Αναν, Αναιας,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.23",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Nehemiah 10:23",
      "text": "Ωσηε, Ανανιας, Ασσουβ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.24",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Nehemiah 10:24",
      "text": "Αλλωης, Φιλεα, Σωβηκ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.25",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Nehemiah 10:25",
      "text": "Ρεουμ, Ασαβνα, Μαασιας,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.26",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Nehemiah 10:26",
      "text": "και Αχια, Αναν, Γαναν,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.27",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Nehemiah 10:27",
      "text": "Μαλλουχ, Χαρημ, Βαανα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.28",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Nehemiah 10:28",
      "text": "Και το υπολοιπον του λαου, οι ιερεις, οι Λευιται, οι πυλωροι, οι ψαλτωδοι, οι Νεθινειμ, και παντες οι αποχωρισθεντες απο των λαων των τοπων προς τον νομον του Θεου, αι γυναικες αυτων, οι υιοι αυτων και αι θυγατερες αυτων, πας εννοων και εχων συνεσιν,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.29",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Nehemiah 10:29",
      "text": "ηνωθησαν μετα των αδελφων αυτων, των προκριτων αυτων, και εισηλθον εις καταραν και εις ορκον, να περιπατωσιν εις τον νομον του Θεου, τον δοθεντα δια χειρος Μωυσεως του δουλου του Θεου, και να φυλαττωσι και να εκτελωσι πασας τας εντολας του Κυριου, του Κυριου ημων, και τας κρισεις αυτου και τα διαταγματα αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.30",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Nehemiah 10:30",
      "text": "και οτι δεν θελομεν δωσει τας θυγατερας ημων εις τους λαους της γης, και τας θυγατερας αυτων δεν θελομεν λαβει εις τους υιους ημων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.31",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Nehemiah 10:31",
      "text": "και, εαν οι λαοι της γης φερωσιν αγορασιμα η οποιασδηποτε τροφας να πωλησωσιν εν τη ημερα του σαββατου, οτι δεν θελομεν λαβει ταυτα παρ' αυτων εν σαββατω και εν ημερα αγια και οτι θελομεν αφησει το εβδομον ετος και την απαιτησιν παντος χρεους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.32",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Nehemiah 10:32",
      "text": "Διεταξαμεν ετι εις εαυτους να επιφορτισθωμεν να διδωμεν κατ' ετος εν τριτον του σικλου δια την υπηρεσιαν του οικου του Θεου ημων,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.33",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "Nehemiah 10:33",
      "text": "δια τους αρτους της προθεσεως και δια την παντοτεινην εξ αλφιτων προσφοραν, και δια την παντοτεινην ολοκαυτωσιν των σαββατων, των νεομηνιων, δια τας επισημους εορτας και δια τα αγια πραγματα και δια τας περι αμαρτιας προσφορας, δια να καμνωμεν εξιλεωσιν υπερ του Ισραηλ, και δια παν το εργον του οικου του Θεου ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.34",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 34,
      "referenceLabel": "Nehemiah 10:34",
      "text": "Και ερριψαμεν κληρους μεταξυ των ιερεων των Λευιτων και του λαου περι της προσφορας των ξυλων, δια να φερωσιν αυτα εις τον οικον του Θεου ημων, κατα τους οικους των πατριων ημων, εν ωρισμενοις καιροις κατ' ετος, δια να καιωσιν επι του θυσιαστηριου Κυριου του Θεου ημων, κατα το γεγραμμενον εν τω νομω",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.35",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 35,
      "referenceLabel": "Nehemiah 10:35",
      "text": "και δια να φερωμεν τα πρωτογεννηματα της γης ημων και τα πρωτογεννηματα των καρπων παντος δενδρου, κατ' ετος, προς τον οικον του Κυριου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.36",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 36,
      "referenceLabel": "Nehemiah 10:36",
      "text": "και τα πρωτοτοκα των υιων ημων και των κτηνων ημων, κατα το γεγραμμενον εν τω νομω, και τα πρωτοτοκα των βοων ημων και των ποιμνιων ημων, να φερωμεν αυτα εις τον οικον του Θεου ημων, προς τους ιερεις τους λειτουργουντας εν τω οικω του Θεου ημων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.37",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 37,
      "referenceLabel": "Nehemiah 10:37",
      "text": "και να φερωμεν τας απαρχας του φυραματος ημων και τας προσφορας ημων και τους καρπους παντος δενδρου, οινου και ελαιου, προς τους ιερεις, εις τα οικηματα του οικου του Θεου ημων και τα δεκατα της γης ημων προς τους Λευιτας, και αυτοι οι Λευιται να λαμβανωσι τα δεκατα εν πασαις ταις πολεσι της γεωργιας ημων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.38",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 38,
      "referenceLabel": "Nehemiah 10:38",
      "text": "Και ο ιερευς ο υιος του Ααρων θελει εισθαι μετα των Λευιτων, οταν οι Λευιται λαμβανωσι τα δεκατα και οι Λευιται θελουσιν αναφερει το δεκατον των δεκατων εις τον οικον του Θεου ημων, εις τα οικηματα του οικου του θησαυρου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:nehemiah.10.39",
      "translationId": "lxx-greek",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 39,
      "referenceLabel": "Nehemiah 10:39",
      "text": "Διοτι οι υιοι Ισραηλ και οι υιοι Λευι θελουσι φερει τας προσφορας του σιτου, του οινου και του ελαιου εις τα οικηματα, οπου ειναι τα σκευη του αγιαστηριου, και οι ιερεις οι λειτουργουντες και οι πυλωροι και οι ψαλτωδοι και δεν θελομεν εγκαταλειψει τον οικον του Θεου ημων.",
      "paragraphStart": false
    }
  ]
}
