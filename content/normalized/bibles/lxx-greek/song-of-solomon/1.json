{
  "chapter": {
    "id": "lxx-greek:song-of-solomon.1",
    "translationId": "lxx-greek",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 1,
    "referenceLabel": "Song of Solomon 1",
    "summary": "Source text for Song of Solomon 1 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:song-of-solomon.1.1",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 1:1",
      "text": "Το Αισμα των Αισματων, το του Σολομωντος.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:song-of-solomon.1.2",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 1:2",
      "text": "Ας με φιληση με τα φιληματα του στοματος αυτου. Διοτι η αγαπη σου ειναι καλητερα παρα τον οινον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.1.3",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 1:3",
      "text": "Δια την ευωδιαν των καλων μυρων σου, το ονομα σου ειναι μυρον εκκεχυμενον δια τουτο αι νεανιδες σε αγαπωσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.1.4",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 1:4",
      "text": "Ελκυσον με θελομεν δραμει κατοπιν σου ο βασιλευς με εισηγαγεν εις τα ταμεια αυτου θελομεν αγαλλεσθαι και ευφραινεσθαι εις σε, θελομεν ενθυμεισθαι την αγαπην σου μαλλον παρα οινον οι εχοντες ευθυτητα σε αγαπωσι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.1.5",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 1:5",
      "text": "Μελαινα ειμαι, πλην ευχαρις, θυγατερες της Ιερουσαλημ ως τα σκηνωματα του Κηδαρ, ως τα παραπετασματα του Σολομωντος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.1.6",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 1:6",
      "text": "Μη βλεπετε εις εμε, οτι ειμαι μεμελανωμενη, επειδη ο ηλιος με εκαυσεν οι υιοι της μητρος μου ωργισθησαν κατ' εμου με εβαλον φυλακα εις τους αμπελωνας τον ιδιον μου αμπελωνα ομως δεν εφυλαξα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.1.7",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 1:7",
      "text": "Απαγγειλον μοι, συ, τον οποιον αγαπα η ψυχη μου, Που ποιμαινεις, που αναπαυεις το ποιμνιον την μεσημβριαν δια τι να γεινω ως περικεκαλυμμενη μεταξυ των ποιμνιων των συντροφων σου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.1.8",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 1:8",
      "text": "Εαν δεν γνωριζης τουτο αφ' εαυτης, ωραια μεταξυ των γυναικων, εξελθε συ κατοπιν εις τα ιχνη του ποιμνιου, και ποιμαινε τα εριφια σου πλησιον των σκηνων των βοσκων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.1.9",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 1:9",
      "text": "Με τας ιππους των αμαξων του Φαραω σε εξωμοιωσα, ηγαπημενη μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.1.10",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 1:10",
      "text": "Αι σιαγονες σου ειναι ωραιαι με τας σειρας των μαργαριτων, και ο τραχηλος σου με τα περιδερραια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.1.11",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 1:11",
      "text": "Θελομεν καμει εις σε αλυσεις χρυσας με στιγματα αργυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.1.12",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 1:12",
      "text": "Ενοσω ο βασιλευς καθηται εις την τραπεζαν αυτου, ο ναρδος μου διαχεει την οσμην αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.1.13",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 1:13",
      "text": "Δεματιον σμυρνης ειναι εις εμε ο αγαπητος μου θελει διανυκτερευει μεταξυ των μαστων μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.1.14",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Song of Solomon 1:14",
      "text": "Ο αγαπητος μου ειναι εις εμε ως βοτρυς κυπρινος εις τους αμπελωνας του Εν-γαδδι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.1.15",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Song of Solomon 1:15",
      "text": "Ιδου, εισαι ωραια, αγαπητη μου ιδου, εισαι ωραια οι οφθαλμοι σου ειναι ως περιστερων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.1.16",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Song of Solomon 1:16",
      "text": "Ιδου, εισαι ωραιος, αγαπητε μου, ναι, ευχαρις και η κλινη ημων ειναι ευθαλης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.1.17",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Song of Solomon 1:17",
      "text": "Αι δοκοι των οικων ημων ειναι κεδροι, τα σανιδωματα ημων εκ κυπαρισσου.",
      "paragraphStart": false
    }
  ]
}
