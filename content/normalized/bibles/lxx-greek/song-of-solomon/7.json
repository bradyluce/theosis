{
  "chapter": {
    "id": "lxx-greek:song-of-solomon.7",
    "translationId": "lxx-greek",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 7,
    "referenceLabel": "Song of Solomon 7",
    "summary": "Source text for Song of Solomon 7 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:song-of-solomon.7.1",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 7:1",
      "text": "Ποσον ωραια ειναι τα βηματα σου με τα σανδαλια, θυγατερ του ηγεμονος το τορνευμα των μηρων σου ειναι ομοιον με περιδεραιον, εργον χειρων καλλιτεχνου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:song-of-solomon.7.2",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 7:2",
      "text": "Ο ομφαλος σου κρατηρ τορνευτος, πληρης κεκερασμενου οινου η κοιλια σου θημωνια σιτου περιπεφραγμενη με κρινους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.7.3",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 7:3",
      "text": "οι δυο σου μαστοι ως δυο σκυμνοι δορκαδος διδυμοι",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.7.4",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 7:4",
      "text": "ο τραχηλος σου ως πυργος ελεφαντινος οι οφθαλμοι σου ως αι κολυμβηθραι εν Εσεβων, προς την πυλην Βαθ-ραββιμ η μυτη σου ως ο πυργος του Λιβανου, βλεπων προς την Δαμασκον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.7.5",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 7:5",
      "text": "Η κεφαλη σου επι σε ως Καρμηλος, και η κομη της κεφαλης σου ως πορφυρα ο βασιλευς ειναι δεδεμενος εις τους πλοκαμους σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.7.6",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 7:6",
      "text": "Ποσον ωραια και ποσον επιθυμητη εισαι, αγαπητη, δια τας τρυφας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.7.7",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 7:7",
      "text": "Τουτο το αναστημα σου ομοιαζει με φοινικα, και οι μαστοι σου με βοτρυας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.7.8",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 7:8",
      "text": "Ειπα, Θελω αναβη εις τον φοινικα, θελω πιασει τα βαια αυτου και ιδου, οι μαστοι σου θελουσιν εισθαι ως βοτρυες της αμπελου, και η οσμη της ρινος σου ως μηλα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.7.9",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 7:9",
      "text": "και ο ουρανισκος σου ως ο καλος οινος ρεων ηδεως δια τον αγαπητον μου, και καμνων να λαλωσι τα χειλη των κοιμωμενων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.7.10",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 7:10",
      "text": "Εγω ειμαι του αγαπητου μου, και η επιθυμια αυτου ειναι προς εμε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.7.11",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 7:11",
      "text": "Ελθε, αγαπητε μου, ας εξελθωμεν εις τον αγρον ας διανυκτερευσωμεν εν ταις κωμαις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.7.12",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 7:12",
      "text": "Ας εξημερωθωμεν εις τους αμπελωνας ας ιδωμεν εαν εβλαστησεν η αμπελος, εαν ηνοιξε το ανθος της σταφυλης και εξηνθησαν αι ροιδιαι εκει θελω δωσει την αγαπην μου εις σε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.7.13",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 7:13",
      "text": "Οι μανδραγοραι εδωκαν οσμην, και εν ταις θυραις ημων ειναι παν ειδος καρπων αρεστων, νεων και παλαιων, τους οποιους εφυλαξα, αγαπητε μου, δια σε.",
      "paragraphStart": false
    }
  ]
}
