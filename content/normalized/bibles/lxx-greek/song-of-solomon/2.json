{
  "chapter": {
    "id": "lxx-greek:song-of-solomon.2",
    "translationId": "lxx-greek",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 2,
    "referenceLabel": "Song of Solomon 2",
    "summary": "Source text for Song of Solomon 2 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:song-of-solomon.2.1",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 2:1",
      "text": "Εγω ειμαι το ανθος του Σαρων και το κρινον των κοιλαδων.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:song-of-solomon.2.2",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 2:2",
      "text": "Καθως το κρινον μεταξυ των ακανθων, ουτως ειναι η αγαπητη μου μεταξυ των νεανιδων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.2.3",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 2:3",
      "text": "Καθως η μηλεα μεταξυ των δενδρων του δασους, ουτως ειναι ο αγαπητος μου μεταξυ των νεανισκων επεθυμησα την σκιαν αυτου και εκαθησα υπ' αυτην, και ο καρπος αυτου ητο γλυκυς εις τον ουρανισκον μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.2.4",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 2:4",
      "text": "Με εφερεν εις τον οικον του οινου, και η σημαια αυτου επ' εμε η αγαπη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.2.5",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 2:5",
      "text": "Υποστηριξατε με με γλυκισματα δυναμωτικα, αναψυξατε με με μηλα διοτι ειμαι τετρωμενη υπο αγαπης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.2.6",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 2:6",
      "text": "Η αριστερα αυτου ειναι υπο την κεφαλην μου, και η δεξια αυτου με εναγκαλιζεται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.2.7",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 2:7",
      "text": "Σας ορκιζω, θυγατερες Ιερουσαλημ, εις τας δορκαδας και εις τας ελαφους του αγρου, να μη εξεγειρητε μηδε να εξυπνησητε την αγαπην μου, εωσου θεληση.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.2.8",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 2:8",
      "text": "Φωνη του αγαπητου μου Ιδου, αυτος ερχεται πηδων επι τα ορη, σκιρτων επι τους λοφους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.2.9",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 2:9",
      "text": "Ο αγαπητος μου ειναι ομοιος με δορκαδα η με σκυμνον ελαφου ιδου, ισταται οπισθεν του τοιχου ημων, κυτταζει εξω δια των θυριδων, προκυπτει δια των δικτυωτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.2.10",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 2:10",
      "text": "Αποκρινεται ο αγαπητος μου και λεγει προς εμε, Σηκωθητι, αγαπητη μου, ωραια μου, και ελθε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.2.11",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 2:11",
      "text": "Διοτι ιδου, ο χειμων παρηλθεν, η βροχη διεβη, απηλθε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.2.12",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 2:12",
      "text": "τα ανθη φαινονται εν τη γη ο καιρος του ασματος εφθασε, και η φωνη της τρυγονος ηκουσθη εν τη γη ημων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.2.13",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 2:13",
      "text": "η συκη εξεφερε τους ολυνθους αυτης, και αι αμπελοι με τα ανθη της σταφυλης διαδιδουσιν ευωδιαν σηκωθητι, αγαπητη μου, ωραια μου, και ελθε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.2.14",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Song of Solomon 2:14",
      "text": "Ω περιστερα μου, ητις εισαι εν ταις σχισμαις του βραχου, εν τοις αποκρυφοις των κρημνων, δειξον μοι την οψιν σου, καμε με να ακουσω την φωνην σου διοτι η φωνη σου ειναι γλυκεια και η οψις σου ωραια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.2.15",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Song of Solomon 2:15",
      "text": "Πιασατε εις ημας τας αλωπεκας, τας μικρας αλωπεκας, αιτινες αφανιζουσι τας αμπελους διοτι αι αμπελοι ημων ανθουσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.2.16",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Song of Solomon 2:16",
      "text": "Ο αγαπητος μου ειναι εις εμε και εγω εις αυτον ποιμαινει μεταξυ των κρινων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:song-of-solomon.2.17",
      "translationId": "lxx-greek",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Song of Solomon 2:17",
      "text": "Εωσου πνευση η αυρα της ημερας και φυγωσιν αι σκιαι, επιστρεψον, αγαπητε μου γινου ομοιος με δορκαδα η με σκυμνον ελαφου επι τα ορη τα διεσχισμενα.",
      "paragraphStart": false
    }
  ]
}
