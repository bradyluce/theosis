{
  "chapter": {
    "id": "lxx-greek:joshua.19",
    "translationId": "lxx-greek",
    "bookSlug": "joshua",
    "chapterNumber": 19,
    "referenceLabel": "Joshua 19",
    "summary": "Source text for Joshua 19 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:joshua.19.1",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Joshua 19:1",
      "text": "Και εξηλθεν ο δευτερος κληρος εις τον Συμεων, εις την φυλην των υιων Συμεων κατα τας συγγενειας αυτων και ητο η κληρονομια αυτων εντος της κληρονομιας των υιων Ιουδα.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:joshua.19.2",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Joshua 19:2",
      "text": "Και ελαβον εις κληρονομιαν αυτων Βηρ-σαβεε, και Σαβεε, και Μωλαδα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.3",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Joshua 19:3",
      "text": "και Ασαρ-σουαλ, και Βαλα, και Ασεμ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.4",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Joshua 19:4",
      "text": "και Ελθωλαδ, και Βεθουλ, και Ορμα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.5",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Joshua 19:5",
      "text": "και Σικλαγ, και Βαιθ-μαρκαβωθ, και Ασαρ-σουσα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.6",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Joshua 19:6",
      "text": "και Βαιθ-λεβαωθ, και Σαρουεν, πολεις δεκατρεις, και τας κωμας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.7",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Joshua 19:7",
      "text": "Αειν, Ρεμμων, και Εθερ, και Ασαν, πολεις τεσσαρας, και τας κωμας αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.8",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Joshua 19:8",
      "text": "και πασας τας κωμας τας περιξ των πολεων τουτων εως Βαλαθ-βηρ, ητις ειναι η Ραμαθ κατα μεσημβριαν. Αυτη ειναι κληρονομια της φυλης των υιων Συμεων κατα τας συγγενειας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.9",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Joshua 19:9",
      "text": "Εκ του μεριδιου των υιων Ιουδα εδοθη η κληρονομια των υιων Συμεων, διοτι το μεριδιον των υιων Ιουδα ητο παραπολυ μεγαλον δι' αυτους οθεν οι υιοι Συμεων ελαβον την κληρονομιαν αυτων εντος της κληρονομιας εκεινων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.10",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Joshua 19:10",
      "text": "Και εξηλθεν ο τριτος κληρος εις τους υιους Ζαβουλων κατα τας συγγενειας αυτων και το οριον της κληρονομιας αυτων ητο εως Σαρειδ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.11",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Joshua 19:11",
      "text": "και ανεβαινε το οριον αυτων προς την θαλασσαν και την Μαραλα, και ηρχετο εις την Δαβασαιθ, και εφθανε προς τον χειμαρρον τον κατεναντι Ιοκνεαμ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.12",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Joshua 19:12",
      "text": "και εστρεφεν απο της Σαρειδ, κατα ανατολας ηλιου προς το οριον της Κισλωθ-θαβωρ, και εξηρχετο εις Δαβραθ, και ανεβαινεν εις Ιαφια",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.13",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Joshua 19:13",
      "text": "και εκειθεν εξετεινετο προς ανατολας εις Γιθθα-εφερ, εις Ιττα-κασιν, και εξηρχετο εις Ρεμμων-μεθωαρ προς Νεα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.14",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Joshua 19:14",
      "text": "και περιηρχετο το οριον κατα το βορειον εις Ανναθων, και ετελειονεν εις την κοιλαδα Ιεφθαηλ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.15",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Joshua 19:15",
      "text": "και περιελαμβανε την Κατταθ, και Νααλαλ, και Σιμβρων, και Ιδαλα, και Βηθλεεμ πολεις δωδεκα, και τας κωμας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.16",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "Joshua 19:16",
      "text": "Αυτη ειναι η κληρονομια των υιων Ζαβουλων κατα τας συγγενειας αυτων, αι πολεις αυται και αι κωμαι αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.17",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "Joshua 19:17",
      "text": "Εξηλθεν ο τεταρτος κληρος εις τον Ισσαχαρ, εις τους υιους Ισσαχαρ κατα τας συγγενειας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.18",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "Joshua 19:18",
      "text": "Και ητο το οριον αυτων Ιεζραελ, και Κεσουλωθ, και Σουνημ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.19",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "Joshua 19:19",
      "text": "και Αφεραιμ, και Σαιων, και Αναχαραθ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.20",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "Joshua 19:20",
      "text": "και Ραββιθ, και Κισιων, και Αβες,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.21",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "Joshua 19:21",
      "text": "και Ραιμεθ, και Εν-γαννιμ, και Εν-αδδα και Βαιθ-φασης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.22",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 22,
      "referenceLabel": "Joshua 19:22",
      "text": "και εφθανε το οριον εις Θαβωρ, και Σαχασειμα, και Βαιθ-σεμες, και το οριον αυτων ετελειονεν εις τον Ιορδανην πολεις δεκαεξ, και αι κωμαι αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.23",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 23,
      "referenceLabel": "Joshua 19:23",
      "text": "Αυτη ειναι η κληρονομια της φυλης των υιων Ισσαχαρ κατα τας συγγενειας αυτων, αι πολεις και αι κωμαι αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.24",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 24,
      "referenceLabel": "Joshua 19:24",
      "text": "Και εξηλθεν ο πεμπτος κληρος εις την φυλην των υιων Ασηρ κατα τας συγγενειας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.25",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 25,
      "referenceLabel": "Joshua 19:25",
      "text": "Και ητο το οριον αυτων Χελκαθ, και Αλει, και Βετεν, και Αχσαφ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.26",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 26,
      "referenceLabel": "Joshua 19:26",
      "text": "και Αλαμμελεχ, και Αμαδ, και Μισαλ και εφθανεν εις Καρμελ προς δυσμας και εις Σιχωρ-λιβναθ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.27",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 27,
      "referenceLabel": "Joshua 19:27",
      "text": "και εστρεφε προς ανατολας ηλιου εις την Βαιθ-δαγων, και εφθανεν εις Ζαβουλων και εις την κοιλαδα Ιεφθαηλ προς το βορειον της Βαιθ-εμεκ, και Ναιηλ, και εξηρχετο εις την Χαβουλ κατα τα αριστερα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.28",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 28,
      "referenceLabel": "Joshua 19:28",
      "text": "και Χεβρων, και Ρεωβ, και Αμμων, και Κανα, εως Σιδωνος της μεγαλης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.29",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 29,
      "referenceLabel": "Joshua 19:29",
      "text": "και εστρεφε το οριον εις την Ραμα, και εως της οχυρας πολεως Τυρου, και εστρεφε το οριον εις την Οσα, και ετελειονεν εις την θαλασσαν κατα το μερος του Αχζιβ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.30",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 30,
      "referenceLabel": "Joshua 19:30",
      "text": "και Αμμα, και Αφεκ, και Ρεωβ πολεις εικοσιδυο, και αι κωμαι αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.31",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 31,
      "referenceLabel": "Joshua 19:31",
      "text": "Αυτη ειναι η κληρονομια της φυλης των υιων Ασηρ κατα τας συγγενειας αυτων, αι πολεις αυται και αι κωμαι αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.32",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 32,
      "referenceLabel": "Joshua 19:32",
      "text": "Εξηλθεν ο εκτος κληρος εις τους υιους Νεφθαλι, εις τους υιους Νεφθαλι κατα τας συγγενειας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.33",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 33,
      "referenceLabel": "Joshua 19:33",
      "text": "Και ητο το οριον αυτων απο Ελεφ, απο Αλλον πλησιον Σαανανειμ, και Αδαμι, Νεκεβ, και Ιαβνηλ, εως Λακκουμ, και ετελειονεν εις τον Ιορδανην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.34",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 34,
      "referenceLabel": "Joshua 19:34",
      "text": "και εστρεφε το οριον απο δυσμων εις Αζνωθ-θαβωρ, και εκειθεν εξηρχετο εις Ουκκωκ, και εφθανεν εις Ζαβουλων κατα μεσημβριαν, και εφθανεν εις Ασηρ κατα δυσμας και εις Ιουδα κατα ανατολας ηλιου επι του Ιορδανου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.35",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 35,
      "referenceLabel": "Joshua 19:35",
      "text": "Και ησαν αι τετειχισμεναι πολεις Σηδδιμ, Σερ, και Αμμαθ, Ρακκαθ, και Χιννερωθ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.36",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 36,
      "referenceLabel": "Joshua 19:36",
      "text": "και Αδαμα, και Ραμα, και Ασωρ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.37",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 37,
      "referenceLabel": "Joshua 19:37",
      "text": "και Κεδες, και Εδρει, και Εν-ασωρ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.38",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 38,
      "referenceLabel": "Joshua 19:38",
      "text": "και Ιρων, και Μιγδαληλ, Ωρεμ, και Βαιθ-αναθ, και Βαιθ-σεμες πολεις δεκαεννεα, και αι κωμαι αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.39",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 39,
      "referenceLabel": "Joshua 19:39",
      "text": "Αυτη ειναι η κληρονομια της φυλης των υιων Νεφθαλι κατα τας συγγενειας αυτων, αι πολεις και αι κωμαι αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.40",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 40,
      "referenceLabel": "Joshua 19:40",
      "text": "Εξηλθεν ο εβδομος κληρος εις την φυλην των υιων Δαν κατα τας συγγενειας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.41",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 41,
      "referenceLabel": "Joshua 19:41",
      "text": "Και ητο το οριον της κληρονομιας αυτων Σαραα, και Εσθαολ, και Ιρ-σεμες,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.42",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 42,
      "referenceLabel": "Joshua 19:42",
      "text": "και Σαλαβειν, και Αιαλων, και Ιεθλα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.43",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 43,
      "referenceLabel": "Joshua 19:43",
      "text": "και Αιλων, και Θαμναθα, και Ακκαρων,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.44",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 44,
      "referenceLabel": "Joshua 19:44",
      "text": "και Ελθεκω, και Γιββεθων, και Βααλαθ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.45",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 45,
      "referenceLabel": "Joshua 19:45",
      "text": "και Ιουδ, και Βανη-βαρακ, και Γαθ-ριμμων,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.46",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 46,
      "referenceLabel": "Joshua 19:46",
      "text": "και Με-ιαρκων, και Ρακκων, μετα του οριου του κατεναντι της Ιοππης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.47",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 47,
      "referenceLabel": "Joshua 19:47",
      "text": "Το δε οριον των υιων Δαν παρεταθη υπ' αυτων δια τουτο οι υιοι Δαν ανεβησαν να πολεμησωσι την Λεσεμ και εκυριευσαν αυτην και επαταξαν αυτην εν στοματι μαχαιρας, και εξουσιασαν αυτην και κατωκησαν εν αυτη και ωνομασαν αυτην Λεσεμ Δαν, κατα το ονομα Δαν του πατρος αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.48",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 48,
      "referenceLabel": "Joshua 19:48",
      "text": "Αυτη ειναι η κληρονομια της φυλης των υιων Δαν κατα τας συγγενειας αυτων, αι πολεις αυται και αι κωμαι αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.49",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 49,
      "referenceLabel": "Joshua 19:49",
      "text": "Αφου δε ετελειωσαν μεριζομενοι την γην κατα τα ορια αυτης, οι υιοι Ισραηλ εδωκαν μεταξυ αυτων κληρονομιαν εις τον Ιησουν τον υιον του Ναυη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.50",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 50,
      "referenceLabel": "Joshua 19:50",
      "text": "κατα τον λογον του Κυριου εδωκαν εις αυτον την πολιν, την οποιαν εζητησε, την Θαμναθ-σαραχ εν τω ορει Εφραιμ και εκτισε την πολιν και κατωκησεν εν αυτη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:joshua.19.51",
      "translationId": "lxx-greek",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 51,
      "referenceLabel": "Joshua 19:51",
