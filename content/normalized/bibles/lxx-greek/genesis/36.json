{
  "chapter": {
    "id": "lxx-greek:genesis.36",
    "translationId": "lxx-greek",
    "bookSlug": "genesis",
    "chapterNumber": 36,
    "referenceLabel": "Genesis 36",
    "summary": "Source text for Genesis 36 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:genesis.36.1",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 1,
      "referenceLabel": "Genesis 36:1",
      "text": "Αυτη δε ειναι η γενεαλογια του Ησαυ, οστις ειναι ο Εδωμ.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:genesis.36.2",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 2,
      "referenceLabel": "Genesis 36:2",
      "text": "Ο Ησαυ ελαβε γυναικας εις εαυτον εκ των θυγατερων Χανααν την Αδα, θυγατερα Αιλων του Χετταιου, και την Ολιβαμα, θυγατερα του Ανα, εγγονην Σεβεγων του υαιου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.3",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 3,
      "referenceLabel": "Genesis 36:3",
      "text": "και την Βασεμαθ, θυγατερα του Ισμαηλ, αδελφην του Νεβαιωθ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.4",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 4,
      "referenceLabel": "Genesis 36:4",
      "text": "Εγεννησε δε εις τον Ησαυ η Αδα τον Ελιφας και η Βασεμαθ εγεννησε τον Ραγουηλ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.5",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 5,
      "referenceLabel": "Genesis 36:5",
      "text": "και η Ολιβαμα εγεννησε τον Ιεους και τον Ιεγλομ και τον Κορε. Ουτοι ειναι οι υιοι του Ησαυ, οι γεννηθεντες εις αυτον εν τη γη Χανααν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.6",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 6,
      "referenceLabel": "Genesis 36:6",
      "text": "Ελαβε δε ο Ησαυ τας γυναικας αυτου και τους υιους αυτου και τας θυγατερας αυτου και παντας τους ανθρωπους του οικου αυτου και τα ποιμνια αυτου και παντα τα κτηνη αυτου και παντα τα υπαρχοντα τα οποια απεκτησεν εν γη Χανααν, και υπηγεν εις αλλην γην μακραν απο Ιακωβ του αδελφου αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.7",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 7,
      "referenceLabel": "Genesis 36:7",
      "text": "διοτι τα υπαρχοντα αυτων ησαν τοσον πολλα, ωστε δεν ηδυναντο να κατοικησωσιν ομου και δεν ηδυνατο η γη της παροικησεως αυτων να χωρεση αυτους, εξ αιτιας των κτηνων αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.8",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 8,
      "referenceLabel": "Genesis 36:8",
      "text": "Κατωκησε δε ο Ησαυ εν τω ορει Σηειρ ο Ησαυ ειναι ο Εδωμ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.9",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 9,
      "referenceLabel": "Genesis 36:9",
      "text": "Και αυτη ειναι η γενεαλογια του Ησαυ, πατρος των Εδωμιτων, εν τω ορει Σηειρ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.10",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 10,
      "referenceLabel": "Genesis 36:10",
      "text": "ταυτα ειναι τα ονοματα των υιων του Ησαυ Ελιφας ο υιος της Αδα γυναικος του Ησαυ, Ραγουηλ ο υιος της Βασεμαθ γυναικος του Ησαυ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.11",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 11,
      "referenceLabel": "Genesis 36:11",
      "text": "Και οι υιοι του Ελιφας ησαν Θαιμαν, Ωμαρ, Σωφαρ και Γοθωμ και Κενεζ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.12",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 12,
      "referenceLabel": "Genesis 36:12",
      "text": "Η δε Θαμνα ητο παλλακη του Ελιφας υιου του Ησαυ, και εγεννησεν εις τον Ελιφας τον Αμαληκ ουτοι ησαν οι υιοι της Αδα γυναικος του Ησαυ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.13",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 13,
      "referenceLabel": "Genesis 36:13",
      "text": "Και ουτοι ειναι οι υιοι του Ραγουηλ Ναχαθ και Ζερα, Σομε και Μοζε ουτοι ησαν οι υιοι της Βασεμαθ γυναικος του Ησαυ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.14",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 14,
      "referenceLabel": "Genesis 36:14",
      "text": "Και ουτοι ησαν οι υιοι της Ολιβαμα θυγατρος του Ανα, εγγονης του Σεβεγων, της γυναικος του Ησαυ και εγεννησεν εις τον Ησαυ τον Ιεους και τον Ιεγλομ και τον Κορε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.15",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 15,
      "referenceLabel": "Genesis 36:15",
      "text": "Ουτοι ησαν οι ηγεμονες των υιων Ησαυ οι υιοι του Ελιφας πρωτοτοκου του Ησαυ, ηγεμων Θαιμαν, ηγεμων Ωμαρ, ηγεμων Σωφαρ, ηγεμων Κενεζ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.16",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 16,
      "referenceLabel": "Genesis 36:16",
      "text": "ηγεμων Κορε, ηγεμων Γοθωμ, ηγεμων Αμαληκ ουτοι ειναι οι ηγεμονες του Ελιφας εν τη γη Εδωμ ουτοι ησαν οι υιοι της Αδα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.17",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 17,
      "referenceLabel": "Genesis 36:17",
      "text": "Και ουτοι ησαν οι υιοι του Ραγουηλ υιου του Ησαυ ηγεμων Ναχαθ, ηγεμων Ζερα, ηγεμων Σομε, ηγεμων Μοζε ουτοι ειναι οι ηγεμονες του Ραγουηλ εν τη γη Εδωμ ουτοι ησαν οι υιοι της Βασεμαθ γυναικος του Ησαυ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.18",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 18,
      "referenceLabel": "Genesis 36:18",
      "text": "Και ουτοι ησαν οι υιοι της Ολιβαμα γυναικος του Ησαυ ηγεμων Ιεους, ηγεμων Ιεγλομ, ηγεμων Κορε ουτοι ησαν οι ηγεμονες της Ολιβαμα θυγατρος του Ανα, γυναικος του Ησαυ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.19",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 19,
      "referenceLabel": "Genesis 36:19",
      "text": "Ουτοι ειναι οι υιοι του Ησαυ, οστις ειναι ο Εδωμ και ουτοι οι ηγεμονες αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.20",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 20,
      "referenceLabel": "Genesis 36:20",
      "text": "Ουτοι ειναι οι υιοι του Σηειρ του Χορραιου, οιτινες κατωκουν την γην Λωταν και Σωβαλ και Σεβεγων και Ανα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.21",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 21,
      "referenceLabel": "Genesis 36:21",
      "text": "και Δησων και Εσερ και Δισαν ουτοι ειναι οι ηγεμονες των Χορραιων, των υιων του Σηειρ, εν τη γη Εδωμ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.22",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 22,
      "referenceLabel": "Genesis 36:22",
      "text": "Οι δε υιοι του Λωταν ησαν Χορρι και Αιμαμ αδελφη δε του Λωταν, η Θαμνα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.23",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 23,
      "referenceLabel": "Genesis 36:23",
      "text": "Ουτοι δε ησαν οι υιοι του Σωβαλ Αλβαν και Μαναχαθ και Εβαλ, Σεφω και Ωναμ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.24",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 24,
      "referenceLabel": "Genesis 36:24",
      "text": "Ουτοι δε ησαν οι υιοι του Σεβεγων και Αιε και Ανα ουτος ειναι ο Ανα οστις ευρηκε τα υδατα εν τη ερημω, οτε εβοσκε τους ονους Σεβεγων του πατρος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.25",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 25,
      "referenceLabel": "Genesis 36:25",
      "text": "Ουτοι δε ησαν οι υιοι του Ανα Δησων και Ολιβαμα η θυγατηρ του Ανα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.26",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 26,
      "referenceLabel": "Genesis 36:26",
      "text": "Ουτοι δε ησαν οι υιοι του Δησων Αμαδαν και Ασβαν και Ιθραμ και Χαρραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.27",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 27,
      "referenceLabel": "Genesis 36:27",
      "text": "Ουτοι ησαν οι υιοι του Εσερ Βαλααν και Ζααβαν και Ακαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.28",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 28,
      "referenceLabel": "Genesis 36:28",
      "text": "Ουτοι ησαν οι υιοι του Δισαν Ουζ και Αραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.29",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 29,
      "referenceLabel": "Genesis 36:29",
      "text": "Ουτοι ειναι οι ηγεμονες των Χορραιων ηγεμων Λωταν, ηγεμων Σωβαλ, ηγεμων Σεβεγων, ηγεμων Ανα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.30",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 30,
      "referenceLabel": "Genesis 36:30",
      "text": "ηγεμων Δησων, ηγεμων Εσερ, ηγεμων Δισαν ουτοι ειναι οι ηγεμονες των Χορραιων μεταξυ των ηγεμονων αυτων εν τη γη Σηειρ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.31",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 31,
      "referenceLabel": "Genesis 36:31",
      "text": "Και ουτοι ειναι οι βασιλεις οιτινες εβασιλευσαν εν τη γη Εδωμ, πριν βασιλευση βασιλευς επι τους υιους Ισραηλ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.32",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 32,
      "referenceLabel": "Genesis 36:32",
      "text": "Και εβασιλευσεν εν Εδωμ Βελα, ο υιος του Βεωρ το δε ονομα της πολεως αυτου ητο Δενναβα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.33",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 33,
      "referenceLabel": "Genesis 36:33",
      "text": "Και απεθανεν ο Βελα και εβασιλευσεν αντ' αυτου ο Ιωβαβ, υιος του Ζερα, εκ Βοσορρας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.34",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 34,
      "referenceLabel": "Genesis 36:34",
      "text": "Και απεθανεν ο Ιωβαβ και εβασιλευσεν αντ' αυτου ο Χουσαμ εκ της γης των Θαιμανιτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.35",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 35,
      "referenceLabel": "Genesis 36:35",
      "text": "Και απεθανεν ο Χουσαμ και εβασιλευσεν αντ' αυτου ο Αδαδ, υιος του Βεραδ, ο παταξας τους Μαδιανιτας εν τη πεδιαδι Μωαβ το δε ονομα της πολεως αυτου ητο Αβιθ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.36",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 36,
      "referenceLabel": "Genesis 36:36",
      "text": "Και απεθανεν ο Αδαδ, και εβασιλευσεν αντ' αυτου ο Σαμλα εκ Μασρεκας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.37",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 37,
      "referenceLabel": "Genesis 36:37",
      "text": "Και απεθανεν ο Σαμλα και εβασιλευσεν αντ' αυτου ο Σαουλ εκ Ρεχωβωθ της παρα τον ποταμον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.38",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 38,
      "referenceLabel": "Genesis 36:38",
      "text": "Και απεθανεν ο Σαουλ και εβασιλευσεν αντ' αυτου Βααλ-αναν, ο υιος του Αχβωρ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.39",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 39,
      "referenceLabel": "Genesis 36:39",
      "text": "Και απεθανεν ο Βααλ-αναν, υιος του Αχβωρ, και εβασιλευσεν αντ' αυτου ο Χαδδαρ το δε ονομα της πολεως αυτου ητο Παου και το ονομα της γυναικος αυτου, Μεεταβεηλ, θυγατηρ του Ματραιδ, εγγονη του Μαιζααβ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.40",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 40,
      "referenceLabel": "Genesis 36:40",
      "text": "Και ταυτα ειναι τα ονοματα των ηγεμονων του Ησαυ, κατα τας οικογενειας αυτων, κατα τους τοπους αυτων, κατα τα ονοματα αυτων. ηγεμων Θαμνα, ηγεμων Αλβα, ηγεμων Ιεθεθ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.41",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 41,
      "referenceLabel": "Genesis 36:41",
      "text": "ηγεμων Ολιβαμα, ηγεμων Ηλα, ηγεμων Φινων,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.42",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 42,
      "referenceLabel": "Genesis 36:42",
      "text": "ηγεμων Κενεζ, ηγεμων Θαιμαν, ηγεμων Μιβσαρ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.36.43",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 43,
      "referenceLabel": "Genesis 36:43",
      "text": "ηγεμων Μαγεδιηλ, ηγεμων Ιραμ ουτοι ειναι οι ηγεμονες του Εδωμ, κατα τας κατοικιας αυτων εν τη γη της κτησεως αυτων ουτος ειναι ο Ησαυ, ο πατηρ των Εδωμιτων.",
      "paragraphStart": false
    }
  ]
}
