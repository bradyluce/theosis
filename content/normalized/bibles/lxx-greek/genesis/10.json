{
  "chapter": {
    "id": "lxx-greek:genesis.10",
    "translationId": "lxx-greek",
    "bookSlug": "genesis",
    "chapterNumber": 10,
    "referenceLabel": "Genesis 10",
    "summary": "Source text for Genesis 10 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:genesis.10.1",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Genesis 10:1",
      "text": "Και αυται ειναι αι γενεαλογιαι των υιων του Νωε, Σημ, Χαμ και Ιαφεθ και εγεννηθησαν εις αυτους υιοι μετα τον κατακλυσμον.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:genesis.10.2",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Genesis 10:2",
      "text": "Οι υιοι του Ιαφεθ ησαν Γομερ, και Μαγωγ, και Μαδαι, και Ιαυαν, και Θουβαλ, και Μεσεχ, και Θειρας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.3",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Genesis 10:3",
      "text": "Και οι υιοι του Γομερ, Ασχεναζ, και Ριφαθ, και Θωγαρμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.4",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Genesis 10:4",
      "text": "Και οι υιοι του Ιαυαν, Ελεισα, και Θαρσεις, Κιττειμ, και Δωδανειμ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.5",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Genesis 10:5",
      "text": "Εκ τουτων εμοιρασθησαν αι νησοι των εθνων εις τους τοπους αυτων εκαστου κατα την γλωσσαν αυτου, κατα τας φυλας αυτων, εις τα εθνη αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.6",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Genesis 10:6",
      "text": "Και οι υιοι του Χαμ, Χους, και Μισραιμ, και Φουθ, και Χανααν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.7",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Genesis 10:7",
      "text": "Και οι υιοι του Χους, Σεβα, και Αβιλα, και Σαβθα, και Ρααμα, και Σαβθεκα και οι υιοι του Ρααμα, Σεβα, και Δαιδαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.8",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Genesis 10:8",
      "text": "Και ο Χους εγεννησε τον Νεβρωδ ουτος ηρχισε να ηναι ισχυρος επι της γης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.9",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Genesis 10:9",
      "text": "αυτος ητο ισχυρος κυνηγος ενωπιον του Κυριου δια τουτο λεγεται, Ως Νεβρωδ, ισχυρος κυνηγος ενωπιον του Κυριου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.10",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Genesis 10:10",
      "text": "και η αρχη της βασιλειας αυτου εσταθη Βαβυλων, και Ερεχ, και Αχαδ, και Χαλνε, εν τη γη Σεννααρ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.11",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Genesis 10:11",
      "text": "Εκ της γης εκεινης εξηλθεν ο Ασσουρ, και ωκοδομησε την Νινευη, και την πολιν Ρεχωβωθ, και την Χαλαχ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.12",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Genesis 10:12",
      "text": "και την Ρεσεν μεταξυ της Νινευη και της Χαλαχ αυτη ειναι η πολις η μεγαλη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.13",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Genesis 10:13",
      "text": "Και ο Μισραιμ εγεννησε τους Λουδειμ, και τους Αναμειμ, και τους Λεαβειμ, και τους Ναφθουχειμ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.14",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Genesis 10:14",
      "text": "και τους Πατρουσειμ, και τους Χασλουχειμ, εκ των οποιων εξηλθον οι Φιλισταιοι, και τους Χαφθορειμ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.15",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Genesis 10:15",
      "text": "Και ο Χανααν εγεννησε τον Σιδωνα, πρωτοτοκον αυτου, και τον Χετταιον,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.16",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Genesis 10:16",
      "text": "και τον Ιεβουσαιον, και τον Αμορραιον, και τον Γεργεσαιον,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.17",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Genesis 10:17",
      "text": "και τον Ευαιον, και τον Αρουχαιον, και τον Ασενναιον,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.18",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Genesis 10:18",
      "text": "και τον Αρβαδιον, και τον Σαμαραιον, και τον Αμαθαιον. Και μετα τουτο διεσπαρησαν αι φυλαι των Χαναναιων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.19",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Genesis 10:19",
      "text": "Και ησαν τα ορια των Χαναναιων απο Σιδωνος, καθως υπαγει τις εις Γεραρα, εως Γαζης, και καθως υπαγει τις εις Σοδομα και Γομορρα, και Αδαμα, και Σεβωειμ, εως Λασα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.20",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Genesis 10:20",
      "text": "Ουτοι ειναι οι υιοι του Χαμ, κατα τας φυλας αυτων, κατα τας γλωσσας αυτων, εις τους τοπους αυτων, εις τα εθνη αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.21",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Genesis 10:21",
      "text": "Και εις τον Σημ, τον πατερα παντων των υιων του Εβερ, τον αδελφον Ιαφεθ του μεγαλητερου, εγεννηθησαν και εις αυτον υιοι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.22",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Genesis 10:22",
      "text": "Υιοι του Σημ ησαν Ελαμ, και Ασσουρ, και Αρφαξαδ, και Λουδ, και Αραμ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.23",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Genesis 10:23",
      "text": "Και οι υιοι του Αραμ, Ουζ, και Ουλ, και Γεθερ, και Μας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.24",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Genesis 10:24",
      "text": "Και ο Αρφαξαδ εγεννησε τον Σαλα και ο Σαλα εγεννησε τον Εβερ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.25",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Genesis 10:25",
      "text": "Και εις τον Εβερ εγεννηθησαν δυο υιοι το ονομα του ενος, Φαλεγ διοτι εν ταις ημεραις αυτου διεμερισθη η γη και το ονομα του αδελφου αυτου, Ιοκταν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.26",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Genesis 10:26",
      "text": "Και ο Ιοκταν εγεννησε τον Αλμωδαδ, και τον Σαλεφ, και τον Ασαρμαβεθ, και τον Ιαραχ,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.27",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Genesis 10:27",
      "text": "και τον Αδωραμ, και τον Ουζαλ, και τον Δικλα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.28",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Genesis 10:28",
      "text": "και τον Οβαλ, και τον Αβιμαηλ, και τον Σεβα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.29",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Genesis 10:29",
      "text": "και τον Οφειρ, και τον Αβιλα, και τον Ιωβαβ παντες ουτοι ησαν υιοι του Ιοκταν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.30",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Genesis 10:30",
      "text": "Και η κατοικια αυτων ητο απο Μησα, καθως υπαγει τις εις Σεφαρα, ορος της Ανατολης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.31",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Genesis 10:31",
      "text": "Ουτοι ειναι οι υιοι του Σημ, κατα τας φυλας αυτων, κατα τας γλωσσας αυτων, εις τους τοπους αυτων, κατα τα εθνη αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.10.32",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Genesis 10:32",
      "text": "Αυται ειναι αι φυλαι των υιων του Νωε, κατα τας γενεας αυτων, εις τα εθνη αυτων και εκ τουτων διεσπαρησαν τα εθνη επι της γης μετα τον κατακλυσμον.",
      "paragraphStart": false
    }
  ]
}
