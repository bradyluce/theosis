{
  "chapter": {
    "id": "lxx-greek:genesis.5",
    "translationId": "lxx-greek",
    "bookSlug": "genesis",
    "chapterNumber": 5,
    "referenceLabel": "Genesis 5",
    "summary": "Source text for Genesis 5 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:genesis.5.1",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Genesis 5:1",
      "text": "Τουτο ειναι το βιβλιον της γενεαλογιας του ανθρωπου. Καθ' ην ημεραν εποιησεν ο Θεος τον Αδαμ, κατ' εικονα Θεου εποιησεν αυτον.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:genesis.5.2",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Genesis 5:2",
      "text": "Αρσεν και θηλυ εποιησεν αυτους και ευλογησεν αυτους, και εκαλεσε το ονομα αυτων, Αδαμ, καθ' ην ημεραν εποιησεν αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.3",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Genesis 5:3",
      "text": "Εζησε δε ο Αδαμ εκατον τριακοντα ετη, και εγεννησεν υιον κατα την ομοιωσιν αυτου, κατα την εικονα αυτου, και εκαλεσε το ονομα αυτου Σηθ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.4",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Genesis 5:4",
      "text": "και εγειναν αι ημεραι του Αδαμ, αφου εγεννησε τον Σηθ, οκτακοσια ετη και εγεννησεν υιους και θυγατερας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.5",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Genesis 5:5",
      "text": "και εγειναν πασαι αι ημεραι του Αδαμ, τας οποιας εζησεν, εννεακοσια τριακοντα ετη και απεθανε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.6",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Genesis 5:6",
      "text": "Και εζησεν ο Σηθ εκατον πεντε ετη, και εγεννησε τον Ενως",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.7",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Genesis 5:7",
      "text": "και εζησεν ο Σηθ αφου εγεννησε τον Ενως, οκτακοσια επτα ετη, και εγεννησεν υιους και θυγατερας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.8",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Genesis 5:8",
      "text": "εγειναν δε πασαι αι ημεραι του Σηθ εννεακοσια δωδεκα ετη και απεθανε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.9",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Genesis 5:9",
      "text": "Και εζησεν ο Ενως ενενηκοντα ετη, και εγεννησε τον Καιναν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.10",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Genesis 5:10",
      "text": "εζησε δε ο Ενως, αφου εγεννησε τον Καιναν, οκτακοσια δεκαπεντε ετη, και εγεννησεν υιους και θυγατερας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.11",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Genesis 5:11",
      "text": "και εγειναν πασαι αι ημεραι του Ενως εννεακοσια πεντε ετη και απεθανε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.12",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Genesis 5:12",
      "text": "Και εζησεν ο Καιναν εβδομηκοντα ετη, και εγεννησε τον Μααλαλεηλ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.13",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Genesis 5:13",
      "text": "εζησε δε ο Καιναν, αφου εγεννησε τον Μααλαλεηλ, οκτακοσια τεσσαρακοντα ετη, και εγεννησεν υιους και θυγατερας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.14",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Genesis 5:14",
      "text": "και εγειναν πασαι αι ημεραι του Καιναν εννεακοσια δεκα ετη και απεθανε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.15",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Genesis 5:15",
      "text": "Και εζησεν ο Μααλαλεηλ εξηκοντα πεντε ετη, και εγεννησε τον Ιαρεδ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.16",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Genesis 5:16",
      "text": "εζησε δε ο Μααλαλεηλ, αφου εγεννησε τον Ιαρεδ, οκτακοσια τριακοντα ετη, και εγεννησεν υιους και θυγατερας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.17",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Genesis 5:17",
      "text": "και εγειναν πασαι αι ημεραι του Μααλαλεηλ οκτακοσια ενενηκοντα πεντε ετη και απεθανε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.18",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Genesis 5:18",
      "text": "Και εζησεν ο Ιαρεδ εκατον εξηκοντα δυο ετη, και εγεννησε τον Ενωχ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.19",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Genesis 5:19",
      "text": "εζησε δε ο Ιαρεδ, αφου εγεννησε τον Ενωχ, οκτακοσια ετη, και εγεννησεν υιους και θυγατερας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.20",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Genesis 5:20",
      "text": "και εγειναν πασαι αι ημεραι του Ιαρεδ εννεακοσια εξηκοντα δυο ετη και απεθανε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.21",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Genesis 5:21",
      "text": "Και εζησεν ο Ενωχ εξηκοντα πεντε ετη, και εγεννησε τον Μαθουσαλα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.22",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Genesis 5:22",
      "text": "και περιεπατησεν ο Ενωχ μετα του Θεου, αφου εγεννησε τον Μαθουσαλα, τριακοσια ετη, και εγεννησεν υιους και θυγατερας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.23",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Genesis 5:23",
      "text": "και εγειναν πασαι αι ημεραι του Ενωχ τριακοσια εξηκοντα πεντε ετη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.24",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Genesis 5:24",
      "text": "Και περιεπατησεν ο Ενωχ μετα του Θεου, και δεν ευρισκετο πλεον διοτι μετεθεσεν αυτον ο Θεος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.25",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Genesis 5:25",
      "text": "Και εζησεν ο Μαθουσαλα εκατον ογδοηκοντα επτα ετη, και εγεννησε τον Λαμεχ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.26",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Genesis 5:26",
      "text": "εζησε δε ο Μαθουσαλα, αφου εγεννησε τον Λαμεχ, επτακοσια ογδοηκοντα δυο ετη, και εγεννησεν υιους και θυγατερας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.27",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Genesis 5:27",
      "text": "και εγειναν πασαι αι ημεραι του Μαθουσαλα εννεακοσια εξηκοντα εννεα ετη και απεθανε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.28",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "Genesis 5:28",
      "text": "Εζησε δε ο Λαμεχ εκατον ογδοηκοντα δυο ετη, και εγεννησεν υιον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.29",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "Genesis 5:29",
      "text": "και εκαλεσε το ονομα αυτου Νωε, λεγων, Ουτος θελει ανακουφισει ημας απο του εργου ημων, και απο του μοχθου των χειρων ημων, εξ αιτιας της γης την οποιαν κατηρασθη ο Κυριος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.30",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "Genesis 5:30",
      "text": "Εζησε δε ο Λαμεχ, αφου εγεννησε τον Νωε, πεντακοσια ενενηκοντα πεντε ετη, και εγεννησεν υιους και θυγατερας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.31",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "Genesis 5:31",
      "text": "και εγειναν πασαι αι ημεραι του Λαμεχ επτακοσια εβδομηκοντα επτα ετη και απεθανε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:genesis.5.32",
      "translationId": "lxx-greek",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 32,
      "referenceLabel": "Genesis 5:32",
      "text": "Και ο Νωε ητο ηλικιας πεντακοσιων ετων και εγεννησεν ο Νωε τον Σημ, τον Χαμ, και τον Ιαφεθ.",
      "paragraphStart": false
    }
  ]
}
