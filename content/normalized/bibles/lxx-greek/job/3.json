{
  "chapter": {
    "id": "lxx-greek:job.3",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 3,
    "referenceLabel": "Job 3",
    "summary": "Source text for Job 3 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.3.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Job 3:1",
      "text": "Μετα ταυτα ηνοιξεν ο Ιωβ το στομα αυτου, και κατηρασθη την ημεραν αυτου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.3.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Job 3:2",
      "text": "Και ελαλησεν ο Ιωβ και ειπεν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Job 3:3",
      "text": "Ειθε να χαθη η ημερα καθ' ην εγεννηθην, και η νυξ καθ' ην ειπον, Εγεννηθη αρσενικον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Job 3:4",
      "text": "Η ημερα εκεινη να ηναι σκοτος ο Θεος να μη αναζητηση αυτην ανωθεν, και να μη φεγξη επ' αυτην φως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Job 3:5",
      "text": "Σκοτος και σκια θανατου να αμαυρωσωσιν αυτην γνοφος να επικαθηται επ' αυτην. Να επελθωσιν επ' αυτην ως πικροτατην ημεραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Job 3:6",
      "text": "Την νυκτα εκεινην να κατακρατηση σκοτος να μη συναφθη με τας ημερας του ετους να μη εισελθη εις τον αριθμον των μηνων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Job 3:7",
      "text": "Ιδου, ερημος να ηναι η νυξ εκεινη φωνη χαρμοσυνος να μη επελθη επ' αυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Job 3:8",
      "text": "Να καταρασθωσιν αυτην οι καταρωμενοι τας ημερας, οι ετοιμοι να ανεγειρωσι το πενθος αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Job 3:9",
      "text": "Να σκοτισθωσι τα αστρα της εσπερας αυτης να προσμενη το φως, και να μη ερχηται και να μη ιδη τα βλεφαρα της αυγης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Job 3:10",
      "text": "διοτι δεν εκλεισε τας θυρας της κοιλιας της μητρος μου, και δεν εκρυψε την θλιψιν απο των οφθαλμων μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Job 3:11",
      "text": "Δια τι δεν απεθανον απο μητρας; και δεν εξεπνευσα αμα εξηλθον εκ της κοιλιας;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Job 3:12",
      "text": "Δια τι με υπεδεχθησαν τα γονατα; η δια τι οι μαστοι δια να θηλασω;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Job 3:13",
      "text": "Διοτι τωρα ηθελον κοιμασθαι και ησυχαζει ηθελον υπνωττει τοτε ηθελον εισθαι εις αναπαυσιν,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Job 3:14",
      "text": "μετα βασιλεων και βουλευτων της γης, οικοδομουντων εις εαυτους ερημωσεις",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Job 3:15",
      "text": "η μετα αρχοντων, οιτινες εχουσι χρυσιον, οιτινες εγεμισαν τους οικους αυτων αργυριου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Job 3:16",
      "text": "η ως εξαμβλωμα κεκρυμμενον δεν ηθελον υπαρχει, ως βρεφη μη ιδοντα φως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Job 3:17",
      "text": "Εκει οι ασεβεις παυουσιν απο του να ταραττωσι, και εκει αναπαυονται οι κεκοπιασμενοι",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Job 3:18",
      "text": "εκει αναπαυονται ομου οι αιχμαλωτοι δεν ακουουσι φωνην καταδυναστου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Job 3:19",
      "text": "εκει ειναι ο μικρος και ο μεγας και ο δουλος, ελευθερος του κυριου αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Job 3:20",
      "text": "Δια τι εδοθη φως εις τον δυστυχη, και ζωη εις τον πεπικραμενον την ευχην,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Job 3:21",
      "text": "οιτινες ποθουσι τον θανατον και δεν επιτυγχανουσιν, αν και ανορυττωσιν αυτον μαλλον παρα κεκρυμμενους θησαυρους,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Job 3:22",
      "text": "οιτινες υπερχαιρουσιν, υπερευφραινονται, οταν ευρωσι τον ταφον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Job 3:23",
      "text": "Δια τι εδοθη φως εις ανθρωπον, του οποιου η οδος ειναι κεκρυμμενη, και τον οποιον ο Θεος περιεκλεισε;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Job 3:24",
      "text": "Διοτι προ του φαγητου μου ερχεται ο στεναγμος μου, και οι βρυγμοι μου εκχεονται ως υδατα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Job 3:25",
      "text": "Επειδη εκεινο, το οποιον εφοβουμην, συνεβη εις εμε, και εκεινο, το οποιον ετρομαζον, ηλθεν επ' εμε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.3.26",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Job 3:26",
      "text": "Δεν ειχον ειρηνην ουδε αναπαυσιν ουδε ησυχιαν οργη επηλθεν επ' εμε.",
      "paragraphStart": false
    }
  ]
}
