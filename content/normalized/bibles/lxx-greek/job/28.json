{
  "chapter": {
    "id": "lxx-greek:job.28",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 28,
    "referenceLabel": "Job 28",
    "summary": "Source text for Job 28 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.28.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Job 28:1",
      "text": "Βεβαιως ειναι τοπος του αργυριου οθεν εξαγεται, και τοπος του χρυσιου οπου καθαριζεται",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.28.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Job 28:2",
      "text": "ο σιδηρος λαμβανεται εκ της γης και ο χαλκος χυνεται εκ της πετρας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Job 28:3",
      "text": "Βαλλει μεν ο ανθρωπος ορια εις το σκοτος και ανιχνευει τα παντα μεχρι τελειοτητος τους λιθους του σκοτους και της σκιας του θανατου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Job 28:4",
      "text": "Χειμαρρος εξορμα εκ του τοπου οπου κατοικει υδατα αδοκιμαστα υπο του ποδος ταυτα ολιγοστευουσι και αναχωρουσιν απο των ανθρωπων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Job 28:5",
      "text": "Περι δε της γης, εξ αυτης εξερχεται ο αρτος και υποκατωθεν αυτης ανασκαπτεται ως υπο πυρος",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Job 28:6",
      "text": "οι λιθοι αυτης ειναι τοπος σαπφειρων και εν αυτη χωμα χρυσιου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Job 28:7",
      "text": "Την οδον εκεινην δεν γνωριζει πτηνον και οφθαλμος γυπος δεν ειδεν αυτην",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Job 28:8",
      "text": "τα θηρια δεν επατησαν αυτην, ο αγριος λεων δεν επερασε δι' αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Job 28:9",
      "text": "Εκτεινει την χειρα αυτου επι τον σκληρον βραχον ανατρεπει τα ορη απο της ριζης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Job 28:10",
      "text": "Εγκοπτει ποταμους μεταξυ των βραχων και ο οφθαλμος αυτου ανακαλυπτει παν πολυτιμον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Job 28:11",
      "text": "Δεσμευει των ποταμων την πλημμυραν και το κεκρυμμενον εκφερει εις φως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 12,
      "referenceLabel": "Job 28:12",
      "text": "Αλλ' η σοφια ποθεν θελει ευρεθη; και που ειναι ο τοπος της συνεσεως;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 13,
      "referenceLabel": "Job 28:13",
      "text": "Ο ανθρωπος δεν γνωριζει την τιμην αυτης και δεν ευρισκεται εν τη γη των ζωντων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 14,
      "referenceLabel": "Job 28:14",
      "text": "Η αβυσσος λεγει, δεν ειναι εν εμοι και η θαλασσα λεγει, δεν ειναι μετ' εμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 15,
      "referenceLabel": "Job 28:15",
      "text": "Δεν δυναται να δοθη χρυσιον αντ' αυτης και αργυριον δεν δυναται να ζυγισθη εις ανταλλαγμα αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 16,
      "referenceLabel": "Job 28:16",
      "text": "Δεν δυναται να εκτιμηθη με το χρυσιον του Οφειρ, με τον πολυτιμον ονυχα και σαπφειρον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 17,
      "referenceLabel": "Job 28:17",
      "text": "Το χρυσιον και ο κρυσταλλος δεν δυναται να εξισωθωσι με αυτην και ανταλλαγμα αυτης να γεινη με σκευη καθαρωτατου χρυσιου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 18,
      "referenceLabel": "Job 28:18",
      "text": "Δεν θελει μνημονευθη κοραλλιον, η μαργαριται διοτι η τιμη της σοφιας ειναι υπερτερα των πολυτιμων λιθων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 19,
      "referenceLabel": "Job 28:19",
      "text": "Το τοπαζιον της Αιθιοπιας δεν θελει εξισωθη με αυτην δεν θελει εκτιμηθη με καθαρον χρυσιον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 20,
      "referenceLabel": "Job 28:20",
      "text": "Ποθεν λοιπον ερχεται η σοφια; και που ειναι ο τοπος της συνεσεως;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 21,
      "referenceLabel": "Job 28:21",
      "text": "Ειναι βεβαιως κεκρυμμενη απο των οφθαλμων παντων των ζωντων, και εσκεπασμενη απο των πτηνων του ουρανου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 22,
      "referenceLabel": "Job 28:22",
      "text": "Η απωλεια και ο θανατος λεγουσι, Δια των ωτων ημων ηκουσαμεν την φημην αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 23,
      "referenceLabel": "Job 28:23",
      "text": "Ο Θεος εννοει την οδον αυτης, και αυτος γνωριζει τον τοπον αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 24,
      "referenceLabel": "Job 28:24",
      "text": "Επειδη αυτος θεωρει εως των περατων της γης, βλεπει υποκατω παντος του ουρανου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 25,
      "referenceLabel": "Job 28:25",
      "text": "δια να ζυγιζη το βαρος των ανεμων, και να σταθμιζη τα υδατα με μετρον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.26",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 26,
      "referenceLabel": "Job 28:26",
      "text": "Οτε εκαμε νομον δια την βροχην και οδον δια την αστραπην της βροντης,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.27",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 27,
      "referenceLabel": "Job 28:27",
      "text": "τοτε ειδε και εφανερωσεν αυτην ητοιμασεν αυτην και μαλιστα εξιχνιασεν αυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.28.28",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 28,
      "referenceLabel": "Job 28:28",
      "text": "Και ειπε προς τον ανθρωπον, Ιδου, ο φοβος του Κυριου, ουτος ειναι η σοφια, και η αποχη απο του κακου συνεσις.",
      "paragraphStart": false
    }
  ]
}
