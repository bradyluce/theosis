{
  "chapter": {
    "id": "lxx-greek:job.5",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 5,
    "referenceLabel": "Job 5",
    "summary": "Source text for Job 5 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.5.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Job 5:1",
      "text": "Καλεσον τωρα, εαν τις σοι αποκριθη; και προς τινα των αγιων θελεις αποβλεψει;",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.5.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Job 5:2",
      "text": "Διοτι η οργη φονευει τον αφρονα, και η αγανακτησις θανατονει τον μωρον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Job 5:3",
      "text": "Εγω ειδον τον αφρονα ριζουμενον αλλ' ευθυς προειπα κατηραμενην την κατοικιαν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Job 5:4",
      "text": "Οι υιοι αυτου ειναι μακραν απο της σωτηριας, και καταπιεζονται εμπροσθεν της πυλης, και ουδεις ο ελευθερων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Job 5:5",
      "text": "των οποιων τον θερισμον κατατρωγει ο πεινων, και αρπαζει αυτον εκ των ακανθων και την περιουσιαν αυτων καταπινει ο διψων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Job 5:6",
      "text": "Διοτι εκ του χωματος δεν εξερχεται η θλιψις, ουδε η λυπη βλαστανει εκ της γης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Job 5:7",
      "text": "αλλ' ο ανθρωπος γενναται δια την λυπην, και οι νεοσσοι των αετων δια να πετωσιν υψηλα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Job 5:8",
      "text": "Αλλ' εγω τον Θεον θελω επικαλεσθη, και εν τω Θεω θελω εναποθεσει την υποθεσιν μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Job 5:9",
      "text": "οστις καμνει μεγαλεια ανεξιχνιαστα, θαυμασια αναριθμητα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Job 5:10",
      "text": "οστις διδει βροχην επι το προσωπον της γης, και πεμπει υδατα επι το προσωπον των αγρων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Job 5:11",
      "text": "οστις υψονει τους ταπεινους, και ανεγειρει εις σωτηριαν τους τεθλιμμενους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Job 5:12",
      "text": "οστις διασκεδαζει τας βουλας των πανουργων, και δεν δυνανται αι χειρες αυτων να εκτελεσωσι την επιχειρησιν αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Job 5:13",
      "text": "οστις συλλαμβανει τους σοφους εν τη πανουργια αυτων και η βουλη των δολιων ανατρεπεται",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Job 5:14",
      "text": "την ημεραν απαντωσι σκοτος, και εν μεσημβρια ψηλαφωσι καθως εν νυκτι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Job 5:15",
      "text": "Τον πτωχον ομως λυτρονει εκ της ρομφαιας, εκ του στοματος αυτων και εκ της χειρος του ισχυρου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Job 5:16",
      "text": "Και ο πτωχος εχει ελπιδα, της δε ανομιας το στομα εμφραττεται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Job 5:17",
      "text": "Ιδου, μακαριος ο ανθρωπος, τον οποιον ελεγχει ο Θεος δια τουτο μη καταφρονει την παιδειαν του Παντοδυναμου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Job 5:18",
      "text": "διοτι αυτος πληγονει και επιδενει κτυπα, και αι χειρες αυτου ιατρευουσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Job 5:19",
      "text": "Εν εξ θλιψεσι θελει σε ελευθερωσει και εν τη εβδομη δεν θελει σε εγγισει κακον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Job 5:20",
      "text": "Εν τη πεινη θελει σε λυτρωσει εκ θανατου και εν πολεμω εκ χειρος ρομφαιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Job 5:21",
      "text": "Απο μαστιγος γλωσσης θελεις εισθαι πεφυλαγμενος και δεν θελεις φοβηθη απο του επερχομενου ολεθρου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Job 5:22",
      "text": "Τον ολεθρον και την πειναν θελεις καταγελα και δεν θελεις φοβηθη απο των θηριων της γης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Job 5:23",
      "text": "Διοτι θελεις εχει συμμαχιαν μετα των λιθων της πεδιαδος και τα θηρια του αγρου θελουσιν ειρηνευει μετα σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Job 5:24",
      "text": "Και θελεις γνωρισει οτι ειρηνη ειναι εν τη σκηνη σου, και θελεις επισκεφθη την κατοικιαν σου, και δεν θελει σοι λειπει ουδεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Job 5:25",
      "text": "Και θελεις γνωρισει οτι ειναι πολυ το σπερμα σου, και οι εκγονοι σου ως η βοτανη της γης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.26",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Job 5:26",
      "text": "Θελεις ελθει εις τον ταφον εν βαθει γηρατι, καθως συσσωρευεται η θημωνια του σιτου εν τω καιρω αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.5.27",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Job 5:27",
      "text": "Ιδου, τουτο εξιχνιασαμεν, ουτως εχει ακουσον αυτο και γνωρισον εν σεαυτω.",
      "paragraphStart": false
    }
  ]
}
