{
  "chapter": {
    "id": "lxx-greek:job.30",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 30,
    "referenceLabel": "Job 30",
    "summary": "Source text for Job 30 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.30.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 1,
      "referenceLabel": "Job 30:1",
      "text": "Αλλα τωρα οι νεωτεροι μου την ηλικιαν με περιγελωσι, των οποιων τους πατερας δεν ηθελον καταδεχθη να βαλω μετα των κυνων του ποιμνιου μου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.30.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 2,
      "referenceLabel": "Job 30:2",
      "text": "Και εις τι τωοντι ηδυνατο να με ωφεληση η δυναμις των χειρων αυτων, εις τους οποιους η ισχυς εξελιπε;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 3,
      "referenceLabel": "Job 30:3",
      "text": "Δι' ενδειαν και πειναν ησαν απομεμονωμενοι εφευγον εις γην ανυδρον, σκοτεινην, ηφανισμενην και ερημον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 4,
      "referenceLabel": "Job 30:4",
      "text": "εκοπτον μολοχην πλησιον των θαμνων και την ριζαν των αρκευθων δια τροφην αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 5,
      "referenceLabel": "Job 30:5",
      "text": "Ησαν εκ μεσου δεδιωγμενοι εφωναζον επ' αυτους ως κλεπτας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 6,
      "referenceLabel": "Job 30:6",
      "text": "Κατωκουν εν τοις κρημνοις των χειμαρρων, ταις τρυπαις της γης και τοις βροχοις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 7,
      "referenceLabel": "Job 30:7",
      "text": "Μεταξυ των θαμνων ωγκωντο υποκατω των ακανθων συνηγοντο",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 8,
      "referenceLabel": "Job 30:8",
      "text": "αφρονες και δυσφημοι, εκδεδιωγμενοι εκ της γης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 9,
      "referenceLabel": "Job 30:9",
      "text": "Και τωρα εγω ειμαι το τραγωδιον αυτων, ειμαι και η παροιμια αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 10,
      "referenceLabel": "Job 30:10",
      "text": "Με βδελυττονται, απομακρυνονται απ' εμου, και δεν συστελλονται να πτυωσιν εις το προσωπον μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 11,
      "referenceLabel": "Job 30:11",
      "text": "Επειδη ο Θεος διελυσε την υπεροχην μου και με εθλιψεν, απερριψαν και αυτοι τον χαλινον εμπροσθεν μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 12,
      "referenceLabel": "Job 30:12",
      "text": "Εκ δεξιων ανιστανται οι νεοι απωθουσι τους ποδας μου, και ετοιμαζουσι κατ' εμου τας ολεθριους οδους αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 13,
      "referenceLabel": "Job 30:13",
      "text": "Ανατρεπουσι την οδον μου, επαυξανουσι την συμφοραν μου, χωρις να εχωσι βοηθον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 14,
      "referenceLabel": "Job 30:14",
      "text": "Εφορμωσιν ως σφοδρα πλημμυρα, επι της ερημωσεως μου περικυλιονται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 15,
      "referenceLabel": "Job 30:15",
      "text": "Τρομοι εστραφησαν επ' εμε καταδιωκουσι την ψυχην μου ως ανεμος και η σωτηρια μου παρερχεται ως νεφος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 16,
      "referenceLabel": "Job 30:16",
      "text": "Και τωρα η ψυχη μου εξεχυθη εντος μου ημεραι θλιψεως με κατελαβον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 17,
      "referenceLabel": "Job 30:17",
      "text": "Την νυκτα τα οστα μου διεπερασθησαν εν εμοι, και τα νευρα μου δεν αναπαυονται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 18,
      "referenceLabel": "Job 30:18",
      "text": "Υπο της σφοδρας δυναμεως ηλλοιωθη το ενδυμα μου με περισφιγγει ως το περιλαιμιον του χιτωνος μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 19,
      "referenceLabel": "Job 30:19",
      "text": "Με ερριψεν εις τον πηλον, και ωμοιωθην με χωμα και κονιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 20,
      "referenceLabel": "Job 30:20",
      "text": "Κραζω προς σε, και δεν μοι αποκρινεσαι ισταμαι, και με παραβλεπεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 21,
      "referenceLabel": "Job 30:21",
      "text": "Εγεινες ανελεημων προς εμε δια της κραταιας χειρος σου με μαστιγονεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 22,
      "referenceLabel": "Job 30:22",
      "text": "Με εσηκωσας επι τον ανεμον με επεβιβασας και διελυσας την ουσιαν μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 23,
      "referenceLabel": "Job 30:23",
      "text": "Εξευρω μεν οτι θελεις με φερει εις θανατον και τον οικον τον προσδιωρισμενον εις παντα ζωντα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 24,
      "referenceLabel": "Job 30:24",
      "text": "Αλλα δεν θελει εκτεινει χειρα εις τον ταφον, εαν κραζωσι προς αυτον οταν αφανιζη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 25,
      "referenceLabel": "Job 30:25",
      "text": "Δεν εκλαυσα εγω δια τον οντα εν ημεραις σκληραις, και ελυπηθη η ψυχη μου δια τον πτωχον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.26",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 26,
      "referenceLabel": "Job 30:26",
      "text": "Ενω περιεμενον το καλον, τοτε ηλθε το κακον και ενω ανεμενον το φως, τοτε ηλθε το σκοτος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.27",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 27,
      "referenceLabel": "Job 30:27",
      "text": "Τα εντοσθια μου ανεβρασαν και δεν ανεπαυθησαν ημεραι θλιψεως με προεφθασαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.28",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 28,
      "referenceLabel": "Job 30:28",
      "text": "Περιεπατησα μελαγχροινος ουχι υπο ηλιου εσηκωθην, εβοησα εν συναξει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.29",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 29,
      "referenceLabel": "Job 30:29",
      "text": "Εγεινα αδελφος των δρακοντων και συντροφος των στρουθοκαμηλων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.30",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 30,
      "referenceLabel": "Job 30:30",
      "text": "Το δερμα μου εμαυρισεν επ' εμε, και τα οστα μου κατεκαυθησαν υπο της φλογωσεως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.30.31",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 31,
      "referenceLabel": "Job 30:31",
      "text": "Η δε κιθαρα μου μετεβληθη εις πενθος και το οργανον μου εις φωνην κλαιοντων.",
      "paragraphStart": false
    }
  ]
}
