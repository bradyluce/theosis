{
  "chapter": {
    "id": "lxx-greek:job.26",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 26,
    "referenceLabel": "Job 26",
    "summary": "Source text for Job 26 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.26.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Job 26:1",
      "text": "Και απεκριθη ο Ιωβ και ειπε",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.26.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Job 26:2",
      "text": "Ποσον εβοηθησας τον αδυνατον εσωσας βραχιονα ανισχυρον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.26.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Job 26:3",
      "text": "Ποσον συνεβουλευσας τον ασοφον και εντελη συνεσιν εδειξας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.26.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Job 26:4",
      "text": "Προς τινα απηγγειλας τους λογους; και τινος πνοη εξηλθεν απο σου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.26.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Job 26:5",
      "text": "Οι νεκροι τρεμουσιν αυτον υποκατωθεν των υδατων, και οι συγκατοικουντες μετ' αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.26.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Job 26:6",
      "text": "Γυμνος ο αδης εμπροσθεν αυτου, και η απωλεια δεν εχει σκεπασμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.26.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Job 26:7",
      "text": "Εκτεινει τον βορεαν επι το κενον κρεμα την γην επι το μηδεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.26.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Job 26:8",
      "text": "Δεσμευει τα υδατα εις τας νεφελας αυτου και η νεφελη δεν σχιζεται υποκατω αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.26.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Job 26:9",
      "text": "Σκεπαζει το προσωπον του θρονου αυτου εκτεινει το νεφος αυτου επ' αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.26.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Job 26:10",
      "text": "Περιεκυκλωσε τα υδατα με ορια, εως της συντελειας του φωτος και του σκοτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.26.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Job 26:11",
      "text": "Οι στυλοι του ουρανου τρεμουσι και εξιστανται απο της επιτιμησεως αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.26.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Job 26:12",
      "text": "Ταραττει την θαλασσαν δια της δυναμεως αυτου, και δια της συνεσεως αυτου καταδαμαζει την υπερηφανιαν αυτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.26.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 13,
      "referenceLabel": "Job 26:13",
      "text": "Δια του πνευματος αυτου εκοσμησε τους ουρανους η χειρ αυτου εσχηματισε τον συστρεφομενον οφιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.26.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 14,
      "referenceLabel": "Job 26:14",
      "text": "Ιδου, ταυτα ειναι μερη των οδων αυτου αλλα ποσον ελαχιστον πραγμα ακουομεν περι αυτου; την δε βροντην της δυναμεως αυτου τις δυναται να εννοηση;",
      "paragraphStart": false
    }
  ]
}
