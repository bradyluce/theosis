{
  "chapter": {
    "id": "lxx-greek:job.31",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 31,
    "referenceLabel": "Job 31",
    "summary": "Source text for Job 31 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.31.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 1,
      "referenceLabel": "Job 31:1",
      "text": "Εκαμον συνθηκην μετα των οφθαλμων μου και πως να εχω τον στοχασμον μου επι παρθενον;",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.31.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 2,
      "referenceLabel": "Job 31:2",
      "text": "και τι το μεριδιον παρα Θεου ανωθεν; και η κληρονομια του Παντοδυναμου εκ των υψηλων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 3,
      "referenceLabel": "Job 31:3",
      "text": "Ουχι αφανισμος δια τον ασεβη; και ταλαιπωρια δια τους εργατας της ανομιας;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 4,
      "referenceLabel": "Job 31:4",
      "text": "δεν βλεπει αυτος τας οδους μου και απαριθμει παντα τα βηματα μου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 5,
      "referenceLabel": "Job 31:5",
      "text": "Εαν περιεπατησα με ψευδος, η ο πους μου εσπευσεν εις δολον,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 6,
      "referenceLabel": "Job 31:6",
      "text": "ας με ζυγιση δια της σταθμης της δικαιοσυνης και ας γνωριση ο Θεος την ακεραιοτητα μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 7,
      "referenceLabel": "Job 31:7",
      "text": "αν το βημα μου εξετραπη απο της οδου και η καρδια μου επηκολουθησε τους οφθαλμους μου, και αν κηλις προσεκολληθη εις τας χειρας μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 8,
      "referenceLabel": "Job 31:8",
      "text": "να σπειρω, και αλλος να φαγη και να εκριζωθωσιν οι εκγονοι μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 9,
      "referenceLabel": "Job 31:9",
      "text": "Αν η καρδια μου ηπατηθη υπο γυναικος, η παρεμονευσα εις την θυραν του πλησιον μου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 10,
      "referenceLabel": "Job 31:10",
      "text": "η γυνη μου να αλεση δι' αλλον, και αλλοι να πεσωσιν επ' αυτην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 11,
      "referenceLabel": "Job 31:11",
      "text": "Διοτι μιαρον ανομημα τουτο και αμαρτημα καταδικον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 12,
      "referenceLabel": "Job 31:12",
      "text": "διοτι ειναι πυρ κατατρωγον μεχρις αφανισμου, και ηθελεν εκριζωσει παντα τα γεννηματα μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 13,
      "referenceLabel": "Job 31:13",
      "text": "Αν κατεφρονησα την κρισιν του δουλου μου η της δουλης μου, οτε διεφεροντο προς εμε,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 14,
      "referenceLabel": "Job 31:14",
      "text": "τι θελω καμει τοτε, οταν εγερθη ο Θεος; και οταν επισκεφθη, τι θελω αποκριθη προς αυτον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 15,
      "referenceLabel": "Job 31:15",
      "text": "Ο ποιησας εμε εν τη κοιλια, δεν εποιησε και εκεινον; και δεν εμορφωσεν ημας ο αυτος εν τη μητρα;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 16,
      "referenceLabel": "Job 31:16",
      "text": "Αν ηρνηθην την επιθυμιαν των πτωχων, η εμαρανα τους οφθαλμους της χηρας,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 17,
      "referenceLabel": "Job 31:17",
      "text": "η εφαγον μονος τον αρτον μου, και ο ορφανος δεν εφαγεν εξ αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 18,
      "referenceLabel": "Job 31:18",
      "text": "διοτι ο μεν εκ νεοτητος μου ετρεφετο μετ' εμου, ως μετα πατρος, την δε εκ κοιλιας της μητρος μου ωδηγησα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 19,
      "referenceLabel": "Job 31:19",
      "text": "αν ειδον τινα απολλυμενον δι' ελλειψιν ενδυματος η πτωχον χωρις σκεπασματος,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 20,
      "referenceLabel": "Job 31:20",
      "text": "αν οι νεφροι αυτου δεν με ευλογησαν και δεν εθερμανθη με το μαλλιον των προβατων μου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 21,
      "referenceLabel": "Job 31:21",
      "text": "αν εσηκωσα την χειρα μου κατα του ορφανου, βλεπων οτι υπερισχυον εν τη πυλη,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 22,
      "referenceLabel": "Job 31:22",
      "text": "να πεση ο βραχιων μου εκ του ωμου, και η χειρ μου να συντριφθη εκ του αγκωνος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 23,
      "referenceLabel": "Job 31:23",
      "text": "Διοτι ο παρα του Θεου ολεθρος ητο εις εμε φρικη και δια την μεγαλειοτητα αυτου δεν ηθελον δυνηθη να ανθεξω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 24,
      "referenceLabel": "Job 31:24",
      "text": "Αν εθεσα εις το χρυσιον την ελπιδα μου, η ειπα προς το καθαρον χρυσιον, Συ εισαι το θαρρος μου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 25,
      "referenceLabel": "Job 31:25",
      "text": "αν ευφρανθην διοτι ο πλουτος μου ητο μεγας και διοτι η χειρ μου ευρηκεν αφθονιαν,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.26",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 26,
      "referenceLabel": "Job 31:26",
      "text": "αν εθεωρουν τον ηλιον αναλαμποντα η την σεληνην περιπατουσαν εν τη λαμπροτητι αυτης,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.27",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 27,
      "referenceLabel": "Job 31:27",
      "text": "και η καρδια μου εθελχθη κρυφιως, η με το στομα μου εφιλησα την χειρα μου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.28",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 28,
      "referenceLabel": "Job 31:28",
      "text": "και τουτο ηθελεν εισθαι ανομημα καταδικον διοτι ηθελον αρνηθη τον Θεον τον Υψιστον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.29",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 29,
      "referenceLabel": "Job 31:29",
      "text": "Αν εχαρην εις τον αφανισμον του μισουντος με, η επεχαρην οτε ευρηκεν αυτον κακον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.30",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 30,
      "referenceLabel": "Job 31:30",
      "text": "διοτι ουδε αφηκα το στομα μου να αμαρτηση, ευχομενος καταραν εις την ψυχην αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.31",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 31,
      "referenceLabel": "Job 31:31",
      "text": "αν οι ανθρωποι της σκηνης μου δεν ειπον, τις θελει δειξει ανθρωπον μη χορτασθεντα απο των κρεατων αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.32",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 32,
      "referenceLabel": "Job 31:32",
      "text": "Ο ξενος δεν διενυκτερευεν εξω ηνοιγον την θυραν μου εις τον οδοιπορον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.33",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 33,
      "referenceLabel": "Job 31:33",
      "text": "αν εσκεπασα την παραβασιν μου ως ο Αδαμ, κρυπτων την ανομιαν μου εν τω κολπω μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.34",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 34,
      "referenceLabel": "Job 31:34",
      "text": "διοτι μηπως εφοβουμην μεγα πληθος, η με ετρομαζεν η καταφρονησις των οικογενειων, ωστε να σιωπησω και να μη εκβω εκ της θυρας;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.35",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 35,
      "referenceLabel": "Job 31:35",
      "text": "Ω να ητο τις να με ηκουεν. Ιδου, η επιθυμια μου ειναι να απεκρινετο ο Παντοδυναμος εις εμε, και ο αντιδικος μου να εγραφε βιβλιον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.36",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 36,
      "referenceLabel": "Job 31:36",
      "text": "Βεβαιως ηθελον βαστασει αυτο επι του ωμου μου, ηθελον περιδεσει αυτο στεφανον επ' εμε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.37",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 37,
      "referenceLabel": "Job 31:37",
      "text": "ηθελον φανερωσει προς αυτον τον αριθμον των βηματων μου ως αρχων ηθελον πλησιασει εις αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.38",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 38,
      "referenceLabel": "Job 31:38",
      "text": "Αν ο αγρος μου καταβοα εναντιον μου και κλαιωσιν ομου οι αυλακες αυτου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.39",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 39,
      "referenceLabel": "Job 31:39",
      "text": "αν εφαγον τον καρπον αυτον χωρις μισθον, η εκαμον να εκβη η ψυχη των γεωργων αυτου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.31.40",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 40,
      "referenceLabel": "Job 31:40",
      "text": "Ας φυτρωσωσι τριβολοι αντι σιτου και ζιζανια αντι κριθης. Ετελειωσαν οι λογοι του Ιωβ.",
      "paragraphStart": false
    }
  ]
}
