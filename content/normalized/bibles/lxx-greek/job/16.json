{
  "chapter": {
    "id": "lxx-greek:job.16",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 16,
    "referenceLabel": "Job 16",
    "summary": "Source text for Job 16 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.16.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Job 16:1",
      "text": "Τοτε ο Ιωβ απεκριθη και ειπε",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.16.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Job 16:2",
      "text": "Πολλα τοιαυτα ηκουσα αθλιοι παρηγορηται εισθε παντες.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Job 16:3",
      "text": "Εχουσι τελος αι ματαιολογιαι; η τι σε ενθαρρυνει εις το να αποκρινησαι;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Job 16:4",
      "text": "Και εγω εδυναμην να λαλησω καθως σεις εαν η ψυχη σας ητο εις τον τοπον της ψυχης μου, ηδυναμην να επισωρευσω λογους εναντιον σας, και να κινησω εναντιον σας την κεφαλην μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Job 16:5",
      "text": "Ηθελον σας ενισχυσει με το στομα μου, και η κινησις των χειλεων μου ηθελε σας ανακουφισει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Job 16:6",
      "text": "Αν λαλω, ο πονος μου δεν ανακουφιζεται και αν σιωπω, ποια ελαττωσις γινεται εις εμε;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Job 16:7",
      "text": "Αλλα τωρα με υπερεβαρυνεν ηρημωσας πασαν την συνοδιαν μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Job 16:8",
      "text": "Και αι ρυτιδες με τας οποιας με εσημειωσας, ειναι μαρτυρια και η ισχνοτης μου ανισταμενη εις εμε, μαρτυρει επι του προσωπου μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Job 16:9",
      "text": "Με διασπαραττει ο εχθρος μου εν τω θυμω αυτου και με μισει τριζει τους οδοντας αυτου εναντιον μου οξυνει τους οφθαλμους αυτου επ' εμε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Job 16:10",
      "text": "Ανοιγουσι το στομα αυτων κατ' εμου με τυπτουσι κατα της σιαγονος υβριστικως συνηχθησαν ομου επ' εμε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Job 16:11",
      "text": "Ο Θεος με παρεδωκεν εις τον αδικον, και με ερριψεν εις χειρας ασεβων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Job 16:12",
      "text": "Ημην εν ησυχια, και με κατεσπαραξε και πιασας με απο του τραχηλου, με κατεσυντριψε, και με εθεσε σκοπον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Job 16:13",
      "text": "Οι τοξοται αυτου με περιεκυκλωσαν διαπερα τα νεφρα μου, και δεν φειδεται εκχεει την χολην μου επι την γην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Job 16:14",
      "text": "Με συντριβει με πληγην επι πληγην εδραμεν επ' εμε ως γιγας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Job 16:15",
      "text": "Σακκον ερραψα επι το δερμα μου, και εμολυνα το κερας μου με χωμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Job 16:16",
      "text": "Το προσωπον μου κατεκαη υπο του κλαυθμου, και σκια θανατου ειναι επι των βλεφαρων μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Job 16:17",
      "text": "ενω αδικια δεν υπαρχει εν ταις χερσι μου, και η προσευχη μου ειναι καθαρα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Job 16:18",
      "text": "Ω γη, μη σκεπασης το αιμα μου, και ας μη υπαρχη τοπος δια την κραυγην μου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Job 16:19",
      "text": "και τωρα, ιδου, ο μαρτυς μου ειναι εν τω ουρανω, και η μαρτυρια μου εν τοις υψιστοις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Job 16:20",
      "text": "Οι φιλοι μου ειναι οι εμπαιζοντες με ο οφθαλμος μου σταλαζει δακρυα προς τον Θεον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "Job 16:21",
      "text": "Να ητο δυνατον να διαδικαζηται τις προς τον Θεον, ως ανθρωπος προς τον πλησιον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.16.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "Job 16:22",
      "text": "Διοτι ηλθον τα ηριθμημενα ετη και θελω υπαγει την οδον, οποθεν δεν θελω επιστρεψει.",
      "paragraphStart": false
    }
  ]
}
