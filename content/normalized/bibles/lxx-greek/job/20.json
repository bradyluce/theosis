{
  "chapter": {
    "id": "lxx-greek:job.20",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 20,
    "referenceLabel": "Job 20",
    "summary": "Source text for Job 20 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.20.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Job 20:1",
      "text": "Και απεκριθη Σωφαρ ο Νααμαθιτης και ειπε",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.20.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Job 20:2",
      "text": "Δια τουτο οι στοχασμοι μου με κινουσιν εις το να αποκριθω, και δια τουτο σπευδω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Job 20:3",
      "text": "Ηκουσα την εις εμε ονειδιστικην επιπληξιν, και το πνευμα της συνεσεως μου με καμνει να αποκριθω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Job 20:4",
      "text": "Δεν γνωριζεις τουτο παλαιοθεν αφ' οτου ο ανθρωπος ετεθη επι της γης,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Job 20:5",
      "text": "οτι ο θριαμβος των ασεβων ειναι ολιγοχρονιος, και η χαρα του υποκριτου στιγμαια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Job 20:6",
      "text": "Και αν το μεγαλειον αυτου αναβη εις τους ουρανους και η κεφαλη αυτου φθαση εως των νεφελων,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Job 20:7",
      "text": "θελει αφανισθη διαπαντος ως κοπρος αυτου οσοι εβλεπον αυτον θελουσι λεγει, Που εκεινος;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Job 20:8",
      "text": "θελει πεταξει ως ονειρον και δεν θελει ευρεθη και, ως ορασις της νυκτος θελει εξαφανισθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Job 20:9",
      "text": "Και ο οφθαλμος οστις εβλεπεν αυτον δεν θελει ιδει αυτον πλεον και ο τοπος αυτου δεν θελει πλεον γνωρισει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Job 20:10",
      "text": "Οι υιοι αυτου θελουσι ζητησει την ευνοιαν των πτωχων, και αι χειρες αυτου θελουσιν επιστρεψει τα αγαθα αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Job 20:11",
      "text": "Τα οστα αυτου γεμουσιν απο των αμαρτηματων της νεοτητος αυτου, και θελουσι κοιμηθη μετ' αυτου εν χωματι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Job 20:12",
      "text": "Αν και η κακια ηναι γλυκεια εν τω στοματι αυτου, κρυπτη αυτην υπο την γλωσσαν αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "Job 20:13",
      "text": "αν και περιθαλπη αυτην και δεν αφινη αυτην, αλλα κρατη αυτην εν τω μεσω του ουρανισκου αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 14,
      "referenceLabel": "Job 20:14",
      "text": "ομως η τροφη αυτου θελει αλλοιωθη εις τα εντοσθια αυτου χολη ασπιδων θελει γεινει εν αυτω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 15,
      "referenceLabel": "Job 20:15",
      "text": "Τα πλουτη οσα κατεπιε, θελει εξεμεσει ο Θεος θελει εκσπασει αυτα απο της κοιλιας αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 16,
      "referenceLabel": "Job 20:16",
      "text": "Φαρμακιον ασπιδων θελει θηλασει γλωσσα εχιδνης θελει θανατωσει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 17,
      "referenceLabel": "Job 20:17",
      "text": "Δεν θελει ιδει τους ποταμους, τους ρυακας τους ρεοντας μελι και βουτυρον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 18,
      "referenceLabel": "Job 20:18",
      "text": "Εκεινο, δια το οποιον εκοπιασε, θελει αποδωσει και δεν θελει καταπιει αυτο κατα την αποκτησιν θελει γεινει η αποδοσις αυτου, και δεν θελει χαρη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 19,
      "referenceLabel": "Job 20:19",
      "text": "Διοτι κατεθλιψεν, εγκατελιπε τους πενητας ηρπασεν οικιαν, την οποιαν δεν ωκοδομησε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 20,
      "referenceLabel": "Job 20:20",
      "text": "Βεβαιως δεν θελει γνωρισει αναπαυσιν εν τη κοιλια αυτου δεν θελει διασωσει ουδεν εκ των επιθυμητων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 21,
      "referenceLabel": "Job 20:21",
      "text": "Δεν θελει μεινει εις αυτον ουδεν προς τροφην οθεν δεν θελει ελπισει επι τα αγαθα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 22,
      "referenceLabel": "Job 20:22",
      "text": "Εν τη πληρει αφθονια αυτου θελει επελθει επ' αυτον στενοχωρια πασα η δυναμις της ταλαιπωριας θελει επιπεσει επ' αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 23,
      "referenceLabel": "Job 20:23",
      "text": "Ενω καταγινεται να εμπληση την κοιλιαν αυτου, ο Θεος θελει αποστειλει τον θυμον της οργης αυτου επ' αυτον, και θελει επιβρεξει αυτον κατ' αυτου ενω τρωγει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 24,
      "referenceLabel": "Job 20:24",
      "text": "Ενω φευγει το οπλον το σιδηρουν, το χαλκινον τοξον θελει διαπερασει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 25,
      "referenceLabel": "Job 20:25",
      "text": "Το βελος συρεται και διαπερα το σωμα, και η αστραπτουσα ακμη εξερχεται εκ της χολης αυτου. Τρομοι ειναι επ' αυτον,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.26",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 26,
      "referenceLabel": "Job 20:26",
      "text": "παν σκοτος κρυπτεται εν τοις ταμειοις αυτου πυρ ασβεστον θελει κατατρωγει αυτον οσοι εναπελειφθησαν εν τη σκηνη αυτου θελουσι δυστυχει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.27",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 27,
      "referenceLabel": "Job 20:27",
      "text": "Ο ουρανος θελει ανακαλυψει την ανομιαν αυτου και η γη θελει σηκωθη κατ' αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.28",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 28,
      "referenceLabel": "Job 20:28",
      "text": "Η περιουσια του οικου αυτου θελει αφανισθη θελει διαρρευσει εν τη ημερα της κατ' αυτου οργης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.20.29",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 29,
      "referenceLabel": "Job 20:29",
      "text": "Αυτη ειναι η παρα του Θεου μερις του ασεβους ανθρωπου, και η κληρονομια η διωρισμενη εις αυτον παρα του Θεου.",
      "paragraphStart": false
    }
  ]
}
