{
  "chapter": {
    "id": "lxx-greek:job.37",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 37,
    "referenceLabel": "Job 37",
    "summary": "Source text for Job 37 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.37.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 1,
      "referenceLabel": "Job 37:1",
      "text": "Εις τουτο ετι η καρδια μου τρεμει και εκπηδα απο του τοπου αυτης.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.37.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 2,
      "referenceLabel": "Job 37:2",
      "text": "Ακουσατε προσεκτικως την τρομεραν φωνην αυτου και τον ηχον τον εξερχομενον εκ του στοματος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 3,
      "referenceLabel": "Job 37:3",
      "text": "Αποστελλει αυτην υποκατω παντος του ουρανου και το φως αυτου επι τα εσχατα της γης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 4,
      "referenceLabel": "Job 37:4",
      "text": "Κατοπιν αυτου βοα φωνη βροντα με την φωνην της μεγαλωσυνης αυτου και δεν θελει στησει αυτα, αφου η φωνη αυτου ακουσθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 5,
      "referenceLabel": "Job 37:5",
      "text": "Ο Θεος βροντα θαυμασιως με την φωνην αυτου καμνει μεγαλεια, και δεν εννοουμεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 6,
      "referenceLabel": "Job 37:6",
      "text": "Διοτι λεγει προς την χιονα, γινου επι την γην και προς την ψεκαδα και προς τον υετον της δυναμεως αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 7,
      "referenceLabel": "Job 37:7",
      "text": "Κατασφραγιζει την χειρα παντος ανθρωπου δια να γνωρισωσι παντες οι ανθρωποι το εργον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 8,
      "referenceLabel": "Job 37:8",
      "text": "Τοτε τα θηρια εισερχονται εις τα σπηλαια και κατασκηνουσιν εν τοις τοποις αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 9,
      "referenceLabel": "Job 37:9",
      "text": "Εκ του νοτου ερχεται ο ανεμοστροβιλος, και το ψυχος εκ του βορρα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 10,
      "referenceLabel": "Job 37:10",
      "text": "Εκ του φυσηματος του Θεου διδεται παγος και το πλατος των υδατων στερεουται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 11,
      "referenceLabel": "Job 37:11",
      "text": "Παλιν η γαληνη διασκεδαζει την νεφελην το φως αυτου διασκορπιζει τα νεφη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 12,
      "referenceLabel": "Job 37:12",
      "text": "και αυτα περιφερονται κυκλω υπο τας οδηγιας αυτου, δια να καμνωσι παν ο, τι προσταζει εις αυτα επι το προσωπον της οικουμενης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 13,
      "referenceLabel": "Job 37:13",
      "text": "καμνει αυτα να ερχωνται, η δια παιδειαν, η δια την γην αυτου, η δια ελεος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 14,
      "referenceLabel": "Job 37:14",
      "text": "Ακροασθητι τουτο, Ιωβ σταθητι και συλλογισθητι τα θαυμασια του Θεου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 15,
      "referenceLabel": "Job 37:15",
      "text": "Εννοεις πως ο Θεος διαταττει αυτα, και καμνει να λαμπη το φως της νεφελης αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 16,
      "referenceLabel": "Job 37:16",
      "text": "Εννοεις τα ζυγοσταθμισματα των νεφων, τα θαυμασια του τελειου κατα την γνωσιν;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 17,
      "referenceLabel": "Job 37:17",
      "text": "Δια τι τα ενδυματα σου ειναι θερμα, οταν αναπαυη την γην δια του νοτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 18,
      "referenceLabel": "Job 37:18",
      "text": "Εξηπλωσας μετ' αυτου το στερεωμα το δυνατον ως κατοπτρον χυτον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 19,
      "referenceLabel": "Job 37:19",
      "text": "Διδαξον ημας τι να ειπωμεν προς αυτον ημεις δεν δυναμεθα να διαταξωμεν τους λογους ημων εξ αιτιας του σκοτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 20,
      "referenceLabel": "Job 37:20",
      "text": "Θελει αναγγελθη προς αυτον, εαν εγω λαλω; εαν λαληση ανθρωπος, βεβαιως θελει καταποθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 21,
      "referenceLabel": "Job 37:21",
      "text": "Τωρα δε οι ανθρωποι δεν δυνανται να ατενισωσιν εις το λαμπρον φως, το εν τω στερεωματι, αφου ο ανεμος περαση και καθαριση αυτο,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 22,
      "referenceLabel": "Job 37:22",
      "text": "και χρυσαυγης καιρος ελθη απο βορρα. Φοβερα δοξα υπαρχει εν τω Θεω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 23,
      "referenceLabel": "Job 37:23",
      "text": "Τον Παντοδυναμον, δεν δυναμεθα να εννοησωμεν αυτον ειναι υπεροχος κατα την δυναμιν και κατα την κρισιν και κατα το πληθος της δικαιοσυνης, δεν καταθλιβει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.37.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 24,
      "referenceLabel": "Job 37:24",
      "text": "Δια τουτο οι ανθρωποι φοβουνται αυτον ουδεις σοφος την καρδιαν δυναται να εννοηση αυτον.",
      "paragraphStart": false
    }
  ]
}
