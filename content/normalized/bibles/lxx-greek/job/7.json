{
  "chapter": {
    "id": "lxx-greek:job.7",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 7,
    "referenceLabel": "Job 7",
    "summary": "Source text for Job 7 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.7.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Job 7:1",
      "text": "Δεν ειναι εκστρατεια ο βιος του ανθρωπου επι της γης; αι ημεραι αυτου ως ημεραι μισθωτου;",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.7.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Job 7:2",
      "text": "Καθως ο δουλος επιποθει την σκιαν, και καθως ο μισθωτος αναμενει τον μισθον αυτου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.7.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Job 7:3",
      "text": "ουτως εγω ελαβον δια κληρονομιαν μηνας ματαιοτητος, και οδυνηραι νυκτες διωρισθησαν εις εμε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.7.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Job 7:4",
      "text": "Οταν πλαγιαζω, λεγω, Ποτε θελω εγερθη, και θελει περασει η νυξ; και ειμαι πληρης ανησυχιας εως της αυγης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.7.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Job 7:5",
      "text": "Η σαρξ μου ειναι περιενδεδυμενη σκωληκας και βωλους χωματος το δερμα μου διασχιζεται και ρεει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.7.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Job 7:6",
      "text": "Αι ημεραι μου ειναι ταχυτεραι της κερκιδος του υφαντου, και χανονται ανευ ελπιδος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.7.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Job 7:7",
      "text": "Ενθυμηθητι οτι η ζωη μου ειναι ανεμος ο οφθαλμος μου δεν θελει επιστρεψει δια να ιδη αγαθον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.7.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Job 7:8",
      "text": "Ο οφθαλμος του βλεποντος με δεν θελει με ιδει πλεον οι οφθαλμοι σου ειναι επ' εμε, και εγω δεν υπαρχω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.7.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Job 7:9",
      "text": "Καθως το νεφος διαλυεται και χανεται ουτως ο καταβαινων εις τον ταφον δεν θελει επαναβη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.7.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Job 7:10",
      "text": "δεν θελει επιστρεψει πλεον εις τον οικον αυτου, και ο τοπος αυτου δεν θελει γνωρισει αυτον πλεον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.7.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Job 7:11",
      "text": "Δια τουτο εγω δεν θελω κρατησει το στομα μου θελω λαλησει εν τη αγωνια του πνευματος μου θελω θρηνολογησει εν τη πικρια της ψυχης μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.7.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Job 7:12",
      "text": "Θαλασσα ειμαι η κητος, ωστε εθεσας επ' εμε φυλακην;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.7.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Job 7:13",
      "text": "Οταν λεγω, Η κλινη μου θελει με παρηγορησει, η κοιτη μου θελει ελαφρωσει το παραπονον μου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.7.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Job 7:14",
      "text": "τοτε με φοβιζεις με ονειρα και με καταπληττεις με ορασεις",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.7.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Job 7:15",
      "text": "και η ψυχη μου εκλεγει αγχονην και θανατον, παρα τα οστα μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.7.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Job 7:16",
      "text": "Αηδιασα δεν θελω ζησει εις τον αιωνα λειψον απ' εμου διοτι αι ημεραι μου ειναι ματαιοτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.7.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Job 7:17",
      "text": "Τι ειναι ο ανθρωπος, ωστε μεγαλυνεις αυτον, και βαλλεις τον νουν σου επ' αυτον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.7.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Job 7:18",
      "text": "Και επισκεπτεσαι αυτον κατα πασαν πρωιαν και δοκιμαζεις αυτον κατα πασαν στιγμην;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.7.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Job 7:19",
      "text": "Εως ποτε δεν θελεις συρθη απ' εμου και δεν θελεις με αφησει, εως να καταπιω τον σιελον μου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.7.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Job 7:20",
      "text": "Ημαρτησα τι δυναμαι να καμω εις σε, διατηρητα του ανθρωπου; δια τι με εθεσας σημαδιον σου, και ειμαι βαρος εις εμαυτον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.7.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Job 7:21",
      "text": "Και δια τι δεν συγχωρεις την παραβασιν μου και αφαιρεις την ανομιαν μου; διοτι μετ' ολιγον θελω κοιμασθαι εν τω χωματι και το πρωι θελεις με ζητησει, και δεν θελω υπαρχει.",
      "paragraphStart": false
    }
  ]
}
