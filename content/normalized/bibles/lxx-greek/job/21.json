{
  "chapter": {
    "id": "lxx-greek:job.21",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 21,
    "referenceLabel": "Job 21",
    "summary": "Source text for Job 21 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.21.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Job 21:1",
      "text": "Και απεκριθη ο Ιωβ και ειπεν",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.21.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Job 21:2",
      "text": "Ακουσατε μετα προσοχης την ομιλιαν μου, και τουτο ας ηναι αντι των παρηγοριων σας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Job 21:3",
      "text": "Υποφερετε με να λαλησω και αφου λαλησω, εμπαιζετε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Job 21:4",
      "text": "Μη εις ανθρωπον παραπονουμαι εγω; δια τι λοιπον να μη ταραχθη το πνευμα μου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Job 21:5",
      "text": "Εμβλεψατε εις εμε και θαυμασατε, και βαλετε χειρα επι στοματος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Job 21:6",
      "text": "Μονον να ενθυμηθω, ταραττομαι, και τρομος κυριευει την σαρκα μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Job 21:7",
      "text": "Δια τι οι ασεβεις ζωσι, γηρασκουσι, μαλιστα ακμαζουσιν εις πλουτη;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Job 21:8",
      "text": "Το σπερμα αυτων στερεουται εμπροσθεν αυτων μετ' αυτων, και τα εκγονα αυτων εμπροσθεν των οφθαλμων αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Job 21:9",
      "text": "Αι οικιαι αυτων ειναι ασφαλεις απο φοβου και ραβδος Θεου δεν ειναι επ' αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Job 21:10",
      "text": "Ο βους αυτων συλλαμβανει και δεν αποτυγχανει η δαμαλις αυτων τικτει και δεν αποβαλλει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Job 21:11",
      "text": "Απολυουσι τα τεκνα αυτων ως προβατα, και τα παιδια αυτων σκιρτωσι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Job 21:12",
      "text": "Λαμβανουσι το τυμπανον και την κιθαραν και ευφραινονται εις τον ηχον του οργανου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Job 21:13",
      "text": "Διαγουσι τας ημερας αυτων εν αγαθοις και εν μια στιγμη καταβαινουσιν εις τον αδην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Job 21:14",
      "text": "Και λεγουσι προς τον Θεον, αποστηθι αφ' ημων, διοτι δεν θελομεν να γνωρισωμεν τας οδους σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Job 21:15",
      "text": "τι ειναι ο Παντοδυναμος δια να δουλευωμεν αυτον; και τι ωφελουμεθα επικαλουμενοι αυτον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Job 21:16",
      "text": "Ιδου, τα αγαθα αυτων δεν ειναι εν τη χειρι αυτων μακραν απ' εμου η βουλη των ασεβων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Job 21:17",
      "text": "Ποσακις σβυνεται ο λυχνος των ασεβων, και ερχεται η καταστροφη αυτων επ' αυτους Ο Θεος διαμοιραζει εις αυτους ωδινας εν τη οργη αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Job 21:18",
      "text": "Ειναι ως αχυρον εμπροσθεν του ανεμου και ως κονιορτος, τον οποιον αρπαζει ο ανεμοστροβιλος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Job 21:19",
      "text": "Ο Θεος φυλαττει την ποινην της ανομιας αυτων δια τους υιους αυτων ανταποδιδει εις αυτους, και θελουσι γνωρισει τουτο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Job 21:20",
      "text": "Οι οφθαλμοι αυτων θελουσιν ιδει την καταστροφην αυτων, και θελουσι πιει απο του θυμου του Παντοδυναμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Job 21:21",
      "text": "Διοτι ο ασεβης ποιαν ηδονην εχει μεθ' εαυτον εν τω οικω αυτου, αφου κοπη εις το μεσον ο αριθμος των μηνων αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Job 21:22",
      "text": "Θελει διδαξει τις τον Θεον γνωσιν; και αυτος κρινει τους υψηλους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Job 21:23",
      "text": "Ο μεν αποθνησκει εν τω ακρω της ευδαιμονιας αυτου, ενω ειναι κατα παντα ευτυχης και ησυχος",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Job 21:24",
      "text": "τα πλευρα αυτου ειναι πληρη παχους, και τα οστα αυτου ποτιζονται μυελον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Job 21:25",
      "text": "Ο δε αποθνησκει εν πικρια ψυχης, και ποτε δεν εφαγεν εν ευφροσυνη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.26",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Job 21:26",
      "text": "Θελουσι κοιτεσθαι ομου εν τω χωματι, και σκωληκες θελουσι σκεπασει αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.27",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Job 21:27",
      "text": "Ιδου, γνωριζω τους διαλογισμους σας, και τας πονηριας τας οποιας μηχανασθε κατ' εμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.28",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Job 21:28",
      "text": "Διοτι λεγετε, Που ο οικος του αρχοντος; και που η σκηνη της κατοικησεως των ασεβων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.29",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Job 21:29",
      "text": "Δεν ηρωτησατε τους διαβαινοντας την οδον; και τα σημεια αυτων δεν καταλαμβανετε;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.30",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Job 21:30",
      "text": "Οτι ο ασεβης φυλαττεται εις ημεραν αφανισμου, εις ημεραν οργης φερεται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.31",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Job 21:31",
      "text": "Τις θελει φανερωσει εμπροσθεν αυτου την οδον αυτου; και τις θελει ανταποδωσει εις αυτον ο, τι αυτος επραξε;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.32",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 32,
      "referenceLabel": "Job 21:32",
      "text": "και αυτος θελει φερθη εις τον ταφον, και θελει διαμενει εν τω μνηματι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.33",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 33,
      "referenceLabel": "Job 21:33",
      "text": "Οι βωλοι της κοιλαδος θελουσιν εισθαι γλυκεις εις αυτον, και πας ανθρωπος θελει υπαγει κατοπιν αυτου, καθως αναριθμητοι προπορευονται αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.21.34",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 34,
      "referenceLabel": "Job 21:34",
      "text": "Πως λοιπον με παρηγορειτε ματαιως, αφου εις τας αποκρισεις σας μενει ψευδος;",
      "paragraphStart": false
    }
  ]
}
