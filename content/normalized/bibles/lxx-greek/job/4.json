{
  "chapter": {
    "id": "lxx-greek:job.4",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 4,
    "referenceLabel": "Job 4",
    "summary": "Source text for Job 4 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.4.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Job 4:1",
      "text": "Τοτε Ελιφας ο Θαιμανιτης απεκριθη και ειπεν",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.4.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Job 4:2",
      "text": "Εαν επιχειρισθωμεν να λαλησωμεν προς σε, θελεις δυσαρεστηθη; αλλα τις δυναται να κρατηθη απο του να ομιληση;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.4.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Job 4:3",
      "text": "Ιδου, συ ενουθετησας πολλους και χειρας αδυνατους ενισχυσας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.4.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Job 4:4",
      "text": "Οι λογοι σου υπεστηριξαν τους κλονιζομενους, και γονατα καμπτοντα ενεδυναμωσας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.4.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Job 4:5",
      "text": "Τωρα δε ηλθεν επι σε τουτο, και βαρυθυμεις σε εγγιζει, και ταραττεσαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.4.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Job 4:6",
      "text": "Ο φοβος σου δεν ειναι το θαρρος σου, και η ευθυτης των οδων σου η ελπις σου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.4.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Job 4:7",
      "text": "Ενθυμηθητι, παρακαλω τις αθωος ων απωλεσθη; και που εξωλοθρευθησαν οι ευθεις;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.4.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Job 4:8",
      "text": "Καθως εγω ειδον, οσοι ηροτριασαν ανομιαν και εσπειραν ασεβειαν, θεριζουσιν αυτας",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.4.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Job 4:9",
      "text": "εξολοθρευονται υπο του φυσηματος του Θεου, και απο της πνοης των μυκτηρων αυτου αφανιζονται",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.4.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Job 4:10",
      "text": "ο βρυγμος του λεοντος και η φωνη του αγριου λεοντος και το γαυριαμα των σκυμνων, εσβεσθησαν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.4.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Job 4:11",
      "text": "ο λεων απολλυται δι' ελλειψιν θηραματος, και οι σκυμνοι της λεαινας διασκορπιζονται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.4.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Job 4:12",
      "text": "Και λογος ηλθεν επ' εμε κρυφιως, και το ωτιον μου ελαβε τι παρ' αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.4.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Job 4:13",
      "text": "Εν μεσω των στοχασμων δια τα οραματα της νυκτος, οτε βαθυς υπνος πιπτει επι τους ανθρωπους,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.4.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Job 4:14",
      "text": "Φρικη συνελαβε με και τρομος, και μεγαλως τα οστα μου συνεσεισε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.4.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Job 4:15",
      "text": "Και πνευμα διηλθεν απ' εμπροσθεν μου, αι τριχες του σωματος μου ανεσηκωθησαν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.4.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Job 4:16",
      "text": "εσταθη, αλλ' εγω δεν διεκρινα την μορφην αυτου σχημα εφανη εμπροσθεν των οφθαλμων μου ηκουσα λεπτον φυσημα και φωνην λεγουσαν,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.4.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Job 4:17",
      "text": "Ο ανθρωπος θελει εισθαι δικαιοτερος του Θεου; θελει εισθαι ο ανθρωπος καθαρωτερος του Ποιητου αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.4.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Job 4:18",
      "text": "Ιδου, αυτος δεν εμπιστευεται εις τους δουλους αυτου, και εν τοις αγγελοις αυτου βλεπει ελαττωμα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.4.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Job 4:19",
      "text": "ποσω μαλλον εις τους κατοικουντας οικιας πηλινας, αιτινες εχουσι το θεμελιον αυτων εν τω χωματι και αφανιζονται εμπροσθεν του σαρακιου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.4.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Job 4:20",
      "text": "Απο πρωι εως εσπερας φθειρονται χωρις να νοηση τις, αφανιζονται δια παντος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.4.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Job 4:21",
      "text": "Το μεγαλειον αυτων το εν αυτοις δεν παρερχεται; Αποθνησκουσιν, αλλ' ουχι εν σοφια.",
      "paragraphStart": false
    }
  ]
}
