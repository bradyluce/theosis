{
  "chapter": {
    "id": "lxx-greek:job.24",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 24,
    "referenceLabel": "Job 24",
    "summary": "Source text for Job 24 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.24.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Job 24:1",
      "text": "Επειδη οι καιροι δεν ειναι κεκρυμμενοι απο του Παντοδυναμου, δια τι οι γνωριζοντες αυτον δεν βλεπουσι τας ημερας αυτου;",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.24.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Job 24:2",
      "text": "Μετακινουσιν ορια αρπαζουσι ποιμνια και ποιμαινουσιν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Job 24:3",
      "text": "αφαιρουσι την ονον των ορφανων λαμβανουσι τον βουν της χηρας εις ενεχυρον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Job 24:4",
      "text": "εξωθουσι τους ενδεεις απο της οδου οι πτωχοι της γης ομου κρυπτονται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Job 24:5",
      "text": "Ιδου, ως αγριοι ονοι εν τη ερημω, εξερχονται εις τα εργα αυτων εγειρομενοι πρωι δια αρπαγην η ερημος διδει τροφην δι' αυτους και δια τα τεκνα αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Job 24:6",
      "text": "Θεριζουσιν αγρον μη οντα εαυτων, και τρυγωσιν αμπελον αδικιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Job 24:7",
      "text": "Καμνουσι τους γυμνους να νυκτερευωσιν ανευ ιματιου, και δεν εχουσι σκεπασμα εις το ψυχος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Job 24:8",
      "text": "Υγραινονται εκ των βροχων των ορεων και εναγκαλιζονται τον βραχον, μη εχοντες καταφυγιον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Job 24:9",
      "text": "Εκεινοι αρπαζουσι τον ορφανον απο του μαστου, και λαμβανουσιν ενεχυρον παρα του πτωχου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Job 24:10",
      "text": "καμνουσιν αυτον να υπαγη γυμνος ανευ ιματιου, και οι βασταζοντες τα χειροβολα μενουσι πεινωντες.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 11,
      "referenceLabel": "Job 24:11",
      "text": "Οι εκπιεζοντες το ελαιον εντος των τοιχων αυτων και πατουντες τους ληνους αυτων, διψωσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 12,
      "referenceLabel": "Job 24:12",
      "text": "Ανθρωποι στεναζουσιν εκ της πολεως, και η ψυχη των πεπληγωμενων βοα αλλ' ο Θεος δεν επιθετει εις αυτους αφροσυνην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 13,
      "referenceLabel": "Job 24:13",
      "text": "Ουτοι ειναι εκ των ανθισταμενων εις το φως δεν γνωριζουσι τας οδους αυτου, και δεν μενουσιν εν ταις τριβοις αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 14,
      "referenceLabel": "Job 24:14",
      "text": "Ο φονευς εγειρομενος την αυγην φονευει τον πτωχον και τον ενδεη, την δε νυκτα γινεται ως κλεπτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 15,
      "referenceLabel": "Job 24:15",
      "text": "Ο οφθαλμος ομοιως του μοιχου παραφυλαττει το νυκτωμα, λεγων, Οφθαλμος δεν θελει με ιδει και καλυπτει το προσωπον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 16,
      "referenceLabel": "Job 24:16",
      "text": "Εν τω σκοτει διατρυπωσι τας οικιας, τας οποιας την ημεραν εσημειωσαν δι' εαυτους. Δεν γνωριζουσι φως",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 17,
      "referenceLabel": "Job 24:17",
      "text": "διοτι η αυγη ειναι εις παντας αυτους σκια θανατου εαν τις γνωριση αυτους, ειναι τρομοι σκιας θανατου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 18,
      "referenceLabel": "Job 24:18",
      "text": "Ειναι ελαφροι επι το προσωπον των υδατων η μερις αυτων ειναι κατηραμενη επι της γης δεν βλεπουσι την οδον των αμπελων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 19,
      "referenceLabel": "Job 24:19",
      "text": "Η ξηρασια και η θερμοτης αρπαζουσι τα υδατα της χιονος, ο δε ταφος τους αμαρτωλους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 20,
      "referenceLabel": "Job 24:20",
      "text": "Η μητρα θελει λησμονησει αυτους ο σκωληξ θελει βοσκεσθαι επ' αυτους δεν θελουσιν ελθει πλεον εις ενθυμησιν και η αδικια θελει συντριφθη ως ξυλον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 21,
      "referenceLabel": "Job 24:21",
      "text": "Κακοποιουσι την στειραν την ατεκνον και δεν αγαθοποιουσι την χηραν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 22,
      "referenceLabel": "Job 24:22",
      "text": "και κατακρατουσι τους δυνατους δια της δυναμεως αυτων εγειρονται, και δεν ειναι ουδεις ασφαλης εν τη ζωη αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 23,
      "referenceLabel": "Job 24:23",
      "text": "Εδωκε μεν ο Θεος εις αυτους ασφαλειαν και αναπαυονται ομως οι οφθαλμοι αυτου ειναι επι τας οδους αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 24,
      "referenceLabel": "Job 24:24",
      "text": "Υψονονται ολιγον καιρον και δεν υπαρχουσι, και καταβαλλονται ως παντες σηκονονται εκ του μεσου και αποκοπτονται ως η κεφαλη των ασταχυων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.24.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 25,
      "referenceLabel": "Job 24:25",
      "text": "και εαν τωρα δεν ηναι ουτω, τις θελει με διαψευσει και εξουθενισει τους λογους μου;",
      "paragraphStart": false
    }
  ]
}
