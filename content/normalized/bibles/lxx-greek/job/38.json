{
  "chapter": {
    "id": "lxx-greek:job.38",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 38,
    "referenceLabel": "Job 38",
    "summary": "Source text for Job 38 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.38.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 1,
      "referenceLabel": "Job 38:1",
      "text": "Τοτε απεκριθη ο Κυριος προς τον Ιωβ εκ του ανεμοστροβιλου και ειπε",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.38.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 2,
      "referenceLabel": "Job 38:2",
      "text": "Τις ουτος, οστις σκοτιζει την βουλην μου δια λογων ασυνετων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 3,
      "referenceLabel": "Job 38:3",
      "text": "Ζωσον ηδη την οσφυν σου ως ανηρ διοτι θελω σε ερωτησει, και φανερωσον μοι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 4,
      "referenceLabel": "Job 38:4",
      "text": "Που ησο οτε εθεμελιονον την γην; απαγγειλον, εαν εχης συνεσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 5,
      "referenceLabel": "Job 38:5",
      "text": "Τις εθεσε τα μετρα αυτης, εαν εξευρης; η τις ηπλωσε σταθμην επ' αυτην;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 6,
      "referenceLabel": "Job 38:6",
      "text": "Επι τινος ειναι εστηριγμενα τα θεμελια αυτης; η τις εθεσε τον ακρογωνιαιον λιθον αυτης,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 7,
      "referenceLabel": "Job 38:7",
      "text": "οτε τα αστρα της αυγης εψαλλον ομου και παντες οι υιοι του Θεου ηλαλαζον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 8,
      "referenceLabel": "Job 38:8",
      "text": "η τις συνεκλεισε την θαλασσαν με θυρας, οτε εξορμωσα εξηλθεν εκ μητρας;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 9,
      "referenceLabel": "Job 38:9",
      "text": "οτε περιεβαλον αυτην με νεφελην και με ομιχλην εσπαργανωσα αυτην,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 10,
      "referenceLabel": "Job 38:10",
      "text": "και περιωρισα αυτην δια προσταγματος μου, και εβαλον μοχλους και πυλας,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 11,
      "referenceLabel": "Job 38:11",
      "text": "και ειπα, Εως αυτου θελεις ερχεσθαι και δεν θελεις υπερβη και εδω θελει συντριβεσθαι η υπερηφανια των κυματων σου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 12,
      "referenceLabel": "Job 38:12",
      "text": "Προσεταξας συ την πρωιαν επι των ημερων σου; εδειξας εις την αυγην τον τοπον αυτης,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 13,
      "referenceLabel": "Job 38:13",
      "text": "δια να πιαση τα εσχατα της γης, ωστε οι κακουργοι να εκτιναχθωσιν απ' αυτης;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 14,
      "referenceLabel": "Job 38:14",
      "text": "Αυτη μεταμορφουται ως πηλος σφραγιζομενος και τα παντα παρουσιαζονται ως στολη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 15,
      "referenceLabel": "Job 38:15",
      "text": "Και το φως των ασεβων αφαιρειται απ' αυτων, ο δε βραχιων των υπερηφανων συντριβεται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 16,
      "referenceLabel": "Job 38:16",
      "text": "Εισηλθες εως των πηγων της θαλασσης; η περιεπατησας εις εξιχνιασιν της αβυσσου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 17,
      "referenceLabel": "Job 38:17",
      "text": "Ηνοιχθησαν εις σε του θανατου αι πυλαι; η ειδες τας θυρας της σκιας του θανατου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 18,
      "referenceLabel": "Job 38:18",
      "text": "Εγνωρισας το πλατος της γης; απαγγειλον, εαν ενοησας παντα ταυτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 19,
      "referenceLabel": "Job 38:19",
      "text": "Που ειναι η οδος της κατοικιας του φωτος; και του σκοτους, που ειναι ο τοπος αυτου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 20,
      "referenceLabel": "Job 38:20",
      "text": "δια να συλλαβης αυτο εις το οριον αυτου και να γνωρισης τας τριβους της οικιας αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 21,
      "referenceLabel": "Job 38:21",
      "text": "Γνωριζεις αυτο, διοτι τοτε εγεννηθης; η διοτι ο αριθμος των ημερων σου ειναι πολυς;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 22,
      "referenceLabel": "Job 38:22",
      "text": "Εισηλθες εις τους θησαυρους της χιονος; η ειδες τους θησαυρους της χαλαζης,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 23,
      "referenceLabel": "Job 38:23",
      "text": "τους οποιους φυλαττω δια τον καιρον της θλιψεως δια την ημεραν της μαχης και του πολεμου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 24,
      "referenceLabel": "Job 38:24",
      "text": "Δια τινος οδου διαδιδεται το φως, η ο ανατολικος ανεμος διαχεεται επι την γην;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 25,
      "referenceLabel": "Job 38:25",
      "text": "Τις ηνοιξε ρυακας δια τας ραγδαιας βροχας, η δρομον δια την αστραπην της βροντης,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.26",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 26,
      "referenceLabel": "Job 38:26",
      "text": "δια να φερη βροχην επι γην ακατοικητον, εις ερημον, οπου ανθρωπος δεν υπαρχει,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.27",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 27,
      "referenceLabel": "Job 38:27",
      "text": "δια να χορταση την αβατον και ακατοικητον, και να αναβλαστηση τον βλαστον της χλοης;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.28",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 28,
      "referenceLabel": "Job 38:28",
      "text": "Εχει πατερα η βροχη; η τις εγεννησε τας σταγονας της δροσου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.29",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 29,
      "referenceLabel": "Job 38:29",
      "text": "Απο μητρας τινος εξερχεται ο παγος; και την παχνην του ουρανου, τις εγεννησε;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.30",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 30,
      "referenceLabel": "Job 38:30",
      "text": "Τα υδατα σκληρυνονται ως λιθος, και το προσωπον της αβυσσου πηγνυεται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.31",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 31,
      "referenceLabel": "Job 38:31",
      "text": "Δυνασαι να δεσμευσης τας γλυκειας επιρροας της Πλειαδος η να λυσης τα δεσμα τον Ωριωνος;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.32",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 32,
      "referenceLabel": "Job 38:32",
      "text": "Δυνασαι να εκβαλης τα Ζωδια εις τον καιρον αυτων; η δυνασαι να οδηγησης τον Αρκτουρον μετα των υιων αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.33",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 33,
      "referenceLabel": "Job 38:33",
      "text": "Γνωριζεις τους νομους του ουρανου; δυνασαι να διαταξης τας επιρροας αυτου επι την γην;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.34",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 34,
      "referenceLabel": "Job 38:34",
      "text": "Δυνασαι να υψωσης την φωνην σου εις τα νεφη, δια να σε σκεπαση αφθονια υδατων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.35",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 35,
      "referenceLabel": "Job 38:35",
      "text": "Δυνασαι να αποστειλης αστραπας, ωστε να εξελθωσι και να ειπωσι προς σε, Ιδου, ημεις;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.36",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 36,
      "referenceLabel": "Job 38:36",
      "text": "Τις εβαλε σοφιαν εντος του ανθρωπου; η τις εδωκε συνεσιν εις την καρδιαν αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.37",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 37,
      "referenceLabel": "Job 38:37",
      "text": "Τις δυναται να αριθμηση τα νεφη δια σοφιας; η τις δυναται να κενονη τα δοχεια του ουρανου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.38",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 38,
      "referenceLabel": "Job 38:38",
      "text": "δια να χωνευθη το χωμα εις συμπηξιν και οι βωλοι να συγκολλωνται;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.39",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 39,
      "referenceLabel": "Job 38:39",
      "text": "Θελεις κυνηγησει θηραμα δια τον λεοντα; η χορτασει την ορεξιν των σκυμνων,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.40",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 40,
      "referenceLabel": "Job 38:40",
      "text": "οταν κοιτωνται εν τοις σπηλαιοις και καθηνται εις τους κρυπτηρας δια να ενεδρευωσι;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.38.41",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 41,
      "referenceLabel": "Job 38:41",
      "text": "Τις ετοιμαζει εις τον κορακα την τροφην αυτου, οταν οι νεοσσοι αυτου κραζωσι προς τον Θεον, περιπλανωμενοι δι' ελλειψιν τροφης;",
      "paragraphStart": false
    }
  ]
}
