{
  "chapter": {
    "id": "lxx-greek:job.18",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 18,
    "referenceLabel": "Job 18",
    "summary": "Source text for Job 18 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.18.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Job 18:1",
      "text": "Και απεκριθη Βιλδαδ ο Σαυχιτης και ειπεν",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.18.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Job 18:2",
      "text": "Εως ποτε δεν θελετε τελειωσει τους λογους; προσεξατε, και επειτα θελομεν λαλησει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.18.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Job 18:3",
      "text": "Δια τι λογιζομεθα ως τετραποδα, και εξαχρειουμεθα εμπροσθεν σας;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.18.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Job 18:4",
      "text": "Ω διασπαραττων την ψυχην σου εν τω θυμω σου, δια σε η γη θελει εγκαταλειφθη; και ο βραχος θελει μετακινηθη απο του τοπου αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.18.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Job 18:5",
      "text": "Βεβαιως το φως των ασεβων θελει σβεσθη, και ο σπινθηρ του πυρος αυτων δεν θελει αναλαμψει",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.18.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Job 18:6",
      "text": "το φως θελει εισθαι σκοτος εν τη σκηνη αυτου, και ο λυχνος αυτου ανωθεν αυτου θελει σβεσθη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.18.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Job 18:7",
      "text": "τα βηματα της δυναμεως αυτου θελουσι συσταλθη, και η βουλη αυτου θελει κατακρημνισει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.18.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Job 18:8",
      "text": "Διοτι με τους εαυτου ποδας ερριφθη εις δικτυον, και περιπατει επι βροχων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.18.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Job 18:9",
      "text": "Παγις θελει συλλαβει αυτον απο της πτερνας ο κλεπτης θελει υπερισχυσει κατ' αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.18.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Job 18:10",
      "text": "Η παγις αυτου ειναι κεκρυμμενη εν τη γη, και η ενεδρα αυτου επι της οδου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.18.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Job 18:11",
      "text": "Τρομοι θελουσι φοβιζει αυτον κυκλοθεν, και θελουσι καταδιωκει αυτον κατα ποδας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.18.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Job 18:12",
      "text": "Η δυναμις αυτου θελει λιμοκτονησει, και ολεθρος θελει εισθαι ετοιμος εις την πλευραν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.18.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "Job 18:13",
      "text": "Πρωτοτοκος θανατος θελει καταφαγει το καλλος του δερματος αυτου το καλλος αυτου θελει καταφαγει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.18.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "Job 18:14",
      "text": "Το θαρρος αυτου θελει εκριζωθη απο της σκηνης αυτου, και αυτος θελει συρθη προς τον βασιλεα των τρομων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.18.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "Job 18:15",
      "text": "Ουτοι θελουσι κατοικησει εν τη σκηνη αυτου, ητις δεν ειναι πλεον αυτου θειον θελει διασπαρη επι την κατοικιαν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.18.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 16,
      "referenceLabel": "Job 18:16",
      "text": "Υποκατωθεν αι ριζαι αυτου θελουσι ξηρανθη, και επανωθεν θελει κοπη ο κλαδος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.18.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 17,
      "referenceLabel": "Job 18:17",
      "text": "Το μνημοσυνον αυτου θελει εξαλειφθη απο της γης, και δεν θελει υπαρχει πλεον το ονομα αυτου εν ταις πλατειαις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.18.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 18,
      "referenceLabel": "Job 18:18",
      "text": "Θελει εξωσθη απο του φωτος εις το σκοτος, και θελει εκβληθη απο του κοσμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.18.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 19,
      "referenceLabel": "Job 18:19",
      "text": "Δεν θελει εχει ουτε υιον ουτε εγγονον μεταξυ του λαου αυτου, ουδε υπολοιπον εν ταις κατοικιαις αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.18.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 20,
      "referenceLabel": "Job 18:20",
      "text": "Οι μεταγενεστεροι θελουσιν εκπλαγη δια την ημεραν αυτου, καθως οι προγενεστεροι ελαβον φρικην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.18.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 21,
      "referenceLabel": "Job 18:21",
      "text": "Βεβαιως τοιαυται ειναι αι κατοικιαι του ασεβους, και ουτος ο τοπος του μη γνωριζοντος τον Θεον.",
      "paragraphStart": false
    }
  ]
}
