{
  "chapter": {
    "id": "lxx-greek:job.17",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 17,
    "referenceLabel": "Job 17",
    "summary": "Source text for Job 17 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.17.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Job 17:1",
      "text": "Το πνευμα μου φθειρεται, αι ημεραι μου σβυνονται, οι ταφοι ειναι ετοιμοι δι' εμε.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.17.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Job 17:2",
      "text": "Δεν ειναι χλευασται πλησιον μου; και δεν διανυκτερευει ο οφθαλμος μου εν ταις πικριαις αυτων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.17.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Job 17:3",
      "text": "Ασφαλισον με, δεομαι γενου εις εμε εγγυητης πλησιον σου τις ηθελεν εγγυηθη εις εμε;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.17.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Job 17:4",
      "text": "Διοτι συ εκρυψας την καρδιαν αυτων απο συνεσεως δια τουτο δεν θελεις υψωσει αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.17.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Job 17:5",
      "text": "Του λαλουντος με απατην προς τους φιλους, και οι οφθαλμοι των τεκνων αυτου θελουσι τηκεσθαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.17.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Job 17:6",
      "text": "Και με κατεστησε παροιμιαν των λαων και ενωπιον αυτων κατεσταθην ονειδος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.17.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Job 17:7",
      "text": "Και ο οφθαλμος μου εμαρανθη υπο της θλιψεως, και παντα τα μελη μου εγειναν ως σκια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.17.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Job 17:8",
      "text": "Οι ευθεις θελουσι θαυμασει εις τουτο, και ο αθωος θελει διεγερθη κατα του υποκριτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.17.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Job 17:9",
      "text": "Ο δε δικαιος θελει κρατει την οδον αυτου, και ο καθαρος τας χειρας θελει επαυξησει την δυναμιν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.17.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Job 17:10",
      "text": "σεις δε παντες επιστραφητε, και ελθετε τωρα διοτι ουδενα συνετον θελω ευρει μεταξυ σας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.17.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Job 17:11",
      "text": "Αι ημεραι μου παρηλθον, εκοπησαν οι σκοποι μου, αι επιθυμιαι της καρδιας μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.17.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Job 17:12",
      "text": "Την νυκτα μετεβαλον εις ημεραν το φως ειναι πλησιον του σκοτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.17.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Job 17:13",
      "text": "Εαν προσμενω, ο ταφος ειναι η κατοικια μου εστρωσα την κλινην μου εν τω σκοτει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.17.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Job 17:14",
      "text": "Εβοησα προς την φθοραν, Εισαι, πατηρ μου προς τον σκωληκα, Μητηρ μου και αδελφη μου εισαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.17.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Job 17:15",
      "text": "Και που τωρα η ελπις μου; και την ελπιδα μου τις θελει ιδει;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.17.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Job 17:16",
      "text": "εις το βαθος του αδου θελει καταβη βεβαιως θελει αναπαυθη μετ' εμου εν τω χωματι.",
      "paragraphStart": false
    }
  ]
}
