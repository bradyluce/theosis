{
  "chapter": {
    "id": "lxx-greek:job.6",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 6,
    "referenceLabel": "Job 6",
    "summary": "Source text for Job 6 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.6.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Job 6:1",
      "text": "Ο δε Ιωβ απεκριθη και ειπεν",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.6.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Job 6:2",
      "text": "Ειθε να εζυγιζετο τωοντι η λυπη μου, και η συμφορα μου να ετιθετο ολη ομου εν τη πλαστιγγι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Job 6:3",
      "text": "Επειδη τωρα ηθελεν εισθαι βαρυτερα υπερ την αμμον της θαλασσης δια τουτο οι λογοι μου καταπινονται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Job 6:4",
      "text": "Διοτι τα βελη του Παντοδυναμου ειναι εντος μου, των οποιων το φαρμακιον εκπινει το πνευμα μου οι τρομοι του Θεου παραταττονται εναντιον μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Job 6:5",
      "text": "Ογκαται ο αγριος ονος παρα τη χλοη; η μυκαται ο βους παρα τη φατνη αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Job 6:6",
      "text": "Τρωγεται το ανοστον χωρις αλατος; η υπαρχει γευσις εν τω λευκωματι του ωου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Job 6:7",
      "text": "Τα πραγματα, τα οποια η ψυχη μου απεστρεφετο να εγγιση, εγειναν ως το αηδες φαγητον μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Job 6:8",
      "text": "Ειθε να απελαμβανον την αιτησιν μου, και να μοι εδιδεν ο Θεος την Επιθυμιαν μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Job 6:9",
      "text": "Και να ηθελεν ευδοκησει ο Θεος να με αφανιση να απολυση την χειρα αυτου και να με κοψη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Job 6:10",
      "text": "Και θελει εισθαι ετι η παρηγορια μου, οτι, και αν καταναλωθω εν τη θλιψει και αυτος δεν με λυπηθη, εγω δεν εκρυψα τους λογους του Αγιου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Job 6:11",
      "text": "Ποια η δυναμις μου, ωστε να εγκαρτερω; και ποιον το τελος μου, ωστε να υποφερη η ψυχη μου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Job 6:12",
      "text": "Μηπως η δυναμις μου ειναι δυναμις λιθων; η η σαρξ μου χαλκος;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Job 6:13",
      "text": "Μηπως δεν εξελιπεν εν εμοι η βοηθεια μου και απεμακρυνθη απ' εμου η σωτηρια;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Job 6:14",
      "text": "Εις τον τεθλιμμενον ελεος πρεπει παρα του φιλου αυτου αλλ' αυτος εγκατελιπε τον φοβον του Παντοδυναμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Job 6:15",
      "text": "Οι αδελφοι μου εφερθησαν απατηλως ως χειμαρρος, ως ρευμα χειμαρρων παρηλθον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Job 6:16",
      "text": "οιτινες θολονονται εκ του παγου, εις τους οποιους διαλυεται η χιων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Job 6:17",
      "text": "οταν θερμανθωσιν, εκλειπουσιν οταν γεινη θερμοτης, εξαλειφονται απο του τοπου αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Job 6:18",
      "text": "Τα ιχνη της πορειας αυτων συστρεφονται καταντωσιν εις το μηδεν και χανονται",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Job 6:19",
      "text": "τα πληθη της Θαιμα εθεωρουν, οι συνοδοιποροι της Σεβα περιεμενον αυτους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Job 6:20",
      "text": "Εψευσθησαν της ελπιδος αυτων ηλθον εκει και ενετραπησαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "Job 6:21",
      "text": "Τωρα και σεις εισθε ως αυτοι ειδετε την πληγην μου και ετρομαξατε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "Job 6:22",
      "text": "Μηπως εγω ειπα, Φερετε προς εμε; η, Δοτε δωρον εις εμε απο της περιουσιας υμων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "Job 6:23",
      "text": "η, Ελευθερωσατε με εκ της χειρος του εχθρου; η, Λυτρωσατε με εκ της χειρος των ισχυρων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "Job 6:24",
      "text": "Διδαξατε με, και εγω θελω σιωπησει και δειξατε μοι κατα τι εσφαλα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 25,
      "referenceLabel": "Job 6:25",
      "text": "Ποσον ισχυροι ειναι οι ορθοι λογοι αλλ' ο ελεγχος σας, τι αποδεικνυει;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.26",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 26,
      "referenceLabel": "Job 6:26",
      "text": "Φανταζεσθε να ελεγξητε λογους, ενω αι ομιλιαι του απηλπισμενου ειναι ως ανεμος;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.27",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 27,
      "referenceLabel": "Job 6:27",
      "text": "Τωοντι, σεις επιπιπτετε επι τον ορφανον, και σκαπτετε λακκον εις τον φιλον σας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.28",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 28,
      "referenceLabel": "Job 6:28",
      "text": "Τωρα λοιπον ευαρεστηθητε να εμβλεψητε εις εμε, διοτι εμπροσθεν υμων κειται αν εγω ψευδωμαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.29",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 29,
      "referenceLabel": "Job 6:29",
      "text": "Επιστρεψατε, παρακαλω ας μη γεινη αδικια ναι, επιστρεψατε παλιν η δικαιοσυνη μου ειναι εν τουτω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.6.30",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 30,
      "referenceLabel": "Job 6:30",
      "text": "Υπαρχει αδικια εν τη γλωσση μου; δεν δυναται ο ουρανισκος μου να διακρινη τα διεφθαρμενα;",
      "paragraphStart": false
    }
  ]
}
