{
  "chapter": {
    "id": "lxx-greek:job.13",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 13,
    "referenceLabel": "Job 13",
    "summary": "Source text for Job 13 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.13.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Job 13:1",
      "text": "Ιδου, ταυτα παντα ειδεν ο οφθαλμος μου το ωτιον μου ηκουσε και ενοησε ταυτα.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.13.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Job 13:2",
      "text": "Καθως γνωριζετε σεις, γνωριζω και εγω δεν ειμαι κατωτερος υμων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Job 13:3",
      "text": "Αλλ' ομως θελω λαλησει προς τον Παντοδυναμον, και επιθυμω να διαλεχθω μετα του Θεου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Job 13:4",
      "text": "Σεις δε εισθε εφευρεται ψευδους εισθε παντες ιατροι ανωφελεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Job 13:5",
      "text": "Ειθε να εσιωπατε πανταπασι και τουτο ηθελεν εισθαι εις εσας σοφια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Job 13:6",
      "text": "Ακουσατε τωρα τους λογους μου, και προσεξατε εις τας δικαιολογιας των χειλεων μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Job 13:7",
      "text": "Θελετε λαλει αδικα υπερ του Θεου; και θελετε προφερει δολια υπερ αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Job 13:8",
      "text": "Θελετε καμει προσωποληψιαν υπερ αυτου; θελετε δικολογησει υπερ του Θεου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Job 13:9",
      "text": "Ειναι καλον να σας εξιχνιαση; η καθως ανθρωπος περιγελα ανθρωπον, θελετε περιγελα αυτον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Job 13:10",
      "text": "Εξαπαντος θελει σας εξελεγξει, εαν κρυφιως προσωποληπτητε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Job 13:11",
      "text": "Το μεγαλειον αυτου δεν θελει σας τρομαξει, και ο φοβος αυτου πεσει εφ' υμας;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Job 13:12",
      "text": "τα απομνημονευματα σας ισοδυναμουσι με κονιορτον, τα προπυργια σας με προπυργια χωματος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Job 13:13",
      "text": "Σιωπησατε, αφησατε με, δια να λαλησω εγω, και ας ελθη επ' εμε ο, τι δηποτε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Job 13:14",
      "text": "δια τι πιανω τας σαρκας μου με τους οδοντας μου και βαλλω την ζωην μου εις την χειρα μου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Job 13:15",
      "text": "Και αν με θανατονη, εγω θελω ελπιζει εις αυτον πλην θελω υπερασπισθη τας οδους μου ενωπιον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Job 13:16",
      "text": "Αυτος μαλιστα θελει εισθαι η σωτηρια μου διοτι δεν θελει ελθει ενωπιον αυτου υποκριτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Job 13:17",
      "text": "Ακροασθητε προσεκτικως τον λογον μου, και την παραστασιν μου με τα ωτα σας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Job 13:18",
      "text": "Ιδου τωρα, διεταξα την κρισιν μου εξευρω οτι εγω θελω δικαιωθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Job 13:19",
      "text": "Τις ειναι εκεινος οστις θελει αντιδιαλεχθη μετ' εμου, δια να σιωπησω τωρα και να εκπνευσω;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Job 13:20",
      "text": "Μονον δυο μη καμης εις εμε τοτε δεν θελω κρυφθη απο του προσωπου σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Job 13:21",
      "text": "την χειρα σου απομακρυνον απ' εμου και ο φοβος σου ας μη με τρομαξη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Job 13:22",
      "text": "Επειτα καλεσον, και εγω θελω αποκριθη η ας λαλησω, και αποκριθητι μοι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Job 13:23",
      "text": "Ποσαι ειναι αι ανομιαι μου και αι αμαρτιαι μου; φανερωσον μοι το εγκλημα μου και την αμαρτιαν μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Job 13:24",
      "text": "Δια τι κρυπτεις το προσωπον σου και με θεωρεις ως εχθρον σου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Job 13:25",
      "text": "Θελεις κατατριψει φυλλον φερομενον υπο του ανεμου; και θελεις κατατρεξει αχυρον ξηρον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.26",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 26,
      "referenceLabel": "Job 13:26",
      "text": "Διοτι γραφεις πικριας εναντιον μου, και αποδιδεις εις εμε τας ανομιας της νεοτητος μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.27",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 27,
      "referenceLabel": "Job 13:27",
      "text": "και βαλλεις τους ποδας μου εις δεσμα, και παραφυλαττεις πασας τας οδους μου σημειονεις τα ιχνη των ποδων εμου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.13.28",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 28,
      "referenceLabel": "Job 13:28",
      "text": "οστις φθειρεται ως πραγμα σεσηπος, ως ενδυμα σκωληκοβρωτον.",
      "paragraphStart": false
    }
  ]
}
