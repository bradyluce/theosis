{
  "chapter": {
    "id": "lxx-greek:job.33",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 33,
    "referenceLabel": "Job 33",
    "summary": "Source text for Job 33 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.33.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 1,
      "referenceLabel": "Job 33:1",
      "text": "Δια τουτο, Ιωβ, ακουσον τωρα τας ομιλιας μου, και ακροασθητι παντας τους λογους μου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.33.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 2,
      "referenceLabel": "Job 33:2",
      "text": "Ιδου, τωρα ηνοιξα το στομα μου η γλωσσα μου λαλει εν τω στοματι μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 3,
      "referenceLabel": "Job 33:3",
      "text": "Οι λογοι μου θελουσιν εισθαι κατα την ευθυτητα της καρδιας μου και τα χειλη μου θελουσι προφερει γνωσιν καθαραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 4,
      "referenceLabel": "Job 33:4",
      "text": "Το Πνευμα του Θεου με εκαμε και η πνοη του Παντοδυναμου με εζωοποιησεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 5,
      "referenceLabel": "Job 33:5",
      "text": "Εαν δυνασαι, αποκριθητι μοι παραταχθητι εμπροσθεν μου στηθι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 6,
      "referenceLabel": "Job 33:6",
      "text": "Ιδου, εγω ειμαι κατα τον λογον σου απο μερους του Θεου εκ πηλου ειμαι και εγω μεμορφωμενος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 7,
      "referenceLabel": "Job 33:7",
      "text": "Ιδου, ο τρομος μου δεν θελει σε ταραξει, ουδε η χειρ μου θελει εισθαι βαρεια επι σε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 8,
      "referenceLabel": "Job 33:8",
      "text": "Συ τωοντι ειπας εις τα ωτα μου, και ηκουσα την φωνην των λογων σου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 9,
      "referenceLabel": "Job 33:9",
      "text": "Ειμαι καθαρος χωρις αμαρτιας ειμαι αθωος και ανομια δεν υπαρχει εν εμοι",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 10,
      "referenceLabel": "Job 33:10",
      "text": "ιδου, ευρισκει αφορμας εναντιον μου με νομιζει εχθρον αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 11,
      "referenceLabel": "Job 33:11",
      "text": "βαλλει τους ποδας μου εν τω ξυλω παραφυλαττει πασας τας οδους μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 12,
      "referenceLabel": "Job 33:12",
      "text": "Ιδου, κατα τουτο δεν εισαι δικαιος θελω αποκριθη προς σε, διοτι ο Θεος ειναι μεγαλητερος του ανθρωπου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 13,
      "referenceLabel": "Job 33:13",
      "text": "Δια τι αντιμαχεσαι προς αυτον; διοτι δεν διδει λογον περι ουδεμιας των πραξεων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 14,
      "referenceLabel": "Job 33:14",
      "text": "Διοτι ο Θεος λαλει απαξ και δις, αλλ' ο ανθρωπος δεν προσεχει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 15,
      "referenceLabel": "Job 33:15",
      "text": "Εν ενυπνιω, εν ορασει νυκτερινη, οτε βαθυς υπνος πιπτει επι τους ανθρωπους, οτε υπνωττουσιν επι της κλινης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 16,
      "referenceLabel": "Job 33:16",
      "text": "τοτε ανοιγει τα ωτα των ανθρωπων, και επισφραγιζει την προς αυτους νουθεσιαν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 17,
      "referenceLabel": "Job 33:17",
      "text": "δια να αποστρεψη τον ανθρωπον απο των πραξεων αυτου και να εκβαλη την υπερηφανιαν εκ του ανθρωπου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 18,
      "referenceLabel": "Job 33:18",
      "text": "Προλαμβανει την ψυχην αυτου απο του λακκου και την ζωην αυτου απο του να διαπερασθη υπο ρομφαιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 19,
      "referenceLabel": "Job 33:19",
      "text": "Παλιν, τιμωρειται με πονους επι της κλινης αυτου, και το πληθος των οστεων αυτου με δυνατους πονους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 20,
      "referenceLabel": "Job 33:20",
      "text": "ωστε η ζωη αυτου αποστρεφεται τον αρτον και η ψυχη αυτου το επιθυμητον φαγητον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 21,
      "referenceLabel": "Job 33:21",
      "text": "η σαρξ αυτου αναλισκεται, ωστε δεν φαινεται, και τα οστα αυτου τα αφανη εξεχουσιν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 22,
      "referenceLabel": "Job 33:22",
      "text": "η δε ψυχη αυτου πλησιαζει εις τον λακκον και η ζωη αυτου εις τους φονευτας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 23,
      "referenceLabel": "Job 33:23",
      "text": "Εαν ηναι μηνυτης μετ' αυτου η ερμηνευτης, εις μεταξυ χιλιων, δια να αναγγειλη προς τον ανθρωπον την ευθυτητα αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 24,
      "referenceLabel": "Job 33:24",
      "text": "τοτε θελει εισθαι ιλεως εις αυτον και θελει ειπει, Λυτρωσον αυτον απο του να καταβη εις τον λακκον εγω ευρηκα εξιλασμον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 25,
      "referenceLabel": "Job 33:25",
      "text": "Η σαρξ αυτου θελει εισθαι ανθηροτερα νηπιου θελει επιστρεψει εις τας ημερας της νεοτητος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.26",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 26,
      "referenceLabel": "Job 33:26",
      "text": "θελει δεηθη του Θεου και θελει ευνοησει προς αυτον και θελει βλεπει το προσωπον αυτου εν χαρα και θελει αποδωσει εις τον ανθρωπον την δικαιοσυνην αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.27",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 27,
      "referenceLabel": "Job 33:27",
      "text": "Θελει βλεπει προς τους ανθρωπους και θελει λεγει, Ημαρτησα και διεστρεψα το ορθον, και δεν με ωφελησεν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.28",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 28,
      "referenceLabel": "Job 33:28",
      "text": "αλλ' αυτος ελυτρωσε την ψυχην μου απο του να υπαγη εις τον λακκον και η ζωη μου θελει ιδει το φως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.29",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 29,
      "referenceLabel": "Job 33:29",
      "text": "Ιδου, παντα ταυτα εργαζεται ο Θεος δις και τρις μετα του ανθρωπου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.30",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 30,
      "referenceLabel": "Job 33:30",
      "text": "δια να αποστρεψη την ψυχην αυτου απο του λακκου, ωστε να φωτισθη εν τω φωτι των ζωντων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.31",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 31,
      "referenceLabel": "Job 33:31",
      "text": "Προσεχε, Ιωβ, ακουσον μου σιωπα, και εγω θελω λαλησει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.32",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 32,
      "referenceLabel": "Job 33:32",
      "text": "Εαν εχης τι να ειπης, αποκριθητι μοι λαλησον, διοτι επιθυμω να δικαιωθης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.33.33",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 33,
      "referenceLabel": "Job 33:33",
      "text": "Ει δε μη, συ ακουσον μου σιωπα και θελω σε διδαξει σοφιαν.",
      "paragraphStart": false
    }
  ]
}
