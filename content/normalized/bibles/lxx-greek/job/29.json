{
  "chapter": {
    "id": "lxx-greek:job.29",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 29,
    "referenceLabel": "Job 29",
    "summary": "Source text for Job 29 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.29.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Job 29:1",
      "text": "Και εξηκολουθησεν ο Ιωβ την παραβολην αυτου και ειπεν",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.29.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Job 29:2",
      "text": "Ω να ημην ως εις τους παρελθοντας μηνας, ως εν ταις ημεραις οτε ο Θεος με εφυλαττεν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Job 29:3",
      "text": "οτε ο λυχνος αυτου εφεγγεν επι της κεφαλης μου, και δια του φωτος αυτου περιεπατουν εν τω σκοτει",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Job 29:4",
      "text": "καθως ημην εν ταις ημεραις της ακμης μου, οτε η ευνοια του Θεου ητο επι την σκηνην μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Job 29:5",
      "text": "οτε ο Παντοδυναμος ητο μετ' εμου, και τα παιδια μου κυκλω μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Job 29:6",
      "text": "οτε επλυνον τα βηματα μου με βουτυρον, και ο βραχος εξεχεε δι' εμε ποταμους ελαιου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Job 29:7",
      "text": "οτε δια της πολεως εξηρχομην εις την πυλην, ητοιμαζον την καθεδραν μου εν τη πλατεια",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Job 29:8",
      "text": "Οι νεοι με εβλεπον και εκρυπτοντο και οι γεροντες εγειρομενοι ισταντο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Job 29:9",
      "text": "Οι αρχοντες επαυον ομιλουντες και εβαλλον χειρα επι το στομα αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Job 29:10",
      "text": "Η φωνη των εγκριτων εκρατειτο, και η γλωσσα αυτων εκολλατο εις τον ουρανισκον αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Job 29:11",
      "text": "Οτε το ωτιον ηκουε και με εμακαριζε, και ο οφθαλμος εβλεπε και εμαρτυρει υπερ εμου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 12,
      "referenceLabel": "Job 29:12",
      "text": "διοτι ηλευθερουν τον πτωχον βοωντα και τον ορφανον τον μη εχοντα βοηθον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 13,
      "referenceLabel": "Job 29:13",
      "text": "Η ευλογια του απολλυμενου ηρχετο επ' εμε και την καρδιαν της χηρας ευφραινον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 14,
      "referenceLabel": "Job 29:14",
      "text": "Εφορουν δικαιοσυνην και ενεδυομην την ευθυτητα μου ως επενδυτην και διαδημα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 15,
      "referenceLabel": "Job 29:15",
      "text": "Ημην οφθαλμος εις τον τυφλον και πους εις τον χωλον εγω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 16,
      "referenceLabel": "Job 29:16",
      "text": "Ημην πατηρ εις τους πτωχους, και την δικην την οποιαν δεν εγνωριζον εξιχνιαζον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 17,
      "referenceLabel": "Job 29:17",
      "text": "Και συνετριβον τους κυνοδοντας του αδικου και απεσπων το θηραμα απο των οδοντων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 18,
      "referenceLabel": "Job 29:18",
      "text": "Τοτε ελεγον, θελω αποθανει εν τη φωλεα μου και ως την αμμον θελω πολλαπλασιασει τας ημερας μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 19,
      "referenceLabel": "Job 29:19",
      "text": "Η ριζα μου ητο ανοικτη προς τα υδατα, και η δροσος διενυκτερευεν επι των κλαδων μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 20,
      "referenceLabel": "Job 29:20",
      "text": "Η δοξα μου ανενεουτο εν εμοι, και το τοξον μου εκρατυνετο εν τη χειρι μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 21,
      "referenceLabel": "Job 29:21",
      "text": "Με ηκροαζοντο προσεχοντες και εις την συμβουλην μου εσιωπων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 22,
      "referenceLabel": "Job 29:22",
      "text": "Μετα τους λογους μου δεν προσεθετον ουδεν, και η ομιλια μου εσταλαζεν επ' αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 23,
      "referenceLabel": "Job 29:23",
      "text": "Και με περιεμενον ως την βροχην και ησαν κεχηνοτες ως δια την οψιμον βροχην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 24,
      "referenceLabel": "Job 29:24",
      "text": "Εγελων προς αυτους, και δεν επιστευον και την φαιδροτητα του προσωπου μου δεν αφινον να πεση.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.29.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 25,
      "referenceLabel": "Job 29:25",
      "text": "Εαν ηρεσκομην εις την οδον αυτων, εκαθημην πρωτος, και κατεσκηνουν ως βασιλευς εν τω στρατευματι, ως ο παρηγορων τους τεθλιμμενους.",
      "paragraphStart": false
    }
  ]
}
