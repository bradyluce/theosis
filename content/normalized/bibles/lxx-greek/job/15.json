{
  "chapter": {
    "id": "lxx-greek:job.15",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 15,
    "referenceLabel": "Job 15",
    "summary": "Source text for Job 15 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.15.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Job 15:1",
      "text": "Τοτε απεκριθη Ελιφας ο Θαιμανιτης και ειπεν",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.15.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Job 15:2",
      "text": "Επρεπε σοφος να προφερη στοχασμους ματαιους και να γεμιζη την κοιλιαν αυτου απο ανατολικου ανεμου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Job 15:3",
      "text": "Επρεπε να φιλονεικη δια λογων ματαιων και ομιλιων ανωφελων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Job 15:4",
      "text": "Βεβαιως συ απορριπτεις τον φοβον και αποκλειεις την δεησιν ενωπιον του Θεου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Job 15:5",
      "text": "Διοτι το στομα σου αποδεικνυει την ανομιαν σου, και εξελεξας την γλωσσαν των πανουργων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Job 15:6",
      "text": "Το στομα σου σε καταδικαζει, και ουχι εγω και τα χειλη σου καταμαρτυρουσιν εναντιον σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Job 15:7",
      "text": "Μη πρωτος ανθρωπος εγεννηθης; η προ των βουνων επλασθης;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Job 15:8",
      "text": "Μηπως ηκουσας τας βουλας του Θεου; και εξηντλησας εις σεαυτον την σοφιαν;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Job 15:9",
      "text": "Τι εξευρεις, και δεν εξευρομεν; τι εννοεις, και δεν εννοουμεν;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Job 15:10",
      "text": "Υπαρχουσι και μεταξυ ημων πολιοι και γεροντες, γεροντοτεροι του πατρος σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Job 15:11",
      "text": "Αι παρηγοριαι του Θεου φαινονται μικρον πραγμα εις σε; η εχεις τι αποκρυφον εν σεαυτω;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Job 15:12",
      "text": "Δια τι σε αποπλανα η καρδια σου; και δια τι παραφερονται οι οφθαλμοι σου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Job 15:13",
      "text": "ωστε στρεφεις το πνευμα σου κατα του Θεου και αφινεις να εξερχωνται τοιουτοι λογοι εκ του στοματος σου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Job 15:14",
      "text": "Τι ειναι ο ανθρωπος, ωστε να ηναι καθαρος; και ο γεγεννημενος εκ γυναικος, ωστε να ηναι δικαιος;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Job 15:15",
      "text": "Ιδου, εις τους αγιους αυτου δεν εμπιστευεται και οι ουρανοι δεν ειναι καθαροι εις τους οφθαλμους αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Job 15:16",
      "text": "ποσω μαλλον βδελυρος και ακαθαρτος ειναι ο ανθρωπος, ο πινων ανομιαν ως υδωρ;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Job 15:17",
      "text": "Εγω θελω σε διδαξει ακουσον μου τουτο βεβαιως ειδον και θελω φανερωσει,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Job 15:18",
      "text": "το οποιον οι σοφοι ανηγγειλαν παρα των πατερων αυτων, και δεν εκρυψαν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Job 15:19",
      "text": "εις τους οποιους μονους εδοθη η γη, και ξενος δεν επερασε δια μεσου αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Job 15:20",
      "text": "Ο ασεβης βασανιζεται πασας τας ημερας, και αριθμητα ετη ειναι πεφυλαγμενα δια τον τυραννον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Job 15:21",
      "text": "Ηχος φοβου ειναι εις τα ωτα αυτου εν μεσω ειρηνης θελει επελθει επ' αυτον ο εξολοθρευτης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Job 15:22",
      "text": "Δεν πιστευει οτι θελει επιστρεψει εκ του σκοτους, και περιμενει την μαχαιραν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Job 15:23",
      "text": "Περιπλαναται δια αρτον, και που; εξευρει οτι η ημερα του σκοτους ειναι ετοιμη πλησιον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Job 15:24",
      "text": "Θλιψις και στενοχωρια θελουσι καταπληττει αυτον θελουσιν υπερισχυσει κατ' αυτου, ως βασιλευς εις μαχην παρεσκευασμενος",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Job 15:25",
      "text": "διοτι εξηπλωσε την χειρα αυτου κατα του Θεου και ηλαζονευθη κατα του Παντοδυναμου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.26",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Job 15:26",
      "text": "ωρμησε κατ' αυτου με τραχηλον επηρμενον, με την πεπυκνωμενην ραχιν των ασπιδων αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.27",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Job 15:27",
      "text": "διοτι εσκεπασε το προσωπον αυτου με το παχος αυτου και υπερεπαχυνε τα πλευρα αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.28",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Job 15:28",
      "text": "και κατωκησεν εις πολεις ερημους, εις οικους ακατοικητους, ετοιμους δια σωρους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.29",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Job 15:29",
      "text": "δεν θελει πλουτισθη, ουδε θελουσι διαμενει τα υπαρχοντα αυτου, ουδε θελει εκτανθη η αφθονια αυτων επι την γην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.30",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Job 15:30",
      "text": "Δεν θελει χωρισθη εκ του σκοτους φλοξ θελει ξηρανει τους βλαστους αυτου, και με την πνοην του στοματος αυτου θελει απελθει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.31",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Job 15:31",
      "text": "Ας μη πιστευση εις την ματαιοτητα ο ηπατημενος, διοτι ματαιοτης θελει εισθαι η αμοιβη αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.32",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Job 15:32",
      "text": "Προ του καιρου αυτου θελει φθαρη, και ο κλαδος αυτου δεν θελει πρασινισει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.33",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Job 15:33",
      "text": "Θελει αποβαλει την αωρον σταφυλην αυτου ως η αμπελος, και θελει ριψει το ανθος αυτου ως η ελαια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.34",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 34,
      "referenceLabel": "Job 15:34",
      "text": "Διοτι η συναξις των υποκριτων θελει ερημωθη, και πυρ θελει καταφαγει τας σκηνας της δωροληψιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.15.35",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 35,
      "referenceLabel": "Job 15:35",
      "text": "Συλλαμβανουσι πονηριαν και γεννωσι ματαιοτητα, και η καρδια αυτων μηχαναται δολον.",
      "paragraphStart": false
    }
  ]
}
