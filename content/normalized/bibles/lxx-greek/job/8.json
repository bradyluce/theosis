{
  "chapter": {
    "id": "lxx-greek:job.8",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 8,
    "referenceLabel": "Job 8",
    "summary": "Source text for Job 8 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.8.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Job 8:1",
      "text": "Και απεκριθη Βιλδαδ ο Σαυχιτης και ειπεν",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.8.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Job 8:2",
      "text": "Εως ποτε θελεις λαλει ταυτα; και οι λογοι του στοματος σου θελουσιν εισθαι ως ανεμος σφοδρος;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Job 8:3",
      "text": "Μηπως ο Θεος ανατρεπει την κρισιν; η ο Παντοδυναμος ανατρεπει το δικαιον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Job 8:4",
      "text": "Εαν οι υιοι σου ημαρτησαν εις αυτον, παρεδωκεν αυτους εις την χειρα της ανομιας αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Job 8:5",
      "text": "Εαν συ ηθελες ζητησει τον Θεον πρωι, και ηθελες δεηθη του Παντοδυναμου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Job 8:6",
      "text": "εαν ησο καθαρος και ευθυς, βεβαιως τωρα ηθελεν εγερθη δια σε, και ηθελεν ευτυχει η κατοικια της δικαιοσυνης σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Job 8:7",
      "text": "Και αν η αρχη σου ητο μικρα, τα υστερα σου ομως ηθελον μεγαλυνθη σφοδρα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Job 8:8",
      "text": "Επειδη ερωτησον, παρακαλω, περι των προτερων γενεων, και ερευνησον ακριβως περι των πατερων αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Job 8:9",
      "text": "διοτι ημεις ειμεθα χθεσινοι, και δεν εξευρομεν ουδεν, επειδη αι ημεραι ημων επι της γης ειναι σκια",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Job 8:10",
      "text": "δεν θελουσι σε διδαξει αυτοι, και σοι ειπει και προφερει λογους εκ της καρδιας αυτων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Job 8:11",
      "text": "Θαλλει ο παπυρος ανευ πηλου; αυξανει ο σχοινος ανευ υδατος;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Job 8:12",
      "text": "Ενω ειναι ετι πρασινος και αθεριστος, ξηραινεται προ παντος χορτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Job 8:13",
      "text": "Ουτως ειναι αι οδοι παντων των λησμονουντων τον Θεον και η ελπις του υποκριτου θελει χαθη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Job 8:14",
      "text": "η ελπις αυτου θελει κοπη, και το θαρρος αυτου θελει εισθαι ιστος αραχνης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Job 8:15",
      "text": "Θελει επιστηριχθη επι την οικιαν αυτου, πλην αυτη δεν θελει σταθη θελει κρατησει αυτην, πλην δεν θελει ανορθωθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Job 8:16",
      "text": "Ειναι χλωρος εμπροσθεν του ηλιου, και ο κλαδος αυτου απλονεται εις τον κηπον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Job 8:17",
      "text": "Αι ριζαι αυτου περιπλεκονται εις τον σωρον των λιθων, και εκλεγει τον πετρωδη τοπον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Job 8:18",
      "text": "Εαν εξαλειφθη απο του τοπου αυτου, τοτε θελει αρνηθη αυτον, λεγων, Δεν σε ειδον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Job 8:19",
      "text": "Ιδου, αυτη ειναι η χαρα της οδου αυτου, και εκ του χωματος αλλοι θελουσι αναβλαστησει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "Job 8:20",
      "text": "Ιδου, ο Θεος δεν θελει απορριψει τον αμεμπτον, ουδε θελει πιασει την χειρα των κακοποιων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "Job 8:21",
      "text": "εωσου γεμιση το στομα σου απο γελωτος, και τα χειλη σου αλαλαγμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.8.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "Job 8:22",
      "text": "Οι μισουντες σε θελουσιν ενδυθη αισχυνην και η κατοικια των ασεβων δεν θελει υπαρχει.",
      "paragraphStart": false
    }
  ]
}
