{
  "chapter": {
    "id": "lxx-greek:job.40",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 40,
    "referenceLabel": "Job 40",
    "summary": "Source text for Job 40 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.40.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 1,
      "referenceLabel": "Job 40:1",
      "text": "Ο Κυριος απεκριθη ετι προς τον Ιωβ και ειπεν",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.40.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 2,
      "referenceLabel": "Job 40:2",
      "text": "Ο διαδικαζομενος προς τον Παντοδυναμον θελει διδαξει αυτον; ο ελεγχων τον Θεον ας αποκριθη προς τουτο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 3,
      "referenceLabel": "Job 40:3",
      "text": "Τοτε ο Ιωβ απεκριθη προς τον Κυριον και ειπεν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 4,
      "referenceLabel": "Job 40:4",
      "text": "Ιδου, εγω ειμαι ουτιδανος τι δυναμαι να αποκριθω προς σε; θελω βαλει την χειρα μου επι το στομα μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 5,
      "referenceLabel": "Job 40:5",
      "text": "απαξ ελαλησα και δεν θελω αποκριθη πλεον μαλιστα, δις αλλα δεν θελω επιπροσθεσει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 6,
      "referenceLabel": "Job 40:6",
      "text": "Τοτε απεκριθη ο Κυριος προς τον Ιωβ εκ του ανεμοστροβιλου και ειπε",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 7,
      "referenceLabel": "Job 40:7",
      "text": "Ζωσον ηδη ως ανηρ την οσφυν σου εγω θελω σε ερωτησει, και απαγγειλον μοι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 8,
      "referenceLabel": "Job 40:8",
      "text": "Θελεις αρα αναιρεσει την κρισιν μου; θελεις με καταδικασει, δια να δικαιωθης;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 9,
      "referenceLabel": "Job 40:9",
      "text": "Εχεις βραχιονα ως ο Θεος; η δυνασαι να βροντας με φωνην ως αυτος;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 10,
      "referenceLabel": "Job 40:10",
      "text": "Στολισθητι τωρα μεγαλοπρεπειαν και υπεροχην και ενδυθητι δοξαν και ωραιοτητα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 11,
      "referenceLabel": "Job 40:11",
      "text": "Εκχεε τας φλογας της οργης σου και βλεπε παντα υπερηφανον και ταπεινονε αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 12,
      "referenceLabel": "Job 40:12",
      "text": "Βλεπε παντα υπερηφανον κρημνιζε αυτον και καταπατει τους ασεβεις εν τω τοπω αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 13,
      "referenceLabel": "Job 40:13",
      "text": "Κρυψον αυτους ομου εν τω χωματι καλυψον τα προσωπα αυτων εν αφανεια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 14,
      "referenceLabel": "Job 40:14",
      "text": "Τοτε και εγω θελω ομολογησει προς σε, οτι η δεξια σου δυναται να σε σωση.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 15,
      "referenceLabel": "Job 40:15",
      "text": "Ιδου τωρα, ο Βεεμωθ, τον οποιον εκαμα μετα σου, τρωγει χορτον ως βους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 16,
      "referenceLabel": "Job 40:16",
      "text": "Ιδου τωρα, η δυναμις αυτου ειναι εν τοις νεφροις αυτου και η ισχυς αυτου εν τω ομφαλω της κοιλιας αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 17,
      "referenceLabel": "Job 40:17",
      "text": "Υψονει την ουραν αυτου ως κεδρον τα νευρα των μηρων αυτου ειναι συμπεπλεγμενα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 18,
      "referenceLabel": "Job 40:18",
      "text": "Τα οστα αυτου ειναι χαλκινοι σωληνες τα οστα αυτου ως μοχλοι σιδηρου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 19,
      "referenceLabel": "Job 40:19",
      "text": "Τουτο ειναι το αριστουργημα του Θεου ο ποιησας αυτον δυναται να πλησιαση εις αυτον την ρομφαιαν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 20,
      "referenceLabel": "Job 40:20",
      "text": "Διοτι τα ορη προμηθευουσιν εις αυτον την τροφην, οπου παιζουσι παντα τα θηρια του αγρου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 21,
      "referenceLabel": "Job 40:21",
      "text": "Πλαγιαζει υποκατω των σκιερων δενδρων, υπο την σκεπην των καλαμων και εν τοις βαλτοις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 22,
      "referenceLabel": "Job 40:22",
      "text": "Τα σκιερα δενδρα σκεπαζουσιν αυτον με την σκιαν αυτων αι ιτεαι των ρυακων περικαλυπτουσιν αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 23,
      "referenceLabel": "Job 40:23",
      "text": "Ιδου, εαν πλημμυριση ποταμος, δεν σπευδει να φυγη εχει θαρρος, και αν ο Ιορδανης προσβαλλη εις το στομα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.40.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 24,
      "referenceLabel": "Job 40:24",
      "text": "Δυναται τις φανερα να συλλαβη αυτον; η δια παγιδων να διατρυπηση την ρινα αυτου;",
      "paragraphStart": false
    }
  ]
}
