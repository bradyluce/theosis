{
  "chapter": {
    "id": "lxx-greek:job.12",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 12,
    "referenceLabel": "Job 12",
    "summary": "Source text for Job 12 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.12.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Job 12:1",
      "text": "Ο δε Ιωβ απεκριθη και ειπε",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.12.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Job 12:2",
      "text": "σεις εισθε αληθως οι ανθρωποι, και με σας θελει τελευτησει η σοφια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Job 12:3",
      "text": "Και εγω εχω συνεσιν ως και υμεις δεν ειμαι κατωτερος υμων και τις δεν γνωριζει τοιαυτα πραγματα;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Job 12:4",
      "text": "Εγεινα χλευη εις τον πλησιον μου, οστις επικαλουμαι τον Θεον, και μοι αποκρινεται. Ο δικαιος και αμεμπτος περιγελαται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Job 12:5",
      "text": "Ο κινδυνευων να ολισθηση με τους ποδας ειναι εις τον στοχασμον του ευτυχουντος ως λυχνος καταπεφρονημενος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Job 12:6",
      "text": "Αι σκηναι των ληστων ευτυχουσι, και οι παροργιζοντες τον Θεον ειναι εν ασφαλεια, εις τας χειρας των οποιων ο Θεος φερει αφθονιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Job 12:7",
      "text": "Αλλ' ερωτησον τωρα τα ζωα, και θελουσι σε διδαξει και τα πετεινα του ουρανου, και θελουσι σοι απαγγειλει",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Job 12:8",
      "text": "η λαλησον προς την γην, και θελει σε διδαξει και οι ιχθυες της θαλασσης θελουσι σοι διηγηθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Job 12:9",
      "text": "Τις εκ παντων τουτων δεν γνωριζει, οτι η χειρ του Κυριου εκαμε ταυτα;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Job 12:10",
      "text": "Εν τη χειρι του οποιου ειναι ψυχη παντων των ζωντων και η πνοη πασης ανθρωπινης σαρκος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Job 12:11",
      "text": "Το ωτιον δεν διακρινει τους λογους; και ο ουρανισκος λαμβανει γευσιν του φαγητου αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Job 12:12",
      "text": "Η σοφια ειναι μετα των γεροντων, και η συνεσις εν τη μακροτητι των ημερων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Job 12:13",
      "text": "Εν αυτω ειναι η σοφια και η δυναμις αυτος εχει βουλην και συνεσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Job 12:14",
      "text": "Ιδου, καταστρεφει, και δεν ανοικοδομειται κλειει κατα του ανθρωπου, και ουδεις ο ανοιγων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Job 12:15",
      "text": "Ιδου, κρατει τα υδατα, και ξηραινονται παλιν εξαποστελλει αυτα, και καταστρεφουσι την γην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Job 12:16",
      "text": "Μετ' αυτου ειναι η δυναμις και η σοφια αυτου ειναι ο απατωμενος και ο απατων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Job 12:17",
      "text": "Παραδιδει λαφυρον τους βουλευτας και μωραινει τους κριτας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Job 12:18",
      "text": "Λυει την ζωνην των βασιλεων και περιζωνει την οσφυν αυτων με σχοινιον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Job 12:19",
      "text": "Παραδιδει λαφυρον τους αρχοντας και καταστρεφει τους ισχυρους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Job 12:20",
      "text": "Αφαιρει τον λογον των δεινων ρητορων, και σηκονει την συνεσιν απο των πρεσβυτερων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Job 12:21",
      "text": "Εκχεει καταφρονησιν επι τους αρχοντας, και λυει την ζωνην των ισχυρων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Job 12:22",
      "text": "Αποκαλυπτει εκ του σκοτους βαθεα πραγματα, και εξαγει εις φως την σκιαν του θανατου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Job 12:23",
      "text": "Μεγαλυνει τα εθνη και αφανιζει αυτα πλατυνει τα εθνη και συστελλει αυτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Job 12:24",
      "text": "Αφαιρει την καρδιαν απο των αρχηγων των λαων της γης, και καμνει αυτους να περιπλανωνται εν ερημω αβατω",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.12.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Job 12:25",
      "text": "ψηλαφωσιν εν σκοτει χωρις φωτος, και καμνει αυτους να παραφερωνται ως ο μεθυων.",
      "paragraphStart": false
    }
  ]
}
