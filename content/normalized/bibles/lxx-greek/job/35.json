{
  "chapter": {
    "id": "lxx-greek:job.35",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 35,
    "referenceLabel": "Job 35",
    "summary": "Source text for Job 35 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.35.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 1,
      "referenceLabel": "Job 35:1",
      "text": "Και επανελαβεν ο Ελιου και ειπε",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.35.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 2,
      "referenceLabel": "Job 35:2",
      "text": "Στοχαζεσαι οτι ειναι ορθον τουτο, το οποιον ειπας, Ειμαι δικαιοτερος του Θεου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.35.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 3,
      "referenceLabel": "Job 35:3",
      "text": "Διοτι ειπας, Τις ωφελεια θελει εισθαι εις σε; Τι κερδος θελω λαβει εκ τουτου μαλλον παρα εκ της αμαρτιας μου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.35.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 4,
      "referenceLabel": "Job 35:4",
      "text": "Εγω θελω αποκριθη προς σε και προς τους φιλους σου μετα σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.35.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 5,
      "referenceLabel": "Job 35:5",
      "text": "Αναβλεψον εις τους ουρανους και ιδε και θεωρησον τα νεφη, ποσον υψηλοτερα σου ειναι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.35.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 6,
      "referenceLabel": "Job 35:6",
      "text": "Εαν αμαρτανης, τι πραττεις κατ' αυτου; η αν αι παραβασεις σου πολλαπλασιασθωσι, τι κατορθονεις κατ' αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.35.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 7,
      "referenceLabel": "Job 35:7",
      "text": "Εαν ησαι δικαιος, τι θελεις δωσει εις αυτον; η τι θελει λαβει εκ της χειρος σου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.35.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 8,
      "referenceLabel": "Job 35:8",
      "text": "Η ασεβεια σου δυναται να βλαψη ανθρωπον ως σε και η δικαιοσυνη σου δυναται να ωφεληση υιον ανθρωπου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.35.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 9,
      "referenceLabel": "Job 35:9",
      "text": "Εκ του πληθους των καταθλιβοντων καταβοωσι κραυγαζουσιν ενεκεν του βραχιονος των ισχυρων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.35.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 10,
      "referenceLabel": "Job 35:10",
      "text": "Αλλ' ουδεις λεγει, που ειναι ο Θεος ο Ποιητης μου, οστις διδει ασματα εις την νυκτα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.35.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 11,
      "referenceLabel": "Job 35:11",
      "text": "Οστις συνετιζει ημας υπερ τα κτηνη της γης, και σοφιζει ημας υπερ τα πετεινα του ουρανου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.35.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 12,
      "referenceLabel": "Job 35:12",
      "text": "Εκει βοωσι δια την υπερηφανιαν των πονηρων, δεν θελει ομως αποκριθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.35.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 13,
      "referenceLabel": "Job 35:13",
      "text": "Ο Θεος βεβαιως δεν θελει εισακουσει της ματαιολογιας, ουδε θελει επιβλεψει ο Παντοδυναμος εις αυτην",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.35.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 14,
      "referenceLabel": "Job 35:14",
      "text": "ποσον ολιγωτερον οταν συ λεγης, οτι δεν θελεις ιδει αυτον η κρισις ομως ειναι ενωπιον αυτου οθεν εχε το θαρρος σου επ' αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.35.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 15,
      "referenceLabel": "Job 35:15",
      "text": "Αλλα τωρα, επειδη δεν επεσκεφθη εν τω θυμω αυτου και δεν παρετηρησε μετα μεγαλης αυστηροτητος,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.35.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 16,
      "referenceLabel": "Job 35:16",
      "text": "δια τουτο ο Ιωβ ανοιγει το στομα αυτου ματαιως επισωρευει λογους εν αγνωσια.",
      "paragraphStart": false
    }
  ]
}
