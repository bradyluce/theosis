{
  "chapter": {
    "id": "lxx-greek:job.22",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 22,
    "referenceLabel": "Job 22",
    "summary": "Source text for Job 22 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.22.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Job 22:1",
      "text": "Και απεκριθη Ελιφας ο Θαιμανιτης και ειπε",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.22.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Job 22:2",
      "text": "Δυναται ανθρωπος να ωφεληση τον Θεον, διοτι φρονιμος ων δυναται να ωφελη εαυτον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Job 22:3",
      "text": "Ειναι ευχαριστησις εις τον Παντοδυναμον, εαν ησαι δικαιος; η κερδος, εαν καθιστας αμεμπτους τας οδους σου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Job 22:4",
      "text": "Μηπως φοβουμενος σε θελει σε ελεγξει και θελει ελθει εις κρισιν μετα σου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Job 22:5",
      "text": "Η κακια σου δεν ειναι μεγαλη; και αι ανομιαι σου απειροι;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Job 22:6",
      "text": "Διοτι ελαβες ενεχυρον παρα του αδελφου σου αναιτιως και εστερησας τους γυμνους απο του ενδυματος αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Job 22:7",
      "text": "Δεν εποτισας υδωρ τον διψωντα, και ηρνηθης αρτον εις τον πεινωντα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Job 22:8",
      "text": "Ο δε ισχυρος ανθρωπος απελαμβανε την γην και ο περιβλεπτος κατωκει εν αυτη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Job 22:9",
      "text": "Χηρας απεβαλες αβοηθητους, και οι βραχιονες των ορφανων συνετριβησαν υπο σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Job 22:10",
      "text": "Δια τουτο παγιδες σε περιεκυκλωσαν, και φοβος αιφνιδιος σε ταραττει",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Job 22:11",
      "text": "και σκοτος, ωστε δεν βλεπεις και πλημμυρα υδατων σε σκεπαζει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Job 22:12",
      "text": "Δεν ειναι ο Θεος εν τοις υψηλοις του ουρανου; και θεωρησον το υψος των αστρων, ποσον υψηλα ειναι",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Job 22:13",
      "text": "Και συ λεγεις, Τι γνωριζει ο Θεος; δυναται να κρινη δια του γνοφου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Job 22:14",
      "text": "Νεφη αποκρυπτουσιν αυτον, και δεν βλεπει, και τον γυρον του ουρανου διαπορευεται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Job 22:15",
      "text": "Μηπως θελεις φυλαξει την παντοτεινην οδον, την οποιαν επατησαν οι ανομοι;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Job 22:16",
      "text": "Οιτινες αφηρπασθησαν αωρως, και το θεμελιον αυτων κατεποντισε χειμαρρος",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Job 22:17",
      "text": "οιτινες ειπον προς τον Θεον, αποστηθι αφ' ημων και τι θελει καμει ο Παντοδυναμος εις αυτους;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Job 22:18",
      "text": "Αλλ' αυτος ενεπλησεν αγαθων τους οικους αυτων πλην μακραν απ' εμου η βουλη των ασεβων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Job 22:19",
      "text": "Οι δικαιοι βλεπουσι και αγαλλονται και οι αθωοι μυκτηριζουσιν αυτους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Job 22:20",
      "text": "Η μεν περιουσια ημων δεν ηφανισθη, το υπολοιπον ομως αυτων κατατρωγει πυρ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Job 22:21",
      "text": "Οικειωθητι λοιπον μετ' αυτου και εσο εν ειρηνη ουτω θελει ελθει καλον εις σε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Job 22:22",
      "text": "Δεχθητι λοιπον τον νομον εκ του στοματος αυτου, και βαλε τους λογους αυτου εν τη καρδια σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Job 22:23",
      "text": "Εαν επιστρεψης προς τον Παντοδυναμου, θελεις ανοικοδομηθη, εκδιωξας την ανομιαν μακραν απο των σκηνων σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Job 22:24",
      "text": "Και θελεις επισωρευσει το χρυσιον ως χωμα και το χρυσιον του Οφειρ ως τας πετρας των χειμαρρων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Job 22:25",
      "text": "Και ο Παντοδυναμος θελει εισθαι ο υπερασπιστης σου, και θελεις εχει πληθος αργυριου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.26",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Job 22:26",
      "text": "Διοτι τοτε θελεις ευφραινεσθε εις τον Παντοδυναμον, και θελεις υψωσει το προσωπον σου προς τον Θεον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.27",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Job 22:27",
      "text": "Θελεις δεηθη αυτου, και θελει σου εισακουσει, και θελεις αποδωσει τας ευχας σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.28",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Job 22:28",
      "text": "Και ο, τι αποφασισης, θελει κατορθουσθαι εις σε και το φως θελει φεγγει επι τας οδους σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.29",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Job 22:29",
      "text": "Οταν ταπεινωθη τις, τοτε θελεις ειπει, Ειναι υψωσις διοτι θελει σωσει τον κεκυφοτα τους οφθαλμους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.22.30",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "Job 22:30",
      "text": "Θελει σωσει και τον μη αθωον ναι, δια της καθαροτητος των χειρων σου θελει σωθη.",
      "paragraphStart": false
    }
  ]
}
