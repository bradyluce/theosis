{
  "chapter": {
    "id": "lxx-greek:job.25",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 25,
    "referenceLabel": "Job 25",
    "summary": "Source text for Job 25 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.25.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Job 25:1",
      "text": "Και απεκριθη Βιλδαδ ο Σαυχιτης και ειπεν",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.25.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Job 25:2",
      "text": "Εξουσια και φοβος ειναι μετ' αυτου εκτελει ειρηνην εις τα υψη αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.25.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Job 25:3",
      "text": "Υπαρχει αριθμος των στρατευματων αυτου; και επι τινα δεν ανατελλει το φως αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.25.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Job 25:4",
      "text": "Πως λοιπον δυναται ανθρωπος να δικαιωθη ενωπιον του Θεου; η πως δυναται να ηναι καθαρος ο γεγεννημενος εκ γυναικος;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.25.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Job 25:5",
      "text": "Ιδου, και αυτη η σεληνη δεν ειναι λαμπρα, και οι αστερες δεν ειναι καθαροι ενωπιον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.25.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Job 25:6",
      "text": "Ποσον ολιγωτερον ο ανθρωπος, σαπρια; και ο υιος του ανθρωπου, ο σκωληξ;",
      "paragraphStart": false
    }
  ]
}
