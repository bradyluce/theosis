{
  "chapter": {
    "id": "lxx-greek:job.41",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 41,
    "referenceLabel": "Job 41",
    "summary": "Source text for Job 41 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.41.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 1,
      "referenceLabel": "Job 41:1",
      "text": "Δυνασαι να συρης εξω τον Λευιαθαν δια αγκιστρου; η να περιδεσης την γλωσσαν αυτου με φορβιαν;",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.41.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 2,
      "referenceLabel": "Job 41:2",
      "text": "Δυνασαι να βαλης χαλινον εις την ρινα αυτου; η να τρυπησης την σιαγονα αυτου με ακανθαν;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 3,
      "referenceLabel": "Job 41:3",
      "text": "Θελει πληθυνει προς σε ικεσιας; θελει σοι λαλησει μετα γλυκυτητος;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 4,
      "referenceLabel": "Job 41:4",
      "text": "Θελει καμει συνθηκην μετα σου; θελεις παρει αυτον δια δουλον παντοτεινον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 5,
      "referenceLabel": "Job 41:5",
      "text": "Θελεις παιζει μετ' αυτου ως μετα πτηνου; η θελεις δεσει αυτον δια τας θεραπαινας σου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 6,
      "referenceLabel": "Job 41:6",
      "text": "Θελουσι καμει οι φιλοι συμποσιον εξ αυτου; θελουσι μοιρασει αυτον μεταξυ των εμπορων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 7,
      "referenceLabel": "Job 41:7",
      "text": "Δυνασαι να γεμισης το δερμα αυτου με βελη; η την κεφαλην αυτου με αλιευτικα καμακια;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 8,
      "referenceLabel": "Job 41:8",
      "text": "Βαλε την χειρα σου επ' αυτον ενθυμηθητι τον πολεμον μη καμης πλεον τουτο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 9,
      "referenceLabel": "Job 41:9",
      "text": "Ιδου, η ελπις να πιαση τις αυτον ειναι ματαια δεν ηθελε μαλιστα εκπλαγη εις την θεωριαν αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 10,
      "referenceLabel": "Job 41:10",
      "text": "Ουδεις ειναι τοσον τολμηρος ωστε να εγειρη αυτον και τις δυναται να σταθη εμπροσθεν εμου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 11,
      "referenceLabel": "Job 41:11",
      "text": "Τις προτερον εδωκεν εις εμε και να ανταποδοσω; τα υποκατω παντος του ουρανου ειναι εμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 12,
      "referenceLabel": "Job 41:12",
      "text": "Δεν θελω σιωπησει τα μελη αυτου ουδε την δυναμιν ουδε την ευαρεστον αυτου συμμετριαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 13,
      "referenceLabel": "Job 41:13",
      "text": "Τις να εξιχνιαση την επιφανειαν του ενδυματος αυτου; τις να εισελθη εντος των διπλων σιαγονων αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 14,
      "referenceLabel": "Job 41:14",
      "text": "Τις δυναται να ανοιξη τας πυλας του προσωπου αυτου; οι οδοντες αυτου κυκλω ειναι τρομεροι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 15,
      "referenceLabel": "Job 41:15",
      "text": "Αι ισχυραι ασπιδες αυτου ειναι το εγκαυχημα αυτου, συγκεκλεισμεναι ομου δια σφιγκτου σφραγισματος",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 16,
      "referenceLabel": "Job 41:16",
      "text": "η μια ενουται μετα της αλλης, ωστε ουδε αηρ δυναται να περαση δι' αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 17,
      "referenceLabel": "Job 41:17",
      "text": "ειναι προσκεκολλημεναι η μια μετα της αλλης συνεχονται ουτως, ωστε δεν δυνανται να αποσπασθωσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 18,
      "referenceLabel": "Job 41:18",
      "text": "Εις τον πταρνισμον αυτου λαμπει φως, και οι οφθαλμοι αυτου ειναι ως τα βλεφαρα της αυγης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 19,
      "referenceLabel": "Job 41:19",
      "text": "Εκ του στοματος αυτου εξερχονται λαμπαδες καιομεναι και σπινθηρες πυρος εξακοντιζονται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 20,
      "referenceLabel": "Job 41:20",
      "text": "Εκ των μυκτηρων αυτου εξερχεται καπνος, ως εξ αγγειου κοχλαζοντος η λεβητος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 21,
      "referenceLabel": "Job 41:21",
      "text": "Η πνοη αυτου αναπτει ανθρακας, και φλοξ εξερχεται εκ του στοματος αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 22,
      "referenceLabel": "Job 41:22",
      "text": "Εν τω τραχηλω αυτου κατοικει δυναμις, και τρομος προπορευεται εμπροσθεν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 23,
      "referenceLabel": "Job 41:23",
      "text": "Τα στρωματα της σαρκος αυτου ειναι συγκεκολλημενα ειναι στερεα επ' αυτον δεν δυνανται να σαλευθωσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 24,
      "referenceLabel": "Job 41:24",
      "text": "Η καρδια αυτου ειναι στερεα ως λιθος σκληρα μαλιστα ως η κατω μυλοπετρα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 25,
      "referenceLabel": "Job 41:25",
      "text": "Οτε ανεγειρεται, φριττουσιν οι δυνατοι, και εκ του φοβου παραφρονουσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.26",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 26,
      "referenceLabel": "Job 41:26",
      "text": "Η ρομφαια του συναπαντωντος αυτον δεν δυναται να ανθεξη η λογχη, το δορυ, ουδε ο θωραξ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.27",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 27,
      "referenceLabel": "Job 41:27",
      "text": "Θεωρει τον σιδηρον ως αχυρον, τον χαλκον ως ξυλον σαθρον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.28",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 28,
      "referenceLabel": "Job 41:28",
      "text": "Τα βελη δεν δυνανται να τρεψωσιν αυτον εις φυγην αι πετραι της σφενδονης ειναι εις αυτον ως στυπιον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.29",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 29,
      "referenceLabel": "Job 41:29",
      "text": "Τα ακοντια λογιζονται ως στυπιον γελα εις το σεισμα της λογχης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.30",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 30,
      "referenceLabel": "Job 41:30",
      "text": "Οξεις λιθοι κοιτονται υποκατω αυτου υποστρονει τα αγκυλωτα σωματα επι πηλου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.31",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 31,
      "referenceLabel": "Job 41:31",
      "text": "Καμνει την αβυσσον ως λεβητα να κοχλαζη καθιστα την θαλασσαν ως σκευος μυρεψου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.32",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 32,
      "referenceLabel": "Job 41:32",
      "text": "Αφινει οπισω την πορειαν φωτεινην ηθελε τις υπολαβει την αβυσσον ως πολιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.33",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 33,
      "referenceLabel": "Job 41:33",
      "text": "Επι της γης δεν υπαρχει ομοιον αυτου, δεδημιουργημενον ουτως αφοβον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.41.34",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 34,
      "referenceLabel": "Job 41:34",
      "text": "Περιορα παντα τα υψηλα ειναι βασιλευς επι παντας τους υιους της υπερηφανιας.",
      "paragraphStart": false
    }
  ]
}
