{
  "chapter": {
    "id": "lxx-greek:job.27",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 27,
    "referenceLabel": "Job 27",
    "summary": "Source text for Job 27 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.27.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 1,
      "referenceLabel": "Job 27:1",
      "text": "Και εξηκολουθησεν ο Ιωβ την παραβολην αυτου και ειπε",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.27.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 2,
      "referenceLabel": "Job 27:2",
      "text": "Ζη ο Θεος, ο αποβαλων την κρισιν μου, και ο Παντοδυναμος, ο πικρανας την ψυχην μου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 3,
      "referenceLabel": "Job 27:3",
      "text": "οτι παντα τον χρονον ενοσω η πνοη μου ειναι εν εμοι και το πνευμα του Θεου εις τους μυκτηρας μου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 4,
      "referenceLabel": "Job 27:4",
      "text": "τα χειλη μου δεν θελουσι λαλησει αδικιαν και η γλωσσα μου δεν θελει μελετησει δολον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 5,
      "referenceLabel": "Job 27:5",
      "text": "Μη γενοιτο εις εμε να σας δικαιωσω εως να εκπνευσω, δεν θελω απομακρυνει την ακεραιοτητα μου απ' εμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 6,
      "referenceLabel": "Job 27:6",
      "text": "Θελω κρατει την δικαιοσυνην μου και δεν θελω αφησει αυτην η καρδια μου δεν θελει με ελεγξει ενοσω ζω.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 7,
      "referenceLabel": "Job 27:7",
      "text": "Ο εχθρος μου να ηναι ως ο ασεβης και ο ανισταμενος κατ' εμου ως ο παρανομος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 8,
      "referenceLabel": "Job 27:8",
      "text": "Διοτι τις η ελπις του υποκριτου, αν και επλεονεκτησεν, οταν ο Θεος αποσπα την ψυχην αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 9,
      "referenceLabel": "Job 27:9",
      "text": "Αρα γε θελει ακουσει ο Θεος την κραυγην αυτου, οταν επελθη επ' αυτον συμφορα;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 10,
      "referenceLabel": "Job 27:10",
      "text": "Θελει ευφραινεσθαι εις τον Παντοδυναμον; θελει επικαλεισθαι τον Θεον εν παντι καιρω;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 11,
      "referenceLabel": "Job 27:11",
      "text": "θελω σας διδαξει τι ειναι εν τη χειρι του Θεου ο, τι ειναι παρα τω Παντοδυναμω, δεν θελω κρυψει αυτο.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 12,
      "referenceLabel": "Job 27:12",
      "text": "Ιδου, σεις παντες ειδετε δια τι λοιπον εισθε ολως τοσον ματαιοι;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 13,
      "referenceLabel": "Job 27:13",
      "text": "Τουτο ειναι παρα Θεου η μερις του ασεβους ανθρωπου, και η κληρονομια των δυναστων, την οποιαν θελουσι λαβει παρα του Παντοδυναμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 14,
      "referenceLabel": "Job 27:14",
      "text": "Εαν οι υιοι αυτου πολλαπλασιασθωσιν, ειναι δια την ρομφαιαν και οι εκγονοι αυτου δεν θελουσι χορτασθη αρτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 15,
      "referenceLabel": "Job 27:15",
      "text": "Οι εναπολειφθεντες αυτου θελουσι ταφη εν θανατω και αι χηραι αυτου δεν θελουσι κλαυσει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 16,
      "referenceLabel": "Job 27:16",
      "text": "Και αν επισωρευση αργυριον ως το χωμα και ετοιμαση ιματια ως τον πηλον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 17,
      "referenceLabel": "Job 27:17",
      "text": "δυναται μεν να ετοιμαση, πλην ο δικαιος θελει ενδυθη αυτα και ο αθωος θελει διαμοιρασθη το αργυριον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 18,
      "referenceLabel": "Job 27:18",
      "text": "Οικοδομει τον οικον αυτου ως το σαρακιον, και ως καλυβην, την οποιαν καμνει ο αγροφυλαξ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 19,
      "referenceLabel": "Job 27:19",
      "text": "Πλαγιαζει πλουσιος, πλην δεν θελει συναχθη ανοιγει τους οφθαλμους αυτου και δεν υπαρχει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 20,
      "referenceLabel": "Job 27:20",
      "text": "Τρομοι συλλαμβανουσιν αυτον ως υδατα, ανεμοστροβιλος αρπαζει αυτον την νυκτα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 21,
      "referenceLabel": "Job 27:21",
      "text": "Σηκονει αυτον ανατολικος ανεμος, και υπαγει και αποσπα αυτον απο του τοπου αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 22,
      "referenceLabel": "Job 27:22",
      "text": "Διοτι ο Θεος θελει ριψει κατ' αυτου συμφορας και δεν θελει φεισθη απο της χειρος αυτου σπευδει να φυγη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.27.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 23,
      "referenceLabel": "Job 27:23",
      "text": "Θελουσι κροτησει τας χειρας αυτων επ' αυτον, και θελουσι συριξει αυτον απο του τοπου αυτων.",
      "paragraphStart": false
    }
  ]
}
