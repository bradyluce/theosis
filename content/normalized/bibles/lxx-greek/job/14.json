{
  "chapter": {
    "id": "lxx-greek:job.14",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 14,
    "referenceLabel": "Job 14",
    "summary": "Source text for Job 14 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.14.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Job 14:1",
      "text": "Ανθρωπος γεγεννημενος εκ γυναικος ειναι ολιγοβιος και πληρης ταραχης",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.14.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Job 14:2",
      "text": "αναβλαστανει ως ανθος και κοπτεται φευγει ως σκια και δεν διαμενει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Job 14:3",
      "text": "Και επι τοιουτον ανοιγεις τους οφθαλμους σου, και με φερεις εις κρισιν μετα σου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Job 14:4",
      "text": "Τις δυναται να εξαγαγη καθαρον απο ακαθαρτου; ουδεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Job 14:5",
      "text": "Επειδη αι ημεραι αυτου ειναι προσδιωρισμεναι, ο αριθμος των μηνων αυτου ευρισκεται παρα σοι, και συ εθεσας τα ορια αυτου, και δεν δυναται να υπερβη αυτα,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Job 14:6",
      "text": "αποστρεψον απ' αυτου, δια να ησυχαση, εωσου χαιρων εκπληρωση ως μισθωτος την ημεραν αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Job 14:7",
      "text": "Διοτι περι του δενδρου, εαν κοπη, ειναι ελπις οτι θελει αναβλαστησει, και οτι ο τρυφερος αυτου βλαστος δεν θελει εκλειψει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Job 14:8",
      "text": "Και αν η ριζα αυτου παλαιωθη εν τη γη και ο κορμος αυτου αποθανη εν τω χωματι,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Job 14:9",
      "text": "ομως δια της οσμης του υδατος θελει αναβλαστησει και θελει εκβαλει κλαδους ως νεοφυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Job 14:10",
      "text": "Αλλ' ο ανθρωπος αποθνησκει και παρερχεται και ο ανθρωπος εκπνεει, και που ειναι;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Job 14:11",
      "text": "Καθως τα υδατα εκλειπουσιν εκ της θαλασσης και ο ποταμος στειρευει και ξηραινεται,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Job 14:12",
      "text": "ουτως ο ανθρωπος, αφου κοιμηθη, δεν ανισταται εωσου οι ουρανοι μη υπαρξωσι, δεν θελουσιν εξυπνησει, και δεν θελουσιν εγερθη εκ του υπνου αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Job 14:13",
      "text": "Ειθε να με εκρυπτες εν τω ταφω, να με εσκεπαζες εωσου παρελθη η οργη σου, να προσδιωριζες εις εμε προθεσμιαν, και τοτε να με ενθυμηθης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Job 14:14",
      "text": "Εαν αποθανη ο ανθρωπος, θελει αναζησει; πασας τας ημερας της εκστρατειας μου θελω περιμενει, εωσου ελθη η απαλλαγη μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Job 14:15",
      "text": "Θελεις καλεσει, και εγω θελω σοι αποκριθη θελεις επιβλεψει εις το εργον των χειρων σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Job 14:16",
      "text": "Διοτι τωρα αριθμεις τα διαβηματα μου δεν παραφυλαττεις τας αμαρτιας μου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Job 14:17",
      "text": "Η παραβασις μου ειναι επεσφραγισμενη εν βαλαντιω, και επισημειονεις την ανομιαν μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Job 14:18",
      "text": "Βεβαιως το μεν ορος πιπτον εξουδενουται, ο δε βραχος μετακινειται απο του τοπου αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Job 14:19",
      "text": "Τα υδατα τρωγουσι τας πετρας αι πλημμυραι αυτων παρασυρουσι το χωμα της γης ουτω συ καταστρεφεις την ελπιδα του ανθρωπου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Job 14:20",
      "text": "υπερισχυεις παντοτε εναντιον αυτου, και αυτος παρερχεται μεταβαλλεις την οψιν αυτου και αποπεμπεις αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Job 14:21",
      "text": "Οι υιοι αυτου υψουνται, και αυτος δεν εξευρει και ταπεινουνται, και αυτος δεν εννοει ουδεν περι αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.14.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Job 14:22",
      "text": "Μονον η σαρξ αυτου επ' αυτου θελει πονει, και η ψυχη αυτου εν αυτω θελει πενθει.",
      "paragraphStart": false
    }
  ]
}
