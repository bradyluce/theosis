{
  "chapter": {
    "id": "lxx-greek:job.23",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 23,
    "referenceLabel": "Job 23",
    "summary": "Source text for Job 23 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.23.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Job 23:1",
      "text": "Και απεκριθη ο Ιωβ και ειπε",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.23.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Job 23:2",
      "text": "Και την σημερον το παραπονον μου ειναι πικρον η πληγη μου ειναι βαρυτερα του στεναγμου μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.23.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Job 23:3",
      "text": "Ειθε να ηξευρον που να ευρω αυτον ηθελον υπαγει εως του θρονου αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.23.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Job 23:4",
      "text": "ηθελον εκθεσει κρισιν ενωπιον αυτου, και ηθελον εμπλησει το στομα μου αποδειξεων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.23.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Job 23:5",
      "text": "ηθελον γνωρισει τους λογους τους οποιους ηθελε μοι αποκριθη, και ηθελον νοησει τι ηθελε μοι ειπει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.23.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Job 23:6",
      "text": "Μη εν πληθει δυναμεως θελει διαμαχεσθαι μετ' εμου; ουχι αλλ' ηθελε βαλει εις εμε προσοχην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.23.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Job 23:7",
      "text": "Τοτε ηδυνατο ο δικαιος να διαλεχθη μετ' αυτου και ηθελον ελευθερωθη διαπαντος απο του κριτου μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.23.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Job 23:8",
      "text": "Ιδου, υπαγω εμπρος, αλλα δεν ειναι και οπισω, αλλα δεν βλεπω αυτον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.23.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Job 23:9",
      "text": "εις τα αριστερα, οταν εργαζηται, αλλα δεν δυναμαι να ιδω αυτον. Κρυπτεται εις τα δεξια, και δεν βλεπω αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.23.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Job 23:10",
      "text": "Γνωριζει ομως την οδον μου με εδοκιμασε θελω εξελθει ως χρυσιον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.23.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "Job 23:11",
      "text": "Ο πους μου ενεμεινεν εις τα βηματα αυτου εφυλαξα την οδον αυτου και δεν εξεκλινα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.23.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "Job 23:12",
      "text": "την εντολην των χειλεων αυτου, και δεν ωπισθοδρομησα διετηρησα τους λογους του στοματος αυτου, μαλλον παρα την αναγκαιαν μου τροφην.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.23.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "Job 23:13",
      "text": "Διοτι αυτος ειναι εν μια βουλη και τις δυναται να αποστρεψη αυτον; και ο, τι επιθυμει η ψυχη αυτου, καμνει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.23.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "Job 23:14",
      "text": "Διοτι εκτελει το ορισθεν εις εμε και πολλα τοιαυτα ειναι μετ' αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.23.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "Job 23:15",
      "text": "Δια τουτο καταπληττομαι απο προσωπου αυτου συλλογιζομαι και φριττω απ' αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.23.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "Job 23:16",
      "text": "διοτι ο Θεος εμαλακωσε την καρδιαν μου, και ο Παντοδυναμος με κατεπληξεν",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.23.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "Job 23:17",
      "text": "επειδη δεν απεκοπην προ του σκοτους, και δεν εκρυψε τον γνοφον απο του προσωπου μου.",
      "paragraphStart": false
    }
  ]
}
