{
  "chapter": {
    "id": "lxx-greek:job.9",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 9,
    "referenceLabel": "Job 9",
    "summary": "Source text for Job 9 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.9.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Job 9:1",
      "text": "Και απεκριθη ο Ιωβ και ειπεν",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.9.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Job 9:2",
      "text": "Αληθως εξευρω οτι ουτως εχει αλλα πως ο ανθρωπος θελει δικαιωθη ενωπιον του Θεου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Job 9:3",
      "text": "Εαν θεληση να διαδικασθη μετ' αυτου δεν δυναται να αποκριθη προς αυτον εν εκ χιλιων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Job 9:4",
      "text": "Ειναι σοφος την καρδιαν και κραταιος την δυναμιν τις εσκληρυνθη εναντιον αυτου και ευτυχησεν;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Job 9:5",
      "text": "Αυτος μετακινει τα ορη, και δεν γνωριζουσι τις εστρεψεν αυτα εν τη οργη αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Job 9:6",
      "text": "Αυτος σειει την γην απο του τοπου αυτης, και οι στυλοι αυτης σαλευονται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Job 9:7",
      "text": "Αυτος προσταζει τον ηλιον, και δεν ανατελλει και κρυπτει υπο σφραγιδα τα αστρα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Job 9:8",
      "text": "Αυτος μονος εκτεινει τους ουρανους και πατει επι τα υψη της θαλασσης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Job 9:9",
      "text": "Αυτος καμνει τον Αρκτουρον, τον Ωριωνα και την Πλειαδα και τα ταμεια του νοτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Job 9:10",
      "text": "Αυτος καμνει μεγαλεια ανεξιχνιαστα και θαυμασια αναριθμητα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Job 9:11",
      "text": "Ιδου, διαβαινει πλησιον μου, και δεν βλεπω αυτον διερχεται, και δεν εννοω αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Job 9:12",
      "text": "Ιδου, αφαιρει τις θελει εμποδισει αυτον; τις θελει ειπει προς αυτον, Τι καμνεις;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Job 9:13",
      "text": "Εαν ο Θεος δεν συρη την οργην αυτου, οι επηρμενοι βοηθοι καταβαλλονται υποκατω αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Job 9:14",
      "text": "Ποσον ολιγωτερον εγω ηθελον αποκριθη προς αυτον, εκλεγων τους προς αυτον λογους μου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Job 9:15",
      "text": "προς τον οποιον, και αν ημην δικαιος, δεν ηθελον αποκριθη, αλλ' ηθελον ζητησει ελεος παρα του Κριτου μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Job 9:16",
      "text": "Εαν κραξω, και μοι αποκριθη, δεν ηθελον πιστευσει οτι εισηκουσε της φωνης μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Job 9:17",
      "text": "Διοτι με κατασυντριβει με ανεμοστροβιλον και πληθυνει τας πληγας μου αναιτιως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Job 9:18",
      "text": "Δεν με αφινει να αναπνευσω, αλλα με χορταζει απο πικριας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Job 9:19",
      "text": "Εαν προκηται περι δυναμεως, ιδου, ειναι δυνατος και εαν περι κρισεως, τις θελει μαρτυρησει υπερ εμου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Job 9:20",
      "text": "Εαν ηθελον να δικαιωσω εμαυτον, το στομα μου ηθελε με καταδικασει εαν ηθελον ειπει, ειμαι αμεμπτος, ηθελε με αποδειξει διεφθαρμενον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Job 9:21",
      "text": "Και αν ημην αμεμπτος, δεν ηθελον φροντισει περι εμαυτου ηθελον καταφρονησει την ζωην μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "Job 9:22",
      "text": "Εν τουτο ειναι, δια τουτο ειπα, αυτος αφανιζει τον αμεμπτον και τον ασεβη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "Job 9:23",
      "text": "Και αν η μαστιξ αυτου θανατονη ευθυς, γελα ομως εις την δοκιμασιαν των αθωων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "Job 9:24",
      "text": "Η γη παρεδοθη εις τας χειρας του ασεβους αυτος σκεπαζει τα προσωπα των κριτων αυτης αν ουχι αυτος, που και τις ειναι;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "Job 9:25",
      "text": "Αι δε ημεραι μου ειναι ταχυδρομου ταχυτεραι φευγουσι και δεν βλεπουσι καλον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.26",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "Job 9:26",
      "text": "Παρηλθον ως πλοια σπευδοντα ως αετος πετωμενος επι το θηραμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.27",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "Job 9:27",
      "text": "Εαν ειπω, Θελω λησμονησει το παραπονον μου, θελω παραιτησει το πενθος μου και παρηγορηθη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.28",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "Job 9:28",
      "text": "τρομαζω δια πασας τας θλιψεις μου, γνωριζων οτι δεν θελεις με αθωωσει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.29",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 29,
      "referenceLabel": "Job 9:29",
      "text": "Ειμαι ασεβης δια τι λοιπον να κοπιαζω εις ματην;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.30",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 30,
      "referenceLabel": "Job 9:30",
      "text": "Εαν λουσθω εν υδατι χιονος και επιμελως αποκαθαρισω τας χειρας μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.31",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 31,
      "referenceLabel": "Job 9:31",
      "text": "συ ομως θελεις με βυθισει εις τον βορβορον, ωστε και αυτα μου τα ιματια θελουσι με βδελυττεσθαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.32",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 32,
      "referenceLabel": "Job 9:32",
      "text": "Διοτι δεν ειναι ανθρωπος ως εγω, δια να αποκριθω προς αυτον, και να ελθωμεν εις κρισιν ομου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.33",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 33,
      "referenceLabel": "Job 9:33",
      "text": "Δεν υπαρχει μεσιτης μεταξυ ημων, δια να βαλη την χειρα αυτου επ' αμφοτερους ημας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.34",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 34,
      "referenceLabel": "Job 9:34",
      "text": "Ας απομακρυνη απ' εμου την ραβδον αυτου, και ο φοβος αυτου ας μη με εκπληττη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.9.35",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 35,
      "referenceLabel": "Job 9:35",
      "text": "τοτε θελω λαλησει και δεν θελω φοβηθη αυτον διοτι ουτω δεν ειμαι εν εμαυτω.",
      "paragraphStart": false
    }
  ]
}
