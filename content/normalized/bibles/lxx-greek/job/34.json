{
  "chapter": {
    "id": "lxx-greek:job.34",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 34,
    "referenceLabel": "Job 34",
    "summary": "Source text for Job 34 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.34.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 1,
      "referenceLabel": "Job 34:1",
      "text": "Επανελαβε δε ο Ελιου και ειπεν",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.34.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 2,
      "referenceLabel": "Job 34:2",
      "text": "Ακουσατε τους λογους μου, ω σοφοι και δοτε ακροασιν εις εμε, οι νοημονες",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 3,
      "referenceLabel": "Job 34:3",
      "text": "Διοτι το ωτιον δοκιμαζει τους λογους, ο δε ουρανισκος γευεται το φαγητον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 4,
      "referenceLabel": "Job 34:4",
      "text": "Ας εκλεξωμεν εις εαυτους κρισιν ας γνωρισωμεν μεταξυ ημων τι το καλον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 5,
      "referenceLabel": "Job 34:5",
      "text": "Διοτι ο Ιωβ ειπεν, Ειμαι δικαιος και ο Θεος αφηρεσε την κρισιν μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 6,
      "referenceLabel": "Job 34:6",
      "text": "εψευσθην εις την κρισιν μου η πληγη μου ειναι ανιατος, ανευ παραβασεως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 7,
      "referenceLabel": "Job 34:7",
      "text": "Τις ανθρωπος ως ο Ιωβ, οστις καταπινει τον χλευασμον ως υδωρ",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 8,
      "referenceLabel": "Job 34:8",
      "text": "και υπαγει εν συνοδια μετα των εργατων της ανομιας, και περιπατει μετα ανθρωπων ασεβων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 9,
      "referenceLabel": "Job 34:9",
      "text": "Διοτι ειπεν, ουδεν ωφελει τον ανθρωπον το να ευαρεστη εις τον Θεον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 10,
      "referenceLabel": "Job 34:10",
      "text": "Δια τουτο ακουσατε μου, ανδρες συνετοι μη γενοιτο να υπαρχη εις τον Θεον αδικια, και εις τον Παντοδυναμον ανομια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 11,
      "referenceLabel": "Job 34:11",
      "text": "Επειδη κατα το εργον του ανθρωπου θελει αποδωσει εις αυτον, και θελει καμει εκαστον να ευρη κατα την οδον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 12,
      "referenceLabel": "Job 34:12",
      "text": "Ναι, βεβαιως ο Θεος δεν θελει πραξει ασεβως, ουδε θελει διαστρεψει ο Παντοδυναμος την κρισιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 13,
      "referenceLabel": "Job 34:13",
      "text": "Τις κατεστησεν αυτον επιτηρητην της γης; η τις διεταξε πασαν την οικουμενην;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 14,
      "referenceLabel": "Job 34:14",
      "text": "Εαν βαλη την καρδιαν αυτου επι τον ανθρωπον, θελει συρει εις εαυτον το πνευμα αυτου και την πνοην αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 15,
      "referenceLabel": "Job 34:15",
      "text": "πασα σαρξ θελει εκπνευσει ομου, και ο ανθρωπος θελει επιστρεψει εις το χωμα.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 16,
      "referenceLabel": "Job 34:16",
      "text": "Εαν τωρα εχης συνεσιν ακουσον τουτο ακροαθητι της φωνης των λογων μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 17,
      "referenceLabel": "Job 34:17",
      "text": "Μηπως κυβερνα ο μισων την ευθυτητα; και θελεις καταδικασει τον κατ' εξοχην δικαιον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 18,
      "referenceLabel": "Job 34:18",
      "text": "οστις λεγει προς βασιλεα, Εισαι ασεβης, προς αρχοντας, Εισθε κακοι;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 19,
      "referenceLabel": "Job 34:19",
      "text": "Οστις δεν προσωποληπτει εις αρχοντας ουδε αποβλεπει εις τον πλουσιον μαλλον παρα εις τον πτωχον; επειδη παντες ουτοι ειναι εργον των χειρων αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 20,
      "referenceLabel": "Job 34:20",
      "text": "Εν μια στιγμη θελουσιν αποθανει, και το μεσονυκτιον ο λαος θελει ταραχθη και θελει παρελθει και ο ισχυρος θελει αναρπαχθη, ουχι υπο χειρος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 21,
      "referenceLabel": "Job 34:21",
      "text": "Διοτι οι οφθαλμοι αυτου ειναι επι τας οδους του ανθρωπου, Και βλεπει παντα τα βηματα αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 22,
      "referenceLabel": "Job 34:22",
      "text": "Δεν ειναι σκοτος ουδε σκια θανατου, οπου οι εργαται της ανομιας να κρυφθωσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 23,
      "referenceLabel": "Job 34:23",
      "text": "Επειδη δεν θελει αφησει πλεον τον ανθρωπον να ελθη εις κρισιν μετα του Θεου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 24,
      "referenceLabel": "Job 34:24",
      "text": "Θελει συντριψει αναριθμητους ισχυρους και βαλει αλλους αντ' αυτων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 25,
      "referenceLabel": "Job 34:25",
      "text": "διοτι γνωριζει τα εργα αυτων, και ανατρεπει αυτους την νυκτα, και συντριβονται.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.26",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 26,
      "referenceLabel": "Job 34:26",
      "text": "Κτυπα αυτους ως ασεβεις εν τω τοπω των θεατων",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.27",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 27,
      "referenceLabel": "Job 34:27",
      "text": "επειδη εξεκλιναν απ' αυτου και δεν εθεωρησαν ουδεμιαν των οδων αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.28",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 28,
      "referenceLabel": "Job 34:28",
      "text": "και εκαμον να ελθη προς αυτον η κραυγη των πτωχων, και ηκουσε την φωνην των τεθλιμμενων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.29",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 29,
      "referenceLabel": "Job 34:29",
      "text": "Και οταν αυτος διδη ησυχιαν, τις θελει διαταραξει αυτην; και οταν κρυπτη το προσωπον αυτου, τις δυναται να ιδη αυτον; ειτε επι εθνος ειτε επι ανθρωπον ομου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.30",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 30,
      "referenceLabel": "Job 34:30",
      "text": "ωστε να μη βασιλευη υποκριτης, δια να μη παγιδευηται ο λαος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.31",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 31,
      "referenceLabel": "Job 34:31",
      "text": "Βεβαιως πρεπει να λεγη τις προς τον Θεον, Επαθον, δεν θελω πλεον πραξει κακως",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.32",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 32,
      "referenceLabel": "Job 34:32",
      "text": "ο, τι δεν βλεπω, συ διδαξον με εαν επραξα ανομιαν, δεν θελω πραξει πλεον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.33",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 33,
      "referenceLabel": "Job 34:33",
      "text": "Αλλα μηπως θελει γεινει κατα τον στοχασμον σου; ειτε συ αποβαλης ειτε εκλεξης, αυτος θελει ανταποδωσει, και ουχι εγω λεγε λοιπον ο, τι εξευρεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.34",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 34,
      "referenceLabel": "Job 34:34",
      "text": "Ανδρες συνετοι θελουσιν ειπει προς εμε, και ο σοφος ανθρωπος οστις με ακουει,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.35",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 35,
      "referenceLabel": "Job 34:35",
      "text": "Ο Ιωβ δεν ελαλησεν εν γνωσει, και οι λογοι αυτου δεν ησαν μετα συνεσεως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.36",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 36,
      "referenceLabel": "Job 34:36",
      "text": "Η επιθυμια μου ειναι, ο Ιωβ να εξετασθη εως τελους επειδη απεκριθη ως οι ανθρωποι οι ασεβεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.34.37",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 37,
      "referenceLabel": "Job 34:37",
      "text": "Διοτι εις την αμαρτιαν αυτου προσθετει ασεβειαν καυχαται μεταξυ ημων, και πολλαπλασιαζει τους λογους αυτου εναντιον του Θεου.",
      "paragraphStart": false
    }
  ]
}
