{
  "chapter": {
    "id": "lxx-greek:job.36",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 36,
    "referenceLabel": "Job 36",
    "summary": "Source text for Job 36 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.36.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 1,
      "referenceLabel": "Job 36:1",
      "text": "Και ο Ελιου εξηκολουθησε και ειπεν",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.36.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 2,
      "referenceLabel": "Job 36:2",
      "text": "Υπομεινον με ολιγον, και θελω σε διδαξει διοτι εχω ετι λογους υπερ του Θεου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 3,
      "referenceLabel": "Job 36:3",
      "text": "Θελω λαβει τα επιχειρηματα μου μακροθεν, και θελω αποδωσει δικαιοσυνην εις τον Ποιητην μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 4,
      "referenceLabel": "Job 36:4",
      "text": "διοτι οι λογοι μου επ' αληθειας δεν θελουσιν εισθαι ψευδεις πλησιον σου ειναι ο τελειος κατα την γνωσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 5,
      "referenceLabel": "Job 36:5",
      "text": "Ιδου, ο Θεος ειναι ισχυρος, ομως δεν καταφρονει ουδενα ισχυρος εις δυναμιν σοφιας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 6,
      "referenceLabel": "Job 36:6",
      "text": "Δεν θελει ζωοποιησει τον ασεβη εις δε τους πτωχους διδει το δικαιον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 7,
      "referenceLabel": "Job 36:7",
      "text": "Δεν αποσυρει τους οφθαλμους αυτου απο των δικαιων, αλλα και μετα βασιλεων βαλλει αυτους επι θρονου μαλιστα καθιζει αυτους διαπαντος, και ειναι υψωμενοι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 8,
      "referenceLabel": "Job 36:8",
      "text": "Και εαν ηθελον εισθαι δεδεμενοι με δεσμα και πιασθη με σχοινια θλιψεως,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 9,
      "referenceLabel": "Job 36:9",
      "text": "τοτε φανερονει εις αυτους τα εργα αυτων και τας παραβασεις αυτων, οτι υπερηυξησαν,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 10,
      "referenceLabel": "Job 36:10",
      "text": "και ανοιγει το ωτιον αυτων εις διδασκαλιαν, και απο της ανομιας προσταζει να επιστρεψωσιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 11,
      "referenceLabel": "Job 36:11",
      "text": "Εαν υπακουσωσι και δουλευσωσι, θελουσι τελειωσει τας ημερας αυτων εν αγαθοις και τα ετη αυτων εν ευφροσυναις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 12,
      "referenceLabel": "Job 36:12",
      "text": "Αλλ' εαν δεν υπακουσωσι, θελουσι διαπερασθη υπο ρομφαιας και θελουσι τελευτησει εν αγνωσια.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 13,
      "referenceLabel": "Job 36:13",
      "text": "Οι δε υποκριται την καρδιαν επισωρευουσιν οργην δεν θελουσι βοησει οταν δεση αυτους",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 14,
      "referenceLabel": "Job 36:14",
      "text": "αυτοι αποθνησκουσιν εν τη νεοτητι, και η ζωη αυτων τελειονει μεταξυ των ασελγων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 15,
      "referenceLabel": "Job 36:15",
      "text": "Λυτρονει τον τεθλιμμενον εν τη θλιψει αυτου και ανοιγει τα ωτα αυτων εν συμφορα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 16,
      "referenceLabel": "Job 36:16",
      "text": "και ουτως ηθελε σε εκβαλει απο της στενοχωριας εις ευρυχωριαν, οπου δεν υπαρχει στενοχωρια και το παρατιθεμενον επι της τραπεζης σου θελει εισθαι πληρες παχους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 17,
      "referenceLabel": "Job 36:17",
      "text": "Αλλα συ εξεπληρωσας δικην ασεβους δικη και κρισις θελουσι σε καταλαβει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 18,
      "referenceLabel": "Job 36:18",
      "text": "Επειδη υπαρχει θυμος, προσεχε μη σε εξαφανιση δια της προσβολης αυτου τοτε ουδε μεγα λυτρον ηθελε σε λυτρωσει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 19,
      "referenceLabel": "Job 36:19",
      "text": "Θελει αποβλεψει εις τα πλουτη σου, ουτε εις χρυσιον ουτε εις πασαν την ισχυν της δυναμεως;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 20,
      "referenceLabel": "Job 36:20",
      "text": "Μη επιποθει την νυκτα, καθ' ην οι λαοι εκκοπτονται εν τω τοπω αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 21,
      "referenceLabel": "Job 36:21",
      "text": "Προσεχε, μη στραφης προς την ανομιαν διοτι συ προεκρινας τουτο μαλλον παρα την θλιψιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 22,
      "referenceLabel": "Job 36:22",
      "text": "Ιδου, ο Θεος ειναι υψωμενος δια της δυναμεως αυτου τις διδασκει ως αυτος;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 23,
      "referenceLabel": "Job 36:23",
      "text": "Τις διωρισεν εις αυτον την οδον αυτου; η τις δυναται να ειπη, Επραξας ανομιαν;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 24,
      "referenceLabel": "Job 36:24",
      "text": "Ενθυμου να μεγαλυνης το εργον αυτου, το οποιον θεωρουσιν οι ανθρωποι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 25,
      "referenceLabel": "Job 36:25",
      "text": "Πας ανθρωπος βλεπει αυτο ο ανθρωπος θεωρει αυτο μακροθεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.26",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 26,
      "referenceLabel": "Job 36:26",
      "text": "Ιδου, ο Θεος ειναι μεγας και ακατανοητος εις ημας, και ο αριθμος των ετων αυτου ανεξερευνητος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.27",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 27,
      "referenceLabel": "Job 36:27",
      "text": "Οταν ανασυρη τας ρανιδας του υδατος, αυται καταχεουσιν εκ των ατμων αυτου βροχην,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.28",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 28,
      "referenceLabel": "Job 36:28",
      "text": "την οποιαν τα νεφη ραινουσιν αφθονως σταλαζουσιν επι τον ανθρωπον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.29",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 29,
      "referenceLabel": "Job 36:29",
      "text": "Δυναται τις ετι να εννοηση τας εφαπλωσεις των νεφελων, τον κροτον της σκηνης αυτου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.30",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 30,
      "referenceLabel": "Job 36:30",
      "text": "Ιδου, εφαπλονει το φως αυτου επ' αυτην και σκεπαζει τους πυθμενας της θαλασσης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.31",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 31,
      "referenceLabel": "Job 36:31",
      "text": "επειδη δι' αυτων δικαζει τους λαους και διδει τροφην αφθονως.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.32",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 32,
      "referenceLabel": "Job 36:32",
      "text": "Εν ταις παλαμαις αυτου κρυπτει την αστραπην και προσταζει αυτην εις ο, τι εχει να απαντηση.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.36.33",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 33,
      "referenceLabel": "Job 36:33",
      "text": "Παραγγελλει εις αυτην υπερ του φιλου αυτου, κατα δε του ασεβους ετοιμαζει οργην.",
      "paragraphStart": false
    }
  ]
}
