{
  "chapter": {
    "id": "lxx-greek:job.11",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 11,
    "referenceLabel": "Job 11",
    "summary": "Source text for Job 11 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.11.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Job 11:1",
      "text": "Και απεκριθη ο Σωφαρ ο Νααμαθιτης και ειπε",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.11.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Job 11:2",
      "text": "Δεν διδεται αποκρισις εις το πληθος των λογων; και ο πολυλογος θελει δικαιωθη;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.11.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Job 11:3",
      "text": "Αι φλυαριαι σου θελουσιν αποστομωσει τους ανθρωπους; και οταν περιγελας, δεν θελει σε καταισχυνει τις;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.11.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Job 11:4",
      "text": "Διοτι ειπες, Η ομιλια μου ειναι καθαρα, και ειμαι καθαρος ενωπιον σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.11.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Job 11:5",
      "text": "Αλλ' ειθε να ελαλει ο Θεος και να ηνοιγε τα χειλη αυτου εναντιον σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.11.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Job 11:6",
      "text": "Και να σοι εφανερονε τα κρυφια της σοφιας, οτι ειναι διπλασια των οσα γνωριζονται. Εξευρε λοιπον, οτι ο Θεος απαιτει απο σου ολιγωτερον της ανομιας σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.11.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Job 11:7",
      "text": "Δυνασαι να εξιχνιασης τα βαθη του Θεου; δυνασαι να εξιχνιασης τον Παντοδυναμον με εντελειαν;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.11.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Job 11:8",
      "text": "Ταυτα ειναι ως τα υψη του ουρανου τι δυνασαι να καμης; ειναι βαθυτερα του αδου τι δυνασαι να γνωρισης;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.11.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Job 11:9",
      "text": "Το μετρον αυτων ειναι μακροτερον της γης, και πλατυτερον της θαλασσης.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.11.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Job 11:10",
      "text": "Εαν θεληση να χαλαση και να κλειση, η να συναξη, τοτε τις δυναται να εμποδιση αυτον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.11.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Job 11:11",
      "text": "Διοτι αυτος γνωριζει την ματαιοτητα των ανθρωπων, και βλεπει την ασεβειαν και δεν θελει εξετασει;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.11.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Job 11:12",
      "text": "Ο δε ματαιος ανθρωπος υπερηφανευεται, και γενναται ο ανθρωπος αγριον οναριον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.11.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Job 11:13",
      "text": "Εαν συ ετοιμασης την καρδιαν σου και εκτεινης τας χειρας σου προς αυτον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.11.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Job 11:14",
      "text": "εαν την ανομιαν, την εν χερσι σου, απομακρυνης και δεν αφινης να κατοικηση ασεβεια εν ταις σκηναις σου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.11.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Job 11:15",
      "text": "τοτε βεβαιως θελεις υψωσει το προσωπον σου ακηλιδωτον μαλιστα θελεις εισθαι σταθερος και δεν θελεις φοβεισθαι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.11.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Job 11:16",
      "text": "Διοτι συ θελεις λησμονησει την θλιψιν θελεις ενθυμηθη αυτην ως υδατα διαρρευσαντα",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.11.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Job 11:17",
      "text": "και ο καιρος σου θελει ανατειλει λαμπροτερος της μεσημβριας και εαν επελθη σκοτος επι σε, παλιν θελεις γεινει ως η αυγη",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.11.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Job 11:18",
      "text": "και θελεις εισθαι ασφαλης, διοτι υπαρχει ελπις εις σε ναι, θελεις σκαπτει δια την σκηνην σου και θελεις κοιμασθαι εν ασφαλεια",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.11.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Job 11:19",
      "text": "θελεις πλαγιαζει, και ουδεις θελει σε τρομαζει και πολλοι θελουσιν ικετευει το προσωπον σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.11.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Job 11:20",
      "text": "Των δε ασεβων οι οφθαλμοι θελουσι μαρανθη, και καταφυγιον θελει λειψει απ' αυτων, και η ελπις αυτων θελει εισθαι να εκπνευσωσι.",
      "paragraphStart": false
    }
  ]
}
