{
  "chapter": {
    "id": "lxx-greek:job.10",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 10,
    "referenceLabel": "Job 10",
    "summary": "Source text for Job 10 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.10.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Job 10:1",
      "text": "Η ψυχη μου εβαρυνθη την ζωην μου θελω παραδοθη εις το παραπονον μου θελω λαλησει εν τη πικρια της ψυχης μου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.10.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Job 10:2",
      "text": "Θελω ειπει προς τον Θεον, μη με καταδικασης δειξον μοι δια τι με δικαζεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Job 10:3",
      "text": "Ειναι καλον εις σε να καταθλιβης, να καταφρονης το εργον των χειρων σου και να ευοδονης την βουλην των ασεβων;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Job 10:4",
      "text": "Σαρκος οφθαλμους εχεις; η βλεπεις καθως βλεπει ανθρωπος;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Job 10:5",
      "text": "Ανθρωπινος ειναι ο βιος σου; η τα ετη σου ως ημεραι ανθρωπου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Job 10:6",
      "text": "ωστε αναζητεις την ανομιαν μου και ανερευνας την αμαρτιαν μου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Job 10:7",
      "text": "Ενω εξευρεις οτι δεν ησεβησα και δεν υπαρχει ο ελευθερων εκ των χειρων σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Job 10:8",
      "text": "Αι χειρες σου με εμορφωσαν και με επλασαν ολον κυκλω και με καταστρεφεις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Job 10:9",
      "text": "Ενθυμηθητι, δεομαι, οτι ως πηλον με εκαμες και εις χωμα θελεις με επιστρεψει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Job 10:10",
      "text": "Δεν με ημελξας ως γαλα και με επηξας ως τυρον;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Job 10:11",
      "text": "Δερμα και σαρκα με ενεδυσας και με οστα και νευρα με περιεφραξας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Job 10:12",
      "text": "Ζωην και ελεος εχαρισας εις εμε, και η επισκεψις σου εφυλαξε το πνευμα μου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Job 10:13",
      "text": "ταυτα ομως εκρυπτες εν τη καρδια σου εξευρω οτι τουτο ητο μετα σου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Job 10:14",
      "text": "Εαν αμαρτησω, με παραφυλαττεις, και απο της ανομιας μου δεν θελεις με αθωωσει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Job 10:15",
      "text": "Εαν ασεβησω, ουαι εις εμε και εαν ημαι δικαιος, δεν δυναμαι να σηκωσω την κεφαλην μου ειμαι πληρης ατιμιας ιδε λοιπον την θλιψιν μου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Job 10:16",
      "text": "διοτι αυξανει. Με κυνηγεις ως αγριος λεων και επιστρεφων δεικνυεσαι θαυμαστος κατ' εμου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Job 10:17",
      "text": "Ανανεονεις τους μαρτυρας σου εναντιον μου, και πληθυνεις την οργην σου κατ' εμου αλλαγαι στρατευματος γινονται επ' εμε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Job 10:18",
      "text": "Δια τι λοιπον με εξηγαγες εκ της μητρας; ειθε να εξεπνεον, και οφθαλμος να μη με εβλεπεν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Job 10:19",
      "text": "Ηθελον εισθαι ως μη υπαρξας ηθελον φερθη εκ της μητρας εις τον ταφον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Job 10:20",
      "text": "Αι ημεραι μου δεν ειναι ολιγαι; παυσον λοιπον, και αφες με, δια να αναλαβω ολιγον,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Job 10:21",
      "text": "πριν υπαγω οθεν δεν θελω επιστρεψει, εις γην σκοτους και σκιας θανατου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.10.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Job 10:22",
      "text": "γην γνοφεραν, ως το σκοτος της σκιας του θανατου, οπου ταξις δεν ειναι, και το φως ειναι ως το σκοτος.",
      "paragraphStart": false
    }
  ]
}
