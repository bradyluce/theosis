{
  "chapter": {
    "id": "lxx-greek:job.32",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 32,
    "referenceLabel": "Job 32",
    "summary": "Source text for Job 32 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.32.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 1,
      "referenceLabel": "Job 32:1",
      "text": "Επαυσαν δε και οι τρεις ουτοι ανθρωποι αποκρινομενοι προς τον Ιωβ, διοτι ητο δικαιος εις τους οφθαλμους αυτου.",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.32.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 2,
      "referenceLabel": "Job 32:2",
      "text": "Τοτε εξηφθη ο θυμος του Ελιου, υιου του Βαραχιηλ του Βουζιτου, εκ της συγγενειας του Αραμ κατα του Ιωβ εξηφθη ο θυμος αυτου, διοτι εδικαιονεν εαυτον μαλλον παρα τον Θεον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 3,
      "referenceLabel": "Job 32:3",
      "text": "Και κατα των τριων αυτου φιλων εξηφθη ο θυμος αυτου, διοτι δεν ευρηκαν αποκρισιν και κατεδικασαν τον Ιωβ.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 4,
      "referenceLabel": "Job 32:4",
      "text": "Ο δε Ελιου περιεμενε να λαληση προς τον Ιωβ, διοτι εκεινοι ησαν γεροντοτεροι αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 5,
      "referenceLabel": "Job 32:5",
      "text": "Οτε δε ο Ελιου ειδεν, οτι δεν ητο αποκρισις εν τω στοματι των τριων ανδρων, εξηφθη ο θυμος αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 6,
      "referenceLabel": "Job 32:6",
      "text": "και απεκριθη ο Ελιου ο υιος του Βαραχιηλ του Βουζιτου και ειπεν Εγω ειμαι νεος την ηλικιαν, και σεις γεροντες δια τουτο εφοβηθην και συνεσταλην να σας φανερωσω την γνωμην μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 7,
      "referenceLabel": "Job 32:7",
      "text": "Εγω ειπα, Αι ημεραι ας λαλησωσι και το πληθος των ετων ας διδαξη, σοφιαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 8,
      "referenceLabel": "Job 32:8",
      "text": "Βεβαιως ειναι πνευμα εν τω ανθρωπω η εμπνευσις ομως του Παντοδυναμου συνετιζει αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 9,
      "referenceLabel": "Job 32:9",
      "text": "Οι μεγαλητεροι δεν ειναι παντοτε σοφοι ουτε οι γεροντες νοουσι κρισιν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 10,
      "referenceLabel": "Job 32:10",
      "text": "Δια τουτο ειπα, Ακουσατε μου θελω φανερωσει και εγω την γνωμην μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 11,
      "referenceLabel": "Job 32:11",
      "text": "Ιδου, επροσμενα τους λογους σας ηκροασθην τα επιχειρηματα σας, εωσου εξετασητε τους λογους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 12,
      "referenceLabel": "Job 32:12",
      "text": "Και σας παρετηρουν, και ιδου, ουδεις εξ υμων ηδυνηθη να καταπειση τον Ιωβ, αποκρινομενος εις τους λογους αυτου",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 13,
      "referenceLabel": "Job 32:13",
      "text": "δια να μη ειπητε, Ημεις ευρηκαμεν σοφιαν. Ο Θεος θελει καταβαλει αυτον, ουχι ανθρωπος.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 14,
      "referenceLabel": "Job 32:14",
      "text": "Εκεινος δε δεν διηυθυνε λογους προς εμε και δεν θελω αποκριθη προς αυτον κατα τας ομιλιας σας.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 15,
      "referenceLabel": "Job 32:15",
      "text": "Εκεινοι ετρομαξαν, δεν απεκριθησαν πλεον εχασαν τους λογους αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 16,
      "referenceLabel": "Job 32:16",
      "text": "Και περιεμενον, επειδη δεν ελαλουν αλλ' ισταντο δεν απεκρινοντο πλεον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 17,
      "referenceLabel": "Job 32:17",
      "text": "Ας αποκριθω και εγω το μερος μου ας φανερωσω και εγω την γνωμην μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 18,
      "referenceLabel": "Job 32:18",
      "text": "Διοτι ειμαι πληρης λογων το πνευμα εντος μου με αναγκαζει.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 19,
      "referenceLabel": "Job 32:19",
      "text": "Ιδου, η κοιλια μου ειναι ως οινος οστις δεν ηνοιχθη ειναι ετοιμη να σπαση, ως ασκοι γλευκους.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 20,
      "referenceLabel": "Job 32:20",
      "text": "Θελω λαλησει δια να αναπνευσω θελω ανοιξει τα χειλη μου και αποκριθη.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 21,
      "referenceLabel": "Job 32:21",
      "text": "Μη γενοιτο να γεινω προσωποληπτης, μηδε να κολακευσω ανθρωπον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.32.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 22,
      "referenceLabel": "Job 32:22",
      "text": "Διοτι δεν εξευρω να κολακευω ο Ποιητης μου ηθελε με αναρπασει ευθυς.",
      "paragraphStart": false
    }
  ]
}
