{
  "chapter": {
    "id": "lxx-greek:job.19",
    "translationId": "lxx-greek",
    "bookSlug": "job",
    "chapterNumber": 19,
    "referenceLabel": "Job 19",
    "summary": "Source text for Job 19 in Septuagint Greek."
  },
  "verses": [
    {
      "id": "lxx-greek:job.19.1",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Job 19:1",
      "text": "Και απεκριθη ο Ιωβ και ειπεν",
      "paragraphStart": true
    },
    {
      "id": "lxx-greek:job.19.2",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Job 19:2",
      "text": "Εως ποτε θελετε θλιβει την ψυχην μου, και θελετε με κατασυντριβει με λογους;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.3",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Job 19:3",
      "text": "Δεκακις ηδη με ωνειδισατε δεν αισχυνεσθε να σκληρυνησθε εναντιον μου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.4",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Job 19:4",
      "text": "Και εαν τωοντι εσφαλα, το σφαλμα μου μενει εν εμοι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.5",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Job 19:5",
      "text": "Αλλ' εαν θελητε εξαπαντος να μεγαλυνθητε εναντιον μου, και να ριπτητε κατ' εμου το ονειδος μου,",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.6",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Job 19:6",
      "text": "μαθετε τωρα οτι ο Θεος με κατεστρεψε, και με περιεκυκλωσε με το δικτυον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.7",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Job 19:7",
      "text": "Ιδου, φωναζω, Αδικια αλλα δεν εισακουομαι επικαλουμαι, αλλ' ουδεμια κρισις.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.8",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Job 19:8",
      "text": "Εφραξε την οδον μου, και δεν δυναμαι να περασω, και εθεσε σκοτος εις τας τριβους μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.9",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Job 19:9",
      "text": "Με εξεδυσε την δοξαν μου, και αφηρεσε τον στεφανον της κεφαλης μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.10",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Job 19:10",
      "text": "Με ηφανισε πανταχοθεν, και χανομαι και εξερριζωσε την ελπιδα μου ως δενδρον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.11",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Job 19:11",
      "text": "Και εξηψε κατ' εμου τον θυμον αυτου, και με στοχαζεται ως εχθρον αυτου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.12",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Job 19:12",
      "text": "Τα ταγματα αυτου ηλθον ομου και ητοιμασαν την οδον αυτων εναντιον μου, και εστρατοπεδευσαν περιξ της σκηνης μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.13",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Job 19:13",
      "text": "Απεμακρυνεν απ' εμου τους αδελφους μου, και ηλλοτριωθησαν ολως απ' εμου οι γνωριμοι μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.14",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Job 19:14",
      "text": "Οι πλησιον μου με αφηκαν, και οι γνωστοι μου με ελησμονησαν.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.15",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Job 19:15",
      "text": "Οι κατοικουντες εν τω οικω μου και αι θεραπαιναι μου με στοχαζονται ως ξενον ξενος κατεσταθην εις τους οφθαλμους αυτων.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.16",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "Job 19:16",
      "text": "Καλω τον υπηρετην μου, και δεν αποκρινεται με το στομα μου ικετευσα αυτον.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.17",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "Job 19:17",
      "text": "Η πνοη μου εγεινε ξενη εις την γυναικα μου, και αι παρακλησεις μου εις τα τεκνα της κοιλιας μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.18",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "Job 19:18",
      "text": "Και αυτα τα παιδαρια με κατεφρονησαν εσηκωθην, και ελαλησαν εναντιον μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.19",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "Job 19:19",
      "text": "Παντες οι μυστικοι φιλοι μου με εβδελυχθησαν και εκεινοι, τους οποιους ηγαπησα, εστραφησαν εναντιον μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.20",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "Job 19:20",
      "text": "Τα οστα μου εκολληθησαν εις το δερμα μου και εις την σαρκα μου και διεσωθην με το δερμα των οδοντων μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.21",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "Job 19:21",
      "text": "Ελεησατε με, ελεησατε με, σεις φιλοι μου διοτι χειρ Θεου με επληγωσε.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.22",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 22,
      "referenceLabel": "Job 19:22",
      "text": "Δια τι με κατατρεχετε ως ο Θεος, και δεν εχορτασθητε απο των σαρκων μου;",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.23",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 23,
      "referenceLabel": "Job 19:23",
      "text": "Ω και να εγραφοντο οι λογοι μου να ενετυπουντο εν βιβλιω",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.24",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 24,
      "referenceLabel": "Job 19:24",
      "text": "να ενεχαραττοντο επι βραχον δια σιδηρας γραφιδος και μολυβδου διαπαντος",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.25",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 25,
      "referenceLabel": "Job 19:25",
      "text": "Διοτι εξευρω οτι ζη ο Λυτρωτης μου, και θελει εγερθη εν τοις εσχατοις καιροις επι της γης",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.26",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 26,
      "referenceLabel": "Job 19:26",
      "text": "και αφου μετα το δερμα μου το σωμα τουτο φθαρη, παλιν με την σαρκα μου θελω ιδη τον Θεον",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.27",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 27,
      "referenceLabel": "Job 19:27",
      "text": "τον οποιον αυτος εγω θελω ιδει, και θελουσι θεωρησει οι οφθαλμοι μου, και ουχι αλλος οι νεφροι μου κατατηκονται εν τω κολπω μου.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.28",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 28,
      "referenceLabel": "Job 19:28",
      "text": "Αλλα σεις επρεπε να ειπητε, Δια τι κατατρεχομεν αυτον; επειδη η ριζα του πραγματος ευρισκεται εν εμοι.",
      "paragraphStart": false
    },
    {
      "id": "lxx-greek:job.19.29",
      "translationId": "lxx-greek",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 29,
      "referenceLabel": "Job 19:29",
      "text": "Φοβηθητε την ρομφαιαν διοτι η ρομφαια ειναι ο εκδικητης των ανομιων, δια να γνωρισητε οτι υπαρχει κρισις.",
      "paragraphStart": false
    }
  ]
}
