# EAS Build archive ignore list.
#
# IMPORTANT: when this file exists, EAS uses it INSTEAD of .gitignore to
# decide what to upload. So it must (a) re-exclude the usual build junk
# that .gitignore handled, AND (b) strip the backend/content payload the
# mobile build doesn't need. EAS archives the git ROOT (not apps/mobile)
# because the mobile app depends on the workspace package
# @theosis/core via file:../../packages/core — so apps/ and packages/
# must stay; everything backend-only can go.

# --- build junk (mirrors .gitignore; required since .easignore overrides it) ---
node_modules/
**/node_modules/
.expo/
**/.expo/
.next/
out/
build/
coverage/
*.log
*.tsbuildinfo
.DS_Store
.vercel
.env*
!.env.example

# --- backend + content payload not needed to build the mobile app ---
# This is the bulk of the 1.1 GB archive (content/ alone is ~41k files).
# IMPORTANT: anchor every entry with a leading "/" so it matches ONLY the
# repo-root backend dir, never a same-named dir nested under packages/ or
# apps/. An UNANCHORED "src/" also strips packages/core/src/ — the workspace
# package the mobile app imports as @theosis/core — and the EAS bundle then
# fails with "main module field could not be resolved (.../@theosis/core/src/index.ts)".
/content/
/corpus/
/docs/
/public/
/scripts/
/src/
/drizzle/
/.claude/
/.agents/

# --- native dirs are regenerated by prebuild on EAS; don't upload local copies ---
apps/mobile/ios/
apps/mobile/android/
